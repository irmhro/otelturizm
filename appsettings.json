{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "dbbaglan": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "SqlServer",
    "RunMigrationsOnStartup": false
  },
  "App": {
    "PublicBaseUrl": "https://otelturizm.com"
  },
  "Email": {
    "DisableCertificateRevocationCheck": true,
    "SmtpAllowInvalidCertificate": false
  },
  "AllowedHosts": "*",
  "Growth": {
    "KillSwitchAll": false,
    "Flags": {
      "otel_detail_cross_sell": { "Percent": 100 },
      "listing_contextual_boost": { "Percent": 100 }
    }
  },
  "DeadLinks": {
    "Map": {
      "/legacy-oteller": "/oteller"
    }
  },
  "Archive": {
    "Reservations": {
      "Enabled": false
    }
  }
}
