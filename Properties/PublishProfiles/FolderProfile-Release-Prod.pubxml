<?xml version="1.0" encoding="utf-8"?>
<!--
  Üretim klasör yayımlama (secret yok).
  CLI: dotnet publish -c Release /p:PublishProfile=FolderProfile-Release-Prod
  Çıktı: D:\otelturizm\bin\Release\net10.0\  (tam site: wwwroot, Views, dll, web.config)
  Canlıya: bu klasörün tamamını (içeriği) sunucu site köküne kopyalayın; yarım bırakmayın.
  DeleteExistingFiles=true → önceki yayımdan kalan silinmiş dosyalar sunucuda kalıp yeni sürümü bozmaz.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishUrl>D:\otelturizm\bin\Release\net10.0\</PublishUrl>
    <PublishDir>bin\Release\net10.0\</PublishDir>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <TargetFramework>net10.0</TargetFramework>
    <SelfContained>false</SelfContained>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <RestorePackagesWithLockFile>false</RestorePackagesWithLockFile>
    <DeleteExistingFiles>true</DeleteExistingFiles>
  </PropertyGroup>
</Project>
