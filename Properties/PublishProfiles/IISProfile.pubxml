<?xml version="1.0" encoding="utf-8"?>
<!--
  Web Deploy (WMSVC): pakette olmayan dosyalari hedeften silerek tam senkron.
  Sunucuda sadece canlida olusan klasorler (yuklemeler, log) silinmesin diye MsDeploySkipRules eklendi.
  VS: Yayımla > IISProfile secildiginde bu ayarlar otomatik kullanilir (dosya repoda kayitlidir).

  SQL Server baglantisi (Sunucu Gezgini): Properties\vs-sql-connection.template.txt
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>otelturizm.com</SiteUrlToLaunchAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>73dde98f-248c-2ee3-5345-73111022b79c</ProjectGuid>
    <SelfContained>false</SelfContained>
    <MSDeployServiceURL>185.111.244.246</MSDeployServiceURL>
    <DeployIisAppPath>otelturizm.com</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <!-- true iken pakette olmayan sunucu dosyalari silinmez; yarim / eski surum riski -->
    <SkipExtraFilesOnServer>false</SkipExtraFilesOnServer>
    <!-- Hedefte paket disi dosyalari temizle (SkipExtraFilesOnServer=false ile birlikte tam yukleme) -->
    <RemoveAdditionalFilesFromDestination>true</RemoveAdditionalFilesFromDestination>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>true</EnableMSDeployBackup>
    <EnableMsDeployAppOffline>true</EnableMsDeployAppOffline>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <UserName>administrator</UserName>
    <_SavePWD>true</_SavePWD>
    <_TargetId>IISWebDeploy</_TargetId>
  </PropertyGroup>
  <ItemGroup>
    <MsDeploySkipRules Include="OtelturizmSkipDelete_WwwrootUploads">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>wwwroot\\uploads</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="OtelturizmSkipDelete_AppDataLogs">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>App_Data\\logs</AbsolutePath>
    </MsDeploySkipRules>
  </ItemGroup>
</Project>
