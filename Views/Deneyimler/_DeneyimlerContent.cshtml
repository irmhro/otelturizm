@model otelturizmnew.Models.Deneyimler.DeneyimlerPageViewModel

<div class="dxp-page" data-dxp-page>
    <div class="dxp-page__glow" aria-hidden="true"></div>

    <section class="dxp-hero" aria-labelledby="dxp-hero-title">
        <div class="dxp-shell dxp-hero__grid">
            <div class="dxp-hero__copy">
                <p class="dxp-hero__eyebrow"><i class="fas fa-star" aria-hidden="true"></i> @Model.HeroEyebrow</p>
                <h1 id="dxp-hero-title" class="dxp-hero__title">@Model.HeroTitle</h1>
                <p class="dxp-hero__lead">@Model.HeroLead</p>
                <div class="dxp-hero__actions">
                    <a href="#dxp-koleksiyon" class="dxp-btn dxp-btn--primary">Koleksiyonları keşfet <i class="fas fa-arrow-down" aria-hidden="true"></i></a>
                    <a href="/oteller" class="dxp-btn dxp-btn--ghost">Otelleri listele</a>
                </div>
                <dl class="dxp-stats" aria-label="Deneyim özeti">
                    @foreach (var stat in Model.Stats)
                    {
                        <div class="dxp-stat">
                            <dt class="dxp-stat__value">@stat.Value</dt>
                            <dd class="dxp-stat__label">@stat.Label</dd>
                        </div>
                    }
                </dl>
            </div>
            <div class="dxp-hero__mosaic" aria-hidden="true">
                @for (var i = 0; i < Math.Min(3, Model.Featured.Count); i++)
                {
                    var card = Model.Featured[i];
                    <article class="dxp-mosaic-card dxp-mosaic-card--@(i + 1)" style="--dxp-accent:@card.Accent; --dxp-bg:@card.Gradient;">
                        @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                        {
                            <img class="dxp-mosaic-card__img" src="@card.ImageUrl" alt="" loading="lazy" decoding="async" />
                        }
                        <div class="dxp-mosaic-card__overlay">
                            <span class="dxp-mosaic-card__stamp">@card.Stamp</span>
                            <strong>@card.Title</strong>
                            <small>@card.Location · @card.Duration</small>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    @if (Model.LiveTicker.Count > 0)
    {
        <div class="dxp-ticker" aria-label="Canlı arama trendleri">
            <div class="dxp-ticker__track" data-dxp-ticker>
                @foreach (var item in Model.LiveTicker.Concat(Model.LiveTicker))
                {
                    <span class="dxp-ticker__item">@item</span>
                }
            </div>
        </div>
    }

    <div class="dxp-shell">
        <nav class="dxp-category-nav" aria-label="Deneyim kategorileri" data-dxp-filter-nav>
            @foreach (var cat in Model.Categories)
            {
                <button type="button"
                        class="dxp-category-chip @(cat.Key == "all" ? "is-active" : string.Empty)"
                        data-dxp-category="@cat.Key">
                    @if (!string.IsNullOrWhiteSpace(cat.Emoji))
                    {
                        <span class="dxp-category-chip__emoji" aria-hidden="true">@cat.Emoji</span>
                    }
                    <span>@cat.Label</span>
                </button>
            }
        </nav>

        @if (Model.MoodPicks.Count > 0)
        {
            <section class="dxp-section dxp-section--moods" aria-labelledby="dxp-mood-title">
                <div class="dxp-section__head">
                    <div>
                        <p class="dxp-section__eyebrow">Ruh halin ne?</p>
                        <h2 id="dxp-mood-title" class="dxp-section__title">Bugün nasıl hissediyorsun?</h2>
                    </div>
                </div>
                <div class="dxp-mood-grid" data-dxp-mood-grid>
                    @foreach (var mood in Model.MoodPicks)
                    {
                        <button type="button"
                                class="dxp-mood-card"
                                data-dxp-mood="@mood.CategoryKey"
                                aria-pressed="false">
                            <span class="dxp-mood-card__emoji" aria-hidden="true">@mood.Emoji</span>
                            <strong>@mood.Label</strong>
                            <small>@mood.Hint</small>
                        </button>
                    }
                </div>
            </section>
        }

        @if (Model.Spotlight != null)
        {
            var spot = Model.Spotlight;
            <section class="dxp-spotlight" aria-labelledby="dxp-spotlight-title">
                <a class="dxp-spotlight__link" href="@spot.LinkUrl" style="--dxp-accent:@spot.Accent;">
                    @if (!string.IsNullOrWhiteSpace(spot.ImageUrl))
                    {
                        <div class="dxp-spotlight__media">
                            <img src="@spot.ImageUrl" alt="" loading="lazy" decoding="async" />
                        </div>
                    }
                    <div class="dxp-spotlight__badge"><span aria-hidden="true">@spot.Emoji</span> @spot.Badge</div>
                    <div class="dxp-spotlight__body">
                        <h2 id="dxp-spotlight-title" class="dxp-spotlight__title">@spot.Title</h2>
                        <p class="dxp-spotlight__subtitle">@spot.Subtitle</p>
                        <div class="dxp-spotlight__meta">
                            <span><i class="fas fa-location-dot" aria-hidden="true"></i> @spot.Location</span>
                            <span><i class="fas fa-clock" aria-hidden="true"></i> @spot.Duration</span>
                        </div>
                        <span class="dxp-spotlight__cta">Rotayı keşfet <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
                    </div>
                </a>
            </section>
        }

        @if (Model.SmartRoutes.Count > 0)
        {
            <section class="dxp-section dxp-section--routes" aria-labelledby="dxp-routes-title">
                <div class="dxp-section__head">
                    <div>
                        <p class="dxp-section__eyebrow">Akıllı Rota</p>
                        <h2 id="dxp-routes-title" class="dxp-section__title">Etiketle otel bul</h2>
                    </div>
                    <span class="dxp-section__badge"><i class="fas fa-route" aria-hidden="true"></i> Anasayfa ile aynı sistem</span>
                </div>
                <div class="dxp-routes-rail" tabindex="0" aria-label="Akıllı rota etiketleri">
                    @foreach (var route in Model.SmartRoutes)
                    {
                        <a class="dxp-route-pill dxp-route-pill--@route.ColorClass" href="@route.LinkUrl">
                            <span class="dxp-route-pill__dot" aria-hidden="true"></span>
                            @route.Hashtag
                        </a>
                    }
                </div>
            </section>
        }

        @if (Model.CampaignHighlights.Count > 0)
        {
            <section class="dxp-campaigns" aria-labelledby="dxp-campaigns-title">
                <div class="dxp-campaigns__head">
                    <h2 id="dxp-campaigns-title" class="dxp-campaigns__title"><i class="fas fa-tags" aria-hidden="true"></i> Kampanyalar</h2>
                </div>
                <div class="dxp-campaigns__rail">
                    @foreach (var camp in Model.CampaignHighlights)
                    {
                        <a class="dxp-campaign-card" href="@camp.LinkUrl">
                            @if (!string.IsNullOrWhiteSpace(camp.ImageUrl))
                            {
                                <span class="dxp-campaign-card__media">
                                    <img src="@camp.ImageUrl" alt="" loading="lazy" decoding="async" />
                                </span>
                            }
                            <span class="dxp-campaign-card__tag">@camp.Tag</span>
                            <strong>@camp.Title</strong>
                            <span class="dxp-campaign-card__go">İncele <i class="fas fa-chevron-right" aria-hidden="true"></i></span>
                        </a>
                    }
                </div>
            </section>
        }

        <section class="dxp-section" id="dxp-one-cikan" aria-labelledby="dxp-featured-title">
            <div class="dxp-section__head">
                <div>
                    <p class="dxp-section__eyebrow">Öne çıkanlar</p>
                    <h2 id="dxp-featured-title" class="dxp-section__title">Editörün seçtiği anlar</h2>
                </div>
                <span class="dxp-section__badge"><i class="fas fa-certificate" aria-hidden="true"></i> Pasaport damgası</span>
            </div>
            <div class="dxp-bento" data-dxp-grid>
                @foreach (var card in Model.Featured)
                {
                    <article class="dxp-card dxp-card--featured @(card.IsWide ? "dxp-card--wide" : string.Empty)"
                             data-dxp-category="@card.CategoryKey"
                             style="--dxp-accent:@card.Accent; --dxp-bg:@card.Gradient;">
                        <a class="dxp-card__link" href="@card.LinkUrl">
                            <div class="dxp-card__visual">
                                @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                                {
                                    <img class="dxp-card__img" src="@card.ImageUrl" alt="@card.Title" loading="lazy" decoding="async" />
                                }
                                <div class="dxp-card__visual-overlay">
                                    <span class="dxp-card__stamp">@card.Stamp</span>
                                    @if (!string.IsNullOrWhiteSpace(card.Mood))
                                    {
                                        <span class="dxp-card__mood">@card.Mood</span>
                                    }
                                </div>
                            </div>
                            <div class="dxp-card__body">
                                <h3 class="dxp-card__title">@card.Title</h3>
                                <p class="dxp-card__subtitle">@card.Subtitle</p>
                                <div class="dxp-card__meta">
                                    <span><i class="fas fa-location-dot" aria-hidden="true"></i> @card.Location</span>
                                    <span><i class="fas fa-clock" aria-hidden="true"></i> @card.Duration</span>
                                </div>
                                <span class="dxp-card__cta">Rotayı gör <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
                            </div>
                        </a>
                    </article>
                }
            </div>
        </section>

        <section class="dxp-section dxp-section--stories" aria-labelledby="dxp-stories-title">
            <div class="dxp-section__head">
                <div>
                    <p class="dxp-section__eyebrow">Misafir anları</p>
                    <h2 id="dxp-stories-title" class="dxp-section__title">Kısa hikâyeler</h2>
                </div>
            </div>
            <div class="dxp-stories-rail" tabindex="0" aria-label="Misafir hikâyeleri">
                @foreach (var story in Model.Stories)
                {
                    <blockquote class="dxp-story" style="--dxp-accent:@story.Accent;">
                        <p class="dxp-story__time">@story.Title</p>
                        <p class="dxp-story__quote">“@story.Quote”</p>
                        <footer class="dxp-story__foot">
                            <strong>@story.Author</strong>
                            <span>@story.Location</span>
                        </footer>
                    </blockquote>
                }
            </div>
        </section>

        <section class="dxp-section" id="dxp-koleksiyon" aria-labelledby="dxp-collection-title">
            <div class="dxp-section__head">
                <div>
                    <p class="dxp-section__eyebrow">Koleksiyonlar</p>
                    <h2 id="dxp-collection-title" class="dxp-section__title">Temaya göre rotalar</h2>
                </div>
            </div>
            <div class="dxp-collection-grid" data-dxp-grid>
                @foreach (var card in Model.Collections)
                {
                    <article class="dxp-card dxp-card--collection"
                             data-dxp-category="@card.CategoryKey"
                             style="--dxp-accent:@card.Accent; --dxp-bg:@card.Gradient;">
                        <a class="dxp-card__link" href="@card.LinkUrl">
                            <div class="dxp-card__visual">
                                @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                                {
                                    <img class="dxp-card__img" src="@card.ImageUrl" alt="@card.Title" loading="lazy" decoding="async" />
                                }
                                <div class="dxp-card__visual-overlay">
                                    <span class="dxp-card__stamp dxp-card__stamp--mini">@card.Stamp</span>
                                </div>
                            </div>
                            <div class="dxp-card__body">
                                <h3 class="dxp-card__title">@card.Title</h3>
                                <p class="dxp-card__subtitle">@card.Subtitle</p>
                                <div class="dxp-card__meta">
                                    <span><i class="fas fa-location-dot" aria-hidden="true"></i> @card.Location</span>
                                    <span><i class="fas fa-clock" aria-hidden="true"></i> @card.Duration</span>
                                </div>
                            </div>
                        </a>
                    </article>
                }
            </div>
            <p class="dxp-empty" data-dxp-empty hidden>
                <i class="fas fa-compass" aria-hidden="true"></i>
                Bu kategoride henüz rota yok. Başka bir ruh hali seçin veya tümünü görüntüleyin.
            </p>
        </section>

        <section class="dxp-section dxp-section--journey" aria-labelledby="dxp-journey-title">
            <div class="dxp-journey">
                <div class="dxp-journey__copy">
                    <p class="dxp-section__eyebrow">Nasıl çalışır?</p>
                    <h2 id="dxp-journey-title" class="dxp-section__title">3 adımda deneyim planı</h2>
                    <p class="dxp-journey__lead">Rezervasyon akışınızı bozmadan, konaklamanızla uyumlu deneyim önerileri ve Akıllı Rota etiketleriyle otel keşfi.</p>
                </div>
                <ol class="dxp-journey__steps">
                    @foreach (var step in Model.JourneySteps)
                    {
                        <li class="dxp-journey-step">
                            <span class="dxp-journey-step__icon" aria-hidden="true"><i class="fas @step.Icon"></i></span>
                            <div>
                                <span class="dxp-journey-step__num">@step.Step</span>
                                <strong>@step.Title</strong>
                                <p>@step.Text</p>
                            </div>
                        </li>
                    }
                </ol>
            </div>
        </section>

        <aside class="dxp-cta" aria-label="Deneyim daveti">
            <div class="dxp-cta__inner">
                <div>
                    <h2 class="dxp-cta__title">İlk rotanızı birlikte kuralım</h2>
                    <p class="dxp-cta__text">Akıllı Rota etiketlerinden birini seçin veya koleksiyonlardan ilham alarak otel aramanıza başlayın.</p>
                </div>
                <div class="dxp-cta__actions">
                    <a href="/oteller" class="dxp-btn dxp-btn--light">Otelleri keşfet</a>
                    <a href="/kampanyalar" class="dxp-btn dxp-btn--outline-light">Kampanyalar</a>
                </div>
            </div>
        </aside>
    </div>
</div>
