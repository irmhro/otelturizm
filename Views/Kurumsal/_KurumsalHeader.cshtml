@using System.Security.Claims
@using otelturizmnew.Constants
@{
    var corporateAccountType = User.FindFirstValue(AuthClaimTypes.AccountType) ?? string.Empty;
    var corporateAuthenticated = User.Identity?.IsAuthenticated == true;
    var corporatePanelUrl = corporateAccountType.ToLowerInvariant() switch
    {
        "partner" => "/panel/partner",
        "firma" => "/panel/firma",
        "admin" => "/admin/dashboard",
        "sales" => "/panel/satis",
        _ => "/panel/user"
    };
    var corporatePanelLabel = corporateAccountType.ToLowerInvariant() switch
    {
        "partner" => "Partner Paneli",
        "firma" => "Firma Paneli",
        "admin" => "Admin Paneli",
        "sales" => "Satış Paneli",
        _ => "Hesabım"
    };
}

<header class="site-header corporate-header" id="corporateHeader">
    <div class="top-utility-bar corporate-utility-bar">
        <div class="utility-container">
            <div class="utility-left">
                <span><i class="fas fa-handshake-angle"></i> Kurumsal Çözüm</span>
                <span><i class="fas fa-headset"></i> 7/24 Partner Desteği</span>
                <span><i class="fas fa-chart-line"></i> Şeffaf Komisyon</span>
            </div>
            <div class="utility-right">
                <div class="dropdown language-dropdown" id="corporateLanguageDropdown">
                    <button type="button" class="dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                        <span class="toggle-flag flag-icon flag-icon-tr" aria-hidden="true"></span>
                        <span class="dropdown-label">TR</span>
                    </button>
                    <ul class="dropdown-menu" role="menu">
                        <li class="dropdown-item" data-value="tr"><span class="flag-icon flag-icon-tr"></span> Türkçe</li>
                        <li class="dropdown-item" data-value="en"><span class="flag-icon flag-icon-gb"></span> English</li>
                        <li class="dropdown-item" data-value="fr"><span class="flag-icon flag-icon-fr"></span> Français</li>
                        <li class="dropdown-item" data-value="ru"><span class="flag-icon flag-icon-ru"></span> Русский</li>
                        <li class="dropdown-item" data-value="ar"><span class="flag-icon flag-icon-sa"></span> العربية</li>
                    </ul>
                </div>
                <div class="currency-selector"><i class="fas fa-lira-sign"></i> TRY</div>
            </div>
        </div>
    </div>

    <div class="header-container">
        <div class="logo-area">
            <a href="/" class="logo logo-image-only corporate-logo-link" aria-label="Otelturizm Kurumsal">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="corporate-logo-image" />
            </a>
        </div>

        <div class="search-wrapper">
            <div class="search-container corporate-search-container">
                <i class="fas fa-search"></i>
                <input type="text" class="search-input" placeholder="Kurumsal çözüm, destek veya partner avantajı ara">
                <div class="search-divider"></div>
                <div class="search-date"><i class="far fa-calendar"></i><span>Demo</span></div>
                <div class="search-divider"></div>
                <div class="search-guests"><i class="fas fa-user-group"></i><span>Partner</span></div>
                <button class="search-btn corporate-search-btn" type="button"><i class="fas fa-search"></i></button>
            </div>
        </div>

        <div class="header-actions corporate-header-actions">
            <a href="/firma" class="action-btn corporate-action-btn corporate-firma-btn">Firma</a>
            @if (!corporateAuthenticated && !string.Equals(corporateAccountType, "partner", StringComparison.OrdinalIgnoreCase))
            {
                <a href="/partner-giris" class="action-btn corporate-action-btn primary">Partner Girişi</a>
            }
            <partial name="~/Views/Shared/_PublicHeaderUserActions.cshtml" />
            <button class="action-btn mobile-nav-toggle corporate-mobile-toggle" id="corporateMenuToggle" type="button"><i class="fas fa-bars"></i></button>
        </div>
    </div>
</header>

<div class="mobile-menu-overlay" id="corporateMenuOverlay"></div>
<div class="mobile-menu-drawer corporate-menu-drawer" id="corporateMenuDrawer">
    <div class="drawer-scroll">
        <div class="drawer-header">
            <div class="drawer-user">
                <div class="drawer-brand-mark corporate-drawer-brand">
                    <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="drawer-brand-logo" />
                </div>
            </div>
            <button class="drawer-close" id="corporateDrawerClose" type="button"><i class="fas fa-times"></i></button>
        </div>

        <div class="drawer-nav">
            <div class="drawer-auth-row">
                @if (corporateAuthenticated)
                {
                    <a href="@corporatePanelUrl" class="drawer-action primary"><i class="fas fa-grid-2"></i> @corporatePanelLabel</a>
                    <form method="post" action="/cikis-yap" class="drawer-inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="drawer-action outline"><i class="fas fa-right-from-bracket"></i> Çıkış</button>
                    </form>
                }
                else
                {
                    <a href="/partner-giris" class="drawer-action primary"><i class="fas fa-briefcase"></i> Partner Girişi</a>
                    <a href="/kullanici-giris" class="drawer-action outline"><i class="fas fa-user"></i> Kayıt Ol</a>
                }
            </div>

            <div class="drawer-quick-features">
                <a href="/kurumsal" class="feature-tile"><i class="fas fa-building"></i><span>Kurumsal</span></a>
                <a href="/firma-giris" class="feature-tile"><i class="fas fa-building-user"></i><span>Firma Girişi</span></a>
                <a href="/partner-giris" class="feature-tile"><i class="fas fa-briefcase"></i><span>Partner Programı</span></a>
                <a href="/yardim-merkezi" class="feature-tile"><i class="fas fa-headset"></i><span>Canlı Destek</span></a>
            </div>

            <div class="drawer-section">
                <div class="drawer-section-title">Öne Çıkan Fırsatlar</div>
                <div class="drawer-promo-grid">
                    <a href="/kampanyalar" class="drawer-action outline promo-link"><i class="fas fa-bolt"></i> Kurumsal Kampanya</a>
                    <a href="/kampanyalar" class="drawer-action outline promo-link"><i class="fas fa-tags"></i> Özel İndirimler</a>
                    <a href="/yardim-merkezi" class="drawer-action outline promo-link"><i class="fas fa-phone-volume"></i> Hızlı Destek</a>
                    <a href="/firma" class="drawer-action outline promo-link"><i class="fas fa-briefcase"></i> İş Seyahati</a>
                </div>
            </div>

            <div class="drawer-corp-row">
                <a href="/kurumsal" class="drawer-action ghost"><i class="fas fa-building"></i> Kurumsal</a>
                <a href="/firma" class="drawer-action ghost"><i class="fas fa-briefcase"></i> Firma</a>
            </div>

            <div class="drawer-section">
                <div class="drawer-section-title">Menü</div>
                <a href="/" class="drawer-link"><i class="fas fa-home"></i> Anasayfa</a>
                <a href="/kurumsal" class="drawer-link"><i class="fas fa-building"></i> Kurumsal</a>
                <a href="/yardim-merkezi" class="drawer-link"><i class="fas fa-headset"></i> Destek</a>
            </div>
        </div>
    </div>
</div>
