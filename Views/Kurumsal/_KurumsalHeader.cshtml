<header class="site-header corporate-header" id="corporateHeader">
    <div class="top-utility-bar corporate-utility-bar">
        <div class="utility-container">
            <div class="utility-left">
                <span><i class="fas fa-handshake-angle"></i> Kurumsal Çözüm</span>
                <span><i class="fas fa-headset"></i> 7/24 Partner Desteği</span>
                <span><i class="fas fa-chart-line"></i> Şeffaf Komisyon</span>
            </div>
            <div class="utility-right">
                <div class="language-selector"><i class="fas fa-globe"></i> TR</div>
                <div class="currency-selector"><i class="fas fa-lira-sign"></i> TRY</div>
            </div>
        </div>
    </div>

    <div class="header-container">
        <div class="logo-area">
            <a href="/" class="logo logo-image-only corporate-logo-link" aria-label="Otelturizm Kurumsal">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="corporate-logo-image" />
            </a>

            <nav class="desktop-nav">
                <a href="/" class="nav-link"><span>Keşfet</span></a>
                <a href="/kurumsal" class="nav-link active"><span>Kurumsal</span></a>
            </nav>
        </div>

        <div class="search-wrapper">
            <div class="search-container corporate-search-container">
                <i class="fas fa-search"></i>
                <input type="text" class="search-input" placeholder="Kurumsal çözüm, destek veya partner avantajı ara">
                <div class="search-divider"></div>
                <div class="search-date"><i class="far fa-calendar"></i><span>Demo</span></div>
                <div class="search-divider"></div>
                <div class="search-guests"><i class="fas fa-user-group"></i><span>Partner</span></div>
                <button class="search-btn corporate-search-btn" type="button"><i class="fas fa-search"></i></button>
            </div>
        </div>

        <div class="header-actions corporate-header-actions">
            <a href="/kullanici-giris" class="action-btn corporate-action-btn">Kullanıcı Girişi</a>
            <a href="/partner-giris" class="action-btn corporate-action-btn primary">Partner Girişi</a>
            <button class="action-btn mobile-nav-toggle corporate-mobile-toggle" id="corporateMenuToggle" type="button"><i class="fas fa-bars"></i></button>
        </div>
    </div>
</header>

<div class="mobile-menu-overlay" id="corporateMenuOverlay"></div>
<div class="mobile-menu-drawer corporate-menu-drawer" id="corporateMenuDrawer">
    <div class="drawer-header">
        <div class="drawer-user">
            <div class="user-avatar corporate-avatar">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" />
            </div>
            <div>
                <h4>Otelturizm Kurumsal</h4>
                <p>Kurumsal hızlı erişim menüsü</p>
            </div>
        </div>
        <button class="drawer-close" id="corporateDrawerClose" type="button"><i class="fas fa-times"></i></button>
    </div>
    <div class="drawer-nav">
        <div class="drawer-section">
            <div class="drawer-section-title">Kurumsal Menü</div>
            <a href="/" class="drawer-link"><i class="fas fa-home"></i> Anasayfa</a>
            <a href="/kurumsal" class="drawer-link"><i class="fas fa-building"></i> Kurumsal</a>
            <a href="/partner-giris" class="drawer-link"><i class="fas fa-briefcase"></i> Partner Girişi</a>
            <a href="/kullanici-giris" class="drawer-link"><i class="fas fa-user"></i> Kullanıcı Girişi</a>
            <a href="/yardim-merkezi" class="drawer-link"><i class="fas fa-headset"></i> Destek</a>
        </div>
    </div>
</div>
