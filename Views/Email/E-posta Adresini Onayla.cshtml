<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#eef3fb;font-family:Inter,Arial,sans-serif;color:#162136;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#eef3fb;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="max-width:640px;background:#ffffff;border:1px solid #dfe8f6;border-radius:24px;overflow:hidden;">
                    <tr>
                        <td style="background:linear-gradient(135deg,#003b95 0%,#0f5bd7 55%,#1a74ff 100%);padding:36px 34px;color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.82;">Otelturizm Guvenlik Merkezi</p>
                            <h1 style="margin:0;font-size:30px;line-height:1.2;">E-posta adresinizi onaylayin</h1>
                            <p style="margin:12px 0 0;font-size:16px;line-height:1.55;opacity:.93;">Hesabinizi aktifleştirmek icin son adimdasiniz.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:34px;">
                            <p style="margin:0 0 16px;font-size:17px;">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#425571;">
                                <strong>{{user_email}}</strong> adresiyle olusturdugunuz hesabi guvenli sekilde etkinlestirmek icin asagidaki butona tiklayin.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 18px;background:#f4f8ff;border:1px dashed #bfd3f7;border-radius:18px;">
                                <tr>
                                    <td style="padding:16px 18px;">
                                        <p style="margin:0 0 6px;font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:#5f7492;">Dogrulama kodunuz</p>
                                        <p style="margin:0;font-size:30px;font-weight:800;letter-spacing:.2em;color:#0f5bd7;">{{verification_code}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
                                <tr>
                                    <td style="border-radius:999px;background:linear-gradient(135deg,#003b95 0%,#0f5bd7 100%);">
                                        <a href="{{verification_link}}" style="display:inline-block;padding:14px 26px;color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;border-radius:999px;">E-postami Onayla</a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:0 0 16px;font-size:13px;color:#5f7492;">Kayit tarihi: {{registration_date}}</p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fff8ea;border:1px solid #ffe3ad;border-radius:14px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:14px 16px;font-size:13px;line-height:1.65;color:#6f4a00;">
                                        Bu baglanti <strong>24 saat</strong> gecerlidir. Bu islemi siz yapmadiysaniz bu e-postayi dikkate almayabilirsiniz.
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:0 0 6px;font-size:12px;color:#6c7f99;">Buton calismazsa baglantiyi tarayiciniza yapistirin:</p>
                            <p style="margin:0;font-size:12px;line-height:1.55;word-break:break-all;color:#3b4f6d;">{{verification_link}}</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:22px 34px;background:#f6f9ff;border-top:1px solid #e3ebf7;">
                            <p style="margin:0;font-size:12px;line-height:1.65;color:#6d7f96;">Bu e-posta Otelturizm tarafindan otomatik gonderilmistir. Yanitlamayiniz.</p>
                            <p style="margin:8px 0 0;font-size:12px;color:#6d7f96;">© 2026 Otelturizm · Tum haklari saklidir.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
