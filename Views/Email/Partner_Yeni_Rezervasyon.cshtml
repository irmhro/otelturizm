@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Yeni Rezervasyon Onayı *@
@* Preheader: Rezervasyon #{{booking_reference}} oluşturuldu *@
@* HeaderTagline: Partner Bildirimi *@
@* HeaderTitle: Yeni Rezervasyon Onayı *@
@* HeaderSubtitle: Rezervasyon #{{booking_reference}} oluşturuldu *@
@* FooterLine1: Operasyon aksiyonları partner panelinden yönetilebilir. *@
@* FooterLine2: Otelturizm Partner Ağı *@
@* FooterLegal: Bu bildirim otomatik gönderilmiştir. Lütfen yanıtlamayınız. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Sayın <strong>{{hotel_manager_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> için yeni bir rezervasyon kaydı oluştu. Detaylar aşağıdadır.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Rezervasyon Özeti</p>
                                        <p class="email-card__row"><strong>Rezervasyon No:</strong> <span class="email-ref">#{{booking_reference}}</span></p>
                                        <p class="email-card__row"><strong>Misafir:</strong> {{guest_full_name}}</p>
                                        <p class="email-card__row"><strong>E-posta:</strong> {{guest_email}}</p>
                                        <p class="email-card__row"><strong>Telefon:</strong> {{guest_phone}}</p>
                                        <p class="email-card__row"><strong>Tarih:</strong> {{check_in_date}} → {{check_out_date}}</p>
                                        <p class="email-card__row"><strong>Oda:</strong> {{room_type_name}} / {{room_count}} oda</p>
                                        <p class="email-card__row"><strong>Toplam:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-note email-note--warn">
                                <tr>
                                    <td class="email-note__cell">
                                        Operasyon aksiyonları ve durum güncellemeleri partner panelinden yönetilebilir.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
