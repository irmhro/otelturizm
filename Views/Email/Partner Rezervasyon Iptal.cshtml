<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#edf1f7;font-family:Inter,Arial,sans-serif;color:#162136;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#edf1f7;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="660" style="max-width:660px;background:#ffffff;border:1px solid #d9e3f1;border-radius:24px;overflow:hidden;">
                    <tr>
                        <td style="background:linear-gradient(135deg,#5e101f 0%,#7f1429 100%);padding:34px;color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.83;">Partner Extranet</p>
                            <h1 style="margin:0;font-size:30px;line-height:1.2;">Misafir rezervasyonu iptal etti</h1>
                            <p style="margin:12px 0 0;font-size:16px;line-height:1.55;opacity:.92;">Iptal bilgileri ve sebep detayini panelinizde inceleyebilirsiniz.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:34px;">
                            <p style="margin:0 0 14px;font-size:17px;">Sayin <strong>{{hotel_manager_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#425571;">
                                <strong>{{hotel_name}}</strong> icin olusturulan rezervasyon misafir tarafindan iptal edildi.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f7f9fd;border:1px solid #e1e8f3;border-radius:16px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:16px 18px;">
                                        <p style="margin:0 0 8px;font-size:13px;color:#60768f;letter-spacing:.06em;text-transform:uppercase;">Rezervasyon no</p>
                                        <p style="margin:0 0 12px;font-size:22px;font-weight:800;color:#a41533;">#{{booking_reference}}</p>
                                        <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Misafir:</strong> {{guest_full_name}}</p>
                                        <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Tarih:</strong> {{check_in_date}} - {{check_out_date}}</p>
                                        <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Oda:</strong> {{room_type_name}}</p>
                                        <p style="margin:0;font-size:14px;color:#2b3f58;"><strong>Toplam:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fff4f6;border:1px solid #f6ccd6;border-radius:14px;">
                                <tr>
                                    <td style="padding:14px 16px;font-size:13px;line-height:1.65;color:#7b2436;">
                                        <strong>Iptal sebebi:</strong> {{cancel_reason}}
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:22px 34px;background:#f6f9ff;border-top:1px solid #e3ebf7;">
                            <p style="margin:0;font-size:12px;color:#6d7f96;">Bu bildirim otomatik gonderilmistir.</p>
                            <p style="margin:8px 0 0;font-size:12px;color:#6d7f96;">© 2026 Otelturizm Partner Agi</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
