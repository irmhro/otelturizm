@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Booking confirmed *@
@* Preheader: Your stay is confirmed *@
@* HeaderTagline: Booking Center *@
@* HeaderTitle: Your booking is confirmed *@
@* HeaderSubtitle: Have a great stay *@
@* FooterLine1: View your account panel for full details. *@
@* FooterLine2: Reservation no.: #{{booking_reference}} *@
@* FooterLegal: This is an automated message. Please do not reply. *@
                    <tr>
                        <td class="email-pad" style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:18px;">Hi <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                                Your booking at <strong>{{hotel_name}}</strong> has been confirmed. Your reference:
                                <strong style="font-size:18px;color:#003B95;">#{{booking_reference}}</strong>
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F5F7FA;border:1px solid #E7E9EC;border-radius:16px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:16px;">
                                        <div style="font-size:12px;color:#6B7380;text-transform:uppercase;letter-spacing:.08em;font-weight:800;">Booking details</div>
                                        <div style="margin-top:10px;font-size:14px;color:#1A1F26;"><strong>Stay:</strong> {{check_in_date}} → {{check_out_date}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Room:</strong> {{room_type_name}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Total:</strong> ₺{{total_price}}</div>
                                        <div style="margin-top:6px;font-size:13px;color:#6B7380;"><strong>Address:</strong> {{hotel_address}}</div>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta" style="margin:0 0 14px;">
                                <tr>
                                    <td style="border-radius:999px;background:linear-gradient(135deg,#003B95 0%,#0c5adb 100%);">
                                        <a href="{{booking_details_link}}" style="display:inline-block;min-height:44px;line-height:44px;padding:0 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">View booking →</a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:0;font-size:12px;color:#6B7380;">
                                Need help? Contact us at destek@otelturizm.com
                            </p>
                        </td>
                    </tr>
