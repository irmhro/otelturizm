@* Layout: _EmailMaster *@
@* EmailTitle: {{title}} *@
@* Preheader: {{badge}} *@
@* HeaderTagline: {{badge}} *@
@* HeaderTitle: {{title}} *@
@* HeaderSubtitle: Olay kodu: {{event_code}} *@
@* FooterLine1: {{occurred_at}} *@
@* FooterLine2: Otelturizm Admin *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-lead">{{intro}}</p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        {{detail_html}}
                                    </td>
                                </tr>
                            </table>
                            <p class="email-muted">Olay kodu: <strong>{{event_code}}</strong> · {{occurred_at}}</p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{primary_url}}" class="email-cta__btn">{{primary_label}}</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
