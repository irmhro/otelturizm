@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Your invoice is ready *@
@* Preheader: Your booking invoice has been uploaded *@
@* HeaderTagline: Invoice Center *@
@* HeaderTitle: Invoice uploaded *@
@* HeaderSubtitle: Your booking invoice is available *@
@* FooterLine1: Download the invoice from your account panel. *@
@* FooterLine2: Reservation no.: #{{booking_reference}} *@
@* FooterLegal: This is an automated message. *@
                    <tr>
                        <td class="email-pad" style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:18px;">Hi <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                                An invoice for your stay at <strong>{{hotel_name}}</strong> (#{{booking_reference}}) is now available.
                            </p>
                            <p style="margin:0 0 18px;font-size:14px;line-height:1.6;color:#64748b;">
                                Download it directly or open your <a href="{{invoices_panel_link}}" style="color:#0f4aa3;font-weight:700;text-decoration:none;">Invoices</a> page.
                            </p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta" style="margin:0;">
                                <tr>
                                    <td style="border-radius:999px;background:#E30A17;">
                                        <a href="{{invoice_download_link}}" style="display:inline-block;min-height:48px;line-height:48px;padding:0 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">Download invoice →</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
