@* Layout: _EmailMaster *@
@* EmailTitle: {{title}} *@
@* Preheader: Beta bildirimi *@
@* HeaderTagline: Beta bildirimi *@
@* HeaderTitle: {{title}} *@
@* HeaderSubtitle: {{panel_key}} · {{feedback_type}} *@
@* FooterLine1: Görsel eklendiyse bildirim kaydında ve e-posta ekinde yer alır. *@
@* FooterLine2: Kayıt zamanı: {{created_at}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-lead">
                                <strong>{{panel_key}}</strong> panelinden yeni bir {{feedback_type}} bildirimi geldi.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">Bildirim ID</span> <strong>#{{feedback_id}}</strong></p>
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">Kullanıcı</span> {{user_full_name}} · {{user_email}}</p>
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">Rol</span> {{account_type}}</p>
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">Sayfa</span> {{page_url}}</p>
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">Ekran</span> {{viewport}}</p>
                                        <p class="email-card__row"><span style="color:#6E6E77;display:inline-block;min-width:120px;">IP</span> {{ip_address}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Talep içeriği</p>
                                        <div style="white-space:pre-line;font-size:15px;line-height:1.65;color:#1A1919;">{{content}}</div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
