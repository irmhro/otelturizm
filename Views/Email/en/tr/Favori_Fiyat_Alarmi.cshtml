<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#edf1f7;font-family:Inter,Arial,sans-serif;color:#162136;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#edf1f7;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="660" style="max-width:660px;background:#ffffff;border:1px solid #d9e3f1;border-radius:24px;overflow:hidden;">
                    <tr>
                        <td style="background:linear-gradient(135deg,#0b2f73 0%,#1a53b0 100%);padding:34px;color:#ffffff;">
                            <h1 style="margin:0;font-size:30px;line-height:1.2;">Beklediğiniz fırsat geldi</h1>
                            <p style="margin:12px 0 0;font-size:16px;line-height:1.55;opacity:.92;">Favori oteliniz hedef fiyatınızın altına indi.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:34px;">
                            <p style="margin:0 0 14px;font-size:17px;">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#425571;">
                                <strong>{{hotel_name}}</strong> için kurduğunuz fiyat alarmı tetiklendi.
                            </p>
                            <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Hedef:</strong> ₺{{target_price}}</p>
                            <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Fiyat:</strong> ₺{{matched_price}}</p>
                            <p style="margin:0 0 18px;font-size:14px;color:#2b3f58;"><strong>Tarih:</strong> {{matched_date}}</p>
                            <a href="{{cta_reserve_link}}" style="display:inline-block;padding:12px 20px;border-radius:12px;background:#0f5bd7;color:#fff;text-decoration:none;font-weight:800;">Hemen rezervasyon yap</a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
