@{
    Layout = null;
    var firstName = ViewData["user_first_name"]?.ToString() ?? "{{user_first_name}}";
    var email = ViewData["user_email"]?.ToString() ?? "{{user_email}}";
    var resetLink = ViewData["reset_link"]?.ToString() ?? "{{reset_link}}";
    var requestIp = ViewData["request_ip"]?.ToString() ?? "{{request_ip}}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Password reset request</title>
</head>
<body style="margin:0;padding:0;background:#f5f7fb;font-family:Arial,sans-serif;color:#10203a;">
<div style="max-width:620px;margin:0 auto;padding:32px 16px;">
    <div style="background:#ffffff;border-radius:20px;padding:32px;border:1px solid #dbe4f0;">
        <p style="margin:0 0 12px;font-size:13px;font-weight:700;letter-spacing:.08em;color:#2f6fed;">OTELTURIZM</p>
        <h1 style="margin:0 0 16px;font-size:28px;line-height:1.2;color:#10203a;">Your password reset link is ready</h1>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">Hi <strong>@firstName</strong>,</p>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">We received a password reset request for <strong>@email</strong>. If this was you, click the button below to set a new password.</p>
        <p style="margin:0 0 20px;">
            <a href="@resetLink" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#174ea6;color:#ffffff;font-weight:700;text-decoration:none;">Reset password</a>
        </p>
        <p style="margin:0;font-size:14px;line-height:1.6;color:#4d5f7a;">Request IP: @requestIp. If you didn’t request this, you can ignore this email.</p>
    </div>
</div>
</body>
</html>

