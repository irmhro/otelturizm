@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Tesis Kullanıcı Daveti *@
@* Preheader: Yönetim erişimi daveti *@
@* HeaderTagline: Partner Daveti *@
@* HeaderTitle: Tesis kullanıcı daveti *@
@* HeaderSubtitle: {{hotel_name}} tesisi için yönetim erişimi *@
@* FooterLine1: Daveti onaylamak için giriş yapmış ve e-postanızı doğrulamış olmanız gerekir. *@
@* FooterLine2: Bu e-posta {{invited_email}} adresine gönderilmiştir. *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{invited_full_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> tesisi için <strong>{{inviter_name}}</strong> tarafından yönetim erişimi daveti aldınız.
                            </p>
                            <p class="email-muted">
                                Yetki aralığı: <strong>{{start_date}}</strong> — <strong>{{end_date}}</strong>
                            </p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{approval_link}}" class="email-cta__btn">Daveti Onayla</a>
                                    </td>
                                </tr>
                            </table>
                            <p class="email-muted">
                                Not: Bu daveti onaylayabilmek için hesabınızla giriş yapmış olmanız ve e-posta adresinizin doğrulanmış olması gerekir.
                            </p>
                        </td>
                    </tr>
