@{
    Layout = null;
    var firstName = ViewData["user_first_name"]?.ToString() ?? "{{user_first_name}}";
    var email = ViewData["user_email"]?.ToString() ?? "{{user_email}}";
    var registrationDate = ViewData["registration_date"]?.ToString() ?? "{{registration_date}}";
    var verificationLink = ViewData["verification_link"]?.ToString() ?? "{{verification_link}}";
    var verificationCode = ViewData["verification_code"]?.ToString() ?? "{{verification_code}}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify your email</title>
</head>
<body style="margin:0;padding:0;background:#f5f7fb;font-family:Arial,sans-serif;color:#10203a;">
<div style="max-width:620px;margin:0 auto;padding:32px 16px;">
    <div style="background:#ffffff;border-radius:20px;padding:32px;border:1px solid #dbe4f0;">
        <p style="margin:0 0 12px;font-size:13px;font-weight:700;letter-spacing:.08em;color:#2f6fed;">OTELTURIZM</p>
        <h1 style="margin:0 0 16px;font-size:28px;line-height:1.2;color:#10203a;">Verify your email address</h1>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">Hi <strong>@firstName</strong>,</p>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">To finish creating your account for <strong>@email</strong>, use the code below or click the verification link.</p>
        <div style="margin:0 0 20px;padding:18px 24px;border-radius:16px;background:#edf4ff;border:1px solid #c7dbff;text-align:center;">
            <span style="display:block;font-size:34px;font-weight:800;letter-spacing:.18em;color:#174ea6;">@verificationCode</span>
        </div>
        <p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#4d5f7a;">Sign-up time: @registrationDate</p>
        <p style="margin:0;">
            <a href="@verificationLink" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#174ea6;color:#ffffff;font-weight:700;text-decoration:none;">Verify email</a>
        </p>
    </div>
</div>
</body>
</html>

