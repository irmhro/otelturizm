<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Special Offer</title>
</head>
<body style="margin:0;padding:0;background:#eef3fa;font-family:Inter,Arial,sans-serif;color:#17263a;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#eef3fa;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="max-width:640px;background:#ffffff;border:1px solid #d9e2f1;border-radius:20px;overflow:hidden;">
                    <tr>
                        <td style="padding:28px;background:linear-gradient(135deg,#0f5bd7 0%,#1647a5 100%);color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;opacity:.88;">Special Offer</p>
                            <h1 style="margin:0;font-size:27px;line-height:1.2;">A tailored offer is ready for {{otel_adi}}</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:16px;">Hello <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 14px;font-size:14px;line-height:1.6;color:#425873;">
                                Your tailored offer for <strong>{{otel_adi}}</strong> is <strong>{{tutar}} TL</strong>.
                            </p>
                            <p style="margin:0 0 14px;font-size:14px;line-height:1.6;color:#425873;">
                                Stay dates: <strong>{{check_in_date}}</strong> - <strong>{{check_out_date}}</strong>
                            </p>
                            <p style="margin:0;">
                                <a href="{{hotel_link}}" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#174ea6;color:#ffffff;font-weight:700;text-decoration:none;">View Offer</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
