<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Password reset request</title>
</head>
<body style="margin:0;padding:0;background:#F3F1ED;font-family:Arial,sans-serif;color:#1A1919;">
<div style="max-width:620px;margin:0 auto;padding:32px 16px;">
    <div style="background:#ffffff;border-radius:20px;padding:32px;border:1px solid #dbe4f0;">
        <p style="margin:0 0 12px;font-size:13px;font-weight:700;letter-spacing:.08em;color:#E30A17;">OTELTURIZM</p>
        <h1 style="margin:0 0 16px;font-size:28px;line-height:1.2;color:#1A1919;">Your password reset link is ready</h1>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">Hi <strong>{{user_first_name}}</strong>,</p>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">We received a password reset request for <strong>{{user_email}}</strong>. If this was you, click the button below to set a new password.</p>
        <p style="margin:0 0 20px;">
            <a href="{{reset_link}}" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#E30A17;color:#ffffff;font-weight:700;text-decoration:none;">Reset password</a>
        </p>
        <p style="margin:0;font-size:14px;line-height:1.6;color:#6E6E77;">Request IP: {{request_ip}}. If you didn’t request this, you can ignore this email.</p>
    </div>
</div>
</body>
</html>

