@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Fiyat Alarmı *@
@* Preheader: Favori oteliniz hedef fiyatınızın altına indi *@
@* HeaderTagline: Fiyat Alarmı *@
@* HeaderTitle: Beklediğiniz fırsat geldi *@
@* HeaderSubtitle: Favori oteliniz hedef fiyatınızın altına indi *@
@* FooterLine1: Bu e-posta fiyat alarmı tercihinize göre otomatik gönderilmiştir. *@
@* FooterLine2: Otelturizm *@
@* FooterLegal: Stok hızla değişebilir; en iyi sonuç için hemen kontrol edin. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> <span style="color:#6E6E77;">{{hotel_location}}</span> için kurduğunuz fiyat alarmı tetiklendi.
                                Takip ettiğiniz tarih aralığında hedefinize uygun bir gün yakaladık.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__row"><strong>Hedef fiyatınız:</strong> ₺{{target_price}}</p>
                                        <p class="email-card__row"><strong>Yakalanan fiyat:</strong> ₺{{matched_price}}</p>
                                        <p class="email-card__row"><strong>Uygun tarih:</strong> {{matched_date}}</p>
                                    </td>
                                </tr>
                            </table>

                            <p class="email-lead">Şimdi hızlıca rezervasyon adımına geçip fırsatı yakalayın.</p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{cta_reserve_link}}" class="email-cta__btn">Hemen rezervasyon yap</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-top:10px;">
                                        <a href="{{hotel_link}}" class="email-cta__btn email-cta__btn--secondary">Oteli incele</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
