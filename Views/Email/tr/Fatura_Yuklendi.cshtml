                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{invoice_download_link}}" class="email-cta__btn">Faturayı indir →</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
