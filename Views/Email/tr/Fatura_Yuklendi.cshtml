@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Faturanız hazır *@
@* Preheader: Rezervasyon faturanız yüklendi *@
@* HeaderTagline: Fatura Merkezi *@
@* HeaderTitle: Faturanız yüklendi *@
@* HeaderSubtitle: Rezervasyonunuz için fatura hazır *@
@* FooterLine1: Faturayı hesap panelinden indirebilirsiniz. *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> rezervasyonunuz (<strong class="email-ref">#{{booking_reference}}</strong>) için fatura yüklendi.
                            </p>
                            <p class="email-muted" style="margin:0 0 18px;font-size:14px;line-height:1.6;color:#64748b;">
                                Faturayı doğrudan indirebilir veya <a href="{{invoices_panel_link}}" style="color:#0f4aa3;font-weight:700;text-decoration:none;">Faturalarım</a> sayfasından görüntüleyebilirsiniz.
                            </p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{invoice_download_link}}" class="email-cta__btn">Faturayı indir →</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
