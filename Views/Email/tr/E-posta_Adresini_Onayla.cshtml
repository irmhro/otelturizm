@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · E-posta Adresinizi Onaylayın *@
@* Preheader: Hesabınızı tamamlamak için doğrulama kodunu kullanın *@
@* EmailLang: tr *@
@* HeaderTagline: Otelturizm *@
@* HeaderTitle: E-posta adresinizi onaylayın *@
@* HeaderSubtitle: Hesabınızı tamamlamak için kodu girin veya bağlantıya tıklayın *@
@* FooterLine1: 7/24 destek: destek@otelturizm.com *@
@* FooterLine2: Kayıt zamanı: {{registration_date}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{user_email}}</strong> adresiyle oluşturduğunuz hesabı tamamlamak için aşağıdaki kodu kullanabilir veya bağlantıya tıklayabilirsiniz.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-code">
                                <tr>
                                    <td class="email-code__cell">
                                        <p class="email-code__label">Doğrulama Kodu</p>
                                        <p class="email-code__value">{{verification_code}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{verification_link}}" class="email-cta__btn">E-postamı doğrula</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
