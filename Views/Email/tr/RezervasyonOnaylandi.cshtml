@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyonun Onaylandı *@
@* Preheader: Tatilin için geri sayım başladı *@
@* HeaderTagline: Rezervasyon Merkezi *@
@* HeaderTitle: Rezervasyonun Onaylandı! *@
@* HeaderSubtitle: Tatilin için geri sayım başladı *@
@* FooterLine1: Detaylar için hesap panelini ziyaret edebilirsin. *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Harika haber <strong>{{user_first_name}}</strong>!</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> rezervasyonun onaylandı. Rezervasyon numaran:
                                <strong class="email-ref">#{{booking_reference}}</strong>
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Konaklama Detayları</p>
                                        <p class="email-card__row"><strong>Konaklama:</strong> {{check_in_date}} → {{check_out_date}}</p>
                                        <p class="email-card__row"><strong>Oda:</strong> {{room_type_name}}</p>
                                        <p class="email-card__row"><strong>Toplam:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-note email-note--success">
                                <tr>
                                    <td class="email-note__cell">
                                        Check-in detayların ve varsa ek taleplerin hesap panelinde görüntülenir.
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{booking_details_link}}" class="email-cta__btn">Rezervasyonu görüntüle →</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
