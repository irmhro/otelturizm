<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Otelturizm · Rezervasyonun Onaylandı</title>
</head>
<body style="margin:0;padding:0;background:#E8ECF2;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,Helvetica,Arial,sans-serif;color:#1A1F26;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#E8ECF2;padding:36px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:#FFFFFF;border-radius:24px;overflow:hidden;box-shadow:0 10px 34px rgba(15,23,42,0.10);">
                    <tr>
                        <td style="background:linear-gradient(135deg,#003B95 0%,#0055CC 100%);padding:34px 28px;color:#ffffff;text-align:center;">
                            <div style="font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.92;font-weight:800;">Rezervasyon Merkezi</div>
                            <div style="margin-top:10px;font-size:22px;font-weight:900;">Rezervasyonun Onaylandı!</div>
                            <div style="margin-top:8px;font-size:14px;opacity:.92;">Tatilin için geri sayım başladı</div>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:18px;">Harika haber <strong>{{user_first_name}}</strong>!</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                                <strong>{{hotel_name}}</strong> rezervasyonun onaylandı. Rezervasyon numaran:
                                <strong style="font-size:18px;color:#003B95;">#{{booking_reference}}</strong>
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F5F7FA;border:1px solid #E7E9EC;border-radius:16px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:16px 16px;">
                                        <div style="font-size:12px;color:#6B7380;text-transform:uppercase;letter-spacing:.08em;font-weight:800;">Konaklama Detayları</div>
                                        <div style="margin-top:10px;font-size:14px;color:#1A1F26;"><strong>Konaklama:</strong> {{check_in_date}} → {{check_out_date}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Oda:</strong> {{room_type_name}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Toplam:</strong> ₺{{total_price}}</div>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:rgba(0,168,107,0.10);border:1px solid rgba(0,168,107,0.26);border-radius:14px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:14px 16px;font-size:13px;line-height:1.65;color:#1e6f42;">
                                        Check-in detayların ve varsa ek taleplerin hesap panelinde görüntülenir.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:18px 22px;background:#F5F7FA;border-top:1px solid #E7E9EC;color:#6B7380;text-align:center;">
                            <p style="margin:0;font-size:12px;">Detaylar için hesap panelini ziyaret edebilirsin.</p>
                            <p style="margin:8px 0 0;font-size:12px;">© 2026 Otelturizm · Rezervasyon No: #{{booking_reference}}</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

