@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyon Talebin Alındı *@
@* Preheader: Onay süreci başladı, en kısa sürede bilgilendirileceksin *@
@* HeaderTagline: Rezervasyon Merkezi *@
@* HeaderTitle: Rezervasyon Talebin Alındı! *@
@* HeaderSubtitle: Onay süreci başladı, en kısa sürede bilgilendirileceksin *@
@* FooterLine1: Otel talebini değerlendirdikten sonra yeni bir bilgilendirme e-postası göndereceğiz. *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad" style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:18px;">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                                <strong>{{hotel_name}}</strong> için rezervasyon talebin bize ulaştı. Rezervasyon numaran:
                                <strong style="font-size:18px;color:#003B95;">#{{booking_reference}}</strong>
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F5F7FA;border:1px solid #E7E9EC;border-radius:16px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:16px;">
                                        <div style="font-size:12px;color:#6B7380;text-transform:uppercase;letter-spacing:.08em;font-weight:800;">Rezervasyon Detayları</div>
                                        <div style="margin-top:10px;font-size:14px;color:#1A1F26;"><strong>Konaklama:</strong> {{check_in_date}} → {{check_out_date}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Oda:</strong> {{room_type_name}}</div>
                                        <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Toplam:</strong> ₺{{total_price}}</div>
                                        <div style="margin-top:6px;font-size:13px;color:#6B7380;"><strong>Adres:</strong> {{hotel_address}}</div>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta" style="margin:0 0 14px;">
                                <tr>
                                    <td style="border-radius:999px;background:linear-gradient(135deg,#003B95 0%,#0c5adb 100%);">
                                        <a href="{{booking_details_link}}" style="display:inline-block;min-height:44px;line-height:44px;padding:0 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">Rezervasyonumu Görüntüle →</a>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:rgba(255,184,0,0.10);border:1px solid rgba(255,184,0,0.35);border-radius:14px;">
                                <tr>
                                    <td style="padding:14px 16px;font-size:13px;line-height:1.65;color:#6f4a00;">
                                        Otel talebini değerlendirdikten sonra sana yeni bir bilgilendirme e-postası göndereceğiz.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
