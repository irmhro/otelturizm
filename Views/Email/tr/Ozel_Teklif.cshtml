@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Özel Teklif *@
@* Preheader: Size özel teklif hazır *@
@* HeaderTagline: Özel Teklif *@
@* HeaderTitle: {{otel_adi}} için size özel teklif hazır *@
@* HeaderSubtitle: Tarih aralığı: {{check_in_date}} - {{check_out_date}} *@
@* FooterLine1: Teklif tutarı: {{tutar}} TL *@
@* FooterLine2: Otelturizm *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{otel_adi}}</strong> için size özel hazırlanan teklif tutarı <strong>{{tutar}} TL</strong>.
                            </p>
                            <p class="email-muted">Tarih aralığı: <strong>{{check_in_date}}</strong> - <strong>{{check_out_date}}</strong></p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{hotel_link}}" class="email-cta__btn">Teklifi Görüntüle</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
