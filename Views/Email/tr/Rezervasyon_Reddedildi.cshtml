@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyon Talebin Reddedildi *@
@* Preheader: Uygun alternatifler için panelini kontrol edebilirsin *@
@* HeaderTagline: Rezervasyon Merkezi *@
@* HeaderTitle: Rezervasyon Talebin Reddedildi *@
@* HeaderSubtitle: Uygun alternatifler için panelini kontrol edebilirsin *@
@* FooterLine1: 7/24 destek: destek@otelturizm.com *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> için oluşturduğun rezervasyon talebi otel tarafından onaylanamadı. Rezervasyon numaran:
                                <strong class="email-ref">#{{booking_reference}}</strong>
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Rezervasyon Detayları</p>
                                        <p class="email-card__row"><strong>Konaklama:</strong> {{check_in_date}} → {{check_out_date}}</p>
                                        <p class="email-card__row"><strong>Oda:</strong> {{room_type_name}}</p>
                                        <p class="email-card__row"><strong>Toplam:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-note email-note--danger">
                                <tr>
                                    <td class="email-note__cell">
                                        <strong>Bilgi:</strong> Ödeme alındıysa iade süreci otomatik olarak başlatılır. Detayları hesabındaki rezervasyon panelinden takip edebilirsin.
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{booking_details_link}}" class="email-cta__btn">Rezervasyonumu Görüntüle</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
