@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyon Güncelleme Bildirimi *@
@* Preheader: Rezervasyon #{{booking_reference}} güncellendi *@
@* HeaderTagline: Partner Bildirimi *@
@* HeaderTitle: Rezervasyon tarihleri güncellendi *@
@* HeaderSubtitle: Misafir tarafından güncellenen rezervasyon detayları *@
@* FooterLine1: Lütfen partner panelinden güncellenen rezervasyon detayını kontrol edin. *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu bildirim otomatik gönderilmiştir. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{hotel_manager_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> için <strong class="email-ref">#{{booking_reference}}</strong> numaralı rezervasyon misafir tarafından güncellendi.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Misafir</p>
                                        <p class="email-card__row">{{guest_full_name}} · {{guest_email}} · {{guest_phone}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Eski tarih</p>
                                        <p class="email-card__row">{{old_check_in_date}} → {{old_check_out_date}} · ₺{{old_total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card" style="border-color:rgba(22,163,74,0.22);background:rgba(22,163,74,0.06);">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label" style="color:#166534;">Yeni tarih</p>
                                        <p class="email-card__row">{{check_in_date}} → {{check_out_date}} · {{night_count}} gece · ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Oda</p>
                                        <p class="email-card__row">{{room_type_name}} · Ortalama gecelik ₺{{nightly_price}}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
