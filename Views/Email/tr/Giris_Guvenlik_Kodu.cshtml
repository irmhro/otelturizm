@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Giriş Güvenlik Kodu *@
@* Preheader: Tek kullanımlık güvenlik kodunuz *@
@* HeaderTagline: Otelturizm Güvenlik *@
@* HeaderTitle: Giriş güvenlik kodunuz hazır *@
@* HeaderSubtitle: Kodu giriş ekranına yazın *@
@* FooterLine1: 7/24 destek: destek@otelturizm.com *@
@* FooterLine2: İstek zamanı: {{login_time}} *@
@* FooterLegal: Bu işlemi siz başlatmadıysanız şifrenizi değiştirin. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                Hesabınıza giriş yapmak için {{verification_channel}} üzerinden doğrulama istediniz.
                                Aşağıdaki tek kullanımlık güvenlik kodunu giriş ekranına yazın.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-code">
                                <tr>
                                    <td class="email-code__cell">
                                        <p class="email-code__label">Güvenlik Kodu</p>
                                        <p class="email-code__value">{{verification_code}}</p>
                                    </td>
                                </tr>
                            </table>

                            <p class="email-muted">Bu kod birkaç dakika içinde kullanılmalıdır. Giriş işlemini siz başlatmadıysanız şifrenizi değiştirin ve destek ekibimizle iletişime geçin.</p>
                        </td>
                    </tr>
