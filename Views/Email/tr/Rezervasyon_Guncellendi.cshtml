@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyon Güncellendi *@
@* Preheader: Rezervasyon tarihlerin güncellendi *@
@* HeaderTagline: Rezervasyon Merkezi *@
@* HeaderTitle: Rezervasyonun güncellendi *@
@* HeaderSubtitle: Güncel fiyat oda takvimine göre yeniden hesaplandı *@
@* FooterLine1: Otel, güncellenen tarihleri panelinde görecek ve gerekli onay adımlarını tamamlayacaktır. *@
@* FooterLine2: Rezervasyon No: #{{booking_reference}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> için <strong class="email-ref">#{{booking_reference}}</strong> numaralı rezervasyon tarihlerin güncellendi. Güncel fiyat oda takvimine göre yeniden hesaplandı.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Eski rezervasyon</p>
                                        <p class="email-card__row">{{old_check_in_date}} → {{old_check_out_date}} · ₺{{old_total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card" style="border-color:rgba(22,163,74,0.22);background:rgba(22,163,74,0.06);">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label" style="color:#166534;">Yeni rezervasyon</p>
                                        <p class="email-card__row">{{check_in_date}} → {{check_out_date}} · {{night_count}} gece · ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Oda</p>
                                        <p class="email-card__row">{{room_type_name}} · Ortalama gecelik ₺{{nightly_price}}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
