@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Şifre Sıfırlama *@
@* Preheader: Şifre sıfırlama bağlantınız hazır *@
@* HeaderTagline: Hesap Güvenliği *@
@* HeaderTitle: Şifre sıfırlama bağlantınız hazır *@
@* HeaderSubtitle: İşlem size aitse aşağıdaki bağlantıyla yeni şifrenizi oluşturabilirsiniz *@
@* FooterLine1: Bu işlemi siz yapmadıysanız bu e-postayı dikkate almayabilirsiniz. *@
@* FooterLine2: İstek IP: {{request_ip}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad" style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                                <strong>{{user_email}}</strong> hesabınız için bir şifre sıfırlama talebi aldık.
                            </p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta" style="margin:0 0 16px;">
                                <tr>
                                    <td style="border-radius:999px;background:linear-gradient(135deg,#174ea6 0%,#003B95 100%);">
                                        <a href="{{reset_link}}" style="display:inline-block;min-height:44px;line-height:44px;padding:0 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">Şifremi sıfırla</a>
                                    </td>
                                </tr>
                            </table>
                            <p style="margin:0;font-size:14px;line-height:1.6;color:#4d5f7a;">İstek IP adresi: {{request_ip}}.</p>
                        </td>
                    </tr>
