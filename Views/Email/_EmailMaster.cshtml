<!DOCTYPE html>
<html lang="{{email_lang}}" dir="{{email_dir}}" class="{{email_rtl_class}}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{{email_title}}</title>
    <style type="text/css">
        body { margin: 0; padding: 0; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        table { border-collapse: collapse; mso-table-lspace: 0; mso-table-rspace: 0; }
        img { border: 0; outline: none; text-decoration: none; }
        a { color: #E30A17; }
        .email-outer { background: #F3F1ED; }
        .email-shell { max-width: 600px; width: 100%; background: #FFFFFF; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 28px rgba(26, 25, 25, 0.08); }
        .email-pad { padding: 28px 28px 32px; }
        .email-header { background: #FFFFFF; border-top: 4px solid #E30A17; padding: 28px 28px 22px; text-align: center; }
        .email-header__tagline { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: #E30A17; font-weight: 800; margin: 0; }
        .email-header__title { margin: 10px 0 0; font-size: 24px; font-weight: 900; line-height: 1.25; color: #1A1919; }
        .email-header__subtitle { margin: 8px 0 0; font-size: 15px; line-height: 1.55; color: #6E6E77; }
        .email-greeting { margin: 0 0 12px; font-size: 18px; line-height: 1.4; color: #1A1919; }
        .email-lead { margin: 0 0 18px; font-size: 15px; line-height: 1.7; color: #1A1919; }
        .email-ref { font-size: 18px; color: #E30A17; font-weight: 800; }
        .email-card { width: 100%; background: #FCFBF9; border: 1px solid #EBE9E4; border-radius: 14px; margin: 0 0 16px; }
        .email-card__label { font-size: 11px; color: #6E6E77; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 800; margin: 0; }
        .email-card__row { margin: 10px 0 0; font-size: 14px; line-height: 1.55; color: #1A1919; }
        .email-card__row:first-of-type { margin-top: 10px; }
        .email-card__cell { padding: 16px 18px; }
        .email-note { width: 100%; border-radius: 12px; margin: 0 0 16px; }
        .email-note__cell { padding: 14px 16px; font-size: 13px; line-height: 1.65; }
        .email-note--success { background: rgba(22, 163, 74, 0.08); border: 1px solid rgba(22, 163, 74, 0.22); }
        .email-note--success .email-note__cell { color: #166534; }
        .email-note--warn { background: rgba(245, 158, 11, 0.10); border: 1px solid rgba(245, 158, 11, 0.30); }
        .email-note--warn .email-note__cell { color: #92400E; }
        .email-note--danger { background: rgba(227, 10, 23, 0.08); border: 1px solid rgba(227, 10, 23, 0.22); }
        .email-note--danger .email-note__cell { color: #991B1B; }
        .email-note--info { background: rgba(227, 10, 23, 0.06); border: 1px solid rgba(227, 10, 23, 0.16); }
        .email-note--info .email-note__cell { color: #1A1919; }
        .email-cta { margin: 0 0 14px; }
        .email-cta__btn { display: inline-block; min-height: 48px; line-height: 48px; padding: 0 24px; color: #ffffff !important; text-decoration: none; font-size: 15px; font-weight: 800; border-radius: 999px; background: #E30A17; mso-padding-alt: 0; text-align: center; }
        .email-cta__btn:hover { background: #B00010; }
        .email-cta__btn--secondary { background: #FFFFFF; color: #E30A17 !important; border: 1px solid #EBE9E4; line-height: 46px; }
        .email-code { width: 100%; border-radius: 14px; background: #FCFBF9; border: 1px solid #EBE9E4; margin: 0 0 18px; text-align: center; }
        .email-code__label { font-size: 11px; color: #6E6E77; text-transform: uppercase; letter-spacing: 0.16em; margin: 0; }
        .email-code__value { margin: 10px 0 0; font-size: 32px; font-weight: 800; letter-spacing: 0.22em; color: #E30A17; }
        .email-code__cell { padding: 18px 20px; }
        .email-muted { margin: 0; font-size: 14px; line-height: 1.6; color: #6E6E77; }
        .email-footer { padding: 18px 22px 22px; background: #FCFBF9; border-top: 1px solid #EBE9E4; color: #6E6E77; text-align: center; }
        .email-footer p { margin: 0; font-size: 12px; line-height: 1.6; }
        .email-footer p + p { margin-top: 8px; }
        .email-footer__legal { font-size: 11px; line-height: 1.5; color: #6E6E77; }
        .email-link { color: #E30A17; font-weight: 700; text-decoration: none; }
        .email-rtl, .email-rtl table { direction: rtl; text-align: right; }
        .email-rtl .email-cta { direction: ltr; }
        @@media only screen and (max-width: 620px) {
            .email-outer-pad { padding: 20px 12px !important; }
            .email-shell { width: 100% !important; border-radius: 16px !important; }
            .email-pad { padding: 20px 16px 24px !important; }
            .email-header { padding: 22px 16px 18px !important; }
            .email-header__title { font-size: 20px !important; }
            .email-header__subtitle { font-size: 14px !important; }
            .email-greeting { font-size: 17px !important; }
            .email-lead { font-size: 15px !important; }
            .email-card { width: 100% !important; }
            .email-card__cell { padding: 14px 16px !important; }
            .email-cta, .email-cta tbody, .email-cta tr, .email-cta td { display: block !important; width: 100% !important; }
            .email-cta__btn { display: block !important; width: 100% !important; min-height: 48px !important; line-height: 48px !important; box-sizing: border-box !important; }
            .email-cta__btn--secondary { margin-top: 10px !important; }
            .email-code__value { font-size: 28px !important; letter-spacing: 0.16em !important; }
            .email-footer { padding: 16px !important; }
        }
    </style>
</head>
<body style="margin:0;padding:0;background:#F3F1ED;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,Helvetica,Arial,sans-serif;color:#1A1919;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;mso-hide:all;">{{email_preheader}}</div>
    <table role="presentation" class="email-outer" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F3F1ED;">
        <tr>
            <td class="email-outer-pad" align="center" style="padding:36px 12px;">
                <table role="presentation" class="email-shell" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;width:100%;background:#FFFFFF;border-radius:20px;overflow:hidden;box-shadow:0 8px 28px rgba(26,25,25,0.08);">
                    <tr>
                        <td class="email-header" style="background:#FFFFFF;border-top:4px solid #E30A17;padding:28px 28px 22px;text-align:center;">
                            <p class="email-header__tagline" style="margin:0;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:#E30A17;font-weight:800;">{{email_header_tagline}}</p>
                            <p class="email-header__title" style="margin:10px 0 0;font-size:24px;font-weight:900;line-height:1.25;color:#1A1919;">{{email_header_title}}</p>
                            <p class="email-header__subtitle" style="margin:8px 0 0;font-size:15px;line-height:1.55;color:#6E6E77;">{{email_header_subtitle}}</p>
                        </td>
                    </tr>
                    {{Body}}
                    <tr>
                        <td class="email-footer" style="padding:18px 22px 22px;background:#FCFBF9;border-top:1px solid #EBE9E4;color:#6E6E77;text-align:center;">
                            <p style="margin:0;font-size:12px;line-height:1.6;">{{email_footer_line1}}</p>
                            <p style="margin:8px 0 0;font-size:12px;line-height:1.6;">© {{email_footer_year}} Otelturizm · {{email_footer_line2}}</p>
                            <p class="email-footer__legal" style="margin:8px 0 0;font-size:11px;line-height:1.5;color:#6E6E77;">{{email_footer_legal}}</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
