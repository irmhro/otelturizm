<!DOCTYPE html>
<html lang="{{email_lang}}" dir="{{email_dir}}" class="{{email_rtl_class}}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{{email_title}}</title>
    <style type="text/css">
        .email-rtl, .email-rtl table { direction: rtl; text-align: right; }
        .email-rtl .email-cta { direction: ltr; }
        @@media only screen and (max-width: 620px) {
            .email-shell { width: 100% !important; }
            .email-pad { padding: 20px 16px !important; }
        }
    </style>
</head>
<body style="margin:0;padding:0;background:#E8ECF2;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,Helvetica,Arial,sans-serif;color:#1A1F26;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;mso-hide:all;">{{email_preheader}}</div>
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#E8ECF2;padding:36px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" class="email-shell" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;width:100%;background:#FFFFFF;border-radius:24px;overflow:hidden;box-shadow:0 10px 34px rgba(15,23,42,0.10);">
                    <tr>
                        <td style="background:linear-gradient(135deg,#003B95 0%,#0055CC 100%);padding:34px 28px;color:#ffffff;text-align:center;">
                            <div style="font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.92;font-weight:800;">{{email_header_tagline}}</div>
                            <div style="margin-top:10px;font-size:22px;font-weight:900;line-height:1.25;">{{email_header_title}}</div>
                            <div style="margin-top:8px;font-size:14px;opacity:.92;line-height:1.5;">{{email_header_subtitle}}</div>
                        </td>
                    </tr>
                    {{Body}}
                    <tr>
                        <td class="email-pad" style="padding:18px 22px;background:#F5F7FA;border-top:1px solid #E7E9EC;color:#6B7380;text-align:center;">
                            <p style="margin:0;font-size:12px;line-height:1.6;">{{email_footer_line1}}</p>
                            <p style="margin:8px 0 0;font-size:12px;line-height:1.6;">© {{email_footer_year}} Otelturizm · {{email_footer_line2}}</p>
                            <p style="margin:8px 0 0;font-size:11px;line-height:1.5;color:#94A3B8;">{{email_footer_legal}}</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
