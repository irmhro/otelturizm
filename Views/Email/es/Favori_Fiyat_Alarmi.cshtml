<!DOCTYPE html>
<html lang="en">
<body style="margin:0;padding:0;background:#F3F1ED;font-family:Inter,Arial,sans-serif;color:#1A1919;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F3F1ED;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="660" style="max-width:660px;background:#ffffff;border:1px solid #d9e3f1;border-radius:24px;overflow:hidden;">
                    <tr>
                        <td style="background:#E30A17;padding:34px;color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.83;">Price Alert • Catch &amp; Book</p>
                            <h1 style="margin:0;font-size:30px;line-height:1.2;">Your target deal is live</h1>
                            <p style="margin:12px 0 0;font-size:16px;line-height:1.55;opacity:.92;">Your favorite hotel price dropped below target. Availability may be limited.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:34px;">
                            <p style="margin:0 0 14px;font-size:17px;">Hello <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#425571;">
                                Your alert for <strong>{{hotel_name}}</strong> <span style="color:#6d7f96;">{{hotel_location}}</span> has been triggered.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f7f9fd;border:1px solid #e1e8f3;border-radius:16px;margin:0 0 16px;">
                                <tr>
                                    <td style="padding:16px 18px;">
                                        <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Target price:</strong> ₺{{target_price}}</p>
                                        <p style="margin:0 0 6px;font-size:14px;color:#2b3f58;"><strong>Matched price:</strong> ₺{{matched_price}}</p>
                                        <p style="margin:0;font-size:14px;color:#2b3f58;"><strong>Matched date:</strong> {{matched_date}}</p>
                                    </td>
                                </tr>
                            </table>

                            <a href="{{cta_reserve_link}}" style="display:inline-block;padding:12px 20px;border-radius:12px;background:#E30A17;color:#fff;text-decoration:none;font-weight:800;">Book now</a>
                            <a href="{{hotel_link}}" style="display:inline-block;margin-left:10px;padding:12px 16px;border-radius:12px;background:#eef2ff;color:#E30A17;text-decoration:none;font-weight:800;">Open hotel</a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
