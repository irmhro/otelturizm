<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify your email</title>
</head>
<body style="margin:0;padding:0;background:#F3F1ED;font-family:Arial,sans-serif;color:#1A1919;">
<div style="max-width:620px;margin:0 auto;padding:32px 16px;">
    <div style="background:#ffffff;border-radius:20px;padding:32px;border:1px solid #dbe4f0;">
        <p style="margin:0 0 12px;font-size:13px;font-weight:700;letter-spacing:.08em;color:#E30A17;">OTELTURIZM</p>
        <h1 style="margin:0 0 16px;font-size:28px;line-height:1.2;color:#1A1919;">Verify your email address</h1>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">Hi <strong>{{user_first_name}}</strong>,</p>
        <p style="margin:0 0 12px;font-size:16px;line-height:1.6;">To finish creating your account for <strong>{{user_email}}</strong>, use the code below or click the verification link.</p>
        <div style="margin:0 0 20px;padding:18px 24px;border-radius:16px;background:#FCFBF9;border:1px solid #EBE9E4;text-align:center;">
            <span style="display:block;font-size:34px;font-weight:800;letter-spacing:.18em;color:#E30A17;">{{verification_code}}</span>
        </div>
        <p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#6E6E77;">Sign-up time: {{registration_date}}</p>
        <p style="margin:0;">
            <a href="{{verification_link}}" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#E30A17;color:#ffffff;font-weight:700;text-decoration:none;">Verify email</a>
        </p>
    </div>
</div>
</body>
</html>

