<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Otelturizm · Booking request received</title>
</head>
<body style="margin:0;padding:0;background:#F3F1ED;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,Helvetica,Arial,sans-serif;color:#1A1919;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F3F1ED;padding:36px 12px;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:#FFFFFF;border-radius:24px;overflow:hidden;box-shadow:0 10px 34px rgba(15,23,42,0.10);">
                <tr>
                    <td style="background:#E30A17;padding:34px 28px;color:#ffffff;text-align:center;">
                        <div style="font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.92;font-weight:800;">Booking Center</div>
                        <div style="margin-top:10px;font-size:22px;font-weight:900;">We received your booking request</div>
                        <div style="margin-top:8px;font-size:14px;opacity:.92;">Your request is being reviewed. We'll update you soon.</div>
                    </td>
                </tr>
                <tr>
                    <td style="padding:28px;">
                        <p style="margin:0 0 12px;font-size:18px;">Hi <strong>{{user_first_name}}</strong>,</p>
                        <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                            Your booking request for <strong>{{hotel_name}}</strong> has been received. Your reference:
                            <strong style="font-size:18px;color:#E30A17;">#{{booking_reference}}</strong>
                        </p>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#FCFBF9;border:1px solid #EBE9E4;border-radius:16px;margin:0 0 16px;">
                            <tr>
                                <td style="padding:16px 16px;">
                                    <div style="font-size:12px;color:#6E6E77;text-transform:uppercase;letter-spacing:.08em;font-weight:800;">Booking details</div>
                                    <div style="margin-top:10px;font-size:14px;color:#1A1919;"><strong>Stay:</strong> {{check_in_date}} → {{check_out_date}}</div>
                                    <div style="margin-top:6px;font-size:14px;color:#1A1919;"><strong>Room:</strong> {{room_type_name}}</div>
                                    <div style="margin-top:6px;font-size:14px;color:#1A1919;"><strong>Total:</strong> ₺{{total_price}}</div>
                                    <div style="margin-top:6px;font-size:13px;color:#6E6E77;"><strong>Address:</strong> {{hotel_address}}</div>
                                </td>
                            </tr>
                        </table>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
                            <tr>
                                <td style="border-radius:999px;background:#E30A17;">
                                    <a href="{{booking_details_link}}" style="display:inline-block;padding:14px 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">View booking →</a>
                                </td>
                            </tr>
                        </table>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:rgba(255,184,0,0.10);border:1px solid rgba(255,184,0,0.35);border-radius:14px;">
                            <tr>
                                <td style="padding:14px 16px;font-size:13px;line-height:1.65;color:#6f4a00;">
                                    We'll send you another email once the hotel reviews your request.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td style="padding:18px 22px;background:#FCFBF9;border-top:1px solid #EBE9E4;color:#6E6E77;text-align:center;">
                        <p style="margin:0;font-size:12px;">24/7 support: destek@otelturizm.com</p>
                        <p style="margin:8px 0 0;font-size:12px;">© 2026 Otelturizm · N° de réservation : #{{booking_reference}}</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>

