@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Rezervasyon İptali *@
@* Preheader: Misafir rezervasyonu iptal etti *@
@* HeaderTagline: Partner Extranet *@
@* HeaderTitle: Misafir rezervasyonu iptal etti *@
@* HeaderSubtitle: İptal bilgileri ve sebep detayını panelinizde inceleyebilirsiniz *@
@* FooterLine1: Bu bildirim otomatik gönderilmiştir. *@
@* FooterLine2: Otelturizm Partner Ağı *@
@* FooterLegal: Lütfen yanıtlamayınız. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Sayın <strong>{{hotel_manager_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{hotel_name}}</strong> için oluşturulan rezervasyon misafir tarafından iptal edildi.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-card">
                                <tr>
                                    <td class="email-card__cell">
                                        <p class="email-card__label">Rezervasyon no</p>
                                        <p class="email-card__row"><span class="email-ref">#{{booking_reference}}</span></p>
                                        <p class="email-card__row"><strong>Misafir:</strong> {{guest_full_name}}</p>
                                        <p class="email-card__row"><strong>Tarih:</strong> {{check_in_date}} - {{check_out_date}}</p>
                                        <p class="email-card__row"><strong>Oda:</strong> {{room_type_name}}</p>
                                        <p class="email-card__row"><strong>Toplam:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-note email-note--danger">
                                <tr>
                                    <td class="email-note__cell">
                                        <strong>İptal sebebi:</strong> {{cancel_reason}}
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
