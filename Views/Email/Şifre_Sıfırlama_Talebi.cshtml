@* Layout: _EmailMaster *@
@* EmailTitle: Otelturizm · Şifre Sıfırlama *@
@* Preheader: Şifre sıfırlama bağlantınız hazır *@
@* HeaderTagline: Hesap Güvenliği *@
@* HeaderTitle: Şifre sıfırlama bağlantınız hazır *@
@* HeaderSubtitle: İşlem size aitse aşağıdaki bağlantıyla yeni şifrenizi oluşturabilirsiniz *@
@* FooterLine1: Bu işlemi siz yapmadıysanız bu e-postayı dikkate almayabilirsiniz. *@
@* FooterLine2: İstek IP: {{request_ip}} *@
@* FooterLegal: Bu e-posta bilgilendirme amaçlıdır. Yanıtlamayın. *@
                    <tr>
                        <td class="email-pad">
                            <p class="email-greeting">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p class="email-lead">
                                <strong>{{user_email}}</strong> hesabınız için bir şifre sıfırlama talebi aldık.
                            </p>
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="email-cta">
                                <tr>
                                    <td>
                                        <a href="{{reset_link}}" class="email-cta__btn">Şifremi sıfırla</a>
                                    </td>
                                </tr>
                            </table>
                            <p class="email-muted">İstek IP adresi: {{request_ip}}.</p>
                        </td>
                    </tr>
