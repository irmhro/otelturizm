@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["PageCss"] = "otel-listeleme";
}

<section class="listing-campaign-band">
    <div class="listing-category-grid">
        @foreach (var link in Model.QuickLinks)
        {
            <a href="@link.Url" class="listing-category-card">
                <div class="listing-category-icon"><i class="fas @link.IconClass"></i></div>
                <div class="listing-category-content">
                    <span class="listing-category-title">@link.Title</span>
                    <small class="listing-category-subtitle">@link.Subtitle</small>
                </div>
            </a>
        }
    </div>
</section>

<section class="listing-discover-band">
    <div class="listing-discover-head">
        <h3>Keşfet</h3>
        <p>Hızlı seçeneklerle aradığın deneyimi tek dokunuşla bul.</p>
    </div>
    <div class="listing-category-grid listing-discover-grid">
        <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-etiket="haftasonu-firsatlari" class="listing-category-card">
            <div class="listing-category-icon"><i class="fas fa-calendar-week"></i></div>
            <div class="listing-category-content">
                <span class="listing-category-title">Hafta Sonu Fırsatları</span>
                <small class="listing-category-subtitle">Kısa kaçamak için öne çıkan fırsatlar</small>
            </div>
        </a>
        <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-etiket="butcene-uygun" class="listing-category-card">
            <div class="listing-category-icon"><i class="fas fa-wallet"></i></div>
            <div class="listing-category-content">
                <span class="listing-category-title">Bütçene Uygun</span>
                <small class="listing-category-subtitle">Ekonomik fiyatlarla konforlu seçenekler</small>
            </div>
        </a>
        <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-etiket="yildiz-yagmuru" class="listing-category-card">
            <div class="listing-category-icon"><i class="fas fa-star"></i></div>
            <div class="listing-category-content">
                <span class="listing-category-title">Yıldız Yağmuru</span>
                <small class="listing-category-subtitle">Yüksek puanlı ve öne çıkan tesisler</small>
            </div>
        </a>
        <a asp-controller="Home" asp-action="Index" class="listing-category-card">
            <div class="listing-category-icon"><i class="fas fa-route"></i></div>
            <div class="listing-category-content">
                <span class="listing-category-title">Seyahat Planlaması</span>
                <small class="listing-category-subtitle">Rotanı oluştur, ideal konaklamayı seç</small>
            </div>
        </a>
    </div>
</section>

<section class="listing-header">
    <div class="listing-summary">
        <a asp-controller="Home" asp-action="Index" class="back-link"><i class="fas fa-arrow-left"></i> Keşfete Don</a>
        <div>
            <h2>@Model.SearchLabel için seçili oteller</h2>
            <p><i class="fas fa-calendar"></i> 15 Nis - 18 Nis · 2 Yetiskin, 1 Cocuk</p>
        </div>
    </div>
    <button type="button" class="listing-action-btn"><i class="fas fa-sliders-h"></i> Aramayi Duzenle</button>
</section>

<section class="results-layout" id="resultsLayout">
    <aside class="filter-sidebar">
        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterSort">
                <h3>Sıralama</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterSort">
                <label><input type="radio" name="sort" checked /> Önerilen</label>
                <label><input type="radio" name="sort" /> En düşük fiyat</label>
                <label><input type="radio" name="sort" /> En yüksek puan</label>
                <label><input type="radio" name="sort" /> Yıldız sayısı</label>
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterPrice">
                <h3>Fiyat Aralığı</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterPrice">
                <input type="range" min="0" max="25000" value="@(Model.MaxPrice > 0 ? Model.MaxPrice : 25000)" class="price-range" />
                <div class="price-input-row">
                    <input type="number" value="@(Model.MinPrice > 0 ? Model.MinPrice : 0)" placeholder="Min" />
                    <input type="number" value="@(Model.MaxPrice > 0 ? Model.MaxPrice : 25000)" placeholder="Max" />
                </div>
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterDistricts">
                <h3>İlçeler</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterDistricts">
                @foreach (var district in Model.Districts)
                {
                    <label><input type="checkbox" checked /> @district</label>
                }
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterStars">
                <h3>Yıldız Sayısı</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterStars">
                @foreach (var star in Model.StarOptions)
                {
                    <label><input type="checkbox" checked /> @star Yıldız</label>
                }
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterGuestScore">
                <h3>Misafir Puanı</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterGuestScore">
                <label><input type="checkbox" /> 9+ Mükemmel</label>
                <label><input type="checkbox" checked /> 8+ Çok İyi</label>
                <label><input type="checkbox" checked /> 7+ İyi</label>
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterPropertyType">
                <h3>Tesis Tipi</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterPropertyType">
                <label><input type="checkbox" checked /> Otel</label>
                <label><input type="checkbox" /> Butik Otel</label>
                <label><input type="checkbox" /> Bungalov</label>
                <label><input type="checkbox" /> Dağ Evi</label>
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterAmenities">
                <h3>Olanaklar</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterAmenities">
                <label><input type="checkbox" /> Ücretsiz WiFi</label>
                <label><input type="checkbox" /> Havuz</label>
                <label><input type="checkbox" /> Spa & Wellness</label>
                <label><input type="checkbox" /> Otopark</label>
            </div>
        </article>

        <article class="filter-card filter-accordion-item is-open">
            <button type="button" class="filter-head filter-toggle" data-accordion-target="filterConditions">
                <h3>Rezervasyon Koşulları</h3>
                <i class="fas fa-chevron-down"></i>
            </button>
            <div class="filter-body" id="filterConditions">
                <label><input type="checkbox" checked /> Ücretsiz iptal</label>
                <label><input type="checkbox" /> Şimdi öde, tesiste kal</label>
                <label><input type="checkbox" /> Kahvaltı dahil</label>
            </div>
        </article>
    </aside>

    <div class="results-listing">
        @if (Model.Hotels.Count == 0)
        {
            <div class="listing-empty-state">
                <h3>@Model.SearchLabel icin yayinda ve onayli otel bulunamadi</h3>
                <p>Listeleme ekraninin tasarima gore dolmasi icin `oteller` tablosunda sehir, yayin ve fiyat verilerinin hazir olmasi gerekiyor.</p>
            </div>
        }
        else
        {
            @foreach (var hotel in Model.Hotels)
            {
                <article class="hotel-card">
                    <div class="hotel-media @(string.IsNullOrWhiteSpace(hotel.ImageUrl) ? string.Empty : "has-image")">
                        @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                        {
                            <img src="@hotel.ImageUrl" alt="@hotel.Name" />
                        }
                        <button type="button" class="favorite-btn @(hotel.IsFavorite ? "active" : string.Empty)" data-hotel-id="@hotel.Id" data-source-page="OtelListeleme">
                            <i class="@(hotel.IsFavorite ? "fas" : "far") fa-heart"></i>
                        </button>
                    </div>

                    <div class="hotel-body">
                        <div class="hotel-topline">
                            <div>
                                <h2>@hotel.Name</h2>
                                <p class="hotel-location"><i class="fas fa-location-dot"></i> @hotel.District, @hotel.City</p>
                            </div>
                            <div class="hotel-score">
                                <span class="score-box">@(hotel.Rating > 0 ? hotel.Rating.ToString("0.0") : "-")</span>
                                <div>
                                    <strong>@hotel.RatingText</strong>
                                    <small>@(hotel.ReviewCount > 0 ? $"{hotel.ReviewCount} yorum" : "Yorum bekleniyor")</small>
                                </div>
                            </div>
                        </div>

                        <div class="amenity-row">
                            @foreach (var amenity in hotel.Amenities)
                            {
                                <span><i class="fas fa-check"></i> @amenity</span>
                            }
                        </div>

                        <div class="hotel-bottomline">
                            <div class="hotel-copy">
                                <div class="tag-row compact">
                                    @foreach (var tag in hotel.Tags)
                                    {
                                        <span class="hotel-tag">@tag</span>
                                    }
                                </div>
                            </div>
                            <div class="hotel-pricebox">
                                <strong>@(hotel.StartingPrice.HasValue ? $"₺{hotel.StartingPrice.Value:N0}" : "Teklif Al")</strong>
                                <span>@hotel.PriceNote</span>
                                <div class="card-actions">
                                    <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@hotel.Slug" class="secondary-link-btn">Oteli İncele</a>
                                    <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@hotel.Slug" class="primary-link-btn js-reservation-btn">Rezervasyon</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            }
        }
    </div>

    <div class="map-view-panel">
        <div class="map-card">
            <iframe
                title="Istanbul Otel Haritasi"
                src="https://www.openstreetmap.org/export/embed.html?bbox=28.9%2C40.98%2C29.22%2C41.15&layer=mapnik"
                loading="lazy"></iframe>
        </div>
    </div>
</section>

<button type="button" class="mobile-filter-btn"><i class="fas fa-sliders-h"></i> Filtrele (@Model.TotalCount otel)</button>

@section Scripts {
    <script>
        (function () {
            const layout = document.getElementById('resultsLayout');
            const accordionButtons = document.querySelectorAll('.filter-toggle');

            accordionButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const parent = button.closest('.filter-accordion-item');
                    parent?.classList.toggle('is-open');
                });
            });

            const hotelCards = document.querySelectorAll('.hotel-card');
            hotelCards.forEach(function (card) {
                const image = card.querySelector('.hotel-media img');
                const reservationBtn = card.querySelector('.js-reservation-btn');
                if (!image || !reservationBtn) {
                    return;
                }

                const setFallbackColor = function () {
                    reservationBtn.style.setProperty('--btn-dominant-color', '#1d4ed8');
                    reservationBtn.style.setProperty('--btn-dominant-color-dark', '#1e3a8a');
                };

                const applyDominantColor = function () {
                    try {
                        const canvas = document.createElement('canvas');
                        canvas.width = 1;
                        canvas.height = 1;
                        const context = canvas.getContext('2d');
                        if (!context) {
                            setFallbackColor();
                            return;
                        }

                        context.drawImage(image, 0, 0, 1, 1);
                        const pixel = context.getImageData(0, 0, 1, 1).data;
                        const color = 'rgb(' + pixel[0] + ', ' + pixel[1] + ', ' + pixel[2] + ')';
                        const darkR = Math.max(0, Math.round(pixel[0] * 0.72));
                        const darkG = Math.max(0, Math.round(pixel[1] * 0.72));
                        const darkB = Math.max(0, Math.round(pixel[2] * 0.72));
                        const darkColor = 'rgb(' + darkR + ', ' + darkG + ', ' + darkB + ')';
                        reservationBtn.style.setProperty('--btn-dominant-color', color);
                        reservationBtn.style.setProperty('--btn-dominant-color-dark', darkColor);
                    } catch (_error) {
                        setFallbackColor();
                    }
                };

                if (image.complete) {
                    applyDominantColor();
                } else {
                    image.addEventListener('load', applyDominantColor, { once: true });
                    image.addEventListener('error', setFallbackColor, { once: true });
                }
            });

            const mobileFilterBtn = document.querySelector('.mobile-filter-btn');
            mobileFilterBtn?.addEventListener('click', function () {
                const firstFilter = document.querySelector('.filter-sidebar');
                firstFilter?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                if (window.innerWidth <= 1180) {
                    layout.classList.remove('show-map');
                }
            });
        })();
    </script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}

