@using System.Globalization
@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["PageCss"] = "otel-listeleme";

    var hotels = Model.Hotels ?? new List<otelturizmnew.Models.Oteller.HotelListingCardViewModel>();
    var visibleCount = hotels.Count;
    var amenityCounts = hotels
        .SelectMany(x => x.Amenities)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .GroupBy(x => x, StringComparer.OrdinalIgnoreCase)
        .OrderByDescending(x => x.Count())
        .ThenBy(x => x.Key)
        .ToList();
    var topAmenities = amenityCounts.Take(10).ToList();
    var minPrice = Model.MinPrice > 0 ? Model.MinPrice : 0;
    var maxPrice = Model.MaxPrice > 0 ? Model.MaxPrice : 15000;
    var activeHeading = !string.IsNullOrWhiteSpace(Model.CampaignSlug) || !string.IsNullOrWhiteSpace(Model.ActiveTag)
        ? Model.CampaignTitle
        : "Oteller";

    string NormalizeToken(string value)
    {
        return (value ?? string.Empty)
            .Replace("ı", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("İ", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("Ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("Ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("Ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("Ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("ğ", "g", StringComparison.OrdinalIgnoreCase)
            .Replace("Ğ", "g", StringComparison.OrdinalIgnoreCase)
            .ToLowerInvariant()
            .Trim();
    }

    string BuildPageUrl(int targetPage)
    {
        var queryItems = new List<string>();
        foreach (var item in Context.Request.Query)
        {
            if (string.Equals(item.Key, "page", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var value = item.Value.ToString();
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            queryItems.Add($"{Uri.EscapeDataString(item.Key)}={Uri.EscapeDataString(value)}");
        }

        queryItems.Add($"page={targetPage.ToString(CultureInfo.InvariantCulture)}");
        return $"{Context.Request.Path}?{string.Join("&", queryItems)}";
    }
}

<section class="hotel-listing-shell listing-template-v41 listing-template-v52">
    <div class="listing-container">
        <header class="listing-hero-panel">
            <div class="listing-hero-copy">
                <a asp-controller="Home" asp-action="Index" class="listing-back-link">
                    <i class="fas fa-arrow-left"></i>
                    <span>Anasayfaya don</span>
                </a>
                <span class="listing-hero-eyebrow">Canli veritabani listeleme</span>
                <h1>@activeHeading</h1>
                <p>@Model.CampaignDescription</p>
            </div>

            <div class="listing-hero-stats">
                <div class="listing-stat-card">
                    <strong>@Model.TotalCount</strong>
                    <span>Toplam tesis</span>
                </div>
                <div class="listing-stat-card">
                    <strong>@Math.Max(Model.TotalPages, 1)</strong>
                    <span>Sayfa adedi</span>
                </div>
                <div class="listing-stat-card">
                    <strong>@Model.CurrentPage / @Math.Max(Model.TotalPages, 1)</strong>
                    <span>Aktif sayfa</span>
                </div>
            </div>
        </header>

        <section class="listing-toolbar-bar">
            <div>
                <h2>@(string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Tum bolgeler" : Model.SearchLabel)</h2>
                <p id="listingResultsSummary">@Model.TotalCount tesis bulundu. Sayfa basi @Model.PageSize tesis gosteriliyor.</p>
            </div>

            <div class="listing-toolbar-actions">
                <button type="button" class="listing-toolbar-filter-btn" data-open-mobile-filters>
                    <i class="fas fa-sliders-h"></i>
                    <span>Filtreler</span>
                </button>

                <label class="listing-sortbox" for="listingSortSelect">
                    <span>Sirala</span>
                    <select id="listingSortSelect" class="sort-select">
                        <option value="recommended">Onerilen</option>
                        <option value="price-asc">En dusuk fiyat</option>
                        <option value="price-desc">En yuksek fiyat</option>
                        <option value="rating-desc">En yuksek puan</option>
                        <option value="name-asc">A-Z</option>
                    </select>
                </label>
            </div>
        </section>

        <div class="listing-results-grid listing-results-grid-v52">
            <aside class="listing-filter-sidebar filter-sidebar" id="listingFilterSidebar">
                <div class="filter-panel filter-card">
                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Hizli arama</h3>
                        </div>
                        <input type="search" id="listingKeywordFilter" class="listing-text-filter" placeholder="Otel, ilce, mahalle veya kampanya ara" value="@Model.SearchTerm" />
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Konum</h3>
                        </div>
                        <div class="listing-filter-stack">
                            <select id="listingCityFilter" class="listing-select-filter">
                                <option value="">Tum iller</option>
                                @foreach (var city in Model.Cities)
                                {
                                    <option value="@NormalizeToken(city)">@city</option>
                                }
                            </select>

                            <select id="listingDistrictFilter" class="listing-select-filter">
                                <option value="">Tum ilceler</option>
                                @foreach (var district in Model.Districts)
                                {
                                    <option value="@NormalizeToken(district)">@district</option>
                                }
                            </select>

                            <select id="listingNeighborhoodFilter" class="listing-select-filter">
                                <option value="">Tum mahalleler</option>
                                @foreach (var neighborhood in Model.Neighborhoods)
                                {
                                    <option value="@NormalizeToken(neighborhood)">@neighborhood</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Kampanyalar</h3>
                            <span>@Model.Campaigns.Count</span>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var campaign in Model.Campaigns.Take(8))
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-campaign-filter" value="@NormalizeToken(campaign.Slug)" @(campaign.IsActive ? "checked" : null) />
                                    <span>@campaign.Name</span>
                                    <strong>@campaign.HotelCount</strong>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Fiyat araligi</h3>
                            <span>Gecelik</span>
                        </div>
                        <input type="range" min="0" max="@(Math.Max(maxPrice, 15000))" value="@maxPrice" class="filter-range" id="listingPriceMaxRange" />
                        <div class="filter-price-grid price-range">
                            <label>
                                <span>Min</span>
                                <input type="number" id="listingMinPriceInput" value="@minPrice" />
                            </label>
                            <label>
                                <span>Max</span>
                                <input type="number" id="listingMaxPriceInput" value="@maxPrice" />
                            </label>
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Konaklama tipi</h3>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var propertyType in Model.PropertyTypes)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-property-filter" value="@NormalizeToken(propertyType)" />
                                    <span>@propertyType</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Yildiz sayisi</h3>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var star in Model.StarOptions)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-star-filter" value="@star" />
                                    <span>@star yildiz</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Misafir puani</h3>
                        </div>
                        <div class="rating-chip-list">
                            <button type="button" class="rating-chip" data-min-score="9">9+ Muhtesem</button>
                            <button type="button" class="rating-chip" data-min-score="8">8+ Cok iyi</button>
                            <button type="button" class="rating-chip" data-min-score="7">7+ Iyi</button>
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Otel ozellikleri</h3>
                            <span>@topAmenities.Count</span>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var amenity in topAmenities)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-amenity-filter" value="@NormalizeToken(amenity.Key)" />
                                    <span>@amenity.Key</span>
                                    <strong>@amenity.Count()</strong>
                                </label>
                            }
                        </div>
                    </div>

                    <button type="button" class="listing-reset-btn" id="listingResetFiltersBtn">Tum filtreleri sifirla</button>
                </div>
            </aside>

            <div class="listing-results-column">
                @if (Model.TotalCount == 0)
                {
                    <div class="listing-empty-state">
                        <div class="listing-empty-icon">
                            <i class="fas fa-bed"></i>
                        </div>
                        <h2>Filtreye uygun tesis bulunamadi</h2>
                        <p>`oteller`, `kampanyalar`, `kampanya_oteller`, `oda_tipleri`, `oda_fiyat_musaitlik` ve `otel_gorselleri` verileri ile tekrar deneyin.</p>
                    </div>
                }
                else
                {
                    <div class="hotel-card-list hotel-list" id="hotelListView">
                        @foreach (var hotel in hotels)
                        {
                            var amenityTokens = string.Join(' ', hotel.Amenities.Select(NormalizeToken));
                            var campaignTokens = string.Join(' ', hotel.CampaignSlugs.Select(NormalizeToken));
                            var locationText = string.IsNullOrWhiteSpace(hotel.Neighborhood)
                                ? $"{hotel.District}, {hotel.City}"
                                : $"{hotel.Neighborhood}, {hotel.District}, {hotel.City}";

                            <article class="hotel-card listing-hotel-card"
                                     data-keywords="@NormalizeToken($"{hotel.Name} {hotel.City} {hotel.District} {hotel.Neighborhood} {string.Join(' ', hotel.CampaignNames)}")"
                                     data-city="@NormalizeToken(hotel.City)"
                                     data-district="@NormalizeToken(hotel.District)"
                                     data-neighborhood="@NormalizeToken(hotel.Neighborhood)"
                                     data-property="@NormalizeToken(hotel.PropertyType)"
                                     data-campaigns="@campaignTokens"
                                     data-amenities="@amenityTokens"
                                     data-featured="@(hotel.IsFeatured ? "1" : "0")"
                                     data-price="@(hotel.StartingPrice ?? 0m)"
                                     data-rating="@hotel.Rating.ToString(CultureInfo.InvariantCulture)"
                                     data-stars="@(hotel.StarCount ?? 0)">
                                <div class="card-image hotel-card-media">
                                    @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                                    {
                                        <img src="@hotel.ImageUrl" alt="@hotel.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="hotel-card-placeholder">
                                            <i class="fas fa-image"></i>
                                            <span>Gorsel bekleniyor</span>
                                        </div>
                                    }

                                    <div class="hotel-card-badges card-badges">
                                        @if (hotel.IsFeatured)
                                        {
                                            <span class="hotel-badge hotel-badge-highlight">
                                                <i class="fas fa-bolt"></i>
                                                One cikan
                                            </span>
                                        }
                                        @if (hotel.CampaignNames.Count > 0)
                                        {
                                            <span class="hotel-badge hotel-badge-discount">
                                                <i class="fas fa-tag"></i>
                                                @hotel.CampaignNames.First()
                                            </span>
                                        }
                                    </div>

                                    <button type="button"
                                            class="favorite-btn wishlist-btn @(hotel.IsFavorite ? "active" : string.Empty)"
                                            data-hotel-id="@hotel.Id"
                                            data-source-page="OtelListeleme"
                                            aria-label="Favorilere ekle">
                                        <i class="@(hotel.IsFavorite ? "fas" : "far") fa-heart"></i>
                                    </button>
                                </div>

                                <div class="card-content hotel-card-content">
                                    <div class="hotel-card-main">
                                        <div class="hotel-card-header">
                                            <div>
                                                <div class="hotel-card-meta">
                                                    @hotel.PropertyType
                                                </div>
                                                <h2 class="hotel-card-title-with-stars">
                                                    @hotel.Name
                                                    @if (hotel.StarCount.HasValue && hotel.StarCount.Value > 0)
                                                    {
                                                        <span class="hotel-card-stars-inline" aria-hidden="true">
                                                            @for (var i = 0; i < hotel.StarCount.Value; i++)
                                                            {
                                                                <text>★</text>
                                                            }
                                                        </span>
                                                        <span class="sr-only">@($"{hotel.StarCount.Value} yıldızlı otel")</span>
                                                    }
                                                </h2>
                                                <p class="hotel-card-location">
                                                    <i class="fas fa-location-dot"></i>
                                                    @locationText
                                                </p>
                                            </div>

                                            <div class="hotel-score-box">
                                                <strong>@(hotel.Rating > 0 ? hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture) : "0.0")</strong>
                                                <span>@hotel.RatingText</span>
                                                <small>@hotel.ReviewCount yorum</small>
                                            </div>
                                        </div>

                                        <p class="hotel-card-summary">@hotel.Summary</p>

                                        <div class="features hotel-feature-list">
                                            @foreach (var amenity in hotel.Amenities.Take(4))
                                            {
                                                <span class="feature-tag hotel-feature-chip">@amenity</span>
                                            }
                                        </div>

                                        @if (hotel.CampaignNames.Count > 0)
                                        {
                                            <div class="hotel-campaign-strip">
                                                @foreach (var campaignName in hotel.CampaignNames.Take(3))
                                                {
                                                    <span class="hotel-tag-pill">@campaignName</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="price-section hotel-card-footer">
                                        <div class="price-info hotel-price-area">
                                            <span class="hotel-price-caption">@hotel.PriceNote</span>
                                            <div class="hotel-price-row">
                                                <strong>@(hotel.StartingPrice.HasValue ? $"₺{hotel.StartingPrice.Value:N0}" : "Teklif Al")</strong>
                                            </div>
                                        </div>

                                        <div class="hotel-card-actions">
                                            <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@hotel.Slug" class="btn-detail hotel-link-btn">Oteli incele</a>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="listing-filter-empty" id="listingFilterEmpty" hidden>
                        <i class="fas fa-filter-circle-xmark"></i>
                        <strong>Secili filtrelere uygun tesis bulunamadi</strong>
                        <span>Kriterleri yumusatip tekrar deneyebilirsiniz.</span>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="listing-pagination" aria-label="Sayfalama">
                            @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
                            {
                                <a href="@BuildPageUrl(pageIndex)" class="listing-page-link @(pageIndex == Model.CurrentPage ? "active" : string.Empty)">@pageIndex</a>
                            }
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</section>

<div class="listing-mobile-actions">
    <button type="button" class="listing-mobile-btn" data-open-mobile-filters>
        <i class="fas fa-sliders-h"></i>
        <span>Filtrele</span>
    </button>
</div>

<div class="listing-mobile-filter-modal" id="listingMobileFilterModal" hidden>
    <div class="listing-mobile-filter-backdrop" data-close-mobile-filters></div>
    <div class="listing-mobile-filter-sheet">
        <div class="listing-mobile-filter-head">
            <div>
                <h3>Gelismis filtreler</h3>
                <p>@Model.TotalCount tesisi hizlica daraltin</p>
            </div>
            <button type="button" class="listing-mobile-close" data-close-mobile-filters aria-label="Kapat">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="listing-mobile-filter-body">
            <input type="search" id="listingKeywordFilterMobile" class="listing-text-filter" placeholder="Otel, ilce, mahalle veya kampanya ara" value="@Model.SearchTerm" />

            <select id="listingCityFilterMobile" class="listing-select-filter">
                <option value="">Tum iller</option>
                @foreach (var city in Model.Cities)
                {
                    <option value="@NormalizeToken(city)">@city</option>
                }
            </select>

            <select id="listingDistrictFilterMobile" class="listing-select-filter">
                <option value="">Tum ilceler</option>
                @foreach (var district in Model.Districts)
                {
                    <option value="@NormalizeToken(district)">@district</option>
                }
            </select>

            <select id="listingNeighborhoodFilterMobile" class="listing-select-filter">
                <option value="">Tum mahalleler</option>
                @foreach (var neighborhood in Model.Neighborhoods)
                {
                    <option value="@NormalizeToken(neighborhood)">@neighborhood</option>
                }
            </select>
        </div>

        <button type="button" class="listing-mobile-apply" data-close-mobile-filters>Sonuclari goster</button>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const mobileFilterModal = document.getElementById('listingMobileFilterModal');
            const cards = Array.from(document.querySelectorAll('.listing-hotel-card'));
            const cardList = document.getElementById('hotelListView');
            const emptyState = document.getElementById('listingFilterEmpty');
            const summary = document.getElementById('listingResultsSummary');
            const sortSelect = document.getElementById('listingSortSelect');
            const desktopKeyword = document.getElementById('listingKeywordFilter');
            const mobileKeyword = document.getElementById('listingKeywordFilterMobile');
            const desktopCity = document.getElementById('listingCityFilter');
            const mobileCity = document.getElementById('listingCityFilterMobile');
            const desktopDistrict = document.getElementById('listingDistrictFilter');
            const mobileDistrict = document.getElementById('listingDistrictFilterMobile');
            const desktopNeighborhood = document.getElementById('listingNeighborhoodFilter');
            const mobileNeighborhood = document.getElementById('listingNeighborhoodFilterMobile');
            const minPriceInput = document.getElementById('listingMinPriceInput');
            const maxPriceInput = document.getElementById('listingMaxPriceInput');
            const maxPriceRange = document.getElementById('listingPriceMaxRange');
            const starFilters = document.querySelectorAll('.listing-star-filter');
            const amenityFilters = document.querySelectorAll('.listing-amenity-filter');
            const propertyFilters = document.querySelectorAll('.listing-property-filter');
            const campaignFilters = document.querySelectorAll('.listing-campaign-filter');
            const ratingChips = document.querySelectorAll('.rating-chip');
            const resetButton = document.getElementById('listingResetFiltersBtn');

            function openFilters() {
                if (!mobileFilterModal) {
                    return;
                }

                mobileFilterModal.hidden = false;
                document.body.classList.add('listing-modal-open');
            }

            function closeFilters() {
                if (!mobileFilterModal) {
                    return;
                }

                mobileFilterModal.hidden = true;
                document.body.classList.remove('listing-modal-open');
            }

            function syncInput(source, target) {
                if (!source || !target) {
                    return;
                }

                target.value = source.value;
            }

            function updateSummary(visibleCount) {
                if (!summary) {
                    return;
                }

                summary.textContent = visibleCount + ' tesis gosteriliyor. Sayfa basi ' + @Model.PageSize + ' tesis planlandi.';
            }

            function getNormalizedValue(primary, secondary) {
                if (primary && primary.value) {
                    return primary.value.toLowerCase();
                }

                if (secondary && secondary.value) {
                    return secondary.value.toLowerCase();
                }

                return '';
            }

            function sortVisibleCards(visibleCards) {
                if (!cardList || !sortSelect) {
                    return;
                }

                const mode = sortSelect.value;
                const sorted = visibleCards.slice().sort(function (a, b) {
                    const priceA = Number(a.dataset.price || '0');
                    const priceB = Number(b.dataset.price || '0');
                    const ratingA = Number(a.dataset.rating || '0');
                    const ratingB = Number(b.dataset.rating || '0');
                    const nameA = (a.querySelector('h2')?.textContent || '').trim();
                    const nameB = (b.querySelector('h2')?.textContent || '').trim();

                    if (mode === 'price-asc') return priceA - priceB;
                    if (mode === 'price-desc') return priceB - priceA;
                    if (mode === 'rating-desc') return ratingB - ratingA;
                    if (mode === 'name-asc') return nameA.localeCompare(nameB, 'tr');
                    return ratingB - ratingA;
                });

                sorted.forEach(function (card) {
                    cardList.appendChild(card);
                });
            }

            function applyFilters() {
                if (!cards.length) {
                    return;
                }

                const keyword = getNormalizedValue(desktopKeyword, mobileKeyword);
                const city = getNormalizedValue(desktopCity, mobileCity);
                const district = getNormalizedValue(desktopDistrict, mobileDistrict);
                const neighborhood = getNormalizedValue(desktopNeighborhood, mobileNeighborhood);
                const minPrice = Number(minPriceInput?.value || '0');
                const maxPrice = Number(maxPriceInput?.value || maxPriceRange?.value || '0');
                const selectedStars = Array.from(starFilters).filter(x => x.checked).map(x => x.value);
                const selectedAmenities = Array.from(amenityFilters).filter(x => x.checked).map(x => x.value.toLowerCase());
                const selectedProperties = Array.from(propertyFilters).filter(x => x.checked).map(x => x.value.toLowerCase());
                const selectedCampaigns = Array.from(campaignFilters).filter(x => x.checked).map(x => x.value.toLowerCase());
                const minScore = Array.from(ratingChips)
                    .filter(x => x.classList.contains('active'))
                    .map(x => Number(x.dataset.minScore || '0'))
                    .reduce((max, value) => Math.max(max, value), 0);

                const visibleCards = [];

                cards.forEach(function (card) {
                    const cardPrice = Number(card.dataset.price || '0');
                    const cardStars = String(card.dataset.stars || '0');
                    const cardRating = Number(card.dataset.rating || '0');
                    const keywords = (card.dataset.keywords || '').toLowerCase();
                    const amenities = (card.dataset.amenities || '').toLowerCase();
                    const campaigns = (card.dataset.campaigns || '').toLowerCase();
                    const property = (card.dataset.property || '').toLowerCase();

                    const matchesKeyword = !keyword || keywords.indexOf(keyword) > -1;
                    const matchesCity = !city || (card.dataset.city || '') === city;
                    const matchesDistrict = !district || (card.dataset.district || '') === district;
                    const matchesNeighborhood = !neighborhood || (card.dataset.neighborhood || '') === neighborhood;
                    const matchesPrice = cardPrice >= minPrice && (maxPrice <= 0 || cardPrice <= maxPrice);
                    const matchesStars = !selectedStars.length || selectedStars.includes(cardStars);
                    const matchesAmenities = !selectedAmenities.length || selectedAmenities.every(x => amenities.indexOf(x) > -1);
                    const matchesProperty = !selectedProperties.length || selectedProperties.includes(property);
                    const matchesCampaigns = !selectedCampaigns.length || selectedCampaigns.every(x => campaigns.indexOf(x) > -1);
                    const matchesRating = minScore <= 0 || cardRating >= minScore;

                    const shouldShow = matchesKeyword
                        && matchesCity
                        && matchesDistrict
                        && matchesNeighborhood
                        && matchesPrice
                        && matchesStars
                        && matchesAmenities
                        && matchesProperty
                        && matchesCampaigns
                        && matchesRating;

                    card.hidden = !shouldShow;
                    if (shouldShow) {
                        visibleCards.push(card);
                    }
                });

                sortVisibleCards(visibleCards);
                if (emptyState) {
                    emptyState.hidden = visibleCards.length !== 0;
                }
                updateSummary(visibleCards.length);
            }

            document.querySelectorAll('[data-open-mobile-filters]').forEach(function (button) {
                button.addEventListener('click', openFilters);
            });

            document.querySelectorAll('[data-close-mobile-filters]').forEach(function (button) {
                button.addEventListener('click', closeFilters);
            });

            sortSelect?.addEventListener('change', applyFilters);
            desktopKeyword?.addEventListener('input', function () {
                syncInput(desktopKeyword, mobileKeyword);
                applyFilters();
            });
            mobileKeyword?.addEventListener('input', function () {
                syncInput(mobileKeyword, desktopKeyword);
                applyFilters();
            });
            desktopCity?.addEventListener('change', function () {
                syncInput(desktopCity, mobileCity);
                applyFilters();
            });
            mobileCity?.addEventListener('change', function () {
                syncInput(mobileCity, desktopCity);
                applyFilters();
            });
            desktopDistrict?.addEventListener('change', function () {
                syncInput(desktopDistrict, mobileDistrict);
                applyFilters();
            });
            mobileDistrict?.addEventListener('change', function () {
                syncInput(mobileDistrict, desktopDistrict);
                applyFilters();
            });
            desktopNeighborhood?.addEventListener('change', function () {
                syncInput(desktopNeighborhood, mobileNeighborhood);
                applyFilters();
            });
            mobileNeighborhood?.addEventListener('change', function () {
                syncInput(mobileNeighborhood, desktopNeighborhood);
                applyFilters();
            });

            minPriceInput?.addEventListener('input', applyFilters);
            maxPriceInput?.addEventListener('input', function () {
                if (maxPriceRange) {
                    maxPriceRange.value = maxPriceInput.value;
                }
                applyFilters();
            });
            maxPriceRange?.addEventListener('input', function () {
                if (maxPriceInput) {
                    maxPriceInput.value = maxPriceRange.value;
                }
                applyFilters();
            });

            starFilters.forEach(function (item) { item.addEventListener('change', applyFilters); });
            amenityFilters.forEach(function (item) { item.addEventListener('change', applyFilters); });
            propertyFilters.forEach(function (item) { item.addEventListener('change', applyFilters); });
            campaignFilters.forEach(function (item) { item.addEventListener('change', applyFilters); });
            ratingChips.forEach(function (item) {
                item.addEventListener('click', function () {
                    item.classList.toggle('active');
                    applyFilters();
                });
            });

            resetButton?.addEventListener('click', function () {
                desktopKeyword.value = '';
                if (mobileKeyword) mobileKeyword.value = '';
                if (desktopCity) desktopCity.value = '';
                if (mobileCity) mobileCity.value = '';
                if (desktopDistrict) desktopDistrict.value = '';
                if (mobileDistrict) mobileDistrict.value = '';
                if (desktopNeighborhood) desktopNeighborhood.value = '';
                if (mobileNeighborhood) mobileNeighborhood.value = '';
                if (minPriceInput) minPriceInput.value = '0';
                if (maxPriceInput) maxPriceInput.value = '@maxPrice';
                if (maxPriceRange) maxPriceRange.value = '@maxPrice';
                starFilters.forEach(function (item) { item.checked = false; });
                amenityFilters.forEach(function (item) { item.checked = false; });
                propertyFilters.forEach(function (item) { item.checked = false; });
                campaignFilters.forEach(function (item) { item.checked = false; });
                ratingChips.forEach(function (item) { item.classList.remove('active'); });
                applyFilters();
            });

            applyFilters();
        })();
    </script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}
