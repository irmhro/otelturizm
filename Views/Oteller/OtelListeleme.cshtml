            async function initializeLocationPermissionState() {
                const persistedLocation = readPersistedLocationSnapshot();
                if (persistedLocation) {
                    userLocation = {
                        lat: persistedLocation.lat,
                        lon: persistedLocation.lon,
                        accuracy: persistedLocation.accuracy,
                        approximate: !!persistedLocation.approximate,
                        source: String(persistedLocation.source || '')
                    };
                    if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                    if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                    enableDistanceFilterUi(true);
                    ensureDistanceControlsEnabled();
                    syncDistanceUi();
                    setLocationCoords(userLocation.lat, userLocation.lon, userLocation.accuracy);
                    setDistanceHotelCount(cards.filter(card => !card.hidden).length, true);
                    setLocationInsight('Yakındaki otelleri görmek için yarıçapı ayarlayabilirsin.');
                }

                if (!('permissions' in navigator) || !navigator.permissions?.query) {
                    setLocationPermissionState(persistedLocation
                        ? (persistedLocation.approximate ? 'approximate' : 'granted')
                        : 'prompt');
                    setLocationStatus(persistedLocation
                        ? 'Konum hazır.'
                        : 'Konumunu paylaş.');
                    return;
                }

                try {
                    const permissionStatus = await navigator.permissions.query({ name: 'geolocation' });
                    const syncState = function () {
                        if (userLocation && Number.isFinite(userLocation.lat) && Number.isFinite(userLocation.lon)) {
                            enableDistanceFilterUi(true);
                            ensureDistanceControlsEnabled();
                            setLocationPermissionState(userLocation.approximate ? 'approximate' : 'granted');
                            setLocationStatus(userLocation.approximate ? 'Yaklaşık konum hazır.' : 'Konum hazır.');
                            return;
                        }

                        if (permissionStatus.state === 'granted') {
                            setLocationPermissionState(userLocation?.approximate ? 'approximate' : 'granted');
                            setLocationStatus(persistedLocation
                                ? 'Konum hazır.'
                                : 'İzin verip konumunu kullan.');
                            enableDistanceFilterUi(true);
                            ensureDistanceControlsEnabled();
                            if (!userLocation || !persistedLocation) {
                                requestUserLocation();
                            }
                            return;
                        }

                        if (permissionStatus.state === 'denied') {
                            if (persistedLocation && userLocation) {
                                setLocationPermissionState(userLocation.approximate ? 'approximate' : 'granted');
                                setLocationStatus('Son doğrulanan konumun hazır. Daha hassas sonuç için tarayıcı konum iznini açabilirsiniz.');
                                enableDistanceFilterUi(true);
                                ensureDistanceControlsEnabled();
                                return;
                            }

                            setLocationPermissionState('prompt');
                            userLocation = null;
                            enableDistanceFilterUi(false);
                            setLocationCoords(NaN, NaN);
                            clearPersistedLocationSnapshot();
                            setLocationStatus('Konum izni kapalıysa yaklaşık konumla devam edebiliriz. Konumu kullan butonuna tekrar dokunun.');
                            return;
                        }

                        setLocationPermissionState(persistedLocation ? 'granted' : 'prompt');
                        setLocationStatus(persistedLocation
                            ? 'Konum hazır.'
                            : 'Konumunu paylaş.');
                    };

                    syncState();
                    permissionStatus.onchange = syncState;
                } catch (_) {
                    setLocationPermissionState('prompt');
                }
            }

