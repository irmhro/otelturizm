      white-space: normal;
      word-break: break-word;
  }
  .star-filter-option {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
      min-height: 42px;
      padding: 0 2px;
  }
  .star-filter-option input { margin: 0; }
  .star-filter-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
  }
