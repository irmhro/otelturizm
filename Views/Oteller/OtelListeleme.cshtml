      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #dbeafe 35%, #60a5fa 100%);
      border: 2px solid rgba(0,59,149,0.55);
      box-shadow: 0 12px 26px rgba(0,59,149,0.28), 0 0 0 6px rgba(0,59,149,0.12);
      cursor: pointer;
  }
  .price-slider-labels {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
      margin-top: 16px;
      color: var(--text-light);
      font-size: 12px;
      font-weight: 700;
  }
  .price-slider-labels span:nth-child(1) { text-align: left; }
  .price-slider-labels span:nth-child(2),
  .price-slider-labels span:nth-child(3) { text-align: center; }
  .price-slider-labels span:nth-child(4) { text-align: right; }
</style>

<section class="hotel-listing-shell listing-template-v41">
    <div class="listing-container">
        <div class="mobile-filter-bar" id="mobileFilterBar">
            <button type="button" class="mobile-filter-bar-btn" id="mobileFilterBarBtn" aria-haspopup="dialog" aria-controls="listingFilterModal">
                <span class="mobile-filter-bar-left">
                    <span class="mobile-filter-bar-icon" aria-hidden="true"><i class="fas fa-sliders"></i></span>
                    <span class="mobile-filter-bar-meta">
                        <span>Filtreler</span>
                        <small>Aramayı özelleştir</small>
                    </span>
                </span>
                <span class="mobile-filter-bar-count" id="mobileFilterCount" hidden>0</span>
            </button>
        </div>
        <div class="results-container">
            <aside class="filter-sidebar">
                <div class="filter-card" id="listingFilterCard">
                    <details class="filter-accordion" open>
                        <summary class="filter-accordion-summary">
                            <span>Gelişmiş Arama</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="listing-search-lux">
                                <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                                <input type="text" id="listingKeywordInput" placeholder="Otel adı / il / ilçe / mahalle">
                                <button type="button" class="listing-search-clear" id="listingKeywordClear" aria-label="Aramayı temizle" hidden>
                                    <i class="fas fa-xmark" aria-hidden="true"></i>
                                </button>
                            </div>
                            <p class="filter-help">İl, ilçe, mahalle veya otel adı ile arayabilirsiniz.</p>
                        </div>
                    </details>

                    <details class="filter-accordion" open>
                        <summary class="filter-accordion-summary">
                            <span>Fiyat Aralığı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="price-slider-wrap">
                                <div class="price-slider-track" aria-hidden="true">
                                    <span class="price-slider-dot" data-price-dot="0"></span>
                                    <span class="price-slider-dot" data-price-dot="1"></span>
                                    <span class="price-slider-dot" data-price-dot="2"></span>
                                    <span class="price-slider-dot" data-price-dot="3"></span>
                                </div>
                                <input type="range"
                                       min="@Math.Floor(minPrice)"
                                       max="@Math.Ceiling(maxPrice)"
                                       value="@maxPrice"
                                       step="1"
                                       id="listingPriceMaxRange"
                                       aria-label="Maksimum fiyat" />
                                <div class="price-slider-labels" aria-hidden="true">
                                    <span id="priceStep0"></span>
                                    <span id="priceStep1"></span>
                                    <span id="priceStep2"></span>
                                    <span id="priceStep3"></span>
                                </div>
                            </div>
                            <div class="price-range">
                                <input type="number" placeholder="Min ₺" value="@minPrice" id="listingMinPriceInput">
                                <input type="number" placeholder="Max ₺" value="@maxPrice" id="listingMaxPriceInput">
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Yıldız Sayısı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                @foreach (var star in Model.StarOptions.OrderByDescending(x => x))
                                {
                                    var count = hotels.Count(h => (h.StarCount ?? 0) == star);
                                    <label class="filter-check"><input type="checkbox" class="listing-star-filter" value="@star"> @star Yıldız <span style="margin-left:auto; color:var(--text-light);">@count</span></label>
                                }
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Misafir Puanı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="rating-stars">
                                <span class="rating-chip" data-min-score="9">9+ Muhteşem</span>
                                <span class="rating-chip" data-min-score="8">8+ Çok İyi</span>
                                <span class="rating-chip" data-min-score="7">7+ İyi</span>
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Popüler Filtreler</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                @foreach (var amenity in amenityCounts.Take(5))
                                {
                                    <label class="filter-check"><input type="checkbox" class="listing-amenity-filter" value="@NormalizeToken(amenity.Key)"> @amenity.Key</label>
                                }
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Özel Konseptler</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                <label class="filter-check"><input type="checkbox" class="listing-featured-filter" value="1"> En İyi Fiyat</label>
                                <label class="filter-check"><input type="checkbox" class="listing-featured-filter" value="1"> Kampanyalı</label>
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Sıralama</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <select class="sort-select" id="listingSortSelect" style="width:100%;">
                                <option value="recommended">Önerilen</option>
                                <option value="price-asc">En Düşük Fiyat</option>
                                <option value="rating-desc">En Yüksek Puan</option>
                            </select>
                        </div>
                    </details>

                    <button type="button" class="btn-detail" id="clearAllFiltersBtn" style="width:100%;">Tüm Filtreleri Temizle</button>
                </div>
            </aside>

            <div class="hotel-list" id="hotelListView">
                @if (!hotels.Any())
                {
                    <div class="hotel-card">
                        <div class="card-content">
                            <div class="hotel-header">
                                <h3 class="hotel-name">Filtreye uygun tesis bulunamadı</h3>
                            </div>
                            <div class="hotel-location"><i class="fas fa-map-pin"></i> Arama kriterlerini değiştirip tekrar deneyin.</div>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var hotel in hotels)
                    {
                        var price = hotel.StartingPrice ?? 0m;
                        var oldPrice = price > 0m ? Math.Round(price * 1.18m, 0) : 0m;
                        var discountRate = oldPrice > 0m ? (int)Math.Round((1m - (price / oldPrice)) * 100m, MidpointRounding.AwayFromZero) : 0;
                        var amenityText = string.Join(" ", hotel.Amenities.Select(NormalizeToken));
                        var keywords = NormalizeToken($"{hotel.Name} {hotel.City} {hotel.District} {hotel.Neighborhood} {hotel.PropertyType} {string.Join(" ", hotel.CampaignNames)} {string.Join(" ", hotel.Amenities)}");
                        var locationText = string.IsNullOrWhiteSpace(hotel.Neighborhood)
                            ? $"{hotel.District} · {hotel.City}"
                            : $"{hotel.Neighborhood} · {hotel.District}";
                        <article class="hotel-card listing-hotel-card"
                                 data-keywords="@keywords"
                                 data-price="@price.ToString(CultureInfo.InvariantCulture)"
                                 data-rating="@hotel.Rating.ToString(CultureInfo.InvariantCulture)"
                                 data-stars="@(hotel.StarCount ?? 0)"
                                 data-amenities="@amenityText"
                                 data-featured="@(hotel.IsFeatured ? "1" : "0")">
                            <div class="card-image">
                                @{
                                    var images = (hotel.GalleryImages?.Count ?? 0) > 0
                                        ? hotel.GalleryImages
                                        : new List<string> { hotel.ImageUrl };
                                    var mainCardImage = images.FirstOrDefault();
                                    var side1 = images.Count > 1 ? images[1] : mainCardImage;
                                    var side2 = images.Count > 2 ? images[2] : side1;
                                }
                                <a asp-controller="Oteller"
                                   asp-action="OtelDetay"
                                   asp-route-slug="@hotel.Slug"
                                   class="card-image-link"
                                   aria-label="@hotel.Name detay sayfasına git">
                                    <div class="card-image-grid">
                                        <img class="card-image-main" src="@(string.IsNullOrWhiteSpace(mainCardImage) ? "/assets/img/placeholder-hotel.jpg" : mainCardImage)" alt="@hotel.Name">
                                        <div class="card-image-side">
                                            <img src="@(string.IsNullOrWhiteSpace(side1) ? "/assets/img/placeholder-hotel.jpg" : side1)" alt="@hotel.Name görsel 2">
                                            <img src="@(string.IsNullOrWhiteSpace(side2) ? "/assets/img/placeholder-hotel.jpg" : side2)" alt="@hotel.Name görsel 3">
                                        </div>
                                    </div>
                                </a>
                                <span class="image-rating" aria-label="Misafir puanı">
                                    @hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture) <i class="fas fa-star" aria-hidden="true"></i>
                                </span>
                                <div class="card-badge-top-left">
                                    @{
                                        var pillCount = 0;
                                        var priceKeyDistrict = NormalizeToken(hotel.District ?? string.Empty);
                                        var priceKeyNeighborhood = NormalizeToken(hotel.Neighborhood ?? string.Empty);
                                        var isBestNeighborhood = (price > 0m)
                                            && !string.IsNullOrWhiteSpace(priceKeyNeighborhood)
                                            && neighborhoodMinPrice.TryGetValue(priceKeyNeighborhood, out var bestN)
                                            && price <= bestN;
                                        var isBestDistrict = (price > 0m)
                                            && !string.IsNullOrWhiteSpace(priceKeyDistrict)
                                            && districtMinPrice.TryGetValue(priceKeyDistrict, out var bestD)
                                            && price <= bestD;

                                        var hasFlash = hotel.CampaignSlugs.Any(x => string.Equals(x, "flash-indirim", StringComparison.OrdinalIgnoreCase));
                                        var hasEarly = hotel.CampaignSlugs.Any(x => string.Equals(x, "erken-rezervasyon", StringComparison.OrdinalIgnoreCase));
                                        var hasWeekend = string.Equals(Model.ActiveTag, "hafta-sonu-firsatlari", StringComparison.OrdinalIgnoreCase)
                                                         || hotel.CampaignSlugs.Any(x => string.Equals(x, "hafta-sonu-firsatlari", StringComparison.OrdinalIgnoreCase));
                                        var isBudget = string.Equals(Model.ActiveTag, "butceme-uygun-oteller", StringComparison.OrdinalIgnoreCase) || (price > 0m && price <= 4000m);
                                        var isCampaign = hotel.CampaignSlugs.Count > 0;

                                        if (isBestNeighborhood && pillCount < 4)
                                        {
                                            <span class="listing-pill best"><i class="fas fa-location-dot"></i> Mahallede En Uygun</span>;
                                            pillCount++;
                                        }
                                        else if (isBestDistrict && pillCount < 4)
                                        {
                                            <span class="listing-pill best"><i class="fas fa-location-dot"></i> İlçede En Uygun</span>;
                                            pillCount++;
                                        }

                                        if (hotel.IsFeatured && pillCount < 4)
                                        {
                                            <span class="listing-pill fav"><i class="fas fa-award"></i> Misafir Favorisi</span>;
                                            pillCount++;
                                        }

                                        if (hasFlash && pillCount < 4)
                                        {
                                            <span class="listing-pill flash"><i class="fas fa-bolt"></i> FLASH</span>;
                                            pillCount++;
                                        }

                                        if (hasWeekend && pillCount < 4)
                                        {
                                            <span class="listing-pill weekend"><i class="fas fa-calendar-week"></i> Hafta Sonu</span>;
                                            pillCount++;
                                        }

                                        if (isBudget && pillCount < 4)
                                        {
                                            <span class="listing-pill budget"><i class="fas fa-wallet"></i> Bütçe Dostu</span>;
                                            pillCount++;
                                        }

                                        if (hasEarly && pillCount < 4)
                                        {
                                            <span class="listing-pill early"><i class="fas fa-clock"></i> Erken Rez.</span>;
                                            pillCount++;
                                        }

                                        if (discountRate > 0 && pillCount < 4)
                                        {
                                            <span class="listing-pill discount"><i class="fas fa-tag"></i> %@discountRate İndirim</span>;
                                            pillCount++;
                                        }

                                        if (isCampaign && pillCount < 4)
                                        {
                                            <span class="listing-pill"><i class="fas fa-badge-percent"></i> Kampanyalı</span>;
                                            pillCount++;
                                        }
                                    }
                                </div>
                                <button type="button"
                                        class="wishlist-btn favorite-btn @(hotel.IsFavorite ? "active" : string.Empty)"
                                        data-hotel-id="@hotel.Id"
                                        data-source-page="OtelListeleme"
                                        aria-label="Favorilere ekle">
                                    <i class="@(hotel.IsFavorite ? "fas" : "far") fa-heart"></i>
                                </button>
                            </div>
                            <div class="card-content">
                                <div>
                                    <div class="hotel-header">
                                        <h3 class="hotel-name">@hotel.Name</h3>
                                        <span class="hotel-rating">@hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture) <i class="fas fa-star" style="font-size:10px;"></i></span>
                                    </div>
                                    <div class="hotel-location"><i class="fas fa-map-pin"></i> @locationText</div>
                                    <div class="features features-compact">
                                        @foreach (var amenity in hotel.Amenities.Take(2))
                                        {
                                            <span class="feature-tag"><i class="fas fa-check"></i> @amenity</span>
                                        }
                                        @if (hotel.Amenities.Count > 2)
                                        {
                                            var amenitiesJson = System.Text.Json.JsonSerializer.Serialize(hotel.Amenities);
                                            <button type="button"
                                                    class="feature-more-btn"
                                                    data-amenities='@Html.Raw(amenitiesJson)'
                                                    data-hotel-name="@hotel.Name">
                                                Diğer özellikler
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="price-section">
                                    <div class="price-info">
                                        <span class="current-price">@(price > 0m ? $"₺{price:N0}" : "Teklif Al")</span>
                                        @if (oldPrice > 0m)
                                        {
                                            <span class="old-price">₺@oldPrice.ToString("N0", CultureInfo.GetCultureInfo("tr-TR"))</span>
                                        }
                                        <span style="font-size:13px; color:var(--text-gray);">/ gece</span>
                                    </div>
                                    <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@hotel.Slug" class="btn-detail">İncele</a>
                                </div>
                            </div>
                        </article>
                    }
                }
            </div>

        </div>
    </div>
</section>

<div class="filter-modal" id="listingFilterModal" aria-hidden="true" role="dialog" aria-label="Filtreler">
    <div class="modal-overlay" id="listingFilterModalOverlay"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h3>Filtreler</h3>
            <button type="button" class="close-modal" id="listingFilterModalClose" aria-label="Kapat">×</button>
        </div>
        <div id="listingMobileFilterHost"></div>
        <button type="button" class="apply-btn" id="listingFilterApplyBtn">Uygula</button>
    </div>
</div>

<div class="filter-modal" id="listingAmenitiesModal" aria-hidden="true" role="dialog" aria-label="Otel özellikleri">
    <div class="modal-overlay" id="listingAmenitiesOverlay"></div>
    <div class="modal-content amenity-modal-content">
        <div class="modal-header">
            <h3 id="listingAmenitiesTitle">Özellikler</h3>
            <button type="button" class="close-modal" id="listingAmenitiesClose" aria-label="Kapat">×</button>
        </div>
        <div class="amenity-modal-list" id="listingAmenitiesList"></div>
        <button type="button" class="apply-btn" id="listingAmenitiesOk">Tamam</button>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const listView = document.getElementById('hotelListView');
            const sortSelect = document.getElementById('listingSortSelect');
            const keywordInput = document.getElementById('listingKeywordInput');
            const minPriceInput = document.getElementById('listingMinPriceInput');
            const maxPriceInput = document.getElementById('listingMaxPriceInput');
            const maxPriceRange = document.getElementById('listingPriceMaxRange');
            const cards = Array.from(document.querySelectorAll('.listing-hotel-card'));
            const amenityChecks = Array.from(document.querySelectorAll('.listing-amenity-filter'));
            const starChecks = Array.from(document.querySelectorAll('.listing-star-filter'));
            const ratingChips = Array.from(document.querySelectorAll('.rating-chip'));
            const featuredChecks = Array.from(document.querySelectorAll('.listing-featured-filter'));
            const clearAllBtn = document.getElementById('clearAllFiltersBtn');
            const keywordClearBtn = document.getElementById('listingKeywordClear');

            function normalize(v) {
                return String(v || '').toLocaleLowerCase('tr-TR');
            }

            function formatTry(amount) {
                const n = Number(amount || 0);
                if (!Number.isFinite(n)) return '₺0';
                return '₺' + Math.round(n).toLocaleString('tr-TR');
            }

            function syncPriceSteps() {
                const min = Number(minPriceInput?.value || '0');
                const max = Number(maxPriceRange?.max || maxPriceInput?.value || '0');
                if (!Number.isFinite(max) || max <= 0) return;
                const a = Math.max(0, Math.min(min, max));
                const b = max;
                const s1 = a + (b - a) * 0.33;
                const s2 = a + (b - a) * 0.66;
                const step0 = document.getElementById('priceStep0');
                const step1 = document.getElementById('priceStep1');
                const step2 = document.getElementById('priceStep2');
                const step3 = document.getElementById('priceStep3');
                if (step0) step0.textContent = formatTry(a);
                if (step1) step1.textContent = formatTry(s1);
                if (step2) step2.textContent = formatTry(s2);
                if (step3) step3.textContent = formatTry(b);
            }

            function syncPriceSliderVisual() {
                if (!maxPriceRange) return;
                const min = Number(maxPriceRange.min || '0');
                const max = Number(maxPriceRange.max || '0');
                const val = Number(maxPriceRange.value || '0');
                const pct = max > min ? ((val - min) / (max - min)) * 100 : 100;
                const wrap = maxPriceRange.closest('.price-slider-wrap');
                if (wrap) wrap.style.setProperty('--slider-pos', Math.max(0, Math.min(100, pct)).toFixed(2) + '%');
            }

            function applyFilters() {
                const keyword = normalize(keywordInput?.value || '');
                const minPrice = Number(minPriceInput?.value || '0');
                const maxPrice = Number(maxPriceInput?.value || '0');
                const selectedAmenities = amenityChecks.filter(x => x.checked).map(x => normalize(x.value));
                const selectedStars = starChecks.filter(x => x.checked).map(x => String(x.value));
                const featuredOnly = featuredChecks.some(x => x.checked);
                const minScore = ratingChips
                    .filter(x => x.classList.contains('active'))
                    .map(x => Number(x.dataset.minScore || '0'))
                    .reduce((acc, v) => Math.max(acc, v), 0);

                cards.forEach(function (card) {
                    const cardPrice = Number(card.dataset.price || '0');
                    const cardStars = String(card.dataset.stars || '0');
                    const cardRating = Number(card.dataset.rating || '0');
                    const cardKeywords = normalize(card.dataset.keywords || '');
                    const cardAmenities = normalize(card.dataset.amenities || '');
                    const isFeatured = (card.dataset.featured || '0') === '1';

                    const keywordOk = !keyword || cardKeywords.indexOf(keyword) > -1;
                    const priceOk = cardPrice >= minPrice && (maxPrice <= 0 || cardPrice <= maxPrice);
                    const starOk = selectedStars.length === 0 || selectedStars.includes(cardStars);
                    const ratingOk = minScore <= 0 || cardRating >= minScore;
                    const amenityOk = selectedAmenities.length === 0 || selectedAmenities.every(x => cardAmenities.indexOf(x) > -1);
                    const featuredOk = !featuredOnly || isFeatured;

                    card.hidden = !(keywordOk && priceOk && starOk && ratingOk && amenityOk && featuredOk);
                });
            }

            if (keywordClearBtn && keywordInput) {
                keywordClearBtn.hidden = String(keywordInput.value || '').trim().length === 0;
            }

            function sortCards() {
                if (!sortSelect || !listView) return;
                const mode = sortSelect.value;
                const visible = cards.filter(card => !card.hidden);
                visible.sort(function (a, b) {
                    const priceA = Number(a.dataset.price || '0');
                    const priceB = Number(b.dataset.price || '0');
                    const scoreA = Number(a.dataset.rating || '0');
                    const scoreB = Number(b.dataset.rating || '0');
                    if (mode === 'price-asc') return priceA - priceB;
                    if (mode === 'rating-desc') return scoreB - scoreA;
                    return scoreB - scoreA;
                });
                visible.forEach(card => listView.appendChild(card));
            }

            sortSelect?.addEventListener('change', sortCards);
            keywordInput?.addEventListener('input', function () {
                applyFilters();
                sortCards();
                if (keywordClearBtn) keywordClearBtn.hidden = String(keywordInput.value || '').trim().length === 0;
                syncMobileFilterCount();
            });
            keywordClearBtn?.addEventListener('click', function () {
                if (!keywordInput) return;
                keywordInput.value = '';
                keywordClearBtn.hidden = true;
                applyFilters();
                sortCards();
                syncMobileFilterCount();
                keywordInput.focus();
            });
            minPriceInput?.addEventListener('input', function () {
                applyFilters();
                sortCards();
                syncPriceSteps();
                syncPriceSliderVisual();
                syncMobileFilterCount();
            });
            maxPriceInput?.addEventListener('input', function () {
                if (maxPriceRange) maxPriceRange.value = maxPriceInput.value;
                applyFilters();
                sortCards();
                syncPriceSliderVisual();
                syncMobileFilterCount();
            });
            maxPriceRange?.addEventListener('input', function () {
                if (maxPriceInput) maxPriceInput.value = maxPriceRange.value;
                applyFilters();
                sortCards();
                syncPriceSliderVisual();
                syncMobileFilterCount();
            });

            const filterCard = document.getElementById('listingFilterCard');
            const barBtn = document.getElementById('mobileFilterBarBtn');
            const modal = document.getElementById('listingFilterModal');
            const modalOverlay = document.getElementById('listingFilterModalOverlay');
            const modalClose = document.getElementById('listingFilterModalClose');
            const modalHost = document.getElementById('listingMobileFilterHost');
            const modalApply = document.getElementById('listingFilterApplyBtn');
            const desktopSidebar = document.querySelector('.filter-sidebar');
            const filterCount = document.getElementById('mobileFilterCount');

            function openMobileFilters() {
                if (!modal || !modalHost || !filterCard) return;
                modal.classList.add('active');
                modal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
                if (filterCard.parentElement !== modalHost) {
                    modalHost.appendChild(filterCard);
                }
            }

            function closeMobileFilters() {
                if (!modal) return;
                modal.classList.remove('active');
                modal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
                if (desktopSidebar && filterCard && filterCard.parentElement !== desktopSidebar) {
                    desktopSidebar.appendChild(filterCard);
                }
            }

            barBtn?.addEventListener('click', openMobileFilters);
            modalOverlay?.addEventListener('click', closeMobileFilters);
            modalClose?.addEventListener('click', closeMobileFilters);
            modalApply?.addEventListener('click', closeMobileFilters);

            window.addEventListener('resize', function () {
                if (window.innerWidth > 900) {
                    closeMobileFilters();
                }
            });
            amenityChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            starChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            featuredChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            ratingChips.forEach(function (chip) {
                chip.addEventListener('click', function () {
                    chip.classList.toggle('active');
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                });
            });

            clearAllBtn?.addEventListener('click', function () {
                amenityChecks.forEach(x => x.checked = false);
                starChecks.forEach(x => x.checked = false);
                featuredChecks.forEach(x => x.checked = false);
                ratingChips.forEach(x => x.classList.remove('active'));
                if (keywordInput) keywordInput.value = '';
                if (minPriceInput) minPriceInput.value = '0';
                if (maxPriceInput) maxPriceInput.value = '@maxPrice.ToString(CultureInfo.InvariantCulture)';
                if (maxPriceRange) maxPriceRange.value = '@maxPrice.ToString(CultureInfo.InvariantCulture)';
                applyFilters();
                sortCards();
                syncPriceSteps();
                syncPriceSliderVisual();
                syncMobileFilterCount();
            });

            function syncMobileFilterCount() {
                if (!filterCount) return;
                const active =
                    (amenityChecks.filter(x => x.checked).length)
                    + (starChecks.filter(x => x.checked).length)
                    + (featuredChecks.filter(x => x.checked).length)
                    + (ratingChips.filter(x => x.classList.contains('active')).length)
                    + ((String(keywordInput?.value || '').trim().length > 0) ? 1 : 0)
                    + ((Number(minPriceInput?.value || '0') > 0) ? 1 : 0)
                    + ((Number(maxPriceInput?.value || '0') > 0 && Number(maxPriceInput?.value || '0') < Number(maxPriceRange?.max || '0')) ? 1 : 0);

                filterCount.textContent = String(active);
                filterCount.hidden = active <= 0;
            }

            const amenitiesModal = document.getElementById('listingAmenitiesModal');
            const amenitiesOverlay = document.getElementById('listingAmenitiesOverlay');
            const amenitiesClose = document.getElementById('listingAmenitiesClose');
            const amenitiesOk = document.getElementById('listingAmenitiesOk');
            const amenitiesTitle = document.getElementById('listingAmenitiesTitle');
            const amenitiesList = document.getElementById('listingAmenitiesList');

            function openAmenitiesModal(hotelName, amenities) {
                if (!amenitiesModal || !amenitiesList) return;
                amenitiesTitle.textContent = (hotelName || 'Otel') + ' • Özellikler';
                const items = Array.isArray(amenities) ? amenities : [];
                amenitiesList.innerHTML = items
                    .filter(x => String(x || '').trim().length > 0)
                    .map(x => '<div class="amenity-modal-item"><i class="fas fa-circle-check"></i><span>' + String(x).replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span></div>')
                    .join('');
                amenitiesModal.classList.add('active');
                amenitiesModal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }

            function closeAmenitiesModal() {
                if (!amenitiesModal) return;
                amenitiesModal.classList.remove('active');
                amenitiesModal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }

            document.querySelectorAll('.feature-more-btn[data-amenities]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    let payload = [];
                    try {
                        payload = JSON.parse(btn.getAttribute('data-amenities') || '[]');
                    } catch { payload = []; }
                    openAmenitiesModal(btn.getAttribute('data-hotel-name') || '', payload);
                });
            });
            amenitiesOverlay?.addEventListener('click', closeAmenitiesModal);
            amenitiesClose?.addEventListener('click', closeAmenitiesModal);
            amenitiesOk?.addEventListener('click', closeAmenitiesModal);

            applyFilters();
            sortCards();
            syncPriceSteps();
            syncPriceSliderVisual();
            syncMobileFilterCount();
        })();
    </script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}
