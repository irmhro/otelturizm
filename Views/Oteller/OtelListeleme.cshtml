@using System.Globalization
@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["PageCss"] = "otel-listeleme";
    ViewData["PageCssMobile"] = "otel-listeleme.mobile";
    ViewData["SuppressGlobalDraftBanner"] = true;
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Oteller" : Model.SearchLabel;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    ViewData["Canonical"] = $"{baseUrl}/oteller";
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.SearchLabel)
        ? "Türkiye genelinde otelleri filtreleyin, fiyatları karşılaştırın ve güvenle rezervasyon oluşturun."
        : $"{Model.SearchLabel} için otelleri filtreleyin, fiyatları karşılaştırın ve güvenle rezervasyon oluşturun.";
    try
    {
        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Oteller", ["item"] = $"{baseUrl}/oteller" }
            }
        };
        ViewData["JsonLd"] = System.Text.Json.JsonSerializer.Serialize(breadcrumbJsonLd);
    }
    catch { }

    var hotels = Model.Hotels ?? new List<otelturizmnew.Models.Oteller.HotelListingCardViewModel>();
    var pricedHotels = hotels.Where(x => (x.StartingPrice ?? 0m) > 0m).ToList();
    var computedMin = pricedHotels.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Min();
    var computedMax = pricedHotels.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Max();
    // Fiyat araligi: sayfadaki 7 otel yerine, mümkünse servis tarafindan gelen global max'ı baz al.
    // Böylece kullanıcı manuel max değeri (örn. 4424) yazabilir.
    // Yeni istek: 0'dan baslamasın; otel fiyatlarına göre min->max oluştur.
    var priceBoundMin = computedMin > 0m ? computedMin : (Model.MinPrice > 0m ? Model.MinPrice : 0m);
    var priceBoundMax = computedMax > 0m ? computedMax : (Model.MaxPrice > 0m ? Model.MaxPrice : 0m);
    var hasValidPriceRange = priceBoundMin > 0m && priceBoundMax > 0m && priceBoundMax >= priceBoundMin;
    var minPrice = hasValidPriceRange ? priceBoundMin : 0m;
    var maxPrice = hasValidPriceRange ? priceBoundMax : 0m;
    var titleText = string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Oteller" : Model.SearchLabel;
    var cityText = string.IsNullOrWhiteSpace(Model.City) ? titleText : Model.City;
    var amenityCounts = hotels
        .SelectMany(h => h.Amenities ?? new List<string>())
        .Where(a => !string.IsNullOrWhiteSpace(a))
        .GroupBy(a => a, StringComparer.OrdinalIgnoreCase)
        .OrderByDescending(g => g.Count())
        .ThenBy(g => g.Key)
        .Take(12)
        .ToList();

    string NormalizeToken(string value)
    {
        return (value ?? string.Empty)
            .Replace("ı", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("İ", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("Ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("Ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("Ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("Ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("ğ", "g", StringComparison.OrdinalIgnoreCase)
            .Replace("Ğ", "g", StringComparison.OrdinalIgnoreCase)
            .ToLowerInvariant()
            .Trim();
    }

    var districtMinPrice = hotels
        .Where(h => (h.StartingPrice ?? 0m) > 0m && !string.IsNullOrWhiteSpace(h.District))
        .GroupBy(h => NormalizeToken(h.District))
        .ToDictionary(g => g.Key, g => g.Min(x => x.StartingPrice ?? decimal.MaxValue), StringComparer.OrdinalIgnoreCase);

    var neighborhoodMinPrice = hotels
        .Where(h => (h.StartingPrice ?? 0m) > 0m && !string.IsNullOrWhiteSpace(h.Neighborhood))
        .GroupBy(h => NormalizeToken(h.Neighborhood))
        .ToDictionary(g => g.Key, g => g.Min(x => x.StartingPrice ?? decimal.MaxValue), StringComparer.OrdinalIgnoreCase);
}

