            id="listingYanbarFilterBtn"
            aria-haspopup="dialog"
            aria-controls="listingFilterModal"
            aria-label="Filtreleri aç">
        <i class="fas fa-sliders" aria-hidden="true"></i>
        <span class="listing-yanbar-filter__pulse" aria-hidden="true"></span>
    </button>
    <div class="mobile-filter-bar" id="mobileFilterBar">
        <div class="mobile-filter-bar-inner">
            <nav class="mobile-filter-dock" aria-label="Hızlı filtreler">
                <button type="button" class="dock-btn" data-mobile-filter-target="search" aria-haspopup="dialog" aria-controls="listingFilterModal">
                    <span class="dock-ico dock-ico-search" aria-hidden="true">
                        <span class="dock-scan" aria-hidden="true"></span>
                        <i class="fas fa-magnifying-glass"></i>
                    </span>
                    <span class="dock-txt">Ara</span>
                </button>
                <button type="button" class="dock-btn" data-mobile-filter-target="all" aria-haspopup="dialog" aria-controls="listingFilterModal">
                    <span class="dock-ico dock-ico-all" aria-hidden="true"><i class="fas fa-sliders"></i></span>
                    <span class="dock-txt">Filtreler</span>
                </button>
            </nav>
        </div>
    </div>
    <div class="listing-container">
        <div class="results-container">
            <aside class="filter-sidebar">
                <div class="filter-card" id="listingFilterCard">
                    <a class="listing-map-cta listing-map-cta--button" href="@mapListingUrl" aria-label="Harita sayfasını aç">
                        <i class="fas fa-map-location-dot" aria-hidden="true"></i>
                        <span>Harita</span>
                    </a>

                    <details class="filter-accordion" id="filterSearch" open>
                        <summary class="filter-accordion-summary">
                            <span>Gelişmiş Arama</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="listing-search-lux">
                                <input type="text" id="listingKeywordInput" placeholder="Otel adı / il / ilçe / mahalle">
                                <button type="button" class="listing-search-clear" id="listingKeywordClear" aria-label="Aramayı temizle" hidden>
                                    <i class="fas fa-xmark" aria-hidden="true"></i>
                                </button>
                                <i class="fas fa-magnifying-glass listing-search-icon-right" aria-hidden="true"></i>
                                <div class="listing-search-suggestions" id="listingKeywordSuggestions" hidden></div>
                            </div>
                            <p class="filter-help">İl/ilçe/mahalle veya otel adı ile arayın.</p>
                        </div>
                    </details>

                    @* Fiyat aralığı + konuma göre ara kaldırıldı (kilitlenme sorunları nedeniyle) *@

                    <details class="filter-accordion" open>
                        <summary class="filter-accordion-summary">
                            <span>Sıralama</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <select class="sort-select" id="listingSortSelect" style="width:100%;">
                                <option value="recommended">Önerilen</option>
                                <option value="price-asc">En Düşük Fiyat</option>
                                <option value="rating-desc">En Yüksek Puan</option>
                            </select>
                        </div>
                    </details>

                    <details class="filter-accordion" id="filterRating" open>
                        <summary class="filter-accordion-summary">
                            <span>Misafir Puanı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="rating-stars">
                                <span class="rating-chip" data-min-score="9">9+ Muhteşem</span>
                                <span class="rating-chip" data-min-score="8">8+ Çok İyi</span>
                                <span class="rating-chip" data-min-score="7">7+ İyi</span>
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion" id="filterMeals" open>
                        <summary class="filter-accordion-summary">
                            <span>Yemek Planı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options" aria-label="Yemek filtreleri">
                                @foreach (var meal in mealFilters)
                                {
                                    var mealActive = string.Equals(Model.ActiveTag, meal.Slug, StringComparison.OrdinalIgnoreCase);
                                    <label class="filter-check">
                                        <input type="checkbox"
                                               class="listing-meal-filter"
                                               value="@meal.Slug"
                                               data-amenity-token="@meal.AmenityToken"
                                               @(mealActive ? "checked" : null)>
                                        <span class="filter-check-text">@meal.Label</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion" open>
                        <summary class="filter-accordion-summary">
                            <span>Popüler Filtreler</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                @foreach (var amenity in amenityCounts.Take(5))
                                {
                                    <label class="filter-check"><input type="checkbox" class="listing-amenity-filter" value="@NormalizeToken(amenity.Key)"> @amenity.Key</label>
                                }
                            </div>
                        </div>
                    </details>

                    <details class="filter-accordion" open>
                        <summary class="filter-accordion-summary">
                            <span>Özel Konseptler</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                <label class="filter-check"><input type="checkbox" class="listing-featured-filter" value="1"> En İyi Fiyat</label>
                                <label class="filter-check"><input type="checkbox" class="listing-featured-filter" value="1"> Kampanyalı</label>
                            </div>
                        </div>
                    </details>
                    <details class="filter-accordion" id="filterCampaigns" open>
                        <summary class="filter-accordion-summary">
                            <span>Kampanyalar</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            @if (campaignFilters.Count == 0)
                            {
                                <small class="text-muted">Yayında kampanya bulunamadı.</small>
                            }
                            else
                            {
                                <div class="filter-options campaign-filter-scroll" aria-label="Kampanya filtreleri">
                                    @foreach (var campaign in campaignFilters)
                                    {
                                        <label class="filter-check">
                                            <input type="checkbox"
                                                   class="listing-campaign-filter"
                                                   value="@campaign.Slug"
                                                   @(campaign.IsActive ? "checked" : null)>
                                            <span class="filter-check-text">@campaign.Name</span>
                                        </label>
                                    }
                                </div>
                            }
                        </div>
                    </details>

                    <details class="filter-accordion">
                        <summary class="filter-accordion-summary">
                            <span>Yıldız Sayısı</span>
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </summary>
                        <div class="filter-accordion-body">
                            <div class="filter-options">
                                  @foreach (var star in Model.StarOptions.OrderByDescending(x => x))
                                  {
                                      var count = hotels.Count(h => (h.StarCount ?? 0) == star);
                                      <label class="filter-check star-filter-option">
                                          <input type="checkbox" class="listing-star-filter" value="@star">
                                          <span class="star-filter-label">
                                              <span class="star-filter-visual" aria-hidden="true">
                                                  @for (var starIcon = 0; starIcon < star; starIcon++)
                                                  {
                                                      <i class="fas fa-star"></i>
                                                  }
                                              </span>
                                              <span class="star-filter-text">@star yıldız</span>
                                          </span>
                                          <span class="star-filter-count">@count</span>
                                      </label>
                                  }
                              </div>
                          </div>
                      </details>

                    <button type="button" class="btn-detail" id="clearAllFiltersBtn" style="width:100%;">Tüm Filtreleri Temizle</button>
                </div>
            </aside>

            <div class="listing-main">
            <nav class="listing-concept-bar" aria-label="Özel konseptler">
                <p class="listing-concept-bar__title">
                    <i class="fas fa-star" aria-hidden="true"></i>
                    <span>Özel Konseptler · Hızlı Filtrele</span>
                </p>
                <div class="listing-concept-bar__track">
                    @foreach (var concept in conceptFilters)
                    {
                        var conceptActive = string.Equals(Model.ActiveTag, concept.Slug, StringComparison.OrdinalIgnoreCase);
                        <a class="listing-concept-btn @concept.Modifier @(conceptActive ? "is-active" : null)"
                           href="@BuildConceptFilterUrl(concept.Slug)">
                            <i class="fas @concept.Icon" aria-hidden="true"></i>
                            <span>@concept.Label</span>
                        </a>
                    }
                    <a class="listing-concept-btn campaign-alt"
                       href="/kampanyalar"
                       @(Context.Request.Path.StartsWithSegments("/kampanyalar", StringComparison.OrdinalIgnoreCase) ? "aria-current=\"page\"" : null)>
                        <i class="fas fa-bullhorn" aria-hidden="true"></i>
                        <span>Tüm Kampanyalar</span>
                    </a>
                </div>
            </nav>
            <div class="filter-sort-bar" aria-label="Hızlı yemek filtreleri">
                <div class="quick-filters">
                    @foreach (var meal in mealFilters)
                    {
                        var mealQuickActive = string.Equals(Model.ActiveTag, meal.Slug, StringComparison.OrdinalIgnoreCase);
                        <a class="quick-filter-btn @(mealQuickActive ? "active" : null)"
                           href="@BuildMealFilterUrl(meal.Slug)"
                           data-meal-slug="@meal.Slug">
                            <i class="fas @meal.Icon" aria-hidden="true"></i>
                            <span>@meal.Label</span>
                        </a>
                    }
                </div>
            </div>
            <div class="listing-reel-viewport" id="listingReelViewport">
            <div class="hotel-list" id="hotelListView">
                <div class="listing-cards" id="listingCards">
                    @if (!hotels.Any())
                    {
                        <div class="listing-empty-state" id="listingServerEmptyState" role="status" aria-live="polite">
                            <div class="listing-empty-icon" aria-hidden="true"><i class="fas fa-hotel"></i></div>
                            <h2>Şu an listelenecek tesis yok</h2>
                            <p>Arama veya bölge kriterlerini genişletin; haritada da keşfedebilirsiniz.</p>
                            <div class="listing-empty-actions">
                                <a class="btn-detail listing-empty-action" href="@Url.Action("OtelListeleme", "Oteller")">Tüm oteller</a>
                                <a class="listing-map-launch-btn listing-empty-action" href="@mapListingUrl">Haritada ara</a>
                            </div>
                        </div>
                    }
                    else
                    {
                    @foreach (var hotel in hotels)
                    {
                        var price = hotel.StartingPrice ?? 0m;
                        var isFirstListingCard = hotels.Count > 0 && ReferenceEquals(hotel, hotels[0]);
                        var amenitiesSafe = hotel.Amenities ?? new List<string>();
                        var campaignSlugsSafe = hotel.CampaignSlugs ?? new List<string>();
                        var campaignNamesSafe = hotel.CampaignNames ?? new List<string>();
                        var amenityText = string.Join(" ", amenitiesSafe.Select(NormalizeToken));
                        var keywords = NormalizeToken($"{hotel.Name} {hotel.City} {hotel.District} {hotel.Neighborhood} {hotel.PropertyType} {string.Join(" ", campaignNamesSafe)} {string.Join(" ", amenitiesSafe)}");
                        var locationText = string.IsNullOrWhiteSpace(hotel.Neighborhood)
                            ? $"{hotel.District} · {hotel.City}"
                            : $"{hotel.Neighborhood} · {hotel.District}";
                        var priceKeyDistrict = NormalizeToken(hotel.District ?? string.Empty);
                        var priceKeyNeighborhood = NormalizeToken(hotel.Neighborhood ?? string.Empty);
                        var isBestNeighborhood = (price > 0m)
                            && !string.IsNullOrWhiteSpace(priceKeyNeighborhood)
                            && neighborhoodMinPrice.TryGetValue(priceKeyNeighborhood, out var bestN)
                            && price <= bestN;
                        var isBestDistrict = (price > 0m)
                            && !string.IsNullOrWhiteSpace(priceKeyDistrict)
                            && districtMinPrice.TryGetValue(priceKeyDistrict, out var bestD)
                            && price <= bestD;

                        var hasEarly = campaignSlugsSafe.Any(x => string.Equals(x, "erken-rezervasyon", StringComparison.OrdinalIgnoreCase));
                        var hasWeekend = string.Equals(Model.ActiveTag, "hafta-sonu-firsatlari", StringComparison.OrdinalIgnoreCase)
                                         || campaignSlugsSafe.Any(x => string.Equals(x, "hafta-sonu-firsatlari", StringComparison.OrdinalIgnoreCase));
                        var isBudget = string.Equals(Model.ActiveTag, "butceme-uygun-oteller", StringComparison.OrdinalIgnoreCase) || (price > 0m && price <= 4000m);
                        var isCampaign = campaignSlugsSafe.Count > 0;
                        var hasDiscount = hotel.HasDiscount;
                        var showFreeCancelBadge = hotel.HasFreeCancellation
                            || (!string.IsNullOrWhiteSpace(hotel.HotelCode)
                                && hotel.HotelCode.StartsWith("ORK", StringComparison.OrdinalIgnoreCase));
                        <article class="hotel-card listing-hotel-card @(hotel.HasDiscount ? "has-discount" : null)"
                                 data-hotel-id="@hotel.Id"
                                 data-keywords="@keywords"
                                 data-price="@price.ToString(CultureInfo.InvariantCulture)"
                                 data-rating="@hotel.Rating.ToString(CultureInfo.InvariantCulture)"
                                 data-stars="@(hotel.StarCount ?? 0)"
                                 data-lat="@(hotel.Latitude?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                                 data-lon="@(hotel.Longitude?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                                 data-amenities="@amenityText"
                                 data-campaign-slugs="@string.Join(" ", campaignSlugsSafe.Where(x => !string.IsNullOrWhiteSpace(x)).Select(NormalizeToken).Distinct())"
                                 data-featured="@(hotel.IsFeatured ? "1" : "0")">
                            <div class="card-image">
                                @{
                                    var galleryImagesSafe = hotel.GalleryImages ?? new List<string>();
                                    var images = galleryImagesSafe.Count > 0
                                        ? galleryImagesSafe
                                        : new List<string> { hotel.ImageUrl };
                                    var mainCardImage = images.FirstOrDefault();
                                    var mosaicImages = images.Where(x => !string.IsNullOrWhiteSpace(x)).Take(4).ToList();
                                    if (mosaicImages.Count == 0 && !string.IsNullOrWhiteSpace(mainCardImage))
                                    {
                                        mosaicImages.Add(mainCardImage);
                                    }
                                    while (mosaicImages.Count < 4 && mosaicImages.Count > 0)
                                    {
                                        mosaicImages.Add(mosaicImages[0]);
                                    }
                                }
                                <a href="@HotelDetailUrl(hotel.Slug)"
                                   class="card-image-link"
                                   aria-label="@hotel.Name detay sayfasına git">
                                    <img class="card-main-image"
                                         src="@(string.IsNullOrWhiteSpace(mainCardImage) ? "/assets/img/placeholder-hotel.jpg" : mainCardImage)"
                                         alt="@hotel.Name"
                                         @(isFirstListingCard ? "fetchpriority=\"high\" loading=\"eager\"" : "loading=\"lazy\"")
                                         decoding="async" />
                                    @{
                                        var campaignPairs = campaignNamesSafe
                                            .Zip(campaignSlugsSafe, (n, s) => new { Name = n, Slug = s })
                                            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                            .DistinctBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                                            .ToList();
                                        var currentCampaign = string.IsNullOrWhiteSpace(Model.CampaignSlug)
                                            ? null
                                            : campaignPairs.FirstOrDefault(x => string.Equals(x.Slug, Model.CampaignSlug, StringComparison.OrdinalIgnoreCase));
                                        var displayCampaigns = new List<string>();
                                        if (currentCampaign is not null)
                                        {
                                            displayCampaigns.Add(currentCampaign.Name);
                                        }
                                        foreach (var c in campaignPairs)
                                        {
                                            if (displayCampaigns.Count >= 3) break;
                                            if (currentCampaign is not null && string.Equals(c.Name, currentCampaign.Name, StringComparison.OrdinalIgnoreCase)) continue;
                                            displayCampaigns.Add(c.Name);
                                        }
                                        var overflowCampaignCount = Math.Max(0, campaignPairs.Count - displayCampaigns.Count);
                                    }
                                    @if (hotel.HasDiscount && hotel.DiscountPercent > 0)
                                    {
                                        <span class="listing-card-discount-corner" aria-label="@($"%{hotel.DiscountPercent} indirim")">
                                            %@hotel.DiscountPercent
                                        </span>
                                    }
                                    @if (showFreeCancelBadge)
                                    {
                                        <span class="card-free-cancel-badge" title="Ücretsiz iptal">
                                            <i class="fas fa-rotate-left" aria-hidden="true"></i>
                                            Ücretsiz iptal
                                        </span>
                                    }
                                    @if (campaignPairs.Count > 0)
                                    {
                                        <div class="card-campaign-badges" aria-label="Kampanyalar">
                                            @foreach (var name in displayCampaigns)
                                            {
                                                <span class="card-campaign-badge">@name</span>
                                            }
                                            if (overflowCampaignCount > 0)
                                            {
                                                <span class="card-campaign-badge card-campaign-badge--more">+@overflowCampaignCount</span>
                                            }
                                        </div>
                                    }
                                    @if (!hotel.HasAvailabilityToday)
                                    {
                                        <div class="card-campaign-badges card-campaign-badges--soldout" aria-label="Müsaitlik uyarısı">
                                            <span class="card-campaign-badge card-campaign-badge--soldout">Bugün için boş oda kalmadı</span>
                                        </div>
                                    }
                                    @if (mosaicImages.Count > 1)
                                    {
                                        <div class="card-image-mosaic" aria-hidden="true">
                                            @for (var mi = 0; mi < mosaicImages.Count; mi++)
                                            {
                                                <img src="@mosaicImages[mi]" alt="" loading="lazy" decoding="async" />
                                            }
                                        </div>
                                    }
                                </a>
                                @if (hotel.StarCount.HasValue && hotel.StarCount.Value > 0)
                                {
                                    <span class="card-star-badge" aria-label="@($"{hotel.StarCount.Value} yıldızlı otel")">
                                        @for (var i = 0; i < hotel.StarCount.Value; i++)
                                        {
                                            <i class="fas fa-star" aria-hidden="true"></i>
                                        }
                                    </span>
                                }
                                <span class="image-rating" aria-label="Misafir puanı">
                                    @hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture) <i class="fas fa-star" aria-hidden="true"></i>
                                </span>
                                <button type="button"
                                        class="wishlist-btn favorite-btn @(hotel.IsFavorite ? "active" : string.Empty)"
                                        data-hotel-id="@hotel.Id"
                                        data-source-page="OtelListeleme"
                                        aria-label="Favorilere ekle"
                                        aria-pressed="@(hotel.IsFavorite ? "true" : "false")">
                                    <i class="@(hotel.IsFavorite ? "fas" : "far") fa-heart"></i>
                                </button>
                            </div>
                            <div class="card-content">
                                <div>
                                    <div class="hotel-header">
                                        <h3 class="hotel-name">@hotel.Name</h3>
                                        <span class="hotel-rating">@hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture) <i class="fas fa-star" style="font-size:10px;"></i></span>
                                    </div>
                                    <div class="hotel-location"><i class="fas fa-map-pin"></i> @locationText</div>

                                    <div class="listing-card-mobile-lines" aria-label="Liste özeti">
                                        <p class="listing-mobile-city"><i class="fas fa-location-dot" aria-hidden="true"></i> @hotel.City · @hotel.District</p>
                                        @if (!string.IsNullOrWhiteSpace(hotel.Neighborhood))
                                        {
                                            <p class="listing-mobile-nb">@hotel.Neighborhood</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(hotel.ListingLeadRoomName))
                                        {
                                            <p class="listing-mobile-room"><i class="fas fa-bed" aria-hidden="true"></i> @hotel.ListingLeadRoomName <span class="listing-mobile-room-note">· bugün</span></p>
                                        }
                                        else
                                        {
                                            <p class="listing-mobile-room @(hotel.HasAvailabilityToday ? "" : "is-warning")">
                                                <i class="fas fa-door-open" aria-hidden="true"></i>
                                                @(hotel.HasAvailabilityToday ? "Bugün uygun oda" : "Bugün uygun oda yok")
                                            </p>
                                        }
                                        @if (hotel.HasDiscount && !string.IsNullOrWhiteSpace(hotel.DiscountName))
                                        {
                                            <p class="listing-mobile-discount"><i class="fas fa-tags" aria-hidden="true"></i> @hotel.DiscountName</p>
                                        }
                                        @{
                                            var mobileCampaignLabels = campaignNamesSafe
                                                .Where(n => !string.IsNullOrWhiteSpace(n))
                                                .Distinct(StringComparer.OrdinalIgnoreCase)
                                                .Take(2)
                                                .ToList();
                                        }
                                        @if (mobileCampaignLabels.Count > 0)
                                        {
                                            <p class="listing-mobile-campaign"><i class="fas fa-bullhorn" aria-hidden="true"></i> @string.Join(" · ", mobileCampaignLabels)</p>
                                        }
                                    </div>

                                    <div class="listing-badges-mobile" aria-label="Kampanya etiketleri">
                                        @{
                                            // Mobile: show only 1 primary badge to keep layout clean.
                                            if (hotel.IsFeatured)
                                            {
                                                <span class="listing-pill fav"><i class="fas fa-award"></i> Misafir Favorisi</span>;
                                            }
                                            else if (hasWeekend)
                                            {
                                                <span class="listing-pill weekend"><i class="fas fa-calendar-week"></i> Hafta Sonu</span>;
                                            }
                                            else if (hasDiscount)
                                            {
                                                <span class="listing-pill discount"><i class="fas fa-tag"></i> @(string.IsNullOrWhiteSpace(hotel.DiscountName) ? "İndirim" : hotel.DiscountName)</span>;
                                            }
                                        }
                                    </div>
                                    <div class="features features-desktop">
                                        @foreach (var amenity in (hotel.AmenityItems?.Count > 0 ? hotel.AmenityItems.Take(4) : Enumerable.Empty<otelturizmnew.Models.Oteller.HotelAmenityViewModel>()))
                                        {
                                            <span class="feature-tag"><i class="fas @amenity.IconClass"></i> @amenity.Name</span>
                                        }
                                    </div>

                                    <div class="listing-badges-inline" aria-label="Kampanya etiketleri">
                                        @{
                                            var pillCountInline = 0;
                                            if (hotel.IsFeatured && pillCountInline < 4)
                                            {
                                                <span class="listing-pill fav"><i class="fas fa-award"></i> Misafir Favorisi</span>;
                                                pillCountInline++;
                                            }
                                            if (hasWeekend && pillCountInline < 4)
                                            {
                                                <span class="listing-pill weekend"><i class="fas fa-calendar-week"></i> Hafta Sonu</span>;
                                                pillCountInline++;
                                            }
                                            if (hasEarly && pillCountInline < 4)
                                            {
                                                <span class="listing-pill early"><i class="fas fa-clock"></i> Erken Rez.</span>;
                                                pillCountInline++;
                                            }
                                            if (hasDiscount && pillCountInline < 4)
                                            {
                                                <span class="listing-pill discount"><i class="fas fa-tag"></i> @(string.IsNullOrWhiteSpace(hotel.DiscountName) ? "İndirim" : hotel.DiscountName)</span>;
                                                pillCountInline++;
                                            }
                                            if (isCampaign && pillCountInline < 4)
                                            {
                                                <span class="listing-pill"><i class="fas fa-badge-percent"></i> Kampanyalı</span>;
                                                pillCountInline++;
                                            }
                                        }
                                    </div>

                                    <div class="features features-mobile">
                                        @foreach (var amenity in (hotel.AmenityItems?.Count > 0 ? hotel.AmenityItems.Take(2) : Enumerable.Empty<otelturizmnew.Models.Oteller.HotelAmenityViewModel>()))
                                        {
                                            <span class="feature-tag"><i class="fas @amenity.IconClass"></i> @amenity.Name</span>
                                        }
                                    </div>

                                    <div class="listing-badges-under" aria-label="Öne çıkan etiketler">
                                        @if (hotel.IsFeatured)
                                        {
                                            <span class="listing-pill fav"><i class="fas fa-award"></i> Misafir Favorisi</span>
                                        }
                                        @if (hasDiscount)
                                        {
                                            <span class="listing-pill discount"><i class="fas fa-tag"></i> @(string.IsNullOrWhiteSpace(hotel.DiscountName) ? "İndirim" : hotel.DiscountName)</span>
                                        }
                                    </div>
                                </div>
                                <div class="price-section">
                                    <div class="price-info">
                                        @if (hotel.HasDiscount && hotel.OriginalPrice.HasValue && hotel.DiscountedPrice.HasValue)
                                        {
                                            <span class="old-price" aria-label="Eski fiyat">₺@hotel.OriginalPrice.Value.ToString("N0")</span>
                                            <span class="current-price listing-price--discounted">₺@hotel.DiscountedPrice.Value.ToString("N0")</span>
                                            <span class="listing-discount-rate listing-discount-rate--pill">%@hotel.DiscountPercent</span>
                                            if (hotel.DiscountId.HasValue && !string.IsNullOrWhiteSpace(hotel.DiscountName))
                                            {
                                                <button type="button"
                                                        class="discount-info-btn"
                                                        data-discount-open
                                                        data-discount-title="@hotel.DiscountName"
                                                        data-discount-desc="@hotel.DiscountShortDescription"
                                                        data-discount-image="@hotel.DiscountImageUrl"
                                                        aria-label="İndirim detayını görüntüle">
                                                    <i class="fas fa-circle-info" aria-hidden="true"></i>
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <span class="current-price">@(price > 0m ? $"₺{price:N0}" : "Teklif Al")</span>
                                        }
                                    </div>
                                    <span class="price-tax-note">Vergiler dahil</span>
                                    @if (Model.ShowLoyaltyTouchpoints)
                                    {
                                        if (Model.LoyaltyUserSignedIn && hotel.EstimatedLoyaltyPoints is int loyaltyPts && loyaltyPts > 0)
                                        {
                                            <span class="listing-loyalty-earn" title="Tahmini sadakat puanı (gecelik)">
                                                <i class="fas fa-gem" aria-hidden="true"></i>
                                                +@loyaltyPts.ToString("N0", CultureInfo.GetCultureInfo("tr-TR")) puan
                                            </span>
                                        }
                                        else if (!Model.LoyaltyUserSignedIn)
                                        {
                                            var loyaltyReturn = Context.Request.Path + Context.Request.QueryString;
                                            <span class="listing-loyalty-earn listing-loyalty-earn--placeholder"
                                                  data-loyalty-hook="earn"
                                                  data-loyalty-price="@(price > 0m ? price.ToString(CultureInfo.InvariantCulture) : null)">
                                                <i class="fas fa-gem" aria-hidden="true"></i>
                                                <a class="listing-loyalty-earn__link"
                                                   href="/giris?returnUrl=@Uri.EscapeDataString(loyaltyReturn)">Giriş yapın, puan kazanın</a>
                                            </span>
                                        }
                                    }
                                    <a href="@HotelDetailUrl(hotel.Slug)" class="btn-detail">İncele</a>
                                </div>
                            </div>
                        </article>
                    }
                    }
                </div>
                <div class="listing-empty-state" id="listingClientEmptyState" hidden role="status" aria-live="polite">
                    <div class="listing-empty-icon" aria-hidden="true"><i class="fas fa-sliders"></i></div>
                    <h2>Filtrelere uygun tesis bulunamadı</h2>
                    <p>Tarih, fiyat veya konum kriterlerini gevşetin; filtreleri sıfırlayıp tekrar deneyin.</p>
                    <div class="listing-empty-actions">
                        <button type="button" class="btn-detail listing-empty-action" id="listingEmptyClearFilters">Filtreleri temizle</button>
                        <a class="listing-map-launch-btn listing-empty-action" href="@mapListingUrl">Haritada ara</a>
                    </div>
                </div>
            </div>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="listing-pagination" aria-label="Sayfalama">
                    @{
                        var current = Math.Max(Model.CurrentPage, 1);
                        var total = Math.Max(Model.TotalPages, 1);
                        var start = Math.Max(1, current - 2);
                        var end = Math.Min(total, current + 2);
                        if (current <= 3) { start = 1; end = Math.Min(total, 5); }
                        if (current >= total - 2) { end = total; start = Math.Max(1, total - 4); }
                    }

                    <a class="page-btn @(current <= 1 ? "disabled" : string.Empty)"
                       href="@(current <= 1 ? "#" : Url.Action("OtelListeleme", "Oteller", new { q = Model.SearchTerm, city = (string?)null, etiket = Model.ActiveTag, kampanya = Model.CampaignSlug, page = current - 1 }))"
                       aria-disabled="@(current <= 1 ? "true" : "false")">Önceki</a>

                    @if (start > 1)
                    {
                        <a class="page-num" href="@Url.Action("OtelListeleme", "Oteller", new { q = Model.SearchTerm, city = (string?)null, etiket = Model.ActiveTag, kampanya = Model.CampaignSlug, page = 1 })">1</a>
                        if (start > 2)
                        {
                            <span class="page-ellipsis" aria-hidden="true">…</span>
                        }
                    }

                    @for (var p = start; p <= end; p++)
                    {
                        <a class="page-num @(p == current ? "active" : string.Empty)"
                           href="@Url.Action("OtelListeleme", "Oteller", new { q = Model.SearchTerm, city = (string?)null, etiket = Model.ActiveTag, kampanya = Model.CampaignSlug, page = p })"
                           aria-current="@(p == current ? "page" : null)">@p</a>
                    }

                    @if (end < total)
                    {
                        if (end < total - 1)
                        {
                            <span class="page-ellipsis" aria-hidden="true">…</span>
                        }
                        <a class="page-num" href="@Url.Action("OtelListeleme", "Oteller", new { q = Model.SearchTerm, city = (string?)null, etiket = Model.ActiveTag, kampanya = Model.CampaignSlug, page = total })">@total</a>
                    }

                    <a class="page-btn @(current >= total ? "disabled" : string.Empty)"
                       href="@(current >= total ? "#" : Url.Action("OtelListeleme", "Oteller", new { q = Model.SearchTerm, city = (string?)null, etiket = Model.ActiveTag, kampanya = Model.CampaignSlug, page = current + 1 }))"
                       aria-disabled="@(current >= total ? "true" : "false")">Sonraki</a>
                </nav>
            }
            </div> @* /.listing-main *@

        </div>
    </div>
</section>

<div class="filter-modal" id="listingFilterModal" aria-hidden="true" role="dialog" aria-label="Filtreler">
    <div class="modal-overlay" id="listingFilterModalOverlay"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h3>Filtreler</h3>
            <button type="button" class="close-modal" id="listingFilterModalClose" aria-label="Kapat">×</button>
        </div>
        <div class="modal-body-scroll" id="listingMobileFilterHost"></div>
        <div class="modal-footer">
            <button type="button" class="apply-btn secondary" id="listingFilterClearBtn">Tüm filtreleri temizle</button>
            <button type="button" class="apply-btn" id="listingFilterApplyBtn">Uygula</button>
        </div>
    </div>
</div>

<div class="discount-modal" id="discountModal" hidden aria-hidden="true">
    <div class="discount-modal-backdrop" data-discount-close></div>
    <section class="discount-modal-card" role="dialog" aria-modal="true" aria-labelledby="discountModalTitle">
        <button type="button" class="discount-modal-close" data-discount-close aria-label="Kapat">×</button>
        <div class="discount-modal-kicker">İndirim Detayı</div>
        <h3 id="discountModalTitle">İndirim</h3>
        <p id="discountModalDesc"></p>
        <div class="discount-modal-visual" id="discountModalVisual" hidden>
            <img id="discountModalImage" alt="İndirim görseli" />
        </div>
    </section>
</div>

@* Fiyat uyarı modalı + konum haritası modalı kaldırıldı *@

@* Inline CSS removed: now served from /assets/css/otel-listeleme.inline-extract.css *@

@section Scripts {
    <script src="~/assets/js/otel-listeleme-enhancements.js" asp-append-version="true"></script>
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const hotelDetailPathPattern = @System.Text.Json.JsonSerializer.Serialize(InternationalSeoPaths.BuildPublicPath(listingPathLang, InternationalSeoPaths.PageKindDetail, null, "{slug}"));
            function buildHotelDetailUrl(slug) {
                return hotelDetailPathPattern.replace('{slug}', encodeURIComponent(String(slug || '').trim()));
            }

            const listView = document.getElementById('hotelListView');
            const sortSelect = document.getElementById('listingSortSelect');
            const keywordInput = document.getElementById('listingKeywordInput');
            // Fiyat aralığı + konuma göre ara filtreleri kaldırıldı (kilitlenme sorunları nedeniyle).
            const minPriceInput = null;
            const maxPriceInput = null;
            const priceAutoRelaxNote = null;
            const useMyLocationBtn = null;
            const distanceKmRange = null;
            const distanceKmValue = null;
            const distanceKmInput = null;
            const distanceHotelCount = null;
            const locationStatusText = null;
            const locationCoordsText = null;
            const locationInsightText = null;
            const locationMapModal = null;
            const listingFilterNoticeModal = null;
            const locationMapCanvas = null;
            const locationMapMeta = null;
            const locationMapHelper = null;
            const locationMapActions = null;
            const locationMapConfirmBtn = null;
            const listingNoticeFocusBtn = null;
            const locationStorageKey = '';
            const defaultLocationRadiusKm = 0;
            const defaultMinPrice = 0;
            const defaultMaxPrice = 0;
            let userLocation = null;
            let locationLogTimer = null;
            let lastLocationLogSignature = '';
            let locationPermissionState = 'prompt';
            let locationLeafletMap = null;
            let locationLeafletLayer = null;
            let locationMapPickMode = false;
            let locationPickedLatLng = null;
            let locationPickedMarker = null;
            let hasPromptedManualLocation = false;
            let desktopApproximateSelectionPending = false;
            let lastFocusBeforeLocationModal = null;
            let lastFocusBeforeListingNoticeModal = null;
            let listingNoticeShown = false;
            let cards = Array.from(document.querySelectorAll('.listing-hotel-card'));
            function refreshCards() {
                cards = Array.from(document.querySelectorAll('.listing-hotel-card'));
                return cards;
            }
            const amenityChecks = Array.from(document.querySelectorAll('.listing-amenity-filter'));
            const starChecks = Array.from(document.querySelectorAll('.listing-star-filter'));
            const ratingChips = Array.from(document.querySelectorAll('.rating-chip'));
            const featuredChecks = Array.from(document.querySelectorAll('.listing-featured-filter'));
            const campaignChecks = Array.from(document.querySelectorAll('.listing-campaign-filter'));
            const mealChecks = Array.from(document.querySelectorAll('.listing-meal-filter'));
            const clearAllBtn = document.getElementById('clearAllFiltersBtn');
            const listingClientEmptyState = document.getElementById('listingClientEmptyState');
            const listingEmptyClearFilters = document.getElementById('listingEmptyClearFilters');
            const keywordClearBtn = document.getElementById('listingKeywordClear');
            const keywordSuggestions = document.getElementById('listingKeywordSuggestions');
            const discountModal = document.getElementById('discountModal');
            let reelResetToTop = null;
            let keywordSuggestionTimer = null;
            let clientFilterPoolLoading = false;
            let clientFilterPoolReady = false;

            function normalize(v) {
                return String(v || '').toLocaleLowerCase('tr-TR');
            }

            function parseFilterNumber(value) {
                const raw = String(value ?? '').trim();
                if (!raw) return 0;
                const parsed = Number(raw.replace(/[^\d]/g, ''));
                return Number.isFinite(parsed) ? parsed : 0;
            }

            function getPriceRangeAttr(input, key, fallback) {
                if (!input || !input.dataset) return parseFilterNumber(String(fallback));
                return parseFilterNumber(input.dataset[key] || String(fallback));
            }

            function hasListingRegionContext() {
                const keyword = String(keywordInput?.value || '').trim();
                if (keyword.length > 0) {
                    return true;
                }

                return !!(
                    userLocation
                    && !(isDesktopViewport() && desktopApproximateSelectionPending && userLocation.approximate)
                );
            }

            async function ensureClientFilterPoolLoaded() {
                if (clientFilterPoolReady || clientFilterPoolLoading) {
                    return;
                }

                if (typeof window.ensureListingCardsLoaded !== 'function') {
                    return;
                }

                clientFilterPoolLoading = true;
                try {
                    await window.ensureListingCardsLoaded();
                    refreshCards();
                    clientFilterPoolReady = true;
                } catch (_) {
                    // sessiz
                } finally {
                    clientFilterPoolLoading = false;
                }
            }

            function isMobileViewport() {
                return window.innerWidth <= 900;
            }

            function isDesktopViewport() {
                return !isMobileViewport();
            }

            function clearUnexpectedScrollLocks() {
                const locationModalOpen = !!(locationMapModal && !locationMapModal.hidden);
                const listingNoticeOpen = !!(listingFilterNoticeModal && !listingFilterNoticeModal.hidden);
                const discountModalOpen = !!(discountModal && !discountModal.hidden);
                if (locationModalOpen || listingNoticeOpen || discountModalOpen) {
                    return;
                }

                if (document.body.style.overflow === 'hidden') {
                    document.body.style.overflow = '';
                }
                if (document.documentElement.style.overflow === 'hidden') {
                    document.documentElement.style.overflow = '';
                }
            }

            function formatTry(amount) {
                const n = Number(amount || 0);
                if (!Number.isFinite(n)) return '₺0';
                return '₺' + Math.round(n).toLocaleString('tr-TR');
            }

            function getPriceBounds() {
                const inputMinAttr = getPriceRangeAttr(minPriceInput, 'rangeMin', defaultMinPrice);
                const inputMaxAttr = getPriceRangeAttr(maxPriceInput, 'rangeMax', defaultMaxPrice);
                const rawMin = parseFilterNumber(minPriceInput?.value || String(defaultMinPrice || inputMinAttr));
                const rawMax = parseFilterNumber(maxPriceInput?.value || String(defaultMaxPrice || inputMaxAttr || rawMin));
                let min = Math.max(0, rawMin || inputMinAttr);
                let max = Math.max(0, rawMax || inputMaxAttr || min);
                if (max < min) {
                    max = min;
                }
                return { min, max, sliderMin: inputMinAttr, sliderMax: inputMaxAttr };
            }

            function normalizeManualPriceInputs(commit) {
                if (!minPriceInput && !maxPriceInput) return;
                const minAttr = getPriceRangeAttr(minPriceInput, 'rangeMin', defaultMinPrice);
                const maxAttr = getPriceRangeAttr(maxPriceInput, 'rangeMax', defaultMaxPrice);
                const minRawText = String(minPriceInput?.value || '').replace(/[^\d]/g, '');
                const maxRawText = String(maxPriceInput?.value || '').replace(/[^\d]/g, '');
                let nextMin = minRawText ? Number(minRawText) : (commit ? (defaultMinPrice || minAttr) : NaN);
                let nextMax = maxRawText ? Number(maxRawText) : (commit ? (defaultMaxPrice || maxAttr || nextMin) : NaN);
                nextMin = Number.isFinite(nextMin) ? Math.max(0, nextMin) : nextMin;
                nextMax = Number.isFinite(nextMax) ? Math.max(0, nextMax) : nextMax;
                if (!Number.isFinite(nextMin) && Number.isFinite(nextMax)) {
                    nextMin = Math.min(nextMax, defaultMinPrice || minAttr);
                }
                if (!Number.isFinite(nextMax) && Number.isFinite(nextMin) && commit) {
                    nextMax = Math.max(nextMin, defaultMaxPrice || maxAttr || nextMin);
                }
                if (nextMax < nextMin) {
                    nextMax = nextMin;
                }
                if (minPriceInput) {
                    minPriceInput.value = minRawText ? String(nextMin) : (commit ? String(defaultMinPrice || minAttr) : '');
                }
                if (maxPriceInput) {
                    maxPriceInput.value = maxRawText ? String(nextMax) : (commit ? String(defaultMaxPrice || maxAttr || nextMin) : '');
                }
            }
            // Slider kaldırıldı: scroll kilidi/visual senkron yok.

            function toRad(d) { return (d * Math.PI) / 180; }

            function haversineKm(aLat, aLon, bLat, bLon) {
                const R = 6371;
                const dLat = toRad(bLat - aLat);
                const dLon = toRad(bLon - aLon);
                const lat1 = toRad(aLat);
                const lat2 = toRad(bLat);
                const s1 = Math.sin(dLat / 2);
                const s2 = Math.sin(dLon / 2);
                const h = s1 * s1 + Math.cos(lat1) * Math.cos(lat2) * s2 * s2;
                return 2 * R * Math.asin(Math.min(1, Math.sqrt(h)));
            }

            function syncDistanceUi() {
                if (!distanceKmRange || !distanceKmValue) return;
                distanceKmValue.textContent = String(distanceKmRange.value || String(defaultLocationRadiusKm));
                if (distanceKmInput) {
                    distanceKmInput.value = String(distanceKmRange.value || String(defaultLocationRadiusKm));
                }
            }

            function hasManualPriceFilter() {
                const bounds = getPriceBounds();
                return bounds.min > defaultMinPrice || bounds.max < defaultMaxPrice;
            }

            function closeListingNoticeModal() {
                if (!listingFilterNoticeModal) return;
                listingFilterNoticeModal.hidden = true;
                listingFilterNoticeModal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
                document.documentElement.style.overflow = '';
                if (lastFocusBeforeListingNoticeModal instanceof HTMLElement) {
                    lastFocusBeforeListingNoticeModal.focus();
                }
            }

            function openListingNoticeModal() {
                if (!listingFilterNoticeModal || !listingFilterNoticeModal.hidden) return;
                lastFocusBeforeListingNoticeModal = document.activeElement instanceof HTMLElement ? document.activeElement : null;
                listingFilterNoticeModal.hidden = false;
                listingFilterNoticeModal.setAttribute('aria-hidden', 'false');
                // Sayfayı kilitleme: kullanıcı arkaplanda kaydırabilsin.
                document.body.style.overflow = '';
                document.documentElement.style.overflow = '';
                window.setTimeout(function () {
                    listingNoticeFocusBtn?.focus();
                }, 0);
            }

            function enableDistanceFilterUi(enabled) {
                if (distanceKmRange) {
                    distanceKmRange.disabled = !enabled;
                }
                if (distanceKmInput) {
                    distanceKmInput.disabled = !enabled;
                }
                useMyLocationBtn?.classList.toggle('active', !!enabled);
            }

            function setLocationPermissionState(state) {
                locationPermissionState = state || 'prompt';
                if (!locationStatusText) {
                    return;
                }

                if (locationPermissionState === 'granted') {
                    locationStatusText.textContent = 'Konum açık';
                    return;
                }
                if (locationPermissionState === 'approximate') {
                    locationStatusText.textContent = 'Konum bulundu';
                    return;
                }
                if (locationPermissionState === 'denied') {
                    locationStatusText.textContent = 'Tarayıcıdan aç';
                    return;
                }
                if (locationPermissionState === 'loading') {
                    locationStatusText.textContent = 'Konum alınıyor...';
                    return;
                }

                locationStatusText.textContent = 'Konumu aç';
            }

            function setLocationStatus(text) {
                if (!locationStatusText) return;
                const safeText = String(text || '').trim();
                locationStatusText.textContent = safeText;
            }

            function ensureDistanceControlsEnabled() {
                if (distanceKmRange) {
                    distanceKmRange.disabled = false;
                }
                if (distanceKmInput) {
                    distanceKmInput.disabled = false;
                }
                useMyLocationBtn?.classList.add('active');
            }

            function setLocationCoords(lat, lon, accuracy) {
                if (!locationCoordsText) return;
                if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
                    locationCoordsText.innerHTML = '';
                    locationCoordsText.classList.remove('is-visible');
                    locationCoordsText.classList.remove('is-clickable');
                    return;
                }

                const isApproximate = !!(userLocation && userLocation.approximate);
                const accuracyText = isApproximate
                    ? ''
                    : Number.isFinite(accuracy) && accuracy > 0
                    ? '<span>Yaklaşık hassasiyet: ' + Math.round(accuracy) + ' m</span>'
                    : '<span>Konum doğrulandı</span>';

                locationCoordsText.innerHTML =
                    '<div class="location-coords-head"><i class="fas fa-location-dot" aria-hidden="true"></i><strong>Neredeyim?</strong></div>' +
                    '<span>Enlem: ' + lat.toFixed(6) + ' · Boylam: ' + lon.toFixed(6) + '</span>' +
                    accuracyText;
                locationCoordsText.classList.add('is-visible');
                locationCoordsText.classList.add('is-clickable');
            }

            function closeLocationMapModal() {
                if (!locationMapModal) return;
                locationMapModal.hidden = true;
                locationMapModal.setAttribute('aria-hidden', 'true');
                // Konum modalı sayfayı kilitlememeli (özellikle \"Yaklaşık konum hazır\" akışında).
                document.body.style.overflow = '';
                document.documentElement.style.overflow = '';
                locationMapModal.classList.remove('is-open');
                locationMapPickMode = false;
                locationPickedLatLng = null;
                if (locationMapConfirmBtn) {
                    locationMapConfirmBtn.disabled = true;
                }

                // Focus restore: kullanıcı konum butonuna geri dönebilsin.
                try {
                    if (lastFocusBeforeLocationModal && typeof lastFocusBeforeLocationModal.focus === 'function') {
                        lastFocusBeforeLocationModal.focus();
                    }
                } catch (_) { /* ignore */ }
                lastFocusBeforeLocationModal = null;
            }

            function applyManualMapSelection() {
                if (!locationPickedLatLng) {
                    return;
                }

                userLocation = {
                    lat: Number(locationPickedLatLng.lat),
                    lon: Number(locationPickedLatLng.lng),
                    accuracy: 0,
                    approximate: false,
                    source: 'harita-secimi'
                };
                desktopApproximateSelectionPending = false;

                if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                persistLocationSnapshot(userLocation.lat, userLocation.lon, 0);
                setLocationPermissionState('granted');
                enableDistanceFilterUi(true);
                ensureDistanceControlsEnabled();
                syncDistanceUi();
                setLocationCoords(userLocation.lat, userLocation.lon, 0);
                setLocationStatus('Konum doğrulandı.');
                setLocationInsight('Haritada seçtiğin konuma göre yakın oteller listelendi.');
                applyFilters();
                sortCards();
                ensureClientFilterPoolLoaded().then(function () {
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                });
                queueLocationLog(true);
                closeLocationMapModal();
            }

            function openLocationMapModal(options) {
                if (!locationMapModal || !locationMapCanvas || !window.L) {
                    return;
                }
                if (!userLocation || !Number.isFinite(userLocation.lat) || !Number.isFinite(userLocation.lon)) {
                    return;
                }

                const settings = options || {};
                locationMapPickMode = !!settings.pickMode;
                locationPickedLatLng = null;
                if (locationMapConfirmBtn) {
                    locationMapConfirmBtn.disabled = true;
                }
                if (locationMapHelper) {
                    locationMapHelper.hidden = !locationMapPickMode;
                }
                if (locationMapActions) {
                    locationMapActions.hidden = !locationMapPickMode || isMobileViewport();
                }
                const visibleHotels = collectVisibleHotelsForMap();
                locationMapModal.hidden = false;
                locationMapModal.setAttribute('aria-hidden', 'false');
                locationMapModal.classList.add('is-open');

                // Focus trap başlangıcı: modal açılınca odak modal içinde kalsın.
                lastFocusBeforeLocationModal = document.activeElement;
                window.setTimeout(function () {
                    const closeBtn = locationMapModal.querySelector('[data-location-map-close]') || locationMapModal.querySelector('button');
                    if (closeBtn && typeof closeBtn.focus === 'function') {
                        closeBtn.focus();
                    } else if (locationMapCanvas && typeof locationMapCanvas.focus === 'function') {
                        locationMapCanvas.setAttribute('tabindex', '-1');
                        locationMapCanvas.focus();
                    }
                }, 0);

                // Sadece mobilde (tam ekran) scroll kilitle; masaüstünde sayfa kilitlenmesi hissi yaratıyor.
                if (isMobileViewport()) {
                    document.body.style.overflow = 'hidden';
                    document.documentElement.style.overflow = 'hidden';
                } else {
                    document.body.style.overflow = '';
                    document.documentElement.style.overflow = '';
                }

                if (!locationLeafletMap) {
                    locationLeafletMap = window.L.map(locationMapCanvas, {
                        zoomControl: true,
                        scrollWheelZoom: false
                    });
                    window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        maxZoom: 19,
                        attribution: '&copy; OpenStreetMap katkıda bulunanlar'
                    }).addTo(locationLeafletMap);
                }

                if (locationLeafletLayer) {
                    locationLeafletLayer.clearLayers();
                } else {
                    locationLeafletLayer = window.L.layerGroup().addTo(locationLeafletMap);
                }
                if (locationPickedMarker) {
                    locationPickedMarker.remove();
                    locationPickedMarker = null;
                }
                locationLeafletMap.off('click');

                const userLatLng = [userLocation.lat, userLocation.lon];
                const bounds = [userLatLng];

                if (!locationMapPickMode) {
                    window.L.marker(userLatLng)
                        .addTo(locationLeafletLayer)
                        .bindPopup('<strong>Konumunuz</strong><br>Enlem: ' + userLocation.lat.toFixed(6) + '<br>Boylam: ' + userLocation.lon.toFixed(6));
                }

                if (locationMapMeta) {
                    locationMapMeta.textContent = locationMapPickMode
                        ? 'Yakın bölge merkezde açıldı. Haritada bulunduğun noktayı seçip konumunu netleştir.'
                        : 'Konumun harita üzerinde gösteriliyor. Gerekirse tekrar seçim yapabilirsin.';
                }

                if (locationMapPickMode) {
                    locationLeafletMap.on('click', function (event) {
                        locationPickedLatLng = event.latlng;
                        if (locationPickedMarker) {
                            locationPickedMarker.setLatLng(event.latlng);
                        } else {
                            locationPickedMarker = window.L.marker(event.latlng, {
                                draggable: true
                            }).addTo(locationLeafletMap);
                            locationPickedMarker.on('dragend', function () {
                                locationPickedLatLng = locationPickedMarker.getLatLng();
                            });
                        }

                        if (locationMapConfirmBtn) {
                            locationMapConfirmBtn.disabled = false;
                        }

                        if (isMobileViewport()) {
                            window.setTimeout(function () {
                                applyManualMapSelection();
                            }, 80);
                        }
                    });
                }

                window.setTimeout(function () {
                    locationLeafletMap.invalidateSize();
                    locationLeafletMap.setView(userLatLng, locationMapPickMode ? 12 : 13);
                }, 80);
            }

            function persistLocationSnapshot(lat, lon, accuracy) {
                try {
                    localStorage.setItem(locationStorageKey, JSON.stringify({
                        lat: Number(lat || 0),
                        lon: Number(lon || 0),
                        accuracy: Number(accuracy || 0),
                        approximate: !!(userLocation && userLocation.approximate),
                        source: String(userLocation?.source || ''),
                        savedAt: new Date().toISOString()
                    }));
                } catch (_) {
                    // Sessiz geç.
                }
            }

            function readPersistedLocationSnapshot() {
                try {
                    const raw = localStorage.getItem(locationStorageKey);
                    if (!raw) {
                        return null;
                    }

                    const parsed = JSON.parse(raw);
                    if (!parsed || !Number.isFinite(parsed.lat) || !Number.isFinite(parsed.lon)) {
                        return null;
                    }

                    return {
                        lat: Number(parsed.lat),
                        lon: Number(parsed.lon),
                        accuracy: Number(parsed.accuracy || 0),
                        approximate: !!parsed.approximate,
                        source: String(parsed.source || ''),
                        savedAt: parsed.savedAt || ''
                    };
                } catch (_) {
                    return null;
                }
            }

            function clearPersistedLocationSnapshot() {
                try {
                    localStorage.removeItem(locationStorageKey);
                } catch (_) {
                    // Sessiz geç.
                }
            }

            function setLocationInsight(text) {
                if (!locationInsightText) return;
                locationInsightText.textContent = text || '';
                locationInsightText.classList.toggle('is-visible', String(text || '').trim().length > 0);
            }

            function setDistanceHotelCount(count, active) {
                if (!distanceHotelCount) return;
                if (!active) {
                    distanceHotelCount.textContent = '-';
                    return;
                }

                const safeCount = Math.max(0, Number(count || 0));
                distanceHotelCount.textContent = safeCount + ' otel';
            }

            function buildSearchRegionText() {
                const rawKeyword = String(keywordInput?.value || '').trim();
                if (rawKeyword.length > 0) {
                    return rawKeyword;
                }

                if (userLocation && Number.isFinite(userLocation.lat) && Number.isFinite(userLocation.lon)) {
                    return userLocation.lat.toFixed(4) + ', ' + userLocation.lon.toFixed(4);
                }

                return '';
            }

            function buildLocationLogPayload() {
                if (!userLocation || !Number.isFinite(userLocation.lat) || !Number.isFinite(userLocation.lon)) {
                    return null;
                }

                const visibleCards = cards.filter(card => !card.hidden);
                const visibleCount = visibleCards.length;
                const listedHotelIds = visibleCards
                    .map(card => Number(card.dataset.hotelId || '0'))
                    .filter(id => Number.isFinite(id) && id > 0);
                return {
                    latitude: Number(userLocation.lat.toFixed(7)),
                    longitude: Number(userLocation.lon.toFixed(7)),
                    radiusKm: Number(distanceKmRange?.value || String(defaultLocationRadiusKm)),
                    visibleHotelCount: visibleCount,
                    listedHotelIds: JSON.stringify(listedHotelIds),
                    searchTerm: String(keywordInput?.value || '').trim(),
                    searchRegion: buildSearchRegionText(),
                    source: userLocation.approximate
                        ? 'otel-listeleme-konum-yaklasik'
                        : 'otel-listeleme-konum'
                };
            }

            async function saveUserLocationLog(force) {
                const payload = buildLocationLogPayload();
                if (!payload) {
                    return;
                }

                const signature = JSON.stringify(payload);
                if (!force && signature === lastLocationLogSignature) {
                    return;
                }

                try {
                    const response = await fetch('/oteller/konum-kaydet', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: signature
                    });

                    if (response && response.ok) {
                        lastLocationLogSignature = signature;
                    }
                } catch (_) {
                    // Sessiz gec.
                }
            }

            function queueLocationLog(force) {
                window.clearTimeout(locationLogTimer);
                locationLogTimer = window.setTimeout(function () {
                    saveUserLocationLog(!!force);
                }, force ? 0 : 450);
            }

            function navigateMealTag(slug) {
                const params = new URLSearchParams(window.location.search);
                const normalizedSlug = String(slug || '').trim().toLowerCase();
                if (normalizedSlug) {
                    params.set('etiket', normalizedSlug);
                } else {
                    params.delete('etiket');
                }
                params.delete('page');
                const query = params.toString();
                window.location.href = query.length > 0
                    ? window.location.pathname + '?' + query
                    : window.location.pathname;
            }

            function cardMatchesMealToken(cardAmenities, amenityToken) {
                const token = normalize(amenityToken || '');
                if (!token) return true;
                return cardAmenities.indexOf(token) > -1;
            }

            function applyFilters() {
                refreshCards();
                const keyword = normalize(keywordInput?.value || '');
                const priceBounds = getPriceBounds();
                const regionContextActive = hasListingRegionContext();
                const manualPriceActive = hasManualPriceFilter();
                const allowPriceFilter = !!(minPriceInput || maxPriceInput) && (!manualPriceActive || regionContextActive);
                const minPrice = allowPriceFilter ? Math.max(0, priceBounds.min) : 0;
                const maxPrice = allowPriceFilter ? Math.max(0, priceBounds.max) : Number.POSITIVE_INFINITY;
                const selectedAmenities = amenityChecks.filter(x => x.checked).map(x => normalize(x.value));
                const selectedMeals = mealChecks
                    .filter(x => x.checked)
                    .map(x => normalize(String(x.dataset.amenityToken || x.value || '')));
                const selectedStars = starChecks.filter(x => x.checked).map(x => String(x.value));
                const featuredOnly = featuredChecks.some(x => x.checked);
                const selectedCampaigns = campaignChecks.filter(x => x.checked).map(x => normalize(x.value));
                const distanceKm = Number(distanceKmRange?.value || '0');
                const distanceActive = !!(
                    userLocation
                    && distanceKm > 0
                    && !(isDesktopViewport() && desktopApproximateSelectionPending && userLocation.approximate)
                );
                const minScore = ratingChips
                    .filter(x => x.classList.contains('active'))
                    .map(x => Number(x.dataset.minScore || '0'))
                    .reduce((acc, v) => Math.max(acc, v), 0);

                let visibleCount = 0;
                let cheapestNonPriceMatch = Number.POSITIVE_INFINITY;
                cards.forEach(function (card) {
                    const cardPrice = Number(card.dataset.price || '0');
                    const cardStars = String(card.dataset.stars || '0');
                    const cardRating = Number(card.dataset.rating || '0');
                    const cardKeywords = normalize(card.dataset.keywords || '');
                    const cardAmenities = normalize(card.dataset.amenities || '');
                    const cardCampaignSlugs = normalize(card.dataset.campaignSlugs || '');
                    const isFeatured = (card.dataset.featured || '0') === '1';
                    const cardLatRaw = String(card.dataset.lat || '').trim();
                    const cardLonRaw = String(card.dataset.lon || '').trim();
                    const cardLat = cardLatRaw ? Number(cardLatRaw) : NaN;
                    const cardLon = cardLonRaw ? Number(cardLonRaw) : NaN;

                    const keywordOk = !keyword || cardKeywords.indexOf(keyword) > -1;
                    const priceOk = !allowPriceFilter || (cardPrice >= minPrice && cardPrice <= maxPrice);
                    const starOk = selectedStars.length === 0 || selectedStars.includes(cardStars);
                    const ratingOk = minScore <= 0 || cardRating >= minScore;
                    const amenityOk = selectedAmenities.length === 0 || selectedAmenities.every(x => cardAmenities.indexOf(x) > -1);
                    const mealOk = selectedMeals.length === 0 || selectedMeals.every(x => cardMatchesMealToken(cardAmenities, x));
                    const featuredOk = !featuredOnly || isFeatured;
                    const campaignOk = selectedCampaigns.length === 0
                        || selectedCampaigns.some(function (slug) { return cardCampaignSlugs.indexOf(slug) > -1; });
                    const distanceOk = !distanceActive
                        || (Number.isFinite(cardLat) && Number.isFinite(cardLon)
                            && haversineKm(userLocation.lat, userLocation.lon, cardLat, cardLon) <= distanceKm);

                    const nonPriceOk = keywordOk && starOk && ratingOk && amenityOk && mealOk && featuredOk && campaignOk && distanceOk;
                    if (nonPriceOk && Number.isFinite(cardPrice) && cardPrice > 0) {
                        cheapestNonPriceMatch = Math.min(cheapestNonPriceMatch, cardPrice);
                    }

                    const isVisible = keywordOk && priceOk && starOk && ratingOk && amenityOk && mealOk && featuredOk && campaignOk && distanceOk;
                    card.hidden = !isVisible;
                    if (isVisible) {
                        visibleCount += 1;
                    }
                });

                // Fiyat filtresi yüzünden liste boş kalmasın: en düşük uygun fiyata otomatik çek.
                if (priceAutoRelaxNote) {
                    const shouldShowPriceNotice = manualPriceActive && !regionContextActive;
                    priceAutoRelaxNote.hidden = !shouldShowPriceNotice;
                    priceAutoRelaxNote.textContent = shouldShowPriceNotice
                        ? 'Fiyat filtrelemesi için önce il, ilçe ya da mahalle seçin.'
                        : '';
                }

                setDistanceHotelCount(visibleCount, distanceActive);
                if (distanceActive) {
                    setLocationInsight('Seçtiğin ' + distanceKm + ' km yarıçap içinde ' + visibleCount + ' otel bulundu.');
                    queueLocationLog(false);
                } else if (userLocation && desktopApproximateSelectionPending && isDesktopViewport()) {
                    setDistanceHotelCount(0, false);
                    setLocationInsight('Yakın bölgen açıldı. Haritada kendi konumunu seçtiğinde oteller km yarıçapına göre listelenecek.');
                } else if (userLocation) {
                    setLocationInsight('Konumun doğrulandı. Aşağıdan yarıçapı artırıp otelleri gerçek koordinat mesafesine göre filtreleyebilirsin.');
                } else {
                    setLocationInsight('Konum aramaları, partnerlerin bölgene otel eklemesi için anonim pazar içgörüsü üretir.');
                }

                if (listingClientEmptyState) {
                    const showClientEmpty = cards.length > 0 && visibleCount === 0;
                    listingClientEmptyState.hidden = !showClientEmpty;
                }

                // Desktop makara: filtre sonrası üstte yarım kart kalmasın.
                if (typeof reelResetToTop === 'function') {
                    reelResetToTop();
                }

                if (distanceActive && !clientFilterPoolReady && !clientFilterPoolLoading) {
                    ensureClientFilterPoolLoaded().then(function () {
                        applyFilters();
                        sortCards();
                        syncMobileFilterCount();
                    });
                }
            }

            function handleManualPriceFilterInteraction(commit) {
                normalizeManualPriceInputs(!!commit);
                if (hasManualPriceFilter() && !hasListingRegionContext()) {
                    if (!listingNoticeShown) {
                        openListingNoticeModal();
                        listingNoticeShown = true;
                    }
                } else {
                    listingNoticeShown = false;
                }
                applyFilters();
                sortCards();
                syncMobileFilterCount();
            }

            function hideKeywordSuggestions() {
                if (!keywordSuggestions) return;
                keywordSuggestions.innerHTML = '';
                keywordSuggestions.hidden = true;
            }

            function renderKeywordSuggestions(items) {
                if (!keywordSuggestions || !Array.isArray(items) || items.length === 0) {
                    hideKeywordSuggestions();
                    return;
                }

                keywordSuggestions.innerHTML = items.map(function (item) {
                    const value = String(item.value || '').replace(/"/g, '&quot;');
                    const type = String(item.type || '').replace(/"/g, '&quot;');
                    const slug = String(item.slug || '').replace(/"/g, '&quot;');
                    return '<button type="button" class="listing-search-suggestion" data-value="' + value + '" data-type="' + type + '" data-slug="' + slug + '">' +
                        '<span>' + String(item.label || '') + '</span>' +
                        '<small>' + String(item.type || '') + '</small>' +
                        '</button>';
                }).join('');
                keywordSuggestions.hidden = false;
            }

            async function loadKeywordSuggestions() {
                const currentValue = String(keywordInput?.value || '').trim();
                if (!currentValue) {
                    hideKeywordSuggestions();
                    return;
                }

                try {
                    const response = await fetch('/api/oteller/arama-onerileri?q=' + encodeURIComponent(currentValue), {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (!response.ok) {
                        hideKeywordSuggestions();
                        return;
                    }

                    const items = await response.json();
                    if (String(keywordInput?.value || '').trim() !== currentValue) {
                        return;
                    }

                    renderKeywordSuggestions(items);
                } catch (_) {
                    hideKeywordSuggestions();
                }
            }

            if (keywordClearBtn && keywordInput) {
                keywordClearBtn.hidden = String(keywordInput.value || '').trim().length === 0;
            }

            function sortCards() {
                if (!sortSelect || !listView) return;
                const mode = sortSelect.value;
                const visible = cards.filter(card => !card.hidden);
                visible.sort(function (a, b) {
                    const priceA = Number(a.dataset.price || '0');
                    const priceB = Number(b.dataset.price || '0');
                    const scoreA = Number(a.dataset.rating || '0');
                    const scoreB = Number(b.dataset.rating || '0');
                    if (mode === 'price-asc') return priceA - priceB;
                    if (mode === 'rating-desc') return scoreB - scoreA;
                    return scoreB - scoreA;
                });
                visible.forEach(card => listView.appendChild(card));
            }

            sortSelect?.addEventListener('change', sortCards);
            keywordInput?.addEventListener('input', function () {
                window.clearTimeout(keywordSuggestionTimer);
                applyFilters();
                sortCards();
                if (keywordClearBtn) keywordClearBtn.hidden = String(keywordInput.value || '').trim().length === 0;
                syncMobileFilterCount();
                keywordSuggestionTimer = window.setTimeout(loadKeywordSuggestions, 180);
            });
            // Mobilde: il/ilçe/mahalle araması yazılır yazılmaz server tarafı aramayı tetikle (page=1).
            // Çünkü client-side filtre sadece yüklenen kartları (örn. ilk 7) daraltır.
            let keywordServerTimer = null;
            function buildListingUrlWithQuery(nextQ) {
                const url = new URL(window.location.href);
                const qValue = String(nextQ || '').trim();
                if (qValue) url.searchParams.set('q', qValue);
                else url.searchParams.delete('q');
                url.searchParams.delete('page');
                return url.toString();
            }
            function maybeNavigateForKeyword() {
                if (!isMobileViewport() || !keywordInput) return;
                const typed = String(keywordInput.value || '').trim();
                const current = (new URL(window.location.href)).searchParams.get('q') || '';
                if (typed === String(current).trim()) return;
                // 1 karakterle sayfa yenilemeyelim; 2+ ise hemen uygula.
                if (typed.length > 0 && typed.length < 2) return;
                window.location.href = buildListingUrlWithQuery(typed);
            }
            keywordInput?.addEventListener('input', function () {
                window.clearTimeout(keywordServerTimer);
                keywordServerTimer = window.setTimeout(maybeNavigateForKeyword, 450);
            });
            keywordInput?.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    window.clearTimeout(keywordServerTimer);
                    maybeNavigateForKeyword();
                }
            });

            function applyLocationSuccess(pos) {
                userLocation = {
                    lat: Number(pos.coords.latitude),
                    lon: Number(pos.coords.longitude),
                    accuracy: Number(pos.coords.accuracy || 0),
                    approximate: false,
                    source: 'tarayici-konum'
                };
                if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                persistLocationSnapshot(userLocation.lat, userLocation.lon, userLocation.accuracy);
                setLocationPermissionState('granted');
                enableDistanceFilterUi(true);
                ensureDistanceControlsEnabled();
                syncDistanceUi();
                setLocationStatus('Konum hazır.');
                setLocationCoords(userLocation.lat, userLocation.lon, userLocation.accuracy);
                setLocationInsight('Yakındaki otelleri görmek için yarıçapı ayarlayabilirsin.');
                applyFilters();
                sortCards();
                ensureClientFilterPoolLoaded().then(function () {
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                });
                queueLocationLog(true);
            }

            async function requestApproximateLocation() {
                const providers = [
                    {
                        url: 'https://ipwho.is/',
                        parse: function (data) {
                            if (!data || data.success === false) {
                                return null;
                            }

                            return {
                                lat: Number(data.latitude),
                                lon: Number(data.longitude),
                                source: 'ipwho.is'
                            };
                        }
                    },
                    {
                        url: 'https://ipapi.co/json/',
                        parse: function (data) {
                            if (!data) {
                                return null;
                            }

                            return {
                                lat: Number(data.latitude),
                                lon: Number(data.longitude),
                                source: 'ipapi.co'
                            };
                        }
                    }
                ];

                for (const provider of providers) {
                    try {
                        const response = await fetch(provider.url, { headers: { 'Accept': 'application/json' } });
                        if (!response.ok) {
                            continue;
                        }

                        const payload = await response.json();
                        const parsed = provider.parse(payload);
                        if (parsed && Number.isFinite(parsed.lat) && Number.isFinite(parsed.lon)) {
                            return parsed;
                        }
                    } catch (_) {
                        // Sonraki sağlayıcıyı dene.
                    }
                }

                return null;
            }

            async function applyApproximateLocationFallback(reasonText) {
                const approximateLocation = await requestApproximateLocation();
                if (!approximateLocation) {
                    setLocationPermissionState('prompt');
                    setLocationStatus(reasonText || 'Konum alınamadı. Tekrar deneyin.');
                    setLocationInsight('Tarayıcı veya Windows tam konumu veremedi. Konumu tekrar deneyebilir ya da tarayıcı ayarlarından konum hizmetini açabilirsiniz.');
                    return;
                }

                userLocation = {
                    lat: approximateLocation.lat,
                    lon: approximateLocation.lon,
                    accuracy: 0,
                    approximate: true,
                    source: approximateLocation.source
                };
                desktopApproximateSelectionPending = isDesktopViewport();

                if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                persistLocationSnapshot(userLocation.lat, userLocation.lon, 0);
                setLocationPermissionState('approximate');
                enableDistanceFilterUi(true);
                ensureDistanceControlsEnabled();
                syncDistanceUi();
                setLocationCoords(userLocation.lat, userLocation.lon, 0);
                if (isDesktopViewport()) {
                    setLocationStatus('Yakın bölge bulundu.');
                    setLocationInsight('Yakın bölgen haritada hazır. Doğru sonucu almak için bulunduğun noktayı haritadan seç.');
                } else {
                    setLocationStatus('Yaklaşık konum hazır.');
                    setLocationInsight('Yakındaki otelleri görmek için yarıçapı ayarlayabilirsin.');
                }

                if (isDesktopViewport()) {
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                } else {
                    applyFilters();
                    sortCards();
                    ensureClientFilterPoolLoaded().then(function () {
                        applyFilters();
                        sortCards();
                        syncMobileFilterCount();
                    });
                    queueLocationLog(true);
                }

                if (!hasPromptedManualLocation && isDesktopViewport()) {
                    hasPromptedManualLocation = true;
                    window.setTimeout(function () {
                        openLocationMapModal({ pickMode: true });
                    }, 180);
                }
            }

            async function applyLocationError(error) {
                setLocationCoords(NaN, NaN);
                if (error && error.code === 1) {
                    clearPersistedLocationSnapshot();
                }
                if (error && error.code === 1) {
                    await applyApproximateLocationFallback('Tarayıcı konum izni kapalı. Yaklaşık konum deneniyor.');
                    return;
                }
                if (error && error.code === 2) {
                    await applyApproximateLocationFallback('Tarayıcı tam konumu bulamadı. Yaklaşık konum deneniyor.');
                    return;
                }
                if (error && error.code === 3) {
                    await applyApproximateLocationFallback('Konum zaman aşımına uğradı. Yaklaşık konum deneniyor.');
                    return;
                }
                await applyApproximateLocationFallback('Konum alınamadı. Yaklaşık konum deneniyor.');
            }

            function requestUserLocation() {
                desktopApproximateSelectionPending = false;
                if (!window.isSecureContext && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
                    setLocationPermissionState('denied');
                    setLocationStatus('Konum için güvenli bağlantı gerekiyor.');
                    return;
                }
                if (!('geolocation' in navigator)) {
                    setLocationPermissionState('denied');
                    setLocationStatus('Tarayıcı konumu desteklemiyor.');
                    return;
                }

                setLocationPermissionState('loading');
                setLocationStatus('Konum alınıyor...');
                const mobile = isMobileViewport();
                const primaryOptions = mobile
                    ? { enableHighAccuracy: true, timeout: 25000, maximumAge: 0 }
                    : { enableHighAccuracy: false, timeout: 15000, maximumAge: 300000 };
                const fallbackOptions = mobile
                    ? { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 }
                    : { enableHighAccuracy: true, timeout: 20000, maximumAge: 0 };

                function handleLocationSuccess(pos) {
                    const accuracy = Number(pos?.coords?.accuracy || 0);
                    if (isDesktopViewport() && Number.isFinite(accuracy) && accuracy > 1500) {
                        applyApproximateLocationFallback('Konum yaklaşık bulundu. Haritadan noktanı seçerek doğrulayabilirsin.');
                        return;
                    }

                    applyLocationSuccess(pos);
                }

                navigator.geolocation.getCurrentPosition(
                    handleLocationSuccess,
                    function (error) {
                        if (error && error.code === 3) {
                            navigator.geolocation.getCurrentPosition(handleLocationSuccess, applyLocationError, fallbackOptions);
                            return;
                        }
                        applyLocationError(error);
                    },
                    primaryOptions
                );
            }

            useMyLocationBtn?.addEventListener('click', function () {
                // Hem masaüstü hem mobilde önce gerçek tarayıcı konumunu dene.
                // Masaüstünde tam konum alınamazsa mevcut fallback akışı yaklaşık konumu dener
                // ve gerekirse haritadan seçimi açar.
                requestUserLocation();
            });

            async function initializeLocationPermissionState() {
                const persistedLocation = readPersistedLocationSnapshot();
                if (persistedLocation) {
                    userLocation = {
                        lat: persistedLocation.lat,
                        lon: persistedLocation.lon,
                        accuracy: persistedLocation.accuracy,
                        approximate: !!persistedLocation.approximate,
                        source: String(persistedLocation.source || '')
                    };
                    if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                    if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                    enableDistanceFilterUi(true);
                    ensureDistanceControlsEnabled();
                    syncDistanceUi();
                    setLocationCoords(userLocation.lat, userLocation.lon, userLocation.accuracy);
                    setDistanceHotelCount(cards.filter(card => !card.hidden).length, true);
                    setLocationInsight('Yakındaki otelleri görmek için yarıçapı ayarlayabilirsin.');
                }

                if (!('permissions' in navigator) || !navigator.permissions?.query) {
                    setLocationPermissionState(persistedLocation
                        ? (persistedLocation.approximate ? 'approximate' : 'granted')
                        : 'prompt');
                    setLocationStatus(persistedLocation
                        ? 'Konum hazır.'
                        : 'Konumunu paylaş.');
                    return;
                }

                try {
                    const permissionStatus = await navigator.permissions.query({ name: 'geolocation' });
                    const syncState = function () {
                        if (userLocation && Number.isFinite(userLocation.lat) && Number.isFinite(userLocation.lon)) {
                            enableDistanceFilterUi(true);
                            ensureDistanceControlsEnabled();
                            setLocationPermissionState(userLocation.approximate ? 'approximate' : 'granted');
                            setLocationStatus(userLocation.approximate ? 'Yaklaşık konum hazır.' : 'Konum hazır.');
                            return;
                        }

                        if (permissionStatus.state === 'granted') {
                            setLocationPermissionState(userLocation?.approximate ? 'approximate' : 'granted');
                            setLocationStatus(persistedLocation
                                ? 'Konum hazır.'
                                : 'İzin verip konumunu kullan.');
                            enableDistanceFilterUi(true);
                            ensureDistanceControlsEnabled();
                            if (!userLocation || !persistedLocation) {
                                requestUserLocation();
                            }
                            return;
                        }

                        if (permissionStatus.state === 'denied') {
                            if (persistedLocation && userLocation) {
                                setLocationPermissionState(userLocation.approximate ? 'approximate' : 'granted');
                                setLocationStatus('Son doğrulanan konumun hazır. Daha hassas sonuç için tarayıcı konum iznini açabilirsiniz.');
                                enableDistanceFilterUi(true);
                                ensureDistanceControlsEnabled();
                                return;
                            }

                            setLocationPermissionState('prompt');
                            userLocation = null;
                            enableDistanceFilterUi(false);
                            setLocationCoords(NaN, NaN);
                            clearPersistedLocationSnapshot();
                            setLocationStatus('Konum izni kapalıysa yaklaşık konumla devam edebiliriz. Konumu kullan butonuna tekrar dokunun.');
                            return;
                        }

                        setLocationPermissionState(persistedLocation ? 'granted' : 'prompt');
                        setLocationStatus(persistedLocation
                            ? 'Konum hazır.'
                            : 'Konumunu paylaş.');
                    };

                    syncState();
                    permissionStatus.onchange = syncState;
                } catch (_) {
                    setLocationPermissionState('prompt');
                }
            }

            distanceKmRange?.addEventListener('input', function () {
                syncDistanceUi();
                if (userLocation) {
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                }
            });
            distanceKmRange?.addEventListener('change', function () {
                syncDistanceUi();
                applyFilters();
            });
            distanceKmRange?.addEventListener('pointerdown', function () {
                if (distanceKmRange.disabled) {
                    requestUserLocation();
                }
            });
            keywordInput?.addEventListener('focus', function () {
                if (String(keywordInput.value || '').trim().length > 0) {
                    window.clearTimeout(keywordSuggestionTimer);
                    keywordSuggestionTimer = window.setTimeout(loadKeywordSuggestions, 120);
                }
            });
            keywordClearBtn?.addEventListener('click', function () {
                if (!keywordInput) return;
                keywordInput.value = '';
                keywordClearBtn.hidden = true;
                hideKeywordSuggestions();
                applyFilters();
                sortCards();
                syncMobileFilterCount();
                keywordInput.focus();
            });
            keywordSuggestions?.addEventListener('click', function (event) {
                const button = event.target instanceof HTMLElement
                    ? event.target.closest('.listing-search-suggestion')
                    : null;
                if (!button || !(button instanceof HTMLButtonElement) || !keywordInput) {
                    return;
                }

                const selectedValue = button.dataset.value || '';
                const selectedType = (button.dataset.type || '').trim().toLowerCase();
                const selectedSlug = (button.dataset.slug || '').trim();

                keywordInput.value = selectedValue;
                if (keywordClearBtn) keywordClearBtn.hidden = selectedValue.trim().length === 0;
                hideKeywordSuggestions();

                if (selectedType === 'otel' && selectedSlug.length > 0) {
                    window.location.href = buildHotelDetailUrl(selectedSlug);
                    return;
                }

                applyFilters();
                sortCards();
                syncMobileFilterCount();
            });
            document.addEventListener('click', function (event) {
                if (keywordSuggestions?.hidden) return;
                const wrapper = keywordInput?.closest('.listing-search-lux');
                if (wrapper && event.target instanceof Node && !wrapper.contains(event.target)) {
                    hideKeywordSuggestions();
                }
            });
            locationCoordsText?.addEventListener('click', function () {
                if (!locationCoordsText.classList.contains('is-visible')) {
                    return;
                }
                openLocationMapModal({ pickMode: !!(userLocation && userLocation.approximate) });
            });
            locationMapConfirmBtn?.addEventListener('click', function () {
                applyManualMapSelection();
            });
            // Slider kaldırıldı.
            minPriceInput?.addEventListener('input', function () {
                handleManualPriceFilterInteraction(false);
            });
            maxPriceInput?.addEventListener('input', function () {
                handleManualPriceFilterInteraction(false);
            });
            minPriceInput?.addEventListener('change', function () {
                handleManualPriceFilterInteraction(true);
            });
            maxPriceInput?.addEventListener('change', function () {
                handleManualPriceFilterInteraction(true);
            });

            const filterCard = document.getElementById('listingFilterCard');
            const dockButtons = Array.from(document.querySelectorAll('[data-mobile-filter-target]'));
            const modal = document.getElementById('listingFilterModal');
            const modalOverlay = document.getElementById('listingFilterModalOverlay');
            const modalClose = document.getElementById('listingFilterModalClose');
            const modalHost = document.getElementById('listingMobileFilterHost');
            const modalApply = document.getElementById('listingFilterApplyBtn');
            const modalClear = document.getElementById('listingFilterClearBtn');
            const desktopSidebar = document.querySelector('.filter-sidebar');
            const filterCount = document.getElementById('mobileFilterCount');
            const modalTitle = modal?.querySelector('.modal-header h3');

            function openMobileFilters() {
                if (!modal || !modalHost || !filterCard) return;
                // Sadece mobilde modal filtre aç (desktop'ta sidebar zaten görünüyor)
                if (window.innerWidth > 900) {
                    return;
                }
                modal.classList.add('active');
                modal.setAttribute('aria-hidden', 'false');
                // Mobilde sayfayı kilitleme: arkaplan scroll serbest kalsın.
                if (filterCard.parentElement !== modalHost) {
                    modalHost.appendChild(filterCard);
                }
            }

            function openMobileFilterSection(target) {
                const idMap = {
                    location: 'filterLocation',
                    search: 'filterSearch',
                    price: 'filterPrice',
                    rating: 'filterRating'
                };
                const titleMap = {
                    location: 'Konuma Göre Ara',
                    search: 'Otel adı / il / ilçe / mahalle',
                    price: 'Fiyat Aralığı',
                    rating: 'Misafir Puanı'
                };

                if (target === 'all') {
                    if (modalTitle) {
                        modalTitle.textContent = 'Filtreler';
                    }
                    openMobileFilters();
                    return;
                }

                openMobileFilters();

                const sectionId = idMap[target] || '';
                const section = sectionId ? document.getElementById(sectionId) : null;
                if (modalTitle) {
                    modalTitle.textContent = titleMap[target] || 'Filtreler';
                }

                // Only keep target open for a focused popup experience.
                if (filterCard) {
                    filterCard.querySelectorAll('details.filter-accordion').forEach(function (d) {
                        if (d && d.id && d.id === sectionId) {
                            d.setAttribute('open', '');
                        }
                    });
                }

                window.setTimeout(function () {
                    if (section) {
                        section.scrollIntoView({ block: 'start', behavior: 'smooth' });
                    }
                }, 60);
            }

            function closeMobileFilters() {
                if (!modal) return;
                modal.classList.remove('active');
                modal.setAttribute('aria-hidden', 'true');
                if (desktopSidebar && filterCard && filterCard.parentElement !== desktopSidebar) {
                    desktopSidebar.appendChild(filterCard);
                }
            }

            dockButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const target = btn.getAttribute('data-mobile-filter-target') || '';
                    openMobileFilterSection(target);
                });
            });
            const yanbarFilterBtn = document.getElementById('listingYanbarFilterBtn');
            yanbarFilterBtn?.addEventListener('click', function () {
                openMobileFilterSection('all');
            });
            modalOverlay?.addEventListener('click', closeMobileFilters);
            modalClose?.addEventListener('click', closeMobileFilters);
            modalApply?.addEventListener('click', closeMobileFilters);
            modalClear?.addEventListener('click', function () {
                clearAllBtn?.click();
                closeMobileFilters();
            });

            window.addEventListener('resize', function () {
                if (window.innerWidth > 900) {
                    closeMobileFilters();
                }
            });
            amenityChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            starChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            featuredChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            campaignChecks.forEach(x => x.addEventListener('change', function () { applyFilters(); sortCards(); syncMobileFilterCount(); }));
            mealChecks.forEach(function (check) {
                check.addEventListener('change', function () {
                    if (check.checked) {
                        mealChecks.forEach(function (other) {
                            if (other !== check) {
                                other.checked = false;
                            }
                        });
                        navigateMealTag(check.value);
                        return;
                    }
                    navigateMealTag('');
                });
            });
            ratingChips.forEach(function (chip) {
                chip.addEventListener('click', function () {
                    chip.classList.toggle('active');
                    applyFilters();
                    sortCards();
                    syncMobileFilterCount();
                });
            });

            clearAllBtn?.addEventListener('click', function () {
                amenityChecks.forEach(x => x.checked = false);
                starChecks.forEach(x => x.checked = false);
                featuredChecks.forEach(x => x.checked = false);
                campaignChecks.forEach(x => x.checked = false);
                mealChecks.forEach(x => x.checked = false);
                ratingChips.forEach(x => x.classList.remove('active'));
                if (String(new URLSearchParams(window.location.search).get('etiket') || '').trim()) {
                    navigateMealTag('');
                    return;
                }
                if (keywordInput) keywordInput.value = '';
                hideKeywordSuggestions();
                if (minPriceInput) minPriceInput.value = String(defaultMinPrice);
                if (maxPriceInput) maxPriceInput.value = String(defaultMaxPrice);
                if (distanceKmRange) distanceKmRange.value = String(defaultLocationRadiusKm);
                if (distanceKmInput) distanceKmInput.value = String(defaultLocationRadiusKm);
                userLocation = null;
                listingNoticeShown = false;
                lastLocationLogSignature = '';
                clearPersistedLocationSnapshot();
                enableDistanceFilterUi(false);
                setLocationCoords(NaN, NaN);
                setDistanceHotelCount(0, false);
                setLocationPermissionState('prompt');
                setLocationStatus('Konumunu paylaş, koordinatını net alıp otelleri km cinsinden tarayalım.');
                setLocationInsight('Konum aramaları, partnerlerin bölgene otel eklemesi için anonim pazar içgörüsü üretir.');
                applyFilters();
                sortCards();
                syncDistanceUi();
                syncMobileFilterCount();
            });

            listingEmptyClearFilters?.addEventListener('click', function () {
                clearAllBtn?.click();
            });

            function syncMobileFilterCount() {
                if (!filterCount) return;
                const active =
                    (amenityChecks.filter(x => x.checked).length)
                    + (starChecks.filter(x => x.checked).length)
                    + (featuredChecks.filter(x => x.checked).length)
                    + (campaignChecks.filter(x => x.checked).length)
                    + (mealChecks.filter(x => x.checked).length)
                    + (ratingChips.filter(x => x.classList.contains('active')).length)
                    + ((String(keywordInput?.value || '').trim().length > 0) ? 1 : 0)
                    + ((Number(minPriceInput?.value || '0') > 0) ? 1 : 0)
                    + ((Number(maxPriceInput?.value || '0') > 0) ? 1 : 0);

                filterCount.textContent = String(active);
                filterCount.hidden = active <= 0;
            }

            // Desktop: film-rulosu/makara (ekranda 7 kart sabit, wheel ile kartlar alttan girer üstten çıkar)
            (function setupDesktopReelScroll() {
                // Klasik sayfalama kullanılır (1-2-3-4...). Reel/sonsuz yükleme devre dışı.
                return;
                if (window.innerWidth <= 900) return;
                const reelViewport = document.getElementById('listingReelViewport');
                const sentinel = null; // sonsuz yükleme kapalı
                if (!reelViewport || !listView) return;

                const pager = document.querySelector('.listing-pagination');
                if (pager) pager.style.display = 'none';

                let loading = false;
                let currentPage = Number(sentinel.getAttribute('data-current-page') || '1');
                const totalPages = Number(sentinel.getAttribute('data-total-pages') || '1');
                const baseSearch = sentinel.getAttribute('data-search-term') || '';
                const baseTag = sentinel.getAttribute('data-active-tag') || '';
                const baseCampaign = sentinel.getAttribute('data-campaign') || '';
                const isNoSearchContext = !String(baseSearch || '').trim()
                    && !String(baseTag || '').trim()
                    && !String(baseCampaign || '').trim();
                const MAX_PRELOAD_NOSEARCH = 50;
                const BUFFER_CARDS = 16; // 6 gorunen + altta en az 10 hazir

                function buildPageUrl(page) {
                    const params = new URLSearchParams(window.location.search);
                    if (baseSearch) params.set('q', baseSearch);
                    if (baseTag) params.set('etiket', baseTag);
                    if (baseCampaign) params.set('kampanya', baseCampaign);
                    params.set('page', String(page));
                    return window.location.pathname + '?' + params.toString();
                }

                async function loadNextPageIfNeeded() {
                    const cardsNow = Array.from(listView.querySelectorAll('.listing-hotel-card'));
                    if (isNoSearchContext && cardsNow.length >= MAX_PRELOAD_NOSEARCH) return;
                    if (loading) return;
                    if (cardsNow.length >= BUFFER_CARDS && !isNoSearchContext) return;
                    if (!Number.isFinite(currentPage) || !Number.isFinite(totalPages) || currentPage >= totalPages) return;
                    loading = true;
                    const nextPage = currentPage + 1;
                    try {
                        const response = await fetch(buildPageUrl(nextPage), {
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        if (!response.ok) return;
                        const html = await response.text();
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const newCards = Array.from(doc.querySelectorAll('.listing-hotel-card'));
                        if (newCards.length === 0) return;
                        newCards.forEach(function (card) {
                            listView.appendChild(document.importNode(card, true));
                        });
                        refreshCards();
                        currentPage = nextPage;
                        sentinel.setAttribute('data-current-page', String(currentPage));
                    } catch (_) {
                        // sessiz
                    } finally {
                        loading = false;
                    }
                }

                window.ensureListingCardsLoaded = async function () {
                    let guard = 0;
                    while (guard < 50 && Number.isFinite(currentPage) && Number.isFinite(totalPages) && currentPage < totalPages) {
                        const before = Array.from(listView.querySelectorAll('.listing-hotel-card')).length;
                        await loadNextPageIfNeeded();
                        const after = Array.from(listView.querySelectorAll('.listing-hotel-card')).length;
                        if (after <= before) {
                            break;
                        }
                        guard += 1;
                    }
                };

                function getStepHeight() {
                    const first = listView.querySelector('.listing-hotel-card');
                    if (!first) return 320;
                    const rect = first.getBoundingClientRect();
                    const gap = 20;
                    return Math.max(220, rect.height + gap);
                }

                function ensureViewportHeight() {
                    const step = getStepHeight();
                    // 6 kart görünsün
                    reelViewport.style.height = (step * 6) + 'px';
                }

                // Sağdaki "kurma kolu/çark" efekti
                const crank = document.getElementById('listingReelCrank');
                function pulseCrank(delta) {
                    if (!crank) return;
                    crank.classList.add('is-cranking');
                    const prev = Number(crank.style.getPropertyValue('--crank-rot') || '0');
                    const next = prev + (delta / 6);
                    crank.style.setProperty('--crank-rot', String(next));
                    window.clearTimeout(crank.__t);
                    crank.__t = window.setTimeout(function () {
                        crank.classList.remove('is-cranking');
                    }, 140);
                }

                // Reel: DOM'u taşımadan (append/insert) scrollTop ile inertia.
                // Böylece kartlarda "yenilenme" hissi oluşmaz ve yarım kart kayması doğal görünür.
                let stepHeight = 0;
                let targetScrollTop = 0;
                let scrollV = 0; // velocity
                let scrolling = false;
                let lastTs = 0;

                function clampScrollTop(value) {
                    const max = Math.max(0, (reelViewport.scrollHeight || 0) - (reelViewport.clientHeight || 0));
                    if (max <= 0) return 0;
                    // Sürekli döngü: sona gelince başa, başa gelince sona sar.
                    // (DOM taşımıyoruz; scrollTop sararak loop hissi veriyoruz.)
                    if (value > max) {
                        return (value - max);
                    }
                    if (value < 0) {
                        return (max + value);
                    }
                    return value;
                }

                function ensureStep() {
                    if (!stepHeight) stepHeight = getStepHeight();
                    ensureViewportHeight();
                }

                function maybePrefetchNearBottom() {
                    ensureStep();
                    const threshold = stepHeight * 3; // alta yaklaşınca
                    const remain = (reelViewport.scrollHeight - (reelViewport.scrollTop + reelViewport.clientHeight));
                    if (remain <= threshold) {
                        loadNextPageIfNeeded();
                    }
                }

                function tick(ts) {
                    if (!scrolling) {
                        lastTs = ts;
                        return;
                    }
                    const dtMs = Math.min(34, Math.max(10, ts - (lastTs || ts)));
                    lastTs = ts;
                    const dt = dtMs / 16.67;

                    // sürtünme: ipeksi akış
                    const friction = 0.86;
                    scrollV = scrollV * Math.pow(friction, dt);

                    if (Math.abs(scrollV) < 0.10) {
                        scrollV = 0;
                        scrolling = false;
                        maybePrefetchNearBottom();
                        // Üstte kart yarım kalmasın: en yakın kart sınırına yumuşak hizala.
                        ensureStep();
                        if (stepHeight > 0) {
                            const st = reelViewport.scrollTop || 0;
                            const snapped = Math.round(st / stepHeight) * stepHeight;
                            reelViewport.scrollTo({ top: clampScrollTop(snapped), behavior: 'smooth' });
                            targetScrollTop = reelViewport.scrollTop || 0;
                        }
                        return;
                    }

                    targetScrollTop = clampScrollTop(targetScrollTop + (scrollV * dt));
                    reelViewport.scrollTop = targetScrollTop;
                    maybePrefetchNearBottom();
                    window.requestAnimationFrame(tick);
                }

                function onWheel(e) {
                    e.preventDefault();
                    ensureStep();

                    const delta = Math.max(-180, Math.min(180, (e.deltaY || 0)));
                    const accel = 0.55; // wheel -> velocity (yumuşak)
                    scrollV += delta * accel;
                    scrollV = Math.max(-95, Math.min(95, scrollV));
                    pulseCrank(delta);

                    if (!scrolling) {
                        scrolling = true;
                        targetScrollTop = reelViewport.scrollTop || 0;
                        lastTs = 0;
                        window.requestAnimationFrame(tick);
                    }
                }

                // initial
                ensureViewportHeight();
                // 6.5 kart görünsün (yarım kart kayması hissi)
                stepHeight = 0;
                (function setHalfCardViewport() {
                    const step = getStepHeight();
                    reelViewport.style.height = (step * 6.5) + 'px';
                })();
                reelViewport.style.overflowY = 'auto';
                reelViewport.style.overflowX = 'hidden';
                reelViewport.style.position = 'relative';
                listView.style.willChange = 'auto';

                // Filtre uygulandiginda listeyi üstten tam baslat.
                reelResetToTop = function () {
                    scrollV = 0;
                    scrolling = false;
                    targetScrollTop = 0;
                    reelViewport.scrollTop = 0;
                };

                reelViewport.addEventListener('wheel', onWheel, { passive: false });
                reelViewport.addEventListener('scroll', function () {
                    // Kullanıcı trackpad ile doğal scroll ederse de prefetch çalışsın.
                    maybePrefetchNearBottom();
                }, { passive: true });

                // Aramasız girişte 50 oteli önceden getir (8 sayfa civarı), sonra loop bu havuzda döner.
                if (isNoSearchContext) {
                    (async function warmUpNoSearchPool() {
                        for (let i = 0; i < 12; i += 1) {
                            const cardsNow = Array.from(listView.querySelectorAll('.listing-hotel-card'));
                            if (cardsNow.length >= MAX_PRELOAD_NOSEARCH) break;
                            const before = cardsNow.length;
                            await loadNextPageIfNeeded();
                            const after = Array.from(listView.querySelectorAll('.listing-hotel-card')).length;
                            if (after <= before) break;
                        }
                    })();
                }

                window.addEventListener('resize', function () {
                    ensureViewportHeight();
                    stepHeight = 0;
                    // yarım kart görünümü korunmalı
                    const step = getStepHeight();
                    reelViewport.style.height = (step * 6.5) + 'px';
                });
            })();

            applyFilters();
            sortCards();
            normalizeManualPriceInputs(true);
            syncMobileFilterCount();
            initializeLocationPermissionState();

            document.addEventListener('click', function (event) {
                const closeTarget = event.target instanceof HTMLElement ? event.target.closest('[data-location-map-close]') : null;
                if (closeTarget) {
                    closeLocationMapModal();
                }
                const noticeCloseTarget = event.target instanceof HTMLElement ? event.target.closest('[data-listing-notice-close]') : null;
                if (noticeCloseTarget) {
                    closeListingNoticeModal();
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && locationMapModal && !locationMapModal.hidden) {
                    closeLocationMapModal();
                }
                if (event.key === 'Escape' && listingFilterNoticeModal && !listingFilterNoticeModal.hidden) {
                    closeListingNoticeModal();
                }
            });

            // Focus trap: Tab ile modal dışına kaçmasın.
            document.addEventListener('keydown', function (event) {
                if (event.key !== 'Tab') return;
                if (!locationMapModal || locationMapModal.hidden) return;
                const focusables = Array.from(locationMapModal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex=\"-1\"])'))
                    .filter(function (el) { return el && !el.hasAttribute('disabled') && (el.offsetParent !== null || el.getAttribute('aria-hidden') !== 'true'); });
                if (!focusables.length) return;
                const first = focusables[0];
                const last = focusables[focusables.length - 1];
                const active = document.activeElement;
                if (event.shiftKey) {
                    if (active === first || !locationMapModal.contains(active)) {
                        event.preventDefault();
                        last.focus();
                    }
                } else {
                    if (active === last) {
                        event.preventDefault();
                        first.focus();
                    }
                }
            });
            listingNoticeFocusBtn?.addEventListener('click', function () {
                closeListingNoticeModal();
                document.getElementById('filterSearch')?.setAttribute('open', 'open');
                keywordInput?.focus();
            });
        })();
    </script>
    <script nonce="@nonce">
        (function () {
            const modal = document.getElementById('discountModal');
            const title = document.getElementById('discountModalTitle');
            const desc = document.getElementById('discountModalDesc');
            const visual = document.getElementById('discountModalVisual');
            const image = document.getElementById('discountModalImage');
            if (!modal || !title || !desc || !visual || !image) return;

            function openDiscount(data) {
                title.textContent = data.title || 'İndirim';
                desc.textContent = data.desc || '';
                const img = (data.image || '').trim();
                if (img) {
                    image.src = img;
                    visual.hidden = false;
                } else {
                    image.src = '';
                    visual.hidden = true;
                }
                modal.hidden = false;
                modal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }

            function closeDiscount() {
                modal.hidden = true;
                modal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }

            document.addEventListener('click', function (event) {
                const btn = event.target.closest('[data-discount-open]');
                if (btn) {
                    event.preventDefault();
                    openDiscount({
                        title: btn.getAttribute('data-discount-title') || '',
                        desc: btn.getAttribute('data-discount-desc') || '',
                        image: btn.getAttribute('data-discount-image') || ''
                    });
                    return;
                }
                if (event.target.closest('[data-discount-close]')) {
                    closeDiscount();
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && !modal.hidden) {
                    closeDiscount();
                }
            });
        })();
    </script>
