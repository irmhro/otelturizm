  .wishlist-btn { position: absolute; top: var(--space-3); right: var(--space-3); width: 38px; height: 38px; border-radius: 50%; background: rgba(255,255,255,0.96); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; color: var(--secondary); cursor: pointer; z-index: 3; box-shadow: 0 10px 26px rgba(0,0,0,0.14); border: 1px solid rgba(15,23,42,0.08); }
