<style>
  :root {
    --font-main: 'Satoshi', sans-serif;
    --primary: #003B95;
    --primary-dark: #002A6B;
    --secondary: #FF385C;
    --success: #00A86B;
    --warning: #FFB800;
    --error: #EF4444;
    --gold: #FFD700;
    --bg-light: #F8FAFC;
    --card-bg: #FFFFFF;
    --text-dark: #1A1F26;
    --text-gray: #4a4a4a;
    --text-light: #94A3B8;
    --border-light: #E2E8F0;
    --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
    --space-5: 20px; --space-6: 24px; --space-8: 32px;
    --radius-sm: 12px; --radius-md: 16px; --radius-lg: 20px;
    --radius-xl: 24px; --radius-full: 9999px;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
    --shadow-md: 0 8px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 20px 40px -10px rgba(0, 59, 149, 0.12);
    --header-height: 65px;
    --filter-bar-height: 56px;
    --container-max: 1280px;
  }

  .hotel-listing-shell { font-family: var(--font-main); background: var(--bg-light); color: var(--text-dark); padding-bottom: 80px; }
  .listing-container {
    box-sizing: border-box;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding-left: var(--space-8);
    padding-right: var(--space-8);
  }
  @@media (max-width: 1024px) {
    .listing-container { padding-left: var(--space-6); padding-right: var(--space-6); }
  }
  @@media (max-width: 560px) {
    .listing-container { padding-left: var(--space-5); padding-right: var(--space-5); }
  }
  .sticky-header { position: sticky; top: 0; z-index: 100; background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.5); box-shadow: var(--shadow-sm); }
  .search-summary-bar { display: flex; align-items: center; justify-content: space-between; padding: var(--space-3) 0; height: var(--header-height); }
  .back-btn { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; font-size: 22px; color: var(--text-dark); cursor: pointer; text-decoration:none; }
  .search-content { flex: 1; text-align: center; }
  .search-content h2 { font-size: 18px; font-weight: 700; margin-bottom: 2px; }
  .search-content p { font-size: 13px; color: var(--text-gray); display: flex; align-items: center; justify-content: center; gap: var(--space-2); }
  .edit-search { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: var(--bg-light); border-radius: var(--radius-full); border: 1px solid var(--border-light); color: var(--primary); cursor: pointer; }
  .filter-sort-bar { display: flex; align-items: center; justify-content: space-between; padding-bottom: var(--space-3); height: var(--filter-bar-height); gap: var(--space-3); }
  .quick-filters { display: flex; gap: var(--space-2); overflow-x: auto; scrollbar-width: none; white-space: nowrap; flex: 1; padding: var(--space-1) 0; }
  .quick-filter-btn { padding: var(--space-2) var(--space-4); background: var(--card-bg); border: 1px solid var(--border-light); border-radius: var(--radius-full); font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; flex-shrink: 0; }
  .quick-filter-btn i { color: var(--primary); font-size: 14px; }
  .quick-filter-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
  .quick-filter-btn.active i { color: white; }
  .sort-select { padding: var(--space-2) var(--space-4); border: 1px solid var(--border-light); border-radius: var(--radius-full); font-size: 14px; background: var(--card-bg); cursor: pointer; flex-shrink: 0; }
  .active-filters { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); padding: var(--space-2) 0 var(--space-3); border-top: 1px solid var(--border-light); }
  .active-filter-tag { display: flex; align-items: center; gap: 6px; background: var(--primary); color: white; padding: 4px 12px; border-radius: var(--radius-full); font-size: 13px; }
  .active-filter-tag i { cursor: pointer; opacity: 0.8; }
  .clear-all { color: var(--primary); font-weight: 600; font-size: 13px; cursor: pointer; margin-left: auto; }
  .view-toggle { display: flex; gap: var(--space-2); margin-bottom: var(--space-4); margin-top: var(--space-4); }
  .view-btn { flex: 1; padding: var(--space-3); background: var(--card-bg); border: 1px solid var(--border-light); border-radius: var(--radius-full); font-weight: 600; font-size: 14px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; transition: all 0.2s; }
  .view-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
  .results-container { display: flex; gap: var(--space-6); margin-top: var(--space-4); align-items: flex-start; }
  .results-container, .filter-sidebar, .listing-main, .hotel-list, .listing-cards { min-width: 0; max-width: 100%; }
  .filter-sidebar { width: 280px; flex-shrink: 0; display: block; }
  .filter-card { background: var(--card-bg); border-radius: var(--radius-lg); border: 1px solid var(--border-light); padding: var(--space-5); margin-bottom: var(--space-4); }
  .filter-section { margin-bottom: var(--space-6); }
  .filter-section h4 { font-size: 15px; font-weight: 700; margin-bottom: var(--space-4); }
  .price-range { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-3); margin: 14px 0 2px; }
  .price-range input { width: 100%; min-width: 0; padding: 10px; border: 1px solid var(--border-light); border-radius: var(--radius-md); background: rgba(248,250,252,1); font-weight: 700; }
  .filter-options { display: flex; flex-direction: column; gap: var(--space-3); }
  .filter-options > input { width: 100%; min-width: 0; padding: 10px 12px; border: 1px solid var(--border-light); border-radius: var(--radius-md); }
  .filter-check { display: flex; align-items: center; gap: var(--space-2); cursor: pointer; font-size: 14px; }
  .campaign-filter-scroll {
      display: flex;
      flex-direction: column;
      gap: 8px;
      max-height: 208px; /* ~5 kampanya görünür */
      overflow-y: auto;
      overflow-x: hidden;
      padding: 2px 2px 4px;
      scrollbar-width: thin;
  }
  .campaign-filter-chip {
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border-light);
      border-radius: 12px;
      padding: 8px 10px;
      font-size: 13px;
      font-weight: 700;
      background: #fff;
      cursor: pointer;
      width: 100%;
  }
  .campaign-filter-chip span {
