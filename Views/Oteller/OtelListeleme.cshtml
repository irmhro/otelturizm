      font-weight: 800;
      color: var(--text-light);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
  }
  .location-btn-state { display: none; }
  .location-coords { display:none; margin-top: 0; font-size: 11.5px; font-weight: 700; color: var(--text-light); background: transparent; border: 0; border-left: 3px solid rgba(0,59,149,0.14); border-radius: 0; padding: 2px 0 2px 10px; word-break: break-word; }
  .location-coords.is-visible { display:block; }
  .location-insight { margin-top: -2px; font-size: 11.5px; color: var(--text-light); background: transparent; border: 0; padding: 0; }

  .location-coords.is-visible { padding-top: 10px; border-top: 1px dashed rgba(226,232,240,1); }
  .km-row { padding: 12px 0 0; border: 0; border-top: 1px dashed rgba(226,232,240,1); border-radius: 0; background: transparent; display:grid; gap: 10px; }
  .km-row-head { display:flex; align-items:center; justify-content:space-between; gap: 10px; margin-bottom: 0; }
  .km-row-head strong { font-size: 14px; font-weight: 900; }
