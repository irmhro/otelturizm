      height: 10px;
      transform: translate(-50%, -50%);
      border-radius: 999px;
      background: rgba(255,255,255,0.9);
      border: 2px solid rgba(0,59,149,0.55);
      box-shadow: 0 10px 20px rgba(0,59,149,0.18);
      z-index: 2;
  }
  .price-slider-dot[data-price-dot="0"] { left: 0%; }
  .price-slider-dot[data-price-dot="1"] { left: 16.666%; }
  .price-slider-dot[data-price-dot="2"] { left: 33.333%; }
  .price-slider-dot[data-price-dot="3"] { left: 50%; }
  .price-slider-dot[data-price-dot="4"] { left: 66.666%; }
  .price-slider-dot[data-price-dot="5"] { left: 83.333%; }
  .price-slider-dot[data-price-dot="6"] { left: 100%; }

  #listingPriceMaxRange {
      width: 100%;
      -webkit-appearance: none;
      appearance: none;
      height: 38px;
      background: transparent;
      margin: 0;
      padding: 0;
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
  }
  #listingPriceMaxRange::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #dbeafe 35%, #60a5fa 100%);
      border: 2px solid rgba(0,59,149,0.55);
      box-shadow: 0 12px 26px rgba(0,59,149,0.28), 0 0 0 6px rgba(0,59,149,0.12);
      cursor: pointer;
  }
  #listingPriceMaxRange::-moz-range-thumb {
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #dbeafe 35%, #60a5fa 100%);
      border: 2px solid rgba(0,59,149,0.55);
      box-shadow: 0 12px 26px rgba(0,59,149,0.28), 0 0 0 6px rgba(0,59,149,0.12);
      cursor: pointer;
  }
  /* Konuma göre filtre */
  .location-filter-card {
      display: grid;
      gap: 12px;
      overflow: hidden;
      border: 0;
      border-radius: 0;
      padding: 0;
      background: transparent;
      box-sizing: border-box;
      min-width: 0;
  }
  .location-btn-eyebrow { display: none; }
  #locationStatusText { display: block; }
  #locationInsightText { display: none; }
  .location-btn {
      width: 100%;
      border: 1px solid rgba(16,185,129,0.35);
      border-radius: 16px;
      padding: 12px 14px;
      background: linear-gradient(135deg, rgba(16,185,129,0.18) 0%, rgba(34,197,94,0.14) 45%, rgba(255,255,255,1) 100%);
      display: flex;
