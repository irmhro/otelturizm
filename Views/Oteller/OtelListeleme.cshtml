@using Microsoft.Extensions.Configuration
@model otelturizmnew.Models.Oteller.HotelListingPageViewModel
@{
    Layout = "~/Views/Shared/_PublicPremiumPageLayout.cshtml";
    ViewData["BodyClass"] = "otelliste-page-shell anasayfa-page";
    ViewData["PageCss"] = "otelliste_masaustu";
    ViewData["PageCssMobile"] = "otelliste_mobil";
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Oteller" : Model.SearchLabel;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    var metaDescription = string.IsNullOrWhiteSpace(Model.SearchLabel)
        ? "Türkiye genelinde otelleri filtreleyin, fiyatları karşılaştırın ve güvenle rezervasyon oluşturun."
        : $"{Model.SearchLabel} için otelleri filtreleyin, fiyatları karşılaştırın ve güvenle rezervasyon oluşturun.";
    ViewData["MetaDescription"] = metaDescription;
    ViewData["Canonical"] = $"{baseUrl}{Context.Request.Path}";
    string? jsonLd = null;
    try
    {
        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Oteller", ["item"] = $"{baseUrl}/oteller" }
            }
        };
        jsonLd = System.Text.Json.JsonSerializer.Serialize(breadcrumbJsonLd);
    }
    catch { }
}

@section HeadStyles {
    <meta name="description" content="@metaDescription" />
    <link rel="canonical" href="@ViewData["Canonical"]" />
    @if (!string.IsNullOrWhiteSpace(jsonLd))
    {
        <script type="application/ld+json">@Html.Raw(jsonLd)</script>
    }
}

<partial name="~/Views/Oteller/_OtelListelemeContent.cshtml" model="Model" />

@section Scripts {
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
    <script src="~/assets/js/otelliste-filters.js" asp-append-version="true" defer></script>
}
