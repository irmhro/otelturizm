@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["PageCss"] = "otel-listeleme";

    var hotels = Model.Hotels ?? new List<otelturizmnew.Models.Oteller.HotelListingCardViewModel>();
    var resultCount = hotels.Count;
    var districtCounts = hotels
        .Where(x => !string.IsNullOrWhiteSpace(x.District))
        .GroupBy(x => x.District)
        .OrderByDescending(x => x.Count())
        .ThenBy(x => x.Key)
        .ToList();
    var starCounts = hotels
        .Where(x => x.StarCount.HasValue && x.StarCount.Value > 0)
        .GroupBy(x => x.StarCount!.Value)
        .OrderByDescending(x => x.Key)
        .ToDictionary(x => x.Key, x => x.Count());
    var amenityCounts = hotels
        .SelectMany(x => x.Amenities)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .GroupBy(x => x, StringComparer.OrdinalIgnoreCase)
        .OrderByDescending(x => x.Count())
        .ThenBy(x => x.Key)
        .ToList();
    var topAmenities = amenityCounts.Take(5).ToList();
    var minPrice = Model.MinPrice > 0 ? Model.MinPrice : 0;
    var maxPrice = Model.MaxPrice > 0 ? Model.MaxPrice : 15000;
    var activeFilters = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.ActiveTag))
    {
        activeFilters.Add(Model.CampaignTitle);
    }
    if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        activeFilters.Add(Model.SearchLabel);
    }
    if (minPrice > 0 || maxPrice > 0)
    {
        activeFilters.Add($"₺{minPrice:N0} - ₺{maxPrice:N0}");
    }

    var quickFilterConfigs = new[]
    {
        new { Label = "WiFi", Icon = "fa-wifi", Match = "wifi" },
        new { Label = "Havuz", Icon = "fa-person-swimming", Match = "havuz" },
        new { Label = "Otopark", Icon = "fa-square-parking", Match = "otopark" },
        new { Label = "Kahvaltı", Icon = "fa-mug-hot", Match = "kahvalt" },
        new { Label = "Spa", Icon = "fa-spa", Match = "spa" }
    };

    string NormalizeToken(string value)
    {
        return value
            .Replace("ı", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("İ", "i", StringComparison.OrdinalIgnoreCase)
            .Replace("ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("Ö", "o", StringComparison.OrdinalIgnoreCase)
            .Replace("ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("Ü", "u", StringComparison.OrdinalIgnoreCase)
            .Replace("ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("Ş", "s", StringComparison.OrdinalIgnoreCase)
            .Replace("ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("Ç", "c", StringComparison.OrdinalIgnoreCase)
            .Replace("ğ", "g", StringComparison.OrdinalIgnoreCase)
            .Replace("Ğ", "g", StringComparison.OrdinalIgnoreCase)
            .ToLowerInvariant();
    }

    string GetAmenityIconClass(string amenity)
    {
        var normalized = NormalizeToken(amenity);
        if (normalized.Contains("wifi")) return "fa-wifi";
        if (normalized.Contains("havuz")) return "fa-person-swimming";
        if (normalized.Contains("otopark")) return "fa-square-parking";
        if (normalized.Contains("spa")) return "fa-spa";
        if (normalized.Contains("kahvalt")) return "fa-mug-hot";
        if (normalized.Contains("restoran")) return "fa-utensils";
        return "fa-circle-check";
    }

    var quickFilterItems = quickFilterConfigs
        .Select(config => new
        {
            config.Label,
            config.Icon,
            Token = config.Match,
            Count = hotels.Count(h => h.Amenities.Any(a => NormalizeToken(a).Contains(config.Match, StringComparison.OrdinalIgnoreCase)))
        })
        .Where(x => x.Count > 0)
        .ToList();

    var guestScoreFilters = new[]
    {
        "9+ Muhtesem",
        "8+ Cok Iyi",
        "7+ Iyi"
    };

    var mealOptions = new[]
    {
        "Oda Kahvalti",
        "Her Sey Dahil",
        "Yarim Pansiyon"
    };

    var specialConcepts = new[]
    {
        "En Iyi Fiyat",
        "Hafta Sonu Indirimi",
        "Yildiz Yagmuru",
        "Kampanyali"
    };

    var infoLine = resultCount > 0
        ? $"{resultCount} tesis • {districtCounts.Count} bolge"
        : "Veritabani kriterlerine uygun sonuc bulunamadi";
}

<section class="hotel-listing-shell listing-template-v41">
    <div class="listing-container">
        <header class="listing-sticky-header sticky-header">
            <div class="listing-search-summary search-summary-bar">
                <a asp-controller="Home" asp-action="Index" class="listing-back-btn back-btn" aria-label="Anasayfaya don">
                    <i class="fas fa-arrow-left"></i>
                </a>

                <div class="listing-search-copy search-content">
                    <h1>@Model.SearchLabel</h1>
                    <p id="listingInfoLine">
                        <i class="fas fa-hotel"></i>
                        <span>@infoLine</span>
                    </p>
                </div>

                <a asp-controller="Home" asp-action="Index" class="listing-edit-search edit-search" aria-label="Aramayi duzenle">
                    <i class="fas fa-sliders-h"></i>
                </a>
            </div>

            <div class="listing-toolbar filter-sort-bar">
                <div class="listing-quick-filters quick-filters" aria-label="Hizli filtreler">
                    @foreach (var quickFilter in quickFilterItems)
                    {
                        <button type="button" class="quick-filter-chip quick-filter-btn" data-chip-filter="@quickFilter.Token">
                            <i class="fas @quickFilter.Icon"></i>
                            <span>@quickFilter.Label</span>
                            <small>@quickFilter.Count</small>
                        </button>
                    }

                    <button type="button" class="quick-filter-chip quick-filter-chip-ghost quick-filter-btn" data-open-mobile-filters>
                        <i class="fas fa-filter"></i>
                        <span>Tum Filtreler</span>
                    </button>
                </div>

                <label class="listing-sortbox" for="listingSortSelect">
                    <span>Sirala</span>
                    <select id="listingSortSelect" class="sort-select">
                        <option value="recommended">Onerilen</option>
                        <option value="price-asc">En Dusuk Fiyat</option>
                        <option value="rating-desc">En Yuksek Puan</option>
                    </select>
                </label>
            </div>

            @if (activeFilters.Count > 0)
            {
                <div class="listing-active-filters active-filters">
                    @foreach (var filter in activeFilters)
                    {
                        <span class="active-filter-pill active-filter-tag">@filter <i class="fas fa-times"></i></span>
                    }
                    <a asp-controller="Oteller" asp-action="OtelListeleme" class="clear-filter-link clear-all">Tumunu Temizle</a>
                </div>
            }
        </header>

        <div class="listing-view-switch view-toggle" role="tablist" aria-label="Gorunum secimi">
            <button type="button" class="view-switch-btn view-btn active" id="listingListViewBtn" data-view-mode="list">
                <i class="fas fa-list"></i>
                <span>Liste</span>
            </button>
            <button type="button" class="view-switch-btn view-btn" id="listingMapViewBtn" data-view-mode="map">
                <i class="fas fa-map-location-dot"></i>
                <span>Harita</span>
            </button>
        </div>

        <div class="listing-results-grid results-container" id="listingResultsGrid">
            <aside class="listing-filter-sidebar filter-sidebar" id="listingFilterSidebar">
                <div class="filter-panel filter-card">
                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Fiyat Araligi</h3>
                            <span>Gecelik</span>
                        </div>
                        <input type="range" min="0" max="@(Math.Max(maxPrice, 15000))" value="@maxPrice" class="filter-range" id="listingPriceMaxRange" />
                        <div class="filter-price-grid price-range">
                            <label>
                                <span>Min</span>
                                <input type="number" id="listingMinPriceInput" value="@minPrice" />
                            </label>
                            <label>
                                <span>Max</span>
                                <input type="number" id="listingMaxPriceInput" value="@maxPrice" />
                            </label>
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Yildiz Sayisi</h3>
                            <span>@starCounts.Values.Sum()</span>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var star in Model.StarOptions)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-star-filter" value="@star" @(starCounts.ContainsKey(star) ? "checked" : null) />
                                    <span>@star Yildiz</span>
                                    <strong>@(starCounts.TryGetValue(star, out var total) ? total : 0)</strong>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Misafir Puani</h3>
                        </div>
                        <div class="rating-chip-list">
                            @foreach (var score in guestScoreFilters)
                            {
                                var normalizedScore = score.StartsWith("9") ? "9" : score.StartsWith("8") ? "8" : "7";
                                <span class="rating-chip" data-min-score="@normalizedScore">@score</span>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Populer Filtreler</h3>
                            <span>@topAmenities.Count</span>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var amenity in topAmenities)
                            {
                                var amenityToken = NormalizeToken(amenity.Key);
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" class="listing-amenity-filter" value="@amenityToken" />
                                    <span>@amenity.Key</span>
                                    <strong>@amenity.Count()</strong>
                                </label>
                            }
                        </div>
                        <span class="filter-more-link">+@Math.Max(0, amenityCounts.Count - topAmenities.Count) filtre daha</span>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Yemek Secenekleri</h3>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var meal in mealOptions)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" />
                                    <span>@meal</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="filter-panel-section filter-section">
                        <div class="filter-panel-head">
                            <h3>Ozel Konseptler</h3>
                        </div>
                        <div class="filter-option-list filter-options">
                            @foreach (var concept in specialConcepts)
                            {
                                <label class="filter-option-row filter-check">
                                    <input type="checkbox" />
                                    <span>@concept</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </aside>

            <div class="listing-results-column">
                @if (resultCount == 0)
                {
                    <div class="listing-empty-state">
                        <div class="listing-empty-icon">
                            <i class="fas fa-bed"></i>
                        </div>
                        <h2>@Model.SearchLabel icin sonuc bulunamadi</h2>
                        <p>Listeleme ekraninin dolmasi icin `oteller`, `oda_tipleri`, `oda_fiyat_musaitlik` ve `otel_gorselleri` tablolarinda aktif veri olmasi gerekir.</p>
                    </div>
                }
                else
                {
                    <div class="hotel-card-list hotel-list" id="hotelListView">
                        @foreach (var hotel in hotels)
                        {
                            var cardFilterValue = string.Join(' ', hotel.Amenities.Select(x => NormalizeToken(x)));
                            var cardRating = hotel.Rating > 0 ? hotel.Rating : 0m;
                            var cardStars = hotel.StarCount ?? 0;
                            var districtToken = NormalizeToken($"{hotel.District} {hotel.City}");
                            var displayAmenities = hotel.Amenities
                                .Where(x => !string.IsNullOrWhiteSpace(x))
                                .Take(3)
                                .ToList();
                            var oldPrice = hotel.StartingPrice.HasValue
                                ? Math.Round(hotel.StartingPrice.Value * 1.24m, 0)
                                : (decimal?)null;
                            if (displayAmenities.Count == 0)
                            {
                                displayAmenities = new List<string> { "Ücretsiz WiFi", "Merkezi Konum" };
                            }

                            <article class="hotel-card listing-hotel-card"
                                     data-amenities="@cardFilterValue"
                                     data-price="@(hotel.StartingPrice ?? 0m)"
                                     data-rating="@cardRating.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                     data-stars="@cardStars"
                                     data-district="@districtToken">
                                <div class="card-image hotel-card-media">
                                    @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                                    {
                                        <img src="@hotel.ImageUrl" alt="@hotel.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="hotel-card-placeholder">
                                            <i class="fas fa-image"></i>
                                            <span>Gorsel bekleniyor</span>
                                        </div>
                                    }

                                    <div class="hotel-card-badges card-badges">
                                        @if (hotel.IsFeatured)
                                        {
                                            <span class="hotel-badge hotel-badge-highlight badge badge-guest">
                                                <i class="fas fa-trophy"></i>
                                                Misafir Favorisi
                                            </span>
                                        }
                                        @if (hotel.StartingPrice.HasValue && hotel.StartingPrice.Value == minPrice && minPrice > 0)
                                        {
                                            <span class="hotel-badge hotel-badge-discount badge badge-discount">
                                                <i class="fas fa-bolt"></i>
                                                %25
                                            </span>
                                        }
                                    </div>

                                    <button type="button"
                                            class="favorite-btn wishlist-btn @(hotel.IsFavorite ? "active" : string.Empty)"
                                            data-hotel-id="@hotel.Id"
                                            data-source-page="OtelListeleme"
                                            aria-label="Favorilere ekle">
                                        <i class="@(hotel.IsFavorite ? "fas" : "far") fa-heart"></i>
                                    </button>
                                </div>

                                <div class="card-content hotel-card-content">
                                    <div>
                                        <div class="hotel-header hotel-card-header">
                                            <h3 class="hotel-name">@hotel.Name</h3>
                                            <span class="hotel-rating">
                                                @(hotel.Rating > 0 ? hotel.Rating.ToString("0.0") : "0.0")
                                                <i class="fas fa-star"></i>
                                            </span>
                                        </div>
                                        <div class="hotel-location hotel-card-location">
                                            <i class="fas fa-map-pin"></i>
                                            @hotel.District, @hotel.City
                                        </div>
                                        <div class="features hotel-feature-list">
                                            @foreach (var amenity in displayAmenities)
                                            {
                                                <span class="feature-tag hotel-feature-chip">
                                                    <i class="fas @GetAmenityIconClass(amenity)"></i>
                                                    @amenity
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    <div class="price-section hotel-card-footer">
                                        <div class="price-info hotel-price-area">
                                            <span class="current-price">@(hotel.StartingPrice.HasValue ? $"₺{hotel.StartingPrice.Value:N0}" : "Teklif Al")</span>
                                            @if (oldPrice.HasValue)
                                            {
                                                <span class="old-price">₺@oldPrice.Value.ToString("N0")</span>
                                            }
                                            <span class="per-night">/ gece</span>
                                        </div>
                                        <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@hotel.Slug" class="btn-detail hotel-link-btn">Incele</a>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                    <div class="listing-filter-empty" id="listingFilterEmpty" hidden>
                        <i class="fas fa-filter-circle-xmark"></i>
                        <strong>Filtrelere uygun tesis bulunamadi</strong>
                        <span>Kriterleri biraz esnetip tekrar deneyebilirsiniz.</span>
                    </div>
                }

                <div class="listing-map-panel map-view" id="hotelMapView" hidden>
                    <div class="listing-map-card">
                        <iframe
                            title="@Model.SearchLabel harita gorunumu"
                            src="https://www.openstreetmap.org/export/embed.html?bbox=28.9%2C40.98%2C29.22%2C41.15&layer=mapnik"
                            loading="lazy"></iframe>
                        <div class="listing-map-overlay">
                            <strong>@resultCount tesis</strong>
                            <span>@Model.SearchLabel icin harita gorunumu</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="listing-mobile-actions">
    <button type="button" class="listing-mobile-btn" data-open-mobile-filters>
        <i class="fas fa-sliders-h"></i>
        <span>Filtrele</span>
    </button>
    <button type="button" class="listing-mobile-btn" id="listingMobileViewToggle">
        <i class="fas fa-map-location-dot"></i>
        <span>Harita</span>
    </button>
</div>

<div class="listing-mobile-filter-modal" id="listingMobileFilterModal" hidden>
    <div class="listing-mobile-filter-backdrop" data-close-mobile-filters></div>
    <div class="listing-mobile-filter-sheet">
        <div class="listing-mobile-filter-head">
            <div>
                <h3>Filtrele</h3>
                <p>@resultCount tesisi veri tabanindan listeliyoruz</p>
            </div>
            <button type="button" class="listing-mobile-close" data-close-mobile-filters aria-label="Filtreleri kapat">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="listing-mobile-filter-body">
            <div class="filter-panel-section">
                <div class="filter-panel-head">
                    <h3>Yildiz Sayisi</h3>
                    <span>@starCounts.Values.Sum()</span>
                </div>
                <div class="filter-option-list">
                    @foreach (var star in Model.StarOptions)
                    {
                        <label class="filter-option-row">
                            <input type="checkbox" @(starCounts.ContainsKey(star) ? "checked" : null) />
                            <span>@star Yildiz</span>
                            <strong>@(starCounts.TryGetValue(star, out var total) ? total : 0)</strong>
                        </label>
                    }
                </div>
            </div>

            <div class="filter-panel-section">
                <div class="filter-panel-head">
                    <h3>Populer Olanaklar</h3>
                    <span>@topAmenities.Count</span>
                </div>
                <div class="filter-option-list">
                    @foreach (var amenity in topAmenities)
                    {
                        <label class="filter-option-row">
                            <input type="checkbox" />
                            <span>@amenity.Key</span>
                            <strong>@amenity.Count()</strong>
                        </label>
                    }
                </div>
            </div>

            <div class="filter-panel-section">
                <div class="filter-panel-head">
                    <h3>Misafir Puani</h3>
                </div>
                <div class="rating-chip-list">
                    @foreach (var score in guestScoreFilters)
                    {
                        <span class="rating-chip">@score</span>
                    }
                </div>
            </div>
        </div>

        <button type="button" class="listing-mobile-apply" data-close-mobile-filters>@resultCount tesisi goster</button>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const listButton = document.getElementById('listingListViewBtn');
            const mapButton = document.getElementById('listingMapViewBtn');
            const mobileToggleButton = document.getElementById('listingMobileViewToggle');
            const listView = document.getElementById('hotelListView');
            const mapView = document.getElementById('hotelMapView');
            const mobileFilterModal = document.getElementById('listingMobileFilterModal');
            const chipButtons = document.querySelectorAll('[data-chip-filter]');
            const ratingChips = document.querySelectorAll('.rating-chip');
            const sortSelect = document.getElementById('listingSortSelect');
            const minPriceInput = document.getElementById('listingMinPriceInput');
            const maxPriceInput = document.getElementById('listingMaxPriceInput');
            const maxPriceRange = document.getElementById('listingPriceMaxRange');
            const starFilters = document.querySelectorAll('.listing-star-filter');
            const amenityFilters = document.querySelectorAll('.listing-amenity-filter');
            const cards = Array.from(document.querySelectorAll('.listing-hotel-card'));
            const cardList = document.getElementById('hotelListView');
            const emptyState = document.getElementById('listingFilterEmpty');
            const listingInfoLine = document.getElementById('listingInfoLine');

            function showListView() {
                listButton?.classList.add('active');
                mapButton?.classList.remove('active');
                if (listView) {
                    listView.hidden = false;
                }
                if (mapView) {
                    mapView.hidden = true;
                }
                if (mobileToggleButton) {
                    mobileToggleButton.innerHTML = '<i class="fas fa-map-location-dot"></i><span>Harita</span>';
                }
            }

            function showMapView() {
                mapButton?.classList.add('active');
                listButton?.classList.remove('active');
                if (listView) {
                    listView.hidden = true;
                }
                if (mapView) {
                    mapView.hidden = false;
                }
                if (mobileToggleButton) {
                    mobileToggleButton.innerHTML = '<i class="fas fa-list"></i><span>Liste</span>';
                }
            }

            function openFilters() {
                if (!mobileFilterModal) {
                    return;
                }

                mobileFilterModal.hidden = false;
                document.body.classList.add('listing-modal-open');
            }

            function closeFilters() {
                if (!mobileFilterModal) {
                    return;
                }

                mobileFilterModal.hidden = true;
                document.body.classList.remove('listing-modal-open');
            }

            function normalizeToken(value) {
                return (value || '')
                    .toString()
                    .toLowerCase()
                    .replace(/ı/g, 'i')
                    .replace(/ö/g, 'o')
                    .replace(/ü/g, 'u')
                    .replace(/ş/g, 's')
                    .replace(/ç/g, 'c')
                    .replace(/ğ/g, 'g');
            }

            function updateInfoLine(visibleCount) {
                if (!listingInfoLine) {
                    return;
                }

                const textNode = listingInfoLine.querySelector('span');
                if (!textNode) {
                    return;
                }

                textNode.textContent = visibleCount + ' tesis • filtrelenmis gorunum';
            }

            function sortVisibleCards(visibleCards) {
                if (!cardList || !sortSelect || visibleCards.length === 0) {
                    return;
                }

                const mode = sortSelect.value;
                const sorted = visibleCards.slice().sort(function (a, b) {
                    const priceA = Number(a.dataset.price || '0');
                    const priceB = Number(b.dataset.price || '0');
                    const ratingA = Number(a.dataset.rating || '0');
                    const ratingB = Number(b.dataset.rating || '0');

                    if (mode === 'price-asc') {
                        return priceA - priceB;
                    }

                    if (mode === 'rating-desc') {
                        return ratingB - ratingA;
                    }

                    return ratingB - ratingA;
                });

                sorted.forEach(function (card) {
                    cardList.appendChild(card);
                });
            }

            function applyFilters() {
                if (cards.length === 0) {
                    return;
                }

                const minPrice = Number(minPriceInput?.value || '0');
                const maxPrice = Number(maxPriceInput?.value || maxPriceRange?.value || '0');
                const selectedStars = Array.from(starFilters)
                    .filter(function (checkbox) { return checkbox.checked; })
                    .map(function (checkbox) { return Number(checkbox.value || '0'); });
                const selectedAmenities = Array.from(amenityFilters)
                    .filter(function (checkbox) { return checkbox.checked; })
                    .map(function (checkbox) { return normalizeToken(checkbox.value); });
                const activeChipTokens = Array.from(chipButtons)
                    .filter(function (chip) { return chip.classList.contains('active'); })
                    .map(function (chip) { return normalizeToken(chip.getAttribute('data-chip-filter')); });
                const activeRatingThresholds = Array.from(ratingChips)
                    .filter(function (chip) { return chip.classList.contains('active'); })
                    .map(function (chip) { return Number(chip.getAttribute('data-min-score') || '0'); })
                    .filter(function (score) { return score > 0; });
                const minimumScore = activeRatingThresholds.length > 0 ? Math.max.apply(Math, activeRatingThresholds) : 0;

                const visibleCards = [];
                cards.forEach(function (card) {
                    const price = Number(card.dataset.price || '0');
                    const rating = Number(card.dataset.rating || '0');
                    const stars = Number(card.dataset.stars || '0');
                    const amenities = normalizeToken(card.dataset.amenities || '');

                    const priceMatch = price >= minPrice && (maxPrice <= 0 || price <= maxPrice);
                    const starMatch = selectedStars.length === 0 || selectedStars.includes(stars);
                    const amenityFilterTokens = selectedAmenities.concat(activeChipTokens);
                    const amenityMatch = amenityFilterTokens.length === 0 || amenityFilterTokens.every(function (token) {
                        return amenities.indexOf(token) > -1;
                    });
                    const ratingMatch = minimumScore <= 0 || rating >= minimumScore;

                    const shouldShow = priceMatch && starMatch && amenityMatch && ratingMatch;
                    card.hidden = !shouldShow;
                    if (shouldShow) {
                        visibleCards.push(card);
                    }
                });

                sortVisibleCards(visibleCards);
                if (emptyState) {
                    emptyState.hidden = visibleCards.length !== 0;
                }
                updateInfoLine(visibleCards.length);
            }

            listButton?.addEventListener('click', showListView);
            mapButton?.addEventListener('click', showMapView);
            mobileToggleButton?.addEventListener('click', function () {
                const mapIsVisible = mapView && !mapView.hidden;
                if (mapIsVisible) {
                    showListView();
                    return;
                }

                showMapView();
            });

            document.querySelectorAll('[data-open-mobile-filters]').forEach(function (button) {
                button.addEventListener('click', openFilters);
            });

            document.querySelectorAll('[data-close-mobile-filters]').forEach(function (button) {
                button.addEventListener('click', closeFilters);
            });

            chipButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const activate = !button.classList.contains('active');

                    chipButtons.forEach(function (item) {
                        item.classList.remove('active');
                    });

                    if (!activate) {
                        applyFilters();
                        return;
                    }

                    button.classList.add('active');
                    applyFilters();
                });
            });

            ratingChips.forEach(function (chip) {
                chip.addEventListener('click', function () {
                    chip.classList.toggle('active');
                    applyFilters();
                });
            });

            starFilters.forEach(function (checkbox) {
                checkbox.addEventListener('change', applyFilters);
            });

            amenityFilters.forEach(function (checkbox) {
                checkbox.addEventListener('change', applyFilters);
            });

            sortSelect?.addEventListener('change', applyFilters);
            minPriceInput?.addEventListener('input', function () {
                applyFilters();
            });
            maxPriceInput?.addEventListener('input', function () {
                if (maxPriceRange) {
                    maxPriceRange.value = maxPriceInput.value;
                }
                applyFilters();
            });
            maxPriceRange?.addEventListener('input', function () {
                if (maxPriceInput) {
                    maxPriceInput.value = maxPriceRange.value;
                }
                applyFilters();
            });

            showListView();
            applyFilters();
        })();
    </script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}
