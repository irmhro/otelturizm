      box-sizing: border-box;
      min-width: 0;
  }
  .location-btn:hover {
      border-color: rgba(16,185,129,0.55);
      background: linear-gradient(135deg, rgba(16,185,129,0.28) 0%, rgba(34,197,94,0.18) 45%, rgba(255,255,255,1) 100%);
      box-shadow: 0 14px 26px rgba(16,185,129,0.16);
  }
  .location-btn:active {
      transform: translateY(1px);
      box-shadow: 0 8px 16px rgba(16,185,129,0.16);
  }
  .location-btn:focus-visible {
      outline: 0;
      border-color: rgba(16,185,129,0.70);
      box-shadow: 0 0 0 4px rgba(16,185,129,0.16), 0 12px 24px rgba(16,185,129,0.16);
  }
  .location-btn { justify-content: space-between; }
  .location-btn:hover { border-color: rgba(0,59,149,0.25); background: rgba(0,59,149,0.03); }
  .location-btn:active { transform: translateY(1px); }
  .location-btn.active {
      border-color: rgba(0,59,149,0.35);
      box-shadow: 0 0 0 4px rgba(0,59,149,0.08);
      background: rgba(0,59,149,0.04);
  }
  .location-btn-icon { display: none; }
  .location-btn-copy { flex: 1; min-width: 0; }
  .location-btn-copy strong {
      display: block;
      font-size: 14px;
      font-weight: 900;
      color: var(--text-dark);
