  .km-manual-input input { width: 100%; flex: 1 1 auto; min-width:0; height:42px; padding:0 12px; border-radius:12px; border:1px solid rgba(226,232,240,1); background:#fff; font-size:18px; font-weight:900; color:var(--text-dark); text-align:center; }
