  .price-slider-track {
      height: 10px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(0,59,149,0.25), rgba(0,59,149,0.12));
      position: relative;
      margin: 0 0 8px;
      overflow: hidden;
      top: 14px;
  }
  .price-slider-track::after {
      content: "";
      position: absolute;
      inset: 0;
