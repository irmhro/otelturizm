@model otelturizmnew.Models.Oteller.HotelDetailConditionsViewModel
@{
    var hasContent = !string.IsNullOrWhiteSpace(Model.CancellationSummary)
        || !string.IsNullOrWhiteSpace(Model.CancellationDetail)
        || !string.IsNullOrWhiteSpace(Model.SmokingPolicy)
        || !string.IsNullOrWhiteSpace(Model.PetPolicy)
        || !string.IsNullOrWhiteSpace(Model.ChildPolicy)
        || Model.HasFreeCancellation
        || Model.PrepaymentRequired;

    string JoinPolicyText(string? primary, string? secondary)
    {
        var parts = new[] { primary?.Trim(), secondary?.Trim() }
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();
        return parts.Count == 0 ? string.Empty : string.Join(" ", parts);
    }
}
@if (hasContent)
{
    <article class="content-card od-section od-section--policies" id="hotelPoliciesSection">
        <div class="section-head tabler-section-head od-section__head">
            <div class="tabler-section-headrow">
                <div class="tabler-section-titles">
                    <h2>Otel kuralları ve koşullar</h2>
                    <p>İptal, ödeme ve konaklama politikaları</p>
                </div>
            </div>
        </div>
        <ul class="od-policy-list">
            @if (Model.HasFreeCancellation || !string.IsNullOrWhiteSpace(Model.CancellationSummary))
            {
                var cancelText = JoinPolicyText(
                    string.IsNullOrWhiteSpace(Model.CancellationSummary) ? "Ücretsiz iptal seçeneği mevcut." : Model.CancellationSummary,
                    Model.CancellationDetail);
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-calendar-check"></i></span>
                    <strong class="od-policy-title">İptal politikası</strong>
                    <span class="od-policy-text">@cancelText</span>
                </li>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SmokingPolicy))
            {
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-smoking-ban"></i></span>
                    <strong class="od-policy-title">Sigara politikası</strong>
                    <span class="od-policy-text">@Model.SmokingPolicy</span>
                </li>
            }
            @if (!string.IsNullOrWhiteSpace(Model.PetPolicy))
            {
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-paw"></i></span>
                    <strong class="od-policy-title">Evcil hayvan</strong>
                    <span class="od-policy-text">@Model.PetPolicy</span>
                </li>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ChildPolicy))
            {
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-child"></i></span>
                    <strong class="od-policy-title">Çocuk politikası</strong>
                    <span class="od-policy-text">@Model.ChildPolicy</span>
                </li>
            }
            @if (Model.PrepaymentRequired)
            {
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-credit-card"></i></span>
                    <strong class="od-policy-title">Ön ödeme</strong>
                    <span class="od-policy-text">Rezervasyon sırasında @(Model.PrepaymentPercent > 0m ? $"%{Model.PrepaymentPercent:N0}" : "ön") ödeme gerekebilir.</span>
                </li>
            }
            else if (Model.CardPaymentAccepted)
            {
                <li class="od-policy-item">
                    <span class="od-policy-icon" aria-hidden="true"><i class="fas fa-wallet"></i></span>
                    <strong class="od-policy-title">Ödeme</strong>
                    <span class="od-policy-text">Kredi kartı ile online ödeme kabul edilir.</span>
                </li>
            }
        </ul>
    </article>
}
