@model otelturizmnew.Models.Oteller.HotelDetailConditionsViewModel
@{
    var policyItems = new List<(string Icon, string Title, string Text)>();

    if (Model.HasFreeCancellation || !string.IsNullOrWhiteSpace(Model.CancellationSummary))
    {
        var cancelParts = new[] { Model.CancellationSummary?.Trim(), Model.CancellationDetail?.Trim() }
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();
        var cancelText = cancelParts.Count == 0
            ? "Ücretsiz iptal seçeneği mevcut."
            : string.Join(" ", cancelParts);
        policyItems.Add(("fa-calendar-check", "İptal politikası", cancelText));
    }

    if (!string.IsNullOrWhiteSpace(Model.SmokingPolicy))
    {
        policyItems.Add(("fa-smoking-ban", "Sigara politikası", Model.SmokingPolicy.Trim()));
    }

    if (!string.IsNullOrWhiteSpace(Model.PetPolicy))
    {
        policyItems.Add(("fa-paw", "Evcil hayvan", Model.PetPolicy.Trim()));
    }

    if (!string.IsNullOrWhiteSpace(Model.ChildPolicy))
    {
        policyItems.Add(("fa-child", "Çocuk politikası", Model.ChildPolicy.Trim()));
    }

    if (Model.PrepaymentRequired)
    {
        policyItems.Add(("fa-credit-card", "Ön ödeme", $"Rezervasyon sırasında {(Model.PrepaymentPercent > 0m ? $"%{Model.PrepaymentPercent:N0}" : "ön")} ödeme gerekebilir."));
    }
    else if (Model.CardPaymentAccepted)
    {
        policyItems.Add(("fa-wallet", "Ödeme", "Kredi kartı ile online ödeme kabul edilir."));
    }
}
@if (policyItems.Count > 0)
{
    <article class="content-card od-section od-section--policies" id="hotelPoliciesSection">
        <div class="section-head tabler-section-head od-section__head">
            <div class="tabler-section-headrow">
                <div class="tabler-section-titles">
                    <h2>Otel kuralları ve koşullar</h2>
                    <p>İptal, ödeme ve konaklama politikaları</p>
                </div>
            </div>
        </div>
        <ul class="od-policy-list od-policy-list--accordion">
            @foreach (var policy in policyItems.Take(6))
            {
                <li class="od-policy-item">
                    <details class="od-policy-accordion">
                        <summary class="od-policy-accordion__summary">
                            <strong class="od-policy-title">@policy.Title</strong>
                            <i class="fas fa-chevron-down od-policy-accordion__chevron" aria-hidden="true"></i>
                        </summary>
                        <div class="od-policy-detail">@policy.Text</div>
                    </details>
                </li>
            }
        </ul>
    </article>
}
