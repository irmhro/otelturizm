@using System.Globalization
@using System.Text.Json
@using otelturizmnew.Services
@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Haritada Oteller" : $"{Model.SearchLabel} haritası";
    ViewData["PageCss"] = "haritaoteller";
    ViewData["PageCssMobile"] = "haritaoteller.mobile";
    var mapLang = InternationalSeoPaths.ResolveCultureFromPath(Context.Request.Path.Value ?? "/");
    var listingBackPath = InternationalSeoPaths.BuildPublicPath(mapLang, InternationalSeoPaths.PageKindListing, null, null);
    var listingBackUrl = listingBackPath;
    if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        listingBackUrl += "?q=" + Uri.EscapeDataString(Model.SearchTerm);
    }
    var mapHotels = (Model.MapHotels ?? new()).Where(x => x.Latitude.HasValue && x.Longitude.HasValue).ToList();
    var mapPayload = mapHotels.Select(x => new
    {
        id = x.Id,
        name = x.Name,
        slug = x.Slug,
        city = x.City,
        district = x.District,
        neighborhood = x.Neighborhood,
        lat = x.Latitude,
        lon = x.Longitude,
        price = x.StartingPrice,
        rating = x.Rating,
        starCount = x.StarCount,
        image = x.ImageUrl
    }).ToList();
    var serializedHotels = JsonSerializer.Serialize(mapPayload);
    var cityOptions = mapHotels.Select(x => x.City).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    var districtOptions = mapHotels.Select(x => x.District).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    var neighborhoodOptions = mapHotels.Select(x => x.Neighborhood).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
}

<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      crossorigin="anonymous" />
<link rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"
      crossorigin="anonymous" />
<link rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"
      crossorigin="anonymous" />

<section class="hotel-map-page">
    <div class="hotel-map-page__shell">
        <header class="hotel-map-page__topline">
            <a class="hotel-map-page__back" href="@listingBackUrl">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
                <span>@SharedLocalizer["Map.BackToList"]</span>
            </a>
            <div class="hotel-map-page__title">
                <span>Harita görünümü</span>
                <h1>@(string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Haritadaki Oteller" : Model.SearchLabel)</h1>
            </div>
        </header>

        <div class="hotel-map-page__layout">
            <section class="hotel-map-page__map-panel">
                <div class="hotel-map-page__toolbar">
                    <div class="hotel-map-page__toolbar-copy">
                        <h2>Harita</h2>
                        <p id="hotelMapSummaryText">İl, ilçe, mahalle ve otel adına göre filtrelenen tesisleri fiyat marker'ları ile inceleyin.</p>
                    </div>
                    <div class="hotel-map-page__toolbar-actions">
                        <span class="hotel-map-page__pin-badge" id="hotelMapPinBadge" title="Haritadaki pin sayısı">
                            <i class="fas fa-map-pin" aria-hidden="true"></i>
                            <strong id="hotelMapPinCount">@mapHotels.Count</strong>
                            <span>pin</span>
                        </span>
                        <button type="button" class="hotel-map-page__toolbar-btn" id="fitHotelMapBtn">
                            <i class="fas fa-expand" aria-hidden="true"></i>
                            <span>Tümünü Göster</span>
                        </button>
                    </div>
                </div>

                <div class="hotel-map-page__map-canvas" id="hotelMapCanvas">
                    <div class="hotel-map-page__empty @(mapHotels.Count == 0 ? "" : "is-hidden")"
                         id="hotelMapEmptyState"
                         role="status"
                         aria-live="polite"
                         @(mapHotels.Count > 0 ? "hidden" : null)>
                        <p>Haritada gösterilecek tesis bulunamadı. Aramayı genişletin veya tüm otelleri listeleyin.</p>
                        <a class="hotel-map-page__empty-cta" href="@listingBackUrl">@SharedLocalizer["Map.BackToAllHotels"]</a>
                    </div>
                </div>
            </section>

            <aside class="hotel-map-page__sidebar">
                <div class="hotel-map-page__sidebar-head">
                    <div>
                        <h2>Oteller</h2>
                        <p>Konum ve otel adı bazlı gelişmiş listeleme</p>
                    </div>
                    <span><strong id="hotelMapVisibleCount">@mapHotels.Count</strong> sonuç</span>
                </div>

                <form class="hotel-map-page__filters" id="hotelMapFilterForm" autocomplete="off">
                    <label class="hotel-map-page__field">
                        <span>Otel adı</span>
                        <input type="search"
                               id="hotelMapSearchInput"
                               placeholder="Otel adı ara"
                               aria-label="Otel adı ara" />
                    </label>
                    <div class="hotel-map-page__filter-grid">
                        <label class="hotel-map-page__field">
                            <span>İl</span>
                            <select id="hotelMapCityFilter" aria-label="İle göre filtrele">
                                <option value="">Tüm iller</option>
                                @foreach (var city in cityOptions)
                                {
                                    <option value="@city">@city</option>
                                }
                            </select>
                        </label>
                        <label class="hotel-map-page__field">
                            <span>İlçe</span>
                            <select id="hotelMapDistrictFilter" aria-label="İlçeye göre filtrele">
                                <option value="">Tüm ilçeler</option>
                                @foreach (var district in districtOptions)
                                {
                                    <option value="@district">@district</option>
                                }
                            </select>
                        </label>
                    </div>
                    <div class="hotel-map-page__filter-grid">
                        <label class="hotel-map-page__field">
                            <span>Mahalle</span>
                            <select id="hotelMapNeighborhoodFilter" aria-label="Mahalleye göre filtrele">
                                <option value="">Tüm mahalleler</option>
                                @foreach (var neighborhood in neighborhoodOptions)
                                {
                                    <option value="@neighborhood">@neighborhood</option>
                                }
                            </select>
                        </label>
                        <label class="hotel-map-page__field">
                            <span>Puan</span>
                            <select id="hotelMapRatingFilter" aria-label="Puana göre filtrele">
                                <option value="">Tüm puanlar</option>
                                <option value="9">9.0 ve üzeri</option>
                                <option value="8">8.0 ve üzeri</option>
                                <option value="7">7.0 ve üzeri</option>
                            </select>
                        </label>
                    </div>
                    <button type="button" class="hotel-map-page__clear" id="hotelMapClearFilters">
                        <i class="fas fa-rotate-left" aria-hidden="true"></i>
                        <span>Temizle</span>
                    </button>
                </form>

                <div class="hotel-map-page__list" id="hotelMapHotelList">
                    @{ var mapListIndex = 0; }
                    @foreach (var hotel in mapHotels)
                    {
                        var isFirstMapItem = mapListIndex == 0;
                        mapListIndex++;
                        var areaText = string.IsNullOrWhiteSpace(hotel.Neighborhood)
                            ? $"{hotel.District}, {hotel.City}"
                            : $"{hotel.Neighborhood}, {hotel.District}, {hotel.City}";
                        var searchText = $"{hotel.Name} {hotel.City} {hotel.District} {hotel.Neighborhood}".ToLowerInvariant();
                        <a class="hotel-map-page__item"
                           href="@Url.Action("OtelDetay", "Oteller", new { slug = hotel.Slug })"
                           data-map-focus
                           data-map-id="@hotel.Id"
                           data-search="@searchText"
                           data-name="@hotel.Name"
                           data-city="@hotel.City"
                           data-district="@hotel.District"
                           data-neighborhood="@hotel.Neighborhood"
                           data-rating="@hotel.Rating.ToString(CultureInfo.InvariantCulture)"
                           data-lat="@hotel.Latitude?.ToString(CultureInfo.InvariantCulture)"
                           data-lon="@hotel.Longitude?.ToString(CultureInfo.InvariantCulture)">
                            <div class="hotel-map-page__item-visual">
                                @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                                {
                                    <img src="@hotel.ImageUrl" alt="@hotel.Name" @(isFirstMapItem ? "fetchpriority=\"high\" loading=\"eager\"" : "loading=\"lazy\"") decoding="async" />
                                }
                                else
                                {
                                    <span><i class="fas fa-hotel" aria-hidden="true"></i></span>
                                }
                            </div>
                            <div class="hotel-map-page__item-copy">
                                <strong>@hotel.Name</strong>
                                <span>@areaText</span>
                                <small data-distance-label hidden></small>
                            </div>
                            <div class="hotel-map-page__item-meta">
                                @if (hotel.StartingPrice.HasValue && hotel.StartingPrice.Value > 0)
                                {
                                    <small>₺@hotel.StartingPrice.Value.ToString("N0")</small>
                                }
                                <em>@hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture)</em>
                            </div>
                        </a>
                    }
                </div>
            </aside>
        </div>
    </div>
</section>

<script type="application/json" id="hotelMapPayload">@Html.Raw(serializedHotels)</script>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="anonymous"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js" crossorigin="anonymous"></script>
    <script>
        (function () {
            const mapCanvas = document.getElementById('hotelMapCanvas');
            const fitBtn = document.getElementById('fitHotelMapBtn');
            const payload = document.getElementById('hotelMapPayload');
            const searchInput = document.getElementById('hotelMapSearchInput');
            const cityFilter = document.getElementById('hotelMapCityFilter');
            const districtFilter = document.getElementById('hotelMapDistrictFilter');
            const neighborhoodFilter = document.getElementById('hotelMapNeighborhoodFilter');
            const ratingFilter = document.getElementById('hotelMapRatingFilter');
            const clearFilters = document.getElementById('hotelMapClearFilters');
            const visibleCount = document.getElementById('hotelMapVisibleCount');
            const pinCount = document.getElementById('hotelMapPinCount');
            const summaryText = document.getElementById('hotelMapSummaryText');
            const listItems = Array.from(document.querySelectorAll('[data-map-focus]'));
            const emptyState = document.getElementById('hotelMapEmptyState');
            if (!mapCanvas || !window.L) return;

            let hotels = [];
            try {
                hotels = JSON.parse(payload?.textContent || '[]');
            } catch (_) {
                hotels = [];
            }

            function normalizeText(value) {
                return String(value || '')
                    .toLocaleLowerCase('tr-TR')
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function formatPrice(value) {
                const amount = Number(value || 0);
                if (!Number.isFinite(amount) || amount <= 0) return 'Fiyat yok';
                return '₺' + Math.round(amount).toLocaleString('tr-TR');
            }

            const map = window.L.map(mapCanvas, {
                zoomControl: true,
                scrollWheelZoom: true
            });

            window.L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                maxZoom: 19,
                subdomains: 'abcd',
                attribution: '&copy; OpenStreetMap katkıda bulunanlar &copy; CARTO'
            }).addTo(map);

            const clusterLayer = typeof window.L.markerClusterGroup === 'function'
                ? window.L.markerClusterGroup({
                    showCoverageOnHover: false,
                    zoomToBoundsOnClick: true,
                    spiderfyOnMaxZoom: true,
                    disableClusteringAtZoom: 15,
                    maxClusterRadius: 56,
                    iconCreateFunction: function (cluster) {
                        const count = cluster.getChildCount();
                        return window.L.divIcon({
                            className: 'hotel-map-cluster-icon',
                            html: '<span class="hotel-map-cluster" aria-label="' + count + ' otel kümesi">' + count + '</span>',
                            iconSize: [44, 44],
                            iconAnchor: [22, 22]
                        });
                    }
                })
                : window.L.layerGroup();
            clusterLayer.addTo(map);
            const markers = [];

            hotels.forEach(function (hotel) {
                const lat = Number(hotel.lat);
                const lon = Number(hotel.lon);
                if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;

                const areaParts = [hotel.neighborhood, hotel.district, hotel.city].filter(Boolean);
                const areaText = areaParts.join(' / ');
                const priceText = formatPrice(hotel.price);
                const pillIcon = window.L.divIcon({
                    className: 'hotel-map-pill-icon',
                    html:
                        '<button type="button" class="hotel-map-pill" aria-label="' + escapeHtml(String(hotel.name || 'Otel')) + '">' +
                            '<span>' + escapeHtml(priceText) + '</span>' +
                        '</button>',
                    iconSize: [74, 36],
                    iconAnchor: [37, 18],
                    popupAnchor: [0, -8]
                });

                const popupImage = hotel.image
                    ? '<div class="hotel-map-popup__visual"><img src="' + escapeHtml(hotel.image) + '" alt="' + escapeHtml(String(hotel.name || 'Otel')) + '" loading="lazy"></div>'
                    : '<div class="hotel-map-popup__visual is-placeholder"><i class="fas fa-hotel" aria-hidden="true"></i></div>';

                const popupHtml =
                    '<article class="hotel-map-popup">' +
                        popupImage +
                        '<div class="hotel-map-popup__body">' +
                            '<strong>' + escapeHtml(String(hotel.name || 'Otel')) + '</strong>' +
                            '<span>' + escapeHtml(areaText) + '</span>' +
                            '<div class="hotel-map-popup__meta">' +
                                '<b>' + escapeHtml(priceText) + '</b>' +
                                '<em>' + escapeHtml(Number(hotel.rating || 0).toLocaleString('tr-TR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })) + '</em>' +
                            '</div>' +
                            '<a class="hotel-map-popup__cta" href="/oteller/' + encodeURIComponent(String(hotel.slug || '')) + '">Oteli İncele</a>' +
                        '</div>' +
                    '</article>';

                const marker = window.L.marker([lat, lon], { icon: pillIcon });
                marker.bindPopup(popupHtml, { closeButton: false, offset: [0, -6], maxWidth: 280, className: 'hotel-map-popup-shell' });
                markers.push({
                    id: Number(hotel.id || 0),
                    lat,
                    lon,
                    hotel,
                    marker,
                    areaText,
                    nameSearch: normalizeText(hotel.name),
                    citySearch: normalizeText(hotel.city),
                    districtSearch: normalizeText(hotel.district),
                    neighborhoodSearch: normalizeText(hotel.neighborhood),
                    ratingValue: Number(hotel.rating || 0)
                });
            });

            function getFilteredEntries() {
                const query = normalizeText(searchInput?.value || '');
                const city = normalizeText(cityFilter?.value || '');
                const district = normalizeText(districtFilter?.value || '');
                const neighborhood = normalizeText(neighborhoodFilter?.value || '');
                const minRating = Number(ratingFilter?.value || 0);

                return markers.filter(function (entry) {
                    if (query && entry.nameSearch.indexOf(query) === -1) return false;
                    if (city && entry.citySearch !== city) return false;
                    if (district && entry.districtSearch !== district) return false;
                    if (neighborhood && entry.neighborhoodSearch !== neighborhood) return false;
                    if (minRating > 0 && entry.ratingValue < minRating) return false;
                    return true;
                });
            }

            function fitEntries(entries) {
                if (!entries.length) {
                    map.setView([41.015137, 28.97953], 10);
                    return;
                }

                if (typeof clusterLayer.getBounds === 'function') {
                    const clusterBounds = clusterLayer.getBounds();
                    if (clusterBounds && clusterBounds.isValid()) {
                        map.fitBounds(clusterBounds, { padding: [50, 50], maxZoom: 12 });
                        return;
                    }
                }

                const bounds = window.L.latLngBounds(entries.map(function (entry) {
                    return [entry.lat, entry.lon];
                }));
                map.fitBounds(bounds, { padding: [50, 50], maxZoom: 12 });
            }

            function applyMapState() {
                const entries = getFilteredEntries();
                clusterLayer.clearLayers();

                entries.forEach(function (entry) {
                    clusterLayer.addLayer(entry.marker);
                });

                listItems.forEach(function (item) {
                    const id = Number(item.getAttribute('data-map-id') || '0');
                    const entry = entries.find(function (x) { return x.id === id; });
                    item.hidden = !entry;
                });

                visibleCount.textContent = String(entries.length);
                if (pinCount) {
                    pinCount.textContent = String(entries.length);
                }
                summaryText.textContent = entries.length
                    ? entries.length + ' pin haritada (yakın pinler küme halinde; küme üzerine dokununca yakınlaşır).'
                    : 'Filtrelere uygun tesis bulunamadı. Aramayı genişletin veya filtreleri temizleyin.';
                if (emptyState) {
                    const showEmpty = entries.length === 0;
                    emptyState.hidden = !showEmpty;
                    emptyState.classList.toggle('is-hidden', !showEmpty);
                }
                fitEntries(entries);
            }

            fitBtn?.addEventListener('click', function () {
                applyMapState();
            });

            [searchInput, cityFilter, districtFilter, neighborhoodFilter, ratingFilter].forEach(function (control) {
                control?.addEventListener('input', applyMapState);
                control?.addEventListener('change', applyMapState);
            });

            clearFilters?.addEventListener('click', function () {
                if (searchInput) searchInput.value = '';
                if (cityFilter) cityFilter.value = '';
                if (districtFilter) districtFilter.value = '';
                if (neighborhoodFilter) neighborhoodFilter.value = '';
                if (ratingFilter) ratingFilter.value = '';
                applyMapState();
            });

            listItems.forEach(function (link) {
                link.addEventListener('mouseenter', function () {
                    const id = Number(link.getAttribute('data-map-id') || '0');
                    const entry = markers.find(function (x) { return x.id === id; });
                    if (!entry) return;
                    map.flyTo([entry.lat, entry.lon], Math.max(map.getZoom(), 13), { duration: 0.45 });
                    entry.marker.openPopup();
                });
            });

            applyMapState();
        })();
    </script>
}
