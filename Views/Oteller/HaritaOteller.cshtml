@using System.Globalization
@using System.Text.Json
@using otelturizmnew.Services
@model otelturizmnew.Models.Oteller.HotelListingPageViewModel

@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Haritada Oteller" : $"{Model.SearchLabel} haritası";
    ViewData["BodyClass"] = "hotel-map-page-shell anasayfa-page";
    ViewData["PageCss"] = "haritaoteller";
    ViewData["PageCssMobile"] = "haritaoteller.mobile";
    ViewData["IncludeAnasayfaStyles"] = true;
    ViewData["IncludeBootstrap"] = true;
    var mapLang = InternationalSeoPaths.ResolveCultureFromPath(Context.Request.Path.Value ?? "/");
    var listingBackPath = InternationalSeoPaths.BuildPublicPath(mapLang, InternationalSeoPaths.PageKindListing, null, null);
    var mapHotelDetailPathPattern = InternationalSeoPaths.BuildPublicPath(mapLang, InternationalSeoPaths.PageKindDetail, null, "{slug}");
    var listingBackUrl = listingBackPath;
    if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        listingBackUrl += "?q=" + Uri.EscapeDataString(Model.SearchTerm);
    }
    var mapHotels = (Model.MapHotels ?? new()).Where(x => x.Latitude.HasValue && x.Longitude.HasValue).ToList();
    var mapPayload = mapHotels.Select(x => new
    {
        id = x.Id,
        name = x.Name,
        slug = x.Slug,
        city = x.City,
        district = x.District,
        neighborhood = x.Neighborhood,
        lat = x.Latitude,
        lon = x.Longitude,
        price = x.StartingPrice,
        rating = x.Rating,
        starCount = x.StarCount,
        image = x.ImageUrl
    }).ToList();
    var serializedHotels = JsonSerializer.Serialize(mapPayload);
    var cityOptions = Model.Cities?.Any() == true
        ? Model.Cities
        : mapHotels.Select(x => x.City).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    var districtOptions = Model.Districts?.Any() == true
        ? Model.Districts
        : mapHotels.Select(x => x.District).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    var neighborhoodOptions = Model.Neighborhoods?.Any() == true
        ? Model.Neighborhoods
        : mapHotels.Select(x => x.Neighborhood).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
    var pricedHotels = mapHotels.Where(x => x.StartingPrice is > 0m).ToList();
    var priceMin = Model.MaxPrice > 0m
        ? Model.MinPrice
        : pricedHotels.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Min();
    var priceMax = Model.MaxPrice > 0m
        ? Model.MaxPrice
        : pricedHotels.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Max();
    var hasPriceRange = priceMax > 0m;
    var activeMinPrice = Model.ActiveMinPrice is > 0m ? (int)Math.Floor(Model.ActiveMinPrice.Value) : (int?)null;
    var activeMaxPrice = Model.ActiveMaxPrice is > 0m ? (int)Math.Ceiling(Model.ActiveMaxPrice.Value) : (int?)null;
    var starOptions = Model.StarOptions?.Any() == true
        ? Model.StarOptions
        : mapHotels.Where(x => x.StarCount.HasValue).Select(x => x.StarCount!.Value).Distinct().OrderByDescending(x => x).ToList();
}

@section HeadStyles {
<link rel="stylesheet"
      href="~/assets/vendor/leaflet/leaflet.css"
      asp-append-version="true" />
<link rel="stylesheet"
      href="~/assets/vendor/leaflet-markercluster/MarkerCluster.css"
      asp-append-version="true" />
<link rel="stylesheet"
      href="~/assets/vendor/leaflet-markercluster/MarkerCluster.Default.css"
      asp-append-version="true" />
}

<section class="hotel-map-page">
    <div class="hotel-map-page__shell">
        <header class="hotel-map-page__topline">
            <a class="hotel-map-page__back" href="@listingBackUrl">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
                <span>@SharedLocalizer["Map.BackToList"]</span>
            </a>
            <div class="hotel-map-page__title">
                <span>Harita görünümü</span>
                <h1>@(string.IsNullOrWhiteSpace(Model.SearchLabel) ? "Haritadaki Oteller" : Model.SearchLabel)</h1>
            </div>
        </header>

        <div class="hotel-map-page__layout">
            <section class="hotel-map-page__map-panel">
                <div class="hotel-map-page__toolbar">
                    <div class="hotel-map-page__toolbar-copy">
                        <h2>Harita</h2>
                        <p id="hotelMapSummaryText">İl, ilçe, mahalle ve otel adına göre filtrelenen tesisleri fiyat marker'ları ile inceleyin.</p>
                    </div>
                    <div class="hotel-map-page__toolbar-actions">
                        <span class="hotel-map-page__pin-badge" id="hotelMapPinBadge" title="Haritadaki pin sayısı">
                            <i class="fas fa-map-pin" aria-hidden="true"></i>
                            <strong id="hotelMapPinCount">@mapHotels.Count</strong>
                            <span>pin</span>
                        </span>
                        <button type="button" class="hotel-map-page__toolbar-btn" id="fitHotelMapBtn">
                            <i class="fas fa-expand" aria-hidden="true"></i>
                            <span>Tümünü Göster</span>
                        </button>
                    </div>
                </div>

                <div class="hotel-map-page__map-canvas" id="hotelMapCanvas">
                    <button type="button" class="hotel-map-page__mobile-filter-btn" id="hotelMapOpenFilters" aria-controls="hotelMapFilterDrawer" aria-expanded="false">
                        <i class="fas fa-sliders" aria-hidden="true"></i>
                        <span>Filtrele</span>
                    </button>
                    <div class="hotel-map-page__empty @(mapHotels.Count == 0 ? "" : "is-hidden")"
                         id="hotelMapEmptyState"
                         role="status"
                         aria-live="polite"
                         @(mapHotels.Count > 0 ? "hidden" : null)>
                        <p>Haritada gösterilecek tesis bulunamadı. Aramayı genişletin veya tüm otelleri listeleyin.</p>
                        <a class="hotel-map-page__empty-cta" href="@listingBackUrl">@SharedLocalizer["Map.BackToAllHotels"]</a>
                    </div>
                </div>
            </section>

            <aside class="hotel-map-page__sidebar">
                <div class="hotel-map-page__sidebar-head">
                    <div>
                        <h2>Oteller</h2>
                        <p>Konum ve otel adı bazlı gelişmiş listeleme</p>
                    </div>
                    <span><strong id="hotelMapVisibleCount">@mapHotels.Count</strong> sonuç</span>
                </div>

                <partial name="~/Views/Oteller/_HaritaOtellerFilters.cshtml" model="Model" view-data="@(new ViewDataDictionary(ViewData) {
                    { "MapFilterScope", "desktop" },
                    { "MapCityOptions", cityOptions },
                    { "MapDistrictOptions", districtOptions },
                    { "MapNeighborhoodOptions", neighborhoodOptions },
                    { "MapPriceMin", priceMin },
                    { "MapPriceMax", priceMax },
                    { "MapHasPriceRange", hasPriceRange },
                    { "MapActiveMinPrice", activeMinPrice },
                    { "MapActiveMaxPrice", activeMaxPrice },
                    { "MapStarOptions", starOptions }
                })" />

                <div class="hotel-map-page__list" id="hotelMapHotelList">
                    @{ var mapListIndex = 0; }
                    @foreach (var hotel in mapHotels)
                    {
                        var isFirstMapItem = mapListIndex == 0;
                        mapListIndex++;
                        var areaText = string.IsNullOrWhiteSpace(hotel.Neighborhood)
                            ? $"{hotel.District}, {hotel.City}"
                            : $"{hotel.Neighborhood}, {hotel.District}, {hotel.City}";
                        var searchText = $"{hotel.Name} {hotel.City} {hotel.District} {hotel.Neighborhood}".ToLowerInvariant();
                        <a class="hotel-map-page__item"
                           href="@Url.Action("OtelDetay", "Oteller", new { slug = hotel.Slug })"
                           data-map-focus
                           data-map-id="@hotel.Id"
                           data-search="@searchText"
                           data-name="@hotel.Name"
                           data-city="@hotel.City"
                           data-district="@hotel.District"
                           data-neighborhood="@hotel.Neighborhood"
                           data-rating="@hotel.Rating.ToString(CultureInfo.InvariantCulture)"
                           data-stars="@(hotel.StarCount ?? 0)"
                           data-price="@((hotel.StartingPrice ?? 0m).ToString(CultureInfo.InvariantCulture))"
                           data-lat="@hotel.Latitude?.ToString(CultureInfo.InvariantCulture)"
                           data-lon="@hotel.Longitude?.ToString(CultureInfo.InvariantCulture)">
                            <div class="hotel-map-page__item-visual">
                                @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                                {
                                    <img src="@hotel.ImageUrl" alt="@hotel.Name" @(isFirstMapItem ? "fetchpriority=\"high\" loading=\"eager\"" : "loading=\"lazy\"") decoding="async" />
                                }
                                else
                                {
                                    <span><i class="fas fa-hotel" aria-hidden="true"></i></span>
                                }
                            </div>
                            <div class="hotel-map-page__item-copy">
                                <strong>@hotel.Name</strong>
                                <span>@areaText</span>
                                <small data-distance-label hidden></small>
                            </div>
                            <div class="hotel-map-page__item-meta">
                                @if (hotel.StartingPrice.HasValue && hotel.StartingPrice.Value > 0)
                                {
                                    <small>₺@hotel.StartingPrice.Value.ToString("N0")</small>
                                }
                                <em>@hotel.Rating.ToString("0.0", CultureInfo.InvariantCulture)</em>
                            </div>
                        </a>
                    }
                </div>
            </aside>
        </div>
    </div>

    <div class="hotel-map-page__filter-overlay" id="hotelMapFilterOverlay" hidden></div>
    <aside class="hotel-map-page__filter-drawer" id="hotelMapFilterDrawer" aria-hidden="true" aria-label="Harita filtreleri">
        <div class="hotel-map-page__filter-drawer-handle" aria-hidden="true"></div>
        <div class="hotel-map-page__filter-drawer-head">
            <h2>Filtreleme</h2>
            <button type="button" class="hotel-map-page__filter-drawer-close" id="hotelMapCloseFilters" aria-label="Kapat">Kapat</button>
        </div>
        <div class="hotel-map-page__filter-drawer-body">
            <partial name="~/Views/Oteller/_HaritaOtellerFilters.cshtml" model="Model" view-data="@(new ViewDataDictionary(ViewData) {
                { "MapFilterScope", "mobile" },
                { "MapCityOptions", cityOptions },
                { "MapDistrictOptions", districtOptions },
                { "MapNeighborhoodOptions", neighborhoodOptions },
                { "MapPriceMin", priceMin },
                { "MapPriceMax", priceMax },
                { "MapHasPriceRange", hasPriceRange },
                { "MapActiveMinPrice", activeMinPrice },
                { "MapActiveMaxPrice", activeMaxPrice },
                { "MapStarOptions", starOptions }
            })" />
        </div>
        <div class="hotel-map-page__filter-drawer-foot">
            <button type="button" class="hotel-map-page__filter-clear" data-map-filter-reset>Sıfırla</button>
            <button type="button" class="hotel-map-page__filter-apply" id="hotelMapApplyFilters">Uygula</button>
        </div>
    </aside>
</section>

<script type="application/json" id="hotelMapPayload">@Html.Raw(serializedHotels)</script>

@section Scripts {
    <script src="~/assets/vendor/leaflet/leaflet.js" asp-append-version="true"></script>
    <script src="~/assets/vendor/leaflet-markercluster/leaflet.markercluster.js" asp-append-version="true"></script>
    <script>
        (function () {
            const hotelDetailPathPattern = @System.Text.Json.JsonSerializer.Serialize(mapHotelDetailPathPattern);
            function buildHotelDetailUrl(slug) {
                return hotelDetailPathPattern.replace('{slug}', encodeURIComponent(String(slug || '').trim()));
            }

            const mapCanvas = document.getElementById('hotelMapCanvas');
            const fitBtn = document.getElementById('fitHotelMapBtn');
            const payload = document.getElementById('hotelMapPayload');
            const visibleCount = document.getElementById('hotelMapVisibleCount');
            const pinCount = document.getElementById('hotelMapPinCount');
            const summaryText = document.getElementById('hotelMapSummaryText');
            const listItems = Array.from(document.querySelectorAll('[data-map-focus]'));
            const emptyState = document.getElementById('hotelMapEmptyState');
            const filterDrawer = document.getElementById('hotelMapFilterDrawer');
            const filterOverlay = document.getElementById('hotelMapFilterOverlay');
            const openFiltersBtn = document.getElementById('hotelMapOpenFilters');
            const closeFiltersBtn = document.getElementById('hotelMapCloseFilters');
            const applyFiltersBtn = document.getElementById('hotelMapApplyFilters');
            if (!mapCanvas || !window.L) return;

            function getFilterRoot() {
                const isMobile = window.matchMedia('(max-width: 900px)').matches;
                if (isMobile && filterDrawer?.classList.contains('is-open')) {
                    return filterDrawer;
                }
                return document.querySelector('.hotel-map-page__sidebar') || filterDrawer || document;
            }

            function readFilterState() {
                const root = getFilterRoot();
                const stars = Array.from(root.querySelectorAll('.hotel-map-page__star-btn.is-active'))
                    .map(function (btn) { return parseInt(btn.getAttribute('data-map-star') || '0', 10); })
                    .filter(function (n) { return n > 0; });
                const minEl = root.querySelector('.hotel-map-page__filter-min-price');
                const maxEl = root.querySelector('.hotel-map-page__filter-max-price');
                const minRaw = minEl?.value?.trim() || '';
                const maxRaw = maxEl?.value?.trim() || '';
                const minPrice = minRaw !== '' ? parseFloat(minRaw) || 0 : 0;
                const maxPrice = maxRaw !== '' ? parseFloat(maxRaw) || Number.MAX_SAFE_INTEGER : Number.MAX_SAFE_INTEGER;
                const priceFilterActive = minRaw !== '' || maxRaw !== '';
                return {
                    query: normalizeText(root.querySelector('.hotel-map-page__filter-search')?.value || ''),
                    city: normalizeText(root.querySelector('.hotel-map-page__filter-city')?.value || ''),
                    district: normalizeText(root.querySelector('.hotel-map-page__filter-district')?.value || ''),
                    neighborhood: normalizeText(root.querySelector('.hotel-map-page__filter-neighborhood')?.value || ''),
                    stars: stars,
                    minPrice: minPrice,
                    maxPrice: maxPrice,
                    priceFilterActive: priceFilterActive
                };
            }

            function writeFilterState(state, scope) {
                const form = document.querySelector('form[data-map-filter-scope="' + scope + '"]');
                if (!form || !state) return;
                const setVal = function (selector, value) {
                    const el = form.querySelector(selector);
                    if (el) el.value = value || '';
                };
                setVal('.hotel-map-page__filter-search', state.queryRaw || '');
                setVal('.hotel-map-page__filter-city', state.cityRaw || '');
                setVal('.hotel-map-page__filter-district', state.districtRaw || '');
                setVal('.hotel-map-page__filter-neighborhood', state.neighborhoodRaw || '');
                const minEl = form.querySelector('.hotel-map-page__filter-min-price');
                const maxEl = form.querySelector('.hotel-map-page__filter-max-price');
                if (minEl) minEl.value = state.priceFilterActive ? String(state.minPrice || '') : '';
                if (maxEl) maxEl.value = state.priceFilterActive && state.maxPrice !== Number.MAX_SAFE_INTEGER ? String(state.maxPrice) : '';
                form.querySelectorAll('.hotel-map-page__star-btn').forEach(function (btn) {
                    const star = parseInt(btn.getAttribute('data-map-star') || '0', 10);
                    btn.classList.toggle('is-active', state.stars.indexOf(star) !== -1);
                });
            }

            function syncFilterScopes(fromScope, toScope) {
                const fromForm = document.querySelector('form[data-map-filter-scope="' + fromScope + '"]');
                if (!fromForm) return;
                writeFilterState({
                    queryRaw: fromForm.querySelector('.hotel-map-page__filter-search')?.value || '',
                    cityRaw: fromForm.querySelector('.hotel-map-page__filter-city')?.value || '',
                    districtRaw: fromForm.querySelector('.hotel-map-page__filter-district')?.value || '',
                    neighborhoodRaw: fromForm.querySelector('.hotel-map-page__filter-neighborhood')?.value || '',
                    minPrice: parseFloat(fromForm.querySelector('.hotel-map-page__filter-min-price')?.value || '0') || 0,
                    maxPrice: parseFloat(fromForm.querySelector('.hotel-map-page__filter-max-price')?.value || '0') || Number.MAX_SAFE_INTEGER,
                    priceFilterActive: !!(fromForm.querySelector('.hotel-map-page__filter-min-price')?.value || fromForm.querySelector('.hotel-map-page__filter-max-price')?.value),
                    stars: Array.from(fromForm.querySelectorAll('.hotel-map-page__star-btn.is-active')).map(function (btn) {
                        return parseInt(btn.getAttribute('data-map-star') || '0', 10);
                    }).filter(function (n) { return n > 0; })
                }, toScope);
            }

            function openFilterDrawer() {
                syncFilterScopes('desktop', 'mobile');
                filterDrawer?.classList.add('is-open');
                filterOverlay?.classList.add('is-open');
                filterOverlay?.removeAttribute('hidden');
                filterDrawer?.setAttribute('aria-hidden', 'false');
                openFiltersBtn?.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            }

            function closeFilterDrawer() {
                filterDrawer?.classList.remove('is-open');
                filterOverlay?.classList.remove('is-open');
                filterOverlay?.setAttribute('hidden', 'hidden');
                filterDrawer?.setAttribute('aria-hidden', 'true');
                openFiltersBtn?.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }

            function resetAllFilters() {
                document.querySelectorAll('form[data-map-filter-scope]').forEach(function (form) {
                    form.querySelectorAll('input[type="search"], input[type="number"]').forEach(function (el) { el.value = ''; });
                    form.querySelectorAll('select').forEach(function (el) { el.selectedIndex = 0; });
                    form.querySelectorAll('.hotel-map-page__star-btn').forEach(function (btn) { btn.classList.remove('is-active'); });
                });
                try {
                    const url = new URL(window.location.href);
                    url.searchParams.delete('minPrice');
                    url.searchParams.delete('maxPrice');
                    window.history.replaceState({}, '', url);
                } catch (_) { /* ignore */ }
                applyMapState();
            }

            let hotels = [];
            try {
                hotels = JSON.parse(payload?.textContent || '[]');
            } catch (_) {
                hotels = [];
            }

            function normalizeText(value) {
                return String(value || '')
                    .toLocaleLowerCase('tr-TR')
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function formatPrice(value) {
                const amount = Number(value || 0);
                if (!Number.isFinite(amount) || amount <= 0) return 'Fiyat yok';
                return '₺' + Math.round(amount).toLocaleString('tr-TR');
            }

            const map = window.L.map(mapCanvas, {
                zoomControl: true,
                scrollWheelZoom: true
            });

            window.L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                maxZoom: 19,
                subdomains: 'abcd',
                attribution: '&copy; OpenStreetMap katkıda bulunanlar &copy; CARTO'
            }).addTo(map);

            const clusterLayer = typeof window.L.markerClusterGroup === 'function'
                ? window.L.markerClusterGroup({
                    showCoverageOnHover: false,
                    zoomToBoundsOnClick: true,
                    spiderfyOnMaxZoom: true,
                    disableClusteringAtZoom: 15,
                    maxClusterRadius: 56,
                    iconCreateFunction: function (cluster) {
                        const count = cluster.getChildCount();
                        return window.L.divIcon({
                            className: 'hotel-map-cluster-icon',
                            html: '<span class="hotel-map-cluster" aria-label="' + count + ' otel kümesi">' + count + '</span>',
                            iconSize: [44, 44],
                            iconAnchor: [22, 22]
                        });
                    }
                })
                : window.L.layerGroup();
            clusterLayer.addTo(map);
            const markers = [];

            hotels.forEach(function (hotel) {
                const lat = Number(hotel.lat);
                const lon = Number(hotel.lon);
                if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;

                const areaParts = [hotel.neighborhood, hotel.district, hotel.city].filter(Boolean);
                const areaText = areaParts.join(' / ');
                const priceText = formatPrice(hotel.price);
                const pillIcon = window.L.divIcon({
                    className: 'hotel-map-pill-icon',
                    html:
                        '<button type="button" class="hotel-map-pill" aria-label="' + escapeHtml(String(hotel.name || 'Otel')) + '">' +
                            '<span>' + escapeHtml(priceText) + '</span>' +
                        '</button>',
                    iconSize: [74, 36],
                    iconAnchor: [37, 18],
                    popupAnchor: [0, -8]
                });

                const popupImage = hotel.image
                    ? '<div class="hotel-map-popup__visual"><img src="' + escapeHtml(hotel.image) + '" alt="' + escapeHtml(String(hotel.name || 'Otel')) + '" loading="lazy"></div>'
                    : '<div class="hotel-map-popup__visual is-placeholder"><i class="fas fa-hotel" aria-hidden="true"></i></div>';

                const popupHtml =
                    '<article class="hotel-map-popup">' +
                        popupImage +
                        '<div class="hotel-map-popup__body">' +
                            '<strong>' + escapeHtml(String(hotel.name || 'Otel')) + '</strong>' +
                            '<span>' + escapeHtml(areaText) + '</span>' +
                            '<div class="hotel-map-popup__meta">' +
                                '<b>' + escapeHtml(priceText) + '</b>' +
                                '<em>' + escapeHtml(Number(hotel.rating || 0).toLocaleString('tr-TR', { minimumFractionDigits: 1, maximumFractionDigits: 1 })) + '</em>' +
                            '</div>' +
                            '<a class="hotel-map-popup__cta" href="' + buildHotelDetailUrl(hotel.slug || '') + '">Oteli İncele</a>' +
                        '</div>' +
                    '</article>';

                const marker = window.L.marker([lat, lon], { icon: pillIcon });
                marker.bindPopup(popupHtml, { closeButton: false, offset: [0, -6], maxWidth: 280, className: 'hotel-map-popup-shell' });
                markers.push({
                    id: Number(hotel.id || 0),
                    lat,
                    lon,
                    hotel,
                    marker,
                    areaText,
                    nameSearch: normalizeText(hotel.name),
                    citySearch: normalizeText(hotel.city),
                    districtSearch: normalizeText(hotel.district),
                    neighborhoodSearch: normalizeText(hotel.neighborhood),
                    keywordSearch: normalizeText([hotel.name, hotel.city, hotel.district, hotel.neighborhood].join(' ')),
                    ratingValue: Number(hotel.rating || 0),
                    starValue: Number(hotel.starCount || 0),
                    priceValue: Number(hotel.price || 0)
                });
            });

            function getFilteredEntries() {
                const state = readFilterState();

                return markers.filter(function (entry) {
                    if (state.query && entry.keywordSearch.indexOf(state.query) === -1) return false;
                    if (state.city && entry.citySearch !== state.city) return false;
                    if (state.district && entry.districtSearch !== state.district) return false;
                    if (state.neighborhood && entry.neighborhoodSearch !== state.neighborhood) return false;
                    if (state.stars.length && state.stars.indexOf(entry.starValue) === -1) return false;
                    if (state.priceFilterActive && entry.priceValue > 0) {
                        if (entry.priceValue < state.minPrice || entry.priceValue > state.maxPrice) return false;
                    }
                    return true;
                });
            }

            function fitEntries(entries) {
                if (!entries.length) {
                    map.setView([41.015137, 28.97953], 10);
                    return;
                }

                if (typeof clusterLayer.getBounds === 'function') {
                    const clusterBounds = clusterLayer.getBounds();
                    if (clusterBounds && clusterBounds.isValid()) {
                        map.fitBounds(clusterBounds, { padding: [50, 50], maxZoom: 12 });
                        return;
                    }
                }

                const bounds = window.L.latLngBounds(entries.map(function (entry) {
                    return [entry.lat, entry.lon];
                }));
                map.fitBounds(bounds, { padding: [50, 50], maxZoom: 12 });
            }

            function applyMapState() {
                const entries = getFilteredEntries();
                clusterLayer.clearLayers();

                entries.forEach(function (entry) {
                    clusterLayer.addLayer(entry.marker);
                });

                listItems.forEach(function (item) {
                    const id = Number(item.getAttribute('data-map-id') || '0');
                    const entry = entries.find(function (x) { return x.id === id; });
                    item.hidden = !entry;
                });

                visibleCount.textContent = String(entries.length);
                if (pinCount) {
                    pinCount.textContent = String(entries.length);
                }
                summaryText.textContent = entries.length
                    ? entries.length + ' pin haritada (yakın pinler küme halinde; küme üzerine dokununca yakınlaşır).'
                    : 'Filtrelere uygun tesis bulunamadı. Aramayı genişletin veya filtreleri temizleyin.';
                if (emptyState) {
                    const showEmpty = entries.length === 0;
                    emptyState.hidden = !showEmpty;
                    emptyState.classList.toggle('is-hidden', !showEmpty);
                }
                fitEntries(entries);
            }

            fitBtn?.addEventListener('click', applyMapState);

            document.querySelectorAll('form[data-map-filter-scope]').forEach(function (form) {
                form.querySelectorAll('.hotel-map-page__filter-search, .hotel-map-page__filter-min-price, .hotel-map-page__filter-max-price').forEach(function (control) {
                    control.addEventListener('input', function () {
                        if (form.getAttribute('data-map-filter-scope') === 'desktop') applyMapState();
                    });
                });
                form.querySelectorAll('.hotel-map-page__filter-city, .hotel-map-page__filter-district, .hotel-map-page__filter-neighborhood').forEach(function (control) {
                    control.addEventListener('change', function () {
                        if (form.getAttribute('data-map-filter-scope') === 'desktop') applyMapState();
                    });
                });
                form.querySelectorAll('.hotel-map-page__star-btn').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        btn.classList.toggle('is-active');
                        if (form.getAttribute('data-map-filter-scope') === 'desktop') applyMapState();
                    });
                });
            });

            document.querySelectorAll('[data-map-filter-reset]').forEach(function (btn) {
                btn.addEventListener('click', resetAllFilters);
            });

            openFiltersBtn?.addEventListener('click', openFilterDrawer);
            closeFiltersBtn?.addEventListener('click', closeFilterDrawer);
            filterOverlay?.addEventListener('click', closeFilterDrawer);
            applyFiltersBtn?.addEventListener('click', function () {
                syncFilterScopes('mobile', 'desktop');
                const state = readFilterState();
                try {
                    const url = new URL(window.location.href);
                    if (state.priceFilterActive && state.minPrice > 0) url.searchParams.set('minPrice', String(Math.floor(state.minPrice)));
                    else url.searchParams.delete('minPrice');
                    if (state.priceFilterActive && state.maxPrice > 0 && state.maxPrice < Number.MAX_SAFE_INTEGER) url.searchParams.set('maxPrice', String(Math.floor(state.maxPrice)));
                    else url.searchParams.delete('maxPrice');
                    window.history.replaceState({}, '', url);
                } catch (_) { /* ignore */ }
                applyMapState();
                closeFilterDrawer();
            });

            listItems.forEach(function (link) {
                link.addEventListener('mouseenter', function () {
                    const id = Number(link.getAttribute('data-map-id') || '0');
                    const entry = markers.find(function (x) { return x.id === id; });
                    if (!entry) return;
                    map.flyTo([entry.lat, entry.lon], Math.max(map.getZoom(), 13), { duration: 0.45 });
                    entry.marker.openPopup();
                });
            });

            applyMapState();
        })();
    </script>
}
