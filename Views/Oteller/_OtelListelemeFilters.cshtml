@model otelturizmnew.Models.Oteller.HotelListingPageViewModel
@using System.Globalization
@{
    var scope = ViewData["FilterScope"] as string ?? "desktop";
    var prefix = scope == "mobile" ? "otelliste-m-" : "otelliste-";
    var hotels = Model.Hotels ?? new List<otelturizmnew.Models.Oteller.HotelListingCardViewModel>();
    var smartRoutes = Model.SmartRoutes ?? new List<otelturizmnew.Models.Oteller.SmartRouteFilterViewModel>();
    var cityOptions = (Model.Cities?.Any() == true
        ? Model.Cities
        : hotels.Select(h => h.City).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase))
        .OrderBy(x => x)
        .ToList();
    var districtOptions = (Model.Districts?.Any() == true
        ? Model.Districts
        : hotels.Select(h => h.District).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase))
        .OrderBy(x => x)
        .ToList();
    var neighborhoodOptions = (Model.Neighborhoods?.Any() == true
        ? Model.Neighborhoods
        : hotels.Select(h => h.Neighborhood).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase))
        .OrderBy(x => x)
        .ToList();
    var starOptions = (Model.StarOptions?.Any() == true
        ? Model.StarOptions
        : hotels.Where(h => h.StarCount.HasValue).Select(h => h.StarCount!.Value).Distinct())
        .OrderByDescending(x => x)
        .ToList();
    var priced = hotels.Where(x => (x.StartingPrice ?? 0m) > 0m).ToList();
    var priceMin = Model.MaxPrice > 0m
        ? Model.MinPrice
        : priced.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Min();
    var priceMax = Model.MaxPrice > 0m
        ? Model.MaxPrice
        : priced.Select(x => x.StartingPrice ?? 0m).DefaultIfEmpty(0m).Max();
    var hasPriceRange = priceMax > 0m;
    var activeMinPrice = Model.ActiveMinPrice.HasValue && Model.ActiveMinPrice.Value > 0m
        ? (int)Math.Floor(Model.ActiveMinPrice.Value)
        : (int?)null;
    var activeMaxPrice = Model.ActiveMaxPrice.HasValue && Model.ActiveMaxPrice.Value > 0m
        ? (int)Math.Ceiling(Model.ActiveMaxPrice.Value)
        : (int?)null;
}

<div class="otelliste-filters" data-filter-scope="@scope">
    @if (Model.UserTravelPreferences?.HasActionablePreferences == true)
    {
        <div class="otelliste-travel-pref-block">
            <button type="button"
                    class="otelliste-travel-pref-btn"
                    data-travel-pref-apply
                    aria-pressed="false">
                <span class="otelliste-travel-pref-btn-icon" aria-hidden="true"><i class="fas fa-compass"></i></span>
                <span class="otelliste-travel-pref-btn-copy">
                    <strong>Seyahat tercihlerime göre ara</strong>
                    <small>@Model.UserTravelPreferences.SummaryText</small>
                </span>
            </button>
            <a class="otelliste-travel-pref-edit" href="/panel/user/profil-bilgilerim">Tercihleri düzenle</a>
            <div class="otelliste-travel-pref-toast" id="otellisteTravelPrefToast-@scope" role="status" aria-live="polite"></div>
        </div>
    }

    <div class="otelliste-filter-group">
        <label for="@(prefix)keyword">Konum / Otel Ara</label>
        <input type="search"
               id="@(prefix)keyword"
               class="otelliste-field otelliste-filter-keyword"
               placeholder="Otel adı, il, ilçe veya mahalle"
               autocomplete="off" />
    </div>

    <div class="otelliste-filter-location-grid">
        <div class="otelliste-filter-group otelliste-filter-group--city">
            <label for="@(prefix)city">İl</label>
            <select id="@(prefix)city" class="otelliste-field otelliste-filter-city">
                <option value="">Tüm iller</option>
                @foreach (var city in cityOptions)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>

        <div class="otelliste-filter-group otelliste-filter-group--district">
            <label for="@(prefix)district">İlçe</label>
            <select id="@(prefix)district" class="otelliste-field otelliste-filter-district">
                <option value="">Tüm ilçeler</option>
                @foreach (var district in districtOptions)
                {
                    <option value="@district">@district</option>
                }
            </select>
        </div>

        <div class="otelliste-filter-group otelliste-filter-group--neighborhood">
            <label for="@(prefix)neighborhood">Mahalle</label>
            <select id="@(prefix)neighborhood" class="otelliste-field otelliste-filter-neighborhood">
                <option value="">Tüm mahalleler</option>
                @foreach (var neighborhood in neighborhoodOptions)
                {
                    <option value="@neighborhood">@neighborhood</option>
                }
            </select>
        </div>
    </div>

    @if (hasPriceRange)
    {
        <div class="otelliste-filter-group otelliste-filter-group--price">
            <span class="otelliste-filter-label">Fiyat Aralığı (₺)</span>
            <div class="otelliste-price-row">
                <input type="number"
                       id="@(prefix)minPrice"
                       class="otelliste-field otelliste-filter-min-price"
                       placeholder="Min @((int)Math.Floor(priceMin))"
                       min="0"
                       step="1"
                       value="@(activeMinPrice?.ToString(CultureInfo.InvariantCulture))"
                       data-default-min="@((int)Math.Floor(priceMin))"
                       data-default-max="@((int)Math.Ceiling(priceMax))"
                       aria-label="Minimum fiyat" />
                <input type="number"
                       id="@(prefix)maxPrice"
                       class="otelliste-field otelliste-filter-max-price"
                       placeholder="Max @((int)Math.Ceiling(priceMax))"
                       min="0"
                       step="1"
                       value="@(activeMaxPrice?.ToString(CultureInfo.InvariantCulture))"
                       data-default-min="@((int)Math.Floor(priceMin))"
                       data-default-max="@((int)Math.Ceiling(priceMax))"
                       aria-label="Maksimum fiyat" />
            </div>
        </div>
    }

    @if (starOptions.Count > 0)
    {
        <div class="otelliste-filter-group">
            <span class="otelliste-filter-label">Yıldız</span>
            <div class="otelliste-star-options otelliste-filter-stars" role="group" aria-label="Yıldız filtresi">
                @foreach (var star in starOptions)
                {
                    <button type="button" class="otelliste-star-btn" data-star="@star">@star★</button>
                }
            </div>
        </div>
    }

    <div class="otelliste-filter-group otelliste-filter-group--smart-routes">
        <span class="otelliste-filter-label">Akıllı Rota</span>
        @if (smartRoutes.Count > 0)
        {
            <p class="otelliste-filter-hint">Ruh halinize uygun otelleri etiketlerle daraltın.</p>
            <div class="otelliste-smart-route-pills otelliste-filter-smart-routes" role="group" aria-label="Akıllı Rota etiketleri">
                @foreach (var tag in smartRoutes)
                {
                    <label class="ai-pill ai-pill--@tag.ColorClass otelliste-filter-smart-route" title="@tag.DisplayName">
                        <input type="checkbox"
                               class="otelliste-filter-smart-route-input"
                               value="@tag.Slug"
                               aria-label="@tag.Hashtag" />
                        <span class="ai-pill-dot" aria-hidden="true"></span>
                        <span class="otelliste-smart-route-label">@tag.Hashtag</span>
                        @if (tag.HotelCount > 0)
                        {
                            <span class="otelliste-smart-route-count">@tag.HotelCount</span>
                        }
                    </label>
                }
            </div>
        }
        else
        {
            <p class="otelliste-filter-empty">Akıllı Rota etiketleri yükleniyor. Kısa süre sonra burada görünecek.</p>
        }
    </div>

    <button type="button" class="otelliste-btn-reset otelliste-filter-reset">Filtreleri Sıfırla</button>
    <button type="button" class="otelliste-btn-apply otelliste-filter-apply">Filtreleri Uygula</button>
</div>
