                    var roomGallery = room.GalleryImages.Count > 0
                        ? room.GalleryImages
                        : (!string.IsNullOrWhiteSpace(room.ImageUrl) ? new List<string> { room.ImageUrl } : new List<string>());
                    var roomCoverImage = !string.IsNullOrWhiteSpace(room.ImageUrl)
                        ? room.ImageUrl
                        : roomGallery.FirstOrDefault();
                    var roomCoverImageResolved = ResolveRoomImageUrl(roomCoverImage);
                    var roomGalleryResolved = roomGallery
                        .Select(ResolveRoomImageUrl)
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();
                    if (roomGalleryResolved.Count == 0)
                    {
                        roomGalleryResolved.Add(roomCoverImageResolved);
                    }

                    <div class="room-card od-room-card">
                        <div class="room-card-main od-room-card__body">
                            <div class="room-card-media">
                                <div class="room-card-cover">
                                    <div class="room-carousel"
                                         data-room-carousel
                                         data-room-id="@room.RoomTypeId"
                                         data-room-name="@room.Name"
                                         aria-label="@room.Name galerisi">
                                        <div class="room-carousel-track">
                                            @for (var imageIndex = 0; imageIndex < roomGalleryResolved.Count; imageIndex++)
                                            {
                                                <div class="room-carousel-slide" data-room-slide-index="@imageIndex">
                                                    <img src="@roomGalleryResolved[imageIndex]"
                                                         alt="@room.Name görsel @(imageIndex + 1)"
                                                         loading="@(imageIndex == 0 ? "eager" : "lazy")"
                                                         decoding="async"
                                                         onerror="this.onerror=null;this.src='@hotelImagePlaceholder';" />
                                                </div>
                                            }
                                        </div>
                                        <span class="room-carousel-name">@room.Name</span>
                                        @if (roomGalleryResolved.Count > 1)
                                        {
                                            <span class="room-gallery-count room-carousel-count">
                                                <i class="fas fa-images" aria-hidden="true"></i>
                                                @string.Format(i18nRoomGalleryCount, roomGalleryResolved.Count)
                                            </span>
                                            <div class="room-carousel-dots" aria-hidden="true">
                                                @for (var dotIndex = 0; dotIndex < roomGalleryResolved.Count; dotIndex++)
                                                {
                                                    <span class="room-carousel-dot @(dotIndex == 0 ? "active" : string.Empty)" data-room-dot="@dotIndex"></span>
                                                }
                                            </div>
                                        }
                                        <button type="button"
                                                class="room-gallery-trigger room-carousel-open"
                                                data-room-name="@room.Name"
                                                data-room-id="@room.RoomTypeId"
                                                data-room-gallery-start="0"
                                                hidden
                                                aria-hidden="true"
                                                tabindex="-1"></button>
                                    </div>
                                </div>
                            </div>
                            <div class="room-card-copy od-room-card__content">
                                <h3 class="od-room-card__title">@room.Name</h3>
                                <div class="od-room-card__meta">
                                    @if (!string.IsNullOrWhiteSpace(room.BedType))
                                    {
                                        <span class="od-pill od-pill--bed"><i class="fas fa-bed" aria-hidden="true"></i> @room.BedType</span>
                                    }
                                    @if (room.SquareMeter.HasValue && room.SquareMeter.Value > 0)
                                    {
                                        <span class="od-pill od-pill--size"><i class="fas fa-ruler-combined" aria-hidden="true"></i> @room.SquareMeter m²</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(room.CancellationText))
                                    {
                                        <span class="od-pill od-pill--meal"><i class="fas fa-utensils" aria-hidden="true"></i> @room.CancellationText</span>
                                    }
                                </div>
                                <p class="od-room-card__specs">@room.Specs</p>
                                @{
                                    var roomFeatureSeed = room.Features ?? new List<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>();
                                    var roomTopFeatures = roomFeatureSeed.Take(3).ToList();
                                    if (roomTopFeatures.Count < 3)
                                    {
                                        // Oda özellikleri azsa, otelin öne çıkan olanaklarından tamamla (tekrarları çıkar).
                                        var existing = new HashSet<string>(roomTopFeatures.Select(x => x.Name ?? string.Empty), StringComparer.OrdinalIgnoreCase);
                                        foreach (var amenity in Model.Amenities.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
                                        {
                                            if (roomTopFeatures.Count >= 3) break;
                                            if (!existing.Add(amenity.Name)) continue;
                                            roomTopFeatures.Add(new otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel
                                            {
                                                Name = amenity.Name,
                                                IconClass = string.IsNullOrWhiteSpace(amenity.IconClass) ? "fa-circle-check" : amenity.IconClass
                                            });
                                        }
                                    }

                                    var roomAllFeatures = (room.Features ?? Enumerable.Empty<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>())
                                        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                        .Select(x => new
                                        {
                                            Name = x.Name,
                                            IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                        })
                                        .ToList();

                                    if (roomAllFeatures.Count == 0)
                                    {
                                        roomAllFeatures = roomTopFeatures
                                            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                            .Select(x => new
                                            {
                                                Name = x.Name,
                                                IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                            })
                                            .ToList();
                                    }
                                    roomGalleryMap[room.RoomTypeId] = roomGallery;
                                    roomDetailsMap[room.RoomTypeId] = roomAllFeatures;
                                }
                                <div class="room-feature-row">
                                    @if (roomTopFeatures.Count > 0)
                                    {
                                        <ul class="room-feature-list" aria-label="Öne çıkan oda özellikleri">
                                            @foreach (var feature in roomTopFeatures)
                                            {
                                                <li class="room-feature-item">
                                                    <i class="fas @feature.IconClass" aria-hidden="true"></i>
                                                    <span>@feature.Name</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                                @{
                                    var roomHasDiscount = room.DiscountPrice.HasValue
                                                         && room.BasePrice.HasValue
                                                         && room.DiscountPrice.Value > 0m
                                                         && room.BasePrice.Value > 0m
                                                         && room.DiscountPrice.Value < room.BasePrice.Value;
                                    var roomBaseDisplay = roomHasDiscount ? Model.GuestInclusiveNightlyFromStoredNet(room.BasePrice!.Value) : 0m;
                                    var roomNightlyDisplay = room.Price > 0m ? Model.GuestInclusiveNightlyFromStoredNet(room.Price) : 0m;
                                    var roomDiscountPercent = roomHasDiscount
                                        ? Math.Clamp((int)Math.Round(((roomBaseDisplay - roomNightlyDisplay) / roomBaseDisplay) * 100m, MidpointRounding.AwayFromZero), 1, 95)
                                        : 0;
                                    var roomStayTotalForPoints = roomNightlyDisplay > 0m ? roomNightlyDisplay * initialNightCount * initialRooms : 0m;
                                    var roomEarnPoints = roomStayTotalForPoints > 0m ? HotelPointsService.CalculateEarnPoints(roomStayTotalForPoints) : 0;
                                }
                                <div class="room-card-actions-row od-room-card__actions">
                                    @if (roomGalleryResolved.Count > 1)
                                    {
                                        <button type="button"
                                                class="amenities-btn amenities-btn--compact room-gallery-btn od-room-action-btn room-card-action-secondary room-gallery-trigger"
                                                data-room-name="@room.Name"
                                                data-room-id="@room.RoomTypeId"
                                                data-room-gallery-start="0"
                                                aria-label="@room.Name galerisi">
                                            <i class="fas fa-images" aria-hidden="true"></i>
                                            Galeri (@roomGalleryResolved.Count)
                                        </button>
                                    }
                                    else if (roomHasDiscount)
                                    {
                                        <div class="room-card-value-hint room-card-value-hint--discount room-card-action-secondary" role="status">
                                            <i class="fas fa-tag" aria-hidden="true"></i>
                                            <span>−%@roomDiscountPercent @(string.IsNullOrWhiteSpace(room.DiscountName) ? "indirim" : room.DiscountName)</span>
                                        </div>
                                    }
                                    else if (roomEarnPoints > 0)
                                    {
                                        <div class="room-card-value-hint room-card-value-hint--loyalty room-card-action-secondary" role="status">
                                            <i class="fas fa-gift" aria-hidden="true"></i>
                                            <span>+@roomEarnPoints puan kazanın</span>
                                        </div>
                                    }
                                    <button type="button"
                                            class="amenities-btn amenities-btn--compact room-feature-more-btn room-detail-btn od-room-action-btn"
                                            data-room-detail-open
                                            data-room-name="@room.Name"
                                            data-room-id="@room.RoomTypeId"
                                            data-room-specs="@room.Specs"
                                            data-room-description="@room.DetailDescription"
                                            data-room-bed-type="@room.BedType"
                                            data-room-square-meter="@(room.SquareMeter?.ToString() ?? string.Empty)"
                                            data-room-max-guests="@room.MaxGuestCount"
                                            data-room-max-adults="@room.MaxAdultCount"
                                            data-room-max-children="@room.MaxChildCount"
                                            data-room-price="@(room.Price > 0m ? roomNightlyDisplay.ToString("N0") : string.Empty)"
                                            data-room-price-base="@(roomHasDiscount ? roomBaseDisplay.ToString("N0") : string.Empty)"
                                            data-room-discount-name="@(roomHasDiscount ? (room.DiscountName ?? string.Empty) : string.Empty)"
                                            data-room-discount-percent="@(roomHasDiscount ? roomDiscountPercent.ToString() : string.Empty)"
                                            data-room-cancellation="@room.CancellationText"
                                            data-room-feature-count="@roomAllFeatures.Count"
                                            data-room-gallery-count="@roomGallery.Count">
                                        Detaylar
                                        <i class="fas fa-arrow-right" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <div class="room-card-aux">
                                    @{
                                        var cancelClass = !string.IsNullOrWhiteSpace(room.CancellationText)
                                            && room.CancellationText.Contains("Ücretsiz", StringComparison.OrdinalIgnoreCase)
                                            ? "is-free"
                                            : "is-restricted";
                                    }
                                    <span class="cancellation-badge @cancelClass"><i class="fas fa-check-circle"></i> @room.CancellationText</span>
                                </div>
                            </div>
                        </div>
                        <div class="room-price-box od-room-card__pricing">
                            <div class="room-price-actions">
                                @if (room.Price > 0m)
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="@room.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                                        @SharedLocalizer["Detail.Room.Reserve"].Value
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="0"
                                            disabled>
                                        @SharedLocalizer["Detail.Room.NoPrice"].Value
                                    </button>
                                }
                            </div>
                            <div class="room-price-value">
                                <small class="room-price-kicker">@SharedLocalizer["Detail.Room.Nightly"].Value</small>
                                @{
                                    var hasRoomDiscount = roomHasDiscount;
                                    var baseDisplay = roomBaseDisplay;
                                    var discountDisplay = roomNightlyDisplay;
                                    var discountPercent = roomDiscountPercent;
                                }

                                @if (room.Price > 0m)
                                {
                                    var nightlyDisplay = Model.GuestInclusiveNightlyFromStoredNet(room.Price);
                                    var stayTotal = nightlyDisplay * initialNightCount;

                                    if (hasRoomDiscount)
                                    {
                                        <div class="room-price-discount-stack">
                                            <span class="room-price-old">₺@baseDisplay.ToString("N0")</span>
                                            <strong>₺@nightlyDisplay.ToString("N0")</strong>
                                            <span class="room-price-discount-pill">
                                                %@discountPercent
                                                @if (room.DiscountId.HasValue && !string.IsNullOrWhiteSpace(room.DiscountName))
                                                {
                                                    <button type="button"
                                                            class="discount-info-btn"
                                                            data-discount-open
                                                            data-discount-title="@room.DiscountName"
                                                            data-discount-desc="@room.DiscountShortDescription"
                                                            data-discount-image="@room.DiscountImageUrl"
                                                            aria-label="İndirim detayını görüntüle">
                                                        <i class="fas fa-circle-info" aria-hidden="true"></i>
                                                    </button>
                                                }
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <strong>₺@nightlyDisplay.ToString("N0")</strong>
                                    }

                                    <span class="room-price-inclusive-label" title="@SharedLocalizer["Detail.Room.TaxesIncluded"].Value">@SharedLocalizer["Detail.Room.TaxesIncluded"].Value</span>
                                    <small class="room-price-total">@string.Format(i18nRoomTotalLine, initialNightCount): ₺@stayTotal.ToString("N0")</small>
                                }
                                else
                                {
                                    <strong>Fiyat yok</strong>
                                    <span class="room-price-unavailable">Bu oda için aktif fiyat bulunamadı</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Oda galerisi: PureVisualSlider tam ekran modal *@

        </article>

        <article class="content-card od-section od-section--reviews" id="reviewsSection">
            <div class="section-head tabler-section-head">
                <div class="tabler-section-headrow">
                    <div class="tabler-section-titles">
                        <h2>@SharedLocalizer["Detail.Reviews.Title"].Value</h2>
                        <p>@SharedLocalizer["Detail.Reviews.Subtitle"].Value</p>
                    </div>
                    <div class="tabler-section-actions">
                        <button type="button" class="tabler-section-action-btn" data-scroll-reviews>
                            @SharedLocalizer["Detail.Reviews.GoTo"].Value
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>

            @if (Model.IsLoggedInUser && Model.EligibleReviewStays.Count > 0)
            {
                <div class="hotel-guest-review-compose" role="region" aria-label="Konaklama yorumu yaz">
                    <div class="hotel-guest-review-compose-head">
                        <strong>Konaklamanı seç, yorum yaz</strong>
                        <span>Tamamlanan ve değerlendirilmeyi bekleyen konaklamaların için bu otelde yorum ekleyebilirsin.</span>
                    </div>
                    <div class="hotel-guest-review-compose-actions">
                        @foreach (var stay in Model.EligibleReviewStays)
                        {
                            <a class="btn btn-primary btn-sm" href="/panel/user/rezervasyonlarim/yorum/@stay.ReservationId">@stay.StayDateText · @stay.RoomName</a>
                        }
                    </div>
                    <a class="hotel-guest-review-compose-link" href="/panel/user/yorumlarim?status=waiting&amp;searchTerm=@Uri.EscapeDataString(Model.Name)">Tüm yorumlarımı aç</a>
                </div>
            }

            <div class="review-summary review-summary--ota">
                <div class="review-summary-score-col">
                    <div class="review-score-circle" aria-label="@SharedLocalizer["Filter.Rating"].Value">
                        <strong>@(signatureScore > 0 ? signatureScore.ToString("0.0") : "0.0")</strong>
                        <span>/10</span>
                    </div>
                    <p class="review-signature-title">@Model.RatingText</p>
                    <small class="review-verified-count">@(Model.ReviewCount > 0 ? SharedLocalizer["Detail.Review.VerifiedCount", Model.ReviewCount].Value : SharedLocalizer["Detail.Rating.NoReviews"].Value)</small>
                </div>
                <div class="review-summary-bars-col">
                <div class="review-bars">
                    <div><span>Genel</span><div class="bar"><span style="width:@(overallBarWidth)%"></span></div><strong>@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "-")</strong></div>
                    <div><span>Konum</span><div class="bar"><span style="width:@(locationBarWidth)%"></span></div><strong>@(locScore > 0 ? locScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Temizlik</span><div class="bar"><span style="width:@(cleaningBarWidth)%"></span></div><strong>@(cleaningScore > 0 ? cleaningScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Personel</span><div class="bar"><span style="width:@(staffBarWidth)%"></span></div><strong>@(staffScore > 0 ? staffScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Fiyat</span><div class="bar"><span style="width:@(valueBarWidth)%"></span></div><strong>@(valScore > 0 ? valScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Sessizlik</span><div class="bar"><span style="width:@(quietBarWidth)%"></span></div><strong>@(quietScore > 0 ? quietScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Ulaşım</span><div class="bar"><span style="width:@(transportBarWidth)%"></span></div><strong>@(transportScore > 0 ? transportScore.ToString("0.0") : "-")</strong></div>
                </div>
                </div>
            </div>

            <div class="review-topic-strip" id="reviewTopicStrip">
                @foreach (var topic in reviewTopicPayload)
                {
                    <button type="button"
                            class="review-topic-chip"
                            data-review-topic-open="true"
                            data-topic-key="@topic.key"
                            data-topic-label="@topic.label"
                            data-topic-score="@topic.score"
                            data-topic-count="@topic.count">
                        <span class="review-topic-chip-icon">@topic.emoji</span>
                        <span class="review-topic-chip-copy">@topic.label</span>
                        <span class="review-topic-chip-count">@topic.count</span>
                    </button>
                }
            </div>

            <script type="application/json" id="reviewTopicPayloadJson">@Html.Raw(reviewTopicPayloadJson)</script>
            <script type="application/json" id="reviewFeedPayloadJson">@Html.Raw(reviewFeedPayloadJson)</script>

            @if ((Model.Reviews?.Count ?? 0) == 0)
            {
                <div class="review-card">
                    <p>Bu tesis icin onayli misafir yorumu bulunmuyor. Onayli rezervasyonunuz varsa ilk yorumu kullanıcı panelinizden siz yazabilirsiniz.</p>
                    <a class="review-more" href="/panel/user/yorumlarim">Yorumlarımı aç</a>
                </div>
            }
            else
            {
                <div class="review-toolbar">
                    <div class="review-toolbar-left">
                        <strong>Yorumlar</strong>
                        <span class="review-toolbar-count">@totalReviewCount</span>
                    </div>
                    <div class="review-toolbar-right">
                        <label class="review-sort">
                            <span>Sırala</span>
                            <select id="reviewSortSelect">
                                <option value="new" selected="@(reviewSort == "new")">En yeni</option>
                                <option value="old" selected="@(reviewSort == "old")">En eski</option>
                                <option value="best" selected="@(reviewSort == "best")">En iyi</option>
                                <option value="worst" selected="@(reviewSort == "worst")">En kötü</option>
                            </select>
                        </label>
                    </div>
                </div>

                <div id="reviewSectionDynamic">
                    <div class="review-list">
                        @foreach (var review in pagedReviews)
                        {
                            <article class="review-card">
                                <div class="review-meta">
                                    <div class="review-meta-author">
                                        <span class="review-avatar" aria-hidden="true">@(!string.IsNullOrWhiteSpace(review.Avatar) ? review.Avatar : "OT")</span>
                                        <div>
                                            <h4>@MaskName(review.Name)</h4>
                                            <p class="review-meta-date">
                                                @review.DateText
                                                @if (!string.IsNullOrWhiteSpace(review.ReservationNoTail))
                                                {
                                                    <span class="review-verified-badge"><i class="fas fa-circle-check" aria-hidden="true"></i> @SharedLocalizer["Detail.Review.Verified"].Value</span>
                                                }
                                            </p>
                                        </div>
                                    </div>
                                    <span class="review-chip">@review.Score.ToString("0.0")</span>
                                </div>
                                <div class="review-body" data-review-card>
                                    <p class="review-text is-clamped" data-review-text>@FixMojibake(review.Text)</p>
                                    <button type="button" class="review-more" data-review-more hidden>Devamını oku</button>
                                    <span data-review-fulltext hidden>@FixMojibake(review.Text)</span>
                                </div>
                            </article>
                        }
                    </div>

                    @if (totalReviewPages > 1)
                    {
                        <nav class="review-pager" aria-label="Yorum sayfalama">
                            @{
                                string BuildReviewUrl(int targetPage)
                                {
                                    var query = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                                    foreach (var key in Context.Request.Query.Keys)
                                    {
                                        query[key] = Context.Request.Query[key].ToString();
                                    }
                                    query["reviewPage"] = targetPage.ToString(System.Globalization.CultureInfo.InvariantCulture);
                                    query["reviewSort"] = reviewSort;
                                    var qs = string.Join("&", query.Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value ?? string.Empty)}"));
                                    return Context.Request.Path + (string.IsNullOrWhiteSpace(qs) ? string.Empty : "?" + qs);
                                }
                            }
                            <a class="review-page-btn @(reviewPage <= 1 ? "disabled" : string.Empty)"
                               href="@(reviewPage <= 1 ? "#" : BuildReviewUrl(reviewPage - 1))"
                               aria-disabled="@(reviewPage <= 1 ? "true" : "false")">Önceki</a>
                            <span class="review-page-indicator">@reviewPage / @totalReviewPages</span>
                            <a class="review-page-btn @(reviewPage >= totalReviewPages ? "disabled" : string.Empty)"
                               href="@(reviewPage >= totalReviewPages ? "#" : BuildReviewUrl(reviewPage + 1))"
                               aria-disabled="@(reviewPage >= totalReviewPages ? "true" : "false")">Sonraki</a>
                        </nav>
                    }
                </div>
            }
        </article>

        <article class="content-card detail-map-card od-section od-section--map" id="detailMapSection">
            <div class="section-head tabler-section-head">
                <div class="tabler-section-headrow detail-map-card__headrow">
                    <div class="tabler-section-titles detail-map-card__titles">
                        <h2>@SharedLocalizer["Detail.Location.Title"].Value</h2>
                        <p>@locationText</p>
                    </div>
                </div>
            </div>
            <div class="map-card">
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <div id="detailLocationMap"
                         class="detail-location-map"
                         data-lat="@mapLatitude"
                         data-lon="@mapLongitude"
                         data-name="@Model.Name"
                         data-location="@locationText"
                         data-address="@Model.Address"
                         data-ulke-id="@(Model.UlkeId?.ToString() ?? "")"
                         data-sehir-id="@(Model.SehirId?.ToString() ?? "")"
                         data-ilce-id="@(Model.IlceId?.ToString() ?? "")"
                         data-mahalle-id="@(Model.MahalleId?.ToString() ?? "")"
                         aria-label="Otel konum haritası"></div>
                }
                else
                {
                    <div class="map-fallback">
                        <strong>Koordinat bilgisi bekleniyor</strong>
                        <span>@Model.Address</span>
                    </div>
                }
            </div>
        </article>

        <partial name="_OtelDetaySimilarHotels" model="Model.SimilarHotels" />

    </div>

    <div class="booking-modal-backdrop rezervasyon-aksiyon-backdrop" id="rezervasyonAksiyonBackdrop" data-rezervasyonaksiyon="backdrop" hidden></div>
    <aside class="booking-sidebar od-detail__booking rezervasyon-aksiyon" id="rezervasyonAksiyon" data-rezervasyonaksiyon="sheet" role="dialog" aria-modal="true" aria-labelledby="rezervasyonAksiyonTitle">
        <h2 class="rezervasyon-aksiyon__title" id="rezervasyonAksiyonTitle" hidden>Rezervasyon</h2>
        <div class="booking-sheet-handle rezervasyon-aksiyon__handle" aria-hidden="true"></div>
        <div class="booking-card rezervasyon-aksiyon__card">
            <button type="button" class="booking-modal-close" id="bookingModalClose" aria-label="Rezervasyon panelini kapat">
                <i class="fas fa-times"></i>
            </button>
            @{
                var bookingNightlyDisplay = initialInclusiveNightly > 0m
                    ? initialInclusiveNightly
                    : (Model.LowestRoomPrice > 0m ? Model.GuestInclusiveNightlyFromStoredNet(Model.LowestRoomPrice) : 0m);
                var showBookingNightlyRow = bookingNightlyDisplay > 0m && !initialHasDawn;
                var showBookingTotalRow = initialTotal > 0m;
            }
            <div class="booking-price-head booking-price-head--ota">
                <div class="booking-price-row">
                    <div class="booking-price-main">
                        <div class="booking-price-line booking-price-line--original" id="bookingPriceOriginalRow" @(initialHasDawn ? null : "hidden")>
                            <span class="booking-price-unit">Normal fiyat</span>
                            <del id="bookingPriceOriginal" class="booking-price-original" @(initialHasDawn ? null : "aria-hidden=\"true\"")>@(initialHasDawn ? $"₺{initialOriginalTotal:N0}" : "—")</del>
                        </div>
                        <div class="booking-price-line booking-price-line--nightly" id="bookingPriceNightlyRow" @(showBookingNightlyRow ? null : "hidden")>
                            <span class="booking-price-from">@SharedLocalizer["Detail.Booking.FromNight"].Value</span>
                            <strong id="bookingNightlyFrom" class="booking-price-nightly">@(showBookingNightlyRow ? $"₺{bookingNightlyDisplay:N0}" : "—")</strong>
                        </div>
                        <div class="booking-price-line booking-price-line--total" id="bookingPriceTotalRow" @(showBookingTotalRow ? null : "hidden")>
                            <span class="booking-price-unit">@SharedLocalizer["Detail.Booking.Total"].Value</span>
                            <strong id="bookingPrice" class="booking-price-total">@(showBookingTotalRow ? $"₺{initialTotal:N0}" : "—")</strong>
                        </div>
                        <div class="booking-price-dawn-pill" id="bookingPriceDawnPill" @(initialHasDawn ? null : "hidden")>@(initialHasDawn ? $"Şafak sürprizi −%{initialDawnPercent} · ₺{initialDawnDiscount:N0}" : "")</div>
                        <div class="booking-price-meta">
                            <span class="booking-price-tax-badge">@SharedLocalizer["Detail.Room.TaxesIncluded"].Value</span>
                            <small class="booking-price-tax-note">@SharedLocalizer["Detail.Booking.TaxesNote"].Value</small>
                        </div>
                    </div>
                </div>
            </div>

            <form class="booking-form" id="bookingForm" method="post" action="/oteller/@Model.Slug/rezervasyon" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="HotelId" value="@Model.Id" />
                <input type="hidden" id="profileCompletionRequired" value="@(Model.ProfilePrompt.IsProfileIncomplete && Model.IsLoggedInUser ? "true" : "false")" />
                <input type="hidden" name="RoomsJson" id="roomsJsonInput" value="" />

                <div class="od-booking-counters-desktop-row">
                <div class="multi-room" id="multiRoomRoot">
                    <div class="multi-room-head">
                        <span class="multi-room-title">Oda seçimi</span>
                    </div>
                    <div class="multi-room-toast" id="multiRoomToast" role="status" aria-live="polite" hidden></div>

                    <div class="multi-room-list" id="roomItems"></div>

                    <template id="roomItemTemplate">
                        <section class="multi-room-item" data-room-item>
                            <div class="multi-room-item-head">
                                <div class="multi-room-item-head-main">
                                    <strong class="multi-room-item-title" data-room-title>Oda</strong>
                                    <span class="multi-room-item-summary" data-room-summary></span>
                                </div>
                                <button type="button" class="multi-room-remove" data-remove-room hidden>Sil</button>
                            </div>
                            <div class="multi-room-item-grid">
                                <div class="multi-room-item-dates">
                                    <label>
                                        <span>Giriş Tarihi</span>
                                        <input type="date" data-field="checkIn" min="@todayDate" value="@checkInDefault" />
                                    </label>
                                    <label>
                                        <span>Çıkış Tarihi</span>
                                        <input type="date" data-field="checkOut" min="@checkOutMinDefault" value="@checkOutDefault" />
                                    </label>
                                </div>
                                <label class="multi-room-item-type">
                                    <span>Oda Tipi</span>
                                    <select data-field="roomType">
                                        @foreach (var room in reservableRoomOptions)
                                        {
                                            if (room.RoomTypeId == selectedRoomSeed?.RoomTypeId)
                                            {
                                                <option value="@room.RoomTypeId"
                                                        selected="selected"
                                                        data-price="@room.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-room-name="@room.Name"
                                                        data-max-guests="@room.MaxGuestCount"
                                                        data-max-adults="@room.MaxAdultCount"
                                                        data-max-children="@room.MaxChildCount">
                                                    @room.Name
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@room.RoomTypeId"
                                                        data-price="@room.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                        data-room-name="@room.Name"
                                                        data-max-guests="@room.MaxGuestCount"
                                                        data-max-adults="@room.MaxAdultCount"
                                                        data-max-children="@room.MaxChildCount">
                                                    @room.Name
                                                </option>
                                            }
                                        }
                                    </select>
                                </label>
                            </div>
                            <div class="od-booking-counters-band od-booking-counters-band--item">
                                <label class="multi-room-quantity">
                                    <span>Oda adedi</span>
                                    <div class="room-quantity-control">
                                        <button type="button" data-room-quantity-action="minus" aria-label="Oda adedini azalt">-</button>
                                        <input type="number" data-field="roomCount" min="1" max="20" value="1" inputmode="numeric" />
                                        <button type="button" data-room-quantity-action="plus" aria-label="Oda adedini artır">+</button>
                                    </div>
                                </label>
                            </div>
                        </section>
                    </template>
                </div>

                <div class="od-booking-counters-band od-booking-counters-band--guests" aria-label="Oda ve misafir sayısı">
                <div class="guest-row">
                    <span>Yetişkin</span>
                    <div class="guest-controls">
                        <button type="button" class="guest-btn" data-target="adult" data-action="minus">-</button>
                        <strong id="adultCount">@reservationForm.AdultCount</strong>
                        <button type="button" class="guest-btn" data-target="adult" data-action="plus">+</button>
                    </div>
                    <input type="hidden" name="AdultCount" id="adultCountInput" value="@reservationForm.AdultCount" />
                </div>

                <div class="guest-row">
                    <span>Çocuk</span>
                    <div class="guest-controls">
                        <button type="button" class="guest-btn" data-target="child" data-action="minus">-</button>
                        <strong id="childCount">@reservationForm.ChildCount</strong>
                        <button type="button" class="guest-btn" data-target="child" data-action="plus">+</button>
                    </div>
                    <input type="hidden" name="ChildCount" id="childCountInput" value="@reservationForm.ChildCount" />
                </div>
                </div>
                </div>

                <input type="hidden" name="RoomCount" id="roomCountInput" value="1" />
                <input type="hidden" name="RoomTypeId" id="roomTypeIdInput" value="@reservationForm.RoomTypeId" />
                <input type="hidden" name="CheckInDate" id="checkInDateInput" value="@checkInDefault" />
                <input type="hidden" name="CheckOutDate" id="checkOutDateInput" value="@checkOutDefault" />

                @{
                    var pmSel = reservationForm.PaymentMethod?.Trim() ?? "";
                    var selCashAtDoor = string.Equals(pmSel, PublicDoorPaymentMethods.CashAtDoor, StringComparison.OrdinalIgnoreCase)
                        || string.Equals(pmSel, "Kapıda Ödeme", StringComparison.OrdinalIgnoreCase);
                    var selCardAtDoor = string.Equals(pmSel, PublicDoorPaymentMethods.CardAtDoor, StringComparison.OrdinalIgnoreCase);
                    var paymentMethodChosen = selCashAtDoor || selCardAtDoor;
                    var guestCheckInDefault = Model.CheckInTime?.ToString(@"hh\:mm") ?? "14:00";
                    var guestCheckOutDefault = Model.CheckOutTime?.ToString(@"hh\:mm") ?? "12:00";
                    var hotelCheckOutStandard = guestCheckOutDefault;
                }
                <div class="booking-advanced-fields booking-visible-fields" id="bookingAdvancedFields"
                     data-hotel-check-in="@guestCheckInDefault"
                     data-hotel-check-out="@hotelCheckOutStandard">
                    <div class="booking-advanced-heading">
                        <strong>Ödeme planı</strong>
                        <span>Kapıda ödeme tercihinizi ve giriş-çıkış saatlerinizi seçin.</span>
                    </div>
                    <div class="booking-advanced-grid">
                        <label>
                            <span>Ödeme planı</span>
                            <select name="PaymentMethod" id="paymentMethodSelect" required>
                                @if (!paymentMethodChosen)
                                {
                                    <option value="" selected disabled>Ödeme yönteminizi seçin</option>
                                }
                                else
                                {
                                    <option value="" disabled>Ödeme yönteminizi seçin</option>
                                }
                                @if (selCashAtDoor)
                                {
                                    <option value="@PublicDoorPaymentMethods.CashAtDoor" selected>@PublicDoorPaymentMethods.CashAtDoor</option>
                                }
                                else
                                {
                                    <option value="@PublicDoorPaymentMethods.CashAtDoor">@PublicDoorPaymentMethods.CashAtDoor</option>
                                }
                                @if (selCardAtDoor)
                                {
                                    <option value="@PublicDoorPaymentMethods.CardAtDoor" selected>@PublicDoorPaymentMethods.CardAtDoor</option>
                                }
                                else
                                {
                                    <option value="@PublicDoorPaymentMethods.CardAtDoor">@PublicDoorPaymentMethods.CardAtDoor</option>
                                }
                            </select>
                        </label>
                        <div class="booking-advanced-times">
                            <p class="booking-advanced-times-note">
                                Otel konaklama saatleri: giriş <strong>@guestCheckInDefault</strong>, çıkış <strong>@guestCheckOutDefault</strong>. Tercihe göre fiyatlar değişebilir.
                            </p>
                            <label>
                                <span>Giriş saati</span>
                                <input type="time" name="CheckInTime" id="checkInTimeInput" value="@guestCheckInDefault" step="900" lang="tr-TR" />
                            </label>
                            <label>
                                <span>Çıkış saati</span>
                                <input type="time" name="CheckOutTime" id="checkOutTimeInput" value="@guestCheckOutDefault" step="900" lang="tr-TR" />
                            </label>
                        </div>
                    </div>
                    <p class="booking-advanced-tip">
                        Seçtiğiniz giriş ve çıkış saatlerine göre toplam fiyat güncellenebilir. Standart çıkış saatinden (@hotelCheckOutStandard) sonra ayrılırsanız ek günlük ücret uygulanabilir.
                    </p>
                </div>

                @await Html.PartialAsync("~/Views/Oteller/Partials/_ReservationCreateButton.cshtml")

                @if (TempData["PublicReservationSuccess"] is string successMessage)
                {
                    <div class="detail-inline-feedback success reservation-submit-feedback" data-reservation-success-redirect="/panel/user/rezervasyonlarim" role="status" aria-live="polite">
                        @successMessage
                    </div>
                }

                <div class="booking-trust-row" aria-label="Güven bilgileri">
                    <span><i class="fas fa-shield-halved" aria-hidden="true"></i> Güvenli • Hızlı onay</span>
                    <span><i class="fas fa-headset" aria-hidden="true"></i> 7/24 destek</span>
                    @if (Model.ShowBusinessLicense)
                    {
                        <span class="booking-trust-row__license"><i class="fas fa-shield-check" aria-hidden="true"></i> Kayıtlı işletme · @Model.TourismDocumentNo</span>
                    }
                </div>
              </form>

            <div class="booking-quote-notice" id="bookingQuoteNotice" hidden></div>
            <div class="price-breakdown" id="priceBreakdown">
                <div class="price-row price-row-tax"><span>KDV <small class="tax-rate-hint">%@Model.TaxDisplayVatPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</small></span><strong>₺@initialVat.ToString("N0")</strong></div>
                <div class="price-row price-row-tax"><span>Konaklama Vergisi <small class="tax-rate-hint">%@Model.TaxDisplayAccommodationPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</small></span><strong>₺@initialAccommodationTax.ToString("N0")</strong></div>
                <div class="price-row price-row-tax"><span>Vergi ve Harçlar</span><strong>₺@initialTax.ToString("N0")</strong></div>
                <div class="price-row total"><span>Toplam</span><strong>₺@initialTotal.ToString("N0")</strong></div>
            </div>
            <details class="nightly-breakdown-details" id="nightlyBreakdownDetails" hidden>
                <summary class="nightly-breakdown-summary">
                    <span class="nightly-breakdown-summary__lead">
                        <i class="fas fa-calendar-day" aria-hidden="true"></i>
                        <span class="nightly-breakdown-summary__copy">
                            <strong class="nightly-breakdown-summary__title">Gün gün fiyat</strong>
                            <small class="nightly-breakdown-summary__hint" id="nightlyBreakdownHint">Gece bazında döküm</small>
                        </span>
                    </span>
                    <span class="nightly-breakdown-summary__meta" id="nightlyBreakdownMeta" aria-hidden="true"></span>
                    <i class="fas fa-angle-down nightly-breakdown-summary__chev" aria-hidden="true"></i>
                </summary>
                <div class="nightly-breakdown-list" id="nightlyBreakdownList"></div>
            </details>
        </div>
    </aside>

    <div class="mobile-booking-bar od-mobile-bottom-dock od-sticky-cta mob-sticky-cta fe-world-safe-bottom" id="mobileBookingBar" role="region" aria-label="@SharedLocalizer["Booking.MobileSummary"].Value">
        <div class="mobile-booking-bar__row mobile-booking-bar__row--price">
            <div class="mobile-booking-price-stack">
                <div class="mobile-booking-room-row">
                    <span class="mobile-booking-room-name" id="mobileBookingRoomName">@selectedRoomSeed?.Name</span>
                    <span class="mobile-booking-loyalty" id="mobileBookingLoyalty" data-loyalty-hook="detail-mobile-bar" @(initialEarnPoints <= 0 ? "hidden" : null)>
                        <i class="fas fa-gift" aria-hidden="true"></i>
                        +@initialEarnPoints puan kazanın
                    </span>
                </div>
                <div class="mobile-booking-price-main">
                    <div class="mobile-booking-price-labels">
                        <span class="mobile-booking-label">@SharedLocalizer["Detail.Booking.Total"].Value</span>
                    </div>
                    <div class="mobile-booking-total-wrap">
                        <del class="mobile-booking-original" id="mobileBookingOriginal" @(initialHasDawn ? null : "hidden aria-hidden=\"true\"")>@(initialHasDawn ? $"₺{initialOriginalTotal:N0}" : "")</del>
                        <strong id="mobileBookingPrice" class="mobile-booking-total">@(initialTotal > 0m ? $"₺{initialTotal:N0}" : (Model.LowestRoomPrice > 0m ? $"₺{Model.GuestInclusiveNightlyFromStoredNet(Model.LowestRoomPrice):N0}" : "—"))</strong>
                        <span class="mobile-booking-dawn-pill" id="mobileBookingDawn" @(initialHasDawn ? null : "hidden")>@(initialHasDawn ? $"Şafak −%{initialDawnPercent} · ₺{initialDawnDiscount:N0}" : "")</span>
                    </div>
                </div>
            </div>
            <small class="mobile-booking-tax-note">@SharedLocalizer["Detail.Booking.TaxesNote"].Value</small>
        </div>
        <div class="mobile-booking-bar__row mobile-booking-bar__row--cta">
            <button type="button" class="mobile-booking-cta" id="openBookingSheetBtn">@SharedLocalizer["Detail.Booking.GoToReserve"].Value</button>
        </div>
    </div>

</section>

@{
    var publicDraftRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    long? publicDraftUserId = long.TryParse(publicDraftRaw, out var parsedPublicDraftUserId) ? parsedPublicDraftUserId : null;
    var publicDraftSessionKey = Context.Request.Cookies.TryGetValue(otelturizmnew.Services.ReservationDraftService.DraftCookieName, out var publicDraftCookieValue)
        ? publicDraftCookieValue
        : null;
    var suppressDraftBanner = ((ViewData["SuppressGlobalDraftBanner"] as bool?) ?? false);
    otelturizmnew.Models.Reservations.ReservationDraftSummaryViewModel? localActiveDraft = null;
    if (!suppressDraftBanner)
    {
        try
        {
            // View render sırasında bu sorgu gecikirse sayfa tamamen düşmesin.
            localActiveDraft = await ReservationDraftService.GetActiveDraftAsync(publicDraftUserId, publicDraftSessionKey, Context.RequestAborted);
        }
        catch
        {
            localActiveDraft = null;
        }
    }
}

@if (localActiveDraft is not null && !suppressDraftBanner)
{
    <aside class="detail-draft-toast" aria-label="Tamamlanmayan rezervasyon bildirimi">
        <div class="detail-draft-toast__icon" aria-hidden="true">
            <i class="fas fa-hourglass-half"></i>
        </div>
        <div class="detail-draft-toast__copy">
            <strong>Tamamlanmayan rezervasyon</strong>
            <span>@localActiveDraft.HotelName · @localActiveDraft.CheckInText - @localActiveDraft.CheckOutText</span>
        </div>
        <div class="detail-draft-toast__actions">
            <a class="detail-draft-toast__btn is-primary" href="@localActiveDraft.ResumeUrl">Devam Et</a>
            <form method="post" action="/rezervasyon-taslagi/iptal" class="detail-draft-toast__form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="draftId" value="@localActiveDraft.DraftId" />
                <input type="hidden" name="returnUrl" value="/oteller/@Model.Slug" />
                <button type="submit" class="detail-draft-toast__btn is-ghost">İptal Et</button>
            </form>
        </div>
    </aside>
}

