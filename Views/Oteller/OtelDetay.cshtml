        <div class="detail-weather-cards popup-weather-cards">
            @foreach (var day in Model.Weather.Days)
            {
                var dayTone = "is-cloudy";
                var dayConditionSafe = FixMojibake(day.ConditionText);
                if (dayConditionSafe.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
                    || dayConditionSafe.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
                    || dayConditionSafe.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
                    || dayConditionSafe.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
                {
                    dayTone = "is-rainy";
                }
                else if (dayConditionSafe.Contains("Açık", StringComparison.OrdinalIgnoreCase) || dayConditionSafe.Contains("Güneş", StringComparison.OrdinalIgnoreCase))
                {
                    dayTone = "is-sunny";
                }
                else if (dayConditionSafe.Contains("Kar", StringComparison.OrdinalIgnoreCase))
                {
                    dayTone = "is-snowy";
                }

                <article class="detail-weather-card @dayTone">
                    <span class="detail-weather-period">@FixMojibake(day.PeriodLabel)</span>
                    <div class="detail-weather-main">
