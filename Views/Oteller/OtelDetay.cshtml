                                <option value="Karma — Kart, Havale ve Kapıda" selected="@(string.Equals(reservationForm.PaymentMethod, "Karma — Kart, Havale ve Kapıda", StringComparison.OrdinalIgnoreCase))">Karma — kart + havale + kapıda</option>
