    <div class="review-insight-dialog" role="dialog" aria-modal="true" aria-labelledby="reviewInsightTitle">
        <div class="review-insight-head">
            <div>
                <strong id="reviewInsightTitle">Yorum içgörüleri</strong>
                <p id="reviewInsightMeta">Kategoriye göre filtrelenmiş geri bildirimler</p>
