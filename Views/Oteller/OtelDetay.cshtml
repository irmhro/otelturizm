            document.querySelectorAll('[data-scroll-reviews]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const target = document.getElementById('reviewsSection');
                    scrollToElementWithOffset(target, 86);
                });
            });

            // Kampanya rozetleri (2 slot): 2 sn'de bir döndür.
            try {
                const campaignJsonEl = document.getElementById('hotelCampaignPayloadJson');
                const campaignItems = campaignJsonEl ? JSON.parse(campaignJsonEl.textContent || '[]') : [];
                const slots = Array.from(document.querySelectorAll('[data-campaign-slot]'));
                if (Array.isArray(campaignItems) && campaignItems.length > 0 && slots.length > 0) {
                    let index = 0;
                    const applySlots = function () {
                        for (let i = 0; i < slots.length; i++) {
                            const el = slots[i];
                            const item = campaignItems[(index + i) % campaignItems.length];
                            const name = (item?.name || '').toString().trim();
                            let slug = (item?.slug || '').toString().trim();
                            if (!name) {
                                el.hidden = true;
                                continue;
                            }
                            // sayfa_url gelirse son segmenti al
                            if (slug.includes('/')) {
                                const parts = slug.split('/').filter(Boolean);
                                slug = parts.length ? parts[parts.length - 1] : slug;
                            }
                            el.hidden = false;
                            const span = el.querySelector('span');
                            if (span) span.textContent = name;
                            el.setAttribute('href', '/kampanyalar/' + encodeURIComponent(slug || ''));
                        }
                        index = (index + 2) % campaignItems.length;
                    };
                    applySlots();
                    window.setInterval(applySlots, 2000);
                }
            } catch (_) { /* no-op */ }

            // Otel videosu modal
            const openHotelVideoBtn = document.querySelector('[data-open-hotel-video]');
            const hotelVideoModal = document.getElementById('hotelVideoModal');
            const hotelVideoBackdrop = document.getElementById('hotelVideoBackdrop');
            const hotelVideoClose = document.querySelector('[data-close-hotel-video]');
            const hotelVideoFrame = document.getElementById('hotelVideoFrame');
            const hotelVideoSeed = '@(Model.VideoUrl ?? string.Empty)'.trim();

            function toYoutubeEmbedUrl(url) {
                const raw = (url || '').toString().trim();
                if (!raw) return '';
                try {
                    const u = new URL(raw, window.location.origin);
                    const host = (u.hostname || '').toLowerCase();
                    if (host.includes('youtu.be')) {
                        const id = u.pathname.split('/').filter(Boolean)[0] || '';
                        return id ? ('https://www.youtube-nocookie.com/embed/' + id) : raw;
                    }
                    if (host.includes('youtube.com')) {
                        const v = u.searchParams.get('v') || '';
                        if (v) return 'https://www.youtube-nocookie.com/embed/' + v;
                        const parts = u.pathname.split('/').filter(Boolean);
                        const idx = parts.indexOf('embed');
                        const id = idx >= 0 ? (parts[idx + 1] || '') : (parts[parts.length - 1] || '');
                        return id ? ('https://www.youtube-nocookie.com/embed/' + id) : raw;
                    }
                } catch (_) { /* ignore */ }
                return raw;
            }

            function openHotelVideo() {
                if (!hotelVideoModal || !hotelVideoBackdrop) return;
                hotelVideoBackdrop.hidden = false;
                hotelVideoBackdrop.classList.add('is-open');
                hotelVideoModal.hidden = false;
                hotelVideoModal.classList.add('is-open');
                hotelVideoModal.setAttribute('aria-hidden', 'false');
                if (hotelVideoFrame instanceof HTMLIFrameElement) {
                    const src = toYoutubeEmbedUrl(hotelVideoSeed);
                    hotelVideoFrame.src = src ? (src + (src.includes('?') ? '&' : '?') + 'autoplay=1&rel=0') : '';
                }
            }

            function closeHotelVideo() {
                if (!hotelVideoModal || !hotelVideoBackdrop) return;
                hotelVideoModal.classList.remove('is-open');
                hotelVideoModal.hidden = true;
                hotelVideoModal.setAttribute('aria-hidden', 'true');
                hotelVideoBackdrop.classList.remove('is-open');
                hotelVideoBackdrop.hidden = true;
                if (hotelVideoFrame instanceof HTMLIFrameElement) {
                    hotelVideoFrame.src = '';
                }
            }

            openHotelVideoBtn?.addEventListener('click', function () {
                openHotelVideo();
            });
            hotelVideoClose?.addEventListener('click', function () {
                closeHotelVideo();
            });
            hotelVideoBackdrop?.addEventListener('click', function () {
                closeHotelVideo();
            });

            // "Sil" butonunun her zaman hızlı çalışması için event delegation (mobil tıklama edge-case fix)
            roomItemsRoot?.addEventListener('click', function (event) {
                const target = event.target instanceof HTMLElement ? event.target : null;
                const removeBtn = target?.closest?.('[data-remove-room]');
                if (!removeBtn) return;
                const item = removeBtn.closest?.('[data-room-item]');
                if (!item) return;
                event.preventDefault();
                item.remove();
                renumberRoomItems();
                syncRoomsJsonAndHiddenFields();
                ensureGuestCapacity(false);
                refreshPriceQuote();
            });

            document.querySelectorAll('[data-room-detail-open]').forEach(function (button) {
                button.addEventListener('click', function () {
                    openRoomDetailModal(button);
                });
            });

            roomDetailModalGalleryOpen?.addEventListener('click', function () {
                if (activeRoomDetailGalleryItems.length > 0) {
                    openSlayt(activeRoomDetailGalleryItems, activeRoomDetailName, 0);
                }
            });

            roomDetailModalSelectBtn?.addEventListener('click', function () {
                if (!activeRoomDetailRoomId) {
                    return;
                }
                const targetButton = document.querySelector('.select-room-btn[data-room-id="' + activeRoomDetailRoomId + '"]');
                if (targetButton instanceof HTMLElement) {
                    closeModal(roomDetailModal);
                    targetButton.click();
                }
            });

            activeDraftResumeLink?.addEventListener('click', function (event) {
                event.preventDefault();
                resumeDraftFlow();
            });

            bookingForm?.addEventListener('submit', function (event) {
                syncRoomsJsonAndHiddenFields();
                const roomNodes = getRoomItemNodes();
                const items = roomNodes.map(getRoomItemData);
                const hasMissingRequiredInfo = roomNodes.length === 0
                    || items.some(function (x) {
                        return !x.roomTypeId
                            || !x.checkIn
                            || !x.checkOut
                            || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                    })
                    || adults < 1;
                if (hasMissingRequiredInfo) {
                    event.preventDefault();
                    showInfoModal('Rezervasyon oncesi tarih, misafir ve oda bilgilerini kontrol edip tamamlayiniz.', false);
                    return;
                }

                if (!ensureGuestCapacity(true)) {
                    event.preventDefault();
                    return;
                }

                if (!isPaymentMethodChosen()) {
                    event.preventDefault();
                    bookingAdvancedFields?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                    showInfoModal('Lütfen ödeme planı seçiniz.', false, 'warning');
                    return;
                }

                if (profileCompletionRequired) {
                    event.preventDefault();
                    shouldResumeReservationAfterProfile = true;
                    openProfileCompletionModal('Rezervasyon oluşturabilmek için telefon, doğum tarihi, cinsiyet, il, ilçe ve mahalle bilgilerinizi tamamlayın.');
                    return;
                }

                if (!reservationSubmitConfirmed) {
                    event.preventDefault();
                    buildReservationConfirmSummary(items);
                    openModal(reservationConfirmModal);
                    return;
                }
            });

            reservationConfirmSubmitBtn?.addEventListener('click', function () {
                if (!bookingForm) {
                    return;
                }

                reservationSubmitConfirmed = true;
                syncRoomsJsonAndHiddenFields();
                closeModal(reservationConfirmModal);
                HTMLFormElement.prototype.submit.call(bookingForm);
            });

            profileCompletionForm?.addEventListener('submit', async function (event) {
                event.preventDefault();
                profileFeedback.hidden = true;
                const formData = new FormData(profileCompletionForm);
                const validationMessage = validateProfileCompletionData(formData);
                if (validationMessage) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = validationMessage;
                    return;
                }

                try {
                    const response = await fetch(profileCompletionForm.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Bilgiler kaydedilemedi.');
                    }

                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback success';
                    profileFeedback.textContent = payload.message;
                    window.setTimeout(function () {
                        markProfileCompletionResolved();
                        closeModal(profileModal);
                        if (shouldResumeReservationAfterProfile) {
                            shouldResumeReservationAfterProfile = false;
                            continueReservationAttemptAfterProfile();
                            return;
                        }
                        resumeDraftFlow();
                    }, 700);
                } catch (error) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = error.message || 'Bilgiler kaydedilemedi.';
                }
            });

            startConversationBtn?.addEventListener('click', async function () {
                const authenticated = startConversationBtn.dataset.authenticated === 'true';
                const canStart = startConversationBtn.dataset.canStart === 'true';
                const infoMessage = startConversationBtn.dataset.infoMessage || 'Görüşme başlatılamıyor.';

                if (!authenticated) {
                    showInfoModal('Otel ile görüşme başlatmak için önce kullanıcı hesabınızla giriş yapmalısınız.', true);
                    return;
                }

                if (!canStart) {
                    showInfoModal(infoMessage, false);
                    return;
                }

                try {
                    const token = bookingForm?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch('/oteller/@Model.Slug/gorusme-baslat', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'X-CSRF-TOKEN': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Görüşme başlatılamadı.');
                    }

                    window.location.href = payload.redirectUrl;
                } catch (error) {
                    showInfoModal(error.message || 'Görüşme başlatılamadı.', false);
                }
            });

            const locationQuery = new URLSearchParams(window.location.search);
            const shouldOpenProfileFromQuery = locationQuery.get('openProfile') === '1';
            if (window.matchMedia('(max-width: 860px)').matches) {
                bookingAdvancedFields?.removeAttribute('open');
            }

            if (shouldOpenProfileFromQuery && @((Model.ActiveDraft is not null && Model.IsLoggedInUser) ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft?.RequiresProfileCompletion == true && Model.IsLoggedInUser ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft is not null && Model.ActiveDraft.RequiresProfileCompletion == false ? "true" : "false")) {
                resumeDraftFlow();
            }

            if (shouldPromptActiveDraft) {
                window.setTimeout(function () {
                    openActiveDraftPrompt();
                }, 80);
            }

            // init first room row (single-room compatible)
            if (getRoomItemNodes().length === 0) {
                addRoomItem({
                    roomTypeId: parseInt(roomTypeIdInput?.value || '@reservationForm.RoomTypeId', 10) || 0,
                    checkIn: checkInInput?.value || '@checkInDefault',
                    checkOut: checkOutInput?.value || '@checkOutDefault'
                });
            }
            renumberRoomItems();
            setActiveRoomIndex(0);
            syncRoomsJsonAndHiddenFields();
            syncGuestInputs();
            ensureGuestCapacity(false);
            syncPaymentMethodState();
            refreshPriceQuote();
            initReviewReadMore();
            initRoomFeaturePanels();
            paymentMethodSelect?.addEventListener('change', syncPaymentMethodState);

            // Oda kart görselleri scroll'a gelince "geç yükleniyor" hissi vermesin diye
            // ilk etapta oda kapak görsellerini prefetch edelim (tarayıcı cache'e alsın).
            (function prefetchRoomCoverImages() {
                const covers = Array.from(document.querySelectorAll('.room-card-cover img'))
                    .map(function (img) { return img instanceof HTMLImageElement ? (img.currentSrc || img.src || '').trim() : ''; })
                    .filter(Boolean);
                if (!covers.length) return;
                const limit = Math.min(14, covers.length);
                for (let i = 0; i < limit; i++) {
                    const src = covers[i];
                    const pre = new Image();
                    pre.decoding = 'async';
                    pre.src = src;
                }
            })();

            const reviewSortSelect = document.getElementById('reviewSortSelect');
            reviewSortSelect?.addEventListener('change', function () {
                const url = new URL(window.location.href);
                url.searchParams.set('reviewSort', reviewSortSelect.value || 'new');
                url.searchParams.set('reviewPage', '1');
                const reviewDynamic = document.getElementById('reviewSectionDynamic');
                if (!reviewDynamic) {
                    window.location.href = url.toString();
                    return;
                }

                fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const next = doc.getElementById('reviewSectionDynamic');
                        if (!next) {
                            window.location.href = url.toString();
                            return;
                        }
                        reviewDynamic.innerHTML = next.innerHTML;
                        initReviewReadMore();
                    })
                    .catch(function () {
                        window.location.href = url.toString();
                    });
            });
        })();
    </script>
    <script src="~/assets/js/otel-detay-reservation.js" asp-append-version="true"></script>
    <script nonce="@nonce">
        (function () {
            var hid = @Model.Id;
            var elCount = document.getElementById('livePresenceCount');
            var line = document.getElementById('livePresenceLine');
            var tabId = sessionStorage.getItem('otelPresenceTab');
            if (!tabId) {
                tabId = (window.crypto && window.crypto.randomUUID) ? window.crypto.randomUUID() : ('t' + Math.random().toString(36).slice(2));
                sessionStorage.setItem('otelPresenceTab', tabId);
            }
            function beat() {
                fetch('/api/hotel-presence/beat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ hotelId: hid, tabId: tabId })
                }).then(function (r) { return r.ok ? r.json() : null; }).then(function (j) {
                    if (!j || !j.ok) return;
                    var active = Number(j.active || 0);
                    if (elCount) elCount.textContent = String(active);
                    if (line) line.hidden = !(active > 0);
                }).catch(function () { });
            }
            beat();
            setInterval(beat, 45000);
        })();
    </script>
    <script src="~/assets/js/otel-detay.js" asp-append-version="true"></script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}
