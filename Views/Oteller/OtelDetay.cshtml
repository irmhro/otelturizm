                </button>
            </div>
            <div class="rating-summary">
                <div class="rating-big">
                    <span class="rating-number">@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "0.0")</span>
                    <span class="rating-max">/10</span>
                </div>
                <div class="rating-text">
                    <strong>@Model.RatingText</strong><br />
                    <span>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} yorum" : "Henuz yorum yok")</span>
                </div>
            </div>
        </div>
    </div>
</section>

@if (TempData["PublicReservationSuccess"] is string successMessage)
{
    <div class="detail-inline-feedback success">@successMessage</div>
}

@if (TempData["PublicReservationInfo"] is string infoMessage)
{
    <div class="detail-inline-feedback info">@infoMessage</div>
}

@{
    string FixMojibake(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        // Common UTF-8-as-ANSI mojibake fixes for Turkish content.
        return value
            .Replace("Ã‡", "Ç", StringComparison.Ordinal)
            .Replace("Ã§", "ç", StringComparison.Ordinal)
            .Replace("Ä±", "ı", StringComparison.Ordinal)
            .Replace("Ä°", "İ", StringComparison.Ordinal)
            .Replace("Ã–", "Ö", StringComparison.Ordinal)
            .Replace("Ã¶", "ö", StringComparison.Ordinal)
            .Replace("Ãœ", "Ü", StringComparison.Ordinal)
            .Replace("Ã¼", "ü", StringComparison.Ordinal)
            .Replace("Åž", "Ş", StringComparison.Ordinal)
            .Replace("ÅŸ", "ş", StringComparison.Ordinal)
            .Replace("ÄŸ", "ğ", StringComparison.Ordinal)
            .Replace("Äž", "Ğ", StringComparison.Ordinal)
            .Replace("Â", "", StringComparison.Ordinal);
    }

    string MaskName(string? fullName)
    {
        var name = (fullName ?? "Misafir").Trim();
        if (string.IsNullOrWhiteSpace(name) || string.Equals(name, "Misafir", StringComparison.OrdinalIgnoreCase))
        {
            return "Misafir";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0];
        }

        var firstName = parts[0];
        var lastName = parts[^1];
        var lastPrefix = lastName.Length <= 3 ? lastName : lastName.Substring(0, 3);
        return $"{firstName} {lastPrefix}***";
    }

    var reviewSort = (Context.Request.Query["reviewSort"].ToString() ?? "new").Trim().ToLowerInvariant();
    var reviewPageRaw = Context.Request.Query["reviewPage"].ToString();
    var reviewPage = int.TryParse(reviewPageRaw, out var parsedReviewPage) ? Math.Max(1, parsedReviewPage) : 1;
    const int reviewPageSize = 7;

    var sortedReviews = (Model.Reviews ?? new List<otelturizmnew.Models.Oteller.HotelReviewViewModel>()).ToList();
    sortedReviews = reviewSort switch
    {
        "old" => sortedReviews.OrderBy(r => r.DateText).ToList(),
        "best" => sortedReviews.OrderByDescending(r => r.Score).ToList(),
        "worst" => sortedReviews.OrderBy(r => r.Score).ToList(),
        _ => sortedReviews.ToList()
    };
    if (reviewSort == "new")
    {
        sortedReviews = sortedReviews.ToList();
    }

    var totalReviewCount = sortedReviews.Count;
    var totalReviewPages = (int)Math.Ceiling(totalReviewCount / (double)reviewPageSize);
    if (totalReviewPages <= 0) totalReviewPages = 1;
    if (reviewPage > totalReviewPages) reviewPage = totalReviewPages;
    var pagedReviews = sortedReviews.Skip((reviewPage - 1) * reviewPageSize).Take(reviewPageSize).ToList();
}

<section class="detail-grid">
    <div class="detail-content">
        <article class="content-card featured-amenities-card">
            <div class="amenities-grid amenities-grid-lux">
                @foreach (var item in featuredAmenities)
                {
                    <div class="amenity-item amenity-item-lux">
                        <i class="fas @item.IconClass"></i>
                        <span class="amenity-copy">
                            <strong>@item.Name</strong>
                            <small>@GetAmenitySubtext(item.Name)</small>
                        </span>
                    </div>
                }
                @if (hiddenAmenities.Count > 0)
                {
                    <button type="button" class="amenity-item amenity-item-lux amenities-action-item" id="openAmenitiesModal">
                        <i class="fas fa-plus"></i>
                        <span class="amenity-copy">
                            <strong>Diger ozellikler</strong>
                            <small>@hiddenAmenities.Count ozellik daha</small>
                        </span>
                    </button>
                }
            </div>
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Tesis Hakkinda</h2>
                <p>@longDescription</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.LocationDescription))
            {
                <p class="detail-long-copy">@Model.LocationDescription</p>
            }
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Oda Tipleri ve Fiyatlar</h2>
                <p>Bu alandaki Odalardan rezervasyon Yapabilirsiniz</p>
            </div>

            <div class="room-list">
                @foreach (var room in Model.Rooms)
                {
                    var roomGallery = room.GalleryImages.Count > 0
                        ? room.GalleryImages
                        : (!string.IsNullOrWhiteSpace(room.ImageUrl) ? new List<string> { room.ImageUrl } : new List<string>());
                    var roomGalleryJson = System.Text.Json.JsonSerializer.Serialize(roomGallery);
                    var roomCoverImage = !string.IsNullOrWhiteSpace(room.ImageUrl)
                        ? room.ImageUrl
                        : roomGallery.FirstOrDefault();

                    <div class="room-card">
                        <div class="room-card-main">
                            <div class="room-card-media">
                                @if (!string.IsNullOrWhiteSpace(roomCoverImage))
                                {
                                    <div class="room-card-cover">
                                        <button type="button"
                                                class="room-gallery-trigger"
                                                data-room-name="@room.Name"
                                                data-room-gallery='@roomGalleryJson'
                                                data-room-gallery-start="0"
                                                aria-label="@room.Name galerisi">
                                            <img src="@roomCoverImage" alt="@room.Name" />
                                            @if (roomGallery.Count > 1)
                                            {
                                                <span class="room-gallery-count">
                                                    <i class="fas fa-images"></i>
                                                    @roomGallery.Count gorsel
                                                </span>
                                            }
                                        </button>
                                    </div>
                                    @if (roomGallery.Count > 1)
                                    {
                                        <div class="room-thumb-strip" aria-label="@room.Name gorselleri">
                                            @for (var imageIndex = 0; imageIndex < roomGallery.Count; imageIndex++)
                                            {
                                                <button type="button"
                                                        class="room-gallery-trigger room-thumb-item @(imageIndex == 0 ? "active" : string.Empty)"
                                                        data-room-name="@room.Name"
                                                        data-room-gallery='@roomGalleryJson'
                                                        data-room-gallery-start="@imageIndex"
                                                        aria-label="@room.Name gorsel @(imageIndex + 1)">
                                                    <img src="@roomGallery[imageIndex]" alt="@room.Name gorsel @(imageIndex + 1)" />
                                                </button>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="room-card-media-placeholder"><i class="fas fa-bed"></i></div>
                                }
                            </div>
                            <div class="room-card-copy">
                                <h3>@room.Name</h3>
                                <p>@room.Specs</p>
                                @{
                                    var roomFeatureSeed = room.Features ?? new List<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>();
                                    var roomTopFeatures = roomFeatureSeed.Take(3).ToList();
                                    if (roomTopFeatures.Count < 3)
                                    {
                                        // Oda özellikleri azsa, otelin öne çıkan olanaklarından tamamla (tekrarları çıkar).
                                        var existing = new HashSet<string>(roomTopFeatures.Select(x => x.Name ?? string.Empty), StringComparer.OrdinalIgnoreCase);
                                        foreach (var amenity in Model.Amenities.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
                                        {
                                            if (roomTopFeatures.Count >= 3) break;
                                            if (!existing.Add(amenity.Name)) continue;
                                            roomTopFeatures.Add(new otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel
                                            {
                                                Name = amenity.Name,
                                                IconClass = string.IsNullOrWhiteSpace(amenity.IconClass) ? "fa-circle-check" : amenity.IconClass
                                            });
                                        }
                                    }

                                    var roomAllFeatures = (room.Features ?? Enumerable.Empty<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>())
                                        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                        .Select(x => new
                                        {
                                            Name = x.Name,
                                            IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                        })
                                        .ToList();

                                    if (roomAllFeatures.Count == 0)
                                    {
                                        roomAllFeatures = roomTopFeatures
                                            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                            .Select(x => new
                                            {
                                                Name = x.Name,
                                                IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                            })
                                            .ToList();
                                    }

                                    var roomDetailsJson = System.Text.Json.JsonSerializer.Serialize(roomAllFeatures);
                                }
                                @if (roomTopFeatures.Count > 0)
                                {
                                    <div class="room-feature-preview">
                                        @foreach (var feature in roomTopFeatures)
                                        {
                                            <span class="room-feature-chip"><i class="fas @feature.IconClass"></i> @feature.Name</span>
                                        }
                                    </div>
                                }
                                @if ((room.Features?.Count ?? 0) > 5)
                                {
                                    <div class="room-feature-more-inline" data-room-feature-wrap>
                                        <button type="button"
                                                class="room-feature-more-btn"
                                                data-room-feature-toggle
                                                aria-expanded="false">
                                            Diğer özellikler
                                            <i class="fas fa-angle-down" aria-hidden="true"></i>
                                        </button>
                                        <div class="room-feature-panel" data-room-feature-panel hidden>
                                            <div class="room-feature-panel-grid">
                                                @foreach (var feature in (room.Features ?? Enumerable.Empty<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>()))
                                                {
                                                    <span class="room-feature-chip room-feature-chip-full"><i class="fas @feature.IconClass"></i> @feature.Name</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                                <span class="cancellation-badge"><i class="fas fa-check-circle"></i> @room.CancellationText</span>
                            </div>
                        </div>
                        <div class="room-price-box">
                            <div class="room-price-actions">
                                <button type="button"
                                        class="room-detail-btn"
                                        data-room-detail-open
                                        data-room-name="@room.Name"
                                        data-room-specs="@room.Specs"
                                        data-room-cancellation="@room.CancellationText"
                                        data-room-feature-count="@roomAllFeatures.Count"
                                        data-room-gallery-count="@roomGallery.Count"
                                        data-room-details='@roomDetailsJson'>
                                    Oda Detay
                                </button>
                                @if (room.Price > 0m)
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="@room.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                                        Odanı Seç
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="0"
                                            disabled>
                                        Fiyat Yok
                                    </button>
                                }
                            </div>
                            <div class="room-price-value">
                                <strong>@(room.Price > 0m ? $"₺{Model.GuestInclusiveNightlyFromStoredNet(room.Price):N0}" : "Fiyat Yok")</strong>
                                @if (room.Price > 0m)
                                {
                                    <span class="room-price-inclusive-label" title="Tüm vergiler dahil fiyat">Vergiler dahil</span>
                                }
                                else
                                {
                                    <span class="room-price-unavailable">Bu oda icin aktif fiyat bulunamadi</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="room-gallery-modal" id="roomGalleryModal" hidden>
                <div class="room-gallery-backdrop" data-room-gallery-close></div>
                <div class="room-gallery-dialog" role="dialog" aria-modal="true" aria-labelledby="roomGalleryTitle">
                    <button type="button" class="room-gallery-close" data-room-gallery-close aria-label="Galeri kapat">
                        <i class="fas fa-times"></i>
                    </button>
                    <div class="room-gallery-stage">
                        <button type="button" class="room-gallery-nav prev" id="roomGalleryPrev" aria-label="Onceki gorsel">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <figure class="room-gallery-figure">
                            <img src="" alt="" id="roomGalleryMainImage" />
                            <figcaption id="roomGalleryTitle"></figcaption>
                        </figure>
                        <button type="button" class="room-gallery-nav next" id="roomGalleryNext" aria-label="Sonraki gorsel">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                    <div class="room-gallery-thumbs" id="roomGalleryThumbs"></div>
                </div>
            </div>

            <section class="detail-modal room-detail-modal" id="roomDetailModal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="roomDetailModalTitle">
                <div class="detail-modal-head room-detail-modal-head">
                    <div>
                        <span class="detail-modal-kicker">Oda Detayı</span>
                        <h3 id="roomDetailModalTitle">Oda özellikleri</h3>
                    </div>
                    <button type="button" class="detail-modal-close" data-close-modal="roomDetailModal" aria-label="Kapat">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="room-detail-modal-body">
                    <div class="room-detail-modal-summary">
                        <div class="room-detail-modal-copy">
                            <strong id="roomDetailModalRoomName">Seçilen oda</strong>
                            <p id="roomDetailModalSpecs">Oda detayları burada gösterilir.</p>
                        </div>
                        <div class="room-detail-modal-meta">
                            <span class="room-detail-modal-badge" id="roomDetailModalGalleryBadge">0 görsel</span>
                            <span class="room-detail-modal-badge" id="roomDetailModalFeatureBadge">0 özellik</span>
                        </div>
                    </div>
                    <div class="room-detail-modal-note" id="roomDetailModalCancellation">Koşullar rezervasyon adımında yeniden doğrulanır.</div>
                    <div class="room-detail-modal-grid" id="roomDetailModalGrid"></div>
                </div>
            </section>
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Misafir Değerlendirmeleri</h2>
                <p>Yorumlar ve puan ortalamasi dogrudan veritabanindan alinmaktadir.</p>
            </div>

            <div class="review-summary">
                <div class="review-score">
                    <strong>@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "0.0")</strong>
                    <span>@Model.RatingText</span>
                    <small>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} yorum" : "Henuz yorum yok")</small>
                </div>
                <div class="review-bars">
                    <div><span>Genel</span><div class="bar"><span style="width:@(overallBarWidth)%"></span></div><strong>@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "-")</strong></div>
                    <div><span>Oda</span><div class="bar"><span style="width:@(roomBarWidth)%"></span></div><strong>@(roomScore > 0 ? roomScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Konum</span><div class="bar"><span style="width:@(locationBarWidth)%"></span></div><strong>@(locScore > 0 ? locScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Fiyat</span><div class="bar"><span style="width:@(valueBarWidth)%"></span></div><strong>@(valScore > 0 ? valScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Personel</span><div class="bar"><span style="width:@(staffBarWidth)%"></span></div><strong>@(staffScore > 0 ? staffScore.ToString("0.0") : "-")</strong></div>
                </div>
            </div>

            @if ((Model.Reviews?.Count ?? 0) == 0)
            {
                <div class="review-card">
                    <p>Bu tesis icin onayli misafir yorumu bulunmuyor. Ilk yorumu yapan kullanıcı siz olabilirsiniz.</p>
                </div>
            }
            else
            {
                <div class="review-toolbar">
                    <div class="review-toolbar-left">
                        <strong>Yorumlar</strong>
                        <span class="review-toolbar-count">@totalReviewCount</span>
                    </div>
                    <div class="review-toolbar-right">
                        <label class="review-sort">
                            <span>Sırala</span>
                            <select id="reviewSortSelect">
                                <option value="new" selected="@(reviewSort == "new")">En yeni</option>
                                <option value="old" selected="@(reviewSort == "old")">En eski</option>
                                <option value="best" selected="@(reviewSort == "best")">En iyi</option>
                                <option value="worst" selected="@(reviewSort == "worst")">En kötü</option>
                            </select>
                        </label>
                    </div>
                </div>

                <div id="reviewSectionDynamic">
                    <div class="review-list">
                        @foreach (var review in pagedReviews)
                        {
                            <article class="review-card">
                                <div class="review-meta">
                                    <div>
                                        <h4>@MaskName(review.Name)</h4>
                                        <p>@review.DateText</p>
                                    </div>
                                    <span class="review-chip">@review.Score.ToString("0.0")</span>
                                </div>
                                <div class="review-body" data-review-card>
                                    <p class="review-text" data-review-text>@FixMojibake(review.Text)</p>
                                    <button type="button" class="review-more" data-review-more hidden>Devamını oku</button>
                                    <span data-review-fulltext hidden>@FixMojibake(review.Text)</span>
                                </div>
                            </article>
                        }
                    </div>

                    @if (totalReviewPages > 1)
                    {
                        <nav class="review-pager" aria-label="Yorum sayfalama">
                            @{
                                string BuildReviewUrl(int targetPage)
                                {
                                    var query = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                                    foreach (var key in Context.Request.Query.Keys)
                                    {
                                        query[key] = Context.Request.Query[key].ToString();
                                    }
                                    query["reviewPage"] = targetPage.ToString(System.Globalization.CultureInfo.InvariantCulture);
                                    query["reviewSort"] = reviewSort;
                                    var qs = string.Join("&", query.Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value ?? string.Empty)}"));
                                    return Context.Request.Path + (string.IsNullOrWhiteSpace(qs) ? string.Empty : "?" + qs);
                                }
                            }
                            <a class="review-page-btn @(reviewPage <= 1 ? "disabled" : string.Empty)"
                               href="@(reviewPage <= 1 ? "#" : BuildReviewUrl(reviewPage - 1))"
                               aria-disabled="@(reviewPage <= 1 ? "true" : "false")">Önceki</a>
                            <span class="review-page-indicator">@reviewPage / @totalReviewPages</span>
                            <a class="review-page-btn @(reviewPage >= totalReviewPages ? "disabled" : string.Empty)"
                               href="@(reviewPage >= totalReviewPages ? "#" : BuildReviewUrl(reviewPage + 1))"
                               aria-disabled="@(reviewPage >= totalReviewPages ? "true" : "false")">Sonraki</a>
                        </nav>
                    }
                </div>
            }
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Konum</h2>
                <p>@locationText</p>
            </div>
            <div class="map-card">
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <iframe
                        title="Otel Konum"
                        src="https://www.openstreetmap.org/export/embed.html?layer=mapnik&marker=@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)%2C@Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        loading="lazy"></iframe>
                }
                else
                {
                    <div class="map-fallback">
                        <strong>Koordinat bilgisi bekleniyor</strong>
                        <span>@Model.Address</span>
                    </div>
                }
            </div>
        </article>

    </div>

    <aside class="booking-sidebar">
        <div class="booking-card">
            <div class="booking-price-head">
                <div class="booking-price-row">
                    <div class="booking-price-main">
                        <strong id="bookingPrice">@(initialInclusiveNightly > 0m ? $"₺{initialInclusiveNightly:N0}" : (Model.LowestRoomPrice > 0m ? $"₺{Model.GuestInclusiveNightlyFromStoredNet(Model.LowestRoomPrice):N0}" : "Fiyat Yok"))</strong>
                        <span class="booking-price-unit"></span>
                    </div>
                </div>
                <p class="booking-price-inclusive-hint" id="bookingPriceHint" title="Tüm vergiler dahil">Vergiler dahil</p>
            </div>

            <form class="booking-form" id="bookingForm" method="post" action="/oteller/@Model.Slug/rezervasyon" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="HotelId" value="@Model.Id" />
                <input type="hidden" id="profileCompletionRequired" value="@(Model.ProfilePrompt.IsProfileIncomplete && Model.IsLoggedInUser ? "true" : "false")" />
                <input type="hidden" name="RoomsJson" id="roomsJsonInput" value="" />

                <div class="multi-room" id="multiRoomRoot">
                    <div class="multi-room-head">
                        <span class="multi-room-title">Oda seçimi</span>
                        <button type="button" class="multi-room-add" id="addRoomBtn">
                            <i class="fas fa-plus"></i> Oda ekle
                        </button>
                    </div>

                    <div class="multi-room-list" id="roomItems"></div>

                    <template id="roomItemTemplate">
                        <section class="multi-room-item" data-room-item>
                            <div class="multi-room-item-head">
                                <strong class="multi-room-item-title" data-room-title>Oda</strong>
                                <button type="button" class="multi-room-remove" data-remove-room hidden>Sil</button>
                            </div>
                            <div class="multi-room-item-grid">
                                <label>
                                    <span>Giriş Tarihi</span>
                                    <input type="date" data-field="checkIn" min="@todayDate" />
                                </label>
                                <label>
                                    <span>Çıkış Tarihi</span>
                                    <input type="date" data-field="checkOut" min="@todayDate" />
                                </label>
                                <label class="multi-room-item-span">
                                    <span>Oda Tipi</span>
                                    <select data-field="roomType">
                                        @foreach (var room in reservableRoomOptions)
                                        {
                                            <option value="@room.RoomTypeId"
                                                    data-price="@room.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-room-name="@room.Name"
                                                    data-max-guests="@room.MaxGuestCount"
                                                    data-max-adults="@room.MaxAdultCount"
                                                    data-max-children="@room.MaxChildCount">
                                                @room.Name
                                            </option>
                                        }
                                    </select>
                                </label>
                            </div>
                        </section>
                    </template>
                </div>

                <div class="guest-row">
                    <span>Yetiskin</span>
                    <div class="guest-controls">
                        <button type="button" class="guest-btn" data-target="adult" data-action="minus">-</button>
                        <strong id="adultCount">@reservationForm.AdultCount</strong>
                        <button type="button" class="guest-btn" data-target="adult" data-action="plus">+</button>
                    </div>
                    <input type="hidden" name="AdultCount" id="adultCountInput" value="@reservationForm.AdultCount" />
                </div>

                <div class="guest-row">
                    <span>Cocuk</span>
                    <div class="guest-controls">
                        <button type="button" class="guest-btn" data-target="child" data-action="minus">-</button>
                        <strong id="childCount">@reservationForm.ChildCount</strong>
                        <button type="button" class="guest-btn" data-target="child" data-action="plus">+</button>
                    </div>
                    <input type="hidden" name="ChildCount" id="childCountInput" value="@reservationForm.ChildCount" />
                </div>

                <input type="hidden" name="RoomCount" id="roomCountInput" value="1" />
                <input type="hidden" name="RoomTypeId" id="roomTypeIdInput" value="@reservationForm.RoomTypeId" />
                <input type="hidden" name="CheckInDate" id="checkInDateInput" value="@checkInDefault" />
                <input type="hidden" name="CheckOutDate" id="checkOutDateInput" value="@checkOutDefault" />

                @{
                    var pmSel = reservationForm.PaymentMethod?.Trim() ?? "";
                    var selKapida = string.Equals(pmSel, "Kapıda Ödeme", StringComparison.OrdinalIgnoreCase);
                    var selOnline = string.Equals(pmSel, "Online Ödeme", StringComparison.OrdinalIgnoreCase);
                    var paymentMethodChosen = selKapida || selOnline;
                }
                <div class="booking-advanced-fields booking-visible-fields" id="bookingAdvancedFields">
                    <div class="booking-advanced-heading">
                        <strong>Ödeme planı</strong>
                        <span>Rezervasyon öncesi ödeme tercihinizi ve giriş saatlerini netleştirin.</span>
                    </div>
                    <div class="booking-advanced-grid">
                        <label>
                            <span>Ödeme planı</span>
                            <select name="PaymentMethod" id="paymentMethodSelect">
                                @if (!paymentMethodChosen)
                                {
                                    <option value="" selected disabled>Ödeme yönteminizi seçin</option>
                                }
                                else
                                {
                                    <option value="" disabled>Ödeme yönteminizi seçin</option>
                                }
                                @if (selKapida)
                                {
                                    <option value="Kapıda Ödeme" selected>Kapıda ödeme</option>
                                }
                                else
                                {
                                    <option value="Kapıda Ödeme">Kapıda ödeme</option>
                                }
                                @if (selOnline)
                                {
                                    <option value="Online Ödeme" selected>Online kart ile ödeme</option>
                                }
                                else
                                {
                                    <option value="Online Ödeme">Online kart ile ödeme</option>
                                }
                            </select>
                        </label>
                        <div class="booking-payment-mix" id="bookingPaymentMix" hidden>
                            <p class="booking-payment-mix-title">Tutarları toplam fiyata bölebilirsiniz (₺)</p>
                            <label>
                                <span>Kart ile</span>
                                <input type="number" step="0.01" min="0" name="CardAmount" id="cardAmountInput" value="@reservationForm.CardAmount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                            </label>
                            <label>
                                <span>Havale / EFT</span>
                                <input type="number" step="0.01" min="0" name="BankTransferAmount" id="bankAmountInput" value="@reservationForm.BankTransferAmount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                            </label>
                            <label>
                                <span>Otelde (kapıda)</span>
                                <input type="number" step="0.01" min="0" name="CashAtHotelAmountSplit" id="cashSplitInput" value="@reservationForm.CashAtHotelAmountSplit.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                            </label>
                            <label>
                                <span>Havale referansı</span>
                                <input type="text" name="BankTransferReference" id="bankRefInput" maxlength="120" placeholder="İşlem / dekont referansı" value="@reservationForm.BankTransferReference" />
                            </label>
                            <label>
                                <span>Havale dekontu (isteğe bağlı)</span>
                                <input type="file" name="BankTransferReceipt" id="bankReceiptInput" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                            </label>
                        </div>
                        <label>
                            <span>Check-in / Check-out</span>
                            <input type="text" value="@(Model.CheckInTime?.ToString(@"hh\:mm") ?? "14:00") / @(Model.CheckOutTime?.ToString(@"hh\:mm") ?? "12:00")" readonly />
                        </label>
                    </div>
                    <p class="booking-advanced-tip">
                        Iptal, tarih ve oda kosullari secilen oda tipine gore rezervasyon adiminda tekrar onaylanir.
                    </p>
                    <div class="booking-payment-note" id="bookingPaymentNote" hidden>
                        Online kart ödemesi rezervasyon kaydından sonra ödeme bağlantısı ile tamamlanacaktır. Havale seçtiyseniz dekont veya referans eklemeniz işlemi hızlandırır.
                    </div>
                </div>

                <button type="submit" class="reserve-btn"@Html.Raw(paymentMethodChosen ? "" : " disabled=\"disabled\"")>Rezervasyon Yap</button>
            </form>

            <div class="booking-quote-notice" id="bookingQuoteNotice" hidden></div>
            <div class="price-breakdown" id="priceBreakdown">
                <div class="price-row price-row-tax"><span>KDV <small class="tax-rate-hint">%@Model.TaxDisplayVatPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</small></span><strong>₺@initialVat.ToString("N0")</strong></div>
                <div class="price-row price-row-tax"><span>Konaklama Vergisi <small class="tax-rate-hint">%@Model.TaxDisplayAccommodationPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</small></span><strong>₺@initialAccommodationTax.ToString("N0")</strong></div>
                <div class="price-row price-row-tax"><span>Vergi ve Harçlar</span><strong>₺@initialTax.ToString("N0")</strong></div>
                <div class="price-row total"><span>Toplam</span><strong>₺@initialTotal.ToString("N0")</strong></div>
            </div>
            <details class="nightly-breakdown-details" id="nightlyBreakdownDetails" hidden>
                <summary><i class="fas fa-angle-down"></i> Gün gün fiyat detayı</summary>
                <div class="nightly-breakdown-list" id="nightlyBreakdownList"></div>
            </details>
        </div>
    </aside>
</section>

<div class="detail-modal-backdrop" id="detailActionBackdrop" hidden></div>

<div class="review-modal" id="reviewModal" aria-hidden="true">
    <div class="review-modal-backdrop" data-review-modal-close></div>
    <div class="review-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="reviewModalTitle">
        <div class="review-modal-head">
            <strong id="reviewModalTitle">Misafir yorumu</strong>
            <button type="button" class="review-modal-close" data-review-modal-close aria-label="Kapat">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="review-modal-body">
            <div class="review-modal-meta">
                <span id="reviewModalDate"></span>
                <span class="review-modal-score" id="reviewModalScore"></span>
            </div>
            <div class="review-modal-text" id="reviewModalText"></div>
        </div>
    </div>
</div>

<section class="detail-modal detail-info-modal" id="detailInfoModal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="detailInfoModalTitle">
    <button type="button" class="detail-modal-close" data-close-modal="detailInfoModal" aria-label="Kapat"><i class="fas fa-times"></i></button>
    <div class="detail-modal-hero" aria-hidden="true">
        <div class="detail-modal-hero-icon">
            <i class="fas fa-circle-info"></i>
        </div>
    </div>
    <div class="detail-modal-head">
        <div>
            <span class="detail-modal-kicker">Bilgilendirme</span>
            <h3 id="detailInfoModalTitle">Önce bir adımı tamamlayalım</h3>
        </div>
    </div>
    <p class="detail-modal-copy" id="detailInfoModalText">Bu işlem için önce uygun koşulların sağlanması gerekiyor.</p>
    <div class="detail-modal-actions" id="detailInfoModalActions">
        <a href="/kullanici-giris" class="detail-modal-primary">Giriş Yap</a>
        <a href="/kullanici-giris?sekme=kayit" class="detail-modal-secondary">Kayıt Ol</a>
    </div>
</section>

@if (Model.IsLoggedInUser)
{
    <section class="detail-modal detail-profile-modal" id="profileCompletionModal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="profileCompletionModalTitle">
        <div class="detail-modal-head">
            <div>
                <span class="detail-modal-kicker">Rezervasyon İçin Zorunlu</span>
                <h3 id="profileCompletionModalTitle">Eksik profil bilgilerini tamamla</h3>
            </div>
            <button type="button" class="detail-modal-close" data-close-modal="profileCompletionModal"><i class="fas fa-times"></i></button>
        </div>
        <p class="detail-modal-copy">Rezervasyonu tamamlayabilmemiz için e-posta, doğum tarihi, cinsiyet ve adres alanlarının eksiksiz olması gerekiyor.</p>

        <form id="profileCompletionForm" class="detail-profile-form" method="post" action="/oteller/@Model.Slug/profil-bilgilerini-tamamla">
            @Html.AntiForgeryToken()
            <label>
                <span>E-posta</span>
                <input type="email" name="Email" value="@Model.ProfilePrompt.Email" />
            </label>
            <label>
                <span>Telefon</span>
                <input type="text" name="Phone" value="@Model.ProfilePrompt.Phone" />
            </label>
            <label>
                <span>Doğum Tarihi</span>
                <input type="date" name="BirthDateText" value="@Model.ProfilePrompt.BirthDateText" required />
            </label>
            <label>
                <span>Cinsiyet</span>
                <select name="Gender" required>
                    <option value="">Seçiniz</option>
                    <option value="Erkek" selected="@(Model.ProfilePrompt.Gender == "Erkek")">Erkek</option>
                    <option value="Kadın" selected="@(Model.ProfilePrompt.Gender == "Kadın")">Kadın</option>
                    <option value="Belirtmek İstemiyorum" selected="@(Model.ProfilePrompt.Gender == "Belirtmek İstemiyorum")">Belirtmek İstemiyorum</option>
