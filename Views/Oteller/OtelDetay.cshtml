@model otelturizmnew.Models.Oteller.HotelDetailPageViewModel

@{
    ViewData["Title"] = Model.Name;
    ViewData["SuppressGlobalDraftBanner"] = true;
    var gallery = Model.GalleryImages.Count > 0 ? Model.GalleryImages : new List<string> { Model.MainImageUrl };
    var mainImage = gallery.FirstOrDefault() ?? string.Empty;
    var roomSelectOptions = Model.Rooms.Count > 0 ? Model.Rooms : new List<otelturizmnew.Models.Oteller.HotelRoomViewModel>
    {
        new()
        {
            RoomTypeId = 0,
            Name = "Standart Oda",
            Specs = "2 Kisi",
            Price = Model.LowestRoomPrice,
            CancellationText = "Ucretsiz iptal"
        }
    };
    var reservableRoomOptions = roomSelectOptions.Where(x => x.Price > 0m).ToList();
    if (reservableRoomOptions.Count == 0)
    {
        reservableRoomOptions = roomSelectOptions;
    }
    var reservationForm = Model.ReservationForm ?? new otelturizmnew.Models.Reservations.PublicHotelReservationForm { HotelId = Model.Id, RoomTypeId = reservableRoomOptions.FirstOrDefault()?.RoomTypeId ?? 0 };
    var selectedRoomSeed = reservableRoomOptions.FirstOrDefault(x => x.RoomTypeId == reservationForm.RoomTypeId) ?? reservableRoomOptions.First();
    var roomPriceSeed = selectedRoomSeed.Price;
    var checkInDefault = reservationForm.CheckInDate.ToString("yyyy-MM-dd");
    var checkOutDefault = reservationForm.CheckOutDate.ToString("yyyy-MM-dd");
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");
    var locationText = $"{Model.District}, {Model.City}";
    var longDescription = string.IsNullOrWhiteSpace(Model.LongDescription) ? Model.ShortDescription : Model.LongDescription;
    var overallBarWidth = Model.Rating > 0 ? Math.Min(100m, Model.Rating * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var locScore = Model.ReviewLocationScore > 0 ? Model.ReviewLocationScore : Model.Rating;
    var roomScore = Model.ReviewRoomScore > 0 ? Model.ReviewRoomScore : Model.Rating;
    var valScore = Model.ReviewValueScore > 0 ? Model.ReviewValueScore : Model.Rating;
    var staffScore = Model.ReviewStaffScore > 0 ? Model.ReviewStaffScore : Model.Rating;
    var locationBarWidth = locScore > 0 ? Math.Min(100m, locScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var roomBarWidth = roomScore > 0 ? Math.Min(100m, roomScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var valueBarWidth = valScore > 0 ? Math.Min(100m, valScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var staffBarWidth = staffScore > 0 ? Math.Min(100m, staffScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var featuredAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Take(4)
        .ToList();
    var featuredAmenityFallbacks = new List<otelturizmnew.Models.Oteller.HotelAmenityViewModel>
    {
        new() { Name = "24 Saat Resepsiyon", IconClass = "fa-clock" },
        new() { Name = "Ucretsiz WiFi", IconClass = "fa-wifi" },
        new() { Name = "Restoran", IconClass = "fa-utensils" },
        new() { Name = "Fitness Merkezi", IconClass = "fa-dumbbell" }
    };
    foreach (var fallbackItem in featuredAmenityFallbacks)
    {
        if (featuredAmenities.Count >= 4)
        {
            break;
        }

        if (featuredAmenities.Any(x => string.Equals(x.Name, fallbackItem.Name, StringComparison.OrdinalIgnoreCase)))
        {
            continue;
        }

        featuredAmenities.Add(fallbackItem);
    }
    var hiddenAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Skip(4)
        .ToList();
    var initialNightCount = Math.Max(1, reservationForm.CheckOutDate.DayNumber - reservationForm.CheckInDate.DayNumber);
    var initialRooms = Math.Max(1, reservationForm.RoomCount);
    var initialSubtotal = roomPriceSeed * initialNightCount * initialRooms;
    var vatRateFrac = Model.TaxDisplayVatPercent / 100m;
    var accomRateFrac = Model.TaxDisplayAccommodationPercent / 100m;
    var initialVat = Math.Round(initialSubtotal * vatRateFrac, 0);
    var initialAccommodationTax = Math.Round(initialSubtotal * accomRateFrac, 0);
    var initialTax = initialVat + initialAccommodationTax;
    var initialTotal = initialSubtotal + initialTax;
    var initialInclusiveNightly = initialNightCount > 0 && initialRooms > 0
        ? Math.Round(initialTotal / initialNightCount / initialRooms, 0)
        : 0m;
    var todayWeather = Model.Weather?.Days.FirstOrDefault();
    var weatherThemeClass = "weather-theme-cloudy";
    var weatherThemeTitle = "İlçe bazlı hava durumu";
    var weatherThemeSummary = "Bugün için dengeli bir gezi ritmi planlayabilirsiniz.";
    var weatherAccentIcon = "fa-cloud-sun";

    if (todayWeather is not null)
    {
        if (todayWeather.ConditionText.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-rainy";
            weatherThemeTitle = "Yağış etkili görünüyor";
            weatherThemeSummary = "Şemsiye ile çıkmak akıllı olur. Kapalı alanlar, kafe ve iç mekan planları öne çıkabilir.";
            weatherAccentIcon = "fa-cloud-showers-heavy";
        }
        else if (todayWeather.ConditionText.Contains("Açık", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-sunny";
            weatherThemeTitle = "Güneşli bir tempo sizi bekliyor";
            weatherThemeSummary = "Açık hava programları, sahil rotaları ve teras deneyimleri için güzel bir görünüm var.";
            weatherAccentIcon = "fa-sun";
        }
        else if (todayWeather.ConditionText.Contains("Kar", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-snowy";
            weatherThemeTitle = "Serin ve kis dokulu hava";
            weatherThemeSummary = "Dış planlarında daha sıcak giyinmek faydalı olur. Sıcak içecek ve iç mekan deneyimleri daha keyifli olabilir.";
            weatherAccentIcon = "fa-snowflake";
        }
    }

    string GetAmenitySubtext(string amenityName)
    {
        var value = amenityName.ToLowerInvariant();
        if (value.Contains("havuz")) return "Ucretsiz kullanim";
        if (value.Contains("spa") || value.Contains("hamam") || value.Contains("sauna")) return "Hamam, sauna, masaj";
        if (value.Contains("restoran") || value.Contains("bar")) return "Gurme mutfak";
        if (value.Contains("wifi") || value.Contains("wi-fi")) return "Tum odalarda";
        if (value.Contains("otopark")) return "Vale ve acik otopark";
        return "Tesis olanağı";
    }
}

<div class="otel-detail-template-v41">
<section class="detail-breadcrumb detail-breadcrumb-with-weather">
    <div class="detail-breadcrumb-left">
        <a asp-controller="Oteller" asp-action="OtelListeleme" class="detail-back-link">
            <i class="fas fa-arrow-left"></i>
            <span>Otellere Dön</span>
        </a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">·</span>
        <span class="detail-breadcrumb-context">
            <i class="fas fa-location-dot"></i>
            <strong>@Model.District</strong><span class="detail-breadcrumb-muted">, @Model.City</span>
        </span>
    </div>
</section>

<section class="gallery-grid">
    <div class="gallery-main-image">
        @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
        {
            <div class="gallery-star-badge" aria-label="@($"{Model.StarCount.Value} yıldızlı otel")">
                @for (var i = 0; i < Model.StarCount.Value; i++)
                {
                    <i class="fas fa-star" aria-hidden="true"></i>
                }
            </div>
        }
        <button type="button" class="gallery-main-trigger" data-gallery-index="0" aria-label="Galeriyi ac">
            <img src="@mainImage" alt="@Model.Name" id="mainGalleryImage" />
        </button>
    </div>
    <div class="gallery-side-grid">
        @for (var imageIndex = 1; imageIndex < gallery.Count && imageIndex <= 4; imageIndex++)
        {
            var image = gallery[imageIndex];
            <button type="button" class="gallery-thumb" data-image="@image" data-gallery-index="@imageIndex">
                <img src="@image" alt="@Model.Name galeri @imageIndex" />
            </button>
        }
    </div>
 </section>
 @if (gallery.Count > 0)
 {
    <section class="gallery-filmstrip-wrap" aria-label="Otel galerisi">
        <div class="gallery-filmstrip">
            @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
            {
                <button type="button"
                        class="gallery-filmstrip-thumb @(imageIndex == 0 ? "active" : string.Empty)"
                        data-gallery-index="@imageIndex"
                        aria-label="Otel gorsel @(imageIndex + 1)">
                    <img src="@gallery[imageIndex]" alt="@Model.Name gorsel @(imageIndex + 1)" />
                </button>
            }
        </div>
    </section>
 }
    @if (gallery.Count > 1)
    {
        <div class="gallery-mobile-strip" id="galleryMobileStrip" aria-label="Mobil galeri slider">
            @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
            {
                <div class="gallery-star-badge gallery-star-badge-mobile" aria-label="@($"{Model.StarCount.Value} yıldızlı otel")">
                    @for (var i = 0; i < Model.StarCount.Value; i++)
                    {
                        <i class="fas fa-star" aria-hidden="true"></i>
                    }
                </div>
            }
            <div class="gallery-mobile-track" id="galleryMobileTrack">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button" class="gallery-mobile-slide" data-image="@gallery[imageIndex]" data-gallery-index="@imageIndex" aria-label="Gorsel @(imageIndex + 1)">
                        <img src="@gallery[imageIndex]" alt="@Model.Name mobil galeri @(imageIndex + 1)" />
                    </button>
                }
            </div>
            <div class="gallery-mobile-dots" id="galleryMobileDots" role="tablist" aria-label="Galeri gezinme">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button"
                            class="gallery-mobile-dot @(imageIndex == 0 ? "active" : string.Empty)"
                            data-gallery-dot-index="@imageIndex"
                            aria-label="Gorsel @(imageIndex + 1)"
                            aria-selected="@(imageIndex == 0 ? "true" : "false")"></button>
                }
            </div>
        </div>
    }

<div class="gallery-lightbox" id="galleryLightbox" hidden>
    <button type="button" class="gallery-lightbox-close" id="galleryLightboxClose" aria-label="Galeriyi kapat">
        <i class="fas fa-times"></i>
    </button>
    <button type="button" class="gallery-lightbox-nav prev" id="galleryLightboxPrev" aria-label="Onceki gorsel">
        <i class="fas fa-chevron-left"></i>
    </button>
    <figure class="gallery-lightbox-figure">
        <img src="" alt="@Model.Name tam ekran galeri" id="galleryLightboxImage" />
        <figcaption id="galleryLightboxCaption"></figcaption>
    </figure>
    <button type="button" class="gallery-lightbox-nav next" id="galleryLightboxNext" aria-label="Sonraki gorsel">
        <i class="fas fa-chevron-right"></i>
    </button>
</div>

