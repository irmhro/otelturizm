            const detailVatFraction = @((Model.TaxDisplayVatPercent / 100m).ToString(System.Globalization.CultureInfo.InvariantCulture));
            const detailAccommodationFraction = @((Model.TaxDisplayAccommodationPercent / 100m).ToString(System.Globalization.CultureInfo.InvariantCulture));
            const detailVatPctLabel = '@Model.TaxDisplayVatPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)';
            const detailAccomPctLabel = '@Model.TaxDisplayAccommodationPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)';
            const reservationAdultCutoffDate = '@reservationAdultCutoffText';
            const reservationAdultEligibilityMessage = 'Rezervasyon oluşturabilmek için 18 yaşını doldurmuş olmanız ve doğum gününüzün üzerinden en az 1 gün geçmiş olması gerekir.';

            function parseIsoDate(value) {
                if (!value || typeof value !== 'string') {
                    return null;
                }

                const parts = value.split('-');
                if (parts.length !== 3) {
                    return null;
                }

                const year = Number(parts[0]);
                const month = Number(parts[1]);
                const day = Number(parts[2]);
                if (!Number.isFinite(year) || !Number.isFinite(month) || !Number.isFinite(day)) {
                    return null;
                }

                const parsed = new Date(year, month - 1, day);
                if (Number.isNaN(parsed.getTime())) {
                    return null;
                }

                parsed.setHours(0, 0, 0, 0);
                return parsed;
            }

            function validateProfileCompletionData(formData) {
                const email = (formData.get('Email') || '').toString().trim();
                const firstName = (formData.get('FirstName') || '').toString().trim();
                const lastName = (formData.get('LastName') || '').toString().trim();
                const phone = (formData.get('Phone') || '').toString().trim();
                const birthDateText = (formData.get('BirthDateText') || '').toString().trim();
                const gender = (formData.get('Gender') || '').toString().trim();
                const city = (formData.get('City') || '').toString().trim();
                const district = (formData.get('District') || '').toString().trim();

                if (!email) {
                    return 'Rezervasyon için e-posta alanı zorunludur.';
                }

                if (!firstName) {
                    return 'Rezervasyon için ad alanı zorunludur.';
                }

                if (!lastName) {
                    return 'Rezervasyon için soyad alanı zorunludur.';
                }

                if (!phone) {
                    return 'Rezervasyon için telefon numarası zorunludur.';
                }

                if (!birthDateText) {
                    return 'Rezervasyon için doğum tarihi zorunludur.';
                }

                const birthDate = parseIsoDate(birthDateText);
                const cutoffDate = parseIsoDate(reservationAdultCutoffDate);
                if (!birthDate || !cutoffDate) {
                    return 'Doğum tarihi geçerli bir formatta girilmelidir.';
                }

                if (birthDate.getTime() > cutoffDate.getTime()) {
                    return reservationAdultEligibilityMessage;
                }

                if (!gender) {
                    return 'Rezervasyon için cinsiyet seçimi zorunludur.';
                }

                if (!city) {
                    return 'Rezervasyon için il seçimi zorunludur.';
                }

                if (!district) {
                    return 'Rezervasyon için ilçe seçimi zorunludur.';
                }

                return '';
            }

