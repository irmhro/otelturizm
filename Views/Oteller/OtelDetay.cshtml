            function showInfoModal(message, isGuest, tone) {
                if (!infoModal || !infoModalText || !infoModalActions) {
                    return;
                }

                infoModal.classList.remove('is-room-pick');
                infoModal.classList.remove('is-warning');
                infoModal.classList.toggle('is-auth-required', !!isGuest);

                const normalizedTone = (tone || '').toString().trim().toLowerCase();
                if (!isGuest && normalizedTone === 'warning') {
                    infoModal.classList.add('is-warning');
                }
                if (infoModalTitle) {
                    infoModalTitle.textContent = defaultInfoModalTitle;
                }

                infoModalText.textContent = message;
                if (isGuest) {
                    infoModalActions.innerHTML = '<a href="/kullanici-giris" class="detail-modal-primary">Giriş Yap</a><a href="/kullanici-giris?sekme=kayit" class="detail-modal-secondary">Kayıt Ol</a>';
                } else if (normalizedTone === 'warning'
                    && (message || '').toString().trim().toLowerCase().includes('ödeme planı')
                    && paymentMethodSelect) {
                    infoModalActions.innerHTML =
                        '<button type="button" class="detail-modal-option" data-set-payment="Kapıda nakit ödeme"><i class="fas fa-hand-holding-dollar"></i> Kapıda nakit ödeme</button>'
                        + '<button type="button" class="detail-modal-option" data-set-payment="Kapıda kart ile ödeme"><i class="fas fa-credit-card"></i> Kapıda kart ile ödeme</button>'
                        + '<button type="button" class="detail-modal-secondary" data-close-modal="detailInfoModal">Vazgeç</button>';
                } else {
                    infoModalActions.innerHTML = '<button type="button" class="detail-modal-primary" data-close-modal="detailInfoModal">Tamam</button>';
                }
                openModal(infoModal);

                infoModalActions.querySelectorAll('[data-set-payment]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
