@model otelturizmnew.Models.Oteller.HotelDetailPageViewModel

@{
    ViewData["Title"] = Model.Name;
    var gallery = Model.GalleryImages.Count > 0 ? Model.GalleryImages : new List<string> { Model.MainImageUrl };
    var mainImage = gallery.FirstOrDefault() ?? string.Empty;
    var roomSelectOptions = Model.Rooms.Count > 0 ? Model.Rooms : new List<otelturizmnew.Models.Oteller.HotelRoomViewModel>
    {
        new()
        {
            RoomTypeId = 0,
            Name = "Standart Oda",
            Specs = "2 Kisi",
            Price = Model.LowestRoomPrice,
            CancellationText = "Ucretsiz iptal"
        }
    };
    var reservableRoomOptions = roomSelectOptions.Where(x => x.Price > 0m).ToList();
    if (reservableRoomOptions.Count == 0)
    {
        reservableRoomOptions = roomSelectOptions;
    }
    var reservationForm = Model.ReservationForm ?? new otelturizmnew.Models.Reservations.PublicHotelReservationForm { HotelId = Model.Id, RoomTypeId = reservableRoomOptions.FirstOrDefault()?.RoomTypeId ?? 0 };
    var selectedRoomSeed = reservableRoomOptions.FirstOrDefault(x => x.RoomTypeId == reservationForm.RoomTypeId) ?? reservableRoomOptions.First();
    var roomPriceSeed = selectedRoomSeed.Price;
    var checkInDefault = reservationForm.CheckInDate.ToString("yyyy-MM-dd");
    var checkOutDefault = reservationForm.CheckOutDate.ToString("yyyy-MM-dd");
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");
    var locationText = $"{Model.District}, {Model.City}";
    var longDescription = string.IsNullOrWhiteSpace(Model.LongDescription) ? Model.ShortDescription : Model.LongDescription;
    var overallBarWidth = Model.Rating > 0 ? Math.Min(100m, Model.Rating * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var locScore = Model.ReviewLocationScore > 0 ? Model.ReviewLocationScore : Model.Rating;
    var roomScore = Model.ReviewRoomScore > 0 ? Model.ReviewRoomScore : Model.Rating;
    var valScore = Model.ReviewValueScore > 0 ? Model.ReviewValueScore : Model.Rating;
    var staffScore = Model.ReviewStaffScore > 0 ? Model.ReviewStaffScore : Model.Rating;
    var locationBarWidth = locScore > 0 ? Math.Min(100m, locScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var roomBarWidth = roomScore > 0 ? Math.Min(100m, roomScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var valueBarWidth = valScore > 0 ? Math.Min(100m, valScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var staffBarWidth = staffScore > 0 ? Math.Min(100m, staffScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var featuredAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Take(4)
        .ToList();
    var featuredAmenityFallbacks = new List<otelturizmnew.Models.Oteller.HotelAmenityViewModel>
    {
        new() { Name = "24 Saat Resepsiyon", IconClass = "fa-clock" },
        new() { Name = "Ucretsiz WiFi", IconClass = "fa-wifi" },
        new() { Name = "Restoran", IconClass = "fa-utensils" },
        new() { Name = "Fitness Merkezi", IconClass = "fa-dumbbell" }
    };
    foreach (var fallbackItem in featuredAmenityFallbacks)
    {
        if (featuredAmenities.Count >= 4)
        {
            break;
        }

        if (featuredAmenities.Any(x => string.Equals(x.Name, fallbackItem.Name, StringComparison.OrdinalIgnoreCase)))
        {
            continue;
        }

        featuredAmenities.Add(fallbackItem);
    }
    var hiddenAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Skip(4)
        .ToList();
    var initialNightCount = Math.Max(1, reservationForm.CheckOutDate.DayNumber - reservationForm.CheckInDate.DayNumber);
    var initialRooms = Math.Max(1, reservationForm.RoomCount);
    var initialSubtotal = roomPriceSeed * initialNightCount * initialRooms;
    var vatRateFrac = Model.TaxDisplayVatPercent / 100m;
    var accomRateFrac = Model.TaxDisplayAccommodationPercent / 100m;
    var initialVat = Math.Round(initialSubtotal * vatRateFrac, 0);
    var initialAccommodationTax = Math.Round(initialSubtotal * accomRateFrac, 0);
    var initialTax = initialVat + initialAccommodationTax;
    var initialTotal = initialSubtotal + initialTax;
    var initialInclusiveNightly = initialNightCount > 0 && initialRooms > 0
        ? Math.Round(initialTotal / initialNightCount / initialRooms, 0)
        : 0m;
    var todayWeather = Model.Weather?.Days.FirstOrDefault();
    var weatherThemeClass = "weather-theme-cloudy";
    var weatherThemeTitle = "Ilce bazli hava durumu";
    var weatherThemeSummary = "Bugun icin dengeli bir gezi ritmi planlayabilirsiniz.";
    var weatherAccentIcon = "fa-cloud-sun";

    if (todayWeather is not null)
    {
        if (todayWeather.ConditionText.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-rainy";
            weatherThemeTitle = "Yagis etkili gorunuyor";
            weatherThemeSummary = "Semsiye ile cikmak akilli olur. Kapali alanlar, kafe ve ic mekan planlari one cikabilir.";
            weatherAccentIcon = "fa-cloud-showers-heavy";
        }
        else if (todayWeather.ConditionText.Contains("Açık", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-sunny";
            weatherThemeTitle = "Gunesli bir tempo sizi bekliyor";
            weatherThemeSummary = "Acik hava programlari, sahil rotalari ve teras deneyimleri icin guzel bir gorunum var.";
            weatherAccentIcon = "fa-sun";
        }
        else if (todayWeather.ConditionText.Contains("Kar", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-snowy";
            weatherThemeTitle = "Serin ve kis dokulu hava";
            weatherThemeSummary = "Dis planlarinda daha sicak giyinmek faydali olur. Sicak icecek ve ic mekan deneyimleri daha keyifli olabilir.";
            weatherAccentIcon = "fa-snowflake";
        }
    }

    string GetAmenitySubtext(string amenityName)
    {
        var value = amenityName.ToLowerInvariant();
        if (value.Contains("havuz")) return "Ucretsiz kullanim";
        if (value.Contains("spa") || value.Contains("hamam") || value.Contains("sauna")) return "Hamam, sauna, masaj";
        if (value.Contains("restoran") || value.Contains("bar")) return "Gurme mutfak";
        if (value.Contains("wifi") || value.Contains("wi-fi")) return "Tum odalarda";
        if (value.Contains("otopark")) return "Vale ve acik otopark";
        return "Tesis olanağı";
    }
}

<div class="otel-detail-template-v41">
<section class="detail-breadcrumb detail-breadcrumb-with-weather">
    <div class="detail-breadcrumb-left">
        <a asp-controller="Oteller" asp-action="OtelListeleme"><i class="fas fa-arrow-left"></i> Otellere Don</a>
    </div>
</section>

<section class="gallery-grid">
    <div class="gallery-main-image">
        <button type="button" class="gallery-main-trigger" data-gallery-index="0" aria-label="Galeriyi ac">
            <img src="@mainImage" alt="@Model.Name" id="mainGalleryImage" />
        </button>
    </div>
    <div class="gallery-side-grid">
        @for (var imageIndex = 1; imageIndex < gallery.Count && imageIndex <= 4; imageIndex++)
        {
            var image = gallery[imageIndex];
            <button type="button" class="gallery-thumb" data-image="@image" data-gallery-index="@imageIndex">
                <img src="@image" alt="@Model.Name galeri @imageIndex" />
            </button>
        }
    </div>
 </section>
 @if (gallery.Count > 0)
 {
    <section class="gallery-filmstrip-wrap" aria-label="Otel galerisi">
        <div class="gallery-filmstrip">
            @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
            {
                <button type="button"
                        class="gallery-filmstrip-thumb @(imageIndex == 0 ? "active" : string.Empty)"
                        data-gallery-index="@imageIndex"
                        aria-label="Otel gorsel @(imageIndex + 1)">
                    <img src="@gallery[imageIndex]" alt="@Model.Name gorsel @(imageIndex + 1)" />
                </button>
            }
        </div>
    </section>
 }
    @if (gallery.Count > 1)
    {
        <div class="gallery-mobile-strip" id="galleryMobileStrip" aria-label="Mobil galeri slider">
            <div class="gallery-mobile-track" id="galleryMobileTrack">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button" class="gallery-mobile-slide" data-image="@gallery[imageIndex]" data-gallery-index="@imageIndex" aria-label="Gorsel @(imageIndex + 1)">
                        <img src="@gallery[imageIndex]" alt="@Model.Name mobil galeri @(imageIndex + 1)" />
                    </button>
                }
            </div>
            <div class="gallery-mobile-dots" id="galleryMobileDots" role="tablist" aria-label="Galeri gezinme">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button"
                            class="gallery-mobile-dot @(imageIndex == 0 ? "active" : string.Empty)"
                            data-gallery-dot-index="@imageIndex"
                            aria-label="Gorsel @(imageIndex + 1)"
                            aria-selected="@(imageIndex == 0 ? "true" : "false")"></button>
                }
            </div>
        </div>
    }

<div class="gallery-lightbox" id="galleryLightbox" hidden>
    <button type="button" class="gallery-lightbox-close" id="galleryLightboxClose" aria-label="Galeriyi kapat">
        <i class="fas fa-times"></i>
    </button>
    <button type="button" class="gallery-lightbox-nav prev" id="galleryLightboxPrev" aria-label="Onceki gorsel">
        <i class="fas fa-chevron-left"></i>
    </button>
    <figure class="gallery-lightbox-figure">
        <img src="" alt="@Model.Name tam ekran galeri" id="galleryLightboxImage" />
        <figcaption id="galleryLightboxCaption"></figcaption>
    </figure>
    <button type="button" class="gallery-lightbox-nav next" id="galleryLightboxNext" aria-label="Sonraki gorsel">
        <i class="fas fa-chevron-right"></i>
    </button>
</div>

<section class="detail-header hotel-title-section">
    <div class="hotel-name">
        <h1>
            @Model.Name
            @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
            {
                <span class="detail-stars" aria-hidden="true">
                    @for (var i = 0; i < Model.StarCount.Value; i++)
                    {
                        <text>★</text>
                    }
                </span>
                <span class="sr-only">@($"{Model.StarCount.Value} yıldızlı otel")</span>
            }
        </h1>
        <p class="detail-location"><i class="fas fa-location-dot"></i> @Model.Address</p>

    </div>
    <div class="header-right-stack">
        <div class="header-top-metrics">
            @if (Model.Weather is not null && Model.Weather.Days.Count > 0)
            {
                <div class="detail-utility-row">
                    <button type="button" class="weather-inline-trigger @weatherThemeClass" id="weatherPopupOpen" aria-haspopup="dialog" aria-controls="weatherPopup">
                        <span class="weather-inline-icon">
                            <i class="fas @(todayWeather?.IconClass ?? "fa-cloud-sun")"></i>
                        </span>
                        <span class="weather-inline-copy">
                            <strong>Hava durumunu gor</strong>
                            <small>@Model.Weather.LocationLabel • @(todayWeather?.ConditionText ?? string.Empty)</small>
                        </span>
                        <span class="weather-inline-badge">3 Gunluk</span>
                    </button>
                </div>
            }
            <div class="rating-summary">
                <div class="rating-big">
                    <span class="rating-number">@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "0.0")</span>
                    <span class="rating-max">/10</span>
                </div>
                <div class="rating-text">
                    <strong>@Model.RatingText</strong><br />
                    <span>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} yorum" : "Henuz yorum yok")</span>
                </div>
            </div>
        </div>
        <div class="detail-actions">
            <button type="button"
                    id="startConversationBtn"
                    class="conversation-btn"
                    data-hotel-slug="@Model.Slug"
                    data-authenticated="@(Model.IsLoggedInUser ? "true" : "false")"
                    data-can-start="@(Model.HasCompletedReservationAtHotel ? "true" : "false")"
                    data-info-message="@Model.ConversationInfoMessage">
                <i class="far fa-comments"></i> Görüşme Başlat
            </button>
            <button type="button" id="shareHotelBtn" aria-haspopup="true" aria-expanded="false" aria-controls="shareMenu">
                <i class="far fa-share-square"></i> Paylas
            </button>
            <div class="share-menu" id="shareMenu" hidden>
                <p class="share-menu-title">Bu oteli paylas</p>
                <div class="share-menu-grid">
                    <a href="#" data-share-platform="whatsapp" target="_blank" rel="noopener">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                    <a href="#" data-share-platform="facebook" target="_blank" rel="noopener">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="#" data-share-platform="x" target="_blank" rel="noopener">
                        <i class="fab fa-x-twitter"></i>
                        <span>X</span>
                    </a>
                    <a href="#" data-share-platform="instagram" target="_blank" rel="noopener">
                        <i class="fab fa-instagram"></i>
                        <span>Instagram</span>
                    </a>
                    <a href="#" data-share-platform="telegram" target="_blank" rel="noopener">
                        <i class="fab fa-telegram-plane"></i>
                        <span>Telegram</span>
                    </a>
                    <button type="button" data-share-platform="copy">
                        <i class="fas fa-link"></i>
                        <span>Link Kopyala</span>
                    </button>
                </div>
                <button type="button" class="share-more-btn" data-share-platform="more">
                    <i class="fas fa-share-nodes"></i>
                    Diger Platformlar
                </button>
            </div>
            <button type="button" id="saveHotelBtn" class="favorite-btn @(Model.IsFavorite ? "active" : string.Empty)" data-hotel-id="@Model.Id" data-source-page="OtelDetay">
                <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
                <span data-favorite-label>@(Model.IsFavorite ? "Kaydedildi" : "Kaydet")</span>
            </button>
        </div>
    </div>
</section>

@if (TempData["PublicReservationSuccess"] is string successMessage)
{
    <div class="detail-inline-feedback success">@successMessage</div>
}

@if (TempData["PublicReservationInfo"] is string infoMessage)
{
    <div class="detail-inline-feedback info">@infoMessage</div>
}

@if (Model.ActiveDraft is not null)
{
    <section class="content-card active-draft-banner">
        <div>
            <strong>Tamamlanmamis rezervasyonunuz var</strong>
            <p class="active-draft-message">@Model.ActiveDraft.HotelName · @Model.ActiveDraft.CheckInText - @Model.ActiveDraft.CheckOutText · @Model.ActiveDraft.Message</p>
        </div>
        <div class="active-draft-actions">
            <a href="@Model.ActiveDraft.ResumeUrl" class="active-draft-link">Devam Et</a>
            @if ((Model.ActiveDraft.RequiresProfileCompletion || Model.ProfilePrompt.IsProfileIncomplete) && Model.IsLoggedInUser)
            {
                <button type="button" class="active-draft-secondary" id="openProfileCompletionFromBanner">Bilgileri Tamamla</button>
            }
            @{ ViewData["CancelButtonClass"] = "active-draft-cancel"; }
            <partial name="~/Views/Shared/_ReservationDraftCancelButton.cshtml" model="Model.ActiveDraft" />
            @{ ViewData.Remove("CancelButtonClass"); }
        </div>
    </section>
}

<section class="detail-grid">
    <div class="detail-content">
        <article class="content-card featured-amenities-card">
            <div class="section-head">
                <h2>One Cikan Ozellikler</h2>
                <p>@(string.IsNullOrWhiteSpace(Model.ShortDescription) ? "Tesisin veritabanindaki one cikan olanaklari." : Model.ShortDescription)</p>
            </div>
            <div class="amenities-grid amenities-grid-lux">
                @foreach (var item in featuredAmenities)
                {
                    <div class="amenity-item amenity-item-lux">
                        <i class="fas @item.IconClass"></i>
                        <span class="amenity-copy">
                            <strong>@item.Name</strong>
                            <small>@GetAmenitySubtext(item.Name)</small>
                        </span>
                    </div>
                }
                @if (hiddenAmenities.Count > 0)
                {
                    <button type="button" class="amenity-item amenity-item-lux amenities-action-item" id="openAmenitiesModal">
                        <i class="fas fa-plus"></i>
                        <span class="amenity-copy">
                            <strong>Diger ozellikler</strong>
                            <small>@hiddenAmenities.Count ozellik daha</small>
                        </span>
                    </button>
                }
            </div>
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Tesis Hakkinda</h2>
                <p>@longDescription</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.LocationDescription))
            {
                <p class="detail-long-copy">@Model.LocationDescription</p>
            }
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Oda Tipleri ve Fiyatlar</h2>
                <p>Bu alandaki Odalardan rezervasyon Yapabilirsiniz</p>
            </div>

            <div class="room-list">
                @foreach (var room in Model.Rooms)
                {
                    var roomGallery = room.GalleryImages.Count > 0
                        ? room.GalleryImages
                        : (!string.IsNullOrWhiteSpace(room.ImageUrl) ? new List<string> { room.ImageUrl } : new List<string>());
                    var roomGalleryJson = System.Text.Json.JsonSerializer.Serialize(roomGallery);
                    var roomCoverImage = !string.IsNullOrWhiteSpace(room.ImageUrl)
                        ? room.ImageUrl
                        : roomGallery.FirstOrDefault();

                    <div class="room-card">
                        <div class="room-card-main">
                            <div class="room-card-media">
                                @if (!string.IsNullOrWhiteSpace(roomCoverImage))
                                {
                                    <div class="room-card-cover">
                                        <button type="button"
                                                class="room-gallery-trigger"
                                                data-room-name="@room.Name"
                                                data-room-gallery='@roomGalleryJson'
                                                data-room-gallery-start="0"
                                                aria-label="@room.Name galerisi">
                                            <img src="@roomCoverImage" alt="@room.Name" />
                                            @if (roomGallery.Count > 1)
                                            {
                                                <span class="room-gallery-count">
                                                    <i class="fas fa-images"></i>
                                                    @roomGallery.Count gorsel
                                                </span>
                                            }
                                        </button>
                                    </div>
                                    @if (roomGallery.Count > 1)
                                    {
                                        <div class="room-thumb-strip" aria-label="@room.Name gorselleri">
                                            @for (var imageIndex = 0; imageIndex < roomGallery.Count; imageIndex++)
                                            {
                                                <button type="button"
                                                        class="room-gallery-trigger room-thumb-item @(imageIndex == 0 ? "active" : string.Empty)"
                                                        data-room-name="@room.Name"
                                                        data-room-gallery='@roomGalleryJson'
                                                        data-room-gallery-start="@imageIndex"
                                                        aria-label="@room.Name gorsel @(imageIndex + 1)">
                                                    <img src="@roomGallery[imageIndex]" alt="@room.Name gorsel @(imageIndex + 1)" />
                                                </button>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="room-card-media-placeholder"><i class="fas fa-bed"></i></div>
                                }
                            </div>
                            <div class="room-card-copy">
                                <h3>@room.Name</h3>
                                <p>@room.Specs</p>
                                <span class="cancellation-badge"><i class="fas fa-check-circle"></i> @room.CancellationText</span>
                                @if (room.Features.Count > 0)
                                {
                                    <div class="room-feature-preview">
                                        @foreach (var feature in room.Features.Take(5))
                                        {
                                            <span class="room-feature-chip"><i class="fas @feature.IconClass"></i> @feature.Name</span>
                                        }
                                    </div>
                                    @if (room.Features.Count > 5)
                                    {
                                        <details class="room-feature-more">
                                            <summary>Tümünü gör</summary>
                                            <div class="room-feature-preview room-feature-preview-all">
                                                @foreach (var feature in room.Features.Skip(5))
                                                {
                                                    <span class="room-feature-chip"><i class="fas @feature.IconClass"></i> @feature.Name</span>
                                                }
                                            </div>
                                        </details>
                                    }
                                }
                            </div>
                        </div>
                        <div class="room-price-box">
                            <strong>@(room.Price > 0m ? $"₺{Model.GuestInclusiveNightlyFromStoredNet(room.Price):N0}" : "Fiyat Yok")</strong>
                            @if (room.Price > 0m)
                            {
                                <span class="room-price-inclusive-label" title="KDV ve konaklama vergisi dahil gece fiyatı">Vergi dahil</span>
                            }
                            else
                            {
                                <span class="room-price-unavailable">Bu oda icin aktif fiyat bulunamadi</span>
                            }
                            @if (room.Price > 0m)
                            {
                                <button type="button"
                                        class="select-room-btn"
                                        data-room-id="@room.RoomTypeId"
                                        data-price="@room.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                                    Odanı Seç
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="select-room-btn"
                                        data-room-id="@room.RoomTypeId"
                                        data-price="0"
                                        disabled>
                                    Fiyat Yok
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="room-gallery-modal" id="roomGalleryModal" hidden>
                <div class="room-gallery-backdrop" data-room-gallery-close></div>
                <div class="room-gallery-dialog" role="dialog" aria-modal="true" aria-labelledby="roomGalleryTitle">
                    <button type="button" class="room-gallery-close" data-room-gallery-close aria-label="Galeri kapat">
                        <i class="fas fa-times"></i>
                    </button>
                    <div class="room-gallery-stage">
                        <button type="button" class="room-gallery-nav prev" id="roomGalleryPrev" aria-label="Onceki gorsel">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <figure class="room-gallery-figure">
                            <img src="" alt="" id="roomGalleryMainImage" />
                            <figcaption id="roomGalleryTitle"></figcaption>
                        </figure>
                        <button type="button" class="room-gallery-nav next" id="roomGalleryNext" aria-label="Sonraki gorsel">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                    <div class="room-gallery-thumbs" id="roomGalleryThumbs"></div>
                </div>
            </div>
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Misafir Değerlendirmeleri</h2>
                <p>Yorumlar ve puan ortalamasi dogrudan veritabanindan alinmaktadir.</p>
            </div>

            <div class="review-summary">
                <div class="review-score">
                    <strong>@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "0.0")</strong>
                    <span>@Model.RatingText</span>
                    <small>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} yorum" : "Henuz yorum yok")</small>
                </div>
                <div class="review-bars">
                    <div><span>Genel</span><div class="bar"><span style="width:@(overallBarWidth)%"></span></div><strong>@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "-")</strong></div>
                    <div><span>Oda</span><div class="bar"><span style="width:@(roomBarWidth)%"></span></div><strong>@(roomScore > 0 ? roomScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Konum</span><div class="bar"><span style="width:@(locationBarWidth)%"></span></div><strong>@(locScore > 0 ? locScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Fiyat</span><div class="bar"><span style="width:@(valueBarWidth)%"></span></div><strong>@(valScore > 0 ? valScore.ToString("0.0") : "-")</strong></div>
                    <div><span>Personel</span><div class="bar"><span style="width:@(staffBarWidth)%"></span></div><strong>@(staffScore > 0 ? staffScore.ToString("0.0") : "-")</strong></div>
                </div>
            </div>

            @if (Model.Reviews.Count == 0)
            {
                <div class="review-card">
                    <p>Bu tesis icin onayli misafir yorumu bulunmuyor. Ilk yorumu yapan kullanıcı siz olabilirsiniz.</p>
                </div>
            }
            else
            {
                <div class="review-list">
                    @foreach (var review in Model.Reviews)
                    {
                        <article class="review-card">
                            <div class="review-meta">
                                <div class="review-avatar">@review.Avatar</div>
                                <div>
                                    <h4>@review.Name</h4>
                                    <p>@review.DateText</p>
                                </div>
                                <span class="review-chip">@review.Score.ToString("0.0")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(review.TravelProfile) || !string.IsNullOrWhiteSpace(review.SatisfactionLabel))
                            {
                                <p class="review-tags">
                                    @if (!string.IsNullOrWhiteSpace(review.TravelProfile))
                                    {
                                        <span>@review.TravelProfile</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(review.SatisfactionLabel))
                                    {
                                        <span>@review.SatisfactionLabel</span>
                                    }
                                </p>
                            }
                            <p>@review.Text</p>
                        </article>
                    }
                </div>
            }
        </article>

        <article class="content-card">
            <div class="section-head">
                <h2>Konum</h2>
                <p>@locationText</p>
            </div>
            <div class="map-card">
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <iframe
                        title="Otel Konum"
                        src="https://www.openstreetmap.org/export/embed.html?layer=mapnik&marker=@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)%2C@Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        loading="lazy"></iframe>
                }
                else
                {
                    <div class="map-fallback">
                        <strong>Koordinat bilgisi bekleniyor</strong>
                        <span>@Model.Address</span>
                    </div>
                }
            </div>
        </article>

    </div>

    <aside class="booking-sidebar">
