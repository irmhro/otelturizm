                <div class="tabler-section-headrow">
                    <div class="tabler-section-titles">
                        <h2>Oda Tipleri ve Fiyatlar</h2>
                        <p>Bu alandaki Odalardan rezervasyon Yapabilirsiniz</p>
                    </div>
                    <div class="tabler-section-actions">
                        <button type="button" class="tabler-section-action-btn is-primary" data-scroll-booking>
                            Rezervasyona geç
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>

            @if (Model.HasNoOpenRoomsForSelectedDate)
            {
                <div class="detail-alert is-warning" style="margin: 10px 0 14px;">
                    <strong>Bu otelde bugün boş oda yok</strong>
                    <p>@Model.NoOpenRoomsMessage</p>
                </div>
            }

            <div class="room-list">
                @{
                    var roomGalleryMap = new Dictionary<long, List<string>>();
                    var roomDetailsMap = new Dictionary<long, object>();
                }
                @foreach (var room in Model.Rooms)
                {
                    var roomGallery = room.GalleryImages.Count > 0
                        ? room.GalleryImages
                        : (!string.IsNullOrWhiteSpace(room.ImageUrl) ? new List<string> { room.ImageUrl } : new List<string>());
                    var roomCoverImage = !string.IsNullOrWhiteSpace(room.ImageUrl)
                        ? room.ImageUrl
                        : roomGallery.FirstOrDefault();

                    <div class="room-card">
                        <div class="room-card-main">
                            <div class="room-card-media">
                                @if (!string.IsNullOrWhiteSpace(roomCoverImage))
                                {
                                    <div class="room-card-cover">
                                        <button type="button"
                                                class="room-gallery-trigger"
                                                data-room-name="@room.Name"
                                                data-room-id="@room.RoomTypeId"
                                                data-room-gallery-start="0"
                                                aria-label="@room.Name galerisi">
                                            <span class="room-cover-title">@room.Name</span>
                                            <img src="@roomCoverImage" alt="@room.Name" />
                                            @if (roomGallery.Count > 1)
                                            {
                                                <span class="room-gallery-count">
                                                    <i class="fas fa-images"></i>
                                                    @roomGallery.Count gorsel
                                                </span>
                                            }
                                        </button>
                                    </div>
                                    @if (roomGallery.Count > 1)
                                    {
                                        <div class="room-thumb-strip" aria-label="@room.Name gorselleri">
                                            @for (var imageIndex = 0; imageIndex < Math.Min(roomGallery.Count, 6); imageIndex++)
                                            {
                                                <button type="button"
                                                        class="room-gallery-trigger room-thumb-item @(imageIndex == 0 ? "active" : string.Empty)"
                                                        data-room-name="@room.Name"
                                                        data-room-id="@room.RoomTypeId"
                                                        data-room-gallery-start="@imageIndex"
                                                        aria-label="@room.Name gorsel @(imageIndex + 1)">
                                                    <img src="@roomGallery[imageIndex]" alt="@room.Name gorsel @(imageIndex + 1)" />
                                                </button>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="room-card-media-placeholder"><i class="fas fa-bed"></i></div>
                                }
                            </div>
                            <div class="room-card-copy">
                                <h3>@room.Name</h3>
                                <p>@room.Specs</p>
                                @{
                                    var roomFeatureSeed = room.Features ?? new List<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>();
                                    var roomTopFeatures = roomFeatureSeed.Take(3).ToList();
                                    if (roomTopFeatures.Count < 3)
                                    {
                                        // Oda özellikleri azsa, otelin öne çıkan olanaklarından tamamla (tekrarları çıkar).
                                        var existing = new HashSet<string>(roomTopFeatures.Select(x => x.Name ?? string.Empty), StringComparer.OrdinalIgnoreCase);
                                        foreach (var amenity in Model.Amenities.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
                                        {
                                            if (roomTopFeatures.Count >= 3) break;
                                            if (!existing.Add(amenity.Name)) continue;
                                            roomTopFeatures.Add(new otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel
                                            {
                                                Name = amenity.Name,
                                                IconClass = string.IsNullOrWhiteSpace(amenity.IconClass) ? "fa-circle-check" : amenity.IconClass
                                            });
                                        }
                                    }

                                    var roomAllFeatures = (room.Features ?? Enumerable.Empty<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>())
                                        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                        .Select(x => new
                                        {
                                            Name = x.Name,
                                            IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                        })
                                        .ToList();

                                    if (roomAllFeatures.Count == 0)
                                    {
                                        roomAllFeatures = roomTopFeatures
                                            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                                            .Select(x => new
                                            {
                                                Name = x.Name,
                                                IconClass = string.IsNullOrWhiteSpace(x.IconClass) ? "fa-circle-check" : x.IconClass
                                            })
                                            .ToList();
                                    }
                                    roomGalleryMap[room.RoomTypeId] = roomGallery;
                                    roomDetailsMap[room.RoomTypeId] = roomAllFeatures;
                                }
                                <div class="room-feature-row">
                                    @if (roomTopFeatures.Count > 0)
                                    {
                                        <ul class="room-feature-list" aria-label="Öne çıkan oda özellikleri">
                                            @foreach (var feature in roomTopFeatures)
                                            {
                                                <li class="room-feature-item">
                                                    <i class="fas @feature.IconClass" aria-hidden="true"></i>
                                                    <span>@feature.Name</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if ((room.Features?.Count ?? 0) > 5)
                                    {
                                        <div class="room-feature-more-inline" data-room-feature-wrap>
                                            <button type="button"
                                                    class="amenities-btn amenities-btn--compact room-feature-more-btn"
                                                    data-room-feature-toggle
                                                    aria-expanded="false">
                                                Diğer özellikler
                                                <i class="fas fa-angle-down" aria-hidden="true"></i>
                                            </button>
                                            <div class="room-feature-panel" data-room-feature-panel hidden>
                                                <h4 class="room-feature-panel-title">Tüm Oda Olanakları</h4>
                                                <ul class="room-feature-panel-list" aria-label="Tüm oda olanakları">
                                                    @foreach (var feature in (room.Features ?? Enumerable.Empty<otelturizmnew.Models.Oteller.HotelRoomFeatureViewModel>()))
                                                    {
                                                        <li class="room-feature-panel-item">
                                                            <i class="fas @feature.IconClass" aria-hidden="true"></i>
                                                            <span>@feature.Name</span>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="room-card-aux">
                                    <button type="button"
                                            class="room-detail-btn room-detail-btn--link"
                                            data-room-detail-open
                                            data-room-name="@room.Name"
                                            data-room-id="@room.RoomTypeId"
                                            data-room-specs="@room.Specs"
                                            data-room-description="@room.DetailDescription"
                                            data-room-bed-type="@room.BedType"
                                            data-room-square-meter="@(room.SquareMeter?.ToString() ?? string.Empty)"
                                            data-room-max-guests="@room.MaxGuestCount"
                                            data-room-max-adults="@room.MaxAdultCount"
                                            data-room-max-children="@room.MaxChildCount"
                                            data-room-price="@(room.Price > 0m ? Model.GuestInclusiveNightlyFromStoredNet(room.Price).ToString("N0") : string.Empty)"
                                            data-room-cancellation="@room.CancellationText"
                                            data-room-feature-count="@roomAllFeatures.Count"
                                            data-room-gallery-count="@roomGallery.Count">
                                        Detaylar
                                        <i class="fas fa-arrow-right" aria-hidden="true"></i>
                                    </button>
                                    <span class="cancellation-badge"><i class="fas fa-check-circle"></i> @room.CancellationText</span>
                                </div>
                            </div>
                        </div>
                        <div class="room-price-box">
                            <div class="room-price-actions">
                                @if (room.Price > 0m)
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="@room.Price.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                                        Rezervasyon
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="select-room-btn"
                                            data-room-id="@room.RoomTypeId"
                                            data-price="0"
                                            disabled>
                                        Fiyat Yok
                                    </button>
                                }
                            </div>
                            <div class="room-price-value">
                                <small class="room-price-kicker">Gecelik</small>
                                @{
                                    var hasRoomDiscount = room.DiscountPrice.HasValue
                                                         && room.BasePrice.HasValue
                                                         && room.DiscountPrice.Value > 0m
                                                         && room.BasePrice.Value > 0m
                                                         && room.DiscountPrice.Value < room.BasePrice.Value;
                                    var baseDisplay = hasRoomDiscount ? Model.GuestInclusiveNightlyFromStoredNet(room.BasePrice!.Value) : 0m;
                                    var discountDisplay = hasRoomDiscount ? Model.GuestInclusiveNightlyFromStoredNet(room.DiscountPrice!.Value) : 0m;
                                    var discountPercent = hasRoomDiscount
                                        ? Math.Clamp((int)Math.Round(((baseDisplay - discountDisplay) / baseDisplay) * 100m, MidpointRounding.AwayFromZero), 1, 95)
                                        : 0;
                                }

                                @if (room.Price > 0m)
                                {
                                    var nightlyDisplay = Model.GuestInclusiveNightlyFromStoredNet(room.Price);
                                    var stayTotal = nightlyDisplay * initialNightCount;

                                    if (hasRoomDiscount)
                                    {
                                        <div class="room-price-discount-stack">
                                            <span class="room-price-old">₺@baseDisplay.ToString("N0")</span>
                                            <strong>₺@nightlyDisplay.ToString("N0")</strong>
                                            <span class="room-price-discount-pill">
                                                %@discountPercent
                                                @if (room.DiscountId.HasValue && !string.IsNullOrWhiteSpace(room.DiscountName))
                                                {
                                                    <button type="button"
                                                            class="discount-info-btn"
                                                            data-discount-open
                                                            data-discount-title="@room.DiscountName"
                                                            data-discount-desc="@room.DiscountShortDescription"
                                                            data-discount-image="@room.DiscountImageUrl"
                                                            aria-label="İndirim detayını görüntüle">
                                                        <i class="fas fa-circle-info" aria-hidden="true"></i>
                                                    </button>
                                                }
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <strong>₺@nightlyDisplay.ToString("N0")</strong>
                                    }

                                    <span class="room-price-inclusive-label" title="Tüm vergiler dahil fiyat">Vergiler dahil</span>
                                    <small class="room-price-total">Toplam (@initialNightCount gece): ₺@stayTotal.ToString("N0")</small>
                                }
                                else
                                {
                                    <strong>Fiyat Yok</strong>
                                    <span class="room-price-unavailable">Bu oda icin aktif fiyat bulunamadi</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

