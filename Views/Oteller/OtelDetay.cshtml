@model otelturizmnew.Models.Oteller.HotelDetailPageViewModel
@using System.Security.Claims
@using otelturizmnew.Constants
@inject otelturizmnew.Services.Abstractions.IReservationDraftService ReservationDraftService

@{
    ViewData["Title"] = Model.Name;
    ViewData["SuppressGlobalDraftBanner"] = true;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.ShortDescription)
        ? $"{Model.Name} · {Model.District}, {Model.City}. Oda seçeneklerini inceleyin ve güvenle rezervasyon oluşturun."
        : Model.ShortDescription;
    ViewData["Canonical"] = $"{baseUrl}/oteller/{Model.Slug}";
    ViewData["OgImage"] = Model.MainImageUrl;

    try
    {
        var hotelJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Hotel",
            ["name"] = Model.Name,
            ["url"] = $"{baseUrl}/oteller/{Model.Slug}",
            ["image"] = string.IsNullOrWhiteSpace(Model.MainImageUrl) ? null : Model.MainImageUrl,
            ["address"] = new Dictionary<string, object?>
            {
                ["@type"] = "PostalAddress",
                ["addressLocality"] = Model.District,
                ["addressRegion"] = Model.City,
                ["addressCountry"] = "TR"
            },
            ["geo"] = (Model.Latitude.HasValue && Model.Longitude.HasValue)
                ? new Dictionary<string, object?>
                {
                    ["@type"] = "GeoCoordinates",
                    ["latitude"] = Model.Latitude.Value,
                    ["longitude"] = Model.Longitude.Value
                }
                : null,
            ["aggregateRating"] = Model.Rating > 0
                ? new Dictionary<string, object?>
                {
                    ["@type"] = "AggregateRating",
                    ["ratingValue"] = Model.Rating,
                    ["bestRating"] = 10,
                    ["worstRating"] = 0
                }
                : null
        };

        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Oteller", ["item"] = $"{baseUrl}/oteller" },
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = Model.Name, ["item"] = $"{baseUrl}/oteller/{Model.Slug}" }
            }
        };

        var json = System.Text.Json.JsonSerializer.Serialize(new object[] { breadcrumbJsonLd, hotelJsonLd },
            new System.Text.Json.JsonSerializerOptions { DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull });
        ViewData["JsonLd"] = json;
    }
    catch
    {
        // fail-safe
    }
    var gallery = Model.GalleryImages.Count > 0 ? Model.GalleryImages : new List<string> { Model.MainImageUrl };
    var mainImage = gallery.FirstOrDefault() ?? string.Empty;
    var roomSelectOptions = Model.Rooms.Count > 0 ? Model.Rooms : new List<otelturizmnew.Models.Oteller.HotelRoomViewModel>
    {
        new()
        {
            RoomTypeId = 0,
            Name = "Standart Oda",
            Specs = "2 Kisi",
            Price = Model.LowestRoomPrice,
            CancellationText = "Ücretsiz iptal"
        }
    };
    var reservableRoomOptions = roomSelectOptions.Where(x => x.Price > 0m).ToList();
    if (reservableRoomOptions.Count == 0)
    {
        reservableRoomOptions = roomSelectOptions;
    }
    var reservationForm = Model.ReservationForm ?? new otelturizmnew.Models.Reservations.PublicHotelReservationForm { HotelId = Model.Id, RoomTypeId = reservableRoomOptions.FirstOrDefault()?.RoomTypeId ?? 0 };
    var selectedRoomSeed = reservableRoomOptions.FirstOrDefault(x => x.RoomTypeId == reservationForm.RoomTypeId) ?? reservableRoomOptions.First();
    var roomPriceSeed = selectedRoomSeed.Price;
    var checkInDefault = reservationForm.CheckInDate.ToString("yyyy-MM-dd");
    var checkOutDefault = reservationForm.CheckOutDate.ToString("yyyy-MM-dd");
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");
    var reservationAdultCutoffDate = DateTime.Today.AddYears(-18).AddDays(-1);
    var reservationAdultCutoffText = reservationAdultCutoffDate.ToString("yyyy-MM-dd");
    var locationText = $"{Model.District}, {Model.City}";
    var longDescription = string.IsNullOrWhiteSpace(Model.LongDescription) ? Model.ShortDescription : Model.LongDescription;
    var overallBarWidth = Model.Rating > 0 ? Math.Min(100m, Model.Rating * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var locScore = Model.ReviewLocationScore > 0 ? Model.ReviewLocationScore : Model.Rating;
    var cleaningScore = Model.ReviewCleaningScore > 0 ? Model.ReviewCleaningScore : (Model.ReviewRoomScore > 0 ? Model.ReviewRoomScore : Model.Rating);
    var valScore = Model.ReviewValueScore > 0 ? Model.ReviewValueScore : Model.Rating;
    var staffScore = Model.ReviewStaffScore > 0 ? Model.ReviewStaffScore : Model.Rating;
    var quietScore = Model.ReviewQuietnessScore > 0 ? Model.ReviewQuietnessScore : Model.Rating;
    var transportScore = Model.ReviewTransportScore > 0 ? Model.ReviewTransportScore : locScore;
    var locationBarWidth = locScore > 0 ? Math.Min(100m, locScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var cleaningBarWidth = cleaningScore > 0 ? Math.Min(100m, cleaningScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var valueBarWidth = valScore > 0 ? Math.Min(100m, valScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var staffBarWidth = staffScore > 0 ? Math.Min(100m, staffScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var quietBarWidth = quietScore > 0 ? Math.Min(100m, quietScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var transportBarWidth = transportScore > 0 ? Math.Min(100m, transportScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var featuredAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Take(4)
        .ToList();
    var featuredAmenityFallbacks = new List<otelturizmnew.Models.Oteller.HotelAmenityViewModel>
    {
        new() { Name = "24 Saat Resepsiyon", IconClass = "fa-clock" },
        new() { Name = "Ucretsiz WiFi", IconClass = "fa-wifi" },
        new() { Name = "Restoran", IconClass = "fa-utensils" },
        new() { Name = "Fitness Merkezi", IconClass = "fa-dumbbell" }
    };
    foreach (var fallbackItem in featuredAmenityFallbacks)
    {
        if (featuredAmenities.Count >= 4)
        {
            break;
        }

        if (featuredAmenities.Any(x => string.Equals(x.Name, fallbackItem.Name, StringComparison.OrdinalIgnoreCase)))
        {
            continue;
        }

        featuredAmenities.Add(fallbackItem);
    }
    var hiddenAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Skip(4)
        .ToList();
    var initialNightCount = Math.Max(1, reservationForm.CheckOutDate.DayNumber - reservationForm.CheckInDate.DayNumber);
    var initialRooms = Math.Max(1, reservationForm.RoomCount);
    var initialTotal = roomPriceSeed * initialNightCount * initialRooms;
    var vatRateFrac = Model.TaxDisplayVatPercent / 100m;
    var accomRateFrac = Model.TaxDisplayAccommodationPercent / 100m;
    var taxDivisor = 1m + vatRateFrac + accomRateFrac;
    var initialSubtotal = taxDivisor > 0m ? Math.Round(initialTotal / taxDivisor, 0) : initialTotal;
    var initialVat = Math.Round(initialSubtotal * vatRateFrac, 0);
    var initialAccommodationTax = Math.Max(0m, initialTotal - initialSubtotal - initialVat);
    var initialTax = initialVat + initialAccommodationTax;
    var initialInclusiveNightly = initialNightCount > 0 && initialRooms > 0
        ? Math.Round(initialTotal / initialNightCount / initialRooms, 0)
        : 0m;
    var todayWeather = Model.Weather?.Days.FirstOrDefault();
    var weatherThemeClass = "weather-theme-cloudy";
    var weatherThemeTitle = "İlçe bazlı hava durumu";
    var weatherThemeSummary = "Bugün için dengeli bir gezi ritmi planlayabilirsiniz.";
    var weatherAccentIcon = "fa-cloud-sun";
    var mapLatitude = Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var mapLongitude = Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture);

    if (todayWeather is not null)
    {
        if (todayWeather.ConditionText.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-rainy";
            weatherThemeTitle = "Yağış etkili görünüyor";
            weatherThemeSummary = "Şemsiye ile çıkmak akıllı olur. Kapalı alanlar, kafe ve iç mekan planları öne çıkabilir.";
            weatherAccentIcon = "fa-cloud-showers-heavy";
        }
        else if (todayWeather.ConditionText.Contains("Açık", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-sunny";
            weatherThemeTitle = "Güneşli bir tempo sizi bekliyor";
            weatherThemeSummary = "Açık hava programları, sahil rotaları ve teras deneyimleri için güzel bir görünüm var.";
            weatherAccentIcon = "fa-sun";
        }
        else if (todayWeather.ConditionText.Contains("Kar", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-snowy";
            weatherThemeTitle = "Serin ve kis dokulu hava";
            weatherThemeSummary = "Dış planlarında daha sıcak giyinmek faydalı olur. Sıcak içecek ve iç mekan deneyimleri daha keyifli olabilir.";
            weatherAccentIcon = "fa-snowflake";
        }
    }

    string GetAmenitySubtext(string amenityName)
    {
        var value = amenityName.ToLowerInvariant();
        if (value.Contains("havuz")) return "Ucretsiz kullanim";
        if (value.Contains("spa") || value.Contains("hamam") || value.Contains("sauna")) return "Hamam, sauna, masaj";
        if (value.Contains("restoran") || value.Contains("bar")) return "Gurme mutfak";
        if (value.Contains("wifi") || value.Contains("wi-fi")) return "Tum odalarda";
        if (value.Contains("otopark")) return "Vale ve acik otopark";
        return "Tesis olanağı";
    }
}

<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      crossorigin="anonymous" />
<link rel="stylesheet" href="~/assets/css/otel-detay-reservation.css" asp-append-version="true" />

<div class="otel-detail-template-v41 otel-detail-tabler">
<section class="detail-breadcrumb detail-breadcrumb-with-weather">
    <div class="detail-breadcrumb-left">
        <a asp-controller="Oteller" asp-action="OtelListeleme" class="detail-back-link">
            <i class="fas fa-arrow-left"></i>
            <span>Otellere Dön</span>
        </a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">·</span>
        <a class="detail-breadcrumb-context"
           href="@Url.Action("OtelListeleme", "Oteller", new { q = $"{Model.District} {Model.City}".Trim(), city = (string?)null, page = 1 })"
           aria-label="Bu bölgedeki otelleri listele">
            <i class="fas fa-location-dot"></i>
            <strong>@Model.District</strong><span class="detail-breadcrumb-muted">, @Model.City</span>
        </a>
    </div>
    <div class="detail-breadcrumb-right" aria-label="Hızlı işlemler">
        <button type="button"
                id="startConversationBtn"
                class="detail-quick-action is-attention is-tone-talk"
                data-hotel-slug="@Model.Slug"
                data-authenticated="@(Model.IsLoggedInUser ? "true" : "false")"
                data-can-start="@(Model.HasCompletedReservationAtHotel ? "true" : "false")"
                data-info-message="@Model.ConversationInfoMessage"
                aria-label="Görüşme Başlat">
            <i class="far fa-comments" aria-hidden="true"></i>
            <span>Görüşme Başlat</span>
        </button>
        <div class="detail-share-wrap">
            <button type="button" id="shareHotelBtn" class="detail-quick-action is-tone-share" aria-haspopup="true" aria-expanded="false" aria-controls="shareMenu" aria-label="Paylaş">
                <i class="far fa-share-square" aria-hidden="true"></i>
                <span>Paylaş</span>
            </button>
            <div class="share-menu share-menu--top" id="shareMenu" hidden>
                <p class="share-menu-title">Bu oteli paylas</p>
                <div class="share-menu-grid">
                    <a href="#" data-share-platform="whatsapp" target="_blank" rel="noopener">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                    <a href="#" data-share-platform="facebook" target="_blank" rel="noopener">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="#" data-share-platform="x" target="_blank" rel="noopener">
                        <i class="fab fa-x-twitter"></i>
                        <span>X</span>
                    </a>
                    <a href="#" data-share-platform="instagram" target="_blank" rel="noopener">
                        <i class="fab fa-instagram"></i>
                        <span>Instagram</span>
                    </a>
                    <a href="#" data-share-platform="telegram" target="_blank" rel="noopener">
                        <i class="fab fa-telegram-plane"></i>
                        <span>Telegram</span>
                    </a>
                    <button type="button" data-share-platform="copy">
                        <i class="fas fa-link"></i>
                        <span>Link Kopyala</span>
                    </button>
                </div>
                <button type="button" class="share-more-btn" data-share-platform="more">
                    <i class="fas fa-share-nodes"></i>
                    Diger Platformlar
                </button>
            </div>
        </div>
        <button type="button"
                id="saveHotelBtnTop"
                class="detail-quick-action favorite-btn is-tone-fav @(Model.IsFavorite ? "active" : string.Empty)"
                data-hotel-id="@Model.Id"
                data-source-page="OtelDetay"
                aria-label="Favoriye ekle">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart" aria-hidden="true"></i>
            <span data-favorite-label>@(Model.IsFavorite ? "Favoride" : "Favoriye Ekle")</span>
        </button>
    </div>
</section>

<section class="gallery-grid">
    <div class="gallery-main-image" style="--hotel-main-ambient: url('@mainImage');">
        @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
        {
            <div class="gallery-star-badge" aria-label="@($"{Model.StarCount.Value} yıldızlı otel")">
                @for (var i = 0; i < Model.StarCount.Value; i++)
                {
                    <i class="fas fa-star" aria-hidden="true"></i>
                }
            </div>
        }
        <button type="button"
                id="saveHotelBtnGallery"
                class="favorite-btn gallery-favorite-btn @(Model.IsFavorite ? "active" : string.Empty)"
                data-hotel-id="@Model.Id"
                data-source-page="OtelDetay"
                aria-label="Favoriye ekle">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart" aria-hidden="true"></i>
            <span class="sr-only" data-favorite-label>@(Model.IsFavorite ? "Favoride" : "Favoriye Ekle")</span>
        </button>
        <button type="button" class="gallery-main-trigger" data-gallery-index="0" aria-label="Galeriyi ac">
            <img src="@mainImage" alt="@Model.Name" id="mainGalleryImage" fetchpriority="high" decoding="async" />
        </button>

        @if (gallery.Count > 0)
        {
            <div class="gallery-count-badge" id="galleryCountBadge" aria-label="Galeri görsel sayacı">
                <span class="gallery-count-badge__current">1</span>
                <span class="gallery-count-badge__sep">/</span>
                <span class="gallery-count-badge__total">@gallery.Count</span>
            </div>
        }

        @if (Model.ActiveViewerBand > 0)
        {
            <div class="gallery-proof-badge" role="status" aria-live="polite">
                <i class="fas fa-eye" aria-hidden="true"></i>
                <span>Son dakikalarda bu otele yaklaşık <strong>@Model.ActiveViewerBand</strong> ilgi gösterdi.</span>
            </div>
        }

        <div class="gallery-proof-badge gallery-proof-badge--presence"
             id="livePresenceLine"
             role="status"
             aria-live="polite"
             hidden>
            <i class="fas fa-users" aria-hidden="true"></i>
            <span>Şu anda bu otelin sayfasında yaklaşık <strong id="livePresenceCount">@Model.LivePresenceCount</strong> aktif oturum var.</span>
        </div>
    </div>
    <div class="gallery-side-grid">
        @for (var imageIndex = 1; imageIndex < gallery.Count && imageIndex <= 4; imageIndex++)
        {
            var image = gallery[imageIndex];
            <button type="button" class="gallery-thumb" data-image="@image" data-gallery-index="@imageIndex">
                <img src="@image" alt="@Model.Name galeri @imageIndex" />
            </button>
        }
    </div>
 </section>
 @if (gallery.Count > 0)
 {
    <section class="gallery-filmstrip-wrap" aria-label="Otel galerisi">
        <div class="gallery-filmstrip">
            @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
            {
                <button type="button"
                        class="gallery-filmstrip-thumb @(imageIndex == 0 ? "active" : string.Empty)"
                        data-gallery-index="@imageIndex"
                        aria-label="Otel gorsel @(imageIndex + 1)">
                    <img src="@gallery[imageIndex]" alt="@Model.Name gorsel @(imageIndex + 1)" />
                </button>
            }
        </div>
    </section>
 }
    @if (gallery.Count > 1)
    {
        <section class="gallery-mobile-strip" id="galleryMobileStrip" aria-label="Mobil galeri slider">
            @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
            {
                <div class="gallery-star-badge gallery-star-badge-mobile" aria-label="@($"{Model.StarCount.Value} yıldızlı otel")">
                    @for (var i = 0; i < Model.StarCount.Value; i++)
                    {
                        <i class="fas fa-star" aria-hidden="true"></i>
                    }
                </div>
            }
            <div class="gallery-mobile-track" id="galleryMobileTrack">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button" class="gallery-mobile-slide" data-image="@gallery[imageIndex]" data-gallery-index="@imageIndex" aria-label="Gorsel @(imageIndex + 1)">
                        <img src="@gallery[imageIndex]" alt="@Model.Name mobil galeri @(imageIndex + 1)" />
                    </button>
                }
            </div>
            <div class="gallery-mobile-dots" id="galleryMobileDots" role="tablist" aria-label="Galeri gezinme">
                @for (var imageIndex = 0; imageIndex < gallery.Count; imageIndex++)
                {
                    <button type="button"
                            class="gallery-mobile-dot @(imageIndex == 0 ? "active" : string.Empty)"
                            data-gallery-dot-index="@imageIndex"
                            aria-label="Gorsel @(imageIndex + 1)"
                            aria-selected="@(imageIndex == 0 ? "true" : "false")"></button>
                }
            </div>
        </section>
    }

@* Eski lightbox/slider DOM'u kaldırıldı: ortak SlaytGorsel (layout + slaytgorsel.js) kullanılıyor. *@

<section class="detail-header hotel-title-section">
    <div class="hotel-name">
        <h1>
            @Model.Name
        </h1>
        @{
            string? ExtractNeighborhood(string? address)
            {
                var a = (address ?? string.Empty).Trim();
                if (a.Length == 0) return null;

                var idx = a.IndexOf("Mahallesi", StringComparison.OrdinalIgnoreCase);
                if (idx > 0)
                {
                    return a.Substring(0, idx + "Mahallesi".Length).Trim();
                }

                idx = a.IndexOf("Mah.", StringComparison.OrdinalIgnoreCase);
                if (idx > 0)
                {
                    return a.Substring(0, idx + "Mah.".Length).Trim();
                }

                return null;
            }

            var neighborhood = ExtractNeighborhood(Model.Address);
            var locationPieces = new List<string>();
            if (!string.IsNullOrWhiteSpace(neighborhood)) locationPieces.Add(neighborhood);
            if (!string.IsNullOrWhiteSpace(Model.District)) locationPieces.Add(Model.District);
            if (!string.IsNullOrWhiteSpace(Model.City)) locationPieces.Add(Model.City);
            var locationOnly = string.Join(", ", locationPieces);
        }
        <p class="detail-location"><i class="fas fa-location-dot"></i> @locationOnly</p>
        <div class="detail-title-subnav" aria-label="Hızlı gezinme">
            @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
            {
                <button type="button" class="detail-title-subnav-btn is-secondary" data-open-hotel-video>
                    <i class="fab fa-youtube" aria-hidden="true"></i>
                    Otel videosu
                </button>
            }

            @if (Model.CampaignNames.Count > 0)
            {
                <a class="detail-title-subnav-badge is-campaign" href="#" data-campaign-slot="0" hidden>
                    <i class="fas fa-tag" aria-hidden="true"></i>
                    <span></span>
                </a>
                <a class="detail-title-subnav-badge is-campaign" href="#" data-campaign-slot="1" hidden>
                    <i class="fas fa-tag" aria-hidden="true"></i>
                    <span></span>
                </a>
                <script type="application/json" id="hotelCampaignPayloadJson">
                    @{
                        var items = new List<object>();
                        var count = Math.Min(Model.CampaignNames.Count, Model.CampaignSlugs.Count);
                        for (var i = 0; i < count; i++)
                        {
                            items.Add(new { name = Model.CampaignNames[i], slug = Model.CampaignSlugs[i] });
                        }
                    }
                    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(items))
                </script>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.IntentSegmentLabel))
        {
            <p class="detail-intent text-muted small mb-0">Seyahat profili: @Model.IntentSegmentLabel</p>
        }

    </div>
    <div class="header-right-stack">
        <div class="header-top-metrics">
            <div class="detail-utility-row">
                <button type="button"
                        class="weather-inline-trigger @(Model.Weather is not null && Model.Weather.Days.Count > 0 ? weatherThemeClass : "weather-theme-cloudy")"
                        id="weatherPopupOpen"
                        data-has-weather="@(Model.Weather is not null && Model.Weather.Days.Count > 0 ? "true" : "false")"
                        aria-haspopup="dialog"
                        aria-controls="weatherPopup">
                    <span class="weather-inline-icon">
                        <i class="fas @(todayWeather?.IconClass ?? "fa-cloud-sun")"></i>
                    </span>
                    <span class="weather-inline-copy">
                        <strong>Hava durumu</strong>
                        <small>
                            @if (Model.Weather is not null && Model.Weather.Days.Count > 0)
                            {
                                @Model.Weather.LocationLabel
                                @if (!string.IsNullOrWhiteSpace(todayWeather?.TemperatureText))
                                {
                                    <text> • @todayWeather!.TemperatureText</text>
                                }
                                @if (!string.IsNullOrWhiteSpace(todayWeather?.ConditionText))
                                {
                                    <text> • @todayWeather!.ConditionText</text>
                                }
                            }
                            else
                            {
                                <text>@Model.District, @Model.City • Tahmin yüklenemedi</text>
                            }
                        </small>
                    </span>
                    <span class="weather-inline-badge">3 Gunluk</span>
                </button>
            </div>
            <div class="rating-summary" id="ratingSummaryJump" role="button" tabindex="0" aria-label="Yorumlara git">
                <div class="rating-big">
                    <span class="rating-number">@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "0.0")</span>
                    <span class="rating-max">/10</span>
                </div>
                <div class="rating-text">
                    <strong>@Model.RatingText</strong><br />
                    <span>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} yorum" : "Henuz yorum yok")</span>
                </div>
            </div>
        </div>
    </div>
</section>

@if (TempData["PublicReservationInfo"] is string infoMessage)
{
    @* Bu bilgi mesajını artık sağ alttaki "tamamlanmayan rezervasyon" bildirimi karşılıyor. *@
    if (!infoMessage.Contains("Rezervasyonunuz kaydedildi", StringComparison.OrdinalIgnoreCase)
        && !infoMessage.Contains("Rezervasyon taslak olarak kaydedildi", StringComparison.OrdinalIgnoreCase)
        && !infoMessage.Contains("profil bilgilerinizi tamamlayin", StringComparison.OrdinalIgnoreCase)
        && !infoMessage.Contains("profil bilgilerinizi tamamlayın", StringComparison.OrdinalIgnoreCase))
    {
        <div class="detail-inline-feedback info">@infoMessage</div>
    }
}

@{
    string FixMojibake(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        // Common UTF-8-as-ANSI mojibake fixes for Turkish content.
        return value
            .Replace("Ã‡", "Ç", StringComparison.Ordinal)
            .Replace("Ã§", "ç", StringComparison.Ordinal)
            .Replace("Ä±", "ı", StringComparison.Ordinal)
            .Replace("Ä°", "İ", StringComparison.Ordinal)
            .Replace("Ã–", "Ö", StringComparison.Ordinal)
            .Replace("Ã¶", "ö", StringComparison.Ordinal)
            .Replace("Ãœ", "Ü", StringComparison.Ordinal)
            .Replace("Ã¼", "ü", StringComparison.Ordinal)
            .Replace("Åž", "Ş", StringComparison.Ordinal)
            .Replace("ÅŸ", "ş", StringComparison.Ordinal)
            .Replace("ÄŸ", "ğ", StringComparison.Ordinal)
            .Replace("Äž", "Ğ", StringComparison.Ordinal)
            .Replace("Â", "", StringComparison.Ordinal);
    }

    string MaskName(string? fullName)
    {
        var name = (fullName ?? "Misafir").Trim();
        if (string.IsNullOrWhiteSpace(name) || string.Equals(name, "Misafir", StringComparison.OrdinalIgnoreCase))
        {
            return "Misafir";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0];
        }

        var firstName = parts[0];
        var lastName = parts[^1];
        var lastPrefix = lastName.Length <= 3 ? lastName : lastName.Substring(0, 3);
        return $"{firstName} {lastPrefix}***";
    }

    var reviewSort = (Context.Request.Query["reviewSort"].ToString() ?? "new").Trim().ToLowerInvariant();
    var reviewPageRaw = Context.Request.Query["reviewPage"].ToString();
    var reviewPage = int.TryParse(reviewPageRaw, out var parsedReviewPage) ? Math.Max(1, parsedReviewPage) : 1;
    const int reviewPageSize = 10;

    var sortedReviews = (Model.Reviews ?? new List<otelturizmnew.Models.Oteller.HotelReviewViewModel>()).ToList();
    sortedReviews = reviewSort switch
    {
        "old" => sortedReviews.OrderBy(r => r.DateText).ToList(),
        "best" => sortedReviews.OrderByDescending(r => r.Score).ToList(),
        "worst" => sortedReviews.OrderBy(r => r.Score).ToList(),
        _ => sortedReviews.ToList()
    };
    if (reviewSort == "new")
    {
        sortedReviews = sortedReviews.ToList();
    }

    var totalReviewCount = sortedReviews.Count;
    var totalReviewPages = (int)Math.Ceiling(totalReviewCount / (double)reviewPageSize);
    if (totalReviewPages <= 0) totalReviewPages = 1;
    if (reviewPage > totalReviewPages) reviewPage = totalReviewPages;
    var pagedReviews = sortedReviews.Skip((reviewPage - 1) * reviewPageSize).Take(reviewPageSize).ToList();
    var signatureScore = Model.Rating > 0 ? Math.Round(Model.Rating, 2) : 0m;

    string NormalizeReviewText(string? value)
    {
        return (FixMojibake(value ?? string.Empty) ?? string.Empty).ToLower(new System.Globalization.CultureInfo("tr-TR"));
    }

    var reviewTopicDefinitions = new[]
    {
        new { Key = "konum", Label = "Konum", Icon = "fa-location-dot", Emoji = "📍", BaseScore = locScore > 0 ? locScore : signatureScore, Keywords = new[] { "konum", "merkez", "lokasyon", "yakın", "yakin", "mesafe", "sahil" } },
        new { Key = "temizlik", Label = "Temizlik", Icon = "fa-soap", Emoji = "🫧", BaseScore = cleaningScore > 0 ? cleaningScore : signatureScore, Keywords = new[] { "temiz", "temizlik", "hijyen", "nevresim", "banyo", "duş", "dus", "ferah" } },
        new { Key = "personel", Label = "Personel", Icon = "fa-user-group", Emoji = "🤝", BaseScore = staffScore > 0 ? staffScore : signatureScore, Keywords = new[] { "personel", "çalışan", "calisan", "güler", "guler", "yardımcı", "yardimci", "karşılama", "karsilama", "iletişim", "iletisim" } },
        new { Key = "fiyat", Label = "Fiyat/Performans", Icon = "fa-tags", Emoji = "🏷️", BaseScore = valScore > 0 ? valScore : signatureScore, Keywords = new[] { "fiyat", "performans", "uygun", "pahalı", "pahali", "değer", "deger", "fiyatına", "fiyatina" } },
        new { Key = "sessizlik", Label = "Sessizlik", Icon = "fa-moon", Emoji = "🌙", BaseScore = quietScore > 0 ? quietScore : signatureScore, Keywords = new[] { "sessiz", "gürültü", "gurultu", "gece", "uyku", "rahat", "huzurlu", "izolasyon" } },
        new { Key = "ulasim", Label = "Ulaşım", Icon = "fa-route", Emoji = "🧭", BaseScore = transportScore > 0 ? transportScore : signatureScore, Keywords = new[] { "ulasim", "ulaşım", "metro", "metrobüs", "metrobus", "otobüs", "otobus", "iskele", "havaalanı", "havalimanı", "tramvay" } }
    };

    var reviewTopicPayload = reviewTopicDefinitions.Select(def =>
    {
        var matchCount = sortedReviews.Count(r =>
        {
            var text = NormalizeReviewText(r.Text);
            return def.Keywords.Any(k => text.Contains(k, StringComparison.Ordinal));
        });
        var normalizedScore = Math.Max(0m, Math.Min(10m, def.BaseScore + (matchCount > 0 ? 0.12m : 0m)));
        return new
        {
            key = def.Key,
            label = def.Label,
            icon = def.Icon,
            emoji = def.Emoji,
            count = matchCount,
            score = normalizedScore.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture),
            keywords = def.Keywords
        };
    }).ToList();

    var reviewFeedPayload = sortedReviews.Select(r =>
    {
        var normalized = NormalizeReviewText(r.Text);
        var topicKeys = reviewTopicDefinitions
            .Where(def => def.Keywords.Any(k => normalized.Contains(k, StringComparison.Ordinal)))
            .Select(def => def.Key)
            .Distinct()
            .ToList();
        return new
        {
            name = MaskName(r.Name),
            date = r.DateText,
            score = r.Score.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture),
            text = FixMojibake(r.Text),
            topics = topicKeys
        };
    }).ToList();

    var reviewTopicPayloadJson = System.Text.Json.JsonSerializer.Serialize(reviewTopicPayload);
    var reviewFeedPayloadJson = System.Text.Json.JsonSerializer.Serialize(reviewFeedPayload);
}

<section class="detail-grid">
    <div class="detail-content">
        <article class="content-card">
            <div class="section-head tabler-section-head">
                <div class="tabler-section-headrow">
