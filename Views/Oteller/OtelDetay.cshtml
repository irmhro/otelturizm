                        <h2>Tesis Hakkinda</h2>
                        <p class="hotel-about-text" id="hotelAboutText">
                            @(!string.IsNullOrWhiteSpace(Model.LocationDescription) ? Model.LocationDescription : longDescription)
                        </p>
                    </div>
                    <div class="tabler-section-actions">
                        <button type="button" class="tabler-section-action-btn" data-about-toggle hidden>
                            Tümünü gör
                            <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="hotel-about-toggle" id="hotelAboutToggle" hidden>
                            Tümünü gör
                        </button>
                    </div>
                </div>
            </div>
        </article>

        <article class="content-card featured-amenities-card">
            <div class="section-head tabler-section-head">
                <div class="tabler-section-headrow">
                    <div class="tabler-section-titles">
                        <h2>Tesis Ozellikleri</h2>
                        <p>Konaklama deneyimini guclendiren one cikan tesis ozellikleri.</p>
                    </div>
                    @if (Model.Amenities.Count > 0)
                    {
                        <div class="tabler-section-actions">
                            <button type="button" class="tabler-section-action-btn" data-open-amenities>
                                Tüm özellikler
                                <i class="fas fa-chevron-right" aria-hidden="true"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>
            <div class="amenities-list-clean" role="list" aria-label="Tesis ozellik listesi">
                @foreach (var item in featuredAmenities)
                {
                    <div class="amenities-list-item" role="listitem">
                        <span class="amenities-list-item-icon" aria-hidden="true">
                            <i class="fas @item.IconClass"></i>
                        </span>
                        <span class="amenities-list-item-copy">
                            <strong>@item.Name</strong>
                            <small>@GetAmenitySubtext(item.Name)</small>
                        </span>
                    </div>
                }
