                    openProfileCompletionModal('Rezervasyona devam edebilmek için profil bilgilerinizi tamamlayın.');
                    return;
                }

                document.querySelector('.booking-sidebar')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            function openActiveDraftPrompt() {
                if (!infoModal || !infoModalText || !infoModalActions) {
                    return;
                }

                const msg = (activeDraftPromptMessage || '').trim()
                    || 'Yarım kalan bir rezervasyon taslağınız var. Devam etmek veya iptal etmek ister misiniz?';
                infoModalText.textContent = msg;
                const titleEl = document.getElementById('detailInfoModalTitle');
                if (titleEl) {
                    titleEl.innerHTML = '<span class="detail-modal-title-icon" aria-hidden="true"><i class="fas fa-triangle-exclamation"></i></span><span>Rezervasyon taslağı</span>';
                }

                infoModal.classList.add('is-warning');
                infoModalActions.innerHTML =
                    '<button type="button" class="detail-modal-primary" id="activeDraftContinueBtn">Devam Et</button>'
                    + '<button type="button" class="detail-modal-secondary" id="activeDraftCancelBtn">İptal Et</button>'
                    + '<button type="button" class="detail-modal-secondary" data-close-modal="detailInfoModal">Şimdi değil</button>';

                openModal(infoModal);

                document.getElementById('activeDraftContinueBtn')?.addEventListener('click', function () {
                    closeModal(infoModal);
                    infoModal.classList.remove('is-warning');
                    if ((activeDraftResumeUrl || '').trim()) {
                        window.location.href = activeDraftResumeUrl;
                    } else {
                        resumeDraftFlow();
                    }
                });
                document.getElementById('activeDraftCancelBtn')?.addEventListener('click', function () {
                    closeModal(infoModal);
                    infoModal.classList.remove('is-warning');
                    if (cancelDraftForm instanceof HTMLFormElement) {
                        cancelDraftForm.submit();
                    }
                });
                infoModalActions.querySelectorAll('[data-close-modal]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        closeModal(infoModal);
                        infoModal.classList.remove('is-warning');
                    });
                });
            }

            function isDoorPaymentValue(value) {
                const v = (value || '').trim();
                return v === 'Kapıda nakit ödeme'
                    || v === 'Kapıda kart ile ödeme'
                    || v === 'Kapıda Ödeme';
            }

            function isPaymentMethodChosen() {
                return isDoorPaymentValue(paymentMethodSelect?.value || '');
            }

            function getGuestCheckOutTimeValue() {
                return (checkOutTimeInput?.value || '').trim();
            }

            function getHotelStandardCheckOutTime() {
                return (bookingAdvancedFields?.dataset?.hotelCheckOut || '12:00').trim();
            }

            function isLateCheckoutSelection() {
                const guest = getGuestCheckOutTimeValue();
                const standard = getHotelStandardCheckOutTime();
                if (!guest || !standard) {
                    return false;
                }
                return guest > standard;
            }

            let lastQuoteUnavailable = false;
            let lastBookingTotalAmount = 0;

            function syncReserveButtonEnabled() {
                const reserveButton = bookingForm?.querySelector('.reserve-btn');
                if (!reserveButton) {
                    return;
                }

                const blocked = lastQuoteUnavailable;
                if (blocked) {
                    reserveButton.setAttribute('disabled', 'disabled');
                } else {
                    reserveButton.removeAttribute('disabled');
                }
            }

            function syncPaymentMethodState() {
                syncReserveButtonEnabled();
            }

            function openProfileCompletionModal(message) {
                hydrateProfileAddressSelectors();
                if (profileFeedback && message) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = message;
                }
                openModal(profileModal);
