                            <small>@dayConditionSafe</small>
                        </div>
                    </div>
                    <span class="detail-weather-note">@FixMojibake(day.DateLabel)</span>
                    <em class="detail-weather-precip">@FixMojibake(day.PrecipitationText)</em>
                </article>
            }
        </div>
    </section>
}
