                                <option value="Online Ödeme" selected="@(string.Equals(reservationForm.PaymentMethod, "Online Ödeme", StringComparison.OrdinalIgnoreCase))">Online kredi kartı — tam tutar</option>
                                <option value="Havale/EFT" selected="@(string.Equals(reservationForm.PaymentMethod, "Havale/EFT", StringComparison.OrdinalIgnoreCase))">Havale / EFT — tam tutar</option>
