            async function refreshPriceQuote() {
                if (!roomTypeSelect || !checkInInput || !checkOutInput || !bookingPrice || !breakdown) {
                    return;
                }

                const selectedOption = roomTypeSelect.options[roomTypeSelect.selectedIndex];
                const roomId = selectedOption?.value;
                const checkIn = checkInInput.value;
                const checkOut = checkOutInput.value;
                const roomCount = parseInt(document.querySelector('input[name="RoomCount"]')?.value || '1', 10);

                if (!roomId || !checkIn || !checkOut) {
                    return;
                }

                latestQuoteRequest = roomId + '|' + checkIn + '|' + checkOut + '|' + roomCount;
                const requestKey = latestQuoteRequest;

                try {
                    const response = await fetch('/oteller/@Model.Slug/fiyat-teklifi?roomTypeId=' + encodeURIComponent(roomId) + '&checkInDate=' + encodeURIComponent(checkIn) + '&checkOutDate=' + encodeURIComponent(checkOut) + '&roomCount=' + encodeURIComponent(roomCount), {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!response.ok) {
                        throw new Error('Fiyat özeti alınamadı');
                    }

                    const quote = await response.json();
                    if (!quote.success || latestQuoteRequest !== requestKey) {
                        return;
                    }

                    const nights = Math.max(1, quote.nightCount || 1);
                    const rc = Math.max(1, roomCount || 1);
                    const inclusiveNightly = Number(quote.totalAmount || 0) / nights / rc;
                    bookingPrice.textContent = formatMoney(inclusiveNightly);
                    breakdown.innerHTML = buildQuoteBreakdownHtml(quote);

                    const reserveButton = bookingForm?.querySelector('.reserve-btn');
                    if (quote.isAvailable === false) {
                        setQuoteNotice(quote.availabilityMessage || 'Seçili tarihler için uygun stok veya satış bulunamadı.', 'warning');
                        reserveButton?.setAttribute('disabled', 'disabled');
                    } else {
                        setQuoteNotice(quote.availabilityMessage || '', 'info');
                        reserveButton?.removeAttribute('disabled');
                    }
                } catch (_error) {
                    const fallbackNetNightly = parseFloat(selectedOption?.dataset.price || '0');
                    const diffMs = new Date(checkOut).getTime() - new Date(checkIn).getTime();
                    const nights = Math.max(1, Math.round(diffMs / 86400000));
                    const subtotal = fallbackNetNightly * nights * roomCount;
                    const vat = Math.round(subtotal * detailVatFraction);
                    const accommodationTax = Math.round(subtotal * detailAccommodationFraction);
                    const tax = vat + accommodationTax;
                    const total = subtotal + tax;
                    const inclNightly = total / nights / Math.max(1, roomCount);
                    bookingPrice.textContent = formatMoney(inclNightly);
                    setQuoteNotice('Günlük fiyat dökümü alınamadı, varsayılan oda fiyatı gösteriliyor.', 'info');
                    bookingForm?.querySelector('.reserve-btn')?.removeAttribute('disabled');
                    breakdown.innerHTML =
                        '<div class="price-row price-row-tax"><span>KDV <small class="tax-rate-hint">%' + detailVatPctLabel + '</small></span><strong>' + formatMoney(vat) + '</strong></div>' +
                        '<div class="price-row price-row-tax"><span>Konaklama Vergisi <small class="tax-rate-hint">%' + detailAccomPctLabel + '</small></span><strong>' + formatMoney(accommodationTax) + '</strong></div>' +
                        '<div class="price-row price-row-tax"><span>Vergi ve Harçlar</span><strong>' + formatMoney(tax) + '</strong></div>' +
                        '<div class="price-row total"><span>Toplam</span><strong>' + formatMoney(total) + '</strong></div>';
                }
            }

            async function loadSelectOptions(url, select, placeholder, selectedText) {
                if (!select) {
                    return [];
                }

                select.innerHTML = '<option value="">' + placeholder + '</option>';
                const response = await fetch(url, { credentials: 'same-origin' });
                const items = response.ok ? await response.json() : [];
                items.forEach(function (item) {
                    const option = document.createElement('option');
                    option.value = item.name;
                    option.textContent = item.name;
                    if (item.id) {
                        option.dataset.id = item.id;
                    }
                    if (item.provinceId) {
                        option.dataset.provinceId = item.provinceId;
                    }
                    if (item.postalCode) {
                        option.dataset.postalCode = item.postalCode;
                    }
                    if (selectedText && item.name === selectedText) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                });
                return items;
            }

