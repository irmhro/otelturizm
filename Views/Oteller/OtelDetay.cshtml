                shareButton.setAttribute('aria-expanded', 'true');
            }

            function bindShareActions() {
                if (!shareMenu) {
                    return;
                }

                const shareUrl = window.location.href;
                const hotelTitle = (document.querySelector('.detail-header h1')?.textContent || 'Otelturizm').trim();
                const encodedUrl = encodeURIComponent(shareUrl);
                const encodedText = encodeURIComponent(hotelTitle + ' - ' + shareUrl);

                const targets = {
                    whatsapp: 'https://api.whatsapp.com/send?text=' + encodedText,
                    facebook: 'https://www.facebook.com/sharer/sharer.php?u=' + encodedUrl,
                    x: 'https://twitter.com/intent/tweet?url=' + encodedUrl + '&text=' + encodeURIComponent(hotelTitle),
                    telegram: 'https://t.me/share/url?url=' + encodedUrl + '&text=' + encodeURIComponent(hotelTitle),
                    instagram: 'https://www.instagram.com/'
                };

                shareMenu.querySelectorAll('[data-share-platform]').forEach(function (element) {
                    const platform = element.getAttribute('data-share-platform');

                    if (element.tagName === 'A' && platform && targets[platform]) {
                        element.setAttribute('href', targets[platform]);
                    }

                    element.addEventListener('click', async function (event) {
                        if (platform === 'copy') {
                            event.preventDefault();
                            try {
                                await navigator.clipboard.writeText(shareUrl);
                                alert('Otel linki kopyalandi.');
                            } catch (_) {
                                alert('Link kopyalanamadi. Tarayici izinlerini kontrol edin.');
                            }
                            return;
                        }

                        if (platform === 'instagram') {
                            try {
                                await navigator.clipboard.writeText(shareUrl);
                            } catch (_) {
                                // ignore clipboard errors for unsupported browsers
                            }
                            alert('Instagram web tarafinda dogrudan baglanti paylasimi sinirlidir. Link kopyalandi, Instagram uygulamasinda yapistirabilirsiniz.');
                            return;
                        }

                        if (platform === 'more') {
                            event.preventDefault();
                            if (navigator.share) {
                                try {
                                    await navigator.share({ title: hotelTitle, text: hotelTitle, url: shareUrl });
                                } catch (_) {
                                    // ignore cancelled share
                                }
                            } else {
                                try {
                                    await navigator.clipboard.writeText(shareUrl);
                                    alert('Bu cihazda gelismis paylasim menusu desteklenmiyor. Link kopyalandi.');
                                } catch (_) {
                                    alert('Paylasim menusu kullanilamadi.');
                                }
                            }
                        }
                    });
                });
            }

            if (shareButton && shareMenu) {
