@model otelturizmnew.Models.Oteller.HotelDetailPageViewModel
@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Reservations
@using Microsoft.Extensions.Configuration
@inject otelturizmnew.Services.Abstractions.IReservationDraftService ReservationDraftService
@inject otelturizmnew.Services.Abstractions.IHotelPointsService HotelPointsService

@{
    ViewData["Title"] = Model.Name;
    ViewData["BodyClass"] = "oteldetay-page-shell anasayfa-page";
    ViewData["PageCss"] = "oteldetay_masaustu";
    ViewData["PageCssMobile"] = "oteldetay_mobil";
    ViewData["IncludeAnasayfaStyles"] = true;
    ViewData["IncludeBootstrap"] = true;
    ViewData["IncludePureVisualSlider"] = true;
    ViewData["IncludeFeWorldTokens"] = true;
    ViewData["SuppressGlobalDraftBanner"] = true;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    var uiCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.ShortDescription)
        ? $"{Model.Name} · {Model.District}, {Model.City}. Oda seçeneklerini inceleyin ve güvenle rezervasyon oluşturun."
        : Model.ShortDescription;
    ViewData["Canonical"] = $"{baseUrl}/oteller/{Model.Slug}";
    ViewData["OgLocale"] = uiCulture.Replace('-', '_');
    ViewData["OgLocaleAlternate"] = "tr_TR,en_US,de_DE,fr_FR";
    ViewData["OgImage"] = Model.MainImageUrl;

    var regionListingLabel = string.IsNullOrWhiteSpace(Model.District)
        ? Model.City
        : $"{Model.District}, {Model.City}".Trim(' ', ',');
    var regionListingUrl = Model.IlceId is > 0
        ? Url.Action("OtelListeleme", "Oteller", new { ilceId = Model.IlceId, q = regionListingLabel, page = 1 })
        : Model.SehirId is > 0
            ? Url.Action("OtelListeleme", "Oteller", new { sehirId = Model.SehirId, q = regionListingLabel, page = 1 })
            : Url.Action("OtelListeleme", "Oteller", new { q = $"{Model.District} {Model.City}".Trim(), page = 1 });
    regionListingUrl ??= "/oteller";

    try
    {
        var pricedRooms = Model.Rooms
            .Where(x => x.Price > 0m)
            .OrderBy(x => x.Price)
            .ThenBy(x => x.RoomTypeId)
            .ToList();
        var minRoomPrice = pricedRooms.FirstOrDefault()?.Price ?? Model.LowestRoomPrice;
        var maxRoomPrice = pricedRooms.LastOrDefault()?.Price ?? minRoomPrice;
        var hotelJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = new[] { "Hotel", "LodgingBusiness" },
            ["name"] = Model.Name,
            ["inLanguage"] = uiCulture,
            ["url"] = $"{baseUrl}/oteller/{Model.Slug}",
            ["image"] = string.IsNullOrWhiteSpace(Model.MainImageUrl) ? null : Model.MainImageUrl,
            ["priceRange"] = minRoomPrice > 0m ? $"{minRoomPrice:N0}-{maxRoomPrice:N0} TRY" : null,
            ["address"] = new Dictionary<string, object?>
            {
                ["@type"] = "PostalAddress",
                ["addressLocality"] = Model.District,
                ["addressRegion"] = Model.City,
                ["addressCountry"] = "TR"
            },
            ["geo"] = (Model.Latitude.HasValue && Model.Longitude.HasValue)
                ? new Dictionary<string, object?>
                {
                    ["@type"] = "GeoCoordinates",
                    ["latitude"] = Model.Latitude.Value,
                    ["longitude"] = Model.Longitude.Value
                }
                : null,
            ["aggregateRating"] = Model.Rating > 0
                ? new Dictionary<string, object?>
                {
                    ["@type"] = "AggregateRating",
                    ["ratingValue"] = Model.Rating,
                    ["bestRating"] = 10,
                    ["worstRating"] = 0
                }
                : null,
            ["makesOffer"] = pricedRooms.Count > 0
                ? pricedRooms.Select(room => new Dictionary<string, object?>
                {
                    ["@type"] = "Offer",
                    ["name"] = room.Name,
                    ["price"] = room.Price,
                    ["priceCurrency"] = "TRY",
                    ["url"] = $"{baseUrl}/oteller/{Model.Slug}?room={room.RoomTypeId}",
                    ["availability"] = "https://schema.org/InStock",
                    ["itemOffered"] = new Dictionary<string, object?>
                    {
                        ["@type"] = "HotelRoom",
                        ["name"] = room.Name,
                        ["occupancy"] = new Dictionary<string, object?>
                        {
                            ["@type"] = "QuantitativeValue",
                            ["maxValue"] = room.MaxGuestCount > 0 ? room.MaxGuestCount : null,
                            ["unitText"] = "guests"
                        }
                    }
                }).ToList()
                : null
        };

        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Oteller", ["item"] = $"{baseUrl}/oteller" },
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = Model.Name, ["item"] = $"{baseUrl}/oteller/{Model.Slug}" }
            }
        };

        var json = System.Text.Json.JsonSerializer.Serialize(new object[] { breadcrumbJsonLd, hotelJsonLd },
            new System.Text.Json.JsonSerializerOptions { DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull });
        ViewData["JsonLd"] = json;
    }
    catch
    {
        // fail-safe
    }
    var gallery = Model.GalleryImages.Count > 0 ? Model.GalleryImages : new List<string> { Model.MainImageUrl };
    var mainImage = gallery.FirstOrDefault() ?? string.Empty;
    var roomSelectOptions = Model.Rooms.Count > 0 ? Model.Rooms : new List<otelturizmnew.Models.Oteller.HotelRoomViewModel>
    {
        new()
        {
            RoomTypeId = 0,
            Name = "Standart Oda",
            Specs = "2 Kişi",
            Price = Model.LowestRoomPrice,
            CancellationText = "Ücretsiz iptal"
        }
    };
    var reservableRoomOptions = roomSelectOptions
        .Where(x => x.Price > 0m)
        .OrderBy(x => x.Price)
        .ThenBy(x => x.RoomTypeId)
        .ToList();
    if (reservableRoomOptions.Count == 0)
    {
        reservableRoomOptions = roomSelectOptions
            .OrderBy(x => x.Price)
            .ThenBy(x => x.RoomTypeId)
            .ToList();
    }
    var cheapestRoomOption = reservableRoomOptions.FirstOrDefault();
    var reservationForm = Model.ReservationForm ?? new otelturizmnew.Models.Reservations.PublicHotelReservationForm
    {
        HotelId = Model.Id,
        RoomTypeId = cheapestRoomOption?.RoomTypeId ?? 0
    };
    if (reservationForm.RoomTypeId <= 0 && cheapestRoomOption is not null)
    {
        reservationForm.RoomTypeId = cheapestRoomOption.RoomTypeId;
    }
    var selectedRoomSeed = reservableRoomOptions.FirstOrDefault(x => x.RoomTypeId == reservationForm.RoomTypeId)
        ?? cheapestRoomOption
        ?? reservableRoomOptions.FirstOrDefault();
    var roomPriceSeed = selectedRoomSeed.Price;
    var checkInDefault = reservationForm.CheckInDate.ToString("yyyy-MM-dd");
    var checkOutDefault = reservationForm.CheckOutDate.ToString("yyyy-MM-dd");
    var checkOutMinDefault = reservationForm.CheckInDate.AddDays(1).ToString("yyyy-MM-dd");
    var todayDate = DateTime.Today.ToString("yyyy-MM-dd");
    var reservationAdultCutoffDate = DateTime.Today.AddYears(-18).AddDays(-1);
    var reservationAdultCutoffText = reservationAdultCutoffDate.ToString("yyyy-MM-dd");
    var locationText = $"{Model.District}, {Model.City}";
    var longDescription = string.IsNullOrWhiteSpace(Model.LongDescription) ? Model.ShortDescription : Model.LongDescription;
    var aboutLocationNote = (Model.LocationDescription ?? string.Empty).Trim();
    var hasPolicyContent = Model.Conditions is not null && (
        Model.Conditions.HasFreeCancellation
        || !string.IsNullOrWhiteSpace(Model.Conditions.CancellationSummary)
        || !string.IsNullOrWhiteSpace(Model.Conditions.CancellationDetail)
        || !string.IsNullOrWhiteSpace(Model.Conditions.SmokingPolicy)
        || !string.IsNullOrWhiteSpace(Model.Conditions.PetPolicy)
        || !string.IsNullOrWhiteSpace(Model.Conditions.ChildPolicy)
        || Model.Conditions.PrepaymentRequired
        || Model.Conditions.CardPaymentAccepted);
    var overallBarWidth = Model.Rating > 0 ? Math.Min(100m, Model.Rating * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var locScore = Model.ReviewLocationScore > 0 ? Model.ReviewLocationScore : Model.Rating;
    var cleaningScore = Model.ReviewCleaningScore > 0 ? Model.ReviewCleaningScore : (Model.ReviewRoomScore > 0 ? Model.ReviewRoomScore : Model.Rating);
    var valScore = Model.ReviewValueScore > 0 ? Model.ReviewValueScore : Model.Rating;
    var staffScore = Model.ReviewStaffScore > 0 ? Model.ReviewStaffScore : Model.Rating;
    var quietScore = Model.ReviewQuietnessScore > 0 ? Model.ReviewQuietnessScore : Model.Rating;
    var transportScore = Model.ReviewTransportScore > 0 ? Model.ReviewTransportScore : locScore;
    var locationBarWidth = locScore > 0 ? Math.Min(100m, locScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var cleaningBarWidth = cleaningScore > 0 ? Math.Min(100m, cleaningScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var valueBarWidth = valScore > 0 ? Math.Min(100m, valScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var staffBarWidth = staffScore > 0 ? Math.Min(100m, staffScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var quietBarWidth = quietScore > 0 ? Math.Min(100m, quietScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var transportBarWidth = transportScore > 0 ? Math.Min(100m, transportScore * 10m).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0";
    var featuredAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Take(4)
        .ToList();
    var featuredAmenityFallbacks = new List<otelturizmnew.Models.Oteller.HotelAmenityViewModel>
    {
        new() { Name = "24 Saat Resepsiyon", IconClass = "fa-clock" },
        new() { Name = "Ücretsiz Wi-Fi", IconClass = "fa-wifi" },
        new() { Name = "Restoran", IconClass = "fa-utensils" },
        new() { Name = "Fitness Merkezi", IconClass = "fa-dumbbell" }
    };
    foreach (var fallbackItem in featuredAmenityFallbacks)
    {
        if (featuredAmenities.Count >= 4)
        {
            break;
        }

        if (featuredAmenities.Any(x => string.Equals(x.Name, fallbackItem.Name, StringComparison.OrdinalIgnoreCase)))
        {
            continue;
        }

        featuredAmenities.Add(fallbackItem);
    }
    var hiddenAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Skip(4)
        .ToList();
    var amenityIconStrip = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .Take(8)
        .ToList();
    var mobileInlineAmenities = Model.Amenities
        .Where(x => !string.IsNullOrWhiteSpace(x.Name))
        .ToList();
    if (mobileInlineAmenities.Count == 0)
    {
        mobileInlineAmenities = featuredAmenities;
    }
    var initialNightCount = Math.Max(1, reservationForm.CheckOutDate.DayNumber - reservationForm.CheckInDate.DayNumber);
    var initialRooms = Math.Max(1, reservationForm.RoomCount);
    var initialPriceQuote = Model.InitialPriceQuote;
    decimal initialTotal;
    decimal initialSubtotal;
    decimal initialVat;
    decimal initialAccommodationTax;
    decimal initialTax;
    decimal initialInclusiveNightly;
    decimal initialOriginalTotal = 0m;
    var initialDawnPercent = 0;
    var initialDawnDiscount = 0m;
    var initialHasDawn = false;
    if (initialPriceQuote is not null && initialPriceQuote.IsAvailable && initialPriceQuote.TotalAmount > 0m)
    {
        initialNightCount = Math.Max(1, initialPriceQuote.NightCount);
        initialTotal = initialPriceQuote.TotalAmount;
        initialSubtotal = initialPriceQuote.NetRoomAmount;
        initialVat = initialPriceQuote.VatAmount;
        initialAccommodationTax = initialPriceQuote.AccommodationTaxAmount;
        initialTax = initialPriceQuote.TaxAmount;
        initialInclusiveNightly = initialPriceQuote.NightlyPrice;
        initialOriginalTotal = initialPriceQuote.OriginalTotalAmount;
        initialDawnPercent = initialPriceQuote.DawnSurprisePercent;
        initialDawnDiscount = initialPriceQuote.DawnSurpriseDiscountAmount;
        initialHasDawn = initialDawnDiscount > 0m && initialDawnPercent > 0 && initialOriginalTotal > initialTotal;
    }
    else
    {
        initialTotal = roomPriceSeed * initialNightCount * initialRooms;
        var vatRateFrac = Model.TaxDisplayVatPercent / 100m;
        var accomRateFrac = Model.TaxDisplayAccommodationPercent / 100m;
        var taxDivisor = 1m + vatRateFrac + accomRateFrac;
        initialSubtotal = taxDivisor > 0m ? Math.Round(initialTotal / taxDivisor, 0) : initialTotal;
        initialVat = Math.Round(initialSubtotal * vatRateFrac, 0);
        initialAccommodationTax = Math.Max(0m, initialTotal - initialSubtotal - initialVat);
        initialTax = initialVat + initialAccommodationTax;
        initialInclusiveNightly = initialNightCount > 0 && initialRooms > 0
            ? Math.Round(initialTotal / initialNightCount / initialRooms, 0)
            : 0m;
    }
    var hotelImagePlaceholder = "/assets/img/placeholder-hotel.jpg";
    string ResolveRoomImageUrl(string? url) =>
        !string.IsNullOrWhiteSpace(url) ? url
        : !string.IsNullOrWhiteSpace(mainImage) ? mainImage
        : hotelImagePlaceholder;
    var i18nRoomSelected = SharedLocalizer["Detail.Room.Selected"].Value;
    var i18nRoomGalleryCount = SharedLocalizer["Detail.Room.GalleryCount"].Value;
    var i18nRoomTotalLine = SharedLocalizer["Detail.Room.TotalLine"].Value;
    var initialEarnPoints = initialTotal > 0m ? HotelPointsService.CalculateEarnPoints(initialTotal) : 0;
    var todayWeather = Model.Weather?.Days.FirstOrDefault();
    string? ExtractNeighborhoodFromAddress(string? address)
    {
        var a = (address ?? string.Empty).Trim();
        if (a.Length == 0) return null;

        var idx = a.IndexOf("Mahallesi", StringComparison.OrdinalIgnoreCase);
        if (idx > 0)
        {
            return a.Substring(0, idx + "Mahallesi".Length).Trim();
        }

        idx = a.IndexOf("Mah.", StringComparison.OrdinalIgnoreCase);
        if (idx > 0)
        {
            return a.Substring(0, idx + "Mah.".Length).Trim();
        }

        return null;
    }

    string GetWeatherDayTone(string? conditionText)
    {
        var value = conditionText ?? string.Empty;
        if (value.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
            || value.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
            || value.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
            || value.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
        {
            return "is-rainy";
        }

        if (value.Contains("Açık", StringComparison.OrdinalIgnoreCase) || value.Contains("Güneş", StringComparison.OrdinalIgnoreCase))
        {
            return "is-sunny";
        }

        if (value.Contains("Kar", StringComparison.OrdinalIgnoreCase))
        {
            return "is-snowy";
        }

        return "is-cloudy";
    }

    (string High, string Low) SplitWeatherTemperature(string? temperatureText)
    {
        var parts = (temperatureText ?? string.Empty).Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        return (parts.Length > 0 ? parts[0] : "—", parts.Length > 1 ? parts[1] : string.Empty);
    }

    var headerNeighborhood = ExtractNeighborhoodFromAddress(Model.Address);
    var headerLocationPieces = new List<string>();
    if (!string.IsNullOrWhiteSpace(headerNeighborhood)) headerLocationPieces.Add(headerNeighborhood);
    if (!string.IsNullOrWhiteSpace(Model.District)) headerLocationPieces.Add(Model.District);
    if (!string.IsNullOrWhiteSpace(Model.City)) headerLocationPieces.Add(Model.City);
    var headerLocationText = string.Join(", ", headerLocationPieces);
    var weatherAreaLabel = !string.IsNullOrWhiteSpace(headerNeighborhood)
        ? headerNeighborhood
        : (!string.IsNullOrWhiteSpace(Model.District) ? Model.District : Model.City);
    var weatherThemeClass = "weather-theme-cloudy";
    var weatherThemeTitle = "İlçe bazlı hava durumu";
    var weatherThemeSummary = "Bugün için dengeli bir gezi ritmi planlayabilirsiniz.";
    var weatherAccentIcon = "fa-cloud-sun";
    var mapLatitude = Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var mapLongitude = Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var checkInDisplay = Model.CheckInTime?.ToString(@"hh\:mm") ?? "14:00";
    var checkOutDisplay = Model.CheckOutTime?.ToString(@"hh\:mm") ?? "12:00";

    if (todayWeather is not null)
    {
        if (todayWeather.ConditionText.Contains("Yağ", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Sağanak", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Fırtına", StringComparison.OrdinalIgnoreCase)
            || todayWeather.ConditionText.Contains("Çisenti", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-rainy";
            weatherThemeTitle = "Yağış etkili görünüyor";
            weatherThemeSummary = "Şemsiye ile çıkmak akıllı olur. Kapalı alanlar, kafe ve iç mekan planları öne çıkabilir.";
            weatherAccentIcon = "fa-cloud-showers-heavy";
        }
        else if (todayWeather.ConditionText.Contains("Açık", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-sunny";
            weatherThemeTitle = "Güneşli bir tempo sizi bekliyor";
            weatherThemeSummary = "Açık hava programları, sahil rotaları ve teras deneyimleri için güzel bir görünüm var.";
            weatherAccentIcon = "fa-sun";
        }
        else if (todayWeather.ConditionText.Contains("Kar", StringComparison.OrdinalIgnoreCase))
        {
            weatherThemeClass = "weather-theme-snowy";
            weatherThemeTitle = "Serin ve kis dokulu hava";
            weatherThemeSummary = "Dış planlarda daha sıcak giyinmek faydalı olur. Sıcak içecek ve iç mekan deneyimleri daha keyifli olabilir.";
            weatherAccentIcon = "fa-snowflake";
        }
    }

    string GetAmenitySubtext(string amenityName)
    {
        var value = amenityName.ToLowerInvariant();
        if (value.Contains("havuz")) return "Ücretsiz kullanım";
        if (value.Contains("spa") || value.Contains("hamam") || value.Contains("sauna")) return "Hamam, sauna, masaj";
        if (value.Contains("restoran") || value.Contains("bar")) return "Gurme mutfak";
        if (value.Contains("wifi") || value.Contains("wi-fi")) return "Tüm odalarda";
        if (value.Contains("otopark")) return "Vale ve acik otopark";
        return "Tesis olanağı";
    }
}

@section HeadStyles {
@if (!string.IsNullOrWhiteSpace(mainImage))
{
    <link rel="preload" as="image" href="@mainImage" fetchpriority="high" />
}
<link rel="stylesheet"
      href="~/assets/vendor/leaflet/leaflet.css"
      asp-append-version="true" />
<link rel="stylesheet" href="~/assets/css/otel-detay-reservation.css" asp-append-version="true" />
<link rel="stylesheet" href="~/assets/css/otel-detay-world.css" asp-append-version="true" />
<link rel="stylesheet" href="~/assets/css/otel-detay-mobile-lock.css" asp-append-version="true" media="(max-width: 900px)" />
<link rel="stylesheet" href="~/assets/css/rezervasyonaksiyon_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
}

<div class="oteldetay-page otel-detail-template-v41 otel-detail-tabler od-detail"
     data-i18n-room-selected="@i18nRoomSelected"
     data-i18n-room-reserve="@SharedLocalizer["Detail.Room.Reserve"].Value">
<section class="detail-breadcrumb detail-breadcrumb-with-weather">
    <div class="detail-breadcrumb-left">
        <a asp-controller="Oteller" asp-action="OtelListeleme" class="detail-back-link">
            <i class="fas fa-arrow-left"></i>
            <span>@SharedLocalizer["Detail.BackToHotels"].Value</span>
        </a>
        <span class="detail-breadcrumb-sep" aria-hidden="true">·</span>
        <a class="detail-back-link detail-region-link"
           href="@regionListingUrl"
           aria-label="@regionListingLabel bölgesindeki otelleri listele">
            <i class="fas fa-location-dot" aria-hidden="true"></i>
            <span>@regionListingLabel</span>
        </a>
    </div>
    <div class="detail-breadcrumb-right" aria-label="Hızlı işlemler">
        <button type="button"
                id="startConversationBtn"
                class="detail-quick-action is-attention is-tone-talk"
                data-hotel-slug="@Model.Slug"
                data-authenticated="@(Model.IsLoggedInUser ? "true" : "false")"
                data-can-start="@(Model.HasCompletedReservationAtHotel ? "true" : "false")"
                data-info-message="@Model.ConversationInfoMessage"
                aria-label="Sohbet">
            <i class="far fa-comments" aria-hidden="true"></i>
            <span>Sohbet</span>
        </button>
        <div class="detail-share-wrap">
            <button type="button" id="shareHotelBtn" class="detail-quick-action is-tone-share" aria-haspopup="true" aria-expanded="false" aria-controls="shareMenu" aria-label="Paylaş">
                <i class="far fa-share-square" aria-hidden="true"></i>
                <span>Paylaş</span>
            </button>
            <div class="share-menu share-menu--top" id="shareMenu" hidden>
                <p class="share-menu-title">Bu oteli paylas</p>
                <div class="share-menu-grid">
                    <a href="#" data-share-platform="whatsapp" target="_blank" rel="noopener">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                    <a href="#" data-share-platform="facebook" target="_blank" rel="noopener">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="#" data-share-platform="x" target="_blank" rel="noopener">
                        <i class="fab fa-x-twitter"></i>
                        <span>X</span>
                    </a>
                    <a href="#" data-share-platform="instagram" target="_blank" rel="noopener">
                        <i class="fab fa-instagram"></i>
                        <span>Instagram</span>
                    </a>
                    <a href="#" data-share-platform="telegram" target="_blank" rel="noopener">
                        <i class="fab fa-telegram-plane"></i>
                        <span>Telegram</span>
                    </a>
                    <button type="button" data-share-platform="copy">
                        <i class="fas fa-link"></i>
                        <span>Link Kopyala</span>
                    </button>
                </div>
                <button type="button" class="share-more-btn" data-share-platform="more">
                    <i class="fas fa-share-nodes"></i>
                    Diğer platformlar
                </button>
            </div>
        </div>
        <button type="button"
                id="saveHotelBtnTop"
                class="detail-quick-action favorite-btn is-tone-fav @(Model.IsFavorite ? "active" : string.Empty)"
                data-hotel-id="@Model.Id"
                data-source-page="OtelDetay"
                aria-label="Favoriye ekle"
                aria-pressed="@(Model.IsFavorite ? "true" : "false")">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart" aria-hidden="true"></i>
            <span data-favorite-label>@(Model.IsFavorite ? "Favoride" : "Favori")</span>
        </button>
    </div>
</section>

@if (gallery.Count > 0)
{
    ViewData["SliderTitle"] = Model.Name;
    <partial name="~/Views/Shared/_HotelHeroGallery.cshtml" model="gallery" />

    <section class="gallery-mobile-strip od-gallery od-gallery--mobile" id="galleryMobileStrip" data-gallery-title="@Model.Name" aria-label="Mobil galeri slider">
        <div class="gallery-mobile-chrome" aria-hidden="false">
            <a asp-controller="Oteller" asp-action="OtelListeleme" class="gallery-mobile-back" aria-label="@SharedLocalizer["Detail.BackToHotels"].Value">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
            </a>
            <div class="gallery-mobile-counter" id="galleryMobileCounter" aria-live="polite">
                <span class="gallery-mobile-counter__current">1</span>
                <span class="gallery-mobile-counter__sep">/</span>
                <span class="gallery-mobile-counter__total">@gallery.Count</span>
            </div>
        </div>
        @if (gallery.Count > 1)
        {
            <div class="gallery-mobile-nav" aria-label="Mobil galeri gezinme">
                <button type="button" class="gallery-mobile-nav-btn gallery-mobile-nav-btn--prev" data-gallery-mobile-nav="prev" aria-label="Önceki görsel">
                    <i class="fas fa-chevron-left" aria-hidden="true"></i>
                </button>
