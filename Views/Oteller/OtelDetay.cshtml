                    const roomName = (button.getAttribute('data-room-name') || button.textContent || 'Oda').trim();
                    const startIdx = parseInt(button.getAttribute('data-room-gallery-start') || '0', 10) || 0;
                    const map = window.__otelDetayConfig?.roomGalleries || {};
                    const imgs = map[roomId] || map[String(roomId)] || [];
                    openVisualGallery(imgs, roomName, startIdx);
                });
