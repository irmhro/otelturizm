                const accR = typeof quote.accommodationTaxRate === 'string' ? quote.accommodationTaxRate : formatRatePct(quote.accommodationTaxRate);
                return '<div class="price-row price-row-tax"><span>KDV <small class="tax-rate-hint">%' + vatR + '</small></span><strong>' + formatMoney(quote.vatAmount || 0) + '</strong></div>' +
                    '<div class="price-row price-row-tax"><span>Konaklama Vergisi <small class="tax-rate-hint">%' + accR + '</small></span><strong>' + formatMoney(quote.accommodationTaxAmount || 0) + '</strong></div>' +
                    '<div class="price-row price-row-tax"><span>Vergi ve Harçlar</span><strong>' + formatMoney(quote.taxAmount) + '</strong></div>' +
                    '<div class="price-row total"><span>Toplam</span><strong>' + formatMoney(quote.totalAmount) + '</strong></div>';
            }

