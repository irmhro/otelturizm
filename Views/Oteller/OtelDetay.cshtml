            async function refreshPriceQuote() {
                if (!bookingPrice || !breakdown) {
                    return;
                }

                if (nightlyDetails && nightlyList) {
                    nightlyDetails.hidden = true;
                    nightlyList.innerHTML = '';
                }

                const roomNodes = getRoomItemNodes();
                if (!roomNodes.length) {
                    return;
                }

                const items = roomNodes.map(getRoomItemData);
                const invalid = items.some(function (x) {
                    return !x.roomTypeId || !x.checkIn || !x.checkOut || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                });
                if (invalid) {
                    return;
                }

                // request-key to avoid race conditions
                latestQuoteRequest = items.map(function (x) { return x.roomTypeId + '|' + x.checkIn + '|' + x.checkOut; }).join('||');
                const requestKey = latestQuoteRequest;

                const totals = {
                    vatRate: detailVatPctLabel,
                    accommodationTaxRate: detailAccomPctLabel,
                    vatAmount: 0,
                    accommodationTaxAmount: 0,
                    taxAmount: 0,
                    totalAmount: 0
                };

                const perRoom = [];
                const nightlySeed = { byRoom: [] };
                let anyUnavailable = false;
                let availabilityMessage = '';

                for (const item of items) {
                    try {
                        const response = await fetch('/oteller/@Model.Slug/fiyat-teklifi?roomTypeId=' + encodeURIComponent(item.roomTypeId) + '&checkInDate=' + encodeURIComponent(item.checkIn) + '&checkOutDate=' + encodeURIComponent(item.checkOut) + '&roomCount=1', {
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        if (!response.ok) {
                            throw new Error('Fiyat özeti alınamadı');
                        }
                        const quote = await response.json();
                        if (latestQuoteRequest !== requestKey) {
                            return;
                        }
                        if (!quote.success) {
                            throw new Error(quote.message || quote.availabilityMessage || 'Fiyat özeti alınamadı');
                        }

                        const vat = Number(quote.vatAmount || 0);
                        const acc = Number(quote.accommodationTaxAmount || 0);
                        const tax = Number(quote.taxAmount || (vat + acc));
                        const total = Number(quote.totalAmount || 0);

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += acc;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });

                        if (Array.isArray(quote.nightlyBreakdown) && quote.nightlyBreakdown.length > 0) {
                            nightlySeed.byRoom.push({
                                index: perRoom.length - 1,
                                roomName: item.roomName,
                                checkIn: item.checkIn,
                                checkOut: item.checkOut,
                                rows: quote.nightlyBreakdown
                            });
                        }

                        if (quote.isAvailable === false) {
                            anyUnavailable = true;
                            availabilityMessage = quote.availabilityMessage || availabilityMessage;
                        }
                    } catch (_error) {
                        // fallback: use option net price from DOM
                        const node = roomNodes[perRoom.length] || null;
                        const opt = node?.querySelector('[data-field="roomType"]')?.selectedOptions?.[0];
                        const netNightly = parseFloat(opt?.dataset.price || '0');
                        const diffMs = new Date(item.checkOut).getTime() - new Date(item.checkIn).getTime();
                        const nights = Math.max(1, Math.round(diffMs / 86400000));
                        const subtotal = netNightly * nights;
                        // Vergiler bilgilendirme icin "fiyatin icinden" hesaplanir; toplam tutara eklenmez.
                        const taxDivisor = 1 + detailVatFraction + detailAccommodationFraction;
                        const net = taxDivisor > 0 ? (subtotal / taxDivisor) : subtotal;
                        const vat = Math.round(net * detailVatFraction);
                        const accommodationTax = Math.max(0, Math.round(subtotal - net - vat));
                        const tax = vat + accommodationTax;
                        const total = subtotal;

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += accommodationTax;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });
                    }
                }

                if (latestQuoteRequest !== requestKey) {
                    return;
                }

                // price head: tek satır toplam (vergiler dahil)
                const unitEl = document.querySelector('.booking-price-unit');
                bookingPrice.textContent = formatMoney(totals.totalAmount);
                if (unitEl) unitEl.textContent = 'Toplam • Vergiler dahil';
                if (mobileBookingPrice) mobileBookingPrice.textContent = formatMoney(totals.totalAmount);

                breakdown.innerHTML = buildMultiRoomBreakdownHtml(perRoom, totals);

                if (nightlyDetails && nightlyList) {
                    const showNightly = Array.isArray(nightlySeed.byRoom) && nightlySeed.byRoom.some(function (x) {
                        return Array.isArray(x.rows) && x.rows.length > 0;
                    });
                    nightlyDetails.hidden = !showNightly;
                    if (showNightly) {
                        nightlyList.innerHTML = nightlySeed.byRoom.map(function (roomBlock) {
                            const header = '<div class="nightly-breakdown-room-head"><strong>Oda ' + (Number(roomBlock.index || 0) + 1) + '</strong><small>' + escapeHtml((roomBlock.roomName || 'Oda').toString()) + ' · ' + escapeHtml((roomBlock.checkIn || '-').toString()) + ' → ' + escapeHtml((roomBlock.checkOut || '-').toString()) + '</small></div>';
                            const rowsHtml = (roomBlock.rows || []).map(function (row) {
                                const label = (row.dateText || row.date || '').toString();
                                const effectiveAmount = Number(row.price || row.totalAmount || row.amount || 0);
                                const baseAmount = Number(row.basePrice || 0);
                                const discountAmount = Number(row.discountPrice || 0);
                                const isDiscounted = !!row.isDiscounted && discountAmount > 0 && baseAmount > discountAmount;
                                const amountHtml = isDiscounted
                                    ? '<strong><small>' + formatMoney(baseAmount) + '</small>' + formatMoney(effectiveAmount) + '</strong>'
                                    : '<strong>' + formatMoney(effectiveAmount) + '</strong>';
                                return '<div class="nightly-breakdown-row' + (isDiscounted ? ' nightly-breakdown-row-discount' : '') + '"><span>' + escapeHtml(label) + '</span>' + amountHtml + '</div>';
                            }).join('');
                            return '<div class="nightly-breakdown-room">' + header + rowsHtml + '</div>';
                        }).join('');
                    } else {
                        nightlyList.innerHTML = '';
                    }
                }

                lastQuoteUnavailable = anyUnavailable;
                if (anyUnavailable) {
                    setQuoteNotice(availabilityMessage || 'Seçili tarihler için uygun stok veya satış bulunamadı.', 'warning');
                } else {
                    setQuoteNotice(availabilityMessage || '', 'info');
                }

                syncReserveButtonEnabled();
            }

            function initReviewReadMore() {
                const modal = document.getElementById('reviewModal');
                const modalTitle = document.getElementById('reviewModalTitle');
                const modalDate = document.getElementById('reviewModalDate');
                const modalScore = document.getElementById('reviewModalScore');
                const modalText = document.getElementById('reviewModalText');
                if (!modal || !modalText) return;
                const insightModal = document.getElementById('reviewInsightModal');
                const insightTitle = document.getElementById('reviewInsightTitle');
                const insightMeta = document.getElementById('reviewInsightMeta');
                const insightList = document.getElementById('reviewInsightList');
                const insightTabs = document.getElementById('reviewInsightTabs');
                const insightSort = document.getElementById('reviewInsightSort');
                const insightPager = document.getElementById('reviewInsightPager');
                const topicPayloadEl = document.getElementById('reviewTopicPayloadJson');
                const feedPayloadEl = document.getElementById('reviewFeedPayloadJson');
                let topicPayload = [];
                let feedPayload = [];
                let activeInsightTopic = 'all';
                let activeInsightPage = 1;
                const insightPageSize = 10;
                try {
                    topicPayload = JSON.parse(topicPayloadEl?.textContent || '[]');
                } catch (_) {
                    topicPayload = [];
                }
                try {
                    feedPayload = JSON.parse(feedPayloadEl?.textContent || '[]');
                } catch (_) {
                    feedPayload = [];
                }

                function openReviewModal(payload) {
                    if (modalTitle) modalTitle.textContent = payload.title || 'Misafir yorumu';
                    if (modalDate) modalDate.textContent = payload.date || '';
                    if (modalScore) modalScore.textContent = payload.score || '';
                    modalText.textContent = payload.text || '';
                    modal.classList.add('is-open');
                    modal.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                }

                function closeReviewModal() {
                    modal.classList.remove('is-open');
                    modal.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                }

                function buildInsightTabs() {
                    if (!insightTabs) return;
                    const tabs = [{ key: 'all', label: 'Genel', count: feedPayload.length }].concat(topicPayload || []);
                    insightTabs.innerHTML = tabs.map(function (topic) {
                        const key = topic.key || 'all';
                        const label = topic.label || 'Genel';
                        const count = key === 'all' ? feedPayload.length : (topic.count || 0);
                        const activeClass = key === activeInsightTopic ? ' is-active' : '';
                        return '<button type="button" class="review-insight-tab' + activeClass + '" data-review-insight-topic="' + escapeHtml(key) + '">' +
                            escapeHtml(label) + '<span>' + escapeHtml(String(count)) + '</span>' +
                        '</button>';
                    }).join('');
                }

                function getInsightItems() {
                    const items = activeInsightTopic === 'all'
                        ? (feedPayload || []).slice()
                        : (feedPayload || []).filter(function (x) {
                            return Array.isArray(x?.topics) && x.topics.indexOf(activeInsightTopic) > -1;
                        });
                    const sortValue = insightSort?.value || 'new';
                    if (sortValue === 'best') {
                        items.sort(function (a, b) { return (parseFloat(b?.score || '0') || 0) - (parseFloat(a?.score || '0') || 0); });
                    } else if (sortValue === 'worst') {
                        items.sort(function (a, b) { return (parseFloat(a?.score || '0') || 0) - (parseFloat(b?.score || '0') || 0); });
                    }
                    return items;
                }

                function renderInsightModal() {
                    if (!insightModal || !insightList) return;
                    const topic = activeInsightTopic === 'all'
                        ? { label: 'Genel', score: '', count: feedPayload.length }
                        : (topicPayload || []).find(function (x) { return x && x.key === activeInsightTopic; });
                    if (!topic) return;
                    const matched = getInsightItems();
                    const totalPages = Math.max(1, Math.ceil(matched.length / insightPageSize));
                    activeInsightPage = Math.min(Math.max(1, activeInsightPage), totalPages);
                    const pageItems = matched.slice((activeInsightPage - 1) * insightPageSize, activeInsightPage * insightPageSize);
                    if (insightTitle) insightTitle.textContent = topic.label + (topic.score ? ' · ' + topic.score : '');
                    if (insightMeta) insightMeta.textContent = matched.length + ' yorum gösteriliyor · Sayfa başı 10 yorum';
                    buildInsightTabs();
                    if (pageItems.length === 0) {
                        insightList.innerHTML = '<div class="review-insight-empty">Bu başlık için henüz detaylı yorum bulunmuyor.</div>';
                    } else {
                        insightList.innerHTML = pageItems.map(function (item) {
                            const date = item?.date || '';
                            const name = item?.name || 'Misafir';
                            const score = item?.score || '';
                            const text = item?.text || '';
                            return '<article class="review-insight-card">' +
                                '<header><strong>' + escapeHtml(name) + '</strong><span>' + escapeHtml(date) + '</span><b>' + escapeHtml(score) + '</b></header>' +
                                '<p>' + escapeHtml(text) + '</p>' +
                            '</article>';
                        }).join('');
                    }
                    if (insightPager) {
                        insightPager.hidden = totalPages <= 1;
                        insightPager.innerHTML = totalPages <= 1 ? '' :
                            '<button type="button" data-review-insight-page="prev" ' + (activeInsightPage <= 1 ? 'disabled' : '') + '>Önceki</button>' +
                            '<span>' + activeInsightPage + ' / ' + totalPages + '</span>' +
                            '<button type="button" data-review-insight-page="next" ' + (activeInsightPage >= totalPages ? 'disabled' : '') + '>Sonraki</button>';
                    }
                }

                function openInsightModal(topicKey) {
                    if (!insightModal || !insightList) return;
                    activeInsightTopic = topicKey || 'all';
                    activeInsightPage = 1;
                    if (insightSort) insightSort.value = 'new';
                    renderInsightModal();
                    insightModal.classList.add('is-open');
                    insightModal.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                }

                function closeInsightModal() {
                    if (!insightModal) return;
                    insightModal.classList.remove('is-open');
                    insightModal.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                }

                modal.querySelectorAll('[data-review-modal-close]').forEach(function (btn) {
                    btn.addEventListener('click', closeReviewModal);
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeReviewModal();
                    if (e.key === 'Escape' && insightModal && insightModal.classList.contains('is-open')) closeInsightModal();
                });

                document.querySelectorAll('[data-review-card]').forEach(function (card) {
                    const p = card.querySelector('[data-review-text]');
                    const moreBtn = card.querySelector('[data-review-more]');
                    const full = card.querySelector('[data-review-fulltext]');
                    if (!p || !moreBtn || !full) return;

                    const metaRoot = card.closest('.review-card');
                    const date = metaRoot?.querySelector('.review-meta p')?.textContent?.trim() || '';
                    const title = metaRoot?.querySelector('.review-meta h4')?.textContent?.trim() || 'Misafir yorumu';
                    const score = metaRoot?.querySelector('.review-chip')?.textContent?.trim() || '';

                    requestAnimationFrame(function () {
                        const isTruncated = p.scrollHeight > p.clientHeight + 2;
                        moreBtn.hidden = !isTruncated;
                    });

                    moreBtn.addEventListener('click', function () {
                        openReviewModal({
                            title: title,
                            date: date,
                            score: score,
                            text: full.textContent || p.textContent || ''
                        });
                    });
                });

                if (insightModal) {
                    insightModal.querySelectorAll('[data-review-insight-close]').forEach(function (btn) {
                        btn.addEventListener('click', closeInsightModal);
                    });
                    insightModal.addEventListener('click', function (event) {
                        const tab = event.target.closest('[data-review-insight-topic]');
                        if (tab) {
                            activeInsightTopic = tab.getAttribute('data-review-insight-topic') || 'all';
                            activeInsightPage = 1;
                            renderInsightModal();
                            return;
                        }
                        const pageButton = event.target.closest('[data-review-insight-page]');
                        if (pageButton) {
                            const direction = pageButton.getAttribute('data-review-insight-page');
                            activeInsightPage += direction === 'next' ? 1 : -1;
                            renderInsightModal();
                        }
                    });
                    insightSort?.addEventListener('change', function () {
                        activeInsightPage = 1;
                        renderInsightModal();
                    });
                }
                document.querySelectorAll('[data-review-topic-open="true"]').forEach(function (chip) {
                    chip.addEventListener('click', function () {
                        const topicKey = chip.getAttribute('data-topic-key') || '';
                        if (!topicKey) return;
                        openInsightModal(topicKey);
                    });
                });
            }

            function initRoomFeaturePanels() {
                document.querySelectorAll('[data-room-feature-wrap]').forEach(function (wrap) {
                    const btn = wrap.querySelector('[data-room-feature-toggle]');
                    const panel = wrap.querySelector('[data-room-feature-panel]');
                    if (!btn || !panel) return;

                    btn.addEventListener('click', function () {
