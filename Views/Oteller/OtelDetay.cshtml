<section class="detail-modal detail-info-modal" id="detailInfoModal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="detailInfoModalTitle">
    <button type="button" class="detail-modal-close" data-close-modal="detailInfoModal" aria-label="Kapat"><i class="fas fa-times"></i></button>
    <div class="detail-modal-head">
