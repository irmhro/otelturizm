            function normalizeBookingDates() {
                if (!checkInInput || !checkOutInput) {
                    return;
                }

                const todayText = '@todayDate';
                const currentCheckIn = checkInInput.value;
                if (!currentCheckIn || currentCheckIn < todayText) {
                    checkInInput.value = todayText;
                }

                const checkInDate = new Date(checkInInput.value + 'T00:00:00');
                if (Number.isNaN(checkInDate.getTime())) {
                    return;
                }

                const minCheckOutDate = new Date(checkInDate);
                minCheckOutDate.setDate(minCheckOutDate.getDate() + 1);
                const minCheckOutText = minCheckOutDate.toISOString().slice(0, 10);
                checkOutInput.min = minCheckOutText;

                if (!checkOutInput.value || checkOutInput.value <= checkInInput.value) {
                    checkOutInput.value = minCheckOutText;
                }
            }

