                {
                    <button type="button" class="amenities-list-more" id="openAmenitiesModal">
                        <i class="fas fa-plus" aria-hidden="true"></i>
                        Diger ozellikler (@hiddenAmenities.Count)
                    </button>
                }
            </div>

            @if (Model.Amenities.Count > featuredAmenities.Count)
            {
                <details class="amenities-expand" id="amenitiesExpand">
                    <summary>
                        <span class="amenities-expand__copy">
                            <strong>Tüm tesis olanakları</strong>
                            <small>@Model.Amenities.Count özellik</small>
                        </span>
                        <i class="fas fa-angle-down" aria-hidden="true"></i>
                    </summary>
                    <div class="amenities-expand__grid" role="list" aria-label="Tüm tesis olanakları">
                        @foreach (var a in Model.Amenities.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
                        {
                            <div class="amenities-expand__item" role="listitem">
                                <span class="amenities-expand__icon" aria-hidden="true"><i class="fas @a.IconClass"></i></span>
