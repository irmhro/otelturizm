                const checkInEl = item.querySelector('[data-field="checkIn"]');
                const checkOutEl = item.querySelector('[data-field="checkOut"]');
                const roomTypeEl = item.querySelector('[data-field="roomType"]');
                if (checkInEl && seed?.checkIn) checkInEl.value = seed.checkIn;
                if (checkOutEl && seed?.checkOut) checkOutEl.value = seed.checkOut;
