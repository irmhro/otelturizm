            </button>
        </div>
        <div class="review-insight-controls">
            <div class="review-insight-tabs" id="reviewInsightTabs" aria-label="Yorum başlıkları"></div>
            <label class="review-sort review-insight-sort">
                <span>Sırala</span>
                <select id="reviewInsightSort">
                    <option value="new">En yeni</option>
                    <option value="best">En iyi</option>
                    <option value="worst">En kötü</option>
                </select>
            </label>
        </div>
        <div class="review-insight-list" id="reviewInsightList"></div>
        <div class="review-insight-pager" id="reviewInsightPager" hidden></div>
