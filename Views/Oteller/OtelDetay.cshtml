                const toast = document.getElementById('multiRoomToast');
                if (!toast) {
                    return;
                }
                toast.textContent = 'Oda ' + roomNumber + ' eklendi — oda tipini seçin';
                toast.hidden = false;
                toast.classList.add('is-visible');
                window.clearTimeout(showRoomAddedToast._timer);
                showRoomAddedToast._timer = window.setTimeout(function () {
                    toast.classList.remove('is-visible');
                    toast.hidden = true;
                }, 4200);
