            function openRoomDetailModal(button) {
                if (!button || !roomDetailModal || !roomDetailModalGrid) {
                    return;
                }

                let details = [];
                try {
                    details = JSON.parse(button.getAttribute('data-room-details') || '[]');
                } catch (error) {
                    details = [];
                }

                const roomName = button.getAttribute('data-room-name') || 'Oda detayları';
                const specs = button.getAttribute('data-room-specs') || 'Oda bilgileri güncelleniyor.';
                const cancellation = button.getAttribute('data-room-cancellation') || 'Koşullar rezervasyon adımında yeniden doğrulanır.';
                const featureCount = button.getAttribute('data-room-feature-count') || String(details.length || 0);
                const galleryCount = button.getAttribute('data-room-gallery-count') || '0';

                if (roomDetailModalTitle) roomDetailModalTitle.textContent = roomName;
                if (roomDetailModalRoomName) roomDetailModalRoomName.textContent = roomName;
                if (roomDetailModalSpecs) roomDetailModalSpecs.textContent = specs;
                if (roomDetailModalCancellation) roomDetailModalCancellation.textContent = cancellation;
                if (roomDetailModalGalleryBadge) roomDetailModalGalleryBadge.textContent = galleryCount + ' görsel';
                if (roomDetailModalFeatureBadge) roomDetailModalFeatureBadge.textContent = featureCount + ' özellik';

                roomDetailModalGrid.innerHTML = '';
                details.forEach(function (detail) {
                    const detailName = detail?.name || detail?.Name || '';
                    const detailIcon = detail?.iconClass || detail?.IconClass || 'fa-circle-check';
                    if (!detailName) {
                        return;
                    }

                    const item = document.createElement('div');
                    item.className = 'room-detail-modal-item';
                    item.innerHTML = '<i class="fas ' + detailIcon + '"></i><span></span>';
                    item.querySelector('span').textContent = detailName;
                    roomDetailModalGrid.appendChild(item);
                });

                openModal(roomDetailModal);
            }

            async function loadSelectOptions(url, select, placeholder, selectedText) {
                if (!select) {
                    return [];
                }

                select.innerHTML = '<option value="">' + placeholder + '</option>';
                const response = await fetch(url, { credentials: 'same-origin' });
                const items = response.ok ? await response.json() : [];
                items.forEach(function (item) {
                    const option = document.createElement('option');
                    option.value = item.name;
                    option.textContent = item.name;
                    if (item.id) {
                        option.dataset.id = item.id;
                    }
                    if (item.provinceId) {
                        option.dataset.provinceId = item.provinceId;
                    }
                    if (item.postalCode) {
                        option.dataset.postalCode = item.postalCode;
                    }
                    if (selectedText && item.name === selectedText) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                });
                return items;
            }

            const countrySelect = document.getElementById('detailCountrySelect');
            const provinceSelect = document.getElementById('detailProvinceSelect');
            const districtSelect = document.getElementById('detailDistrictSelect');
            const neighborhoodSelect = document.getElementById('detailNeighborhoodSelect');
            const profileAddressSeed = {
                country: '@(Model.ProfilePrompt.Nationality ?? string.Empty)',
                city: '@(Model.ProfilePrompt.City ?? string.Empty)',
                district: '@(Model.ProfilePrompt.District ?? string.Empty)',
                neighborhood: '@(Model.ProfilePrompt.Neighborhood ?? string.Empty)'
            };

            async function hydrateProfileAddressSelectors() {
                await loadSelectOptions('/api/adres/ulkeler', countrySelect, 'Uyruk seçiniz', profileAddressSeed.country);
                await loadSelectOptions('/api/adres/iller', provinceSelect, 'İl seçiniz', profileAddressSeed.city);
                const provinceId = provinceSelect?.selectedOptions[0]?.dataset.id || provinceSelect?.selectedOptions[0]?.dataset.provinceId;
                if (provinceId) {
                    await loadSelectOptions('/api/adres/ilceler?ilId=' + encodeURIComponent(provinceId), districtSelect, 'İlçe seçiniz', profileAddressSeed.district);
                    const districtId = districtSelect?.selectedOptions[0]?.dataset.id;
                    if (districtId) {
                        await loadSelectOptions('/api/adres/mahalleler?ilceId=' + encodeURIComponent(districtId), neighborhoodSelect, 'Mahalle seçiniz', profileAddressSeed.neighborhood);
                    }
                }
            }

            provinceSelect?.addEventListener('change', async function () {
                const provinceId = provinceSelect.selectedOptions[0]?.dataset.id || provinceSelect.selectedOptions[0]?.dataset.provinceId || '';
                await loadSelectOptions('/api/adres/ilceler?ilId=' + encodeURIComponent(provinceId), districtSelect, 'İlçe seçiniz', '');
                neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
            });

            districtSelect?.addEventListener('change', async function () {
                const districtId = districtSelect.selectedOptions[0]?.dataset.id || '';
                await loadSelectOptions('/api/adres/mahalleler?ilceId=' + encodeURIComponent(districtId), neighborhoodSelect, 'Mahalle seçiniz', '');
            });

            openProfileCompletionFromBanner?.addEventListener('click', function () {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            });
            openAmenitiesModal?.addEventListener('click', function () {
                openModal(amenitiesModal);
            });

            document.querySelectorAll('[data-room-detail-open]').forEach(function (button) {
                button.addEventListener('click', function () {
                    openRoomDetailModal(button);
                });
            });

            activeDraftResumeLink?.addEventListener('click', function (event) {
                event.preventDefault();
                resumeDraftFlow();
            });

            bookingForm?.addEventListener('submit', function (event) {
                syncRoomsJsonAndHiddenFields();
                const roomNodes = getRoomItemNodes();
                const items = roomNodes.map(getRoomItemData);
                const hasMissingRequiredInfo = roomNodes.length === 0
                    || items.some(function (x) {
                        return !x.roomTypeId
                            || !x.checkIn
                            || !x.checkOut
                            || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                    })
                    || adults < 1;
                if (hasMissingRequiredInfo) {
                    event.preventDefault();
                    showInfoModal('Rezervasyon oncesi tarih, misafir ve oda bilgilerini kontrol edip tamamlayiniz.', false);
                    return;
                }

                if (!ensureGuestCapacity(true)) {
                    event.preventDefault();
                    return;
                }

                if (!isPaymentMethodChosen()) {
                    event.preventDefault();
                    bookingAdvancedFields?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                    showInfoModal('Rezervasyon için önce ödeme yönteminizi seçin.', false);
                    return;
                }

                if (isOnlinePaymentSelected()) {
                    event.preventDefault();
                    showInfoModal('Online ödeme altyapısı şu anda geliştirme aşamasında. Şimdilik kapıda ödeme / nakit seçeneği ile rezervasyon tamamlayabilirsiniz.', false);
                    return;
                }

                if (profileCompletionRequired) {
                    event.preventDefault();
                    hydrateProfileAddressSelectors();
                    openModal(profileModal);
                }
            });

            profileCompletionForm?.addEventListener('submit', async function (event) {
                event.preventDefault();
                profileFeedback.hidden = true;
                const formData = new FormData(profileCompletionForm);

                try {
                    const response = await fetch(profileCompletionForm.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Bilgiler kaydedilemedi.');
                    }

                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback success';
                    profileFeedback.textContent = payload.message;
                    window.setTimeout(function () {
                        markProfileCompletionResolved();
                        closeModal(profileModal);
                        resumeDraftFlow();
                    }, 700);
                } catch (error) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = error.message || 'Bilgiler kaydedilemedi.';
                }
            });

            startConversationBtn?.addEventListener('click', async function () {
                const authenticated = startConversationBtn.dataset.authenticated === 'true';
                const canStart = startConversationBtn.dataset.canStart === 'true';
                const infoMessage = startConversationBtn.dataset.infoMessage || 'Görüşme başlatılamıyor.';

                if (!authenticated) {
                    showInfoModal('Otel ile görüşme başlatmak için önce kullanıcı hesabınızla giriş yapmalısınız.', true);
                    return;
                }

                if (!canStart) {
                    showInfoModal(infoMessage, false);
                    return;
                }

                try {
                    const token = bookingForm?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch('/oteller/@Model.Slug/gorusme-baslat', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'X-CSRF-TOKEN': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Görüşme başlatılamadı.');
                    }

                    window.location.href = payload.redirectUrl;
                } catch (error) {
                    showInfoModal(error.message || 'Görüşme başlatılamadı.', false);
                }
            });

            const locationQuery = new URLSearchParams(window.location.search);
            const shouldOpenProfileFromQuery = locationQuery.get('openProfile') === '1';
            if (window.matchMedia('(max-width: 860px)').matches) {
                bookingAdvancedFields?.removeAttribute('open');
            }

            if (shouldOpenProfileFromQuery && @((Model.ActiveDraft is not null && Model.IsLoggedInUser) ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft?.RequiresProfileCompletion == true && Model.IsLoggedInUser ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft is not null && Model.ActiveDraft.RequiresProfileCompletion == false ? "true" : "false")) {
                resumeDraftFlow();
            }

            // init first room row (single-room compatible)
            if (getRoomItemNodes().length === 0) {
                addRoomItem({
                    roomTypeId: parseInt(roomTypeIdInput?.value || '@reservationForm.RoomTypeId', 10) || 0,
                    checkIn: checkInInput?.value || '@checkInDefault',
                    checkOut: checkOutInput?.value || '@checkOutDefault'
                });
            }
            renumberRoomItems();
            syncRoomsJsonAndHiddenFields();
            syncGuestInputs();
            ensureGuestCapacity(false);
            syncPaymentMethodState();
            refreshPriceQuote();
            initReviewReadMore();
            initRoomFeaturePanels();
            paymentMethodSelect?.addEventListener('change', syncPaymentMethodState);

            const reviewSortSelect = document.getElementById('reviewSortSelect');
            reviewSortSelect?.addEventListener('change', function () {
                const url = new URL(window.location.href);
                url.searchParams.set('reviewSort', reviewSortSelect.value || 'new');
                url.searchParams.set('reviewPage', '1');
                const reviewDynamic = document.getElementById('reviewSectionDynamic');
                if (!reviewDynamic) {
                    window.location.href = url.toString();
                    return;
                }

                fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const next = doc.getElementById('reviewSectionDynamic');
                        if (!next) {
                            window.location.href = url.toString();
                            return;
                        }
                        reviewDynamic.innerHTML = next.innerHTML;
                        initReviewReadMore();
                    })
                    .catch(function () {
                        window.location.href = url.toString();
                    });
            });
        })();
    </script>
    <script>
        (function () {
            const modal = document.getElementById('roomGalleryModal');
            const mainImage = document.getElementById('roomGalleryMainImage');
            const title = document.getElementById('roomGalleryTitle');
            const thumbs = document.getElementById('roomGalleryThumbs');
            const prevButton = document.getElementById('roomGalleryPrev');
            const nextButton = document.getElementById('roomGalleryNext');
            const triggers = document.querySelectorAll('.room-gallery-trigger');
            let galleryItems = [];
            let currentIndex = 0;
            let currentRoomName = '';

            function renderGallery() {
                if (!mainImage || !title || !thumbs || galleryItems.length === 0) {
                    return;
                }

                mainImage.src = galleryItems[currentIndex];
                mainImage.alt = currentRoomName + ' gorsel ' + (currentIndex + 1);
                title.textContent = currentRoomName + ' · ' + (currentIndex + 1) + '/' + galleryItems.length;
                thumbs.innerHTML = galleryItems.map(function (item, index) {
                    const isActive = index === currentIndex ? 'active' : '';
                    return '<button type="button" class="room-gallery-thumb ' + isActive + '" data-room-thumb-index="' + index + '">' +
                        '<img src="' + item + '" alt="' + currentRoomName + ' kucuk gorsel ' + (index + 1) + '">' +
                        '</button>';
                }).join('');

                thumbs.querySelectorAll('[data-room-thumb-index]').forEach(function (button) {
                    button.addEventListener('click', function () {
                        currentIndex = Number(button.getAttribute('data-room-thumb-index') || '0');
                        renderGallery();
                    });
                });
            }

            function openGallery(items, roomName, startIndex) {
                if (!modal || !items || items.length === 0) {
                    return;
                }

                galleryItems = items;
                currentRoomName = roomName || 'Oda';
                currentIndex = Math.max(0, Math.min(startIndex || 0, items.length - 1));
                renderGallery();
                modal.hidden = false;
                document.body.classList.add('room-gallery-open');
            }

            function closeGallery() {
                if (!modal) {
                    return;
                }

                modal.hidden = true;
                document.body.classList.remove('room-gallery-open');
            }

            triggers.forEach(function (trigger) {
                trigger.addEventListener('click', function () {
                    const rawGallery = trigger.getAttribute('data-room-gallery') || '[]';
                    const startIndex = Number(trigger.getAttribute('data-room-gallery-start') || '0');
                    try {
                        const items = JSON.parse(rawGallery);
                        openGallery(Array.isArray(items) ? items : [], trigger.getAttribute('data-room-name') || 'Oda', startIndex);
                    } catch (_error) {
                        openGallery([], trigger.getAttribute('data-room-name') || 'Oda', startIndex);
                    }
                });
            });

            document.querySelectorAll('[data-room-gallery-close]').forEach(function (button) {
                button.addEventListener('click', closeGallery);
            });

            prevButton?.addEventListener('click', function () {
                if (galleryItems.length === 0) {
                    return;
                }

                currentIndex = (currentIndex - 1 + galleryItems.length) % galleryItems.length;
                renderGallery();
            });

            nextButton?.addEventListener('click', function () {
                if (galleryItems.length === 0) {
                    return;
                }

                currentIndex = (currentIndex + 1) % galleryItems.length;
                renderGallery();
            });

            document.addEventListener('keydown', function (event) {
                if (!modal || modal.hidden) {
                    return;
                }

                if (event.key === 'Escape') {
                    closeGallery();
                } else if (event.key === 'ArrowLeft') {
                    prevButton?.click();
                } else if (event.key === 'ArrowRight') {
                    nextButton?.click();
                }
            });
        })();
    </script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
