@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="anonymous"></script>
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        // Inline OtelDetay (v41) script'i aktif: legacy `otel-detay.js` içindeki minimal multi-room init'i devre dışı bırakmak için.
        window.__otelDetayInlineV41 = true;
        window.__otelDetayConfig = {
            hotelTitle: '@Model.Name',
            galleryImages: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(gallery)),
            roomGalleries: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(roomGalleryMap)),
            roomDetails: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(roomDetailsMap)),
            activeDraftResumeUrl: '@(Model.ActiveDraft?.ResumeUrl ?? "")',
            activeDraftPromptMessage: '@(Model.ActiveDraft?.Message ?? "")',
            shouldPromptActiveDraft: false
        };

        (function () {
            const galleryImages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(gallery));
            const mainImage = document.getElementById('mainGalleryImage');
            const mainImageWrap = document.querySelector('.gallery-main-image');
            // SlaytGorsel ortak bileşen (layout'ta yüklü)
            const favoriteButtons = Array.from(document.querySelectorAll('.favorite-btn'));
            const bookingForm = document.getElementById('bookingForm');
            const paymentMethodSelect = document.getElementById('paymentMethodSelect');
            const roomsJsonInput = document.getElementById('roomsJsonInput');
            const roomItemsRoot = document.getElementById('roomItems');
            const roomItemTemplate = document.getElementById('roomItemTemplate');
            const addRoomBtn = document.getElementById('addRoomBtn');
            const roomTypeIdInput = document.getElementById('roomTypeIdInput');
            const checkInInput = document.getElementById('checkInDateInput');
            const checkOutInput = document.getElementById('checkOutDateInput');
            const bookingPrice = document.getElementById('bookingPrice');
            const breakdown = document.getElementById('priceBreakdown');
            const nightlyDetails = document.getElementById('nightlyBreakdownDetails');
            const nightlyList = document.getElementById('nightlyBreakdownList');
            const bookingQuoteNotice = document.getElementById('bookingQuoteNotice');
            const bookingPaymentNote = document.getElementById('bookingPaymentNote');
            const bookingPaymentMix = document.getElementById('bookingPaymentMix');
            let profileCompletionRequired = document.getElementById('profileCompletionRequired')?.value === 'true';
            let hasAutoPromptedProfileCompletion = false;
            const actionBackdrop = document.getElementById('detailActionBackdrop');
            const profileModal = document.getElementById('profileCompletionModal');
            const infoModal = document.getElementById('detailInfoModal');
            const infoModalTitle = document.getElementById('detailInfoModalTitle');
            const defaultInfoModalTitle = infoModalTitle?.textContent || 'Önce bir adımı tamamlayalım';
            const infoModalText = document.getElementById('detailInfoModalText');
            const infoModalActions = document.getElementById('detailInfoModalActions');
            const reservationConfirmModal = document.getElementById('reservationConfirmModal');
            const reservationConfirmSummary = document.getElementById('reservationConfirmSummary');
            const reservationConfirmSubmitBtn = document.getElementById('reservationConfirmSubmitBtn');
            const profileFeedback = document.getElementById('profileCompletionFeedback');
            const profileCompletionForm = document.getElementById('profileCompletionForm');
            const startConversationBtn = document.getElementById('startConversationBtn');
            const weatherPopup = document.getElementById('weatherPopup');
            const weatherPopupBackdrop = document.getElementById('weatherPopupBackdrop');
            const weatherPopupOpen = document.getElementById('weatherPopupOpen');
            const weatherPopupClose = document.getElementById('weatherPopupClose');
            const shareButton = document.getElementById('shareHotelBtn');
            const shareMenu = document.getElementById('shareMenu');
            const bookingAdvancedFields = document.getElementById('bookingAdvancedFields');
            const bookingSidebar = document.getElementById('bookingSidebar') || document.querySelector('.booking-sidebar');
            const bookingModalBackdrop = document.getElementById('bookingModalBackdrop');
            const bookingModalClose = document.getElementById('bookingModalClose');
            const openBookingSheetBtn = document.getElementById('openBookingSheetBtn');
            const mobileBookingPrice = document.getElementById('mobileBookingPrice');
            const activeDraftResumeLink = document.querySelector('.active-draft-link');
            const activeDraftMessage = document.querySelector('.active-draft-message');
            const openProfileCompletionFromBanner = document.getElementById('openProfileCompletionFromBanner');
            const openAmenitiesModal = document.getElementById('openAmenitiesModal');
            const amenitiesModal = document.getElementById('amenitiesModal');
            const cancelDraftForm = document.getElementById('cancelDraftForm');
            const activeDraftResumeUrl = '@(Model.ActiveDraft?.ResumeUrl ?? "")';
            const activeDraftPromptMessage = '@(Model.ActiveDraft?.Message ?? "")';
            const shouldPromptActiveDraft = false;
            const roomDetailModal = document.getElementById('roomDetailModal');
            const roomDetailModalTitle = document.getElementById('roomDetailModalTitle');
            const roomDetailModalRoomName = document.getElementById('roomDetailModalRoomName');
            const roomDetailModalSpecs = document.getElementById('roomDetailModalSpecs');
            const roomDetailModalDescription = document.getElementById('roomDetailModalDescription');
            const roomDetailModalCancellation = document.getElementById('roomDetailModalCancellation');
            const roomDetailModalGalleryBadge = document.getElementById('roomDetailModalGalleryBadge');
            const roomDetailModalFeatureBadge = document.getElementById('roomDetailModalFeatureBadge');
            const roomDetailModalGalleryOpen = document.getElementById('roomDetailModalGalleryOpen');
            const roomDetailModalBedType = document.getElementById('roomDetailModalBedType');
            const roomDetailModalSquareMeter = document.getElementById('roomDetailModalSquareMeter');
            const roomDetailModalCapacity = document.getElementById('roomDetailModalCapacity');
            const roomDetailModalPrice = document.getElementById('roomDetailModalPrice');
            const roomDetailModalSelectBtn = document.getElementById('roomDetailModalSelectBtn');
            const roomDetailModalGrid = document.getElementById('roomDetailModalGrid');
            const galleryMobileTrack = document.getElementById('galleryMobileTrack');
            const galleryMobileDots = Array.from(document.querySelectorAll('[data-gallery-dot-index]'));
            let adults = parseInt(document.getElementById('adultCountInput')?.value || '2', 10);
            let children = parseInt(document.getElementById('childCountInput')?.value || '0', 10);
            const roomCountInput = document.getElementById('roomCountInput');
            let latestQuoteRequest = null;
            let activeGalleryIndex = 0;
            let galleryScrollTicking = false;
            let activeRoomDetailGalleryItems = [];
            let activeRoomDetailName = 'Oda';
            let activeRoomDetailRoomId = '';
            let reservationSubmitConfirmed = false;
            let shouldResumeReservationAfterProfile = false;

            function pulseFavorite(btn) {
                if (!btn) return;
                btn.classList.remove('is-fav-burst');
                // reflow
                void btn.offsetWidth;
                btn.classList.add('is-fav-burst');
                window.setTimeout(() => btn.classList.remove('is-fav-burst'), 520);
            }

            function initFavoriteAnimations() {
                if (!favoriteButtons || favoriteButtons.length === 0) return;
                favoriteButtons.forEach((btn) => {
                    btn.addEventListener('click', () => {
                        window.setTimeout(() => {
                            if (btn.classList.contains('active')) {
                                pulseFavorite(btn);
                            }
                        }, 120);
                    }, { passive: true });
                });
            }

            function initDetailLocationMap() {
                const mapEl = document.getElementById('detailLocationMap');
                if (!mapEl || !window.L) {
                    return;
                }

                const lat = Number(mapEl.getAttribute('data-lat') || '');
                const lon = Number(mapEl.getAttribute('data-lon') || '');
                if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
                    return;
                }

                const hotelName = (mapEl.getAttribute('data-name') || 'Otel').trim();
                const location = (mapEl.getAttribute('data-location') || '').trim();
                const map = window.L.map(mapEl, {
                    zoomControl: true,
                    scrollWheelZoom: true
                });

                window.L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                    maxZoom: 19,
                    subdomains: 'abcd',
                    attribution: '&copy; OpenStreetMap katkıda bulunanlar &copy; CARTO'
                }).addTo(map);

                const flagIcon = window.L.divIcon({
                    className: 'detail-map-flag-icon',
                    html:
                        '<div class="detail-map-flag">' +
                            '<span class="detail-map-flag__name">' + hotelName + '</span>' +
                            '<small class="detail-map-flag__area">' + location + '</small>' +
                        '</div>',
                    iconSize: [168, 44],
                    iconAnchor: [26, 44],
                    popupAnchor: [64, -34]
                });

                const marker = window.L.marker([lat, lon], { icon: flagIcon }).addTo(map);
                marker.bindPopup(
                    '<strong>' + hotelName + '</strong><br>' +
                    (location ? '<span>' + location + '</span>' : '')
                );
                map.setView([lat, lon], 14);
            }

            initFavoriteAnimations();

            initDetailLocationMap();

            function scrollToBookingArea() {
                if (!(bookingSidebar instanceof HTMLElement)) {
                    return;
                }

                const top = bookingSidebar.getBoundingClientRect().top + window.scrollY - 76;
                window.scrollTo({
                    top: Math.max(0, top),
                    behavior: 'smooth'
                });
            }
            // SlaytGorsel kendi içinde scroll kilidi yönetir.

            function isMobileBookingMode() {
                return window.matchMedia && window.matchMedia('(max-width: 900px)').matches;
            }

            function openBookingSheet() {
                if (!bookingSidebar || !bookingModalBackdrop) {
                    return;
                }

                bookingModalBackdrop.hidden = false;
                bookingSidebar.classList.add('is-open');
                bookingModalBackdrop.classList.add('is-open');
                document.documentElement.classList.add('modal-open');
                document.body.classList.add('modal-open');

                // Profil eksikse banner yerine modal ile yönlendir.
                if (profileCompletionRequired && !hasAutoPromptedProfileCompletion) {
                    hasAutoPromptedProfileCompletion = true;
                    window.setTimeout(function () {
                        openProfileCompletionModal('Rezervasyonunuza devam edebilmek için eksik profil bilgilerinizi tamamlayın.');
                    }, 120);
                }
            }

            function closeBookingSheet() {
                if (!bookingSidebar || !bookingModalBackdrop) {
                    return;
                }

                bookingSidebar.classList.remove('is-open');
                bookingModalBackdrop.classList.remove('is-open');
                document.documentElement.classList.remove('modal-open');
                document.body.classList.remove('modal-open');
                window.setTimeout(function () {
                    bookingModalBackdrop.hidden = true;
                }, 220);
            }

            // İlk yüklemede de seçili görselin blur arkaplanını set et
            if (mainImageWrap instanceof HTMLElement && mainImage instanceof HTMLImageElement && mainImage.src) {
                mainImageWrap.style.setProperty('--hotel-main-ambient', 'url(\"' + mainImage.src + '\")');
            }

            function syncGuestInputs() {
                document.getElementById('adultCount').textContent = adults;
                document.getElementById('adultCountInput').value = adults;
                document.getElementById('childCount').textContent = children;
                document.getElementById('childCountInput').value = children;
            }

            function getRoomItemNodes() {
                if (!roomItemsRoot) {
                    return [];
                }
                return Array.from(roomItemsRoot.querySelectorAll('[data-room-item]'));
            }

            function getRoomItemData(item) {
                const roomTypeSelect = item?.querySelector('[data-field="roomType"]');
                const checkIn = item?.querySelector('[data-field="checkIn"]');
                const checkOut = item?.querySelector('[data-field="checkOut"]');
                const selectedOption = roomTypeSelect?.selectedOptions?.[0];
                const roomTypeId = parseInt(roomTypeSelect?.value || '0', 10) || 0;
                const roomName = selectedOption?.dataset.roomName || selectedOption?.textContent?.trim() || 'Seçilen oda';
                const maxGuests = Math.max(1, parseInt(selectedOption?.dataset.maxGuests || '1', 10) || 1);
                const maxAdults = Math.max(1, parseInt(selectedOption?.dataset.maxAdults || String(maxGuests), 10) || maxGuests);
                const maxChildren = Math.max(0, parseInt(selectedOption?.dataset.maxChildren || '0', 10) || 0);
                return {
                    roomTypeId,
                    roomName,
                    checkIn: checkIn?.value || '',
                    checkOut: checkOut?.value || '',
                    roomCount: 1,
                    capacity: { roomName, maxGuests, maxAdults, maxChildren }
                };
            }

            function syncLegacyHiddenInputsFromFirstItem() {
                const items = getRoomItemNodes();
                const first = items[0];
                if (!first) {
                    return;
                }
                const data = getRoomItemData(first);
                if (roomTypeIdInput) {
                    roomTypeIdInput.value = String(data.roomTypeId || 0);
                }
                if (checkInInput) {
                    checkInInput.value = data.checkIn || '';
                }
                if (checkOutInput) {
                    checkOutInput.value = data.checkOut || '';
                }
            }

            function getRoomCountValue() {
                return Math.max(1, parseInt(roomCountInput?.value || '1', 10) || 1);
            }

            function buildRoomCapacityMessage(capacity, totalAdults, totalChildren, roomCountValue, isMultiRoom) {
                const allowedGuestsTotal = capacity.maxGuests * roomCountValue;
                const allowedAdultsTotal = capacity.maxAdults * roomCountValue;
                const allowedChildrenTotal = capacity.maxChildren * roomCountValue;
                const totalGuests = totalAdults + totalChildren;

                if (totalAdults > allowedAdultsTotal) {
                    if (isMultiRoom) {
                        const requiredRooms = Math.ceil(totalAdults / capacity.maxAdults);
                        const missing = Math.max(0, requiredRooms - roomCountValue);
                        return `Seçilen oda(lar) toplam yetişkin kapasitesi ${allowedAdultsTotal} kişi. ${totalAdults} yetişkin için en az ${requiredRooms} oda gerekir. ${missing > 0 ? `Lütfen ${missing} oda daha ekleyin.` : 'Lütfen oda seçiminizi kontrol edin.'}`;
                    } else {
                        const requiredRooms = Math.ceil(totalAdults / capacity.maxAdults);
                        return `${capacity.roomName} odası kişi kapasitesi: en fazla ${capacity.maxAdults} yetişkin. ${totalAdults} yetişkin için en az ${requiredRooms} oda kiralamanız gerekmektedir.`;
                    }
                }

                if (totalChildren > allowedChildrenTotal) {
                    if (isMultiRoom) {
                        const requiredRooms = capacity.maxChildren > 0
                            ? Math.ceil(totalChildren / capacity.maxChildren)
                            : roomCountValue + 1;
                        const missing = Math.max(0, requiredRooms - roomCountValue);
                        return `Seçilen oda(lar) toplam çocuk kapasitesi ${allowedChildrenTotal} kişi. ${totalChildren} çocuk için en az ${requiredRooms} oda gerekir. ${missing > 0 ? `Lütfen ${missing} oda daha ekleyin.` : 'Lütfen oda seçiminizi kontrol edin.'}`;
                    } else {
                        const requiredRooms = capacity.maxChildren > 0
                            ? Math.ceil(totalChildren / capacity.maxChildren)
                            : roomCountValue + 1;
                        return `${capacity.roomName} odası kişi kapasitesi: en fazla ${capacity.maxChildren} çocuk. ${totalChildren} çocuk için en az ${requiredRooms} oda kiralamanız gerekmektedir.`;
                    }
                }

                if (totalGuests > allowedGuestsTotal) {
                    if (isMultiRoom) {
                        const requiredRooms = Math.ceil(totalGuests / capacity.maxGuests);
                        const missing = Math.max(0, requiredRooms - roomCountValue);
                        return `Seçilen oda(lar) toplam kapasitesi ${allowedGuestsTotal} kişi. Toplam ${totalGuests} misafir için en az ${requiredRooms} oda gerekir. ${missing > 0 ? `Lütfen ${missing} oda daha ekleyin.` : 'Lütfen oda seçiminizi kontrol edin.'}`;
                    } else {
                        const requiredRooms = Math.ceil(totalGuests / capacity.maxGuests);
                        return `${capacity.roomName} odası ${capacity.maxGuests} kişiliktir. Toplam ${totalGuests} misafir için en az ${requiredRooms} oda kiralamanız gerekmektedir.`;
                    }
                }

                return null;
            }

            function ensureGuestCapacity(showWarning) {
                const items = getRoomItemNodes();
                if (!items.length) {
                    return true;
                }

                const roomCountValue = Math.max(1, items.length);
                const totalCapacity = items
                    .map(getRoomItemData)
                    .reduce(function (acc, item) {
                        acc.maxGuests += item.capacity.maxGuests;
                        acc.maxAdults += item.capacity.maxAdults;
                        acc.maxChildren += item.capacity.maxChildren;
                        acc.roomName = item.capacity.roomName;
                        return acc;
                    }, { roomName: 'Seçilen oda', maxGuests: 0, maxAdults: 0, maxChildren: 0 });

                const isMulti = items.length > 1;
                const roomCapacityMessage = buildRoomCapacityMessage(totalCapacity, adults, children, roomCountValue, isMulti);
                if (!roomCapacityMessage) {
                    return true;
                }

                if (showWarning) {
                    showInfoModal(roomCapacityMessage, false);
                }

                return false;
            }

            function setActiveMobileDot(index) {
                if (!galleryMobileDots.length) {
                    return;
                }

                galleryMobileDots.forEach(function (dot) {
                    const dotIndex = parseInt(dot.getAttribute('data-gallery-dot-index') || '0', 10);
                    const isActive = dotIndex === index;
                    dot.classList.toggle('active', isActive);
                    dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });
            }

            function scrollMobileTrackTo(index) {
                if (!galleryMobileTrack) {
                    return;
                }

                const slide = galleryMobileTrack.querySelector('[data-gallery-index="' + index + '"]');
                if (!slide) {
                    return;
                }

                slide.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
            }

            function syncMainImage(index) {
                if (!Array.isArray(galleryImages) || !galleryImages.length || !mainImage) {
                    return;
                }

                const safeIndex = Math.min(Math.max(index, 0), galleryImages.length - 1);
                activeGalleryIndex = safeIndex;
                mainImage.src = galleryImages[safeIndex];
                if (mainImageWrap instanceof HTMLElement) {
                    mainImageWrap.style.setProperty('--hotel-main-ambient', 'url(\"' + (galleryImages[safeIndex] || '') + '\")');
                }
                const counter = document.getElementById('galleryCountBadge');
                if (counter) {
                    const currentEl = counter.querySelector('.gallery-count-badge__current');
                    if (currentEl) currentEl.textContent = String(safeIndex + 1);
                }
                document.querySelectorAll('.gallery-thumb, .gallery-filmstrip-thumb').forEach(function (thumb) {
                    const thumbIndex = parseInt(thumb.getAttribute('data-gallery-index') || '0', 10);
                    thumb.classList.toggle('active', thumbIndex === safeIndex);
                });
                setActiveMobileDot(safeIndex);
            }

            function openSlayt(images, title, startIndex) {
                if (!window.SlaytGorsel || !Array.isArray(images) || images.length === 0) {
                    return;
                }
                window.SlaytGorsel.open({
                    images: images,
                    title: title || '',
                    startIndex: startIndex || 0
                });
            }

            document.querySelectorAll('.gallery-thumb').forEach(function (button) {
                button.addEventListener('click', function () {
                    const index = parseInt(button.getAttribute('data-gallery-index') || '0', 10);
                    syncMainImage(index);
                });
            });

            document.querySelectorAll('.gallery-filmstrip-thumb').forEach(function (button) {
                button.addEventListener('click', function () {
                    const index = parseInt(button.getAttribute('data-gallery-index') || '0', 10);
                    syncMainImage(index);
                    openSlayt(galleryImages, '@Model.Name', index);
                });
            });

            document.querySelectorAll('.gallery-main-trigger, .gallery-mobile-slide').forEach(function (button) {
                button.addEventListener('click', function () {
                    const index = parseInt(button.getAttribute('data-gallery-index') || '0', 10);
                    syncMainImage(index);
                    scrollMobileTrackTo(index);
                    openSlayt(galleryImages, '@Model.Name', index);
                });
            });

            // Oda kartı görselleri: ortak slayt gösterim
            document.querySelectorAll('.room-gallery-trigger').forEach(function (button) {
                button.addEventListener('click', function () {
                    const roomId = button.getAttribute('data-room-id') || '';
                    const roomName = (button.getAttribute('data-room-name') || button.textContent || 'Oda').trim();
                    const startIdx = parseInt(button.getAttribute('data-room-gallery-start') || '0', 10) || 0;
                    const map = window.__otelDetayConfig?.roomGalleries || {};
                    const imgs = map[roomId] || map[String(roomId)] || [];
                    openSlayt(imgs, roomName, startIdx);
                });
            });

            galleryMobileDots.forEach(function (dot) {
                dot.addEventListener('click', function () {
                    const index = parseInt(dot.getAttribute('data-gallery-dot-index') || '0', 10);
                    syncMainImage(index);
                    scrollMobileTrackTo(index);
                });
            });

            galleryMobileTrack?.addEventListener('scroll', function () {
                if (galleryScrollTicking) {
                    return;
                }

                galleryScrollTicking = true;
                window.requestAnimationFrame(function () {
                    const slides = Array.from(galleryMobileTrack.querySelectorAll('.gallery-mobile-slide'));
                    if (!slides.length) {
                        galleryScrollTicking = false;
                        return;
                    }

                    const trackRect = galleryMobileTrack.getBoundingClientRect();
                    const trackCenter = trackRect.left + (trackRect.width / 2);
                    let nearestIndex = activeGalleryIndex;
                    let nearestDistance = Number.POSITIVE_INFINITY;

                    slides.forEach(function (slide) {
                        const rect = slide.getBoundingClientRect();
                        const center = rect.left + (rect.width / 2);
                        const distance = Math.abs(center - trackCenter);
                        if (distance < nearestDistance) {
                            nearestDistance = distance;
                            nearestIndex = parseInt(slide.getAttribute('data-gallery-index') || '0', 10);
                        }
                    });

                    if (nearestIndex !== activeGalleryIndex) {
                        syncMainImage(nearestIndex);
                    } else {
                        setActiveMobileDot(nearestIndex);
                    }

                    galleryScrollTicking = false;
                });
            });

            // Not: Eski inline lightbox event'leri kaldırıldı; ortak SlaytGorsel kullanılıyor.

            function ensureSelectButtonOriginalText(button) {
                if (!button) return;
                if (!button.dataset.originalText) {
                    button.dataset.originalText = button.textContent?.trim() || 'Odanı Seç';
                }
            }

            function getRoomSelectionMap() {
                const nodes = getRoomItemNodes();
                const map = new Map(); // roomTypeId(string) -> [index...]
                nodes.forEach(function (node, idx) {
                    const select = node?.querySelector('[data-field="roomType"]');
                    const value = (select && 'value' in select) ? String(select.value || '') : '';
                    if (!value) return;
                    const arr = map.get(value) || [];
                    arr.push(idx);
                    map.set(value, arr);
                });
                return map;
            }

            function updateSelectRoomButtons() {
                const selectionMap = getRoomSelectionMap();
                document.querySelectorAll('.select-room-btn').forEach(function (btn) {
                    ensureSelectButtonOriginalText(btn);
                    const roomId = String(btn.getAttribute('data-room-id') || '');
                    const indexes = roomId ? (selectionMap.get(roomId) || []) : [];
                    if (!indexes.length) {
                        btn.classList.remove('is-selected-room');
                        btn.textContent = btn.dataset.originalText || 'Odanı Seç';
                        btn.removeAttribute('title');
                        return;
                    }

                    btn.classList.add('is-selected-room');
                    const lastPicked = parseInt(btn.dataset.lastPickedRoomIndex || '', 10);
                    const preferIndex = Number.isFinite(lastPicked) && indexes.includes(lastPicked) ? lastPicked : indexes[0];
                    const listLabel = indexes.map(function (i) { return 'Oda ' + (i + 1); }).join(', ');
                    btn.title = 'Seçili: ' + listLabel;

                    // Daha anlaşılır: seçili oda + toplam adet rozeti
                    const count = indexes.length;
                    btn.innerHTML =
                        '<span class="select-room-btn-text">Oda ' + (preferIndex + 1) + ' seçili</span>'
                        + (count > 1 ? '<span class="select-room-btn-count" aria-label="' + count + ' adet oda seçili">' + count + '</span>' : '');
                });
            }

            document.querySelectorAll('.select-room-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    const roomId = button.getAttribute('data-room-id');
                    const nodes = getRoomItemNodes();
                    const popover = document.getElementById('roomPickPopover');
                    const popoverGrid = document.getElementById('roomPickPopoverGrid');

                    function closeRoomPickPopover() {
                        if (!popover) return;
                        popover.hidden = true;
                        popover.setAttribute('aria-hidden', 'true');
                        popoverGrid && (popoverGrid.innerHTML = '');
                    }

                    function openRoomPickPopover() {
                        if (!popover || !popoverGrid) {
                            return false;
                        }

                        // Mobilde popover yerine mevcut modal akışı daha iyi.
                        if (window.matchMedia('(max-width: 860px)').matches) {
                            return false;
                        }

                        popoverGrid.innerHTML = nodes.map(function (_n, idx) {
                            return '<button type="button" class="room-pick-popover__btn" data-pick-room-index="' + idx + '"><span>Oda ' + (idx + 1) + '</span></button>';
                        }).join('');

                        const rect = button.getBoundingClientRect();
                        const top = Math.max(10, rect.bottom + window.scrollY + 8);
                        const left = Math.min(window.scrollX + rect.left, (window.scrollX + window.innerWidth) - 260);
                        popover.style.top = top + 'px';
                        popover.style.left = left + 'px';
                        popover.hidden = false;
                        popover.setAttribute('aria-hidden', 'false');

                        popoverGrid.querySelectorAll('[data-pick-room-index]').forEach(function (pickBtn) {
                            pickBtn.addEventListener('click', function () {
                                const idx = parseInt(pickBtn.getAttribute('data-pick-room-index') || '0', 10);
                                closeRoomPickPopover();
                                applyRoomSelectionToIndex(Number.isFinite(idx) ? idx : 0);
                            });
                        });

                        // dışarı tıkla kapat
                        const onDocClick = function (evt) {
                            const t = evt.target;
                            if (!(t instanceof HTMLElement)) return;
                            if (t.closest('#roomPickPopover')) return;
                            if (t.closest('.select-room-btn') === button) return;
                            document.removeEventListener('click', onDocClick, true);
                            closeRoomPickPopover();
                        };
                        document.addEventListener('click', onDocClick, true);
                        // ESC ile kapat
                        const onKey = function (evt) {
                            if (evt.key === 'Escape') {
                                document.removeEventListener('keydown', onKey, true);
                                closeRoomPickPopover();
                            }
                        };
                        document.addEventListener('keydown', onKey, true);
                        return true;
                    }

                    function applyRoomSelectionToIndex(index) {
                        const target = nodes[index] || null;
                        const select = target?.querySelector('[data-field="roomType"]');
                        if (select && roomId) {
                            select.value = roomId;
                        }
                        setActiveRoomIndex(index);
                        syncRoomsJsonAndHiddenFields();
                        ensureGuestCapacity(true);
                        refreshPriceQuote();
                        if (isMobileBookingMode()) {
                            openBookingSheet();
                            setTimeout(scrollToBookingArea, 90);
                        } else {
                            scrollToBookingArea();
                        }
                        button.dataset.lastPickedRoomIndex = String(index);
                        updateSelectRoomButtons();
                    }

                    // Yeni davranış: Aynı oda tipinden birden fazla seçilebilsin diye her tıklamada yeni oda satırı ekle.
                    // (Eski "hangi odaya uygula" akışı yerine, hızlı şekilde çoğaltma.)
                    if (roomId) {
                        const first = nodes.length ? getRoomItemData(nodes[0]) : null;
                        addRoomItem(first ? { roomTypeId: roomId, checkIn: first.checkIn, checkOut: first.checkOut } : { roomTypeId: roomId });
                        const nextNodes = getRoomItemNodes();
                        const newIndex = Math.max(0, nextNodes.length - 1);
                        setActiveRoomIndex(newIndex);
                        syncRoomsJsonAndHiddenFields();
                        ensureGuestCapacity(true);
                        refreshPriceQuote();
                        if (isMobileBookingMode()) {
                            openBookingSheet();
                            setTimeout(scrollToBookingArea, 90);
                        } else {
                            scrollToBookingArea();
                        }
                        button.dataset.lastPickedRoomIndex = String(newIndex);
                        updateSelectRoomButtons();
                        return;
                    }

                    // tek oda: direkt uygula
                    if (nodes.length <= 1) {
                        applyRoomSelectionToIndex(0);
                        return;
                    }

                    // çoklu oda: hangi oda güncellensin?
                    // Önce eski davranış: buton yanında katman/popup ile oda 1-2-3 seçimi.
                    if (openRoomPickPopover()) {
                        return;
                    }

                    // Popover kullanılamıyorsa: fallback modal
                    if (!infoModal || !infoModalText || !infoModalActions) {
                        applyRoomSelectionToIndex(0);
                        return;
                    }

                    const pickedTitle = button.closest('.room-card')?.querySelector('.room-card-copy h3')?.textContent?.trim() || 'Seçilen oda';
                    infoModalText.textContent = '“' + pickedTitle + '” oda tipini hangi oda için uygulayalım?';
                    const titleEl = document.getElementById('detailInfoModalTitle');
                    if (titleEl) {
                        titleEl.innerHTML = '<span class="detail-modal-title-icon" aria-hidden="true"><i class="fas fa-bed"></i></span><span>Oda seçimi</span>';
                    }
                    infoModal.classList.add('is-room-pick');

                    infoModalActions.innerHTML =
                        nodes.map(function (_n, idx) {
                            return '<button type="button" class="detail-modal-primary room-pick-btn" data-pick-room-index="' + idx + '">Oda ' + (idx + 1) + '</button>';
                        }).join('') +
                        '<button type="button" class="detail-modal-secondary" data-close-modal="detailInfoModal">Vazgeç</button>';

                    openModal(infoModal);
                    infoModalActions.querySelectorAll('[data-pick-room-index]').forEach(function (pickBtn) {
                        pickBtn.addEventListener('click', function () {
                            const idx = parseInt(pickBtn.getAttribute('data-pick-room-index') || '0', 10);
                            closeModal(infoModal);
                            infoModal.classList.remove('is-room-pick');
                            applyRoomSelectionToIndex(Number.isFinite(idx) ? idx : 0);
                        });
                    });
                    infoModalActions.querySelectorAll('[data-close-modal]').forEach(function (btn) {
                        btn.addEventListener('click', function () {
                            closeModal(infoModal);
                            infoModal.classList.remove('is-room-pick');
                        });
                    });
                });
            });

            updateSelectRoomButtons();

            openBookingSheetBtn?.addEventListener('click', function () {
                if (!isMobileBookingMode()) {
                    scrollToBookingArea();
                    return;
                }
                openBookingSheet();
                setTimeout(scrollToBookingArea, 90);
            });

            bookingModalClose?.addEventListener('click', function () {
                closeBookingSheet();
            });

            bookingModalBackdrop?.addEventListener('click', function () {
                closeBookingSheet();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && bookingSidebar && bookingSidebar.classList.contains('is-open')) {
                    closeBookingSheet();
                }
            });

            document.querySelectorAll('.guest-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    const target = button.getAttribute('data-target');
                    const action = button.getAttribute('data-action');
                    const nextAdults = target === 'adult'
                        ? (action === 'plus' ? Math.min(adults + 1, 6) : Math.max(adults - 1, 1))
                        : adults;
                    const nextChildren = target === 'child'
                        ? (action === 'plus' ? Math.min(children + 1, 4) : Math.max(children - 1, 0))
                        : children;
                    const items = getRoomItemNodes();
                    const roomCountValue = Math.max(1, items.length);
                    const totalCapacity = items
                        .map(getRoomItemData)
                        .reduce(function (acc, item) {
                            acc.maxGuests += item.capacity.maxGuests;
                            acc.maxAdults += item.capacity.maxAdults;
                            acc.maxChildren += item.capacity.maxChildren;
                            acc.roomName = item.capacity.roomName;
                            return acc;
                        }, { roomName: 'Seçilen oda', maxGuests: 0, maxAdults: 0, maxChildren: 0 });
                    const roomCapacityMessage = buildRoomCapacityMessage(totalCapacity, nextAdults, nextChildren, roomCountValue, items.length > 1);
                    if (roomCapacityMessage) {
                        showInfoModal(roomCapacityMessage, false);
                        return;
                    }

                    if (target === 'adult') {
                        adults = nextAdults;
                    } else {
                        children = nextChildren;
                    }

                    syncGuestInputs();
                });
            });

            (function initHotelAboutClamp() {
                const textEl = document.getElementById('hotelAboutText');
                const toggleEl = document.getElementById('hotelAboutToggle');
                const tablerBtn = document.querySelector('[data-about-toggle]');
                if (!(textEl instanceof HTMLElement) || !(toggleEl instanceof HTMLButtonElement)) {
                    return;
                }

                function computeNeedsToggle() {
                    textEl.classList.remove('is-expanded');
                    textEl.classList.add('is-clamped');
                    const needs = textEl.scrollHeight > textEl.clientHeight + 2;
                    textEl.classList.toggle('has-toggle', needs);
                    if (!needs) {
                        textEl.classList.remove('is-clamped', 'has-toggle');
                    }
                    toggleEl.textContent = 'Tümünü gör';
                    if (tablerBtn instanceof HTMLElement) {
                        tablerBtn.hidden = !needs;
                        toggleEl.hidden = true;
                        if (needs) {
                            syncExpandedLabel(false);
                        }
                    } else {
                        toggleEl.hidden = !needs;
                    }
                }

                function syncExpandedLabel(expanded) {
                    const label = expanded ? 'Kapat' : 'Tümünü gör';
                    const icon = expanded ? 'fa-chevron-up' : 'fa-chevron-down';
                    toggleEl.textContent = label;
                    if (tablerBtn instanceof HTMLElement) {
                        tablerBtn.innerHTML = label + ' <i class="fas ' + icon + '" aria-hidden="true"></i>';
                    }
                }

                function onAboutToggleClick() {
                    const expanded = textEl.classList.toggle('is-expanded');
                    syncExpandedLabel(expanded);
                }

                toggleEl.addEventListener('click', onAboutToggleClick);
                if (tablerBtn instanceof HTMLButtonElement) {
                    tablerBtn.addEventListener('click', onAboutToggleClick);
                }

                computeNeedsToggle();
                window.addEventListener('resize', function () {
                    if (!textEl.classList.contains('is-expanded')) {
                        computeNeedsToggle();
                    }
                });
            })();

            function normalizeRoomItemDates(item) {
                const todayText = '@todayDate';
                const checkInEl = item?.querySelector('[data-field="checkIn"]');
                const checkOutEl = item?.querySelector('[data-field="checkOut"]');
                if (!checkInEl || !checkOutEl) {
                    return;
                }

                if (!checkInEl.value || checkInEl.value < todayText) {
                    checkInEl.value = todayText;
                }

                const checkInDate = new Date(checkInEl.value + 'T00:00:00');
                if (Number.isNaN(checkInDate.getTime())) {
                    return;
                }

                const minCheckOutDate = new Date(checkInDate);
                minCheckOutDate.setDate(minCheckOutDate.getDate() + 1);
                const minCheckOutText = minCheckOutDate.toISOString().slice(0, 10);
                checkOutEl.min = minCheckOutText;
                if (!checkOutEl.value || checkOutEl.value <= checkInEl.value) {
                    checkOutEl.value = minCheckOutText;
                }
            }

            function bindRoomItemEvents(item) {
                if (!item) return;
                item.querySelectorAll('select, input[type="date"]').forEach(function (el) {
                    el.addEventListener('change', function () {
                        const nodes = getRoomItemNodes();
                        const idx = nodes.indexOf(item);
                        if (idx >= 0) setActiveRoomIndex(idx);
                        normalizeRoomItemDates(item);
                        syncRoomsJsonAndHiddenFields();
                        ensureGuestCapacity(false);
                        refreshPriceQuote();
                    });
                });

                item.addEventListener('focusin', function () {
                    const nodes = getRoomItemNodes();
                    const idx = nodes.indexOf(item);
                    if (idx >= 0) setActiveRoomIndex(idx);
                });

                const removeBtn = item.querySelector('[data-remove-room]');
                removeBtn?.addEventListener('click', function () {
                    item.remove();
                    renumberRoomItems();
                    setActiveRoomIndex(0);
                    syncRoomsJsonAndHiddenFields();
                    ensureGuestCapacity(false);
                    refreshPriceQuote();
                });
            }

            function setActiveRoomIndex(index) {
                const nodes = getRoomItemNodes();
                const safeIndex = Math.max(0, Math.min(index || 0, nodes.length - 1));
                nodes.forEach(function (node, idx) {
                    node.classList.toggle('is-active', idx === safeIndex);
                });
            }

            function renumberRoomItems() {
                const nodes = getRoomItemNodes();
                nodes.forEach(function (node, idx) {
                    const title = node.querySelector('[data-room-title]');
                    if (title) {
                        title.textContent = 'Oda ' + (idx + 1);
                    }
                    node.setAttribute('data-room-index', String(idx));
                    node.classList.remove('room-tone-1', 'room-tone-2', 'room-tone-3', 'room-tone-4', 'room-tone-5', 'room-tone-6');
                    node.classList.add('room-tone-' + ((idx % 6) + 1));
                    const removeBtn = node.querySelector('[data-remove-room]');
                    if (removeBtn) {
                        removeBtn.hidden = nodes.length <= 1;
                    }
                });

                const root = document.getElementById('multiRoomRoot');
                if (root) {
