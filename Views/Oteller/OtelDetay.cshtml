            function buildReservationConfirmSummary(items) {
                if (!reservationConfirmSummary) {
                    return;
                }

                const paymentText = (paymentMethodSelect?.value || '').trim() || (confirmI18n.notSelected || 'Seçilmedi');
                const roomCards = items.map(function (item, index) {
                    const roomName = item.roomName || (confirmI18n.notSelected || 'Seçilmedi');
                    return buildConfirmRoomCard(item, index, roomName);
                }).join('');

                reservationConfirmSummary.innerHTML =
                    '<div class="reservation-confirm-stack">'
                    + roomCards
                    + buildConfirmPaymentCard(paymentText)
                    + '</div>';
                updateConfirmTotalDisplay();
            }

            function continueReservationAttemptAfterProfile() {
                if (!bookingForm) {
                    return;
                }

                syncRoomsJsonAndHiddenFields();
                const roomNodes = getRoomItemNodes();
                const items = roomNodes.map(getRoomItemData);
                const hasMissingRequiredInfo = roomNodes.length === 0
                    || items.some(function (x) {
                        return !x.roomTypeId
                            || !x.checkIn
                            || !x.checkOut
                            || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                    })
                    || adults < 1;
                if (hasMissingRequiredInfo) {
                    showInfoModal('Rezervasyon öncesi tarih, misafir ve oda bilgilerini kontrol edip tamamlayınız.', false);
                    return;
                }

                if (!ensureGuestCapacity(true)) {
                    return;
                }

                if (!isPaymentMethodChosen()) {
                    bookingAdvancedFields?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    showInfoModal('Lütfen ödeme planı seçiniz.', false, 'warning');
                    return;
                }

                buildReservationConfirmSummary(items);
                openModal(reservationConfirmModal);
            }

