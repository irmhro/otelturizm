            function scrollToElementWithOffset(targetEl, offset) {
                if (!(targetEl instanceof HTMLElement)) return;
                const top = targetEl.getBoundingClientRect().top + window.scrollY - (offset || 0);
                window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
            }

            const ratingSummaryJump = document.getElementById('ratingSummaryJump');
            ratingSummaryJump?.addEventListener('click', function () {
                const target = document.getElementById('reviewsSection');
                scrollToElementWithOffset(target, 86);
            });
            ratingSummaryJump?.addEventListener('keydown', function (event) {
                if (event.key === 'Enter' || event.key === ' ') {
