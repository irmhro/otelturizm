            function formatRatePct(value) {
                const n = Number(value || 0);
                if (!Number.isFinite(n) || n <= 0) {
                    return '0';
                }
                const t = n.toFixed(2);
                if (t.endsWith('.00')) {
                    return n.toFixed(0);
                }
                return t.replace(/0$/, '');
            }

            function escapeHtml(value) {
                return (value || '').toString()
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function buildTaxAndTotalRows(quote) {
                const vatR = typeof quote.vatRate === 'string' ? quote.vatRate : formatRatePct(quote.vatRate);
                const accR = typeof quote.accommodationTaxRate === 'string' ? quote.accommodationTaxRate : formatRatePct(quote.accommodationTaxRate);
                const dawnRow = Number(quote.dawnSurpriseDiscountAmount || 0) > 0
                    ? '<div class="price-row price-row-tax price-row-dawn"><span>Şafak Sürprizi <small class="tax-rate-hint">%' + escapeHtml(String(quote.dawnSurprisePercent || 0)) + '</small></span><strong>-' + formatMoney(quote.dawnSurpriseDiscountAmount) + '</strong></div>'
                    : '';
                const lateCheckoutRow = Number(quote.lateCheckoutSurchargeAmount || 0) > 0
                    ? '<div class="price-row price-row-tax price-row-late-checkout"><span>Geç çıkış ek gün</span><strong>' + formatMoney(quote.lateCheckoutSurchargeAmount) + '</strong></div>'
                    : '';
                return '<div class="price-row price-row-tax"><span>KDV <small class="tax-rate-hint">%' + vatR + '</small></span><strong>' + formatMoney(quote.vatAmount || 0) + '</strong></div>' +
                    '<div class="price-row price-row-tax"><span>Konaklama Vergisi <small class="tax-rate-hint">%' + accR + '</small></span><strong>' + formatMoney(quote.accommodationTaxAmount || 0) + '</strong></div>' +
                    '<div class="price-row price-row-tax"><span>Vergi ve Harçlar</span><strong>' + formatMoney(quote.taxAmount) + '</strong></div>' +
                    dawnRow +
                    lateCheckoutRow +
                    '<div class="price-row total"><span>Toplam</span><strong>' + formatMoney(quote.totalAmount) + '</strong></div>';
            }

            function buildQuoteBreakdownHtml(quote) {
                return buildTaxAndTotalRows(quote);
            }

            function setQuoteNotice(message, tone) {
                if (!bookingQuoteNotice) {
                    return;
                }

                if (!message) {
                    bookingQuoteNotice.hidden = true;
                    bookingQuoteNotice.className = 'booking-quote-notice';
                    bookingQuoteNotice.textContent = '';
                    return;
                }

                bookingQuoteNotice.hidden = false;
                bookingQuoteNotice.className = 'booking-quote-notice ' + (tone || 'info');
                bookingQuoteNotice.textContent = message;
            }

            function buildRoomLine(roomName, checkIn, checkOut, amountText, index) {
                const safeName = roomName || 'Oda';
                const safeIndex = (index || 0) + 1;
                const primary = safeIndex + '. ' + safeName;
                const secondary = (checkIn || '-') + ' → ' + (checkOut || '-');
                return '<div class="price-row price-row-room">' +
                    '<span class="price-row-label-stack">' +
                    '<span class="price-row-primary">' + primary + '</span>' +
                    '<small>' + secondary + '</small>' +
                    '</span>' +
                    '<strong>' + amountText + '</strong>' +
                    '</div>';
            }

            function buildMultiRoomBreakdownHtml(items, totals) {
                const roomLines = items.map(function (x, idx) {
                    return buildRoomLine(x.roomName, x.checkIn, x.checkOut, formatMoney(x.totalAmount || 0), idx);
                }).join('');
                return roomLines + buildTaxAndTotalRows(totals);
            }

            const loyaltyEstimateCache = new Map();

            async function resolveEarnPoints(totalAmount) {
                const total = Number(totalAmount || 0);
                if (total <= 0) {
                    return 0;
                }

                const cacheKey = String(Math.round(total));
                if (loyaltyEstimateCache.has(cacheKey)) {
                    return loyaltyEstimateCache.get(cacheKey);
                }

                try {
                    const response = await fetch('/oteller/puan-tahmini?amount=' + encodeURIComponent(total), {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (response.ok) {
                        const payload = await response.json();
                        const points = Number(payload.earnPoints || 0);
                        loyaltyEstimateCache.set(cacheKey, points);
                        return points;
                    }
                } catch (_error) {
                    // ignore
                }

                return 0;
            }

            function updateMobileBookingLoyalty(earnPoints) {
                const loyaltyEl = document.getElementById('mobileBookingLoyalty');
                if (!loyaltyEl) {
                    return;
                }

                const points = Number(earnPoints || 0);
                if (points > 0) {
                    loyaltyEl.innerHTML = '<i class="fas fa-gift" aria-hidden="true"></i> +' + points + ' puan kazanın';
                    loyaltyEl.hidden = false;
                } else {
                    loyaltyEl.textContent = '';
                    loyaltyEl.hidden = true;
                }
            }

            function updateMobileBookingSummary(summary) {
                const data = summary || {};
                const roomNameEl = document.getElementById('mobileBookingRoomName');
                const originalEl = document.getElementById('mobileBookingOriginal');
                const dawnEl = document.getElementById('mobileBookingDawn');
                const total = Number(data.totalAmount || 0);
                const originalTotal = Number(data.originalTotalAmount || 0);
                const dawnDiscount = Number(data.dawnSurpriseDiscountAmount || 0);
                const dawnPercent = Number(data.dawnSurprisePercent || 0);
                const roomName = (data.roomName || '').toString().trim();
                const hasDawn = dawnDiscount > 0 && dawnPercent > 0 && originalTotal > total;
                const earnPoints = data.earnPoints;

                if (roomNameEl) {
                    if (roomName) {
                        roomNameEl.textContent = roomName;
                        roomNameEl.hidden = false;
                        roomNameEl.title = roomName;
                    } else {
                        roomNameEl.textContent = '';
                        roomNameEl.hidden = true;
                        roomNameEl.removeAttribute('title');
                    }
                }

                if (mobileBookingPrice) {
                    mobileBookingPrice.textContent = total > 0 ? formatMoney(total) : '—';
                }

                if (originalEl) {
                    if (hasDawn) {
                        originalEl.textContent = formatMoney(originalTotal);
                        originalEl.hidden = false;
                        originalEl.setAttribute('aria-hidden', 'false');
                    } else {
                        originalEl.textContent = '';
                        originalEl.hidden = true;
                        originalEl.setAttribute('aria-hidden', 'true');
                    }
                }

                if (dawnEl) {
                    if (hasDawn) {
                        dawnEl.textContent = 'Şafak −%' + dawnPercent + ' · ' + formatMoney(dawnDiscount);
                        dawnEl.hidden = false;
                    } else {
                        dawnEl.textContent = '';
                        dawnEl.hidden = true;
                    }
                }

                if (earnPoints !== undefined && earnPoints !== null) {
                    updateMobileBookingLoyalty(earnPoints);
                } else if (total > 0) {
                    resolveEarnPoints(total).then(updateMobileBookingLoyalty);
                } else if (Object.prototype.hasOwnProperty.call(data, 'totalAmount')) {
                    updateMobileBookingLoyalty(0);
                }
            }

            function syncRoomsJsonAndHiddenFields() {
                const nodes = getRoomItemNodes();
                const items = nodes.map(getRoomItemData);

                // legacy hidden inputs: first item
                syncLegacyHiddenInputsFromFirstItem();

                // room count: toplam oda adedi (multi-room + adet)
                const totalRooms = items.reduce(function (sum, x) { return sum + Math.max(1, parseInt(x.roomCount || 1, 10) || 1); }, 0);
                if (roomCountInput) {
                    roomCountInput.value = String(Math.max(1, totalRooms));
                }

                // misafir sayıları: oda adedine göre çarp (per-room mantığı)
                const nextAdults = Math.max(1, adultsPerRoom) * Math.max(1, totalRooms);
                const nextChildren = Math.max(0, childrenPerRoom) * Math.max(1, totalRooms);
                adults = nextAdults;
                children = nextChildren;
                syncGuestInputs();

                // roomTypeId legacy: first item
                if (roomTypeIdInput && items[0]) {
                    roomTypeIdInput.value = String(items[0].roomTypeId || 0);
                }

                if (roomsJsonInput) {
                    roomsJsonInput.value = JSON.stringify(items.map(function (x) {
                        return {
                            roomTypeId: x.roomTypeId,
                            checkInDate: x.checkIn,
                            checkOutDate: x.checkOut,
                            roomCount: Math.max(1, parseInt(x.roomCount || 1, 10) || 1)
                        };
                    }));
                }

                // oda kartlarındaki "Oda 1/2 seçili" etiketlerini senkron tut
                updateSelectRoomButtons?.();
            }

            function updateBookingPriceHead(totals, nightsForNightly, roomsForNightly) {
                const nightlyRow = document.getElementById('bookingPriceNightlyRow');
                const totalRow = document.getElementById('bookingPriceTotalRow');
                const originalRow = document.getElementById('bookingPriceOriginalRow');
                const bookingNightlyFrom = document.getElementById('bookingNightlyFrom');
                const bookingPriceOriginal = document.getElementById('bookingPriceOriginal');
                const bookingPriceDawnPill = document.getElementById('bookingPriceDawnPill');
                const total = Number(totals.totalAmount || 0);
                const originalTotal = Number(totals.originalTotalAmount || 0);
                const dawnDiscount = Number(totals.dawnSurpriseDiscountAmount || 0);
                const dawnPercent = Number(totals.dawnSurprisePercent || 0);
                const hasTotal = total > 0;
                const hasDawn = dawnDiscount > 0 && dawnPercent > 0 && originalTotal > total;
                const nightlyAmount = hasTotal
                    ? Math.round(total / Math.max(1, nightsForNightly) / Math.max(1, roomsForNightly))
                    : 0;
                const showNightly = hasTotal && !hasDawn && nightsForNightly > 1;

                if (bookingPrice) {
                    bookingPrice.textContent = hasTotal ? formatMoney(total) : '—';
                }
                if (totalRow) {
                    totalRow.hidden = !hasTotal;
                }
                lastBookingTotalAmount = total;

                if (originalRow && bookingPriceOriginal) {
                    if (hasDawn) {
                        bookingPriceOriginal.textContent = formatMoney(originalTotal);
                        originalRow.hidden = false;
                        bookingPriceOriginal.setAttribute('aria-hidden', 'false');
                    } else {
                        bookingPriceOriginal.textContent = '';
                        originalRow.hidden = true;
                        bookingPriceOriginal.setAttribute('aria-hidden', 'true');
                    }
                }

                if (bookingPriceDawnPill) {
                    if (hasDawn) {
                        bookingPriceDawnPill.textContent = 'Şafak sürprizi −%' + dawnPercent + ' · ' + formatMoney(dawnDiscount);
                        bookingPriceDawnPill.hidden = false;
                    } else {
                        bookingPriceDawnPill.textContent = '';
                        bookingPriceDawnPill.hidden = true;
                    }
                }

                if (showNightly && nightlyAmount > 0) {
                    if (bookingNightlyFrom) bookingNightlyFrom.textContent = formatMoney(nightlyAmount);
                    if (nightlyRow) nightlyRow.hidden = false;
                } else if (nightlyRow) {
                    nightlyRow.hidden = true;
                }
            }

            let draftSaveTimer = null;
            function scheduleBookingDraftSave() {
                if (draftSaveTimer) {
                    window.clearTimeout(draftSaveTimer);
                }
                draftSaveTimer = window.setTimeout(function () {
                    draftSaveTimer = null;
                    persistBookingDraft();
                }, 900);
            }

            async function persistBookingDraft() {
                const formEl = document.getElementById('bookingForm');
                if (!(formEl instanceof HTMLFormElement)) {
                    return;
                }

                syncRoomsJsonAndHiddenFields();
                const tokenInput = formEl.querySelector('input[name="__RequestVerificationToken"]');
                const formData = new FormData(formEl);
                if (tokenInput instanceof HTMLInputElement && tokenInput.value) {
                    formData.set('__RequestVerificationToken', tokenInput.value);
                }

                try {
                    await fetch('/oteller/@Model.Slug/rezervasyon-taslagi-kaydet', {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                } catch (_error) {
                    // Taslak kaydi sessizce atlanir; rezervasyon sunucuda yeniden hesaplanir.
                }
            }

            async function refreshPriceQuote() {
                if (!bookingPrice || !breakdown) {
                    return;
                }

                if (nightlyDetails && nightlyList) {
                    nightlyDetails.hidden = true;
                    nightlyList.innerHTML = '';
                }

                const roomNodes = getRoomItemNodes();
                if (!roomNodes.length) {
                    return;
                }

                const items = roomNodes.map(getRoomItemData);
                const invalid = items.some(function (x) {
                    return !x.roomTypeId || !x.checkIn || !x.checkOut || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                });
                if (invalid) {
                    return;
                }

                // request-key to avoid race conditions
                latestQuoteRequest = items.map(function (x) { return x.roomTypeId + '|' + x.checkIn + '|' + x.checkOut; }).join('||');
                const requestKey = latestQuoteRequest;

                const totals = {
                    vatRate: detailVatPctLabel,
                    accommodationTaxRate: detailAccomPctLabel,
                    vatAmount: 0,
                    accommodationTaxAmount: 0,
                    taxAmount: 0,
                    totalAmount: 0,
                    originalTotalAmount: 0,
                    dawnSurprisePercent: 0,
                    dawnSurpriseDiscountAmount: 0,
                    lateCheckoutSurchargeAmount: 0,
                    lateCheckoutApplied: false
                };

                const perRoom = [];
                const nightlySeed = { byRoom: [] };
                let anyUnavailable = false;
                let availabilityMessage = '';

                for (let itemIndex = 0; itemIndex < items.length; itemIndex++) {
                    const item = items[itemIndex];
                    try {
                        const rc = Math.max(1, parseInt(item.roomCount || 1, 10) || 1);
                        const quoteParams = new URLSearchParams({
                            roomTypeId: String(item.roomTypeId),
                            checkInDate: item.checkIn,
                            checkOutDate: item.checkOut,
                            roomCount: String(rc)
                        });
                        if (itemIndex === 0) {
                            const guestCheckOut = getGuestCheckOutTimeValue();
                            if (guestCheckOut) {
                                quoteParams.set('checkOutTime', guestCheckOut);
                            }
                            quoteParams.set('applyLateCheckoutSurcharge', isLateCheckoutSelection() ? 'true' : 'false');
                        } else {
                            quoteParams.set('applyLateCheckoutSurcharge', 'false');
                        }
                        const response = await fetch('/oteller/@Model.Slug/fiyat-teklifi?' + quoteParams.toString(), {
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        if (!response.ok) {
                            throw new Error('Fiyat özeti alınamadı');
                        }
                        const quote = await response.json();
                        if (latestQuoteRequest !== requestKey) {
                            return;
                        }
                        if (!quote.success) {
                            throw new Error(quote.message || quote.availabilityMessage || 'Fiyat özeti alınamadı');
                        }

                        const vat = Number(quote.vatAmount || 0);
                        const acc = Number(quote.accommodationTaxAmount || 0);
                        const tax = Number(quote.taxAmount || (vat + acc));
                        const total = Number(quote.totalAmount || 0);

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += acc;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;
                        totals.originalTotalAmount += Number(quote.originalTotalAmount || quote.totalAmount || 0);
                        totals.dawnSurpriseDiscountAmount += Number(quote.dawnSurpriseDiscountAmount || 0);
                        if (Number(quote.dawnSurprisePercent || 0) > 0) {
                            totals.dawnSurprisePercent = Number(quote.dawnSurprisePercent);
                        }
                        if (Number(quote.lateCheckoutSurchargeAmount || 0) > 0) {
                            totals.lateCheckoutSurchargeAmount += Number(quote.lateCheckoutSurchargeAmount);
                            totals.lateCheckoutApplied = true;
                        }

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });

                        if (Array.isArray(quote.nightlyBreakdown) && quote.nightlyBreakdown.length > 0) {
                            nightlySeed.byRoom.push({
                                index: perRoom.length - 1,
                                roomName: item.roomName,
                                checkIn: item.checkIn,
                                checkOut: item.checkOut,
                                rows: quote.nightlyBreakdown
                            });
                        }

                        if (quote.isAvailable === false) {
                            anyUnavailable = true;
                            availabilityMessage = quote.availabilityMessage || availabilityMessage;
                        }
                    } catch (_error) {
                        // fallback: use option net price from DOM
                        const node = roomNodes[perRoom.length] || null;
                        const opt = node?.querySelector('[data-field="roomType"]')?.selectedOptions?.[0];
                        const netNightly = parseFloat(opt?.dataset.price || '0');
                        const diffMs = new Date(item.checkOut).getTime() - new Date(item.checkIn).getTime();
                        const nights = Math.max(1, Math.round(diffMs / 86400000));
                        const rc = Math.max(1, parseInt(item.roomCount || 1, 10) || 1);
                        const subtotal = (netNightly * nights) * rc;
                        // Vergiler bilgilendirme icin "fiyatin icinden" hesaplanir; toplam tutara eklenmez.
                        const taxDivisor = 1 + detailVatFraction + detailAccommodationFraction;
                        const net = taxDivisor > 0 ? (subtotal / taxDivisor) : subtotal;
                        const vat = Math.round(net * detailVatFraction);
                        const accommodationTax = Math.max(0, Math.round(subtotal - net - vat));
                        const tax = vat + accommodationTax;
                        const total = subtotal;

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += accommodationTax;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });
                    }
                }

                if (latestQuoteRequest !== requestKey) {
                    return;
                }

                const firstItem = items[0];
                const nightsForNightly = firstItem
                    ? Math.max(1, Math.round((new Date(firstItem.checkOut).getTime() - new Date(firstItem.checkIn).getTime()) / 86400000))
                    : 1;
                const roomsForNightly = firstItem ? Math.max(1, parseInt(firstItem.roomCount || 1, 10) || 1) : 1;

                updateBookingPriceHead(totals, nightsForNightly, roomsForNightly);

                const earnPoints = await resolveEarnPoints(totals.totalAmount);

                updateMobileBookingSummary({
                    roomName: firstItem?.roomName || '',
                    totalAmount: totals.totalAmount,
                    originalTotalAmount: totals.originalTotalAmount,
                    dawnSurprisePercent: totals.dawnSurprisePercent,
                    dawnSurpriseDiscountAmount: totals.dawnSurpriseDiscountAmount,
                    earnPoints: earnPoints
                });

                breakdown.innerHTML = buildMultiRoomBreakdownHtml(perRoom, totals);

                if (nightlyDetails && nightlyList) {
                    const showNightly = Array.isArray(nightlySeed.byRoom) && nightlySeed.byRoom.some(function (x) {
                        return Array.isArray(x.rows) && x.rows.length > 0;
                    });
                    const nightlyHintEl = document.getElementById('nightlyBreakdownHint');
                    const nightlyMetaEl = document.getElementById('nightlyBreakdownMeta');
                    nightlyDetails.hidden = !showNightly;
                    if (showNightly) {
                        let totalNightRows = 0;
                        nightlyList.innerHTML = nightlySeed.byRoom.map(function (roomBlock) {
                            const header = '<div class="nightly-breakdown-room-head"><strong>Oda ' + (Number(roomBlock.index || 0) + 1) + '</strong><small>' + escapeHtml((roomBlock.roomName || 'Oda').toString()) + ' · ' + escapeHtml((roomBlock.checkIn || '-').toString()) + ' → ' + escapeHtml((roomBlock.checkOut || '-').toString()) + '</small></div>';
                            const rowsHtml = (roomBlock.rows || []).map(function (row) {
                                totalNightRows += 1;
                                const label = (row.dateText || row.date || '').toString();
                                const baseAmount = Number(row.basePrice || 0);
                                const discountAmount = Number(row.discountPrice || 0);
                                let effectiveAmount = Number(row.price || row.totalAmount || row.amount || 0);
                                if (!(effectiveAmount > 0) && discountAmount > 0) {
                                    effectiveAmount = discountAmount;
                                } else if (!(effectiveAmount > 0) && baseAmount > 0) {
                                    effectiveAmount = baseAmount;
                                }
                                const isDiscounted = baseAmount > 0 && effectiveAmount > 0 && effectiveAmount < baseAmount;
                                const discountPercent = isDiscounted
                                    ? Math.max(1, Math.min(95, Math.round(((baseAmount - effectiveAmount) / baseAmount) * 100)))
                                    : 0;
                                const stockText = Number(row.remainingRooms || 0) > 0
                                    ? '<span class="nightly-stock">' + Number(row.remainingRooms || 0) + ' oda</span>'
                                    : '';
                                const amountHtml = isDiscounted
                                    ? '<div class="nightly-breakdown-prices nightly-breakdown-prices--discount">'
                                        + '<del class="nightly-breakdown-base">' + formatMoney(baseAmount) + '</del>'
                                        + '<strong class="nightly-breakdown-amount">' + formatMoney(effectiveAmount) + '</strong>'
                                        + '<span class="nightly-breakdown-badge">−%' + discountPercent + '</span>'
                                        + '</div>'
                                    : '<strong class="nightly-breakdown-amount">' + formatMoney(effectiveAmount) + '</strong>';
                                return '<div class="nightly-breakdown-row' + (isDiscounted ? ' nightly-breakdown-row-discount' : '') + '">'
                                    + '<div class="nightly-breakdown-row-meta">'
                                    + '<span class="nightly-breakdown-date">' + escapeHtml(label) + '</span>'
                                    + stockText
                                    + '</div>'
                                    + amountHtml
                                    + '</div>';
                            }).join('');
                            return '<div class="nightly-breakdown-room">' + header + rowsHtml + '</div>';
                        }).join('');
                        if (nightlyHintEl) {
                            nightlyHintEl.textContent = totalNightRows + ' gece · indirimli gecelik fiyatlar dahil';
                        }
                        if (nightlyMetaEl) {
                            nightlyMetaEl.textContent = totalNightRows > 0 ? (totalNightRows + ' gece') : '';
                            nightlyMetaEl.hidden = !(totalNightRows > 0);
                        }
                    } else {
                        nightlyList.innerHTML = '';
                        if (nightlyHintEl) {
                            nightlyHintEl.textContent = 'Gece bazında döküm';
                        }
                        if (nightlyMetaEl) {
                            nightlyMetaEl.textContent = '';
                            nightlyMetaEl.hidden = true;
                        }
                    }
                }

                lastQuoteUnavailable = anyUnavailable;
                if (anyUnavailable) {
                    setQuoteNotice(availabilityMessage || 'Seçili tarihler için uygun stok veya satış bulunamadı.', 'warning');
                } else if (totals.lateCheckoutApplied) {
                    setQuoteNotice('Seçtiğiniz çıkış saati standart saatten sonra olduğu için ek günlük ücret eklendi.', 'info');
                } else {
                    setQuoteNotice(availabilityMessage || '', 'info');
                }

                syncReserveButtonEnabled();
                if (totals.totalAmount > 0) {
                    scheduleBookingDraftSave();
                }
            }

            function initReviewReadMore() {
                const modal = document.getElementById('reviewModal');
                const modalTitle = document.getElementById('reviewModalTitle');
                const modalDate = document.getElementById('reviewModalDate');
                const modalScore = document.getElementById('reviewModalScore');
                const modalText = document.getElementById('reviewModalText');
                if (!modal || !modalText) return;
                const insightModal = document.getElementById('reviewInsightModal');
                const insightTitle = document.getElementById('reviewInsightTitle');
                const insightMeta = document.getElementById('reviewInsightMeta');
                const insightList = document.getElementById('reviewInsightList');
                const insightTabs = document.getElementById('reviewInsightTabs');
                const insightSort = document.getElementById('reviewInsightSort');
                const insightPager = document.getElementById('reviewInsightPager');
                const topicPayloadEl = document.getElementById('reviewTopicPayloadJson');
                const feedPayloadEl = document.getElementById('reviewFeedPayloadJson');
                let topicPayload = [];
                let feedPayload = [];
                let activeInsightTopic = 'all';
                let activeInsightPage = 1;
                const insightPageSize = 7;
                try {
                    topicPayload = JSON.parse(topicPayloadEl?.textContent || '[]');
                } catch (_) {
                    topicPayload = [];
                }
                try {
                    feedPayload = JSON.parse(feedPayloadEl?.textContent || '[]');
                } catch (_) {
                    feedPayload = [];
                }

                function openReviewModal(payload) {
                    if (modalTitle) modalTitle.textContent = payload.title || 'Misafir yorumu';
                    if (modalDate) modalDate.textContent = payload.date || '';
                    if (modalScore) modalScore.textContent = payload.score || '';
                    modalText.textContent = payload.text || '';
                    modal.classList.add('is-open');
                    modal.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                }

                function closeReviewModal() {
                    modal.classList.remove('is-open');
                    modal.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                }

                function buildInsightTabs() {
                    if (!insightTabs) return;
                    const tabs = [{ key: 'all', label: 'Genel', count: feedPayload.length }].concat(topicPayload || []);
                    insightTabs.innerHTML = tabs.map(function (topic) {
                        const key = topic.key || 'all';
                        const label = topic.label || 'Genel';
                        const count = key === 'all' ? feedPayload.length : (topic.count || 0);
                        const activeClass = key === activeInsightTopic ? ' is-active' : '';
                        return '<button type="button" class="review-insight-tab' + activeClass + '" data-review-insight-topic="' + escapeHtml(key) + '">' +
                            escapeHtml(label) + '<span>' + escapeHtml(String(count)) + '</span>' +
                        '</button>';
                    }).join('');
                }

                function getInsightItems() {
                    const items = activeInsightTopic === 'all'
                        ? (feedPayload || []).slice()
                        : (feedPayload || []).filter(function (x) {
                            return Array.isArray(x?.topics) && x.topics.indexOf(activeInsightTopic) > -1;
                        });
                    const sortValue = insightSort?.value || 'new';
                    if (sortValue === 'best') {
                        items.sort(function (a, b) { return (parseFloat(b?.score || '0') || 0) - (parseFloat(a?.score || '0') || 0); });
                    } else if (sortValue === 'worst') {
                        items.sort(function (a, b) { return (parseFloat(a?.score || '0') || 0) - (parseFloat(b?.score || '0') || 0); });
                    }
                    return items;
                }

                function renderInsightModal() {
                    if (!insightModal || !insightList) return;
                    const topic = activeInsightTopic === 'all'
                        ? { label: 'Genel', score: '', count: feedPayload.length }
                        : (topicPayload || []).find(function (x) { return x && x.key === activeInsightTopic; });
                    if (!topic) return;
                    const matched = getInsightItems();
                    const totalPages = Math.max(1, Math.ceil(matched.length / insightPageSize));
                    activeInsightPage = Math.min(Math.max(1, activeInsightPage), totalPages);
                    const pageItems = matched.slice((activeInsightPage - 1) * insightPageSize, activeInsightPage * insightPageSize);
                    if (insightTitle) insightTitle.textContent = topic.label + (topic.score ? ' · ' + topic.score : '');
                    if (insightMeta) insightMeta.textContent = matched.length + ' yorum gösteriliyor · Sayfa başı 10 yorum';
                    buildInsightTabs();
                    if (pageItems.length === 0) {
                        insightList.innerHTML = '<div class="review-insight-empty">Bu başlık için henüz detaylı yorum bulunmuyor.</div>';
                    } else {
                        insightList.innerHTML = pageItems.map(function (item) {
                            const date = item?.date || '';
                            const name = item?.name || 'Misafir';
                            const score = item?.score || '';
                            const text = item?.text || '';
                            return '<article class="review-insight-card">' +
                                '<header><strong>' + escapeHtml(name) + '</strong><span>' + escapeHtml(date) + '</span><b>' + escapeHtml(score) + '</b></header>' +
                                '<p>' + escapeHtml(text) + '</p>' +
                            '</article>';
                        }).join('');
                    }
                    if (insightPager) {
                        insightPager.hidden = totalPages <= 1;
                        insightPager.innerHTML = totalPages <= 1 ? '' :
                            '<button type="button" data-review-insight-page="prev" ' + (activeInsightPage <= 1 ? 'disabled' : '') + '>Önceki</button>' +
                            '<span>' + activeInsightPage + ' / ' + totalPages + '</span>' +
                            '<button type="button" data-review-insight-page="next" ' + (activeInsightPage >= totalPages ? 'disabled' : '') + '>Sonraki</button>';
                    }
                }

                function openInsightModal(topicKey) {
                    if (!insightModal || !insightList) return;
                    activeInsightTopic = topicKey || 'all';
                    activeInsightPage = 1;
                    if (insightSort) insightSort.value = 'new';
                    renderInsightModal();
                    insightModal.classList.add('is-open');
                    insightModal.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                }

                function closeInsightModal() {
                    if (!insightModal) return;
                    insightModal.classList.remove('is-open');
                    insightModal.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                }

                modal.querySelectorAll('[data-review-modal-close]').forEach(function (btn) {
                    btn.addEventListener('click', closeReviewModal);
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeReviewModal();
                    if (e.key === 'Escape' && insightModal && insightModal.classList.contains('is-open')) closeInsightModal();
                });

                document.querySelectorAll('[data-review-card]').forEach(function (card) {
                    const p = card.querySelector('[data-review-text]');
                    const moreBtn = card.querySelector('[data-review-more]');
                    const full = card.querySelector('[data-review-fulltext]');
                    if (!p || !moreBtn || !full) return;

                    const metaRoot = card.closest('.review-card');
                    const date = metaRoot?.querySelector('.review-meta p')?.textContent?.trim() || '';
                    const title = metaRoot?.querySelector('.review-meta h4')?.textContent?.trim() || 'Misafir yorumu';
                    const score = metaRoot?.querySelector('.review-chip')?.textContent?.trim() || '';

                    function syncReviewClamp() {
                        p.classList.remove('is-expanded');
                        requestAnimationFrame(function () {
                            const isTruncated = p.scrollHeight > p.clientHeight + 2;
                            moreBtn.hidden = !isTruncated;
                            if (!isTruncated) {
                                p.classList.remove('is-clamped');
                            } else {
                                p.classList.add('is-clamped');
                            }
                        });
                    }

                    syncReviewClamp();

                    moreBtn.addEventListener('click', function () {
                        const expanded = p.classList.toggle('is-expanded');
                        p.classList.toggle('is-clamped', !expanded);
                        moreBtn.textContent = expanded ? 'Daha az göster' : 'Devamını oku';
                    });
                });

                if (insightModal) {
                    insightModal.querySelectorAll('[data-review-insight-close]').forEach(function (btn) {
                        btn.addEventListener('click', closeInsightModal);
                    });
                    insightModal.addEventListener('click', function (event) {
                        const tab = event.target.closest('[data-review-insight-topic]');
                        if (tab) {
                            activeInsightTopic = tab.getAttribute('data-review-insight-topic') || 'all';
                            activeInsightPage = 1;
                            renderInsightModal();
                            return;
                        }
                        const pageButton = event.target.closest('[data-review-insight-page]');
                        if (pageButton) {
                            const direction = pageButton.getAttribute('data-review-insight-page');
                            activeInsightPage += direction === 'next' ? 1 : -1;
                            renderInsightModal();
                        }
                    });
                    insightSort?.addEventListener('change', function () {
                        activeInsightPage = 1;
                        renderInsightModal();
                    });
                }
                document.querySelectorAll('[data-review-topic-open="true"]').forEach(function (chip) {
                    chip.addEventListener('click', function () {
                        const topicKey = chip.getAttribute('data-topic-key') || '';
                        if (!topicKey) return;
                        openInsightModal(topicKey);
                    });
                });
            }

            function initRoomFeaturePanels() {
                document.querySelectorAll('[data-room-feature-wrap]').forEach(function (wrap) {
                    const btn = wrap.querySelector('[data-room-feature-toggle]');
                    const panel = wrap.querySelector('[data-room-feature-panel]');
                    if (!btn || !panel) return;

                    btn.addEventListener('click', function () {
                        const isOpen = panel.hidden === false;
                        panel.hidden = isOpen;
                        btn.setAttribute('aria-expanded', (!isOpen).toString());
                        const icon = btn.querySelector('i.fas');
                        if (icon) {
                            icon.classList.toggle('fa-angle-down', isOpen);
                            icon.classList.toggle('fa-angle-up', !isOpen);
                        }
                    });
                });
            }

            function renderRoomDetailGallery(roomImages, hotelImages) {
                if (!roomDetailModalGallery || !roomDetailModalGalleryTrack || !roomDetailModalGalleryDots) {
                    return;
                }

                const merged = [];
                (Array.isArray(roomImages) ? roomImages : []).forEach(function (src) {
                    if (src && !merged.includes(src)) merged.push(src);
                });
                (Array.isArray(hotelImages) ? hotelImages : []).forEach(function (src) {
                    if (src && !merged.includes(src)) merged.push(src);
                });

                if (!merged.length) {
                    roomDetailModalGallery.hidden = true;
                    roomDetailModalGalleryTrack.innerHTML = '';
                    roomDetailModalGalleryDots.innerHTML = '';
                    return;
                }

                roomDetailModalGallery.hidden = false;
                roomDetailModalGalleryTrack.innerHTML = merged.map(function (src, index) {
                    return '<div class="room-detail-gallery-slide" data-gallery-slide="' + index + '">'
                        + '<img src="' + src + '" alt="" loading="' + (index === 0 ? 'eager' : 'lazy') + '" decoding="async" />'
                        + '</div>';
                }).join('');
                roomDetailModalGalleryDots.innerHTML = merged.map(function (_, index) {
                    return '<button type="button" class="room-detail-gallery-dot' + (index === 0 ? ' active' : '') + '" data-gallery-dot="' + index + '" aria-label="Görsel ' + (index + 1) + '"></button>';
                }).join('');

                document.dispatchEvent(new CustomEvent('otelturizm:room-detail-gallery-ready', {
                    detail: { track: roomDetailModalGalleryTrack, dotsRoot: roomDetailModalGalleryDots }
                }));
            }

            function renderRoomDetailNightlyBreakdown(priceText) {
                if (!roomDetailModalNightly) {
                    return;
                }

                const nightly = parseInt(String(priceText || '').replace(/\D/g, ''), 10) || 0;
                const checkInValue = checkInInput?.value || '';
                if (!nightly || !checkInValue) {
                    roomDetailModalNightly.innerHTML = '';
                    roomDetailModalNightly.hidden = true;
                    return;
                }

                const start = new Date(checkInValue + 'T12:00:00');
                if (Number.isNaN(start.getTime())) {
                    roomDetailModalNightly.innerHTML = '';
                    roomDetailModalNightly.hidden = true;
                    return;
                }

                const rows = [];
                for (let i = 0; i < 4; i += 1) {
                    const day = new Date(start);
                    day.setDate(day.getDate() + i);
                    const label = day.toLocaleDateString('tr-TR', { weekday: 'short', day: 'numeric', month: 'short' });
                    rows.push('<div class="room-detail-nightly-row"><span>' + label + '</span><strong>₺' + nightly.toLocaleString('tr-TR') + '</strong></div>');
                }

                roomDetailModalNightly.hidden = false;
                roomDetailModalNightly.innerHTML = rows.join('');
            }

            function openRoomDetailModal(button) {
                if (!button || !roomDetailModal || !roomDetailModalGrid) {
                    return;
                }

                let details = [];
                let galleryItems = [];
                try {
                    const id = Number(button.getAttribute('data-room-id') || '0');
                    const detailMap = window.__otelDetayConfig?.roomDetails || window.__hotelRoomDetails || {};
                    details = (id && detailMap && detailMap[id]) ? detailMap[id] : [];
                } catch (error) {
                    details = [];
                }
                try {
                    const id = Number(button.getAttribute('data-room-id') || '0');
                    const galleryMap = window.__otelDetayConfig?.roomGalleries || window.__hotelRoomGalleries || {};
                    galleryItems = (id && galleryMap && galleryMap[id]) ? galleryMap[id] : [];
                } catch (error) {
                    galleryItems = [];
                }

                const roomName = button.getAttribute('data-room-name') || 'Oda detayları';
                const specs = button.getAttribute('data-room-specs') || 'Oda bilgileri güncelleniyor.';
                const description = button.getAttribute('data-room-description') || 'Bu oda için detaylı sunum bilgileri hazırlanıyor.';
                const bedType = button.getAttribute('data-room-bed-type') || 'Belirtilmedi';
                const squareMeter = button.getAttribute('data-room-square-meter') || '';
                const maxGuests = button.getAttribute('data-room-max-guests') || '0';
                const maxAdults = button.getAttribute('data-room-max-adults') || '0';
                const maxChildren = button.getAttribute('data-room-max-children') || '0';
                const priceText = button.getAttribute('data-room-price') || '';
                const roomId = button.getAttribute('data-room-id') || '';
                const cancellation = button.getAttribute('data-room-cancellation') || 'Koşullar rezervasyon adımında yeniden doğrulanır.';
                const featureCount = button.getAttribute('data-room-feature-count') || String(details.length || 0);
                const galleryCount = button.getAttribute('data-room-gallery-count') || '0';
                const capacityText = maxChildren && maxChildren !== '0'
                    ? `${maxGuests} kişi · ${maxAdults} yetişkin + ${maxChildren} çocuk`
                    : `${maxGuests} kişi · ${maxAdults} yetişkin`;

                if (roomDetailModalTitle) roomDetailModalTitle.textContent = roomName;
                if (roomDetailModalRoomName) roomDetailModalRoomName.textContent = roomName;
                if (roomDetailModalSpecs) roomDetailModalSpecs.textContent = specs;
                if (roomDetailModalDescription) roomDetailModalDescription.textContent = description;
                if (roomDetailModalCancellation) roomDetailModalCancellation.textContent = cancellation;
                if (roomDetailModalGalleryBadge) roomDetailModalGalleryBadge.textContent = galleryCount + ' görsel';
                if (roomDetailModalFeatureBadge) roomDetailModalFeatureBadge.textContent = featureCount + ' özellik';
                if (roomDetailModalBedType) roomDetailModalBedType.textContent = bedType;
                if (roomDetailModalSquareMeter) roomDetailModalSquareMeter.textContent = squareMeter ? squareMeter + ' m²' : 'Belirtilmedi';
                if (roomDetailModalCapacity) roomDetailModalCapacity.textContent = capacityText;

                const priceBase = button.getAttribute('data-room-price-base') || '';
                const priceCurrent = button.getAttribute('data-room-price') || '';
                const discountName = (button.getAttribute('data-room-discount-name') || '').trim();
                const discountPercent = (button.getAttribute('data-room-discount-percent') || '').trim();
                const hasDiscountPrice = !!priceBase && !!priceCurrent && priceBase !== priceCurrent;

                if (roomDetailModalPriceStack) {
                    if (hasDiscountPrice) {
                        roomDetailModalPriceStack.innerHTML =
                            '<span class="room-detail-modal-price-old">₺' + priceBase + '</span>'
                            + '<strong class="room-detail-modal-price-current" id="roomDetailModalPrice">₺' + priceCurrent + '</strong>'
                            + (discountName
                                ? '<span class="room-detail-modal-price-discount">' + discountName + '</span>'
                                : (discountPercent ? '<span class="room-detail-modal-price-discount">%' + discountPercent + ' indirim</span>' : ''))
                            + '<small class="room-detail-modal-price-note">Vergiler dahil</small>';
                    } else if (priceCurrent) {
                        roomDetailModalPriceStack.innerHTML =
                            '<strong class="room-detail-modal-price-current" id="roomDetailModalPrice">₺' + priceCurrent + '</strong>'
                            + '<small class="room-detail-modal-price-note">Vergiler dahil</small>';
                    } else {
                        roomDetailModalPriceStack.innerHTML =
                            '<strong class="room-detail-modal-price-current" id="roomDetailModalPrice">Fiyat bilgisi yok</strong>';
                    }
                } else if (roomDetailModalPrice) {
                    roomDetailModalPrice.textContent = priceCurrent ? ('₺' + priceCurrent) : 'Fiyat bilgisi yok';
                }

                renderRoomDetailNightlyBreakdown(priceCurrent);

                if (roomDetailModalSelectBtn) {
                    roomDetailModalSelectBtn.disabled = !roomId || !priceCurrent;
                    roomDetailModalSelectBtn.dataset.roomId = roomId;
                }

                activeRoomDetailGalleryItems = Array.isArray(galleryItems) ? galleryItems : [];
                activeRoomDetailName = roomName;
                activeRoomDetailRoomId = roomId;

                renderRoomDetailGallery(activeRoomDetailGalleryItems, galleryImages);

                roomDetailModalGrid.innerHTML = '';
                details.forEach(function (detail) {
                    const detailName = detail?.name || detail?.Name || '';
                    const detailIcon = detail?.iconClass || detail?.IconClass || 'fa-circle-check';
                    if (!detailName) {
                        return;
                    }

                    const item = document.createElement('div');
                    item.className = 'room-detail-modal-item';
                    item.innerHTML = '<i class="fas ' + detailIcon + '"></i><span></span>';
                    item.querySelector('span').textContent = detailName;
                    roomDetailModalGrid.appendChild(item);
                });

                if (roomDetailModalGrid.children.length === 0) {
                    const fallback = document.createElement('div');
                    fallback.className = 'room-detail-modal-item';
                    fallback.innerHTML = '<i class="fas fa-circle-info"></i><span>Bu oda için ek özellik bilgisi yakında güncellenecek.</span>';
                    roomDetailModalGrid.appendChild(fallback);
                }

                openModal(roomDetailModal);
            }

            async function loadSelectOptions(url, select, placeholder, selectedText) {
                if (!select) {
                    return [];
                }

                select.innerHTML = '<option value="">' + placeholder + '</option>';
                const response = await fetch(url, { credentials: 'same-origin' });
                const items = response.ok ? await response.json() : [];
                items.forEach(function (item) {
                    const option = document.createElement('option');
                    option.value = item.name;
                    option.textContent = item.name;
                    if (item.id) {
                        option.dataset.id = item.id;
                    }
                    if (item.iso2) {
                        option.dataset.iso2 = item.iso2;
                    }
                    if (item.provinceId) {
                        option.dataset.provinceId = item.provinceId;
                    }
                    if (item.postalCode) {
                        option.dataset.postalCode = item.postalCode;
                    }
                    if (selectedText && item.name === selectedText) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                });
                return items;
            }

            const countrySelect = document.getElementById('detailCountrySelect');
            const provinceSelect = document.getElementById('detailProvinceSelect');
            const districtSelect = document.getElementById('detailDistrictSelect');
            const neighborhoodSelect = document.getElementById('detailNeighborhoodSelect');
            const profileAddressSeed = {
                country: '@(Model.ProfilePrompt.Nationality ?? string.Empty)',
                city: '@(Model.ProfilePrompt.City ?? string.Empty)',
                district: '@(Model.ProfilePrompt.District ?? string.Empty)',
                neighborhood: '@(Model.ProfilePrompt.Neighborhood ?? string.Empty)'
            };

            function selectedCountryId() {
                return countrySelect?.selectedOptions[0]?.dataset.id || '';
            }

            function isTurkeySelected() {
                const iso2 = (countrySelect?.selectedOptions[0]?.dataset.iso2 || '').toUpperCase();
                return iso2 === 'TR';
            }

            async function hydrateProfileAddressSelectors() {
                const countries = await loadSelectOptions('/api/adres/ulkeler', countrySelect, 'Uyruk seçiniz', profileAddressSeed.country);
                countries.forEach(function (item) {
                    const opt = Array.from(countrySelect.options).find(function (o) { return o.value === item.name; });
                    if (opt) {
                        opt.dataset.iso2 = item.iso2 || '';
                    }
                });
                const countryId = selectedCountryId();
                if (!countryId) {
                    return;
                }
                const regionLabel = isTurkeySelected() ? 'İl seçiniz' : 'Eyalet seçiniz';
                await loadSelectOptions('/api/adres/iller?ulkeId=' + encodeURIComponent(countryId), provinceSelect, regionLabel, profileAddressSeed.city);
                if (!isTurkeySelected()) {
                    districtSelect.innerHTML = '<option value="">Türkiye dışı adreslerde ilçe seçilmez</option>';
                    neighborhoodSelect.innerHTML = '<option value="">Türkiye dışı adreslerde mahalle seçilmez</option>';
                    return;
                }
                const provinceId = provinceSelect?.selectedOptions[0]?.dataset.id || provinceSelect?.selectedOptions[0]?.dataset.provinceId;
                if (provinceId) {
                    await loadSelectOptions('/api/adres/ilceler?ilId=' + encodeURIComponent(provinceId), districtSelect, 'İlçe seçiniz', profileAddressSeed.district);
                    const districtId = districtSelect?.selectedOptions[0]?.dataset.id;
                    if (districtId) {
                        await loadSelectOptions('/api/adres/mahalleler?ilceId=' + encodeURIComponent(districtId), neighborhoodSelect, 'Mahalle seçiniz (opsiyonel)', profileAddressSeed.neighborhood);
                    }
                }
            }

            countrySelect?.addEventListener('change', async function () {
                const countryId = selectedCountryId();
                const regionLabel = isTurkeySelected() ? 'İl seçiniz' : 'Eyalet seçiniz';
                await loadSelectOptions('/api/adres/iller?ulkeId=' + encodeURIComponent(countryId), provinceSelect, regionLabel, '');
                if (!isTurkeySelected()) {
                    districtSelect.innerHTML = '<option value="">Türkiye dışı adreslerde ilçe seçilmez</option>';
                    neighborhoodSelect.innerHTML = '<option value="">Türkiye dışı adreslerde mahalle seçilmez</option>';
                    return;
                }
                districtSelect.innerHTML = '<option value="">Önce il seçiniz</option>';
                neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
            });

            provinceSelect?.addEventListener('change', async function () {
                if (!isTurkeySelected()) {
                    return;
                }
                const provinceId = provinceSelect.selectedOptions[0]?.dataset.id || provinceSelect.selectedOptions[0]?.dataset.provinceId || '';
                await loadSelectOptions('/api/adres/ilceler?ilId=' + encodeURIComponent(provinceId), districtSelect, 'İlçe seçiniz', '');
                neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
            });

            districtSelect?.addEventListener('change', async function () {
                const districtId = districtSelect.selectedOptions[0]?.dataset.id || '';
                await loadSelectOptions('/api/adres/mahalleler?ilceId=' + encodeURIComponent(districtId), neighborhoodSelect, 'Mahalle seçiniz (opsiyonel)', '');
            });

            openProfileCompletionFromBanner?.addEventListener('click', function () {
                openProfileCompletionModal('Rezervasyonunuza kaldığınız yerden devam etmek için eksik profil bilgilerinizi tamamlayın.');
            });
            openAmenitiesModal?.addEventListener('click', function () {
                openModal(amenitiesModal);
            });
            document.querySelectorAll('[data-open-amenities]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (amenitiesModal) {
                        openModal(amenitiesModal);
                        return;
                    }
                    const expand = document.getElementById('amenitiesExpand');
                    if (expand && 'open' in expand) {
                        expand.open = true;
                        scrollToElementWithOffset(expand, 86);
                    }
                });
            });
            document.querySelectorAll('[data-open-policies]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (policiesModal) {
                        openModal(policiesModal);
                    }
                });
            });

            function scrollToElementWithOffset(targetEl, offset) {
                if (!(targetEl instanceof HTMLElement)) return;
                const top = targetEl.getBoundingClientRect().top + window.scrollY - (offset || 0);
                window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
            }

            document.querySelectorAll('[data-rating-jump]').forEach(function (ratingSummaryJump) {
                ratingSummaryJump.addEventListener('click', function () {
                    const target = document.getElementById('reviewsSection');
                    scrollToElementWithOffset(target, 86);
                });
                ratingSummaryJump.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        const target = document.getElementById('reviewsSection');
                        scrollToElementWithOffset(target, 86);
                    }
                });
            });

            document.querySelectorAll('[data-scroll-booking]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (isMobileBookingMode()) {
                        openBookingSheet();
                    } else {
                        scrollToBookingArea();
                    }
                });
            });

            document.querySelectorAll('[data-scroll-reviews]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const target = document.getElementById('reviewsSection');
                    scrollToElementWithOffset(target, 86);
                });
            });

            // Kampanya rozetleri (2 slot): 2 sn'de bir döndür.
            try {
                const campaignJsonEl = document.getElementById('hotelCampaignPayloadJson');
                const campaignItems = campaignJsonEl ? JSON.parse(campaignJsonEl.textContent || '[]') : [];
                const slots = Array.from(document.querySelectorAll('[data-campaign-slot]'));
                if (Array.isArray(campaignItems) && campaignItems.length > 0 && slots.length > 0) {
                    let index = 0;
                    const applySlots = function () {
                        for (let i = 0; i < slots.length; i++) {
                            const el = slots[i];
                            const item = campaignItems[(index + i) % campaignItems.length];
                            const name = (item?.name || '').toString().trim();
                            let slug = (item?.slug || '').toString().trim();
                            if (!name) {
                                el.hidden = true;
                                continue;
                            }
                            // sayfa_url gelirse son segmenti al
                            if (slug.includes('/')) {
                                const parts = slug.split('/').filter(Boolean);
                                slug = parts.length ? parts[parts.length - 1] : slug;
                            }
                            el.hidden = false;
                            const span = el.querySelector('span');
                            if (span) span.textContent = name;
                            el.setAttribute('href', '/kampanyalar/' + encodeURIComponent(slug || ''));
                        }
                        index = (index + 2) % campaignItems.length;
                    };
                    applySlots();
                    window.setInterval(applySlots, 2000);
                }
            } catch (_) { /* no-op */ }

            // Otel videosu modal
            const openHotelVideoBtn = document.querySelector('[data-open-hotel-video]');
            const hotelVideoModal = document.getElementById('hotelVideoModal');
            const hotelVideoBackdrop = document.getElementById('hotelVideoBackdrop');
            const hotelVideoClose = document.querySelector('[data-close-hotel-video]');
            const hotelVideoFrame = document.getElementById('hotelVideoFrame');
            const hotelVideoSeed = '@(Model.VideoUrl ?? string.Empty)'.trim();

            function toYoutubeEmbedUrl(url) {
                const raw = (url || '').toString().trim();
                if (!raw) return '';
                try {
                    const u = new URL(raw, window.location.origin);
                    const host = (u.hostname || '').toLowerCase();
                    if (host.includes('youtu.be')) {
                        const id = u.pathname.split('/').filter(Boolean)[0] || '';
                        return id ? ('https://www.youtube-nocookie.com/embed/' + id) : raw;
                    }
                    if (host.includes('youtube.com')) {
                        const v = u.searchParams.get('v') || '';
                        if (v) return 'https://www.youtube-nocookie.com/embed/' + v;
                        const parts = u.pathname.split('/').filter(Boolean);
                        const idx = parts.indexOf('embed');
                        const id = idx >= 0 ? (parts[idx + 1] || '') : (parts[parts.length - 1] || '');
                        return id ? ('https://www.youtube-nocookie.com/embed/' + id) : raw;
                    }
                } catch (_) { /* ignore */ }
                return raw;
            }

            function openHotelVideo() {
                if (!hotelVideoModal || !hotelVideoBackdrop) return;
                hotelVideoBackdrop.hidden = false;
                hotelVideoBackdrop.classList.add('is-open');
                hotelVideoModal.hidden = false;
                hotelVideoModal.classList.add('is-open');
                hotelVideoModal.setAttribute('aria-hidden', 'false');
                if (hotelVideoFrame instanceof HTMLIFrameElement) {
                    const src = toYoutubeEmbedUrl(hotelVideoSeed);
                    hotelVideoFrame.src = src ? (src + (src.includes('?') ? '&' : '?') + 'autoplay=1&rel=0') : '';
                }
            }

            function closeHotelVideo() {
                if (!hotelVideoModal || !hotelVideoBackdrop) return;
                hotelVideoModal.classList.remove('is-open');
                hotelVideoModal.hidden = true;
                hotelVideoModal.setAttribute('aria-hidden', 'true');
                hotelVideoBackdrop.classList.remove('is-open');
                hotelVideoBackdrop.hidden = true;
                if (hotelVideoFrame instanceof HTMLIFrameElement) {
                    hotelVideoFrame.src = '';
                }
            }

            openHotelVideoBtn?.addEventListener('click', function () {
                openHotelVideo();
            });
            hotelVideoClose?.addEventListener('click', function () {
                closeHotelVideo();
            });
            hotelVideoBackdrop?.addEventListener('click', function () {
                closeHotelVideo();
            });

            // "Sil" butonunun her zaman hızlı çalışması için event delegation (mobil tıklama edge-case fix)
            roomItemsRoot?.addEventListener('click', function (event) {
                const target = event.target instanceof HTMLElement ? event.target : null;
                const removeBtn = target?.closest?.('[data-remove-room]');
                if (!removeBtn) return;
                const item = removeBtn.closest?.('[data-room-item]');
                if (!item) return;
                event.preventDefault();
                item.remove();
                renumberRoomItems();
                syncRoomsJsonAndHiddenFields();
                ensureGuestCapacity(false);
                refreshPriceQuote();
            });

            document.querySelectorAll('[data-room-detail-open]').forEach(function (button) {
                button.addEventListener('click', function () {
                    openRoomDetailModal(button);
                });
            });

            roomDetailModalSelectBtn?.addEventListener('click', function () {
                if (!activeRoomDetailRoomId) {
                    return;
                }
                const targetButton = document.querySelector('.select-room-btn[data-room-id="' + activeRoomDetailRoomId + '"]');
                if (targetButton instanceof HTMLElement) {
                    closeModal(roomDetailModal);
                    targetButton.click();
                }
            });

            activeDraftResumeLink?.addEventListener('click', function (event) {
                event.preventDefault();
                resumeDraftFlow();
            });

            bookingForm?.addEventListener('submit', function (event) {
                syncRoomsJsonAndHiddenFields();
                const roomNodes = getRoomItemNodes();
                const items = roomNodes.map(getRoomItemData);
                const hasMissingRequiredInfo = roomNodes.length === 0
                    || items.some(function (x) {
                        return !x.roomTypeId
                            || !x.checkIn
                            || !x.checkOut
                            || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                    })
                    || adults < 1;
                if (hasMissingRequiredInfo) {
                    event.preventDefault();
                    showInfoModal('Rezervasyon oncesi tarih, misafir ve oda bilgilerini kontrol edip tamamlayiniz.', false);
                    return;
                }

                if (!ensureGuestCapacity(true)) {
                    event.preventDefault();
                    return;
                }

                if (!isPaymentMethodChosen()) {
                    event.preventDefault();
                    bookingAdvancedFields?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                    showInfoModal('Lütfen ödeme planı seçiniz.', false, 'warning');
                    return;
                }

                if (profileCompletionRequired) {
                    event.preventDefault();
                    shouldResumeReservationAfterProfile = true;
                    openProfileCompletionModal('Rezervasyon oluşturabilmek için telefon, doğum tarihi, cinsiyet, il ve ilçe bilgilerinizi tamamlayın.');
                    return;
                }

                if (!reservationSubmitConfirmed) {
                    event.preventDefault();
                    buildReservationConfirmSummary(items);
                    openModal(reservationConfirmModal);
                    return;
                }
            });

            reservationConfirmSubmitBtn?.addEventListener('click', function () {
                if (!bookingForm) {
                    return;
                }

                reservationSubmitConfirmed = true;
                syncRoomsJsonAndHiddenFields();
                closeModal(reservationConfirmModal);
                const reserveButton = bookingForm.querySelector('[data-reservation-create-button], .reserve-btn');
                if (reserveButton instanceof HTMLButtonElement) {
                    reserveButton.classList.add('is-submitting');
                    reserveButton.disabled = true;
                }
                if (typeof window.showReservationSubmitOverlay === 'function') {
                    window.showReservationSubmitOverlay();
                }
                HTMLFormElement.prototype.submit.call(bookingForm);
            });

            profileCompletionForm?.addEventListener('submit', async function (event) {
                event.preventDefault();
                profileFeedback.hidden = true;
                const formData = new FormData(profileCompletionForm);
                const validationMessage = validateProfileCompletionData(formData);
                if (validationMessage) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = validationMessage;
                    return;
                }

                try {
                    const response = await fetch(profileCompletionForm.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Bilgiler kaydedilemedi.');
                    }

                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback success';
                    profileFeedback.textContent = payload.message;
                    window.setTimeout(function () {
                        markProfileCompletionResolved();
                        closeModal(profileModal);
                        if (shouldResumeReservationAfterProfile) {
                            shouldResumeReservationAfterProfile = false;
                            continueReservationAttemptAfterProfile();
                            return;
                        }
                        resumeDraftFlow();
                    }, 700);
                } catch (error) {
                    profileFeedback.hidden = false;
                    profileFeedback.className = 'detail-modal-feedback error';
                    profileFeedback.textContent = error.message || 'Bilgiler kaydedilemedi.';
                }
            });

            startConversationBtn?.addEventListener('click', async function () {
                const authenticated = startConversationBtn.dataset.authenticated === 'true';
                const canStart = startConversationBtn.dataset.canStart === 'true';
                const infoMessage = startConversationBtn.dataset.infoMessage || 'Görüşme başlatılamıyor.';

                if (!authenticated) {
                    showInfoModal('Otel ile görüşme başlatmak için önce kullanıcı hesabınızla giriş yapmalısınız.', true);
                    return;
                }

                if (!canStart) {
                    showInfoModal(infoMessage, false);
                    return;
                }

                try {
                    const token = bookingForm?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch('/oteller/@Model.Slug/gorusme-baslat', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'X-CSRF-TOKEN': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        throw new Error(payload.message || 'Görüşme başlatılamadı.');
                    }

                    window.location.href = payload.redirectUrl;
                } catch (error) {
                    showInfoModal(error.message || 'Görüşme başlatılamadı.', false);
                }
            });

            const locationQuery = new URLSearchParams(window.location.search);
            const shouldOpenProfileFromQuery = locationQuery.get('openProfile') === '1';
            if (window.matchMedia('(max-width: 860px)').matches) {
                bookingAdvancedFields?.removeAttribute('open');
            }

            if (shouldOpenProfileFromQuery && @((Model.ActiveDraft is not null && Model.IsLoggedInUser) ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft?.RequiresProfileCompletion == true && Model.IsLoggedInUser ? "true" : "false")) {
                hydrateProfileAddressSelectors();
                openModal(profileModal);
            } else if (@(Model.ShouldResumeDraftOnLoad && Model.ActiveDraft is not null && Model.ActiveDraft.RequiresProfileCompletion == false ? "true" : "false")) {
                resumeDraftFlow();
            }

            if (shouldPromptActiveDraft) {
                window.setTimeout(function () {
                    openActiveDraftPrompt();
                }, 80);
            }

            // init first room row (single-room compatible)
            if (getRoomItemNodes().length === 0) {
                addRoomItem({
                    roomTypeId: parseInt(roomTypeIdInput?.value || '@reservationForm.RoomTypeId', 10) || 0,
                    checkIn: checkInInput?.value || '@checkInDefault',
                    checkOut: checkOutInput?.value || '@checkOutDefault'
                });
            }
            renumberRoomItems();
            setActiveRoomIndex(0);
            syncRoomsJsonAndHiddenFields();
            syncGuestInputs();
            ensureGuestCapacity(false);
            syncPaymentMethodState();
            refreshPriceQuote();
            initReviewReadMore();
            initRoomFeaturePanels();
            paymentMethodSelect?.addEventListener('change', syncPaymentMethodState);
            checkInTimeInput?.addEventListener('change', refreshPriceQuote);
            checkOutTimeInput?.addEventListener('change', refreshPriceQuote);

            // Oda kart görselleri scroll'a gelince "geç yükleniyor" hissi vermesin diye
            // ilk etapta oda kapak görsellerini prefetch edelim (tarayıcı cache'e alsın).
            (function prefetchRoomCoverImages() {
                const covers = Array.from(document.querySelectorAll('.room-card-cover img'))
                    .map(function (img) { return img instanceof HTMLImageElement ? (img.currentSrc || img.src || '').trim() : ''; })
                    .filter(Boolean);
                if (!covers.length) return;
                const limit = Math.min(14, covers.length);
                for (let i = 0; i < limit; i++) {
                    const src = covers[i];
                    const pre = new Image();
                    pre.decoding = 'async';
                    pre.src = src;
                }
            })();

            const reviewSortSelect = document.getElementById('reviewSortSelect');
            const reviewDynamic = document.getElementById('reviewSectionDynamic');
            const reviewFeedPayloadEl = document.getElementById('reviewFeedPayloadJson');
            const reviewVerifiedLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(SharedLocalizer["Detail.Review.Verified"].Value));
            let reviewFeedItems = [];
            try {
                reviewFeedItems = JSON.parse(reviewFeedPayloadEl?.textContent || '[]');
            } catch (_) {
                reviewFeedItems = [];
            }

            function sortReviewFeedItems(items, sortValue) {
                const copy = (items || []).slice();
                if (sortValue === 'best') {
                    copy.sort(function (a, b) { return (parseFloat(b?.score) || 0) - (parseFloat(a?.score) || 0); });
                } else if (sortValue === 'worst') {
                    copy.sort(function (a, b) { return (parseFloat(a?.score) || 0) - (parseFloat(b?.score) || 0); });
                } else if (sortValue === 'old') {
                    copy.sort(function (a, b) { return (a?.order || 0) - (b?.order || 0); });
                } else {
                    copy.sort(function (a, b) { return (b?.order || 0) - (a?.order || 0); });
                }
                return copy;
            }

            function renderReviewFeedList(sortValue) {
                if (!reviewDynamic) {
                    return;
                }

                const sorted = sortReviewFeedItems(reviewFeedItems, sortValue || 'new');
                const pageItems = sorted.slice(0, 10);
                if (pageItems.length === 0) {
                    reviewDynamic.innerHTML = '<div class="review-card"><p>Bu tesis icin onayli misafir yorumu bulunmuyor.</p></div>';
                    return;
                }

                reviewDynamic.innerHTML = '<div class="review-list">' + pageItems.map(function (item) {
                    const verified = item?.reservationTail
                        ? '<span class="review-verified-badge"><i class="fas fa-circle-check" aria-hidden="true"></i> ' + escapeHtml(reviewVerifiedLabel) + '</span>'
                        : '';
                    return '<article class="review-card">' +
                        '<div class="review-meta">' +
                            '<div class="review-meta-author">' +
                                '<span class="review-avatar" aria-hidden="true">' + escapeHtml(item?.avatar || 'OT') + '</span>' +
                                '<div>' +
                                    '<h4>' + escapeHtml(item?.name || 'Misafir') + '</h4>' +
                                    '<p class="review-meta-date">' + escapeHtml(item?.date || '') + verified + '</p>' +
                                '</div>' +
                            '</div>' +
                            '<span class="review-chip">' + escapeHtml(item?.score || '') + '</span>' +
                        '</div>' +
                        '<div class="review-body" data-review-card>' +
                            '<p class="review-text is-clamped" data-review-text>' + escapeHtml(item?.text || '') + '</p>' +
                            '<button type="button" class="review-more" data-review-more hidden>Devamını oku</button>' +
                            '<span data-review-fulltext hidden>' + escapeHtml(item?.text || '') + '</span>' +
                        '</div>' +
                    '</article>';
                }).join('') + '</div>';

                initReviewReadMore();
            }

            reviewSortSelect?.addEventListener('change', function () {
                const sortValue = reviewSortSelect.value || 'new';
                renderReviewFeedList(sortValue);
                const url = new URL(window.location.href);
                url.searchParams.set('reviewSort', sortValue);
                url.searchParams.set('reviewPage', '1');
                window.history.replaceState({}, '', url.toString());
                document.getElementById('reviewsSection')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });

            (function handleLegacyReservationCreatedRedirect() {
                const url = new URL(window.location.href);
                if (url.searchParams.get('reservationCreated') !== '1') {
                    return;
                }

                url.searchParams.delete('reservationCreated');
                window.history.replaceState({}, '', url.pathname + (url.search || ''));

                if (typeof window.showReservationSubmitOverlay === 'function') {
                    window.showReservationSubmitOverlay();
                } else {
                    showInfoModal('Teşekkür ederiz! Rezervasyonunuz oluşturuldu. Rezervasyonlarım sayfasına yönlendiriliyorsunuz.', false);
                }
                window.setTimeout(function () {
                    window.location.href = '/panel/user/rezervasyonlarim?created=1';
                }, 1600);
            })();
        })();
    </script>
    <script src="~/assets/js/oteldetay-gallery-mobile.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/otel-detay-reservation.js" asp-append-version="true"></script>
    <script src="~/assets/js/booking-date-guard.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/oteldetay-detail-mobile.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/otel-detay.js" asp-append-version="true"></script>
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
}
