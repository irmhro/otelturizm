@{
    string FixMojibake(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        // Common UTF-8-as-ANSI mojibake fixes for Turkish content.
        return value
            .Replace("Ã‡", "Ç", StringComparison.Ordinal)
            .Replace("Ã§", "ç", StringComparison.Ordinal)
            .Replace("Ä±", "ı", StringComparison.Ordinal)
            .Replace("Ä°", "İ", StringComparison.Ordinal)
            .Replace("Ã–", "Ö", StringComparison.Ordinal)
            .Replace("Ã¶", "ö", StringComparison.Ordinal)
            .Replace("Ãœ", "Ü", StringComparison.Ordinal)
            .Replace("Ã¼", "ü", StringComparison.Ordinal)
            .Replace("Åž", "Ş", StringComparison.Ordinal)
            .Replace("ÅŸ", "ş", StringComparison.Ordinal)
            .Replace("ÄŸ", "ğ", StringComparison.Ordinal)
            .Replace("Äž", "Ğ", StringComparison.Ordinal)
            .Replace("Â", "", StringComparison.Ordinal);
    }

    string MaskName(string? fullName)
    {
        var name = (fullName ?? "Misafir").Trim();
        if (string.IsNullOrWhiteSpace(name) || string.Equals(name, "Misafir", StringComparison.OrdinalIgnoreCase))
        {
            return "Misafir";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0];
        }

        var firstName = parts[0];
        var lastName = parts[^1];
        var lastPrefix = lastName.Length <= 3 ? lastName : lastName.Substring(0, 3);
        return $"{firstName} {lastPrefix}***";
    }

    var reviewSort = (Context.Request.Query["reviewSort"].ToString() ?? "new").Trim().ToLowerInvariant();
    var reviewPageRaw = Context.Request.Query["reviewPage"].ToString();
    var reviewPage = int.TryParse(reviewPageRaw, out var parsedReviewPage) ? Math.Max(1, parsedReviewPage) : 1;
    const int reviewPageSize = 7;

    var sortedReviews = (Model.Reviews ?? new List<otelturizmnew.Models.Oteller.HotelReviewViewModel>()).ToList();
    sortedReviews = reviewSort switch
    {
        "old" => sortedReviews.OrderBy(r => r.DateText).ToList(),
        "best" => sortedReviews.OrderByDescending(r => r.Score).ToList(),
        "worst" => sortedReviews.OrderBy(r => r.Score).ToList(),
        _ => sortedReviews.ToList()
    };
    if (reviewSort == "new")
    {
        sortedReviews = sortedReviews.ToList();
    }

    var totalReviewCount = sortedReviews.Count;
    var totalReviewPages = (int)Math.Ceiling(totalReviewCount / (double)reviewPageSize);
    if (totalReviewPages <= 0) totalReviewPages = 1;
    if (reviewPage > totalReviewPages) reviewPage = totalReviewPages;
    var pagedReviews = sortedReviews.Skip((reviewPage - 1) * reviewPageSize).Take(reviewPageSize).ToList();
    var signatureScore = Model.Rating > 0 ? Math.Round(Model.Rating, 2) : 0m;

    string NormalizeReviewText(string? value)
    {
        return (FixMojibake(value ?? string.Empty) ?? string.Empty).ToLower(new System.Globalization.CultureInfo("tr-TR"));
    }

    var reviewTopicDefinitions = new[]
    {
        new { Key = "konum", Label = "Konum", Icon = "fa-location-dot", Emoji = "📍", BaseScore = locScore > 0 ? locScore : signatureScore, Keywords = new[] { "konum", "merkez", "lokasyon", "yakın", "yakin", "mesafe", "sahil" } },
        new { Key = "temizlik", Label = "Temizlik", Icon = "fa-soap", Emoji = "🫧", BaseScore = cleaningScore > 0 ? cleaningScore : signatureScore, Keywords = new[] { "temiz", "temizlik", "hijyen", "nevresim", "banyo", "duş", "dus", "ferah" } },
        new { Key = "personel", Label = "Personel", Icon = "fa-user-group", Emoji = "🤝", BaseScore = staffScore > 0 ? staffScore : signatureScore, Keywords = new[] { "personel", "çalışan", "calisan", "güler", "guler", "yardımcı", "yardimci", "karşılama", "karsilama", "iletişim", "iletisim" } },
        new { Key = "fiyat", Label = "Fiyat", Icon = "fa-tags", Emoji = "🏷️", BaseScore = valScore > 0 ? valScore : signatureScore, Keywords = new[] { "fiyat", "performans", "uygun", "pahalı", "pahali", "değer", "deger", "fiyatına", "fiyatina" } },
        new { Key = "sessizlik", Label = "Sessizlik", Icon = "fa-moon", Emoji = "🌙", BaseScore = quietScore > 0 ? quietScore : signatureScore, Keywords = new[] { "sessiz", "gürültü", "gurultu", "gece", "uyku", "rahat", "huzurlu", "izolasyon" } },
        new { Key = "ulasim", Label = "Ulaşım", Icon = "fa-route", Emoji = "🧭", BaseScore = transportScore > 0 ? transportScore : signatureScore, Keywords = new[] { "ulasim", "ulaşım", "metro", "metrobüs", "metrobus", "otobüs", "otobus", "iskele", "havaalanı", "havalimanı", "tramvay" } }
    };

    var reviewTopicPayload = reviewTopicDefinitions.Select(def =>
    {
        var matchCount = sortedReviews.Count(r =>
        {
            var text = NormalizeReviewText(r.Text);
            return def.Keywords.Any(k => text.Contains(k, StringComparison.Ordinal));
        });
        var normalizedScore = Math.Max(0m, Math.Min(10m, def.BaseScore + (matchCount > 0 ? 0.12m : 0m)));
        return new
        {
            key = def.Key,
            label = def.Label,
            icon = def.Icon,
            emoji = def.Emoji,
            count = matchCount,
            score = normalizedScore.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture),
            keywords = def.Keywords
        };
    }).ToList();

    var reviewFeedSource = (Model.Reviews ?? new List<otelturizmnew.Models.Oteller.HotelReviewViewModel>()).ToList();
    var reviewFeedPayload = reviewFeedSource.Select((r, order) =>
    {
        var normalized = NormalizeReviewText(r.Text);
        var topicKeys = reviewTopicDefinitions
            .Where(def => def.Keywords.Any(k => normalized.Contains(k, StringComparison.Ordinal)))
            .Select(def => def.Key)
            .Distinct()
            .ToList();
        return new
        {
            order,
            name = MaskName(r.Name),
            date = r.DateText,
            score = r.Score.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture),
            scoreNum = r.Score,
            text = FixMojibake(r.Text),
            avatar = !string.IsNullOrWhiteSpace(r.Avatar) ? r.Avatar : "OT",
            reservationTail = r.ReservationNoTail,
            topics = topicKeys
        };
    }).ToList();

    var reviewTopicPayloadJson = System.Text.Json.JsonSerializer.Serialize(reviewTopicPayload);
    var reviewFeedPayloadJson = System.Text.Json.JsonSerializer.Serialize(reviewFeedPayload);
}

