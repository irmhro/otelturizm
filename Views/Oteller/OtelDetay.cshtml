            async function refreshPriceQuote() {
                if (!bookingPrice || !breakdown) {
                    return;
                }

                if (nightlyDetails && nightlyList) {
                    nightlyDetails.hidden = true;
                    nightlyList.innerHTML = '';
                }

                const roomNodes = getRoomItemNodes();
                if (!roomNodes.length) {
                    return;
                }

                const items = roomNodes.map(getRoomItemData);
                const invalid = items.some(function (x) {
                    return !x.roomTypeId || !x.checkIn || !x.checkOut || new Date(x.checkOut).getTime() <= new Date(x.checkIn).getTime();
                });
                if (invalid) {
                    return;
                }

                // request-key to avoid race conditions
                latestQuoteRequest = items.map(function (x) { return x.roomTypeId + '|' + x.checkIn + '|' + x.checkOut; }).join('||');
                const requestKey = latestQuoteRequest;

                const totals = {
                    vatRate: detailVatPctLabel,
                    accommodationTaxRate: detailAccomPctLabel,
                    vatAmount: 0,
                    accommodationTaxAmount: 0,
                    taxAmount: 0,
                    totalAmount: 0
                };

                const perRoom = [];
                const nightlySeed = { rows: [] };
                let anyUnavailable = false;
                let availabilityMessage = '';

                for (const item of items) {
                    try {
                        const response = await fetch('/oteller/@Model.Slug/fiyat-teklifi?roomTypeId=' + encodeURIComponent(item.roomTypeId) + '&checkInDate=' + encodeURIComponent(item.checkIn) + '&checkOutDate=' + encodeURIComponent(item.checkOut) + '&roomCount=1', {
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        if (!response.ok) {
                            throw new Error('Fiyat özeti alınamadı');
                        }
                        const quote = await response.json();
                        if (!quote.success || latestQuoteRequest !== requestKey) {
                            return;
                        }

                        const vat = Number(quote.vatAmount || 0);
                        const acc = Number(quote.accommodationTaxAmount || 0);
                        const tax = Number(quote.taxAmount || (vat + acc));
                        const total = Number(quote.totalAmount || 0);

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += acc;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });

                        if (perRoom.length === 1 && Array.isArray(quote.nightlyBreakdown)) {
                            nightlySeed.rows = quote.nightlyBreakdown;
                        }

                        if (quote.isAvailable === false) {
                            anyUnavailable = true;
                            availabilityMessage = quote.availabilityMessage || availabilityMessage;
                        }
                    } catch (_error) {
                        // fallback: use option net price from DOM
                        const node = roomNodes[perRoom.length] || null;
                        const opt = node?.querySelector('[data-field="roomType"]')?.selectedOptions?.[0];
                        const netNightly = parseFloat(opt?.dataset.price || '0');
                        const diffMs = new Date(item.checkOut).getTime() - new Date(item.checkIn).getTime();
                        const nights = Math.max(1, Math.round(diffMs / 86400000));
                        const subtotal = netNightly * nights;
                        const vat = Math.round(subtotal * detailVatFraction);
                        const accommodationTax = Math.round(subtotal * detailAccommodationFraction);
                        const tax = vat + accommodationTax;
                        const total = subtotal + tax;

                        totals.vatAmount += vat;
                        totals.accommodationTaxAmount += accommodationTax;
                        totals.taxAmount += tax;
                        totals.totalAmount += total;

                        perRoom.push({
                            roomName: item.roomName,
                            checkIn: item.checkIn,
                            checkOut: item.checkOut,
                            totalAmount: total
                        });
                    }
                }

                if (latestQuoteRequest !== requestKey) {
                    return;
                }

                // price head: show total if multiple rooms, otherwise nightly
                const unitEl = document.querySelector('.booking-price-unit');
                const itemCount = Math.max(1, roomNodes.length);
                if (itemCount > 1) {
                    bookingPrice.textContent = formatMoney(totals.totalAmount);
                    if (unitEl) unitEl.textContent = 'toplam';
                } else {
                    const nights = Math.max(1, Math.round((new Date(items[0].checkOut).getTime() - new Date(items[0].checkIn).getTime()) / 86400000));
                    const inclusiveNightly = totals.totalAmount / nights;
                    bookingPrice.textContent = formatMoney(inclusiveNightly);
                    if (unitEl) unitEl.textContent = '';
                }

                breakdown.innerHTML = buildMultiRoomBreakdownHtml(perRoom, totals);

                if (nightlyDetails && nightlyList) {
                    const showNightly = roomNodes.length === 1 && Array.isArray(nightlySeed.rows) && nightlySeed.rows.length > 0;
                    nightlyDetails.hidden = !showNightly;
                    if (showNightly) {
                        nightlyList.innerHTML = nightlySeed.rows.map(function (row) {
                            const label = (row.dateText || row.date || '').toString();
                            const effectiveAmount = Number(row.price || row.totalAmount || row.amount || 0);
                            const baseAmount = Number(row.basePrice || 0);
                            const discountAmount = Number(row.discountPrice || 0);
                            const isDiscounted = !!row.isDiscounted && discountAmount > 0 && baseAmount > discountAmount;
                            const amountHtml = isDiscounted
                                ? '<strong><small>' + formatMoney(baseAmount) + '</small>' + formatMoney(effectiveAmount) + '</strong>'
                                : '<strong>' + formatMoney(effectiveAmount) + '</strong>';
                            return '<div class="nightly-breakdown-row' + (isDiscounted ? ' nightly-breakdown-row-discount' : '') + '"><span>' + escapeHtml(label) + '</span>' + amountHtml + '</div>';
                        }).join('');
                    } else {
                        nightlyList.innerHTML = '';
                    }
                }

                lastQuoteUnavailable = anyUnavailable;
                if (anyUnavailable) {
                    setQuoteNotice(availabilityMessage || 'Seçili tarihler için uygun stok veya satış bulunamadı.', 'warning');
                } else {
                    setQuoteNotice(availabilityMessage || '', 'info');
                }

                syncReserveButtonEnabled();
            }

