                }

                if (activeDraftMessage) {
                    activeDraftMessage.textContent = '@Model.ActiveDraft?.HotelName · @Model.ActiveDraft?.CheckInText - @Model.ActiveDraft?.CheckOutText · Rezervasyonunuza kaldığınız yerden devam edebilirsiniz.';
                }

                if (openProfileCompletionFromBanner) {
