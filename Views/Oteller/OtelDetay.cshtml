            function addRoomItem(seed) {
                if (!roomItemsRoot || !roomItemTemplate) {
                    return;
                }
                const fragment = roomItemTemplate.content.cloneNode(true);
                const item = fragment.querySelector('[data-room-item]');
                if (!item) {
                    return;
                }
                const checkInEl = item.querySelector('[data-field="checkIn"]');
                const checkOutEl = item.querySelector('[data-field="checkOut"]');
                const roomTypeEl = item.querySelector('[data-field="roomType"]');
                if (checkInEl && seed?.checkIn) checkInEl.value = seed.checkIn;
                if (checkOutEl && seed?.checkOut) checkOutEl.value = seed.checkOut;
                if (roomTypeEl && seed?.roomTypeId) roomTypeEl.value = String(seed.roomTypeId);
                roomItemsRoot.appendChild(fragment);
                const appended = roomItemsRoot.querySelectorAll('[data-room-item]')[roomItemsRoot.querySelectorAll('[data-room-item]').length - 1];
                normalizeRoomItemDates(appended);
                bindRoomItemEvents(appended);
