            function formatRatePct(value) {
                const n = Number(value || 0);
                if (!Number.isFinite(n) || n <= 0) {
                    return '0';
                }
                const t = n.toFixed(2);
                if (t.endsWith('.00')) {
                    return n.toFixed(0);
                }
                return t.replace(/0$/, '');
            }

