                        if (!paymentMethodSelect || !value) {
                            return;
                        }
                        paymentMethodSelect.value = value;
                        syncPaymentMethodState();
                        closeModal(infoModal);
                        bookingAdvancedFields?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    });
                });
                infoModalActions.querySelectorAll('[data-close-modal]').forEach(function (button) {
                    button.addEventListener('click', function () {
                        closeModal(infoModal);
                        infoModal.classList.remove('is-auth-required');
                    });
                });
