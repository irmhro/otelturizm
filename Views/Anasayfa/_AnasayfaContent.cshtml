@model otelturizmnew.Models.Anasayfa.AnasayfaViewModel
@{
    var featuredHotels = (Model.PopularHotels?.Any() == true ? Model.PopularHotels : Model.WeekendHotels)?.Take(4).ToList() ?? new();
    var fallbackImages = new[]
    {
        "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=700&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=700&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1584132967334-10e028bd69f7?w=700&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=700&auto=format&fit=crop&q=80"
    };
    var fallbackNames = new[] { "Bodrum Premium Resort", "Kapadokya Cave Suite", "İstanbul Boğaz Oteli", "Antalya Eko Resort" };
    var fallbackLocations = new[] { "Bodrum, Muğla", "Ürgüp, Nevşehir", "Beşiktaş, İstanbul", "Kemer, Antalya" };
    var turkeyTz = TimeZoneInfo.FindSystemTimeZoneById("Turkey Standard Time");
    var homeToday = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, turkeyTz).Date;
    var homeCheckInDefault = homeToday.ToString("yyyy-MM-dd");
    var homeCheckOutDefault = homeToday.AddDays(7).ToString("yyyy-MM-dd");
    var homeCheckOutMinDefault = homeToday.AddDays(1).ToString("yyyy-MM-dd");
    var heroHeadlines = new[]
    {
        "Global güven ve Türk misafirperverliğiyle dünyayı keşfedin.",
        "Hayalinizdeki tatili güvenle planlayın, dünyayı keşfedin.",
        "Binlerce otel ve tur seçeneğiyle seyahatin yeni adresi.",
        "Yerel samimiyetle global seyahat deneyimini bir araya getiriyoruz.",
        "Dünyanın her yerinde güvenli, kolay ve konforlu rezervasyon."
    };
    var heroHeadline = heroHeadlines[Random.Shared.Next(heroHeadlines.Length)];
    var heroWords = heroHeadline.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var destinationFallbackImages = new[]
    {
        "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=100&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=100&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1584132967334-10e028bd69f7?w=100&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=100&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=100&auto=format&fit=crop&q=80",
        "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=100&auto=format&fit=crop&q=80"
    };
    var popularDestinations = (Model.PopularDestinations ?? new List<otelturizmnew.Models.Anasayfa.HomeDestinationCardViewModel>())
        .Where(d => d.HotelCount > 0 && !string.IsNullOrWhiteSpace(d.City))
        .Take(6)
        .ToList();
    var heroSplitAt = 1;
    if (heroWords.Length > 1)
    {
        var bestScore = double.MaxValue;
        for (var k = 1; k < heroWords.Length; k++)
        {
            var line1Len = string.Join(" ", heroWords.Take(k)).Length;
            var line2Len = string.Join(" ", heroWords.Skip(k)).Length;
            var score = Math.Max(line1Len, line2Len) * 2 + Math.Abs(line1Len - line2Len);
            if (score < bestScore)
            {
                bestScore = score;
                heroSplitAt = k;
            }
        }
    }
    var heroLine1 = heroWords.Take(heroSplitAt).ToArray();
    var heroLine2 = heroWords.Skip(heroSplitAt).ToArray();
    string HeroWordTone(int index) => $"hero-title-word--tone-{index % 5}";
}

<main>
    <section class="hero-section">
        <div class="hero-section-atmosphere" aria-hidden="true">
            <span class="hero-atmosphere-orb hero-atmosphere-orb--warm"></span>
            <span class="hero-atmosphere-orb hero-atmosphere-orb--crimson"></span>
            <span class="hero-atmosphere-orb hero-atmosphere-orb--mist"></span>
        </div>
        <div class="container">
            <div class="hero-stage">
                <div class="hero-stage-veil" aria-hidden="true"></div>
            <div class="hero-top-grid hero-top-grid--solo">
                <div class="hero-headline-pro">
                    @await Component.InvokeAsync("LogoOzelGun")
                    <h1 class="hero-title hero-title-pro hero-title-pro--headline" aria-label="@heroHeadline">
                        <span class="hero-title-row hero-title-row--spread" aria-hidden="false">
                            @for (var i = 0; i < heroLine1.Length; i++)
                            {
                                <span class="hero-title-word @HeroWordTone(i)">@heroLine1[i]</span>
                            }
                        </span>
                        @if (heroLine2.Length > 0)
                        {
                            <span class="hero-title-row hero-title-row--spread">
                                @for (var i = 0; i < heroLine2.Length; i++)
                                {
                                    <span class="hero-title-word @HeroWordTone(i + heroLine1.Length)">@heroLine2[i]</span>
                                }
                            </span>
                        }
                    </h1>
                </div>
            </div>

            <div class="search-engine-shell">
                <form class="search-engine search-engine-pro" method="get" action="/oteller" data-search-pro-form>
                    <div class="search-pro-row search-pro-row-trip">
                        <div class="search-pro-field search-pro-destination input-group input-destination">
                            <label for="home-q"><i class="fas fa-location-dot"></i> Nereye gitmek istersiniz ?</label>
                            <div class="search-pro-input typewriter-field">
                                <input id="home-q" name="q" type="text" placeholder=" " autocomplete="off" aria-describedby="home-q-hint" />
                                <span id="home-q-hint" class="typewriter-hint" aria-hidden="true"></span>
                            </div>
                        </div>
                        <div class="search-pro-field search-pro-checkin input-group input-checkin">
                            <label for="home-checkin"><i class="far fa-calendar"></i> Giriş</label>
                            <div class="search-pro-input">
                                <input id="home-checkin" name="checkIn" type="date" min="@homeCheckInDefault" value="@homeCheckInDefault" />
                            </div>
                        </div>
                        <div class="search-pro-field search-pro-checkout input-group input-checkout">
                            <label for="home-checkout"><i class="far fa-calendar-check"></i> Çıkış</label>
                            <div class="search-pro-input">
                                <input id="home-checkout" name="checkOut" type="date" min="@homeCheckOutMinDefault" value="@homeCheckOutDefault" />
                            </div>
                        </div>
                    </div>
                    <div class="search-pro-row search-pro-row-meta">
                        <div class="search-pro-guests-group">
                            <label class="search-pro-guests-title"><i class="fas fa-user-group"></i> Konuk &amp; Oda</label>
                            <div class="search-pro-guests-row">
                                <div class="search-pro-field search-pro-adults input-group input-adults">
                                    <label for="home-adults">Yetişkin</label>
                                    <div class="search-pro-input">
                                        <select id="home-adults" name="adults" aria-label="Yetişkin sayısı">
                                            <option value="1">1</option>
                                            <option value="2" selected>2</option>
                                            <option value="3">3</option>
                                            <option value="4">4</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="search-pro-field search-pro-children input-group input-children">
                                    <label for="home-children">Çocuk</label>
                                    <div class="search-pro-input">
                                        <select id="home-children" name="children" aria-label="Çocuk sayısı">
                                            <option value="0" selected>0</option>
                                            <option value="1">1</option>
                                            <option value="2">2</option>
                                            <option value="3">3</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="search-pro-field search-pro-rooms input-group input-rooms">
                                    <label for="home-rooms">Oda</label>
                                    <div class="search-pro-input">
                                        <select id="home-rooms" name="rooms" aria-label="Oda sayısı">
                                            <option value="1" selected>1</option>
                                            <option value="2">2</option>
                                            <option value="3">3</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="search-pro-action">
                            <button type="submit" class="btn-search btn-search-pro"><span>Otel Bul</span><i class="fas fa-magnifying-glass"></i></button>
                        </div>
                    </div>
                    <div class="search-pro-row search-pro-row-tags is-collapsed" data-search-ai-tags>
                        <div class="search-pro-ai-bar">
                            <button type="button" class="search-pro-ai-toggle" data-search-ai-toggle aria-expanded="false" aria-controls="search-ai-panel">
                                <span class="search-pro-ai-toggle-main">
                                    <i class="fas fa-wand-magic-sparkles" aria-hidden="true"></i>
                                    <span>Yapay Zeka Destekli Akıllı Rota</span>
                                </span>
                                <span class="search-pro-ai-toggle-meta">
                                    <span class="search-pro-ai-selected-count" data-search-ai-count hidden></span>
                                    <i class="fas fa-chevron-down search-pro-ai-chevron" aria-hidden="true"></i>
                                </span>
                            </button>
                        </div>
                        <div class="search-pro-ai-panel" id="search-ai-panel" data-search-ai-panel hidden>
                            <p class="search-pro-ai-label" data-search-ai-label>Etiket önerileri <small>(çoklu seçim · aramaya eklenir)</small></p>
                            <div class="search-pro-ai-pills ai-pills ai-pills-grid" role="group" aria-label="Arama etiketleri">
                                <button type="button" class="ai-pill ai-pill--sage" data-search-tag="sakin ve huzurlu ortam"><span class="ai-pill-dot" aria-hidden="true"></span>#SakinlikArayanlar</button>
                                <button type="button" class="ai-pill ai-pill--amber" data-search-tag="çocuk dostu, aile oteli"><span class="ai-pill-dot" aria-hidden="true"></span>#ÇocukDostu</button>
                                <button type="button" class="ai-pill ai-pill--wine" data-search-tag="gurme deneyim, fine dining"><span class="ai-pill-dot" aria-hidden="true"></span>#GurmeDeneyimi</button>
                                <button type="button" class="ai-pill ai-pill--sky" data-search-tag="özel havuz, suite"><span class="ai-pill-dot" aria-hidden="true"></span>#ÖzelHavuzlu</button>
                                <button type="button" class="ai-pill ai-pill--ocean" data-search-tag="denize sıfır, plaj"><span class="ai-pill-dot" aria-hidden="true"></span>#DenizeSıfır</button>
                                <button type="button" class="ai-pill ai-pill--violet" data-search-tag="spa ve wellness"><span class="ai-pill-dot" aria-hidden="true"></span>#SpaWellness</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            </div>

            <div class="route-picker" data-route-picker>
                <button type="button" class="route-picker-marquee-btn" data-route-picker-open aria-haspopup="dialog" aria-expanded="false" aria-label="Popüler rotalar — tümünü gör">
                    <div class="route-picker-marquee">
                        <div class="route-picker-marquee-viewport">
                            <div class="route-picker-marquee-track" data-route-marquee-track>
                                <span class="route-marquee-chip route-marquee-chip--sun">🌅 Ege Şafakları</span>
                                <span class="route-marquee-chip route-marquee-chip--rose">🎈 Kapadokya Mağara</span>
                                <span class="route-marquee-chip route-marquee-chip--gold">🕌 Tarihi Yarımada</span>
                                <span class="route-marquee-chip route-marquee-chip--sea">🌊 Turkuaz Akdeniz</span>
                                <span class="route-marquee-chip route-marquee-chip--forest">🌲 Karadeniz Yayla</span>
                                <span class="route-marquee-chip route-marquee-chip--steam">♨️ Termal Lüks</span>
                            </div>
                        </div>
                        <span class="route-picker-marquee-action" aria-hidden="true">
                            <i class="fas fa-th-large"></i>
                            <span>Tümü</span>
                        </span>
                    </div>
                </button>
            </div>
        </div>
    </section>

    <div class="container">
        <section class="flash-mystery-box" id="dawnSurpriseBanner" data-dawn-surprise-banner>
            <div class="mystery-left">
                <span class="mystery-icon" aria-hidden="true">🎁</span>
                <div class="mystery-details">
                    <h4>Şanslı Şafak Sürpriz Kutusu Aktif!</h4>
                    <p data-dawn-surprise-copy>Hesabınıza özel ek %1 ila %6 arasında rastgele ekstra indirim kazanın.</p>
                </div>
            </div>
            <div class="mystery-action-row">
                <span class="mystery-countdown" id="dawnSurpriseCountdown" data-dawn-countdown>🎁 24 saat geçerli</span>
                <button type="button" class="btn-open-box" id="dawnSurpriseOpenBtn" data-dawn-open>Kutuyu Aç ve Uygula</button>
            </div>
        </section>

        <div class="dawn-surprise-modal" id="dawnSurpriseModal" hidden aria-hidden="true">
            <div class="dawn-surprise-backdrop" data-dawn-close tabindex="-1"></div>
            <div class="dawn-surprise-dialog" role="dialog" aria-modal="true" aria-labelledby="dawnSurpriseTitle">
                <button type="button" class="dawn-surprise-close" data-dawn-close aria-label="Kapat"><i class="fas fa-times"></i></button>
                <h3 id="dawnSurpriseTitle" class="dawn-surprise-title">Şanslı Şafak Kutusu</h3>
                <p class="dawn-surprise-error" id="dawnSurpriseError" hidden role="alert"></p>
                <div class="dawn-surprise-stage">
                    <div class="dawn-surprise-box" id="dawnSurpriseBox" aria-hidden="true">
                        <div class="dawn-surprise-glow" aria-hidden="true"></div>
                        <div class="dawn-surprise-lid">
                            <span class="dawn-surprise-ribbon dawn-surprise-ribbon--h" aria-hidden="true"></span>
                            <span class="dawn-surprise-ribbon dawn-surprise-ribbon--v" aria-hidden="true"></span>
                        </div>
                        <div class="dawn-surprise-base">
                            <span class="dawn-surprise-gift">🎁</span>
                        </div>
                        <div class="dawn-surprise-confetti" aria-hidden="true">
                            <span></span><span></span><span></span><span></span><span></span><span></span>
                            <span></span><span></span><span></span><span></span><span></span><span></span>
                        </div>
                        <div class="dawn-surprise-sparkles" aria-hidden="true"></div>
                    </div>
                    <div class="dawn-surprise-result" id="dawnSurpriseResult" hidden>
                        <div class="dawn-surprise-percent-badge"><span id="dawnSurprisePercentValue">0</span>%</div>
                        <p class="dawn-surprise-result-text">Ek indirim rezervasyon toplamından düşülecek. İndiriminiz 24 saat boyunca tarayıcınızda saklanır.</p>
                        <a class="dawn-surprise-go-hotels" href="/oteller">Otelleri Keşfet</a>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="section-headline"><span class="headline-left">Seçilen Özel Rotalar</span><a class="headline-link" href="/oteller">Tümünü gör</a></h2>
        <section class="hotel-grid">
            @if (featuredHotels.Count > 0)
            {
                var index = 0;
                foreach (var hotel in featuredHotels)
                {
                    var image = !string.IsNullOrWhiteSpace(hotel.ImageUrl) ? hotel.ImageUrl : fallbackImages[index % fallbackImages.Length];
                    var detailUrl = string.IsNullOrWhiteSpace(hotel.DetailSlug) ? "/oteller" : $"/oteller/{Uri.EscapeDataString(hotel.DetailSlug)}";
                    var location = !string.IsNullOrWhiteSpace(hotel.LocationText) ? hotel.LocationText : $"{hotel.District}, {hotel.City}".Trim(' ', ',');
                    var hasDiscount = hotel.HasDiscount && hotel.OriginalPrice.HasValue && hotel.DiscountedPrice.HasValue;
                    <article class="hotel-card">
                        <a href="@detailUrl" class="home-premium-card-link" aria-label="@hotel.Name detay">
                            <div class="img-holder">
                                <img src="@image" alt="@hotel.Name" loading="lazy" decoding="async" />
                                <span class="badge-lux">★★★★★</span>
                            </div>
                            <div class="hotel-card-body">
                                <h3 class="hotel-title">@hotel.Name</h3>
                                <p class="hotel-desc"><i class="fas fa-location-dot"></i> @location</p>
                                <div class="price-row">
                                    <div class="price-inline">
                                        @if (hasDiscount)
                                        {
                                            <strong>₺@hotel.DiscountedPrice!.Value.ToString("N0")</strong>
                                            <small class="price-tax-note">Vergiler dahil · %@hotel.DiscountPercent indirim</small>
                                        }
                                        else if (hotel.StartingPrice.HasValue)
                                        {
                                            <strong>₺@hotel.StartingPrice.Value.ToString("N0")</strong>
                                            <small class="price-tax-note">Vergiler dahil</small>
                                        }
                                        else
                                        {
                                            <strong>@hotel.PriceText</strong>
                                            <small class="price-tax-note">Vergiler dahil</small>
                                        }
                                    </div>
                                    <span class="card-link">İncele →</span>
                                </div>
                            </div>
                        </a>
                    </article>
                    index++;
                }
            }
            else
            {
                for (var i = 0; i < 4; i++)
                {
                    <article class="hotel-card">
                        <a href="/oteller" class="home-premium-card-link">
                            <div class="img-holder"><img src="@fallbackImages[i]" alt="@fallbackNames[i]" loading="lazy" decoding="async" /><span class="badge-lux">★★★★★</span></div>
                            <div class="hotel-card-body">
                                <h3 class="hotel-title">@fallbackNames[i]</h3>
                                <p class="hotel-desc"><i class="fas fa-location-dot"></i> @fallbackLocations[i]</p>
                                <div class="price-row"><div class="price-inline"><strong>₺3.900</strong><small class="price-tax-note">Vergiler dahil</small></div><span class="card-link">İncele →</span></div>
                            </div>
                        </a>
                    </article>
                }
            }
        </section>

        <div class="section-headline"><span class="headline-left">Güncel Fırsatlar</span></div>
        <section class="deals-row">
            <a class="deal-card" href="/kampanyalar">
                <div class="deal-head"><h3>%35 Bodrum Erken Rezervasyon Fırsatı</h3><span class="deal-tag">-35% İndirim</span></div>
                <p class="deal-body">Seçili ultra lüks resortlarda bu gece yarısına özel sınırlı kontenjan ve premium transfer hediyeli.</p>
                <div class="deal-foot"><span class="deal-timer"><i class="far fa-clock"></i> Sayaç: 04sa : 12dk kaldı</span><span class="deal-cta">Yer Ayır →</span></div>
            </a>
            <a class="deal-card" href="/oteller?filter=weekend">
                <div class="deal-head"><h3>Kapadokya Hafta Sonu Premium Paket</h3><span class="deal-tag deal-tag-gold">Club Özel</span></div>
                <p class="deal-body">Mağara suit konaklamalarında ücretsiz sabah balonu turu ikramı ve havalimanı karşılama dahil.</p>
                <div class="deal-foot"><span class="deal-timer"><i class="far fa-clock"></i> Sayaç: 08sa : 44dk kaldı</span><span class="deal-cta deal-cta-light">Detayları Gör →</span></div>
            </a>
        </section>

        <div class="section-headline"><span class="headline-left">Akıllı Fiyat Kalkanı</span></div>
        <section class="price-lock-banner" aria-label="Fiyat alarmı ve favori takibi">
            <div class="lock-content">
                <div class="lock-text">
                    <div class="lock-title-row">
                        <span class="lock-badge" aria-hidden="true"><i class="fas fa-bell"></i></span>
                        <h4>Fiyat alarmı ve favori takibi</h4>
                    </div>
                    <p>Beğendiğiniz otelleri favorilere ekleyin, hedef fiyat belirleyin. Fiyat hedefinize düştüğünde sizi e-posta ile bilgilendiririz.</p>
                    <ul class="price-lock-steps">
                        <li><i class="fas fa-heart" aria-hidden="true"></i> Oteli favorile</li>
                        <li><i class="fas fa-bullseye" aria-hidden="true"></i> Hedef fiyat gir</li>
                        <li><i class="fas fa-envelope" aria-hidden="true"></i> E-posta bildirimi</li>
                    </ul>
                </div>
            </div>
            <a class="btn-lock-action" href="/panel/user/favorilerim">Fiyat takibini başlat</a>
        </section>

        <div class="section-headline"><span class="headline-left">Seyahat Rozetleri & Görevler</span></div>
        <section class="quest-layout" aria-label="Seyahat rozetleri ve görevler">
            <div class="quest-grid">
                <div class="quest-item">
                    <div class="quest-info">
                        <h5>Ege Kaşifi · Seviye 2</h5>
                        <p>3 Ege konaklaması · %5 kalıcı indirim</p>
                        <div class="quest-progress-bar"><div class="quest-progress-fill" style="width: 66%;"></div></div>
                        <span class="quest-status">2 / 3 tamamlandı</span>
                    </div>
                </div>
                <div class="quest-item">
                    <div class="quest-info">
                        <h5>Gurme Gurusu</h5>
                        <p>Deneyim rezervasyonu · gurme ikramı</p>
                        <div class="quest-progress-bar"><div class="quest-progress-fill" style="width: 33%;"></div></div>
                        <span class="quest-status">Devam ediyor</span>
                    </div>
                </div>
                <div class="quest-item">
                    <div class="quest-info">
                        <h5>Business Üstat</h5>
                        <p>Kurumsal profil · lounge hakkı</p>
                        <div class="quest-progress-bar"><div class="quest-progress-fill quest-progress-done" style="width: 100%;"></div></div>
                        <span class="quest-status quest-status-done">Tamamlandı</span>
                    </div>
                </div>
                <div class="quest-item">
                    <div class="quest-info">
                        <h5>Yaz Gezgini</h5>
                        <p>İlk yaz rezervasyonu · %8 kupon</p>
                        <div class="quest-progress-bar"><div class="quest-progress-fill" style="width: 45%;"></div></div>
                        <span class="quest-status">Devam ediyor</span>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-headline">
            <span class="headline-left">Bölgelere Göre Keşfet</span>
            <a href="/oteller/harita" class="headline-link">Tüm Haritayı Gör →</a>
        </div>
        <section class="destinations-grid">
            @if (popularDestinations.Count > 0)
            {
                for (var destIndex = 0; destIndex < popularDestinations.Count; destIndex++)
                {
                    var dest = popularDestinations[destIndex];
                    var destImage = string.IsNullOrWhiteSpace(dest.ImageUrl)
                        ? destinationFallbackImages[destIndex % destinationFallbackImages.Length]
                        : dest.ImageUrl;
                    var destListingUrl = string.IsNullOrWhiteSpace(dest.ListingUrl)
                        ? $"/oteller?q={Uri.EscapeDataString(dest.City)}"
                        : dest.ListingUrl;
                    var destAria = $"{dest.City} — {dest.HotelCount} otel";
                    <a class="dest-card" href="@destListingUrl" aria-label="@destAria">
                        <img class="dest-img" src="@destImage" alt="@dest.City" width="72" height="72" loading="lazy" decoding="async" />
                        <div class="dest-meta">
                            <h4>@dest.City</h4>
                            <p>
                                @dest.HotelCount otel
                                @if (!string.IsNullOrWhiteSpace(dest.LeadText))
