@model otelturizmnew.Models.Anasayfa.AnasayfaViewModel

@{
    var categoryShowcaseHotels = Model.PopularHotels.Count > 0 ? Model.PopularHotels : Model.WeekendHotels;
    var todayIso = DateTime.Today.ToString("yyyy-MM-dd");
    var homepageCategorySections = new[]
    {
        new { Key = "haftasonu-firsatlari", Title = "Hafta Sonu Fırsatları" },
        new { Key = "butcene-uygun", Title = "Bütçene Uygun" },
        new { Key = "evcil-hayvan-dostu", Title = "Evcil Hayvan Dostu" },
        new { Key = "kampanyali-oteller", Title = "Kampanyalı Oteller" },
        new { Key = "yildiz-yagmuru", Title = "Yıldız Yağmuru" }
    };
}

<section class="hero-section">
    <div class="container-xl px-4">
        <div class="hero-layout">

            <div class="hero-slider-shell desktop-only">
                @if (Model.CampaignSlides.Count == 0)
                {
                    <div class="hero-slide-empty">
                        <strong>Kampanya vitrini hazir degil</strong>
                        <span>Aktif kampanya gorselleri geldikce bu alan otomatik dolar.</span>
                    </div>
                }
                else
                {
                    <div class="swiper hero-swiper">
                        <div class="swiper-wrapper">
                            @foreach (var slide in Model.CampaignSlides)
                            {
                                <div class="swiper-slide">
                                    <a href="@slide.TargetUrl" class="hero-slide-card campaign-slide-card">
                                        <img src="@slide.ImageUrl" alt="@slide.CampaignName" />
                                        <span class="hero-slide-tag">@slide.BadgeText</span>
                                        <div class="hero-slide-overlay">
                                            <h3>@slide.CampaignName</h3>
                                            <p>@slide.Slogan</p>
                                            <span class="hero-slide-cta">Kampanyayi Incele <i class="fas fa-arrow-right"></i></span>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                        <div class="swiper-pagination hero-pagination"></div>
                    </div>
                }
            </div>

            <div class="hero-copy" style="text-align:center;">
                <h1 class="hero-title">Türkiye'nin <span class="rose-gradient-text">Seçkin</span> Otellerini Keşfet</h1>
                <p class="hero-text">Şehir otelleri, butik tesisler ve hafta sonu indirimleri tek platformda; güvenli rezervasyon ve şeffaf fiyatlarla karşılaştırın.</p>

                <form class="fancy-search-card" asp-controller="Oteller" asp-action="OtelListeleme" method="get" aria-label="Gelişmiş arama">
                    <div class="fancy-main">
                        <label class="fancy-label">Nereye gidiyorsun?</label>
                        <div class="fancy-input-wrap">
                            <div class="fancy-pin"><i class="fas fa-location-crosshairs"></i></div>
                            <input class="fancy-input" type="text" name="q" value="" data-seeded-value="" placeholder="İl, ilçe, mahalle veya otel adı yazın" autocomplete="off" />
                            <input type="hidden" class="fancy-selected-type" value="" />
                            <input type="hidden" class="fancy-selected-slug" value="" />
                        </div>
                        <div class="fancy-search-suggestions" id="homeSearchSuggestions" hidden></div>
                        <div class="fancy-suggestions" aria-hidden="true">İpucu: İl · İlçe · Mahalle · Otel adı ile arayın</div>
                    </div>

                    <div class="fancy-controls">
                        <label class="pill pill-checkin">
                            <i class="fa-regular fa-calendar"></i>
                            <input type="date" name="checkIn" min="@todayIso" />
                        </label>

                        <label class="pill pill-checkout">
                            <i class="fa-regular fa-calendar"></i>
                            <input type="date" name="checkOut" min="@todayIso" />
                        </label>

                        <label class="pill pill-guests">
                            <i class="fas fa-user"></i>
                            <select name="guests">
                                <option value="2">2 Yetişkin</option>
                                <option value="1">1 Yetişkin</option>
                                <option value="3">3 Yetişkin</option>
                                <option value="4">4 Yetişkin</option>
                            </select>
                        </label>

                        <button type="submit" class="fancy-cta"><span class="fancy-cta-text">Ara</span> <i class="fas fa-search"></i></button>
                    </div>
                </form>
            </div>
        </div>

        <div class="page-feature-section" aria-label="Öne çıkan özellikler">
            <div class="feature-hub">
                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="budget" class="feature-card" title="Bütçeye Uygun Oteller">
                    <div class="feature-icon gradient-budget"><i class="fas fa-wallet"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">Bütçeye Uygun</div>
                        <div class="feature-sub">Ekonomik ve kaliteli seçenekler</div>
                    </div>
                </a>

                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="discount" class="feature-card" title="İndirimli Oteller">
                    <div class="feature-icon gradient-discount"><i class="fas fa-tag"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">İndirimli Oteller</div>
                        <div class="feature-sub">Güncel kampanyalarla tasarruf edin</div>
                    </div>
                </a>

                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="weekend" class="feature-card" title="Hafta Sonu Fırsatları">
                    <div class="feature-icon gradient-weekend"><i class="fas fa-calendar-week"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">Hafta Sonu</div>
                        <div class="feature-sub">Kısa tatil fırsatları</div>
                    </div>
                </a>

                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="pool" class="feature-card" title="Havuzlu Oteller">
                    <div class="feature-icon gradient-pool"><i class="fas fa-swimming-pool"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">Havuzlu Oteller</div>
                        <div class="feature-sub">Havuz keyfini yaşayın</div>
                    </div>
                </a>

                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="campaign" class="feature-card" title="Kampanyalı Oteller">
                    <div class="feature-icon gradient-campaign"><i class="fas fa-bolt"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">Kampanyalı</div>
                        <div class="feature-sub">Özel fırsatlar ve erken rezervasyon</div>
                    </div>
                </a>

                <a href="/seyahat-planlama" class="feature-card" title="Seyahat Planlama">
                    <div class="feature-icon gradient-plan"><i class="fas fa-route"></i></div>
                    <div class="feature-content">
                        <div class="feature-title">Seyahat Planlama</div>
                        <div class="feature-sub">Kişiselleştirilmiş gezi planları</div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-campaign-section mobile-only">
    <div class="container-xl px-4">
        <div class="section-header">
            <h2 class="section-title">Kampanyalar</h2>
            <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-filter="discount" class="section-link">Tümünü Gör <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="campaign-slider-shell">
            @if (Model.CampaignSlides.Count == 0)
            {
                <div class="hero-slide-empty">
                    <strong>Kampanya vitrini hazir degil</strong>
                    <span>Aktif kampanya gorselleri geldikce bu alan otomatik dolar.</span>
                </div>
            }
            else
            {
                <div class="swiper hero-swiper campaign-swiper">
                    <div class="swiper-wrapper">
                        @foreach (var slide in Model.CampaignSlides)
                        {
                            <div class="swiper-slide">
                                <a href="@slide.TargetUrl" class="hero-slide-card campaign-slide-card">
                                    <img src="@slide.ImageUrl" alt="@slide.CampaignName" />
                                    <span class="hero-slide-tag">@slide.BadgeText</span>
                                    <div class="hero-slide-overlay">
                                        <h3>@slide.CampaignName</h3>
                                        <p>@slide.Slogan</p>
                                        <span class="hero-slide-cta">Kampanyayi Incele <i class="fas fa-arrow-right"></i></span>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="swiper-pagination hero-pagination"></div>
                </div>
            }
        </div>
    </div>
</section>

<script>
    (function () {
        const input = document.querySelector('.hero-section .fancy-input[name="q"]');
        if (!input) return;

        const checkInEl = document.querySelector('.hero-section input[type="date"][name="checkIn"]');
        const checkOutEl = document.querySelector('.hero-section input[type="date"][name="checkOut"]');
        const today = new Date();
        const todayIso = new Date(today.getFullYear(), today.getMonth(), today.getDate()).toISOString().slice(0, 10);

        function addDaysIso(isoDate, dayCount) {
            const base = new Date(isoDate + 'T00:00:00');
            base.setDate(base.getDate() + (dayCount || 0));
            return new Date(base.getFullYear(), base.getMonth(), base.getDate()).toISOString().slice(0, 10);
        }

        function syncDateMins() {
            if (checkInEl) {
                checkInEl.min = todayIso;
            }
            if (checkOutEl) {
                const minOut = checkInEl?.value ? addDaysIso(checkInEl.value, 1) : todayIso;
                checkOutEl.min = minOut;
                if (checkOutEl.value && checkOutEl.value < minOut) {
                    checkOutEl.value = '';
                }
            }
        }

        checkInEl?.addEventListener('change', function () {
            syncDateMins();
        });
        checkOutEl?.addEventListener('change', function () {
            syncDateMins();
        });
        syncDateMins();

        const basePlaceholder = input.getAttribute('placeholder') || '';
        const phrases = [
            'İstanbul, Kadıköy',
            'Kapadokya, Ürgüp',
            'Bodrum, Yalıkavak',
            'Otel adı: 216 Suites Hotel'
        ];

        let timer = null;
        let phraseIndex = 0;
        let charIndex = 0;
        let deleting = false;

        function clearTimer() {
            if (timer) window.clearTimeout(timer);
            timer = null;
        }

        function tick() {
            if (document.activeElement === input) return;
            if ((input.value || '').trim().length > 0) return;

            const full = phrases[phraseIndex] || '';
            const current = full.slice(0, charIndex);
            input.setAttribute('placeholder', current.length > 0 ? current : basePlaceholder);

            if (!deleting && charIndex < full.length) {
                charIndex += 1;
                timer = window.setTimeout(tick, 34);
                return;
            }

            if (!deleting && charIndex >= full.length) {
                deleting = true;
                timer = window.setTimeout(tick, 900);
                return;
            }

            if (deleting && charIndex > 0) {
                charIndex -= 1;
                timer = window.setTimeout(tick, 18);
                return;
            }

            deleting = false;
            phraseIndex = (phraseIndex + 1) % phrases.length;
            timer = window.setTimeout(tick, 250);
        }

        input.addEventListener('focus', function () {
            clearTimer();
            input.setAttribute('placeholder', basePlaceholder);
        });

        input.addEventListener('blur', function () {
            clearTimer();
            charIndex = 0;
            deleting = false;
            timer = window.setTimeout(tick, 450);
        });

        // Start only if empty
        if ((input.value || '').trim().length === 0) {
            timer = window.setTimeout(tick, 700);
        }
    })();
</script>

<!-- Populer Konaklama Yerleri removed as requested; placeholder kept for future feature -->


<section class="home-section">
    <div class="container-xl px-4">
        <div class="section-header">
            <h2 class="section-title">Öne Çıkan Oteller</h2>
            <a asp-controller="Oteller" asp-action="OtelListeleme" class="section-link">Tümünü Gör <i class="fas fa-arrow-right"></i></a>
        </div>

        @if (Model.PopularHotels.Count == 0)
        {
            <div class="hotel-empty-state">
                <h3>Yayınlanmış otel bulunamadı</h3>
                <p>`oteller` tablosunda yayın ve onay durumu aktif kayıtlar geldiğinde bu alan otomatik dolacak.</p>
            </div>
        }
        else
        {
            <div class="swiper popular-swiper">
                <div class="swiper-wrapper">
                    @foreach (var hotel in Model.PopularHotels.Take(8))
                    {
                        <div class="swiper-slide">
                            <partial name="~/Views/Anasayfa/_HomeHotelCard.cshtml" model="hotel" />
                        </div>
                    }
                </div>
                <div class="swiper-button-prev popular-prev"></div>
                <div class="swiper-button-next popular-next"></div>
            </div>
        }
    </div>
</section>

<section class="home-section weekend-section">
    <div class="container-xl px-4">
        <div class="section-header">
            <h2 class="section-title">İstanbul'da Hafta Sonu</h2>
            <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-city="istanbul" class="section-link">Tümünü Gör <i class="fas fa-arrow-right"></i></a>
        </div>

        @if (Model.WeekendHotels.Count == 0)
        {
            <div class="hotel-empty-state">
                <h3>İstanbul için önerilen otel bulunamadı</h3>
                <p>`tavsiye_edilen_otel` veya İstanbul yayındaki tesis kayıtlarını kontrol ederek bu alanı doldurabiliriz.</p>
            </div>
        }
        else
        {
            <div class="swiper weekend-swiper">
                <div class="swiper-wrapper">
                    @foreach (var hotel in Model.WeekendHotels)
                    {
                        <div class="swiper-slide">
                            <partial name="~/Views/Anasayfa/_HomeHotelCard.cshtml" model="hotel" />
                        </div>
                    }
                </div>
                <div class="swiper-button-prev weekend-prev"></div>
                <div class="swiper-button-next weekend-next"></div>
            </div>
        }
    </div>
</section>

@foreach (var categorySection in homepageCategorySections)
{
    <section class="home-section home-category-section">
        <div class="container-xl px-4">
            <div class="section-header">
                <h2 class="section-title">@categorySection.Title</h2>
                <a asp-controller="Oteller" asp-action="OtelListeleme" asp-route-etiket="@categorySection.Key" class="section-link">Tümünü Gör <i class="fas fa-arrow-right"></i></a>
            </div>

            @if (categoryShowcaseHotels.Count == 0)
            {
                <div class="hotel-empty-state">
                    <h3>Gösterilecek otel bulunamadı</h3>
                    <p>Bu alanlar şimdilik mevcut oteller ile listelenir; kategori bazlı veri bağlantısı sonraki adımda yapılabilir.</p>
                </div>
            }
            else
            {
                <div class="swiper home-category-swiper" data-swiper-key="@categorySection.Key">
                    <div class="swiper-wrapper">
                        @foreach (var hotel in categoryShowcaseHotels.Take(8))
                        {
                            <div class="swiper-slide">
                                <partial name="~/Views/Anasayfa/_HomeHotelCard.cshtml" model="hotel" />
                            </div>
                        }
                    </div>
                    <div class="swiper-button-prev home-category-prev"></div>
                    <div class="swiper-button-next home-category-next"></div>
                </div>
            }
        </div>
    </section>
}

<button type="button" class="floating-live-support-btn" aria-label="Canlı destek" hidden>
    <i class="fas fa-comments"></i>
    <span>Canlı Destek</span>
</button>

<div class="discount-modal" id="discountModal" hidden aria-hidden="true">
    <div class="discount-modal-backdrop" data-discount-close></div>
    <section class="discount-modal-card" role="dialog" aria-modal="true" aria-labelledby="discountModalTitle">
        <button type="button" class="discount-modal-close" data-discount-close aria-label="Kapat">
            <i class="fas fa-times" aria-hidden="true"></i>
        </button>
        <div class="discount-modal-head">
            <div class="discount-modal-kicker">İndirim Detayı</div>
            <h3 id="discountModalTitle">İndirim</h3>
            <p id="discountModalDesc"></p>
        </div>
        <div class="discount-modal-visual" id="discountModalVisual" hidden>
            <img id="discountModalImage" alt="İndirim görseli" />
        </div>
    </section>
</div>

<style>
    .discount-info-btn {
        margin-left: 8px;
        width: 28px;
        height: 28px;
        border-radius: 999px;
        border: 1px solid rgba(29, 78, 216, 0.22);
        background: rgba(239, 246, 255, 0.9);
        color: #1d4ed8;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        vertical-align: middle;
    }

    .discount-modal {
        position: fixed;
        inset: 0;
        z-index: 5200;
        display: grid;
        place-items: center;
    }

    .discount-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .discount-modal-card {
        position: relative;
        width: min(720px, calc(100vw - 22px));
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(239, 246, 255, 0.92) 0%, rgba(255, 255, 255, 1) 55%);
        border: 1px solid rgba(29, 78, 216, 0.18);
        box-shadow: 0 30px 90px rgba(2, 6, 23, 0.32);
        padding: 18px 18px 16px;
        overflow: hidden;
    }

    .discount-modal-close {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.35);
        background: rgba(255, 255, 255, 0.95);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .discount-modal-kicker {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(29, 78, 216, 0.10);
        border: 1px solid rgba(29, 78, 216, 0.14);
        color: #1d4ed8;
        font-size: 0.74rem;
        font-weight: 900;
        letter-spacing: 0.03em;
        margin-bottom: 10px;
    }

    .discount-modal-head h3 {
        margin: 0 0 6px;
        font-size: 1.55rem;
        letter-spacing: -0.01em;
        color: #0f172a;
    }

    .discount-modal-head p {
        margin: 0;
        color: #475569;
        line-height: 1.6;
        font-weight: 600;
    }

    .discount-modal-visual {
        margin-top: 14px;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: #fff;
    }

    .discount-modal-visual img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }
</style>

<script>
    (function () {
        const modal = document.getElementById('discountModal');
        const title = document.getElementById('discountModalTitle');
        const desc = document.getElementById('discountModalDesc');
        const visual = document.getElementById('discountModalVisual');
        const image = document.getElementById('discountModalImage');
        if (!modal || !title || !desc || !visual || !image) return;

        function openDiscount(data) {
            title.textContent = data.title || 'İndirim';
            desc.textContent = data.desc || '';
            const img = (data.image || '').trim();
            if (img) {
                image.src = img;
                visual.hidden = false;
            } else {
                image.src = '';
                visual.hidden = true;
            }
            modal.hidden = false;
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeDiscount() {
            modal.hidden = true;
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        document.addEventListener('click', function (event) {
            const btn = event.target.closest('[data-discount-open]');
            if (btn) {
                event.preventDefault();
                openDiscount({
                    title: btn.getAttribute('data-discount-title') || '',
                    desc: btn.getAttribute('data-discount-desc') || '',
                    image: btn.getAttribute('data-discount-image') || ''
                });
                return;
            }

            if (event.target.closest('[data-discount-close]')) {
                closeDiscount();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && !modal.hidden) {
                closeDiscount();
            }
        });
    })();
</script>

