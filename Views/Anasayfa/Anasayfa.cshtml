@model otelturizmnew.Models.Anasayfa.AnasayfaViewModel
@inject otelturizmnew.Services.Abstractions.IDevelopmentAccessService DevelopmentAccessService
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@{
    Layout = null;
    ViewData["Title"] ??= "Anasayfa";
    var nonce = Context.Items["CspNonce"] as string;
    var cfg = Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration;
    var publicBaseUrl = cfg?["App:PublicBaseUrl"]?.TrimEnd('/') ?? $"{Context.Request.Scheme}://{Context.Request.Host}";
    var metaDesc = ViewData["MetaDescription"] as string ?? "Otelturizm ile otelleri karşılaştırın, kampanyaları keşfedin ve güvenle rezervasyon oluşturun.";
    var canonical = ViewData["Canonical"] as string ?? $"{publicBaseUrl}/";
    var ogImage = ViewData["OgImage"] as string ?? $"{publicBaseUrl}/uploads/logo/logo.png";
    var pageTitle = ViewData["Title"] as string ?? "Anasayfa";
    var jsonLd = ViewData["HomeJsonLd"] as string;
    var hostEnv = Context.RequestServices.GetService(typeof(IWebHostEnvironment)) as IWebHostEnvironment;
    var requestHost = Context.Request.Host.Host ?? string.Empty;
    var isLoopbackHost = string.Equals(requestHost, "localhost", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestHost, "127.0.0.1", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestHost, "::1", StringComparison.OrdinalIgnoreCase)
        || requestHost.EndsWith(".localhost", StringComparison.OrdinalIgnoreCase);
    var isLocalDevelopment = hostEnv?.IsDevelopment() == true || isLoopbackHost;
    var developmentGateEnabled = cfg?.GetValue("DevelopmentGate:Enabled", false) == true;
    var isDevelopmentUnlocked = !developmentGateEnabled
        || isLocalDevelopment
        || DevelopmentAccessService.TryGetAccessExpiration(Context, out var developmentAccessExpiresAt);
    var showPopupMesaj = User.Identity?.IsAuthenticated != true;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="description" content="@metaDesc" />
    <link rel="canonical" href="@canonical" />
    <meta property="og:site_name" content="Otelturizm" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@metaDesc" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@ogImage" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@metaDesc" />
    <meta name="twitter:image" content="@ogImage" />
    @if (!string.IsNullOrWhiteSpace(jsonLd))
    {
        <script type="application/ld+json" nonce="@nonce">@Html.Raw(jsonLd)</script>
    }
    <title>@pageTitle - Otelturizm</title>
    <partial name="~/Views/Shared/_VendorPlusJakartaFont.cshtml" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" asp-append-version="true" />
    @if (developmentGateEnabled)
    {
        <link rel="stylesheet" href="~/assets/css/development-gate.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/development-gate.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/anasayfa_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/anasayfa_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/footer_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/footer_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/public-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/public-shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/route-picker-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/route-picker-modal.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/dawn-surprise-box.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/popupmesaj.css" asp-append-version="true" />
</head>
<body class="@(isDevelopmentUnlocked ? "development-unlocked anasayfa-page" : "development-locked anasayfa-page")">
    @if (developmentGateEnabled)
    {
        <partial name="~/Views/Shared/_DevelopmentGateOverlay.cshtml" model="isDevelopmentUnlocked" />
    }
    <partial name="~/Views/Anasayfa/_AnasayfaPremiumHeader.cshtml" />
    <partial name="~/Views/Anasayfa/_AnasayfaContent.cshtml" model="Model" />
    <partial name="~/Views/Anasayfa/_AnasayfaPremiumFooter.cshtml" />
    <partial name="~/Views/Shared/_RoutePickerModal.cshtml" />
    @if (showPopupMesaj)
    {
        <partial name="~/Views/Shared/_PopupMesaj.cshtml" />
    }
    <partial name="~/Views/Shared/_FavoriteToggleScriptPartial.cshtml" />
    <script nonce="@nonce">
        (() => {
            const btn = document.getElementById('homeMenuToggle');
            const closeBtn = document.getElementById('homeDrawerClose');
            const drawer = document.getElementById('homeDrawerMenu');
            const overlay = document.getElementById('homeDrawerOverlay');
            if (!btn || !closeBtn || !drawer || !overlay) return;
            const open = () => { drawer.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; };
            const close = () => { drawer.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; };
            btn.addEventListener('click', open);
            closeBtn.addEventListener('click', close);
            overlay.addEventListener('click', close);
            drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', close));
        })();
    </script>
    <script nonce="@nonce">
        (() => {
            const input = document.querySelector('[data-rotating-placeholder]');
            if (!input) return;
            const samples = [
                "İstanbul'da hafta sonu oteli ara",
                "Kadıköy, Beşiktaş veya Taksim otelleri",
                "Aile oteli, kahvaltı dahil",
                "Bütçeme uygun şehir oteli",
                "Antalya denize yakın oteller"
            ];
            let index = 0;
            window.setInterval(() => {
                if (document.activeElement === input || input.value.trim()) return;
                index = (index + 1) % samples.length;
                input.setAttribute('placeholder', samples[index]);
            }, 2200);
        })();
    </script>
    <script src="~/assets/js/route-picker-modal.js" asp-append-version="true"></script>
    <script src="~/assets/js/home-drawer-prefs.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/home-header-prefs.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/utility-pulse-bar.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/home-search-dates.js" asp-append-version="true"></script>
    <script src="~/assets/js/home-search-tags.js" asp-append-version="true"></script>
    <script src="~/assets/js/home-radar-live.js" asp-append-version="true"></script>
    <script src="~/assets/js/home-dest-ticker.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/home-ai-route.js" asp-append-version="true"></script>
    <script src="~/assets/js/dawn-surprise-box.js" asp-append-version="true" defer></script>
    @if (showPopupMesaj)
    {
        <script src="~/assets/js/popupmesaj.js" asp-append-version="true" defer></script>
    }
</body>
</html>
