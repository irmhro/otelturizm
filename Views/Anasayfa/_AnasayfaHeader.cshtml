                <span>
                    <i class="fas fa-headset"></i>
                    7/24 Destek
                    <span class="support-contact">
                        <i class="fas fa-envelope"></i>
                        <a href="mailto:destek@otelturizm.com">destek@otelturizm.com</a>
                    </span>
                </span>
                <span><i class="fas fa-tag"></i> En Iyi Fiyat</span>
            </div>
            <div class="utility-right">
                <div class="dropdown language-dropdown" id="languageDropdown">
                    <button type="button" class="dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                        <span class="toggle-flag flag-icon flag-icon-tr" aria-hidden="true"></span>
                        <span class="dropdown-label">TR</span>
                    </button>
                    <ul class="dropdown-menu" role="menu">
                        <li class="dropdown-item" data-value="tr"><span class="flag-icon flag-icon-tr"></span> Türkçe</li>
                        <li class="dropdown-item" data-value="en"><span class="flag-icon flag-icon-gb"></span> English</li>
                        <li class="dropdown-item" data-value="fr"><span class="flag-icon flag-icon-fr"></span> Français</li>
                        <li class="dropdown-item" data-value="ru"><span class="flag-icon flag-icon-ru"></span> Русский</li>
                        <li class="dropdown-item" data-value="ar"><span class="flag-icon flag-icon-sa"></span> العربية</li>
                    </ul>
                </div>

                <!-- currency selector removed -->
            </div>
        </div>
    </div>

    <div class="header-container">
        <div class="logo-area">
            <a asp-controller="Home" asp-action="Index" class="logo logo-image-only" aria-label="Otelturizm Anasayfa">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="brand-logo-image" />
            </a>

            <nav class="desktop-nav"><!-- desktop nav removed; primary link moved to header actions -->
            </nav>
        </div>

        <div class="search-wrapper">
            <form class="search-container public-header-search-form" method="get" action="/oteller" autocomplete="off">
                <input type="text" class="search-input" id="publicHeaderSearchInput" name="q" placeholder="Otel adı, il, ilçe, mahalle veya bölge ara">
                <button type="submit" class="search-btn header-search-btn" aria-label="Ara">
                    <i class="fas fa-search"></i>
                </button>
                <div class="header-search-suggestions" id="publicHeaderSearchSuggestions" hidden></div>
            </form>
        </div>

        <div class="header-actions">
            <a asp-controller="Oteller" asp-action="Index" class="action-btn">Oteller</a>
            <a asp-controller="Home" asp-action="Kurumsal" class="action-btn primary">Kurumsal</a>
            <partial name="~/Views/Shared/_PublicHeaderUserActions.cshtml" />
            <button class="action-btn mobile-nav-toggle" id="mobileMenuToggle" type="button"><i class="fas fa-bars"></i></button>
        </div>
    </div>

    <div class="home-header-quick-links" aria-label="Öne çıkan bağlantılar">
