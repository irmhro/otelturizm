@model otelturizmnew.Models.Anasayfa.HomeHotelCardViewModel

@{
    var priceNote = (Model.PriceNote ?? string.Empty)
        .Replace("KDV dahil", "Vergiler dahil", StringComparison.OrdinalIgnoreCase)
        .Replace("Kdv dahil", "Vergiler dahil", StringComparison.OrdinalIgnoreCase)
        .Replace("GÜNLÜK - ", string.Empty, StringComparison.OrdinalIgnoreCase)
        .Replace("Gunluk - ", string.Empty, StringComparison.OrdinalIgnoreCase)
        .Replace("Günlük - ", string.Empty, StringComparison.OrdinalIgnoreCase)
        .Trim();

    if (string.IsNullOrWhiteSpace(priceNote))
    {
        priceNote = "Vergiler dahil";
    }
}

<article class="home-hotel-card">
    <a asp-controller="Oteller" asp-action="OtelDetay" asp-route-slug="@Model.DetailSlug" class="home-hotel-card-link">
        <div class="card-image-shell">
            @{
                var gallery = (Model.GalleryImageUrls ?? new List<string>())
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Take(4)
                    .ToList();

                if (gallery.Count == 0 && !string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    gallery.Add(Model.ImageUrl);
                }
            }

            <div class="card-image-grid" aria-label="Otel görselleri">
                @if (gallery.Count == 0)
                {
                    <div class="card-image-fallback"></div>
                }
                else
                {
                    // Always render 4 slots (repeat last image if fewer)
                    for (var i = 0; i < 4; i++)
                    {
                        var src = gallery[Math.Min(i, gallery.Count - 1)];
                        <span class="card-image-tile">
                            <img src="@src" alt="@Model.Name" loading="lazy" decoding="async" />
                        </span>
                    }
                }
            </div>

            @if (Model.StarCount.HasValue && Model.StarCount.Value > 0)
            {
                <span class="card-star-badge" aria-label="@($"{Model.StarCount.Value} yıldızlı otel")">
                    @for (var i = 0; i < Model.StarCount.Value; i++)
                    {
                        <i class="fas fa-star" aria-hidden="true"></i>
                    }
                </span>
            }

            <button class="favorite-btn @(Model.IsFavorite ? "active" : string.Empty)" type="button" data-hotel-id="@Model.Id" data-source-page="Anasayfa" aria-label="Favorilere ekle">
                <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
            </button>
        </div>

        <div class="card-content">
            <div class="hotel-name-row">
                <h3 class="hotel-name hotel-name-inline-title">
                    @Model.Name
                </h3>
            </div>

            <div class="hotel-location">
                <i class="fas fa-map-pin"></i>
                <span>@Model.LocationText</span>
                @if (!string.IsNullOrWhiteSpace(Model.Temperature) || !string.IsNullOrWhiteSpace(Model.WeatherIcon))
                {
                    <span class="hotel-weather">
                        <i class="fas @Model.WeatherIcon" aria-hidden="true"></i>
                        <span class="hotel-temp">@Model.Temperature</span>
                    </span>
                }
            </div>

            @{
                var recentCampaigns = Model.RecentCampaigns ?? new List<string>();
                var recentDiscounts = Model.RecentDiscounts ?? new List<string>();
            }

            @if (recentCampaigns.Count > 0 || recentDiscounts.Count > 0)
            {
                <div class="home-hotel-promo">
                    @if (recentCampaigns.Count > 0)
                    {
                        foreach (var item in recentCampaigns.Take(2))
                        {
                            <span class="promo-pill promo-pill--campaign">
                                <i class="fas fa-bullhorn" aria-hidden="true"></i>
                                @item
                            </span>
                        }
                    }
                    @if (recentDiscounts.Count > 0)
                    {
                        foreach (var item in recentDiscounts.Take(2))
                        {
                            <span class="promo-pill promo-pill--discount">
                                <i class="fas fa-tags" aria-hidden="true"></i>
                                @item
                            </span>
                        }
                    }
                </div>
            }

            <div class="home-hotel-tags">
                @foreach (var tag in Model.Tags)
                {
                    if (string.Equals(tag, "Öne Çıkan", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(tag, "One Cikan", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(tag, "Hafta Sonu Seçimi", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(tag, "Hafta Sonu Secimi", StringComparison.OrdinalIgnoreCase))
                    {
                        continue;
                    }
                    <span>@tag</span>
                }
            </div>

            <div class="amenities">
                @foreach (var amenity in Model.Amenities)
                {
                    <span><i class="fas @amenity.IconClass"></i> @amenity.Label</span>
                }
            </div>

            <div class="home-hotel-price-row">
                <div class="price-box">
                    @if (Model.HasDiscount && Model.OriginalPrice.HasValue && Model.DiscountedPrice.HasValue)
                    {
                        <span class="price-original">Normal Fiyat: <s>TRY @Model.OriginalPrice.Value.ToString("N0")</s></span>
                        <span class="price-discount-label">
                            İndirim: %@Model.DiscountPercent
                            @if (Model.DiscountId.HasValue && !string.IsNullOrWhiteSpace(Model.DiscountName))
                            {
                                <button type="button"
                                        class="discount-info-btn"
                                        data-discount-open
                                        data-discount-title="@Model.DiscountName"
                                        data-discount-desc="@Model.DiscountShortDescription"
                                        data-discount-image="@Model.DiscountImageUrl"
                                        aria-label="İndirim detayını görüntüle">
                                    <i class="fas fa-circle-info" aria-hidden="true"></i>
                                </button>
                            }
                        </span>
                        <span class="price-value discounted">İndirimli Fiyatı: TRY @Model.DiscountedPrice.Value.ToString("N0")</span>
                    }
                    else
                    {
                        <span class="price-from">Başlayan fiyatlarla</span>
                        <span class="price-value">@Model.PriceText</span>
                    }
                    <span class="price-note">@priceNote</span>
                </div>
            </div>
        </div>
    </a>
</article>

