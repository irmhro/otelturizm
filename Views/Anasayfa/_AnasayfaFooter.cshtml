@using otelturizmnew.Services
@{
    // Path-based listing links; SharedLocalizer uses fixed Resources lookup (no ResourcesPath prefix).
    var footerLang = InternationalSeoPaths.ResolveCultureFromPath(Context.Request.Path.Value ?? "/");
    var footerHotelsPath = InternationalSeoPaths.BuildPublicPath(footerLang, InternationalSeoPaths.PageKindListing, null, null);
}
<footer class="site-footer">
    <div class="footer-pattern"></div>
    <div class="footer-container">
        <div class="footer-grid">
            <div class="footer-col">
                <div class="footer-logo">
                    <img src="~/uploads/logo/altlogo.png" alt="Otelturizm" class="footer-logo-image" />
                </div>
                <p class="footer-description">Türkiye genelinde güvenli bağlantı ile otel arayıp rezervasyon oluşturabileceğiniz platform; özet ve iptal koşullarını hesabınızdan takip edebilirsiniz.</p>
                <div class="footer-social">
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="Instagram iletişim"><i class="fab fa-instagram"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="Facebook iletişim"><i class="fab fa-facebook-f"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="X iletişim"><i class="fab fa-x-twitter"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="YouTube iletişim"><i class="fab fa-youtube"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4 class="footer-title">@SharedLocalizer["Footer.Company"]</h4>
                <ul class="footer-links">
                    <li><a href="/yardim-merkezi/sayfa/about/hakkimizda"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.About"]</a></li>
                    <li><a href="/yardim-merkezi/sayfa/career/kariyer"><i class="fas fa-chevron-right"></i> Kariyer</a></li>
                    <li><a href="/yardim-merkezi/sayfa/press/basin-odasi"><i class="fas fa-chevron-right"></i> Basın Odası</a></li>
                    <li><a href="/yardim-merkezi/sayfa/blog/blog"><i class="fas fa-chevron-right"></i> Blog</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4 class="footer-title">@SharedLocalizer["Footer.Explore"]</h4>
                <ul class="footer-links">
                    <li><a href="@footerHotelsPath"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Hotels"]</a></li>
                    <li><a href="/kampanyalar"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Campaigns"]</a></li>
                    <li><a href="/kampanyalar"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.EarlyBooking"]</a></li>
                    <li><a href="/firma"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.BusinessTravel"]</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4 class="footer-title">Otelciler İçin</h4>
                <ul class="footer-links">
                    <li><a href="/partner-giris"><i class="fas fa-chevron-right"></i> Extranet Girişi</a></li>
                    <li><a href="/kurumsal"><i class="fas fa-chevron-right"></i> Partner Programı</a></li>
                    <li><a href="/kurumsal"><i class="fas fa-chevron-right"></i> Komisyon Oranları</a></li>
                    <li><a href="/yardim-merkezi"><i class="fas fa-chevron-right"></i> Eğitim ve Destek</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4 class="footer-title">@SharedLocalizer["Footer.Support"]</h4>
                <ul class="footer-links">
                    <li><a href="/yardim-merkezi"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Help"]</a></li>
                    <li><a href="/sss?kategori=iptal-iade"><i class="fas fa-chevron-right"></i> İptal ve İade</a></li>
                    <li><a href="/sss"><i class="fas fa-chevron-right"></i> SSS</a></li>
                    <li><a href="/yardim-merkezi#destek-kanallari"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Contact"]</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-top">
                <div class="footer-copyright">&copy; @DateTime.Now.Year Otelturizm. @SharedLocalizer["Footer.Copyright"]</div>
                <div class="footer-agency-wrap">
                    <div class="trust-badges" role="group" aria-label="Güven taahhütleri">
                        <a class="trust-badge" href="/" title="HTTPS güvenliği"><i class="fas fa-lock" aria-hidden="true"></i> @SharedLocalizer["Footer.Https"]</a>
                        <a class="trust-badge" href="/panel/user/rezervasyonlarim" title="Rezervasyon özetine git"><i class="fas fa-user-check" aria-hidden="true"></i> @SharedLocalizer["Footer.ReservationSummary"]</a>
                        <a class="trust-badge" href="/sozlesmeler/kullanici-kvkk-aydinlatma" title="KVKK aydınlatma metni"><i class="fas fa-scale-balanced" aria-hidden="true"></i> @SharedLocalizer["Footer.KvkkProcessing"]</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom-links">
                <a asp-controller="Home" asp-action="Privacy">@SharedLocalizer["Footer.Privacy"]</a>
                <a href="/sozlesmeler/kullanici-kullanim-kosullari">@SharedLocalizer["Footer.Terms"]</a>
                <a href="/sozlesmeler/kullanici-kvkk-aydinlatma">@SharedLocalizer["Footer.Kvkk"]</a>
            </div>
        </div>
    </div>
</footer>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        try {
            const storageKey = 'otelturizm.sitemap.refresh.lastPing';
            const refreshIntervalMs = 3 * 24 * 60 * 60 * 1000;
            const now = Date.now();
            const lastPing = Number(localStorage.getItem(storageKey) || '0');

            if ((now - lastPing) < refreshIntervalMs) {
                return;
            }

            fetch('/seo/sitemap-refresh', {
                method: 'GET',
                credentials: 'same-origin',
                cache: 'no-store',
                keepalive: true,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                if (response && response.ok) {
                    localStorage.setItem(storageKey, String(now));
                }
            }).catch(function () {
                // sessiz
            });
        } catch (_) {
            // sessiz
        }
    })();
</script>

<script src="~/assets/js/konum-kordinat.js" asp-append-version="true"></script>


