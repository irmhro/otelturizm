@using otelturizmnew.Services
@{
    var footerLang = InternationalSeoPaths.ResolveCultureFromPath(Context.Request.Path.Value ?? "/");
    var footerHotelsPath = InternationalSeoPaths.BuildPublicPath(footerLang, InternationalSeoPaths.PageKindListing, null, null);
    var footerIsTurkish = string.Equals(footerLang, "tr", StringComparison.OrdinalIgnoreCase);
    var footerDescription = footerIsTurkish
        ? "Türkiye genelinde güvenli bağlantı ile otel arayıp rezervasyon oluşturabileceğiniz platform; özet ve iptal koşullarını hesabınızdan takip edebilirsiniz."
        : SharedLocalizer["Footer.Description"].Value;
}
<footer class="site-footer">
    <div class="footer-pattern"></div>
    <div class="footer-container">
        <div class="footer-grid">
            <div class="footer-col">
                <div class="footer-logo">
                    <img src="~/uploads/logo/altlogo.png" alt="Otelturizm" class="footer-logo-image" />
                </div>
                <p class="footer-description">@footerDescription</p>
                <div class="footer-social">
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="X"><i class="fab fa-x-twitter"></i></a>
                    <a href="/yardim-merkezi#destek-kanallari" class="social-link" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                </div>
            </div>

            <div class="footer-col footer-col--accordion">
                <details class="footer-accordion" open>
                    <summary class="footer-title">@SharedLocalizer["Footer.Company"]</summary>
                    <ul class="footer-links">
                        <li><a href="/hakkimizda"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.About"]</a></li>
                        <li><a href="/kariyer"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Career"]</a></li>
                        <li><a href="/basin-odasi"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Press"]</a></li>
                        <li><a href="/blog"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Blog"]</a></li>
                    </ul>
                </details>
            </div>

            <div class="footer-col footer-col--accordion">
                <details class="footer-accordion" open>
                    <summary class="footer-title">@SharedLocalizer["Footer.Explore"]</summary>
                    <ul class="footer-links">
                        <li><a href="@footerHotelsPath"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Hotels"]</a></li>
                        <li><a href="/kampanyalar"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Campaigns"]</a></li>
                        <li><a href="/kampanyalar"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.EarlyBooking"]</a></li>
                        <li><a href="/firma"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.BusinessTravel"]</a></li>
                    </ul>
                </details>
            </div>

            <div class="footer-col footer-col--accordion">
                <details class="footer-accordion" open>
                    <summary class="footer-title">@SharedLocalizer["Footer.ForHotels"]</summary>
                    <ul class="footer-links">
                        <li><a href="/partner-giris"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.ExtranetLogin"]</a></li>
                        <li><a href="/kurumsal"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.PartnerProgram"]</a></li>
                        <li><a href="/kurumsal"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.CommissionRates"]</a></li>
                        <li><a href="/yardim-merkezi"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.TrainingSupport"]</a></li>
                    </ul>
                </details>
            </div>

            <div class="footer-col footer-col--accordion">
                <details class="footer-accordion" open>
                    <summary class="footer-title">@SharedLocalizer["Footer.Support"]</summary>
                    <ul class="footer-links">
                        <li><a href="/yardim-merkezi"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Nav.Help"]</a></li>
                        <li><a href="/sss?kategori=iptal-iade"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.CancelRefund"]</a></li>
                        <li><a href="/sss"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Faq"]</a></li>
                        <li><a href="/yardim-merkezi#destek-kanallari"><i class="fas fa-chevron-right"></i> @SharedLocalizer["Footer.Contact"]</a></li>
                    </ul>
                </details>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-top">
                <div class="footer-copyright">&copy; @DateTime.Now.Year Otelturizm. @SharedLocalizer["Footer.Copyright"]</div>
                <div class="footer-agency-wrap">
                    <div class="trust-badges" role="group" aria-label="@SharedLocalizer["Footer.TrustCommitments"].Value">
                        <a class="trust-badge" href="/" title="HTTPS"><i class="fas fa-lock" aria-hidden="true"></i> @SharedLocalizer["Footer.Https"].Value</a>
                        <a class="trust-badge" href="/panel/user/rezervasyonlarim" title="@SharedLocalizer["Footer.ReservationSummary"].Value"><i class="fas fa-user-check" aria-hidden="true"></i> @SharedLocalizer["Footer.ReservationSummary"].Value</a>
                        <a class="trust-badge" href="/sozlesmeler/kullanici-kvkk-aydinlatma" title="@SharedLocalizer["Footer.Kvkk"].Value"><i class="fas fa-scale-balanced" aria-hidden="true"></i> @SharedLocalizer["Footer.KvkkProcessing"].Value</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom-links">
                <a asp-controller="Home" asp-action="Privacy">@SharedLocalizer["Footer.Privacy"]</a>
                <a href="/sozlesmeler/kullanici-kullanim-kosullari">@SharedLocalizer["Footer.Terms"]</a>
                <a href="/sozlesmeler/kullanici-kvkk-aydinlatma">@SharedLocalizer["Footer.Kvkk"]</a>
            </div>
        </div>
    </div>
</footer>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        try {
            const storageKey = 'otelturizm.sitemap.refresh.lastPing';
            const refreshIntervalMs = 3 * 24 * 60 * 60 * 1000;
            const now = Date.now();
            const lastPing = Number(localStorage.getItem(storageKey) || '0');

            if ((now - lastPing) < refreshIntervalMs) {
                return;
            }

            fetch('/seo/sitemap-refresh', {
                method: 'GET',
                credentials: 'same-origin',
                cache: 'no-store',
                keepalive: true,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            }).then(function (response) {
                if (response && response.ok) {
                    localStorage.setItem(storageKey, String(now));
                }
            }).catch(function () {
            });
        } catch (_) {
        }
    })();
</script>

<script src="~/assets/js/konum-kordinat.js" asp-append-version="true"></script>
