<div class="contract-popup" id="contractPopup" hidden>
    <div class="contract-popup__backdrop" data-contract-popup-close></div>
    <section class="contract-popup__panel" role="dialog" aria-modal="true" aria-labelledby="contractPopupTitle">
        <header class="contract-popup__head">
            <div>
                <p class="contract-popup__kicker">Sozlesme Onizleme</p>
                <h3 id="contractPopupTitle">Sozlesme Detayi</h3>
            </div>
            <button type="button" class="contract-popup__close" data-contract-popup-close aria-label="Kapat">
                <i class="fas fa-times"></i>
            </button>
        </header>
        <div class="contract-popup__frame-wrap">
            <iframe id="contractPopupFrame" title="Sozlesme icerigi" loading="lazy"></iframe>
        </div>
    </section>
</div>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        if (window.otelturizmContractPopupInitDone) {
            return;
        }
        window.otelturizmContractPopupInitDone = true;

        const popup = document.getElementById('contractPopup');
        const frame = document.getElementById('contractPopupFrame');
        const title = document.getElementById('contractPopupTitle');
        if (!popup || !frame || !title) {
            return;
        }

        function openPopup(url, heading) {
            frame.src = url;
            title.textContent = heading || 'Sozlesme Detayi';
            popup.hidden = false;
            document.body.classList.add('contract-popup-open');
        }

        function closePopup() {
            popup.hidden = true;
            frame.src = '';
            document.body.classList.remove('contract-popup-open');
        }

        document.addEventListener('click', function (event) {
            const link = event.target.closest('a[data-contract-popup]');
            if (link) {
                event.preventDefault();
                openPopup(link.getAttribute('href') || '/', link.getAttribute('data-contract-title') || link.textContent.trim());
                return;
            }

            if (event.target.closest('[data-contract-popup-close]')) {
                closePopup();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && !popup.hidden) {
                closePopup();
            }
        });
    })();
</script>

<style>
    .contract-popup-open {
        overflow: hidden;
    }

    .contract-popup {
        position: fixed;
        inset: 0;
        z-index: 4200;
        display: grid;
        place-items: center;
    }

    .contract-popup__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.52);
        backdrop-filter: blur(6px);
    }

    .contract-popup__panel {
        position: relative;
        width: min(980px, calc(100vw - 28px));
        max-height: min(86vh, 860px);
        background: #fff;
        border-radius: 22px;
        border: 1px solid rgba(0, 59, 149, 0.14);
        box-shadow: 0 28px 60px rgba(15, 23, 42, 0.28);
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        overflow: hidden;
    }

    .contract-popup__head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid #e2e8f0;
        background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    }

    .contract-popup__kicker {
        margin: 0 0 4px;
        font-size: .74rem;
        font-weight: 800;
        color: #1d4ed8;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .contract-popup__head h3 {
        margin: 0;
        font-size: clamp(1.1rem, 2vw, 1.45rem);
        letter-spacing: -0.01em;
        color: #0f172a;
    }

    .contract-popup__close {
        width: 38px;
        height: 38px;
        border: 1px solid #dbe4f0;
        border-radius: 999px;
        background: #fff;
        color: #334155;
        cursor: pointer;
    }

    .contract-popup__frame-wrap {
        min-height: 0;
        background: #fff;
    }

    .contract-popup__frame-wrap iframe {
        width: 100%;
        height: 100%;
        min-height: 56vh;
        border: 0;
        background: #fff;
    }

    @@media (max-width: 760px) {
        .contract-popup__panel {
            width: min(100vw, calc(100vw - 10px));
            max-height: 92vh;
            border-radius: 18px;
        }

        .contract-popup__head {
            padding: 12px;
        }

        .contract-popup__close {
            width: 34px;
            height: 34px;
        }
    }
</style>
