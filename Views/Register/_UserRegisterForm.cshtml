<div class="auth-form-hint"><i class="fas fa-user-plus"></i> e-posta ile kayıt olun</div>

@if (TempData["UserRegisterError"] is string registerError)
{
    <div class="auth-alert">@registerError</div>
}

<form class="auth-form" id="userRegisterForm" method="post" asp-controller="Register" asp-action="UserKayit">
    @Html.AntiForgeryToken()
    <div class="double-field">
        <div class="form-group">
            <label for="firstName">Ad</label>
            <input id="firstName" name="firstName" type="text" class="form-control" placeholder="Adınız" autocomplete="given-name" required />
        </div>
        <div class="form-group">
            <label for="lastName">Soyad</label>
            <input id="lastName" name="lastName" type="text" class="form-control" placeholder="Soyadınız" autocomplete="family-name" required />
        </div>
    </div>
    <div class="form-group">
        <label for="registerEmail">E-posta</label>
        <input id="registerEmail" name="email" type="email" class="form-control" placeholder="ornek@email.com" autocomplete="email" required />
    </div>
    <div class="form-group">
        <label for="phoneNumber">Telefon</label>
        <input id="phoneNumber" name="phoneNumber" type="tel" inputmode="tel" pattern="[0-9\s()+-]+" class="form-control" placeholder="5XX XXX XX XX" autocomplete="tel" />
    </div>
    <div class="double-field">
        <div class="form-group">
            <label for="registerPassword">Şifre</label>
            <div class="input-wrap password-wrapper">
                <input id="registerPassword" name="password" type="password" class="form-control" placeholder="En az 6 karakter" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." autocomplete="new-password" required />
                <button type="button" class="toggle-password" data-toggle-target="registerPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
            </div>
        </div>
        <div class="form-group">
            <label for="confirmPassword">Şifre Tekrar</label>
            <div class="input-wrap password-wrapper">
                <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" placeholder="Tekrar girin" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" autocomplete="new-password" required />
                <button type="button" class="toggle-password" data-toggle-target="confirmPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
            </div>
        </div>
    </div>
    <label class="checkbox-stack">
        <input type="checkbox" name="acceptTerms" value="true" required />
        <span><a href="/sozlesmeler/kullanici-kullanim-kosullari" target="_blank" rel="noopener noreferrer">Kullanım Koşulları</a> sözleşmesini kabul ediyorum.</span>
    </label>
    <label class="checkbox-stack">
        <input type="checkbox" name="acceptKvkk" value="true" required />
        <span><a href="/sozlesmeler/kullanici-kvkk-aydinlatma" target="_blank" rel="noopener noreferrer">KVKK Aydınlatma Metni</a> kapsamında verilerimin işlenmesini onaylıyorum.</span>
    </label>
    <label class="checkbox-stack">
        <input type="checkbox" name="acceptMarketing" value="true" checked />
        <span>Fırsat ve kampanya e-postaları almak istiyorum.</span>
    </label>
    <button type="submit" class="auth-submit-btn">Kayıt Ol ve Keşfet <i class="fas fa-arrow-right"></i></button>
</form>
<p class="auth-helper">Zaten üye misin? <button type="button" class="text-button" data-switch-tab="loginPanel">Giriş yap</button></p>
