<div class="divider-line"><span>e-posta ile kayıt olun</span></div>

@if (TempData["UserRegisterError"] is string registerError)
{
    <div class="auth-alert">@registerError</div>
}

<form class="auth-form" id="userRegisterForm" method="post" asp-controller="Register" asp-action="UserKayit">
    @Html.AntiForgeryToken()
    <div class="double-field">
        <div class="form-group">
            <label for="firstName">Ad</label>
            <div class="input-wrap">
                <i class="far fa-user"></i>
                <input id="firstName" name="firstName" type="text" class="form-control" placeholder="Adınız" autocomplete="given-name" required />
            </div>
        </div>

        <div class="form-group">
            <label for="lastName">Soyad</label>
            <div class="input-wrap">
                <i class="far fa-user"></i>
                <input id="lastName" name="lastName" type="text" class="form-control" placeholder="Soyadınız" autocomplete="family-name" required />
            </div>
        </div>
    </div>

    <div class="form-group">
        <label for="registerEmail">E-posta</label>
        <div class="input-wrap">
            <i class="far fa-envelope"></i>
            <input id="registerEmail" name="email" type="email" class="form-control" placeholder="ornek@email.com" autocomplete="email" required />
        </div>
    </div>

    <div class="form-group">
        <label for="phoneNumber">Telefon</label>
        <div class="input-wrap">
            <i class="fas fa-phone-alt"></i>
            <input id="phoneNumber" name="phoneNumber" type="tel" inputmode="tel" pattern="[0-9\s()+-]+" class="form-control" placeholder="5XX XXX XX XX" autocomplete="tel" />
        </div>
    </div>

    <div class="form-group">
        <label for="registerPassword">Şifre</label>
            <div class="input-wrap">
            <i class="fas fa-lock"></i>
            <input id="registerPassword" name="password" type="password" class="form-control" placeholder="En az 6 karakter (harf + rakam)" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." autocomplete="new-password" required />
            <button type="button" class="toggle-password" data-toggle-target="registerPassword">
                <i class="far fa-eye"></i>
            </button>
        </div>
    </div>

    <div class="form-group">
        <label for="confirmPassword">Şifre Tekrar</label>
            <div class="input-wrap">
            <i class="fas fa-lock"></i>
            <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" placeholder="Şifrenizi tekrar girin" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." autocomplete="new-password" required />
            <button type="button" class="toggle-password" data-toggle-target="confirmPassword">
                <i class="far fa-eye"></i>
            </button>
        </div>
    </div>

    <label class="checkbox-stack">
        <input type="checkbox" name="acceptTerms" value="true" required />
        <span>Kullanım Koşulları ve Gizlilik Politikasıni kabul ediyorum.</span>
    </label>

    <label class="checkbox-stack">
        <input type="checkbox" name="acceptMarketing" value="true" checked />
        <span>Fırsat ve kampanya e-postalari almak istiyorum.</span>
    </label>

    <button type="submit" class="auth-submit-btn">Kayıt Ol ve Keşfet <i class="fas fa-arrow-right"></i></button>
</form>

<p class="auth-helper">Zaten uye misin? <button type="button" class="text-button" data-switch-tab="loginPanel">Giriş yap</button></p>
