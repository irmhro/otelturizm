@model otelturizmnew.Models.Kampanyalar.CampaignListingPageViewModel

@{
    ViewData["Title"] = SharedLocalizer["Nav.Campaigns"].Value;
    ViewData["PageCss"] = "kampanyalar";
    ViewData["PageCssMobile"] = "kampanyalar.mobile";
    ViewData["IncludeFeWorldTokens"] = true;
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.PageDescription)
        ? SharedLocalizer["Campaign.Hero.Description"].Value
        : Model.PageDescription;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    ViewData["Canonical"] = $"{baseUrl}/kampanyalar";
    var timerEnd = new DateTime(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month), 23, 59, 59);
    var timerEndIso = timerEnd.ToString("yyyy-MM-ddTHH:mm:ss");
    try
    {
        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = SharedLocalizer["Nav.Campaigns"].Value, ["item"] = $"{baseUrl}/kampanyalar" }
            }
        };
        ViewData["JsonLd"] = System.Text.Json.JsonSerializer.Serialize(breadcrumbJsonLd);
    }
    catch { }
}

<section class="campaign-index-shell" aria-label="@SharedLocalizer["Nav.Campaigns"].Value">
    <div class="campaign-hero campaign-index-hero-v2">
        <div class="campaign-hero__content">
            <div class="campaign-hero__text">
                <span class="campaign-hero__badge"><i class="fas fa-tags" aria-hidden="true"></i> @SharedLocalizer["Nav.Campaigns"]</span>
                <h1>@SharedLocalizer["Campaign.Hero.Title"]</h1>
                <p>@SharedLocalizer["Campaign.Hero.Description"]</p>
            </div>
            <div class="campaign-hero__timer" aria-live="polite">
                <div class="campaign-hero__timer-label"><i class="far fa-clock" aria-hidden="true"></i> @SharedLocalizer["Campaign.Timer.Label"]</div>
                <div class="campaign-hero__timer-numbers" id="campaignIndexTimer" data-end="@timerEndIso">
                    <div class="campaign-hero__timer-block">
                        <div class="campaign-hero__timer-number" id="campaignTimerDays">--</div>
                        <div class="campaign-hero__timer-unit">@SharedLocalizer["Campaign.Timer.Days"]</div>
                    </div>
                    <div class="campaign-hero__timer-block">
                        <div class="campaign-hero__timer-number" id="campaignTimerHours">--</div>
                        <div class="campaign-hero__timer-unit">@SharedLocalizer["Campaign.Timer.Hours"]</div>
                    </div>
                    <div class="campaign-hero__timer-block">
                        <div class="campaign-hero__timer-number" id="campaignTimerMinutes">--</div>
                        <div class="campaign-hero__timer-unit">@SharedLocalizer["Campaign.Timer.Minutes"]</div>
                    </div>
                    <div class="campaign-hero__timer-block">
                        <div class="campaign-hero__timer-number" id="campaignTimerSeconds">--</div>
                        <div class="campaign-hero__timer-unit">@SharedLocalizer["Campaign.Timer.Seconds"]</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="campaign-index-stats" aria-label="@SharedLocalizer["Campaign.Stat.Active"].Value">
        <span class="campaign-stat-chip"><i class="fas fa-hotel" aria-hidden="true"></i> <strong>@Model.Campaigns.Count</strong> @SharedLocalizer["Campaign.Stat.Active"]</span>
        <a class="campaign-stat-chip campaign-stat-chip--link" href="/oteller?etiket=kampanyaya-dahil-oteller"><i class="fas fa-percent" aria-hidden="true"></i> @SharedLocalizer["Campaign.Stat.DiscountedHotels"]</a>
    </div>
</section>

<section class="campaign-index-grid">
    @if (Model.Campaigns.Count == 0)
    {
        <div class="campaign-empty-state">
            <strong>@SharedLocalizer["Campaign.Empty.Title"]</strong>
            <p>@SharedLocalizer["Campaign.Empty.Description"]</p>
        </div>
    }
    else
    {
        @foreach (var campaign in Model.Campaigns)
        {
            var listingUrl = $"/oteller?kampanya={Uri.EscapeDataString(campaign.Slug ?? string.Empty)}";
            <article class="campaign-card" style="--campaign-accent:@campaign.ColorCode;">
                <a class="campaign-card__tap" href="@listingUrl" aria-label="@campaign.CampaignName @SharedLocalizer["Campaign.ListHotels"].Value">
                    <div class="campaign-card__media @(string.IsNullOrWhiteSpace(campaign.HeroImageUrl) ? string.Empty : "has-image")">
                        @if (!string.IsNullOrWhiteSpace(campaign.HeroImageUrl))
                        {
                            <img src="@campaign.HeroImageUrl" alt="@campaign.CampaignName" loading="lazy" decoding="async" />
                        }
                        @if (!string.IsNullOrWhiteSpace(campaign.BadgeText))
                        {
                            <span class="campaign-card__badge">@campaign.BadgeText</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(campaign.PromoBadge))
                        {
                            <span class="campaign-card__promo">@campaign.PromoBadge</span>
                        }
                    </div>
                    <div class="campaign-card__body">
                        <h2>@campaign.CampaignName</h2>
                        <p>@campaign.ShortDescription</p>
                        <div class="campaign-card__meta">
                            <span><i class="fas fa-tag"></i> @campaign.CampaignType</span>
                        </div>
                        <span class="campaign-card__date"><i class="fas fa-calendar-check"></i> @campaign.EndDateText</span>
                        <span class="campaign-card__link">@SharedLocalizer["Campaign.ListHotels"].Value</span>
                    </div>
                </a>
                <div class="campaign-card__footer">
                    <a class="campaign-card__secondary" href="@campaign.Url" aria-label="@campaign.CampaignName @SharedLocalizer["Campaign.ViewDetail"].Value">
                        @SharedLocalizer["Campaign.ViewDetail"] <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </article>
        }
    }
</section>

@section Scripts {
<script nonce="@(Context.Items["CspNonce"])">
(function () {
    var root = document.getElementById('campaignIndexTimer');
    if (!root) return;
    var endRaw = root.getAttribute('data-end');
    var end = endRaw ? new Date(endRaw) : null;
    if (!end || isNaN(end.getTime())) return;
    function pad(n) { return String(n).padStart(2, '0'); }
    function tick() {
        var diff = Math.max(0, end.getTime() - Date.now());
        var totalSec = Math.floor(diff / 1000);
        var days = Math.floor(totalSec / 86400);
        var hours = Math.floor((totalSec % 86400) / 3600);
        var mins = Math.floor((totalSec % 3600) / 60);
        var secs = totalSec % 60;
        var d = document.getElementById('campaignTimerDays');
        var h = document.getElementById('campaignTimerHours');
        var m = document.getElementById('campaignTimerMinutes');
        var s = document.getElementById('campaignTimerSeconds');
        if (d) d.textContent = pad(days);
        if (h) h.textContent = pad(hours);
        if (m) m.textContent = pad(mins);
        if (s) s.textContent = pad(secs);
    }
    tick();
    setInterval(tick, 1000);
})();
</script>
}
