@model otelturizmnew.Models.Kampanyalar.CampaignListingPageViewModel
@using Microsoft.Extensions.Configuration
@{
    ViewData["Title"] = SharedLocalizer["Nav.Campaigns"].Value;
    ViewData["BodyClass"] = "kampanyalar-page anasayfa-page";
    ViewData["PageCss"] = "kampanyalar";
    ViewData["PageCssMobile"] = "kampanyalar";
    ViewData["IncludeAnasayfaStyles"] = true;
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.PageDescription)
        ? SharedLocalizer["Campaign.Hero.Description"].Value
        : Model.PageDescription;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    ViewData["Canonical"] = $"{baseUrl}/kampanyalar";
    try
    {
        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = SharedLocalizer["Nav.Campaigns"].Value, ["item"] = $"{baseUrl}/kampanyalar" }
            }
        };
        ViewData["JsonLd"] = System.Text.Json.JsonSerializer.Serialize(breadcrumbJsonLd);
    }
    catch { }
}

<partial name="~/Views/Kampanyalar/_KampanyalarContent.cshtml" model="Model" />

@section Scripts {
    <script src="~/assets/js/kampanyalar-filter.js" asp-append-version="true" defer></script>
}
