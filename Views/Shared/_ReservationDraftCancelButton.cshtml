@model otelturizmnew.Models.Reservations.ReservationDraftSummaryViewModel
@{
    var returnPath = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<form method="post" action="/rezervasyon-taslagi/iptal" class="reservation-draft-cancel-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="draftId" value="@Model.DraftId" />
    <input type="hidden" name="returnUrl" value="@returnPath" />
    <button type="submit" class="@(ViewData["CancelButtonClass"] as string ?? "global-draft-banner-cancel")">Iptal Et</button>
</form>
