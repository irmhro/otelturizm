@{
    var title = ViewData["Title"] as string ?? "Otelturizm";
    var pageCss = ViewData["PageCss"] as string;
    var nonce = Context.Items["CspNonce"] as string;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/tabler-bridge.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/footer_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/footer_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
    @if (!string.IsNullOrWhiteSpace(pageCss))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCss).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCss).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body class="d-flex flex-column min-vh-100 auth-tabler-body" style="--tblr-primary: #003B95;">
    <a class="visually-hidden-focusable position-absolute top-0 start-0 p-2" href="#auth-main">İçeriğe atla</a>
    <partial name="~/Views/Anasayfa/_AnasayfaPremiumHeader.cshtml" />

    <main id="auth-main" class="flex-fill d-flex flex-column">
        @RenderBody()
    </main>

    <partial name="~/Views/Anasayfa/_AnasayfaPremiumFooter.cshtml" />

    <script src="~/paneltematabler/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script nonce="@nonce">
    (() => {
        const menuButton = document.getElementById('homeMenuToggle');
        const closeButton = document.getElementById('homeDrawerClose');
        const drawer = document.getElementById('homeDrawerMenu');
        const overlay = document.getElementById('homeDrawerOverlay');
        if (!menuButton || !drawer || !overlay) return;
        const open = () => {
            drawer.classList.add('open');
            overlay.classList.add('open');
            menuButton.setAttribute('aria-expanded', 'true');
            document.body.style.overflow = 'hidden';
        };
        const close = () => {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            menuButton.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
        };
        menuButton.addEventListener('click', open);
        closeButton?.addEventListener('click', close);
        overlay.addEventListener('click', close);
        drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', close));
        document.addEventListener('keydown', event => {
            if (event.key === 'Escape') close();
        });
    })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
