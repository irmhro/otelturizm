@model otelturizmnew.Models.Reservations.ReservationDraftSummaryViewModel

@if (Model is not null)
{
    <section class="global-draft-banner">
        <div class="global-draft-banner-copy">
            <strong>Tamamlanmamis rezervasyonunuz var</strong>
            <p>@Model.HotelName · @Model.CheckInText - @Model.CheckOutText · @Model.Message</p>
        </div>
        <div class="global-draft-banner-actions">
            <a href="@Model.ResumeUrl" class="global-draft-banner-link">Devam Et</a>
            @if (Model.RequiresProfileCompletion && !string.IsNullOrWhiteSpace(Model.ProfileCompletionUrl))
            {
                <a href="@Model.ProfileCompletionUrl" class="global-draft-banner-secondary">Bilgileri Guncelle</a>
            }
        </div>
    </section>
}
