<form id="favoriteAntiForgeryForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<script>
    (function () {
        if (window.otelturizmFavoriteInitDone) {
            return;
        }

        window.otelturizmFavoriteInitDone = true;

        function getAntiForgeryToken() {
            const tokenInput = document.querySelector('#favoriteAntiForgeryForm input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        function setButtonState(button, isFavorite) {
            if (!button) {
                return;
            }

            button.classList.toggle('active', isFavorite);

            const icon = button.querySelector('i');
            if (icon) {
                icon.classList.toggle('fas', isFavorite);
                icon.classList.toggle('far', !isFavorite);
            }

            const label = button.querySelector('[data-favorite-label]');
            if (label) {
                label.textContent = isFavorite ? 'Kaydedildi' : 'Kaydet';
            }
        }

        function syncButtons(hotelId, isFavorite) {
            document.querySelectorAll('.favorite-btn[data-hotel-id="' + hotelId + '"]').forEach(function (button) {
                setButtonState(button, isFavorite);
            });
        }

        function ensureLoginPrompt() {
            let backdrop = document.getElementById('favoriteLoginPrompt');
            if (backdrop) {
                return backdrop;
            }

            backdrop = document.createElement('div');
            backdrop.id = 'favoriteLoginPrompt';
            backdrop.className = 'favorite-login-prompt';
            backdrop.innerHTML = `
                <div class="favorite-login-prompt__backdrop" data-favorite-modal-close></div>
                <div class="favorite-login-prompt__dialog" role="dialog" aria-modal="true" aria-labelledby="favoritePromptTitle">
                    <button type="button" class="favorite-login-prompt__close" data-favorite-modal-close aria-label="Pencereyi kapat">
                        <i class="fas fa-times"></i>
                    </button>
                    <div class="favorite-login-prompt__icon"><i class="fas fa-heart"></i></div>
                    <strong id="favoritePromptTitle">Favorilere eklemek için giriş yapın</strong>
                    <p id="favoritePromptMessage">Kaydetmek istediğiniz otelleri profilinizde görmek ve daha sonra hızlıca ulaşmak için kullanıcı hesabınızla giriş yapabilirsiniz.</p>
                    <div class="favorite-login-prompt__actions">
                        <a class="favorite-login-prompt__primary" id="favoritePromptLoginButton" href="/kullanici-giris">Giriş Yap</a>
                        <a class="favorite-login-prompt__secondary" id="favoritePromptRegisterButton" href="/kullanici-giris?sekme=kayit">Kayıt Ol</a>
                    </div>
                </div>
            `;

            document.body.appendChild(backdrop);

            backdrop.querySelectorAll('[data-favorite-modal-close]').forEach(function (element) {
                element.addEventListener('click', function () {
                    backdrop.classList.remove('is-visible');
                    document.body.classList.remove('favorite-modal-open');
                });
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    backdrop.classList.remove('is-visible');
                    document.body.classList.remove('favorite-modal-open');
                }
            });

            return backdrop;
        }

        function showLoginPrompt(message, loginUrl, registerUrl) {
            const modal = ensureLoginPrompt();
            const messageNode = modal.querySelector('#favoritePromptMessage');
            const loginButton = modal.querySelector('#favoritePromptLoginButton');
            const registerButton = modal.querySelector('#favoritePromptRegisterButton');

            if (messageNode) {
                messageNode.textContent = message || 'Favori özelliğini kullanabilmek için lütfen giriş yapınız.';
            }

            if (loginButton) {
                loginButton.setAttribute('href', loginUrl || '/kullanici-giris');
            }

            if (registerButton) {
                registerButton.setAttribute('href', registerUrl || '/kullanici-giris?sekme=kayit');
            }

            modal.classList.add('is-visible');
            document.body.classList.add('favorite-modal-open');
        }

        async function toggleFavorite(button) {
            const hotelId = button.getAttribute('data-hotel-id');
            if (!hotelId || button.dataset.loading === 'true') {
                return;
            }

            const token = getAntiForgeryToken();
            if (!token) {
                console.warn('Antiforgery token bulunamadi.');
                return;
            }

            button.dataset.loading = 'true';
            button.classList.add('is-loading');

            try {
                const response = await fetch('/api/favoriler/toggle', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        hotelId: parseInt(hotelId, 10),
                        sourcePage: button.getAttribute('data-source-page') || document.body.getAttribute('data-page-source') || 'Bilinmeyen Sayfa',
                        sourceUrl: window.location.pathname + window.location.search
                    })
                });

                const responseText = await response.text();
                let payload = null;
                try {
                    payload = responseText ? JSON.parse(responseText) : null;
                } catch (parseError) {
                    payload = null;
                }

                if (response.status === 401 || response.status === 403) {
                    showLoginPrompt(
                        payload && payload.message ? payload.message : 'Favori eklemek için lütfen giriş yapınız.',
                        payload && payload.loginUrl ? payload.loginUrl : '/kullanici-giris',
                        payload && payload.registerUrl ? payload.registerUrl : '/kullanici-giris?sekme=kayit'
                    );
                    return;
                }

                if (!response.ok || !payload || payload.success !== true) {
                    if (!payload && response.status === 400) {
                        window.alert('Favori işlemi güvenlik doğrulamasından geçemedi. Sayfayı yenileyip tekrar deneyin.');
                        return;
                    }

                    window.alert(payload && payload.message ? payload.message : 'Favori işlemi sırasında bir sorun oluştu.');
                    return;
                }

                syncButtons(hotelId, payload.isFavorite === true);
            }
            catch (error) {
                console.error(error);
                window.alert('Favori işlemi sırasında bağlantı hatası oluştu.');
            }
            finally {
                button.dataset.loading = 'false';
                button.classList.remove('is-loading');
            }
        }

        document.addEventListener('click', function (event) {
            const button = event.target.closest('.favorite-btn[data-hotel-id]');
            if (!button) {
                return;
            }

            event.preventDefault();
            event.stopPropagation();
            toggleFavorite(button);
        });
    })();
</script>

<style>
    .favorite-modal-open {
        overflow: hidden;
    }

    .favorite-login-prompt {
        position: fixed;
        inset: 0;
        z-index: 4000;
        display: none;
    }

    .favorite-login-prompt.is-visible {
        display: block;
    }

    .favorite-login-prompt__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.48);
        backdrop-filter: blur(4px);
    }

    .favorite-login-prompt__dialog {
        position: relative;
        width: min(92vw, 420px);
        margin: 10vh auto 0;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-radius: 24px;
        border: 1px solid rgba(0, 59, 149, 0.10);
        box-shadow: 0 28px 60px rgba(15, 23, 42, 0.24);
        padding: 28px 24px 24px;
        text-align: center;
    }

    .favorite-login-prompt__close {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 36px;
        height: 36px;
        border: 0;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.06);
        color: #334155;
    }

    .favorite-login-prompt__icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 16px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #ff385c 0%, #ff7790 100%);
        color: #fff;
        font-size: 24px;
        box-shadow: 0 18px 32px rgba(255, 56, 92, 0.25);
    }

    .favorite-login-prompt__dialog strong {
        display: block;
        font-size: 1.15rem;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .favorite-login-prompt__dialog p {
        margin: 0;
        color: #475569;
        line-height: 1.6;
    }

    .favorite-login-prompt__actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 22px;
    }

    .favorite-login-prompt__primary,
    .favorite-login-prompt__secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
    }

    .favorite-login-prompt__primary {
        background: #003b95;
        color: #fff;
        box-shadow: 0 14px 28px rgba(0, 59, 149, 0.20);
    }

    .favorite-login-prompt__secondary {
        border: 1px solid rgba(0, 59, 149, 0.16);
        background: #fff;
        color: #0f172a;
    }

    @@media (max-width: 600px) {
        .favorite-login-prompt__dialog {
            margin-top: 8vh;
            padding: 24px 18px 18px;
            border-radius: 20px;
        }

        .favorite-login-prompt__actions {
            grid-template-columns: 1fr;
        }
    }
</style>
