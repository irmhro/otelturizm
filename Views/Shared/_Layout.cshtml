@using System.Security.Claims
@using otelturizmnew.Constants
@inject otelturizmnew.Services.Abstractions.IReservationDraftService ReservationDraftService
@inject otelturizmnew.Services.Abstractions.IDevelopmentAccessService DevelopmentAccessService
<!DOCTYPE html>
@{
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var nonce = Context.Items["CspNonce"] as string;
    var isDevelopmentPage = Context.Request.Path.StartsWithSegments("/gelisim", StringComparison.OrdinalIgnoreCase);
    var isDevelopmentUnlocked = DevelopmentAccessService.TryGetAccessExpiration(Context, out var developmentAccessExpiresAt);
}
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="google-site-verification" content="XOjXVbWYoGSwJOaCHdDNb2l8Zs_JO7nr2BnsfeAp9Uw" />
    <title>@ViewData["Title"] - Otelturizm</title>
    <script type="importmap" nonce="@nonce"></script>

    <link rel="preload" as="style" href="~/assets/vendor/fonts/inter/inter-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preload" as="style" href="~/assets/css/site-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/site-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/site-layout.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/development-gate.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/development-gate.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    @{
        var pageCss = ViewData["PageCss"] as string;
    }
    @if (!string.IsNullOrWhiteSpace(pageCss))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCss).css" asp-append-version="true" />
    }
    @{
        var pageCssMobile = ViewData["PageCssMobile"] as string;
    }
    @if (!string.IsNullOrWhiteSpace(pageCssMobile))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssMobile).css" asp-append-version="true" media="(max-width: 900px)" />
    }
    else if (!string.IsNullOrWhiteSpace(pageCss))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCss).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body class="@(isDevelopmentUnlocked ? "development-unlocked" : "development-locked")">
@{
    ViewData["HeaderContext"] = ViewData["HeaderContext"] as string ?? "auth";
}
<partial name="~/Views/Anasayfa/_AnasayfaHeader.cshtml" />

<script src="~/assets/js/sw-asset-guard.js" asp-append-version="true"></script>
<script src="~/assets/js/layout/sw-cleanup.js" asp-append-version="true"></script>

@{
    var publicDraftRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    long? publicDraftUserId = long.TryParse(publicDraftRaw, out var parsedPublicDraftUserId) ? parsedPublicDraftUserId : null;
    var publicDraftSessionKey = Context.Request.Cookies.TryGetValue(otelturizmnew.Services.ReservationDraftService.DraftCookieName, out var publicDraftCookieValue)
        ? publicDraftCookieValue
        : null;
    var publicActiveDraft = await ReservationDraftService.GetActiveDraftAsync(publicDraftUserId, publicDraftSessionKey, Context.RequestAborted);
}

@if (publicActiveDraft is not null && ViewData["SuppressGlobalDraftBanner"] as bool? != true)
{
    <partial name="~/Views/Shared/_ActiveReservationDraftBanner.cshtml" model="publicActiveDraft" />
}

@if (!isDevelopmentPage)
{
    <partial name="~/Views/Shared/_DevelopmentGateOverlay.cshtml" model="isDevelopmentUnlocked" />
}

<main class="site-main">@RenderBody()</main>

<partial name="~/Views/Anasayfa/_AnasayfaFooter.cshtml" />

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/assets/js/layout/mobile-menu.js" asp-append-version="true"></script>
<script src="~/assets/js/layout/development-gate.js" asp-append-version="true"></script>
<script src="~/assets/js/rum-webvitals.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>




