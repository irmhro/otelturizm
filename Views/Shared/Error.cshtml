@model ErrorViewModel
@{
    ViewData["Title"] = "Bir şeyler ters gitti";
    ViewData["HeaderContext"] = "home";
}

<section class="ot-card" style="width:min(980px,calc(100% - 32px));margin:28px auto;padding:22px;border-radius:18px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:14px;flex-wrap:wrap;">
        <div>
            <p style="margin:0 0 6px;color:#64748b;font-weight:800;">Hata</p>
            <h1 style="margin:0 0 8px;font-size:1.6rem;letter-spacing:-.01em;">Bir şeyler ters gitti</h1>
            <p style="margin:0;color:#475569;line-height:1.7;font-weight:600;">
                Sayfa yüklenirken beklenmeyen bir hata oluştu. Lütfen sayfayı yenileyin veya ana sayfaya dönün.
            </p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <a class="ot-btn ot-btn--ghost" href="/" style="text-decoration:none;">Ana sayfaya dön</a>
            <a class="ot-btn ot-btn--primary" href="/yardim-merkezi" style="text-decoration:none;">Destek</a>
        </div>
    </div>

@if (Model.ShowRequestId)
{
    <div style="margin-top:14px;padding:12px 14px;border:1px solid rgba(148,163,184,.35);background:rgba(15,23,42,.03);border-radius:14px;">
        <strong style="display:block;margin-bottom:6px;">İşlem kodu (Trace ID)</strong>
        <code style="font-size:.9rem;">@Model.RequestId</code>
        <div style="margin-top:6px;color:#64748b;font-weight:600;font-size:.92rem;">
            Destek ekibine yazarken bu kodu paylaşabilirsiniz.
        </div>
    </div>
}
    <div style="margin-top:14px;color:#64748b;font-weight:600;">
        İpucu: Sorun devam ederse gizli sekmede deneyin veya tarayıcı önbelleğini temizleyin.
    </div>
</section>

