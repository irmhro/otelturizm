@model int
@{
    var code = Model;
    var title = code == 404 ? "Sayfa bulunamadı" : "İşlem tamamlanamadı";
    var subtitle = code == 404
        ? "Aradığınız sayfa taşınmış veya kaldırılmış olabilir."
        : "Geçici bir problem yaşanmış olabilir. Lütfen tekrar deneyin.";
}

<section class="ot-card" style="width:min(980px,calc(100% - 32px));margin:28px auto;padding:22px;border-radius:18px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:14px;flex-wrap:wrap;">
        <div>
            <p style="margin:0 0 6px;color:#64748b;font-weight:800;">@code</p>
            <h1 style="margin:0 0 8px;font-size:1.6rem;letter-spacing:-.01em;">@title</h1>
            <p style="margin:0;color:#475569;line-height:1.7;font-weight:600;">@subtitle</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <a class="ot-btn ot-btn--ghost" href="/" style="text-decoration:none;">Ana sayfa</a>
            <a class="ot-btn ot-btn--ghost" href="/hotel" style="text-decoration:none;">Oteller</a>
            <a class="ot-btn ot-btn--primary" href="/kampanyalar" style="text-decoration:none;">Kampanyalar</a>
        </div>
    </div>

    <div style="margin-top:14px;">
        <form method="get" action="/hotel" style="display:flex;gap:10px;flex-wrap:wrap;">
            <input name="q" type="search" placeholder="Otel / İl / İlçe / Mahalle ara"
                   style="flex:1;min-width:240px;padding:12px 14px;border:1px solid rgba(148,163,184,.45);border-radius:14px;font-weight:600;" />
            <button type="submit" class="ot-btn ot-btn--primary">Ara</button>
        </form>
        <div style="margin-top:10px;color:#64748b;font-weight:600;">
            İpucu: Linki kopyalayıp tekrar deneyin veya ana menüden gezinin.
        </div>
    </div>
</section>

