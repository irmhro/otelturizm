@model bool

@if (!Model)
{
    <div class="development-gate-overlay" id="developmentGateOverlay" aria-hidden="false">
        <div class="development-gate-office-bg" aria-hidden="true">
            <div class="development-gate-monitor-glow"></div>
            <div class="development-gate-code-lines">
                <div class="development-gate-code-line">const accessToken = await validateEntry(code);</div>
                <div class="development-gate-code-line">if (token.expires &lt; Date.now()) return false;</div>
                <div class="development-gate-code-line">// Oturum süresi: 10 saat</div>
                <div class="development-gate-code-line">localStorage.setItem('session', encrypt(token));</div>
                <div class="development-gate-code-line">console.log('Platform erişimi açıldı');</div>
                <div class="development-gate-code-line">setTimeout(() =&gt; lockPlatform(), 36_000_000);</div>
                <div class="development-gate-code-line">app.render('dashboard', { theme: 'lux' });</div>
                <div class="development-gate-code-line">fetch('/gelisim/kilit-ac', { method: 'POST', body });</div>
            </div>
            <div class="development-gate-grain"></div>
        </div>

        <div class="development-gate-wrapper">
            <div class="development-gate-card">
                <div class="development-gate-diamond" aria-hidden="true"></div>

                <div class="development-gate-top-badge">
                    <span class="development-gate-badge-dot"></span>
                    Geliştirme Aşamasında
                </div>

                <h1 class="development-gate-title">
                    PLATFORM<br />
                    <span>GELİŞTİRİLİYOR</span>
                </h1>

                <p class="development-gate-subtitle">Geçici erişim perdesi aktif</p>
                <div class="development-gate-divider"></div>

                <p class="development-gate-description">
                    Platform şu an geliştirme ve test aşamasında. Normal kullanım kapalıdır.
                    <br /><br />
                    <span class="development-gate-url">https://otelturizm.com/gelisim</span>
                </p>

                <div class="development-gate-input-group">
                    <label class="development-gate-input-label" for="developmentGateCodeInput">Erişim Kodu</label>
                    <div class="development-gate-input-wrap">
                        <input id="developmentGateCodeInput" class="development-gate-input" type="password" inputmode="numeric" autocomplete="one-time-code" placeholder="••••••" />
                        <span class="development-gate-input-icon" aria-hidden="true">🔑</span>
                    </div>
                </div>

                <button type="button" class="development-gate-button" id="developmentGateSubmit">Platformu Aç</button>
                <p class="development-gate-status" id="developmentGateStatus">Yetkiliyseniz ekranda erişim kodunu yazın.</p>
            </div>

            <p class="development-gate-note">Kod doğrulanınca platform 10 saat boyunca açılır.</p>
        </div>
    </div>
}
