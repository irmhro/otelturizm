@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@inject otelturizmnew.Services.Abstractions.IDevelopmentAccessService DevelopmentAccessService
@{
    Layout = null;
    var pageTitle = ViewData["Title"] as string ?? "Otelturizm";
    var bodyClass = ViewData["BodyClass"] as string ?? "anasayfa-page";
    var pageCss = ViewData["PageCss"] as string;
    var pageCssMobile = ViewData["PageCssMobile"] as string ?? pageCss;
    var pageCssBase = ViewData["PageCssBase"] as string;
    var includeBootstrap = ViewData["IncludeBootstrap"] as bool? ?? false;
    var includePureVisualSlider = ViewData["IncludePureVisualSlider"] as bool? ?? false;
    var includeFeWorldTokens = ViewData["IncludeFeWorldTokens"] as bool? ?? false;
    var publicBaseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                        ?? "https://otelturizm.com";
    var metaDescription = (ViewData["MetaDescription"] as string)?.Trim();
    if (string.IsNullOrWhiteSpace(metaDescription))
    {
        metaDescription = "Otelturizm ile otelleri karşılaştırın, kampanyaları keşfedin ve güvenle rezervasyon oluşturun.";
    }
    var ogImage = (ViewData["OgImage"] as string)?.Trim();
    var canonical = (ViewData["Canonical"] as string)?.Trim();
    if (string.IsNullOrWhiteSpace(canonical))
    {
        canonical = publicBaseUrl + (Context.Request.Path.HasValue ? Context.Request.Path.Value : "/");
    }
    var jsonLd = ViewData["JsonLd"] as string;
    var ogLocale = (ViewData["OgLocale"] as string)?.Trim();
    var ogLocaleAlternate = (ViewData["OgLocaleAlternate"] as string)?.Trim();
    var hreflangFromView = ViewData["HreflangAlternates"] as IReadOnlyList<otelturizmnew.Services.InternationalSeoService.HreflangAlternate>;
    string ResolveMobileStylesheet(string? cssName)
    {
        if (string.IsNullOrWhiteSpace(cssName))
        {
            return string.Empty;
        }

        if (cssName.Contains('/'))
        {
            return cssName;
        }

        if (cssName.EndsWith("_mobil", StringComparison.OrdinalIgnoreCase)
            || cssName.EndsWith("_mobile", StringComparison.OrdinalIgnoreCase)
            || cssName.EndsWith(".mobile", StringComparison.OrdinalIgnoreCase))
        {
            return cssName;
        }

        return cssName + ".mobile";
    }

    var pageCssMobileResolved = ResolveMobileStylesheet(pageCssMobile);
    var pageCssMobileMaxWidth = ViewData["PageCssMobileMaxWidth"] as string ?? "900px";
    var pageCssBaseMobileResolved = string.IsNullOrWhiteSpace(pageCssBase)
        ? string.Empty
        : ResolveMobileStylesheet(pageCssBase);
    var nonce = Context.Items["CspNonce"] as string;
    var hostEnv = Context.RequestServices.GetService(typeof(IWebHostEnvironment)) as IWebHostEnvironment;
    var cfg = Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration;
    var requestHost = Context.Request.Host.Host ?? string.Empty;
    var isLoopbackHost = string.Equals(requestHost, "localhost", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestHost, "127.0.0.1", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestHost, "::1", StringComparison.OrdinalIgnoreCase)
        || requestHost.EndsWith(".localhost", StringComparison.OrdinalIgnoreCase);
    var isLocalDevelopment = hostEnv?.IsDevelopment() == true || isLoopbackHost;
    var developmentGateEnabled = cfg?.GetValue("DevelopmentGate:Enabled", false) == true;
    var isDevelopmentUnlocked = !developmentGateEnabled
        || isLocalDevelopment
        || DevelopmentAccessService.TryGetAccessExpiration(Context, out _);
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var showPopupMesaj = User.Identity?.IsAuthenticated != true
        && !requestPath.StartsWith("/kullanici-giris", StringComparison.OrdinalIgnoreCase)
        && !requestPath.StartsWith("/partner-giris", StringComparison.OrdinalIgnoreCase)
        && !requestPath.StartsWith("/firma-giris", StringComparison.OrdinalIgnoreCase)
        && !requestPath.StartsWith("/panel", StringComparison.OrdinalIgnoreCase)
        && (ViewData["SuppressPopupMesaj"] as bool? != true);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <meta name="google-site-verification" content="XOjXVbWYoGSwJOaCHdDNb2l8Zs_JO7nr2BnsfeAp9Uw" />
    <title>@pageTitle - OTELTURİZM</title>
    <meta name="description" content="@metaDescription" />
    @{
        var robots = (ViewData["Robots"] as string)?.Trim();
    }
    @if (!string.IsNullOrWhiteSpace(robots))
    {
        <meta name="robots" content="@robots" />
    }
    <link rel="canonical" href="@canonical" />
    <meta property="og:site_name" content="Otelturizm" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:type" content="website" />
    @if (!string.IsNullOrWhiteSpace(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    @if (!string.IsNullOrWhiteSpace(ogLocale))
    {
        <meta property="og:locale" content="@ogLocale" />
    }
    @if (!string.IsNullOrWhiteSpace(ogLocaleAlternate))
    {
        foreach (var alt in ogLocaleAlternate.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            <meta property="og:locale:alternate" content="@alt" />
        }
    }
    @if (!string.IsNullOrWhiteSpace(jsonLd))
    {
        <script type="application/ld+json">@Html.Raw(jsonLd)</script>
    }
    @if (hreflangFromView is { Count: > 0 })
    {
        foreach (var alt in hreflangFromView)
        {
            <link rel="alternate" hreflang="@alt.Hreflang" href="@alt.Href" />
        }
    }
    <partial name="~/Views/Shared/_VendorPlusJakartaFont.cshtml" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" asp-append-version="true" />
    @if (developmentGateEnabled)
    {
        <link rel="stylesheet" href="~/assets/css/development-gate.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/development-gate.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/anasayfa-header.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/footer_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/footer_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/route-picker-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/route-picker-modal.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/otelturizm-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/public-premium-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/public-premium-pages.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/popupmesaj.css" asp-append-version="true" />
    @if (includeBootstrap)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    @if (includeFeWorldTokens)
    {
        <link rel="stylesheet" href="~/assets/css/fe-world-tokens.css" asp-append-version="true" />
    }
    @if (includePureVisualSlider)
    {
        <link rel="stylesheet" href="~/assets/vendor/swiper/swiper-bundle.min.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/pure-visual-slider.css" asp-append-version="true" />
    }
    @if (ViewData["IncludeAnasayfaStyles"] as bool? == true)
    {
        <link rel="stylesheet" href="~/assets/css/anasayfa_masaustu.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/anasayfa_mobil.css" asp-append-version="true" media="(max-width: 900px)" />
    }
    @if (!string.IsNullOrWhiteSpace(pageCssBase) && !string.Equals(pageCssBase, pageCss, StringComparison.OrdinalIgnoreCase))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssBase).css" asp-append-version="true" />
        @if (!string.IsNullOrWhiteSpace(pageCssBaseMobileResolved))
        {
            <link rel="stylesheet" href="~/assets/css/@(pageCssBaseMobileResolved).css" asp-append-version="true" media="(max-width: 900px)" />
        }
    }
    @if (!string.IsNullOrWhiteSpace(pageCss))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCss).css" asp-append-version="true" />
    }
    @if (!string.IsNullOrWhiteSpace(pageCssMobileResolved) && !string.Equals(pageCssMobileResolved, pageCss, StringComparison.OrdinalIgnoreCase))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssMobileResolved).css" asp-append-version="true" media="(max-width: @(pageCssMobileMaxWidth))" />
    }
    @RenderSection("HeadStyles", required: false)
</head>
<body class="@bodyClass @(isDevelopmentUnlocked ? "development-unlocked" : "development-locked")">
    @if (developmentGateEnabled)
    {
        <partial name="~/Views/Shared/_DevelopmentGateOverlay.cshtml" model="isDevelopmentUnlocked" />
    }
    <partial name="~/Views/Anasayfa/_AnasayfaPremiumHeader.cshtml" />

    <main class="public-premium-main" id="mainContent">
        @RenderBody()
    </main>

    <partial name="~/Views/Anasayfa/_AnasayfaPremiumFooter.cshtml" />
    <partial name="~/Views/Shared/_RoutePickerModal.cshtml" />
    @if (showPopupMesaj)
    {
        <partial name="~/Views/Shared/_PopupMesaj.cshtml" />
    }
    @if (includePureVisualSlider)
    {
        <partial name="~/Views/Shared/_PureVisualSliderModal.cshtml" />
    }

    @if (includeBootstrap)
    {
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    }
    @if (includePureVisualSlider)
    {
        <script src="~/assets/vendor/swiper/swiper-bundle.min.js" asp-append-version="true"></script>
        <script src="~/assets/js/pure-visual-slider.js" asp-append-version="true"></script>
    }
    <script src="~/assets/js/home-drawer-prefs.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/home-header-prefs.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/utility-pulse-bar.js" asp-append-version="true" defer></script>
    <script src="~/assets/js/route-picker-modal.js" asp-append-version="true" defer></script>
    @if (showPopupMesaj)
    {
        <script src="~/assets/js/popupmesaj.js" asp-append-version="true" defer></script>
    }
    <script nonce="@nonce">
        (() => {
            const btn = document.getElementById('homeMenuToggle');
            const closeBtn = document.getElementById('homeDrawerClose');
            const drawer = document.getElementById('homeDrawerMenu');
            const overlay = document.getElementById('homeDrawerOverlay');
            if (!btn || !drawer || !overlay) return;
            const open = () => {
                drawer.classList.add('open');
                overlay.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            };
            const close = () => {
                drawer.classList.remove('open');
                overlay.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            };
            btn.addEventListener('click', open);
            closeBtn?.addEventListener('click', close);
            overlay.addEventListener('click', close);
            drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', close));
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
