@model otelturizmnew.Models.Firma.FirmaLandingPageViewModel
<div class="fir-main">
    <section class="fir-hero-shell" aria-label="İşletmeler için partner otel konaklaması">
        <div class="container">
            <div class="fir-hero-section">
                <div class="fir-hero-copy">
                    <h1 class="hero-title fir-hero-title">
                        Partner Otellerden <span class="fir-hero-accent">Toplu Oda</span> Kiralayın
                    </h1>
                    <p class="fir-hero-lead">@Model.HeroDescription</p>

                    <div class="fir-process-cards" aria-label="Partner otel kiralama akışı">
                        <article class="fir-process-card">
                            <span class="fir-process-step">1</span>
                            <h4>Partner Oteller Plan Tanımlar</h4>
                            <p>Kurumsal partner tesisler, işletmelere özel minimum oda adedi ve indirimli kurumsal tarifelerini belirler.</p>
                        </article>
                        <article class="fir-process-card">
                            <span class="fir-process-step">2</span>
                            <h4>İşletmeniz Panelde Görür</h4>
                            <p>Firma hesabınızda partner otellerin kurumsal oda teklifleri bireysel fiyat yerine otomatik listelenir.</p>
                        </article>
                        <article class="fir-process-card">
                            <span class="fir-process-step">3</span>
                            <h4>Toplu Oda Kiralama</h4>
                            <p>Üretim, lojistik, perakende ve hizmet firmaları partner otellerden toplu oda kiralayarak maliyeti düşürür.</p>
                        </article>
                    </div>

                    <div class="fir-hero-points">
                        <div class="fir-hero-point"><i class="fas fa-check-circle" aria-hidden="true"></i> Otelturizm partner otelleri işletmelere kurumsal oda ve indirim planı sunar</div>
                        <div class="fir-hero-point"><i class="fas fa-check-circle" aria-hidden="true"></i> Firma panelinden partner tesislerde anlık müsaitlik ve kurumsal fiyat görürsünüz</div>
                        <div class="fir-hero-point"><i class="fas fa-check-circle" aria-hidden="true"></i> Saha, proje ve ekip konaklamalarında toplu oda kiralama tek akışta yönetilir</div>
                        <div class="fir-hero-point"><i class="fas fa-check-circle" aria-hidden="true"></i> Satın alma, operasyon ve finans ekipleri partner otel harcamasını aynı panelden izler</div>
                    </div>

                    <div class="fir-hero-actions">
                        <a href="/firma-giris?sekme=kayit" class="btn-club-pro">Firma Hesabı Açın <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                        <a href="/firma-giris" class="btn-club-pro-outline">Firma Girişi <i class="fas fa-building" aria-hidden="true"></i></a>
                    </div>
                </div>

                <div class="fir-hero-visual" aria-label="Partner otel kurumsal fiyat karşılaştırması">
                    <span class="fir-visual-badge"><i class="fas fa-handshake" aria-hidden="true"></i> Partner Otel Ağı</span>
                    <p class="fir-visual-title">Örnek İşletme Kiralama · Partner otel · 5 oda · 2 gece</p>
                    <div class="fir-kpi-grid">
                        <div class="fir-kpi">
                            <small>Toplam Oda</small>
                            <strong>5</strong>
                        </div>
                        <div class="fir-kpi fir-kpi--up">
                            <small>İndirim Oranı</small>
                            <strong>%20</strong>
                        </div>
                        <div class="fir-kpi">
                            <small>Geceleme</small>
                            <strong>2</strong>
                        </div>
                    </div>
                    <div class="fir-compare-panel">
                        <div class="fir-compare-row">
                            <span><i class="fas fa-hotel" aria-hidden="true"></i> Standart (Bireysel)</span>
                            <strong class="fir-compare-standard">₺3.600</strong>
                        </div>
                        <div class="fir-compare-row fir-compare-row--highlight">
                            <span><i class="fas fa-building" aria-hidden="true"></i> Partner Otel · İşletme (5 oda)</span>
                            <strong class="fir-compare-corp">₺2.880 <b class="fir-savings-tag"><i class="fas fa-arrow-down" aria-hidden="true"></i> %20</b></strong>
                        </div>
                        <div class="fir-compare-row">
                            <span><i class="fas fa-piggy-bank" aria-hidden="true"></i> Toplam Tasarruf</span>
                            <strong class="fir-compare-save">₺720</strong>
                        </div>
                    </div>
                    <div class="fir-visual-foot">
                        <span>Örnek gösterim — gerçek fiyatlar panelinizde otel bazlı güncellenir</span>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <div class="container fir-body">
        <nav class="fir-section-nav" aria-label="Sayfa bölümleri">
            <a href="#fir-isletmeler" class="fir-nav-pill">İşletmeler</a>
            <a href="#fir-avantajlar" class="fir-nav-pill">Avantajlar</a>
            <a href="#fir-fiyat-mantigi" class="fir-nav-pill">Fiyat Mantığı</a>
            <a href="#fir-fiyatlar" class="fir-nav-pill">Fiyat Kademeleri</a>
            @if (Model.FeaturedDeals.Any())
            {
                <a href="#fir-teklifler" class="fir-nav-pill">Örnek Teklifler</a>
            }
            <a href="#fir-adimlar" class="fir-nav-pill">Süreç</a>
            <a href="#fir-sss" class="fir-nav-pill">SSS</a>
        </nav>

        <section class="eco-ribbon eco-ribbon-stack fir-trust-strip" aria-label="Güven göstergeleri">
            <div class="eco-meta"><span>🤝</span> Partner otel ağı · işletmelere kurumsal oda kiralama</div>
            <div class="eco-pills fir-trust-pills">
                <span class="eco-pill">Partner otel kurumsal fiyatları</span>
                <span class="eco-pill">Toplu oda kiralama</span>
                <span class="eco-pill">Fatura &amp; harcama takibi</span>
            </div>
        </section>

        <h2 class="section-headline" id="fir-isletmeler"><span class="headline-left">Hangi İşletmeler Partner Otellerden Oda Kiralar?</span></h2>
        <p class="fir-section-intro">Üretim, lojistik, perakende ve hizmet firmaları saha ekipleri, proje konaklamaları ve operasyon personeli için partner otellerden toplu oda kiralayabilir.</p>
        <section class="fir-firm-types" aria-label="Partner otel oda kiralayan işletme türleri">
            <article class="fir-firm-type">
                <span class="fir-firm-type-icon"><i class="fas fa-industry" aria-hidden="true"></i></span>
                <div>
                    <h3>Üretim Firmaları</h3>
                    <p>Fabrika ve tesis personeli, vardiya değişimleri ve saha mühendisleri için partner otellerden toplu oda kiralayın.</p>
                </div>
            </article>
            <article class="fir-firm-type">
                <span class="fir-firm-type-icon"><i class="fas fa-truck-fast" aria-hidden="true"></i></span>
                <div>
                    <h3>Lojistik Firmaları</h3>
                    <p>Şoför, depo ve dağıtım ekipleri için rota üzerindeki partner otellerde kurumsal fiyatla konaklama alın.</p>
                </div>
            </article>
            <article class="fir-firm-type">
                <span class="fir-firm-type-icon"><i class="fas fa-store" aria-hidden="true"></i></span>
                <div>
                    <h3>Perakende Firmaları</h3>
                    <p>Mağaza açılışları, bölge temsilcileri ve eğitim grupları için partner otellerden indirimli oda kiralayın.</p>
                </div>
            </article>
            <article class="fir-firm-type">
                <span class="fir-firm-type-icon"><i class="fas fa-briefcase" aria-hidden="true"></i></span>
                <div>
                    <h3>Hizmet Firmaları</h3>
                    <p>Proje, bakım ve danışmanlık ekipleri partner otellerin işletmenize özel tarifeleriyle konaklama maliyetini düşürür.</p>
                </div>
            </article>
        </section>

        <div class="fir-info-banner">
            <i class="fas fa-handshake" aria-hidden="true"></i>
            <p>Partner oteller kurumsal tarifelerini kendi belirler; işletmeniz firma panelinde bu fiyatları görür. Faturalar partner otel tarafından kesilir ve <strong>Faturalar</strong> ekranından takip edilir.</p>
        </div>

        <h2 class="section-headline" id="fir-avantajlar"><span class="headline-left">Firma Paneli İşletmelere Neler Sunar?</span></h2>
        <p class="fir-section-intro">Partner otellerden oda kiralama, ekip yönetimi ve harcama raporlamasını tek panelden yönetin.</p>
        <section class="fintech-strip fir-benefits-strip">
            @foreach (var benefit in Model.Benefits)
            {
                <div class="fin-card fir-fin-card">
                    <span class="fin-icon"><i class="fas @benefit.IconClass" aria-hidden="true"></i></span>
                    <div class="fin-text">
                        <h5>@benefit.Title</h5>
                        <p>@benefit.Description</p>
                    </div>
                </div>
            }
        </section>

        <section class="business-lounge business-lounge-teaser fir-pricing-story" id="fir-fiyat-mantigi">
            <div class="biz-teaser-copy">
                <span class="biz-teaser-kicker">Partner otel modeli</span>
                <h3>İşletmeler partner otellerden oda kiralar; bireysel arama fiyatı ile aynı değildir</h3>
                <p class="biz-teaser-lead">Otelturizm partner otelleri, kayıtlı işletmelere oda adedine göre kurumsal tarife tanımlar. Minimum eşiğe ulaşınca partner otel fiyatı otomatik devreye girer.</p>
                <ul class="biz-teaser-points">
                    <li><i class="fas fa-hotel" aria-hidden="true"></i><span>Partner oteller işletmenize özel toplu oda fiyatı ve müsaitlik sunar.</span></li>
                    <li><i class="fas fa-users-gear" aria-hidden="true"></i><span>Üretim, lojistik ve saha ekipleri için harcama tek panelden izlenir.</span></li>
                    <li><i class="fas fa-file-invoice" aria-hidden="true"></i><span>Partner otel faturaları panelde toplanır; dönemsel raporlar tek tıkla alınır.</span></li>
                </ul>
                <div class="biz-teaser-actions">
                    <a class="btn-biz-lounge" href="/firma-giris?sekme=kayit">Firma Hesabı Aç</a>
                    <a class="btn-biz-lounge-outline" href="/kurumsal">Partner Programı</a>
                </div>
            </div>
            <div class="biz-teaser-examples" aria-label="Örnek fiyat karşılaştırmaları">
                <div class="biz-teaser-compare">
                    <span class="biz-teaser-compare-label">Örnek · 5 oda · 2 gece</span>
                    <div class="biz-teaser-compare-row">
                        <span class="biz-teaser-compare-item">Bireysel <strong>₺3.600</strong></span>
                        <i class="fas fa-arrow-right biz-teaser-compare-arrow" aria-hidden="true"></i>
                        <span class="biz-teaser-compare-item biz-teaser-compare-item--corp">Firma <strong>₺2.880</strong></span>
                        <span class="biz-teaser-compare-save"><i class="fas fa-arrow-down" aria-hidden="true"></i> %20</span>
                    </div>
                </div>
                <div class="biz-teaser-compare">
                    <span class="biz-teaser-compare-label">Örnek · 10 oda · 2 gece</span>
                    <div class="biz-teaser-compare-row">
                        <span class="biz-teaser-compare-item">Bireysel <strong>₺14.400</strong></span>
                        <i class="fas fa-arrow-right biz-teaser-compare-arrow" aria-hidden="true"></i>
                        <span class="biz-teaser-compare-item biz-teaser-compare-item--corp">Firma <strong>₺10.800</strong></span>
                        <span class="biz-teaser-compare-save"><i class="fas fa-arrow-down" aria-hidden="true"></i> %25</span>
                    </div>
                </div>
            </div>
        </section>

        <h2 class="section-headline" id="fir-fiyatlar"><span class="headline-left">Partner Oteller İşletmeler İçin Nasıl Fiyatlandırıyor?</span></h2>
        <p class="fir-section-intro">Her partner otel, işletmelere özel minimum oda sayısı ve indirim yapısını kendi belirler — panelde şeffaf görürsünüz.</p>
        <section class="fir-pricing-panel" aria-label="Oda adedine göre örnek indirim kademeleri">
            <div class="fir-tier-grid">
                @foreach (var tier in Model.PricingTiers)
                {
                    <article class="fir-tier-card @(tier.Highlighted ? "fir-tier-card--highlight" : string.Empty)">
                        <h3 class="fir-tier-name">@tier.Name</h3>
                        <p class="fir-tier-range">@tier.Range</p>
                        <span class="fir-tier-rate">@tier.DiscountText</span>
                        <p class="fir-tier-example">@tier.ExampleText</p>
                    </article>
                }
            </div>
            <p class="fir-tier-note"><strong>Önemli:</strong> Kademeler partner otelden partner otele değişir. Firma panelinde her partner tesisin işletmenize özel şartlarını görebilirsiniz.</p>
        </section>

        @if (Model.FeaturedDeals.Any())
        {
            <h2 class="section-headline" id="fir-teklifler"><span class="headline-left">Partner Otellerden Canlı Teklif Örnekleri</span></h2>
            <p class="fir-section-intro">Partner otellerin işletmelere sunduğu gerçek fiyat karşılaştırmaları — bireysel ve kurumsal teklif yan yana.</p>
            <section class="fir-deals-grid" aria-label="Öne çıkan kurumsal teklifler">
                @foreach (var deal in Model.FeaturedDeals)
                {
                    <article class="fir-deal-card">
                        <div class="fir-deal-head">
                            <h3>@deal.HotelName</h3>
                            <span class="fir-deal-city"><i class="fas fa-location-dot" aria-hidden="true"></i> @deal.City</span>
                        </div>
                        <div class="fir-deal-prices">
                            <div class="fir-deal-row">
                                <span>Bireysel</span>
                                <strong>@deal.StandardPriceText</strong>
                            </div>
                            <div class="fir-deal-row fir-deal-row--corp">
                                <span>Firma · @deal.MinRoomText</span>
                                <strong>@deal.CorporatePriceText <small>@deal.DiscountRateText</small></strong>
                            </div>
                            <div class="fir-deal-row fir-deal-row--save">
                                <span>Tasarruf</span>
                                <strong>@deal.SavingsText</strong>
                            </div>
                        </div>
                    </article>
                }
            </section>
        }

        <h2 class="section-headline" id="fir-adimlar"><span class="headline-left">3 Adımda Partner Otellerden Oda Kiralama</span></h2>
        <p class="fir-section-intro">İşletme hesabınızı açın, ekibinizi tanımlayın, partner otellerden toplu oda kiralayın.</p>
        <section class="fir-steps">
            <article class="fir-step">
                <span class="fir-step-num" aria-hidden="true">1</span>
                <div class="fir-step-body">
                    <h3>İşletme Hesabı Oluşturun</h3>
                    <p>Kurumsal işletme bilgilerinizle ücretsiz firma hesabı açın.</p>
                </div>
            </article>
            <article class="fir-step">
                <span class="fir-step-num" aria-hidden="true">2</span>
                <div class="fir-step-body">
                    <h3>Ekip ve Çalışanları Ekleyin</h3>
                    <p>Saha, proje ve operasyon ekiplerini tanımlayın; harcama limitlerini yönetin.</p>
                </div>
            </article>
            <article class="fir-step">
                <span class="fir-step-num" aria-hidden="true">3</span>
                <div class="fir-step-body">
                    <h3>Partner Otellerden Oda Kiralayın</h3>
                    <p>Partner otellerin işletmenize tanımladığı kurumsal fiyatlarla toplu oda rezervasyonu yapın.</p>
                </div>
            </article>
        </section>

        <h2 class="section-headline" id="fir-sss"><span class="headline-left">Sıkça Sorulan Sorular</span></h2>
        <section class="fir-faq-grid">
            <article class="fir-faq-item">
                <h3><i class="fas fa-circle-question" aria-hidden="true"></i> Partner otel nedir?</h3>
                <p>Otelturizm kurumsal programına katılan tesislerdir. Bu oteller kayıtlı işletmelere minimum oda adedine göre indirimli kurumsal tarife tanımlar.</p>
            </article>
            <article class="fir-faq-item">
                <h3><i class="fas fa-circle-question" aria-hidden="true"></i> Hangi işletmeler oda kiralayabilir?</h3>
                <p>Üretim, lojistik, perakende ve hizmet firmaları dahil tüm kayıtlı işletmeler partner otellerden toplu oda kiralayabilir.</p>
            </article>
            <article class="fir-faq-item">
                <h3><i class="fas fa-circle-question" aria-hidden="true"></i> İndirim oranı nasıl belirlenir?</h3>
                <p>Her partner otel minimum oda adedi ve indirim oranını kendi kurumsal planına göre tanımlar; firma panelinde şeffaf görürsünüz.</p>
            </article>
            <article class="fir-faq-item">
                <h3><i class="fas fa-circle-question" aria-hidden="true"></i> Firma hesabı ücretli mi?</h3>
                <p>Hayır, işletme hesabı açmak ve partner otel fiyatlarını görüntülemek ücretsizdir.</p>
            </article>
        </section>

        <section class="club-banner club-banner-pro fir-final-cta">
            <div class="club-pro-glow" aria-hidden="true"></div>
            <div class="club-pro-main">
                <div class="club-pro-head">
                    <span class="club-pro-badge">İŞLETME PROGRAMI</span>
                    <h3>Partner otellerden toplu oda kiralamaya hazır mısınız?</h3>
                    <p>Ücretsiz işletme hesabı açın; üretim, lojistik, perakende ve hizmet firmaları partner otellerin kurumsal fiyatlarını hemen görsün.</p>
                </div>
                <div class="club-pro-perks">
                    <span>Ücretsiz kayıt</span>
                    <span>Kredi kartı gerekmez</span>
                    <span>2 dakikada kurulum</span>
                </div>
            </div>
            <div class="club-pro-actions fir-cta-actions">
                <a class="btn-club-pro" href="/firma-giris?sekme=kayit">Firma Hesabı Açın</a>
                <a class="btn-club-pro-outline" href="/firma-giris">Firma Girişi</a>
                <a class="btn-club-pro-outline" href="#fir-adimlar">Süreci İncele</a>
            </div>
        </section>
    </div>

    <div class="fir-mobile-cta">
        <a href="/firma-giris?sekme=kayit" class="fir-mobile-cta-btn fir-mobile-cta-btn--primary">Firma Hesabı Açın</a>
        <a href="/firma-giris" class="fir-mobile-cta-btn fir-mobile-cta-btn--ghost">Firma Girişi</a>
    </div>
</div>
