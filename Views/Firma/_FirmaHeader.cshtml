@model otelturizmnew.Models.Firma.FirmaLandingPageViewModel
<header class="site-header firma-site-header" id="firmaHeader">
    <div class="top-utility-bar firma-utility-bar">
        <div class="utility-container">
            <div class="utility-left">
                <span><i class="fas fa-building-shield"></i> Firma Güvencesi</span>
                <span><i class="fas fa-headset"></i> 7/24 Öncelikli Destek</span>
                <span><i class="fas fa-file-invoice"></i> Tek Merkezden Faturalama</span>
            </div>
            <div class="utility-right">
                <div class="language-selector"><i class="fas fa-globe"></i> TR</div>
                <div class="currency-selector"><i class="fas fa-lira-sign"></i> TRY</div>
            </div>
        </div>
    </div>

    <div class="header-container firma-header-container">
        <div class="logo-area">
            <a href="/" class="logo logo-image-only firma-logo-link" aria-label="Otelturizm Firma">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="brand-logo-image" />
            </a>

            <nav class="desktop-nav firma-desktop-nav">
                <a href="/" class="nav-link"><span>Keşfet</span></a>
                <a href="/kurumsal" class="nav-link"><span>Kurumsal</span></a>
                <a href="/firma" class="nav-link active"><span>Firma</span></a>
            </nav>
        </div>

        <div class="search-wrapper">
            <div class="search-container firma-search-container">
                <i class="fas fa-search"></i>
                <input type="text" class="search-input" placeholder="Firma fiyatı, otel veya şehir arayın">
                <div class="search-divider"></div>
                <div class="search-date"><i class="far fa-building"></i><span>Toplu Konaklama</span></div>
                <div class="search-divider"></div>
                <div class="search-guests"><i class="fas fa-user-tie"></i><span>Kurumsal</span></div>
                <button class="search-btn firma-search-btn" type="button"><i class="fas fa-search"></i></button>
            </div>
        </div>

        <div class="header-actions firma-header-actions">
            <a href="/oteller" class="action-btn">Oteller</a>
            <a href="/firma-giris" class="action-btn">Firma Girişi</a>
            <a href="/firma-giris?sekme=kayit" class="action-btn primary">Firma Hesabı Açın</a>
            <button class="action-btn mobile-nav-toggle" id="firmaMenuToggle" type="button"><i class="fas fa-bars"></i></button>
        </div>
    </div>
</header>

<div class="mobile-menu-overlay" id="firmaMenuOverlay"></div>
<div class="mobile-menu-drawer firma-menu-drawer" id="firmaMenuDrawer">
    <div class="drawer-header">
        <div class="drawer-user">
            <div class="user-avatar firma-avatar">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" />
            </div>
            <div>
                <h4>Otelturizm Firma</h4>
                <p>Kurumsal konaklama hızlı menüsü</p>
            </div>
        </div>
        <button class="drawer-close" id="firmaDrawerClose" type="button"><i class="fas fa-times"></i></button>
    </div>

    <div class="drawer-actions drawer-actions-row">
        <a href="/firma-giris" class="drawer-action primary">Firma Girişi</a>
        <a href="/firma-giris?sekme=kayit" class="drawer-action outline">Kayıt Ol</a>
    </div>

    <div class="drawer-nav">
        <div class="drawer-section">
            <div class="drawer-section-title">Firma Menü</div>
            <a href="/" class="drawer-link"><i class="fas fa-home"></i> Anasayfa</a>
            <a href="/kurumsal" class="drawer-link"><i class="fas fa-building"></i> Kurumsal</a>
            <a href="/firma" class="drawer-link"><i class="fas fa-briefcase"></i> Firma</a>
            <a href="/yardim-merkezi" class="drawer-link"><i class="fas fa-headset"></i> Destek</a>
            <a href="/panel/firma" class="drawer-link"><i class="fas fa-chart-pie"></i> Firma Paneli</a>
        </div>
    </div>
</div>

<script>
    (function () {
        const toggle = document.getElementById('firmaMenuToggle');
        const overlay = document.getElementById('firmaMenuOverlay');
        const drawer = document.getElementById('firmaMenuDrawer');
        const close = document.getElementById('firmaDrawerClose');

        if (!toggle || !overlay || !drawer || !close) {
            return;
        }

        function openDrawer() {
            overlay.classList.add('is-visible');
            drawer.classList.add('is-visible');
            document.body.classList.add('firma-mobile-open');
        }

        function closeDrawer() {
            overlay.classList.remove('is-visible');
            drawer.classList.remove('is-visible');
            document.body.classList.remove('firma-mobile-open');
        }

        toggle.addEventListener('click', openDrawer);
        overlay.addEventListener('click', closeDrawer);
        close.addEventListener('click', closeDrawer);
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeDrawer();
            }
        });
    })();
</script>
