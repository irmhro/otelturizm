@model otelturizmnew.Models.Giris.ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<section class="auth-shell user-auth-shell">
    <div class="auth-standalone-panel">
        <div class="divider-line"><span>yeni şifrenizi oluşturun</span></div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/sifre-sifirla">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="NewPassword">Yeni Şifre</label>
                <div class="input-wrap">
                    <i class="fas fa-lock"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="En az 6 karakter (harf + rakam)" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Yeni Şifre Tekrar</label>
                <div class="input-wrap">
                    <i class="fas fa-lock"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Şifrenizi tekrar girin" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." />
                </div>
            </div>
            <p class="auth-inline-hint">Sifre kurali: en az 6 karakter, en az 1 harf ve 1 rakam.</p>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Şifreyi Güncelle <i class="fas fa-arrow-right"></i></button>
            </div>
        </form>
    </div>
</section>
