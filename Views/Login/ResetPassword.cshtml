@model otelturizmnew.Models.Giris.ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="auth-card auth-card--solo">
    <div class="auth-form-panel auth-form-panel--solo">
        <div class="auth-solo-head">
            <span class="auth-solo-kicker">Güvenlik</span>
            <h1 class="auth-solo-title">Yeni Şifre Oluştur</h1>
            <p class="auth-solo-desc">En az 6 karakter, en az 1 harf ve 1 rakam içeren yeni şifrenizi belirleyin.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/sifre-sifirla">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="NewPassword">Yeni Şifre</label>
                <div class="input-wrap password-wrapper">
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="En az 6 karakter (harf + rakam)" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" title="En az 6 karakter, en az 1 harf ve 1 rakam girin." autocomplete="new-password" />
                    <button type="button" class="toggle-password" data-toggle-target="NewPassword" aria-label="Şifreyi göster veya gizle">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Yeni Şifre Tekrar</label>
                <div class="input-wrap password-wrapper">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Şifrenizi tekrar girin" minlength="6" pattern="(?=.*[A-Za-z])(?=.*\d).{6,}" autocomplete="new-password" />
                    <button type="button" class="toggle-password" data-toggle-target="ConfirmPassword" aria-label="Şifreyi göster veya gizle">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Şifreyi Güncelle <i class="fas fa-arrow-right"></i></button>
                <a href="/kullanici-giris" class="text-link">Giriş ekranına dön</a>
            </div>
        </form>
    </div>
</div>
