@{
    ViewData["Title"] = "Kullanıcı Giriş";
    var showResendVerifyButton = string.Equals(TempData["ShowResendVerifyButton"] as string, "1", StringComparison.Ordinal);
    var resendVerifyEmail = TempData["ResendVerifyEmail"] as string ?? string.Empty;
}

<div class="auth-card">
    <div class="auth-layout">
        <div class="auth-form-panel">
            <div class="auth-tab-buttons" data-auth-tabs>
                <button type="button" class="auth-tab-btn active" data-target="loginPanel">Giriş Yap</button>
                <button type="button" class="auth-tab-btn" data-target="registerPanel">Kayıt Ol</button>
            </div>

            <div class="auth-form-panel-block active" id="loginPanel">
                <div class="auth-form-hint"><i class="fas fa-envelope"></i> e-posta ile giriş yapın</div>

                @if (TempData["UserLoginError"] is string loginError)
                {
                    <div class="auth-alert">@loginError</div>
                    @if (showResendVerifyButton && !string.IsNullOrWhiteSpace(resendVerifyEmail))
                    {
                        <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@resendVerifyEmail" />
                            <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane"></i> Onaylama E-postası Gönder</button>
                        </form>
                    }
                }
                @if (TempData["UserLoginSuccess"] is string loginSuccess)
                {
                    <div class="auth-alert auth-alert-success">@loginSuccess</div>
                }

                <form class="auth-form" id="userLoginForm" method="post" asp-controller="Auth" asp-action="UserLogin">
                    @Html.AntiForgeryToken()
                    @if (!string.IsNullOrWhiteSpace(ViewData["ReturnUrl"] as string))
                    {
                        <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />
                    }
                    <div class="form-group">
                        <label for="loginEmail">E-posta Adresiniz</label>
                        <input id="loginEmail" name="loginEmail" type="email" class="form-control" placeholder="ornek@email.com" value="@resendVerifyEmail" required />
                    </div>
                    <div class="form-group">
                        <label for="loginPassword">Şifreniz</label>
                        <div class="input-wrap password-wrapper">
                            <input id="loginPassword" name="loginPassword" type="password" class="form-control" placeholder="••••••••" required />
                            <button type="button" class="toggle-password" data-toggle-target="loginPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-row-meta">
                        <label class="checkbox-inline">
                            <input type="checkbox" name="rememberMe" value="true" checked />
                            <span>Beni hatırla</span>
                        </label>
                        <a href="/sifremi-unuttum" class="text-link">Şifremi unuttum</a>
                    </div>
                    <button type="submit" class="auth-submit-btn">Giriş Yap <i class="fas fa-arrow-right"></i></button>
                </form>
                <p class="auth-helper">Henüz üye değil misin? <button type="button" class="text-button" data-switch-tab="registerPanel">Hemen kayıt ol</button></p>
            </div>

            <div class="auth-form-panel-block" id="registerPanel">
                <partial name="~/Views/Register/_UserRegisterForm.cshtml" />
            </div>

            <div class="legal-note">
                <span><i class="fas fa-lock"></i> SSL</span>
                <span><i class="fas fa-database"></i> KVKK</span>
                <span><i class="fas fa-shield-alt"></i> 3D Secure</span>
            </div>
        </div>

        <aside class="auth-info">
            <div>
                <div class="auth-info-logo">
                    <partial name="~/Views/Anasayfa/_AnasayfaLogo.cshtml" />
                </div>
                <span class="auth-info-badge">Üye Alanı</span>
                <h2>Hayalindeki tatile bir adım daha yaklaş</h2>
                <p class="tagline">Giriş yap, kayıt ol ve üye avantajlarıyla rezervasyon sürecini hızlandır.</p>
                <ul class="benefits-list">
                    <li><i class="fas fa-tag"></i> Üyeye özel kampanya ve indirimler</li>
                    <li><i class="fas fa-bolt"></i> Hızlı rezervasyon ve otomatik form doldurma</li>
                    <li><i class="fas fa-gem"></i> Puan, kupon ve sadakat avantajı</li>
                    <li><i class="fas fa-headset"></i> 7/24 öncelikli destek</li>
                </ul>
            </div>
            <div class="trust-badges">
                <span><i class="fas fa-shield-alt"></i> 256-bit SSL</span>
                <span><i class="fas fa-credit-card"></i> Güvenli ödeme</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
        var openRegister = TempData["OpenUserRegisterTab"] as string ?? string.Empty;
    }
    <script nonce="@nonce">
        (() => {
            const query = new URLSearchParams(window.location.search);
            if ('@openRegister' === '1' || query.get('sekme') === 'kayit' || window.location.hash === '#kayit-ol') {
                document.querySelector('[data-auth-tabs] [data-target="registerPanel"]')?.click();
            }
            const loginForm = document.getElementById('userLoginForm');
            loginForm?.addEventListener('submit', function () {
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Giriş yapılıyor <i class="fas fa-spinner fa-spin"></i>'; }
            });
            const registerForm = document.getElementById('userRegisterForm');
            registerForm?.addEventListener('submit', function () {
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Kayıt oluşturuluyor <i class="fas fa-spinner fa-spin"></i>'; }
            });
        })();
    </script>
}
