@{
    ViewData["Title"] = "Kullanıcı Giriş";
    var showResendVerifyButton = string.Equals(TempData["ShowResendVerifyButton"] as string, "1", StringComparison.Ordinal);
    var resendVerifyEmail = TempData["ResendVerifyEmail"] as string ?? string.Empty;
}

<section class="auth-shell user-auth-shell">
    <div class="auth-stage">
        <aside class="auth-sidebar">
            <div class="auth-sidebar-top">
                <div class="auth-sidebar-logo"><i class="fas fa-hotel"></i> Otelturizm</div>
                <span class="auth-sidebar-badge">Üye Alanı</span>
            </div>

            <div class="auth-sidebar-content">
                <p class="auth-kicker">Seyahatini hızlandır</p>
                <h1>Hayalindeki tatile bir adım daha yaklaş</h1>
                <p class="auth-lead">Giriş yap, kayıt ol ve üye avantajlarıyla rezervasyon sürecini çok daha hızlı tamamla.</p>

                <ul class="auth-feature-list">
                    <li><i class="fas fa-tag"></i> Üyeye özel kampanya ve indirimler</li>
                    <li><i class="fas fa-bolt"></i> Daha hızlı rezervasyon ve otomatik form doldurma</li>
                    <li><i class="fas fa-gem"></i> Puan, kupon ve sadakat avantajı</li>
                    <li><i class="fas fa-headset"></i> 7/24 öncelikli destek deneyimi</li>
                </ul>
            </div>

            <div class="auth-sidebar-bottom">
                <span><i class="fas fa-shield-alt"></i> 256-bit SSL koruması</span>
                <span><i class="fas fa-credit-card"></i> Güvenli ödeme altyapısı</span>
            </div>
        </aside>

        <div class="auth-panel-wrap">
            <div class="auth-tabs" data-auth-tabs>
                <button type="button" class="auth-tab active" data-target="loginPanel">
                    <i class="fas fa-sign-in-alt"></i> Giriş Yap
                </button>
                <button type="button" class="auth-tab" data-target="registerPanel">
                    <i class="fas fa-user-plus"></i> Kayıt Ol
                </button>
            </div>

            <div class="auth-panel active" id="loginPanel">
                <div class="divider-line"><span>e-posta ile giriş yapın</span></div>

                @if (TempData["UserLoginError"] is string loginError)
                {
                    <div class="auth-alert">@loginError</div>
                    @if (showResendVerifyButton && !string.IsNullOrWhiteSpace(resendVerifyEmail))
                    {
                        <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@resendVerifyEmail" />
                            <button type="submit" class="auth-resend-verify-btn">
                                <i class="fas fa-paper-plane"></i> Onaylama E-postası Gönder
                            </button>
                        </form>
                    }
                }
                @if (TempData["UserLoginSuccess"] is string loginSuccess)
                {
                    <div class="auth-alert auth-alert-success">@loginSuccess</div>
                }

                <form class="auth-form" id="userLoginForm" method="post" asp-controller="Auth" asp-action="UserLogin">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="loginEmail">E-posta Adresiniz</label>
                        <div class="input-wrap">
                            <i class="far fa-envelope"></i>
                            <input id="loginEmail" name="loginEmail" type="email" class="form-control" placeholder="ornek@email.com" value="@resendVerifyEmail" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="loginPassword">Şifreniz</label>
                        <div class="input-wrap">
                            <i class="fas fa-lock"></i>
                            <input id="loginPassword" name="loginPassword" type="password" class="form-control" placeholder="••••••••" required />
                            <button type="button" class="toggle-password" data-toggle-target="loginPassword">
                                <i class="far fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-row-meta">
                        <label class="checkbox-inline">
                            <input type="checkbox" name="rememberMe" value="true" checked />
                            <span>Beni hatırla</span>
                        </label>
                        <a href="/sifremi-unuttum" class="text-link">Şifremi unuttum</a>
                    </div>

                    <button type="submit" class="auth-submit-btn">Giriş Yap <i class="fas fa-arrow-right"></i></button>
                </form>

                <p class="auth-helper">Henüz üye değil misin? <button type="button" class="text-button" data-switch-tab="registerPanel">Hemen kayıt ol</button></p>
            </div>

            <div class="auth-panel" id="registerPanel">
                <partial name="~/Views/Register/_UserRegisterForm.cshtml" />
            </div>

            <div class="auth-trust-row">
                <span><i class="fas fa-shield-alt"></i> SSL</span>
                <span><i class="fas fa-check-circle"></i> KVKK</span>
                <span><i class="fas fa-credit-card"></i> Güvenli Ödeme</span>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            let lastTouchEnd = 0;
            document.addEventListener('touchend', function (event) {
                const now = Date.now();
                if (now - lastTouchEnd <= 280) {
                    event.preventDefault();
                }
                lastTouchEnd = now;
            }, { passive: false });

            const tabs = document.querySelectorAll('[data-auth-tabs] .auth-tab');
            const panels = document.querySelectorAll('.user-auth-shell .auth-panel');

            function switchPanel(id) {
                tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.target === id));
                panels.forEach(panel => panel.classList.toggle('active', panel.id === id));
            }

            tabs.forEach(tab => {
                tab.addEventListener('click', () => switchPanel(tab.dataset.target));
            });

            document.querySelectorAll('[data-switch-tab]').forEach(button => {
                button.addEventListener('click', () => switchPanel(button.dataset.switchTab));
            });

            document.querySelectorAll('[data-toggle-target]').forEach(button => {
                button.addEventListener('click', function () {
                    const input = document.getElementById(this.dataset.toggleTarget);
                    const icon = this.querySelector('i');
                    if (!input || !icon) {
                        return;
                    }

                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    icon.className = isPassword ? 'far fa-eye-slash' : 'far fa-eye';
                });
            });

            const loginForm = document.getElementById('userLoginForm');
            loginForm?.addEventListener('submit', function () {
                const submitButton = this.querySelector('.auth-submit-btn');
                if (submitButton) {
                    submitButton.disabled = true;
                    submitButton.innerHTML = 'Giriş yapılıyor <i class="fas fa-spinner fa-spin"></i>';
                }
            });

            const registerForm = document.getElementById('userRegisterForm');
            registerForm?.addEventListener('submit', function () {
                const submitButton = this.querySelector('.auth-submit-btn');
                if (submitButton) {
                    submitButton.disabled = true;
                    submitButton.innerHTML = 'Kayıt oluşturuluyor <i class="fas fa-spinner fa-spin"></i>';
                }
            });

            const query = new URLSearchParams(window.location.search);
            const shouldOpenRegister = '@(TempData["OpenUserRegisterTab"] as string ?? string.Empty)';
            const shouldOpenRegisterFromUrl = query.get('sekme') === 'kayit' || window.location.hash === '#kayit-ol';
            if (shouldOpenRegister === '1' || shouldOpenRegisterFromUrl) {
                switchPanel('registerPanel');
            }
        })();
    </script>
}

