@model otelturizmnew.Models.Giris.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<section class="auth-shell user-auth-shell">
    <div class="auth-standalone-panel">
        <div class="divider-line"><span>şifre sıfırlama bağlantısı isteyin</span></div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/sifremi-unuttum">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Email">E-posta Adresiniz</label>
                <div class="input-wrap">
                    <i class="far fa-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                </div>
                <p class="auth-inline-hint">Şifre sıfırlama bağlantısı 1 saat boyunca geçerli olacak şekilde e-posta adresinize gönderilir.</p>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Şifre Sıfırlama Linki Gönder <i class="fas fa-arrow-right"></i></button>
                <a href="/kullanici-giris" class="text-link">Giriş ekranına dön</a>
            </div>
        </form>
    </div>
</section>
