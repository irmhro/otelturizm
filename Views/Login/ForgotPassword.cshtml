@model otelturizmnew.Models.Giris.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="auth-card auth-card--solo">
    <div class="auth-form-panel auth-form-panel--solo">
        <div class="auth-solo-head">
            <span class="auth-solo-kicker">Hesap</span>
            <h1 class="auth-solo-title">Şifremi Unuttum</h1>
            <p class="auth-solo-desc">Şifre sıfırlama bağlantısı 1 saat geçerli olacak şekilde e-posta adresinize gönderilir.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/sifremi-unuttum">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Email">E-posta Adresiniz</label>
                <div class="input-wrap">
                    <i class="far fa-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="email" />
                </div>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Şifre Sıfırlama Linki Gönder <i class="fas fa-arrow-right"></i></button>
                <a href="/eposta-dogrula" class="text-link">E-postamı onayla</a>
                <a href="/kullanici-giris" class="text-link">Giriş ekranına dön</a>
            </div>
        </form>
    </div>
</div>
