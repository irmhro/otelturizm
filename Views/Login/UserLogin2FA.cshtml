@model otelturizmnew.Models.Giris.LoginTwoFactorViewModel
@{
    ViewData["Title"] = "Güvenlik Kodu";
}

<section class="auth-shell user-auth-shell">
    <div class="auth-standalone-panel">
        <div class="divider-line"><span>@Model.ChannelLabel güvenlik kodu</span></div>

        @if (TempData["UserLoginError"] is string loginError)
        {
            <div class="auth-alert">@loginError</div>
        }
        @if (TempData["UserLoginSuccess"] is string loginSuccess)
        {
            <div class="auth-alert success">@loginSuccess</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/kullanici-giris-2fa">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Code">Güvenlik Kodu</label>
                <div class="input-wrap">
                    <i class="fas fa-shield-check"></i>
                    <input asp-for="Code" class="form-control" placeholder="Güvenlik kodunu girin" maxlength="8" inputmode="numeric" />
                </div>
                <p class="auth-inline-hint">@Model.InlineHint</p>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Girişi Tamamla <i class="fas fa-arrow-right"></i></button>
            </div>
        </form>

        <form method="post" action="/kullanici-giris-2fa/tekrar-gonder" style="margin-top:16px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="text-button">Kodu tekrar gönder</button>
        </form>
    </div>
</section>

