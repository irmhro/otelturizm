@model otelturizmnew.Models.Giris.LoginTwoFactorViewModel
@{
    ViewData["Title"] = "Güvenlik Kodu";
}

<div class="auth-card auth-card--solo">
    <div class="auth-form-panel auth-form-panel--solo">
        <div class="auth-solo-head">
            <span class="auth-solo-kicker">Güvenlik</span>
            <h1 class="auth-solo-title">@Model.ChannelLabel Güvenlik Kodu</h1>
            <p class="auth-solo-desc">@Model.InlineHint</p>
        </div>

        @if (TempData["UserLoginError"] is string loginError)
        {
            <div class="auth-alert">@loginError</div>
        }
        @if (TempData["UserLoginSuccess"] is string loginSuccess)
        {
            <div class="auth-alert auth-alert-success">@loginSuccess</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/kullanici-giris-2fa">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Code">Güvenlik Kodu</label>
                <div class="input-wrap">
                    <i class="fas fa-shield-halved"></i>
                    <input asp-for="Code" class="form-control" placeholder="Güvenlik kodunu girin" maxlength="8" inputmode="numeric" autocomplete="one-time-code" />
                </div>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">Girişi Tamamla <i class="fas fa-arrow-right"></i></button>
            </div>
        </form>

        <form method="post" action="/kullanici-giris-2fa/tekrar-gonder" class="auth-resend-verify-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane"></i> Kodu tekrar gönder</button>
        </form>
    </div>
</div>
