@{
    ViewData["Title"] = "Admin Giriş";
}

<div class="auth-card auth-card-admin">
    <div class="auth-layout">
        <div class="auth-form-panel">
            <div class="auth-form-header">
                <h3><i class="fas fa-lock"></i> Yönetici Girişi</h3>
                <p>Yetkili admin paneli erişimi için bilgilerinizi girin.</p>
            </div>

            @if (TempData["AdminLoginError"] is string loginError)
            {
                <div class="auth-alert">@loginError</div>
            }

            <form class="auth-form" id="adminLoginForm" method="post" asp-controller="Auth" asp-action="AdminLogin">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="adminEmail">E-posta Adresiniz</label>
                    <input id="adminEmail" name="adminEmail" type="email" class="form-control" placeholder="admin@otelturizm.com" required />
                </div>
                <div class="form-group">
                    <label for="adminPassword">Şifreniz</label>
                    <div class="input-wrap password-wrapper">
                        <input id="adminPassword" name="adminPassword" type="password" class="form-control" placeholder="••••••••" required />
                        <button type="button" class="toggle-password" data-toggle-target="adminPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
                    </div>
                </div>
                <div class="form-row-meta">
                    <label class="checkbox-inline">
                        <input type="checkbox" name="rememberMe" value="true" checked />
                        <span>Bu cihazı 30 gün hatırla</span>
                    </label>
                    <a asp-controller="Auth" asp-action="UserLogin" class="text-link">Normal kullanıcı girişi</a>
                </div>
                <button type="submit" class="auth-submit-btn">Yönetici Girişi <i class="fas fa-arrow-right"></i></button>
            </form>

            <div class="auth-admin-note">
                <i class="fas fa-info-circle"></i>
                Bu ekran sadece admin ve yönetici ekip kullanıcıları içindir. Başarılı girişten sonra doğrudan admin paneline yönlendirilirsiniz.
                <a asp-controller="Home" asp-action="Index">Ana siteye dön</a>
            </div>

            <div class="legal-note">
                <span><i class="fas fa-lock"></i> SSL</span>
                <span><i class="fas fa-database"></i> KVKK</span>
                <span><i class="fas fa-shield-alt"></i> 256-bit</span>
            </div>
        </div>

        <aside class="auth-info">
            <div>
                <div class="auth-info-logo">
                    <partial name="~/Views/Anasayfa/_AnasayfaLogo.cshtml" />
                    <small>Admin</small>
                </div>
                <span class="auth-info-badge">Yönetici</span>
                <h2>Admin Paneli</h2>
                <p class="tagline">Tüm sistemi tek noktadan yönetin, performansı anlık takip edin.</p>
                <ul class="benefits-list">
                    <li><i class="fas fa-chart-pie"></i> Genel istatistikler ve raporlar</li>
                    <li><i class="fas fa-hotel"></i> Otel ve kullanıcı yönetimi</li>
                    <li><i class="fas fa-calendar-alt"></i> Rezervasyon onay süreçleri</li>
                    <li><i class="fas fa-coins"></i> Komisyon ve ödeme takibi</li>
                    <li><i class="fas fa-headset"></i> Öncelikli destek hattı</li>
                </ul>
            </div>
            <div class="trust-badges">
                <span><i class="fas fa-shield-alt"></i> SSL</span>
                <span><i class="fas fa-history"></i> Oturum logları</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        document.getElementById('adminLoginForm')?.addEventListener('submit', function () {
            const btn = this.querySelector('.auth-submit-btn');
            if (btn) { btn.disabled = true; btn.innerHTML = 'Giriş doğrulanıyor <i class="fas fa-spinner fa-spin"></i>'; }
        });
    </script>
}
