@model otelturizmnew.Models.Giris.EmailVerificationViewModel
@{
    ViewData["Title"] = "E-posta Doğrula";
}

<div class="auth-card auth-card--solo auth-card--verify">
    <div class="auth-form-panel auth-form-panel--solo">
        <div class="auth-solo-head">
            <span class="auth-solo-kicker">Doğrulama</span>
            <h1 class="auth-solo-title">E-posta Adresinizi Onaylayın</h1>
            <p class="auth-solo-desc">Kayıt sonrası e-postanıza gelen 6 haneli kodu girin veya maildeki bağlantıya tıklayın.</p>
        </div>

        <div class="info-banner auth-verify-banner" role="note">
            <i class="fas fa-circle-info" aria-hidden="true"></i>
            <span>Kod birkaç dakika içinde gelmezse spam klasörünü kontrol edin veya aşağıdan yeni kod isteyin.</span>
        </div>

        @if (TempData["UserLoginError"] is string loginError)
        {
            <div class="auth-alert">@loginError</div>
        }
        @if (TempData["UserLoginSuccess"] is string loginSuccess)
        {
            <div class="auth-alert auth-alert-success">@loginSuccess</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form auth-form--verify" method="post" action="/eposta-dogrula">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="Email">E-posta Adresiniz</label>
                <div class="input-wrap">
                    <i class="far fa-envelope" aria-hidden="true"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="email" inputmode="email" />
                </div>
            </div>

            <div class="form-group form-group--otp">
                <label asp-for="Code">Doğrulama Kodu</label>
                <input asp-for="Code" class="form-control form-control--otp" placeholder="000000" maxlength="8" inputmode="numeric" autocomplete="one-time-code" aria-label="6 haneli doğrulama kodu" />
                <p class="auth-inline-hint">E-postanızdaki 6 haneli kodu boşluksuz girin.</p>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">E-postayı Doğrula <i class="fas fa-arrow-right" aria-hidden="true"></i></button>
            </div>
        </form>

        <div class="auth-verify-footer">
            <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane" aria-hidden="true"></i> Kodu tekrar gönder</button>
            </form>
            <a href="/kullanici-giris" class="text-link auth-verify-back-link">Giriş ekranına dön</a>
        </div>
    </div>
</div>
