@model otelturizmnew.Models.Giris.EmailVerificationViewModel
@{
    ViewData["Title"] = "E-posta Doğrula";
}

<section class="auth-shell user-auth-shell">
    <div class="auth-standalone-panel">
        <div class="divider-line"><span>e-posta adresinizi onaylayın</span></div>

        @if (TempData["UserLoginError"] is string loginError)
        {
            <div class="auth-alert">@loginError</div>
        }
        @if (TempData["UserLoginSuccess"] is string loginSuccess)
        {
            <div class="auth-alert auth-alert-success">@loginSuccess</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/eposta-dogrula">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="Email">E-posta Adresiniz</label>
                <div class="input-wrap">
                    <i class="far fa-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Code">Doğrulama Kodu</label>
                <div class="input-wrap">
                    <i class="fas fa-shield-check"></i>
                    <input asp-for="Code" class="form-control" placeholder="6 haneli kod" maxlength="8" />
                </div>
                <p class="auth-inline-hint">Kayıt sonrası e-posta adresinize gönderilen 6 haneli kodu girin. İsterseniz mail içindeki bağlantıya da tıklayabilirsiniz.</p>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">E-postayı Doğrula <i class="fas fa-arrow-right"></i></button>
            </div>
        </form>

        <form method="post" action="/eposta-dogrula/tekrar-gonder" style="margin-top:16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@Model.Email" />
            <button type="submit" class="text-button">Kodu tekrar gönder</button>
        </form>
    </div>
</section>
