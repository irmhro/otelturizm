@model otelturizmnew.Models.Giris.EmailVerificationViewModel
@{
    ViewData["Title"] = "E-posta Doğrula";
}

<div class="auth-card auth-card--solo">
    <div class="auth-form-panel auth-form-panel--solo">
        <div class="auth-solo-head">
            <span class="auth-solo-kicker">Doğrulama</span>
            <h1 class="auth-solo-title">E-posta Adresinizi Onaylayın</h1>
            <p class="auth-solo-desc">Kayıt sonrası e-postanıza gelen 6 haneli kodu girin veya maildeki bağlantıya tıklayın.</p>
        </div>

        @if (TempData["UserLoginError"] is string loginError)
        {
            <div class="auth-alert">@loginError</div>
        }
        @if (TempData["UserLoginSuccess"] is string loginSuccess)
        {
            <div class="auth-alert auth-alert-success">@loginSuccess</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">@Html.ValidationSummary(false)</div>
        }

        <form class="auth-form" method="post" action="/eposta-dogrula">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="Email">E-posta Adresiniz</label>
                <div class="input-wrap">
                    <i class="far fa-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="email" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Code">Doğrulama Kodu</label>
                <div class="input-wrap">
                    <i class="fas fa-shield-halved"></i>
                    <input asp-for="Code" class="form-control" placeholder="6 haneli kod" maxlength="8" inputmode="numeric" autocomplete="one-time-code" />
                </div>
            </div>

            <div class="auth-form-actions">
                <button type="submit" class="auth-submit-btn">E-postayı Doğrula <i class="fas fa-arrow-right"></i></button>
            </div>
        </form>

        <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@Model.Email" />
            <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane"></i> Kodu tekrar gönder</button>
        </form>
    </div>
</div>
