@{
    ViewData["Title"] = "Partner Giriş";
    var showResendVerifyButton = string.Equals(TempData["ShowResendVerifyButton"] as string, "1", StringComparison.Ordinal);
    var resendVerifyEmail = TempData["ResendVerifyEmail"] as string ?? string.Empty;
    var partnerRegisterSuccessMessage = TempData["PartnerRegisterSuccess"] as string;
    var partnerRegisterSuccessEmail = TempData["PartnerRegisterSuccessEmail"] as string ?? string.Empty;
}

<div class="auth-card">
    <div class="auth-layout">
        <div class="auth-form-panel">
            <div class="auth-tab-buttons" data-auth-tabs>
                <button type="button" class="auth-tab-btn active" data-target="partnerLoginPanel">Extranet Girişi</button>
                <button type="button" class="auth-tab-btn" data-target="partnerRegisterPanel">Partner Kaydı</button>
            </div>

            <div class="auth-form-panel-block active" id="partnerLoginPanel">
                <div class="info-banner">
                    <i class="fas fa-info-circle"></i>
                    <span>Extranet üzerinden rezervasyon, fiyat, oda ve operasyon kayıtlarını yönetebilirsiniz.</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(partnerRegisterSuccessMessage))
                {
                    <div class="auth-alert auth-alert-success">@partnerRegisterSuccessMessage</div>
                }

                @if (TempData["PartnerLoginError"] is string partnerLoginError)
                {
                    <div class="auth-alert">@partnerLoginError</div>
                    @if (showResendVerifyButton && !string.IsNullOrWhiteSpace(resendVerifyEmail))
                    {
                        <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@resendVerifyEmail" />
                            <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane"></i> Onaylama E-postası Gönder</button>
                        </form>
                    }
                }

                <div class="auth-form-hint"><i class="fas fa-building"></i> Otel hesabınızla giriş yapın</div>

                <form class="auth-form" id="partnerLoginForm" method="post" action="/partner-giris">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="partnerIdentity">E-posta Adresiniz</label>
                        <input id="partnerIdentity" name="partnerIdentity" type="email" class="form-control" placeholder="ornek@otel.com" value="@resendVerifyEmail" autocomplete="email" required />
                    </div>
                    <div class="form-group">
                        <label for="partnerPassword">Şifreniz</label>
                        <div class="input-wrap password-wrapper">
                            <input id="partnerPassword" name="partnerPassword" type="password" class="form-control" placeholder="••••••••" required />
                            <button type="button" class="toggle-password" data-toggle-target="partnerPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-row-meta">
                        <label class="checkbox-inline">
                            <input type="checkbox" name="rememberMe" value="true" checked />
                            <span>Beni hatırla</span>
                        </label>
                        <a href="/sifremi-unuttum" class="text-link">Şifremi unuttum</a>
                    </div>
                    <button type="submit" class="auth-submit-btn">Panele Giriş Yap <i class="fas fa-arrow-right"></i></button>
                </form>
                <p class="auth-helper">Henüz partner değil misiniz? <button type="button" class="text-button" data-switch-tab="partnerRegisterPanel">Hemen kayıt olun</button></p>
            </div>

            <div class="auth-form-panel-block" id="partnerRegisterPanel">
                <partial name="~/Views/Register/_PartnerRegisterForm.cshtml" />
            </div>

            <div class="legal-note">
                <span><i class="fas fa-lock"></i> SSL</span>
                <span><i class="fas fa-database"></i> KVKK</span>
                <span><i class="fas fa-shield-alt"></i> 3D Secure</span>
            </div>
        </div>

        <aside class="auth-info">
            <div>
                <div class="auth-info-logo">
                    <partial name="~/Views/Anasayfa/_AnasayfaLogo.cshtml" />
                    <small>Partner</small>
                </div>
                <span class="auth-info-badge">Extranet</span>
                <h2>Partner Paneli</h2>
                <p class="tagline">Otel yönetimini kolaylaştırın, rezervasyonlarınızı tek noktadan takip edin.</p>
                <ul class="benefits-list">
                    <li><i class="fas fa-chart-simple"></i> Anlık doluluk ve gelir takibi</li>
                    <li><i class="fas fa-tags"></i> Kendi fiyat ve kampanyalarınızı yönetin</li>
                    <li><i class="fas fa-calendar-alt"></i> Tüm rezervasyonlar tek panelde</li>
                    <li><i class="fas fa-chart-pie"></i> Detaylı komisyon raporları</li>
                    <li><i class="fas fa-headset"></i> 7/24 öncelikli destek</li>
                </ul>
            </div>
            <div class="trust-badges">
                <span><i class="fas fa-shield-alt"></i> TURSAB</span>
                <span><i class="fas fa-lock"></i> PCI DSS</span>
            </div>
        </aside>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(partnerRegisterSuccessMessage))
{
    <div class="partner-register-done" id="partnerRegisterDonePopup" role="dialog" aria-modal="true" aria-labelledby="partnerRegisterDoneTitle">
        <div class="partner-register-done__card">
            <button type="button" class="partner-register-done__close" data-partner-done-close aria-label="Kapat"><i class="fas fa-times"></i></button>
            <span class="partner-register-done__icon"><i class="fas fa-check"></i></span>
            <p class="partner-register-done__kicker">Başvurunuz tamamlandı</p>
            <h2 id="partnerRegisterDoneTitle">Partner başvurunuz güvenli şekilde alındı.</h2>
            <p>@partnerRegisterSuccessMessage Sözleşme ve KVKK paketi PDF ekleriyle e-posta kuyruğuna alındı.</p>
            <a class="partner-register-done__action" href="/eposta-dogrula?email=@Uri.EscapeDataString(partnerRegisterSuccessEmail)">E-posta doğrulamasına devam et</a>
        </div>
    </div>
}

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const query = new URLSearchParams(window.location.search);
            if (query.get('sekme') === 'kayit' || window.location.hash === '#partner-kayit') {
                document.querySelector('[data-auth-tabs] [data-target="partnerRegisterPanel"]')?.click();
            }
            const shouldOpenRegister = '@(TempData["OpenPartnerRegisterTab"] as string ?? string.Empty)';
            if (shouldOpenRegister === '1') {
                document.querySelector('[data-auth-tabs] [data-target="partnerRegisterPanel"]')?.click();
            }

            document.getElementById('partnerLoginForm')?.addEventListener('submit', function () {
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Giriş yapılıyor <i class="fas fa-spinner fa-spin"></i>'; }
            });

            const registerForm = document.getElementById('partnerRegisterForm');
            const draftCookieName = 'ot_partner_register_draft';
            const successPopup = document.getElementById('partnerRegisterDonePopup');

            function setDraftCookie(value, maxAge) {
                document.cookie = draftCookieName + '=' + encodeURIComponent(value) + '; Max-Age=' + maxAge + '; Path=/; SameSite=Lax; Secure';
            }
            function readDraftCookie() {
                return document.cookie.split('; ').find(x => x.startsWith(draftCookieName + '='))?.split('=').slice(1).join('=') || '';
            }
            function persistPartnerDraft() {
                if (!registerForm) return;
                const data = {};
                registerForm.querySelectorAll('input,select,textarea').forEach(function (field) {
                    if (!field.name || field.name === '__RequestVerificationToken' || field.type === 'password') return;
                    data[field.name] = field.type === 'checkbox' ? field.checked : field.value;
                });
                setDraftCookie(JSON.stringify(data), 86400);
            }
            function restorePartnerDraft() {
                if (!registerForm) return;
                const raw = readDraftCookie();
                if (!raw) return;
                try {
                    const data = JSON.parse(decodeURIComponent(raw));
                    Object.keys(data).forEach(function (name) {
                        const field = registerForm.querySelector('[name="' + CSS.escape(name) + '"]');
                        if (!field || field.type === 'password') return;
                        if (field.type === 'checkbox') field.checked = !!data[name];
                        else if (field.tagName === 'SELECT' && field.options.length <= 1) field.dataset.restoreValue = data[name] || '';
                        else field.value = data[name] || '';
                    });
                } catch (_error) {}
            }
            restorePartnerDraft();
            registerForm?.addEventListener('input', persistPartnerDraft);
            registerForm?.addEventListener('change', persistPartnerDraft);
            registerForm?.addEventListener('submit', function () {
                persistPartnerDraft();
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Partner hesabı oluşturuluyor <i class="fas fa-spinner fa-spin"></i>'; }
            });

            if (successPopup) {
                setDraftCookie('', 0);
                document.body.classList.add('partner-register-done-open');
                successPopup.querySelector('[data-partner-done-close]')?.addEventListener('click', function () {
                    successPopup.remove();
                    document.body.classList.remove('partner-register-done-open');
                });
            }

            if (window.otelturizmInitAuthAddressLookup) {
                window.otelturizmInitAuthAddressLookup({
                    countryId: 'partnerCountry',
                    provinceId: 'partnerCity',
                    districtId: 'partnerDistrict',
                    neighborhoodId: 'partnerNeighborhood',
                    defaultCountryIso: 'TR'
                }).catch(console.error);
            }
        })();
    </script>
}
