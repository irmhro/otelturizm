@{
    ViewData["Title"] = "Firma Giriş";
    var showResendVerifyButton = string.Equals(TempData["ShowResendVerifyButton"] as string, "1", StringComparison.Ordinal);
    var resendVerifyEmail = TempData["ResendVerifyEmail"] as string ?? string.Empty;
}

<div class="auth-card">
    <div class="auth-layout">
        <div class="auth-form-panel">
            <div class="auth-tab-buttons" data-auth-tabs>
                <button type="button" class="auth-tab-btn active" data-target="firmaLoginPanel">Firma Girişi</button>
                <button type="button" class="auth-tab-btn" data-target="firmaRegisterPanel">Firma Hesabı Açın</button>
            </div>

            <div class="auth-form-panel-block active" id="firmaLoginPanel">
                @if (TempData["FirmaRegisterSuccess"] is string successMessage)
                {
                    <div class="auth-alert auth-alert-success">@successMessage</div>
                }

                @if (TempData["FirmaLoginError"] is string loginError)
                {
                    <div class="auth-alert">@loginError</div>
                    @if (showResendVerifyButton && !string.IsNullOrWhiteSpace(resendVerifyEmail))
                    {
                        <form method="post" action="/eposta-dogrula/tekrar-gonder" class="auth-resend-verify-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@resendVerifyEmail" />
                            <button type="submit" class="auth-resend-verify-btn"><i class="fas fa-paper-plane"></i> Onaylama E-postası Gönder</button>
                        </form>
                    }
                }

                <div class="auth-form-hint"><i class="fas fa-building"></i> Onaylı firma hesabı ile giriş yapın</div>

                <form class="auth-form" id="firmaLoginForm" method="post" action="/firma-giris">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="firmaIdentity">Yetkili E-posta</label>
                        <input id="firmaIdentity" name="firmaIdentity" type="email" class="form-control" placeholder="yetkili@firma.com" value="@resendVerifyEmail" required />
                    </div>
                    <div class="form-group">
                        <label for="firmaLoginPassword">Şifre</label>
                        <div class="input-wrap password-wrapper">
                            <input id="firmaLoginPassword" name="firmaPassword" type="password" class="form-control" placeholder="••••••••" required />
                            <button type="button" class="toggle-password" data-toggle-target="firmaLoginPassword" aria-label="Şifreyi göster"><i class="far fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-row-meta">
                        <label class="checkbox-inline">
                            <input type="checkbox" name="rememberMe" value="true" checked />
                            <span>Beni hatırla</span>
                        </label>
                        <a href="/sifremi-unuttum" class="text-link">Şifremi unuttum</a>
                    </div>
                    <button type="submit" class="auth-submit-btn">Firma Paneline Giriş Yap <i class="fas fa-arrow-right"></i></button>
                </form>
                <p class="auth-helper">Henüz firma hesabınız yok mu? <button type="button" class="text-button" data-switch-tab="firmaRegisterPanel">Hemen başvurun</button></p>
            </div>

            <div class="auth-form-panel-block" id="firmaRegisterPanel">
                <partial name="~/Views/Register/_FirmaRegisterForm.cshtml" />
            </div>

            <div class="legal-note">
                <span><i class="fas fa-shield-alt"></i> KVKK</span>
                <span><i class="fas fa-building-shield"></i> Kurumsal Doğrulama</span>
                <span><i class="fas fa-file-signature"></i> Onaylı Erişim</span>
            </div>
        </div>

        <aside class="auth-info">
            <div>
                <h2>İş seyahatlerinizi tek panelden yönetin</h2>
                <p class="tagline">Firma hesabınızı açın, onay sonrasında özel fiyatlar ve rapor ekranlarıyla ilerleyin.</p>
                <ul class="benefits-list">
                    <li><i class="fas fa-tags"></i> Firmalara özel indirimli fiyatlar</li>
                    <li><i class="fas fa-user-group"></i> Çalışan limit ve onay akışları</li>
                    <li><i class="fas fa-file-invoice"></i> Kurumsal fatura ve rezervasyon geçmişi</li>
                    <li><i class="fas fa-shield-check"></i> Onaylı hesap ile güvenli giriş</li>
                </ul>
            </div>
            <div class="trust-badges">
                <span><i class="fas fa-clock"></i> Ortalama onay: 24 saat</span>
                <span><i class="fas fa-circle-check"></i> Onaylı erişim</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const query = new URLSearchParams(window.location.search);
            const shouldOpenRegister = '@(TempData["OpenFirmaRegisterTab"] as string ?? string.Empty)';
            if (shouldOpenRegister === '1' || query.get('sekme') === 'kayit' || window.location.hash === '#firma-kayit') {
                document.querySelector('[data-auth-tabs] [data-target="firmaRegisterPanel"]')?.click();
            }

            document.getElementById('firmaLoginForm')?.addEventListener('submit', function () {
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Giriş doğrulanıyor <i class="fas fa-spinner fa-spin"></i>'; }
            });

            document.getElementById('firmaRegisterForm')?.addEventListener('submit', function () {
                const btn = this.querySelector('.auth-submit-btn');
                if (btn) { btn.disabled = true; btn.innerHTML = 'Başvuru oluşturuluyor <i class="fas fa-spinner fa-spin"></i>'; }
            });

            if (window.otelturizmInitAuthAddressLookup) {
                window.otelturizmInitAuthAddressLookup({
                    countryId: 'firmaCountry',
                    provinceId: 'firmaCity',
                    districtId: 'firmaDistrict',
                    neighborhoodId: 'firmaNeighborhood',
                    postalCodeId: 'firmaPostalCode',
                    defaultCountryIso: 'TR'
                }).catch(console.error);
            }
        })();
    </script>
}
