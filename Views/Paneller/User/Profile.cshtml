@model otelturizmnew.Models.Paneller.User.UserProfilePageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Profil Bilgilerim";
}

<div class="user-profile-page">
    <section class="profile-hero">
        <div class="profile-identity">
            <div class="profile-avatar-xl">
                <img src="@Model.ProfileImageUrl" alt="Profil görseli" data-profile-preview-image />
            </div>
            <div>
                <p class="page-pretitle">PROFİL MERKEZİ</p>
                <h1>@Model.Form.FirstName @Model.Form.LastName</h1>
                <div class="profile-contact-stack">
                    <div class="profile-contact-row">
                        <span class="profile-contact-value">@Model.Form.Email</span>
                        <span class="profile-status @(Model.EmailVerified ? "is-ok" : "is-warn")"><i class="fas @(Model.EmailVerified ? "fa-circle-check" : "fa-clock")"></i>@(Model.EmailVerified ? "E-posta doğrulandı" : "E-posta doğrulama bekliyor")</span>
                    </div>
                    <div class="profile-contact-row">
                        <span class="profile-contact-value">@Model.Form.Phone</span>
                        <span class="profile-status tone-@Model.PhoneVerification.StatusToneClass"><i class="fas fa-mobile-screen-button"></i>@Model.PhoneVerification.StatusText</span>
                    </div>
                </div>
            </div>
        </div>
        <form method="post" asp-action="UploadProfileImage" enctype="multipart/form-data" class="profile-upload-card" data-panel-auto-upload data-panel-auto-upload-reload="false" data-panel-auto-upload-success="Profil görseliniz kaydedildi.">
            @Html.AntiForgeryToken()
            <strong>Profil görseli</strong>
            <span>Görsel seçildiğinde otomatik yüklenir. Dosyalar güvenli alanda tutulur.</span>
            <div class="profile-upload-actions">
                <label class="profile-file-picker">
                    <input type="file" name="profileImage" accept="image/jpeg,image/png,image/webp,image/gif" data-profile-image-input />
                    <i class="fas fa-cloud-arrow-up"></i>
                    <span data-profile-file-label>Görsel seç</span>
                </label>
            </div>
        </form>
    </section>

    @if (Model.UploadedProfileAvatars.Count > 0)
    {
    <section class="profile-preset-card">
        <div class="profile-preset-head">
            <h2>Profil görselleri</h2>
            <p>Bir görsele dokunarak profil resminizi değiştirin.</p>
        </div>
        <div class="profile-avatar-picker-grid" data-profile-avatar-grid>
            @foreach (var avatar in Model.UploadedProfileAvatars)
            {
                <article class="profile-avatar-picker-tile @(avatar.IsCurrent ? "is-current" : string.Empty)" data-avatar-file-id="@avatar.FileId">
                    <form method="post" asp-action="SelectUploadedProfileImage" class="profile-avatar-picker-select-form" data-panel-auto-action="select" data-panel-auto-action-reload="false" data-panel-auto-action-success="Profil görseliniz güncellendi.">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="fileId" value="@avatar.FileId" />
                    </form>
                    <button type="button"
                            class="profile-avatar-picker-tile-btn"
                            data-profile-avatar-select
                            data-image-url="@avatar.AccessUrl"
                            aria-label="@(avatar.IsCurrent ? "Aktif profil görseli" : "Profil görseli olarak seç")"
                            aria-pressed="@(avatar.IsCurrent ? "true" : "false")"
                            disabled="@(avatar.IsCurrent ? "disabled" : null)">
                        <img src="@avatar.AccessUrl" alt="@avatar.OriginalFileName" loading="lazy" />
                        @if (avatar.IsCurrent)
                        {
                            <span class="profile-avatar-picker-badge" aria-hidden="true"><i class="fas fa-check"></i></span>
                        }
                        else
                        {
                            <span class="profile-avatar-picker-hover" aria-hidden="true">Seç</span>
                        }
                    </button>
                    <span class="profile-avatar-picker-date">@avatar.UploadedAtText</span>
                    <form method="post" asp-action="DeleteProfileImage" class="profile-avatar-picker-delete" data-panel-auto-action="delete" data-panel-auto-action-reload="false">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="fileId" value="@avatar.FileId" />
                        <button type="submit" class="profile-avatar-picker-delete-btn" aria-label="Görseli sil" title="Sil">
                            <i class="fas fa-trash-can"></i>
                        </button>
                    </form>
                </article>
            }
        </div>
    </section>
    }

    <form method="post" asp-action="SaveProfile" class="profile-form" data-panel-auto-save data-panel-auto-save-success="Profil bilgileriniz kaydedildi.">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

        <article class="profile-panel profile-travel-panel">
            <div class="profile-panel-head">
                <div>
                    <h2>Kişisel Bilgiler</h2>
                    <p>Değişiklikler otomatik kaydedilir.</p>
                </div>
            </div>
            <div class="profile-form-grid">
                <label><span>Ad</span><input class="form-control" asp-for="Form.FirstName" type="text" data-panel-autosave="blur" /></label>
                <label><span>Soyad</span><input class="form-control" asp-for="Form.LastName" type="text" data-panel-autosave="blur" /></label>
                <label lang="tr-TR"><span>Doğum Tarihi</span><input class="form-control" asp-for="Form.BirthDateText" type="date" lang="tr-TR" autocomplete="bday" title="gg/aa/yyyy" required data-panel-autosave="change" /></label>
                <label><span>Telefon</span><input class="form-control" asp-for="Form.Phone" type="text" data-panel-autosave="blur" /></label>
                <label><span>TC Kimlik No</span><input class="form-control" asp-for="Form.IdentityNumber" type="text" maxlength="11" data-panel-autosave="blur" /></label>
                <label>
                    <span>Cinsiyet</span>
                    <select class="form-select" asp-for="Form.Gender" required data-panel-autosave="change">
                        <option value="">Seçiniz</option>
                        <option value="Erkek">Erkek</option>
                        <option value="Kadın">Kadın</option>
                        <option value="Belirtmek İstemiyorum">Belirtmek İstemiyorum</option>
                    </select>
                </label>
                <label>
                    <span>Uyruk</span>
                    <select class="form-select" asp-for="Form.Nationality" id="userCountrySelect" data-panel-autosave="change">
                        <option value="">Seçiniz</option>
                        @foreach (var country in Model.Countries)
                        {
                            <option value="@country.Name" data-country-id="@country.Id" data-iso2="@country.Iso2" selected="@(string.Equals(Model.Form.Nationality, country.Name, StringComparison.OrdinalIgnoreCase))">@country.Name</option>
                        }
                    </select>
                </label>
                <label><span>Posta Kodu</span><input class="form-control" asp-for="Form.PostalCode" type="text" data-panel-autosave="blur" /></label>
                <label class="profile-field-full">
                    <span>E-posta</span>
                    <div class="profile-email-field">
                        <input class="form-control" asp-for="Form.Email" type="email" required readonly="@(Model.EmailVerified ? "readonly" : null)" />
                        <span class="profile-status @(Model.EmailVerified ? "is-ok" : "is-warn")">@(Model.EmailVerified ? "Onaylandı" : "Bekliyor")</span>
                    </div>
                    <small>@(Model.EmailVerified ? $"Onay tarihi: {Model.EmailVerifiedAtText}" : "Bu e-posta henüz doğrulanmadı.")</small>
                </label>
                <input type="hidden" id="userSelectedProvinceId" value="@(Model.SelectedProvinceId?.ToString() ?? string.Empty)" />
                <input type="hidden" id="userSelectedDistrictId" value="@(Model.SelectedDistrictId?.ToString() ?? string.Empty)" />
                <input type="hidden" id="userSelectedNeighborhoodId" value="@(Model.SelectedNeighborhoodId?.ToString() ?? string.Empty)" />
                <label>
                    <span id="userProvinceLabel">İl</span>
                    <select class="form-select" asp-for="Form.City" id="userProvinceSelect" required data-panel-autosave="change">
                        <option value="">Seçiniz</option>
                        @foreach (var province in Model.Provinces)
                        {
                            <option value="@province.Name" data-province-id="@province.Id" data-region-type="@province.RegionType" selected="@(string.Equals(Model.Form.City, province.Name, StringComparison.OrdinalIgnoreCase))">@province.Name</option>
                        }
                    </select>
                </label>
                <label id="userDistrictField">
                    <span>İlçe</span>
                    <select class="form-select" asp-for="Form.District" id="userDistrictSelect" data-selected-text="@Model.Form.District" required data-panel-autosave="change">
                        <option value="">Önce il seçiniz</option>
                    </select>
                </label>
                <label id="userNeighborhoodField">
                    <span>Mahalle</span>
                    <select class="form-select" asp-for="Form.Neighborhood" id="userNeighborhoodSelect" data-selected-text="@Model.Form.Neighborhood" required data-panel-autosave="change">
                        <option value="">Önce ilçe seçiniz</option>
                    </select>
                </label>
                <label class="profile-field-full"><span>Adres</span><textarea class="form-control" asp-for="Form.Address" rows="3" data-panel-autosave="blur"></textarea></label>
            </div>
        </article>
    </form>

    @if (Model.EmailVerified)
    {
        <article class="profile-panel email-update-card @(Model.OpenEmailUpdate ? "email-update-open" : string.Empty)">
            <div class="profile-panel-head profile-email-update-head">
                <div>
                    <h2>E-posta adresimi güncelle</h2>
                    <p>Yeni adres doğrulama kodu ile güvenli şekilde aktif edilir.</p>
                </div>
                <span class="profile-status is-ok"><i class="fas fa-shield-halved"></i> Güvenli doğrulama</span>
            </div>
            <div class="profile-email-update-steps">
                <section class="profile-email-step">
                    <div class="profile-email-step-head">
                        <span class="profile-email-step-no" aria-hidden="true">1</span>
                        <div>
                            <strong>Doğrulama kodu gönder</strong>
                            <p>Yeni e-posta adresinize kod iletilecek.</p>
                        </div>
                    </div>
                    <form method="post" asp-action="SendEmailUpdateCode" class="profile-email-step-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EmailUpdate.ReturnUrl" value="@Model.ReturnUrl" />
                        <label class="profile-email-field-label" for="newEmail">
                            <span>Yeni E-posta</span>
                            <input class="form-control" id="newEmail" type="email" name="EmailUpdate.NewEmail" placeholder="yeni@email.com" autocomplete="email" required />
                        </label>
                        <button type="submit" class="btn-primary-ap profile-email-action-btn">
                            <i class="fas fa-paper-plane" aria-hidden="true"></i>
                            <span>Kod Gönder</span>
                        </button>
                    </form>
                </section>
                <section class="profile-email-step">
                    <div class="profile-email-step-head">
                        <span class="profile-email-step-no" aria-hidden="true">2</span>
                        <div>
                            <strong>Doğrula ve güncelle</strong>
                            <p>E-posta ve gelen kodu girerek işlemi tamamlayın.</p>
                        </div>
                    </div>
                    <form method="post" asp-action="VerifyEmailUpdateCode" class="profile-email-step-form profile-email-step-form-verify">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EmailUpdateVerify.ReturnUrl" value="@Model.ReturnUrl" />
                        <label class="profile-email-field-label" for="verifyNewEmail">
                            <span>Yeni E-posta</span>
                            <input class="form-control" id="verifyNewEmail" type="email" name="EmailUpdateVerify.NewEmail" placeholder="yeni@email.com" autocomplete="email" required />
                        </label>
                        <label class="profile-email-field-label" for="emailCode">
                            <span>Doğrulama Kodu</span>
                            <input class="form-control" id="emailCode" type="text" name="EmailUpdateVerify.Code" inputmode="numeric" maxlength="8" placeholder="6 haneli kod" autocomplete="one-time-code" required />
                        </label>
                        <button type="submit" class="btn-primary-ap profile-email-action-btn">
                            <i class="fas fa-circle-check" aria-hidden="true"></i>
                            <span>Doğrula ve Güncelle</span>
                        </button>
                    </form>
                </section>
            </div>
        </article>
    }

    <form method="post" asp-action="SaveTravelPreferences" class="profile-form" data-panel-auto-save data-panel-auto-save-success="Seyahat tercihleriniz kaydedildi.">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <article class="profile-panel">
            <div class="profile-panel-head">
                <div>
                    <h2>Seyahat Tercihleri</h2>
                    <p>Seçimleriniz otomatik kaydedilir.</p>
                </div>
            </div>
            <div class="profile-form-grid">
                <label>
                    <span>Oda Tercihi</span>
                    <select class="form-select" name="RoomPreference" data-panel-autosave="change">
                        @foreach (var option in Model.RoomPreferenceOptions)
                        {
                            <option value="@option" selected="@(string.Equals(Model.Form.RoomPreference, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Yatak Tercihi</span>
                    <select class="form-select" name="BedPreference" data-panel-autosave="change">
                        @foreach (var option in Model.BedPreferenceOptions)
                        {
                            <option value="@option" selected="@(string.Equals(Model.Form.BedPreference, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                        }
                    </select>
                </label>
                <label class="profile-field-full profile-travel-purpose-field">
                    <span>Seyahat Amacı</span>
                    <small class="profile-travel-purpose-hint">Birden fazla amaç seçebilirsiniz.</small>
                    @{
                        var selectedTravelPurposes = UserPanelService.ParseTravelPurposes(Model.Form.TravelPurpose)
                            .ToHashSet(StringComparer.OrdinalIgnoreCase);
                    }
                    <input type="hidden"
                           name="TravelPurpose"
                           id="travelPurposeValue"
                           value="@Model.Form.TravelPurpose"
                           data-panel-autosave="change" />
                    <div class="profile-travel-purpose-grid" role="group" aria-label="Seyahat amacı seçimi">
                        @foreach (var option in Model.TravelPurposeOptions)
                        {
                            var isSelected = selectedTravelPurposes.Contains(option);
                            <label class="profile-travel-purpose-pill @(isSelected ? "is-selected" : string.Empty)">
                                <input type="checkbox"
                                       value="@option"
                                       data-travel-purpose-option
                                       @(isSelected ? "checked" : null) />
                                <span>@option</span>
                            </label>
                        }
                    </div>
                </label>
                <label>
                    <span>Konuşulan Dil</span>
                    <select class="form-select" name="SpokenLanguages" data-panel-autosave="change">
                        @foreach (var option in Model.SpokenLanguageOptions)
                        {
                            <option value="@option" selected="@(string.Equals(Model.Form.SpokenLanguages, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                        }
                    </select>
                </label>
                <label class="profile-field-full"><span>Özel İstekler</span><textarea class="form-control" name="SpecialRequests" rows="3" data-panel-autosave="blur">@Model.Form.SpecialRequests</textarea></label>
            </div>
        </article>
    </form>
</div>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        const input = document.querySelector('[data-profile-image-input]');
        const image = document.querySelector('[data-profile-preview-image]');
        const label = document.querySelector('[data-profile-file-label]');
        if (!input || !image) return;

        input.addEventListener('change', function () {
            const file = input.files && input.files[0];
            if (!file) return;

            const allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
            const maxBytes = 10 * 1024 * 1024;
            const ok = allowed.includes((file.type || '').toLowerCase()) && file.size <= maxBytes;
            if (!ok) {
                window.OtPanelToast?.show('Lütfen JPG/PNG/WebP/GIF formatında ve en fazla 10 MB bir görsel seçin.', 'danger');
                input.value = '';
                if (label) label.textContent = 'Görsel seç';
                return;
            }

            if (label) label.textContent = file.name;
            const previewUrl = URL.createObjectURL(file);
            image.onload = function () { URL.revokeObjectURL(previewUrl); };
            image.src = previewUrl;
        });

        const uploadForm = input.closest('[data-panel-auto-upload]');
        uploadForm?.addEventListener('panel-auto-upload:success', function (event) {
            const serverUrl = event.detail?.payload?.imageUrl;
            if (serverUrl) image.src = serverUrl;
        });
    })();

    (function () {
        const grid = document.querySelector('[data-profile-avatar-grid]');
        if (!grid) return;

        const syncTileState = (activeTile) => {
            grid.querySelectorAll('.profile-avatar-picker-tile').forEach((tile) => {
                const isCurrent = tile === activeTile;
                tile.classList.toggle('is-current', isCurrent);

                const selectBtn = tile.querySelector('[data-profile-avatar-select]');
                if (!selectBtn) return;

                selectBtn.disabled = isCurrent;
                selectBtn.setAttribute('aria-pressed', isCurrent ? 'true' : 'false');
                selectBtn.setAttribute(
                    'aria-label',
                    isCurrent ? 'Aktif profil görseli' : 'Profil görseli olarak seç'
                );

                let badge = selectBtn.querySelector('.profile-avatar-picker-badge');
                let hover = selectBtn.querySelector('.profile-avatar-picker-hover');

                if (isCurrent) {
                    if (!badge) {
                        badge = document.createElement('span');
                        badge.className = 'profile-avatar-picker-badge';
                        badge.setAttribute('aria-hidden', 'true');
                        badge.innerHTML = '<i class="fas fa-check"></i>';
                        selectBtn.appendChild(badge);
                    }
                    if (hover) hover.remove();
                } else {
                    if (badge) badge.remove();
                    if (!hover) {
                        hover = document.createElement('span');
                        hover.className = 'profile-avatar-picker-hover';
                        hover.setAttribute('aria-hidden', 'true');
                        hover.textContent = 'Seç';
                        selectBtn.appendChild(hover);
                    }
                }
            });
        };

        grid.querySelectorAll('[data-profile-avatar-select]').forEach((button) => {
            button.addEventListener('click', () => {
                if (button.disabled) return;
                const tile = button.closest('.profile-avatar-picker-tile');
                const form = tile?.querySelector('.profile-avatar-picker-select-form');
                if (!form) return;
                form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            });
        });

        grid.addEventListener('panel-auto-action:success', (event) => {
            const action = event.detail?.action;
            const form = event.detail?.form;

            if (action === 'delete') {
                const tile = form?.closest('.profile-avatar-picker-tile');
                tile?.remove();
                if (!grid.querySelector('.profile-avatar-picker-tile')) {
                    grid.closest('.profile-preset-card')?.remove();
                }
                return;
            }

            if (action !== 'select') return;

            const tile = form?.closest('.profile-avatar-picker-tile');
            const imageUrl = tile?.querySelector('[data-profile-avatar-select]')?.dataset.imageUrl;
            const preview = document.querySelector('[data-profile-preview-image]');
            if (preview && imageUrl) preview.src = imageUrl;
            if (tile) syncTileState(tile);
        });
    })();

    (function () {
        const countrySelect = document.getElementById('userCountrySelect');
        const provinceSelect = document.getElementById('userProvinceSelect');
        const districtSelect = document.getElementById('userDistrictSelect');
        const neighborhoodSelect = document.getElementById('userNeighborhoodSelect');
        const provinceLabel = document.getElementById('userProvinceLabel');
        const districtField = document.getElementById('userDistrictField');
        const neighborhoodField = document.getElementById('userNeighborhoodField');
        const selectedProvinceId = document.getElementById('userSelectedProvinceId')?.value || '';
        const selectedDistrictId = document.getElementById('userSelectedDistrictId')?.value || '';

        if (!provinceSelect || !districtSelect || !neighborhoodSelect) return;

        const selectedCountryIso = function () {
            const opt = countrySelect?.selectedOptions[0];
            return (opt?.dataset.iso2 || '').toUpperCase();
        };

        const isTurkey = function () {
            return selectedCountryIso() === 'TR';
        };

        const syncTurkeyFields = function () {
            const tr = isTurkey();
            if (districtField) districtField.style.display = tr ? '' : 'none';
            if (neighborhoodField) neighborhoodField.style.display = tr ? '' : 'none';
            districtSelect.required = tr;
            neighborhoodSelect.required = tr;
            if (!tr) {
                districtSelect.value = '';
                neighborhoodSelect.value = '';
                districtSelect.innerHTML = '<option value="">Türkiye dışı adreslerde ilçe seçilmez</option>';
                neighborhoodSelect.innerHTML = '<option value="">Türkiye dışı adreslerde mahalle seçilmez</option>';
            }
        };

        const loadProvinces = async function (countryId, selectedText) {
            provinceSelect.innerHTML = '<option value="">Yükleniyor...</option>';
            districtSelect.innerHTML = '<option value="">Önce il/eyalet seçiniz</option>';
            neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
            if (!countryId) {
                provinceSelect.innerHTML = '<option value="">Önce ülke seçiniz</option>';
                return;
            }
            const response = await fetch('/api/adres/iller?ulkeId=' + encodeURIComponent(countryId), { credentials: 'same-origin' });
            const items = response.ok ? await response.json() : [];
            const regionType = (items[0] && items[0].regionType) ? items[0].regionType : (isTurkey() ? 'IL' : 'EYALET');
            if (provinceLabel) {
                provinceLabel.textContent = regionType === 'EYALET' ? 'Eyalet' : 'İl';
            }
            provinceSelect.innerHTML = buildOptions(items, isTurkey() ? 'İl seçiniz' : 'Eyalet seçiniz', selectedText || '', 'id', 'name');
            syncTurkeyFields();
        };

        const buildOptions = function (items, placeholder, selectedValue, idField, nameField) {
            const options = ['<option value="">' + placeholder + '</option>'];
            items.forEach(function (item) {
                const value = item[nameField] || '';
                const selected = selectedValue && value === selectedValue ? ' selected' : '';
                const idVal = item[idField] ?? item[idField === 'id' ? 'Id' : idField];
                const dataIdAttr = idVal ? ' data-id="' + idVal + '"' : '';
                const provinceAttr = (idField === 'id' && idVal) ? ' data-province-id="' + idVal + '"' : '';
                options.push('<option value="' + value.replace(/"/g, '&quot;') + '"' + dataIdAttr + provinceAttr + selected + '>' + value + '</option>');
            });
            return options.join('');
        };

        const loadNeighborhoods = async function (districtId, selectedText) {
            neighborhoodSelect.innerHTML = '<option value="">Yükleniyor...</option>';
            if (!districtId) {
                neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
                return;
            }
            const response = await fetch('/api/adres/mahalleler?ilceId=' + encodeURIComponent(districtId), { credentials: 'same-origin' });
            const items = response.ok ? await response.json() : [];
            neighborhoodSelect.innerHTML = buildOptions(items, 'Mahalle seçiniz', selectedText || neighborhoodSelect.dataset.selectedText || '', 'id', 'name');
        };

        const loadDistricts = async function (provinceId, selectedText) {
            districtSelect.innerHTML = '<option value="">Yükleniyor...</option>';
            neighborhoodSelect.innerHTML = '<option value="">Önce ilçe seçiniz</option>';
            if (!provinceId) {
                districtSelect.innerHTML = '<option value="">Önce il seçiniz</option>';
                return;
            }
            const response = await fetch('/api/adres/ilceler?ilId=' + encodeURIComponent(provinceId), { credentials: 'same-origin' });
            const items = response.ok ? await response.json() : [];
            districtSelect.innerHTML = buildOptions(items, 'İlçe seçiniz', selectedText || districtSelect.dataset.selectedText || '', 'id', 'name');
            const currentDistrictId = selectedDistrictId || districtSelect.selectedOptions[0]?.dataset.id || '';
            if (currentDistrictId) await loadNeighborhoods(currentDistrictId, neighborhoodSelect.dataset.selectedText || '');
        };

        if (countrySelect) {
            countrySelect.addEventListener('change', async function () {
                const countryId = countrySelect.selectedOptions[0]?.dataset.countryId || '';
                provinceSelect.dataset.selectedText = '';
                districtSelect.dataset.selectedText = '';
                neighborhoodSelect.dataset.selectedText = '';
                await loadProvinces(countryId, '');
            });
        }

        provinceSelect.addEventListener('change', async function () {
            const provinceId = provinceSelect.selectedOptions[0]?.dataset.provinceId || provinceSelect.selectedOptions[0]?.dataset.id || '';
            districtSelect.dataset.selectedText = '';
            neighborhoodSelect.dataset.selectedText = '';
            if (!isTurkey()) return;
            await loadDistricts(provinceId, '');
        });

        districtSelect.addEventListener('change', async function () {
            const districtId = districtSelect.selectedOptions[0]?.dataset.id || '';
            neighborhoodSelect.dataset.selectedText = '';
            await loadNeighborhoods(districtId, '');
        });

        syncTurkeyFields();
        const initialCountryId = countrySelect?.selectedOptions[0]?.dataset.countryId || '';
        if (initialCountryId && provinceSelect.options.length <= 1) {
            loadProvinces(initialCountryId, provinceSelect.dataset.selectedText || '');
        }
        const initialProvinceId = selectedProvinceId || provinceSelect.selectedOptions[0]?.dataset.provinceId || provinceSelect.selectedOptions[0]?.dataset.id || '';
        if (initialProvinceId && isTurkey()) loadDistricts(initialProvinceId, districtSelect.dataset.selectedText || '');
    })();

    (function () {
        const hidden = document.getElementById('travelPurposeValue');
        const grid = document.querySelector('.profile-travel-purpose-grid');
        if (!hidden || !grid) return;

        const syncHidden = () => {
            const selected = Array.from(grid.querySelectorAll('[data-travel-purpose-option]:checked'))
                .map(input => input.value.trim())
                .filter(Boolean);
            hidden.value = selected.join('|');
            hidden.dispatchEvent(new Event('change', { bubbles: true }));
        };

        grid.addEventListener('change', function (event) {
            const checkbox = event.target.closest('[data-travel-purpose-option]');
            if (!checkbox) return;
            checkbox.closest('.profile-travel-purpose-pill')
                ?.classList.toggle('is-selected', checkbox.checked);
            syncHidden();
        });
    })();
</script>
