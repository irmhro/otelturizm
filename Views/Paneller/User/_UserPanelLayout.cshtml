@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@inject otelturizmnew.Services.Abstractions.IReservationDraftService ReservationDraftService
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@inject otelturizmnew.Services.Abstractions.IUserPanelService UserPanelService
@inject otelturizmnew.Services.Abstractions.IPanelThemeService PanelThemeService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string ?? ViewData["PageCss"] as string;
    var pageCssMobilePath = ViewData["PageCssMobilePath"] as string ?? ViewData["PageCssMobile"] as string;
    var title = ViewData["Title"] as string ?? ViewData["PanelTitle"] as string ?? "Kullanıcı Paneli";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var hideLayoutHeader = string.Equals(currentAction, "Dashboard", StringComparison.OrdinalIgnoreCase);

    var userRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var userId = long.TryParse(userRaw, out var parsedUserId) ? parsedUserId : 0;
    var userDraftUserId = userId > 0 ? userId : (long?)null;
    var userDraftSessionKey = Context.Request.Cookies.TryGetValue(otelturizmnew.Services.ReservationDraftService.DraftCookieName, out var userDraftCookieValue)
        ? userDraftCookieValue
        : null;
    var userActiveDraft = await ReservationDraftService.GetActiveDraftAsync(userDraftUserId, userDraftSessionKey, Context.RequestAborted);
    var profileImageUrl = userId > 0 ? await UserPanelService.GetProfileImageUrlAsync(userId, Context.RequestAborted) : string.Empty;
    ViewData["UserProfileImageUrl"] = profileImageUrl;

    if (userId > 0)
    {
        var needsFavorite = ViewData["FavoriteCount"] is not int;
        var needsReservation = ViewData["ReservationCount"] is not int;
        var needsMessage = ViewData["MessageCount"] is not int;
        if (needsFavorite || needsReservation || needsMessage)
        {
            var badges = await UserPanelService.GetNavBadgeCountsAsync(userId, Context.RequestAborted);
            if (needsFavorite) { ViewData["FavoriteCount"] = badges.FavoriteCount; }
            if (needsReservation) { ViewData["ReservationCount"] = badges.TotalReservations; }
            if (needsMessage) { ViewData["MessageCount"] = badges.MessageThreads; }
        }

        if (ViewData["UserLoyaltyTierName"] is not string)
        {
            var loyaltyChip = await UserPanelService.GetLoyaltyTierChipAsync(userId, Context.RequestAborted);
            ViewData["UserLoyaltyTierName"] = loyaltyChip.TierName;
            ViewData["UserLoyaltyPoints"] = loyaltyChip.AvailablePoints;
        }
    }

    var theme = userId > 0 ? await PanelThemeService.LoadAsync("user", userId, Context.RequestAborted) : new otelturizmnew.Models.Paneller.Partner.PanelThemeViewModel();
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme is not ("light" or "dark" or "auto")) { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";
    var nonce = Context.Items["CspNonce"] as string;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : theme?.PrimaryHex;
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--ap-primary-red: {accentHex};");
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--ap-sidebar-bg: {theme!.SidebarBgHex};");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily)) parts.Add($"font-family: {theme!.FontFamily}, Inter, sans-serif;");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" asp-append-version="true" />
    <partial name="~/Views/Shared/_VendorPlusJakartaFont.cshtml" />
    <link rel="stylesheet" href="~/assets/css/kullanici_panel_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/kullanici_panel_mobil.css" asp-append-version="true" media="(max-width: 991px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.mobile.css" asp-append-version="true" media="(max-width: 991px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.mobile.css" asp-append-version="true" media="(max-width: 991px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/ot-geo-prompt.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        var pageCssMobileHref = !string.IsNullOrWhiteSpace(pageCssMobilePath)
            ? $"~/assets/css/{pageCssMobilePath}.css"
            : $"~/assets/css/{pageCssPath}.mobile.css";
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="@pageCssMobileHref" asp-append-version="true" media="(max-width: 991px)" />
    }
</head>
<body class="kullanici-panel-shell" style="@BuildThemeStyle()">
    <div class="admin-shell-container">
        <partial name="~/Views/Paneller/User/_UserSidebar.cshtml" />
        <div class="admin-sidebar-backdrop" id="userSidebarBackdrop" aria-hidden="true"></div>

        <div class="main-layout">
            <partial name="~/Views/Paneller/User/_UserTopNav.cshtml" />

            <main class="content-body">
                @if (!hideLayoutHeader)
                {
                    var panelTitle = ViewData["PanelTitle"] as string;
                    var panelSubtitle = ViewData["PanelSubtitle"] as string;
                    if (!string.IsNullOrWhiteSpace(panelTitle))
                    {
                        <div class="ap-page-header d-print-none">
                            <div>
                                <div class="ap-page-pretitle">Misafir Portalı</div>
                                <h1>@panelTitle</h1>
                                @if (!string.IsNullOrWhiteSpace(panelSubtitle))
                                {
                                    <p>@panelSubtitle</p>
                                }
                            </div>
                        </div>
                    }
                }
                @if (userActiveDraft is not null && ViewData["ShowGlobalDraftBanner"] as bool? == true)
                {
                    <partial name="~/Views/Shared/_ActiveReservationDraftBanner.cshtml" model="userActiveDraft" />
                }
                <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
                @RenderBody()
            </main>

            <partial name="~/Views/Paneller/User/_UserPanelFooter.cshtml" />
            @if (userId > 0)
            {
                <partial name="~/Views/Paneller/User/_UserMobileNav.cshtml" />
            }

            <div class="admin-theme-backdrop" id="userThemeBackdrop" aria-hidden="true"></div>
            <aside class="admin-theme-drawer" id="userThemeSettings" aria-labelledby="userThemeSettingsLabel" aria-hidden="true">
                <div class="admin-theme-drawer-header">
                    <h2 id="userThemeSettingsLabel">Tema Ayarları</h2>
                    <button type="button" class="admin-theme-close" id="userThemeClose" aria-label="Kapat"><i class="fas fa-times"></i></button>
                </div>
                <div class="admin-theme-drawer-body">
                    <form method="post" action="/panel/user/tema/kaydet">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <input type="hidden" name="PrimaryHex" id="userThemePrimaryHex" value="@(theme?.PrimaryHex ?? string.Empty)" />
                        <input type="hidden" name="AccentHex" id="userThemeAccentHex" value="@(theme?.AccentHex ?? theme?.PrimaryHex ?? string.Empty)" />
                        <input type="hidden" name="SidebarBgHex" id="userThemeSidebarBgHex" value="@(theme?.SidebarBgHex ?? string.Empty)" />
                        <label class="form-group"><span>Renk modu</span></label>
                        <div class="ap-theme-options">
                            <label class="ap-theme-option">
                                <input type="radio" name="BsTheme" value="light" @(string.Equals(bsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                <span><i class="fas fa-sun"></i> Açık</span>
                            </label>
                            <label class="ap-theme-option">
                                <input type="radio" name="BsTheme" value="dark" @(string.Equals(bsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                <span><i class="fas fa-moon"></i> Koyu</span>
                            </label>
                        </div>
                        <label class="form-group"><span>Ana renk</span></label>
                        <div class="ap-color-swatches" data-color-palette="user-primary">
                            @foreach (var color in new[] { "#DC2626", "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#8b5cf6", "#334155" })
                            {
                                <button type="button" class="btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                            }
                        </div>
                        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Temayı Kaydet</button>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
    <script src="~/assets/js/kullanici_panel-shell.js" asp-append-version="true"></script>
    <script nonce="@nonce">
    (() => {
        const primaryInput = document.getElementById('userThemePrimaryHex');
        const accentInput = document.getElementById('userThemeAccentHex');
        document.querySelectorAll('[data-color-palette="user-primary"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                document.documentElement.style.setProperty('--ap-primary-red', hex);
            });
        });
    })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
