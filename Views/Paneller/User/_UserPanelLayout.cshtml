@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@inject otelturizmnew.Services.Abstractions.IReservationDraftService ReservationDraftService
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string ?? ViewData["PageCss"] as string;
    var title = ViewData["Title"] as string ?? ViewData["PanelTitle"] as string ?? "Kullanıcı Paneli";
    var userDraftRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    long? userDraftUserId = long.TryParse(userDraftRaw, out var parsedUserDraftUserId) ? parsedUserDraftUserId : null;
    var userDraftSessionKey = Context.Request.Cookies.TryGetValue(otelturizmnew.Services.ReservationDraftService.DraftCookieName, out var userDraftCookieValue)
        ? userDraftCookieValue
        : null;
    var userActiveDraft = await ReservationDraftService.GetActiveDraftAsync(userDraftUserId, userDraftSessionKey, Context.RequestAborted);
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.User, userDraftUserId ?? 0, Context.RequestAborted);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    
    
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/assets/css/panel-user-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-user-shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body>
    <div class="dashboard-shell">
        <partial name="~/Views/Paneller/User/_UserSidebar.cshtml" />

        <main class="dashboard-main">
            <header class="dashboard-page-header">
                <div>
                    <p class="dashboard-kicker">USER PANEL</p>
                    <h1>@ViewData["PanelTitle"]</h1>
                    <p class="dashboard-sub">@ViewData["PanelSubtitle"]</p>
                </div>

                <div class="dashboard-header-tools">
                    <div class="dashboard-search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Panel icinde ara..." />
                    </div>
                    <partial name="~/Views/Shared/_HeaderBildiri.cshtml" model="headerBildiri" />
                    <form method="post" action="/cikis-yap" class="panel-header-logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="panel-header-logout-btn">
                            <i class="fas fa-right-from-bracket"></i>
                            <span>Cikis Yap</span>
                        </button>
                    </form>
                </div>
            </header>

            @if (userActiveDraft is not null)
            {
                <partial name="~/Views/Shared/_ActiveReservationDraftBanner.cshtml" model="userActiveDraft" />
            }

            <partial name="~/Views/Paneller/User/_UserRouteHub.cshtml" />

            @RenderBody()
        </main>
    </div>

    <partial name="~/Views/Paneller/User/_UserMobileNav.cshtml" />
    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>




