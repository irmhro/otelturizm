@model otelturizmnew.Models.Paneller.User.UserInvoicesPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Faturalarım";
}

<div class="user-invoices-page">
    <section class="user-invoices-hero">
        <div>
            <div class="page-pretitle">FİNANS</div>
            <h1>Faturalarım</h1>
            <p class="text-muted mb-0">Tamamlanan konaklamalarınıza ait otel tarafından yüklenen fatura belgelerini indirin.</p>
        </div>
        <a class="btn btn-outline-primary btn-pill" href="/panel/user/odeme-yontemleri"><i class="fas fa-credit-card me-2"></i>Fatura bilgilerim</a>
    </section>

    @if (Model.TableMissing)
    {
        <div class="user-invoices-empty">
            <i class="fas fa-database me-2"></i>Fatura tablosu henüz hazır değil. Migration uygulandıktan sonra liste görünecek.
        </div>
    }
    else if (Model.Rows.Count == 0)
    {
        <div class="user-invoices-empty">
            <i class="fas fa-file-invoice me-2"></i>Tamamlanan konaklamanız için henüz yüklenmiş fatura bulunmuyor.
        </div>
    }
    else
    {
        <div class="user-invoices-table-wrap">
            <div class="table-responsive">
                <table class="table table-vcenter user-invoices-table user-table--cards mb-0">
                    <thead>
                        <tr>
                            <th>Rez. No</th>
                            <th>Otel</th>
                            <th>Tarih</th>
                            <th>Tutar</th>
                            <th>Fatura</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td data-label="Rez. No"><strong>@row.ReservationNo</strong></td>
                                <td data-label="Otel">@row.HotelName</td>
                                <td data-label="Tarih">@row.StayText</td>
                                <td data-label="Tutar">@row.TotalText</td>
                                <td data-label="Fatura">
                                    @if (row.HasInvoice)
                                    {
                                        <span class="user-invoice-badge user-invoice-badge--ok"><i class="fas fa-circle-check"></i>Yüklendi</span>
                                    }
                                    else
                                    {
                                        <span class="user-invoice-badge user-invoice-badge--wait"><i class="fas fa-clock"></i>Bekleniyor</span>
                                    }
                                </td>
                                <td class="text-end" data-label="İşlem">
                                    @if (row.HasInvoice && !string.IsNullOrWhiteSpace(row.DownloadUrl))
                                    {
                                        @if (row.IsPdf)
                                        {
                                            <a class="btn btn-sm btn-outline-primary btn-pill" href="@row.DownloadUrl" target="_blank" rel="noopener">Görüntüle</a>
                                        }
                                        <a class="btn btn-sm btn-primary btn-pill user-invoice-btn-download" href="@row.DownloadUrl" target="_blank" rel="noopener">İndir</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="user-invoices-mobile-list">
            @foreach (var row in Model.Rows)
            {
                <article class="user-invoice-card @(row.HasInvoice ? "user-invoice-card--ok" : "user-invoice-card--wait")">
                    <div class="user-invoice-card-top">
                        <div>
                            <strong>@row.HotelName</strong>
                            <small>@row.ReservationNo · @row.StayText</small>
                        </div>
                        @if (row.HasInvoice)
                        {
                            <span class="user-invoice-badge user-invoice-badge--ok"><i class="fas fa-circle-check"></i>Var</span>
                        }
                        else
                        {
                            <span class="user-invoice-badge user-invoice-badge--wait"><i class="fas fa-clock"></i>Bekliyor</span>
                        }
                    </div>
                    <div class="user-invoice-card-meta">
                        <span><i class="fas fa-coins me-2"></i>@row.TotalText</span>
                        @if (!string.IsNullOrWhiteSpace(row.UploadedAtText))
                        {
                            <span><i class="fas fa-cloud-arrow-up me-2"></i>@row.UploadedAtText</span>
                        }
                    </div>
                    <div class="user-invoice-card-actions">
                        <a class="btn btn-outline-primary btn-pill" href="/panel/user/rezervasyonlarim">Rezervasyon</a>
                        @if (row.HasInvoice && !string.IsNullOrWhiteSpace(row.DownloadUrl))
                        {
                            @if (row.IsPdf)
                            {
                                <a class="btn btn-outline-primary btn-pill user-invoice-btn-touch" href="@row.DownloadUrl" target="_blank" rel="noopener"><i class="fas fa-eye me-2"></i>Görüntüle</a>
                            }
                            <a class="btn btn-primary btn-pill user-invoice-btn-download" href="@row.DownloadUrl" target="_blank" rel="noopener"><i class="fas fa-download me-2"></i>İndir</a>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>
