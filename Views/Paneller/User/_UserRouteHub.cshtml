@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var favoriteCount = ViewData["FavoriteCount"] as int? ?? 0;
    var reservationCount = ViewData["ReservationCount"] as int? ?? 0;
    var messageCount = ViewData["MessageCount"] as int? ?? 0;
}

<section class="panel-route-hub" aria-label="Kullanıcı paneli hızlı menü">
    <div class="route-hub-block">
        <p class="route-hub-caption">Ana Menu</p>
        <div class="route-hub-grid">
            <a asp-action="Index" class="route-hub-link @(currentAction == "Index" ? "active" : "")">
                <i class="fas fa-columns"></i>
                <span>Dashboard</span>
            </a>
            <a asp-action="Reservations" class="route-hub-link @(currentAction == "Reservations" ? "active" : "")">
                <i class="fas fa-calendar-check"></i>
                <span>Rezervasyonlarim</span>
                @if (reservationCount > 0)
                {
                    <em>@reservationCount</em>
                }
            </a>
            <a asp-action="Favorites" class="route-hub-link @(currentAction == "Favorites" ? "active" : "")">
                <i class="fas fa-heart"></i>
                <span>Favorilerim</span>
                <em class="ok">@(favoriteCount > 0 ? favoriteCount : 0)</em>
            </a>
            <a asp-action="Loyalty" class="route-hub-link @(currentAction == "Loyalty" ? "active" : "")">
                <i class="fas fa-star"></i>
                <span>Puanlarim</span>
            </a>
            <a asp-action="Messages" class="route-hub-link @(currentAction == "Messages" ? "active" : "")">
                <i class="fas fa-envelope"></i>
                <span>Mesajlarim</span>
                @if (messageCount > 0)
                {
                    <em class="warn">@messageCount</em>
                }
            </a>
        </div>
    </div>

    <div class="route-hub-block">
        <p class="route-hub-caption second">Hesap Ayarlari</p>
        <div class="route-hub-grid settings">
            <a asp-action="Profile" class="route-hub-link @(currentAction == "Profile" ? "active" : "")">
                <i class="fas fa-user-circle"></i>
                <span>Profil Bilgilerim</span>
            </a>
            <a asp-action="PaymentMethods" class="route-hub-link @(currentAction == "PaymentMethods" ? "active" : "")">
                <i class="fas fa-credit-card"></i>
                <span>Odeme Yontemleri</span>
            </a>
            <a asp-action="Notifications" class="route-hub-link @(currentAction == "Notifications" ? "active" : "")">
                <i class="fas fa-bell"></i>
                <span>Bildirim Tercihleri</span>
            </a>
            <a asp-action="Security" class="route-hub-link @(currentAction == "Security" ? "active" : "")">
                <i class="fas fa-shield-alt"></i>
                <span>Guvenlik ve Giris</span>
            </a>
        </div>
    </div>
</section>
