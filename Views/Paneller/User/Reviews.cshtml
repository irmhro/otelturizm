@model otelturizmnew.Models.Paneller.User.UserReviewsPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Yorumlarım";
    var pageStart = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var pageEnd = Math.Min(Model.TotalCount, Model.Page * Model.PageSize);
}

<div class="user-reviews-page">
    @if (TempData["UserReviewSuccess"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="review-alert review-alert--success"><i class="fas fa-check-circle"></i><span>@successMessage</span></div>
    }
    @if (TempData["UserReviewError"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="review-alert review-alert--danger"><i class="fas fa-triangle-exclamation"></i><span>@errorMessage</span></div>
    }

    <section class="reviews-page-hero reviews-page-hero--compact">
        <div class="reviews-page-hero-copy">
            <div class="page-pretitle">Değerlendirmeler</div>
            <p class="reviews-page-hero-lead mb-0">Onaylanmış ve tamamlanmış konaklamalarında tesise yorum yazabilir; yorumunu 7 gün içinde düzenleyebilir veya silebilirsin.</p>
        </div>
        <div class="reviews-page-hero-actions ap-page-hero-actions">
            @if (Model.WaitingReviewCount > 0)
            {
                <a class="btn btn-primary-ap reviews-hero-cta" asp-action="Reviews" asp-route-status="waiting" asp-route-page="1">
                    <i class="fas fa-pen-to-square" aria-hidden="true"></i>
                    <span>@Model.WaitingReviewCount yorum bekliyor</span>
                </a>
            }
            <a class="btn btn-primary-ap reviews-hero-link" href="/hotel">
                <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                <span>Otel Ara</span>
            </a>
            <a class="btn btn-outline-ap reviews-hero-link" asp-action="Reservations">
                <i class="fas fa-calendar-check" aria-hidden="true"></i>
                <span>Rezervasyonlarım</span>
            </a>
        </div>
    </section>

    <section class="reviews-stat-grid" aria-label="Yorum özeti">
        <article class="reviews-stat reviews-stat--all">
            <span><i class="fas fa-list-check" aria-hidden="true"></i></span>
            <div><strong>@Model.EligibleCount</strong><small>Toplam konaklama</small></div>
        </article>
        <article class="reviews-stat reviews-stat--waiting">
            <span><i class="fas fa-hourglass-half" aria-hidden="true"></i></span>
            <div><strong>@Model.WaitingReviewCount</strong><small>Yorum bekleyen</small></div>
        </article>
        <article class="reviews-stat reviews-stat--reviewed">
            <span><i class="fas fa-comment-dots" aria-hidden="true"></i></span>
            <div><strong>@Model.ReviewedCount</strong><small>Yorumlanan</small></div>
        </article>
    </section>

    <section class="reviews-filter-card">
        <div class="reviews-filter-shell">
            <div class="reviews-filter-top">
                <span class="reviews-count-chip">@pageStart-@pageEnd / @Model.TotalCount kayıt</span>
            </div>

            <nav class="reviews-status-tabs reviews-status-tabs--scroll" aria-label="Yorum durumu">
                <a asp-action="Reviews" asp-route-status="all" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "all" ? "is-active" : string.Empty)">
                    Tümü
                    @if (Model.EligibleCount > 0)
                    {
                        <span class="reviews-tab-count">@Model.EligibleCount</span>
                    }
                </a>
                <a asp-action="Reviews" asp-route-status="waiting" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "waiting" ? "is-active" : string.Empty)">
                    Yorum bekleyen
                    @if (Model.WaitingReviewCount > 0)
                    {
                        <span class="reviews-tab-count">@Model.WaitingReviewCount</span>
                    }
                </a>
                <a asp-action="Reviews" asp-route-status="reviewed" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "reviewed" ? "is-active" : string.Empty)">
                    Yorumlanan
                    @if (Model.ReviewedCount > 0)
                    {
                        <span class="reviews-tab-count">@Model.ReviewedCount</span>
                    }
                </a>
            </nav>

            <details class="reviews-filter-drawer">
                <summary><i class="fas fa-search" aria-hidden="true"></i> Arama</summary>
                <form method="get" asp-action="Reviews" class="reviews-filter-form">
                    <input type="hidden" name="status" value="@Model.StatusFilter" />
                    <input type="hidden" name="page" value="1" />
                    <div class="reviews-filter-field reviews-filter-field--search">
                        <label class="form-label">Otel, şehir veya rezervasyon no</label>
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="fas fa-search" aria-hidden="true"></i></span>
                            <input class="form-control" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Örn. Antalya, rezervasyon no" />
                        </div>
                    </div>
                    <div class="reviews-filter-actions ap-page-filter-actions">
                        <button type="submit" class="btn btn-primary-ap"><i class="fas fa-filter" aria-hidden="true"></i> Filtrele</button>
                        <a asp-action="Reviews" class="btn btn-outline-ap">Temizle</a>
                    </div>
                </form>
            </details>

            <p class="reviews-policy-note">
                <i class="fas fa-circle-info" aria-hidden="true"></i>
                <span>Yorum yazabilmek için rezervasyonunun onaylanmış, konaklamanın tamamlanmış ve çıkış tarihinin geçmiş olması gerekir.</span>
            </p>
        </div>
    </section>

    <section class="reviews-list-card">
        <div class="reviews-list-head">
            <h2>Konaklama ve yorumlar</h2>
            <span class="reviews-list-meta">Sayfa @Model.Page / @Model.TotalPages</span>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty reviews-empty">
                <div class="empty-icon"><i class="fas fa-comment-slash" aria-hidden="true"></i></div>
                <p class="empty-title">Kayıt bulunamadı</p>
                <p class="empty-subtitle text-muted">
                    @if (Model.StatusFilter == "waiting")
                    {
                        @:Şu an yorum bekleyen onaylı konaklaman görünmüyor. Tamamlanan konaklamaların burada listelenir.
                    }
                    else if (Model.StatusFilter == "reviewed")
                    {
                        @:Henüz yorum yazdığın bir konaklama yok.
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                    {
                        @:Arama kriterine uygun konaklama bulunamadı. Farklı bir otel adı veya rezervasyon no dene.
                    }
                    else
                    {
                        @:Onaylanmış ve tamamlanmış konaklamaların burada listelenir. Konaklama bittikten sonra &quot;Yorum ekle&quot; ile değerlendirme yapabilirsin.
                    }
                </p>
                <div class="empty-action">
                    @if (Model.WaitingReviewCount > 0)
                    {
                        <a asp-action="Reviews" asp-route-status="waiting" asp-route-page="1" class="btn btn-primary-ap">Yorum bekleyenleri göster</a>
                    }
                    else
                    {
                        <a asp-action="Reservations" class="btn btn-primary-ap">Rezervasyonlarım</a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="reviews-list-horizontal">
                @foreach (var item in Model.Items)
                {
                    <article class="review-row-card review-row-card--@item.ReviewTone">
                        <a class="review-row-media" href="/hotel/@item.HotelSlug">
                            @if (!string.IsNullOrWhiteSpace(item.HotelImageUrl))
                            {
                                <img src="@item.HotelImageUrl" alt="@item.HotelName" loading="lazy" />
                            }
                            else
                            {
                                <span><i class="fas fa-hotel" aria-hidden="true"></i></span>
                            }
                        </a>
                        <div class="review-row-main">
                            <div class="review-row-top">
                                <div class="review-row-titles">
                                    <strong>@item.HotelName</strong>
                                    <small>@item.District, @item.City</small>
                                </div>
                                <span class="review-row-status review-row-status--@item.ReviewTone">@item.ReviewStatusText</span>
                            </div>
                            <div class="review-row-meta">
                                <span><i class="far fa-calendar" aria-hidden="true"></i>@item.StayDateText</span>
                                <span><i class="far fa-moon" aria-hidden="true"></i>@item.RoomName</span>
                                <span><i class="fas fa-hashtag" aria-hidden="true"></i>Rez. @item.ReservationNo</span>
                                <span class="review-row-res-status">@item.ReservationStatusText</span>
                            </div>

                            @if (item.HasReview)
                            {
                                <div class="review-snippet-block">
                                    <div class="review-snippet-head">
                                        <span class="review-snippet-score">@item.ReviewScore.ToString("0.0")<small>/10</small></span>
                                        <span class="review-snippet-date">@item.ReviewDateText</span>
                                    </div>
                                    <p class="review-snippet-text">@item.ReviewSnippet</p>
                                    @if (item.ReviewSnippetTruncated)
                                    {
                                        <span class="review-snippet-hint text-muted">Yorumun bir kısmı gösteriliyor.</span>
                                    }
                                </div>
                            }

                            <div class="review-row-footer">
                                <div class="review-row-actions review-row-actions--primary">
                                    @if (item.CanWriteReview && !item.HasReview)
                                    {
                                        <a class="btn btn-primary-ap" asp-action="ReservationReview" asp-route-reservationId="@item.ReservationId">
                                            <i class="fas fa-plus" aria-hidden="true"></i> Yorum ekle
                                        </a>
                                    }
                                </div>
                                <div class="review-row-actions review-row-actions--secondary">
                                    <a class="btn btn-outline-ap btn-sm" href="/hotel/@item.HotelSlug"><i class="fas fa-hotel" aria-hidden="true"></i> Otel</a>
                                    @if (item.HasReview && item.CanEditReview && item.ReviewId.HasValue)
                                    {
                                        <details class="review-edit-details">
                                            <summary class="btn btn-outline-ap btn-sm review-edit-summary"><i class="fas fa-pen" aria-hidden="true"></i> Düzenle</summary>
                                            <div class="review-edit-panel">
                                                <form method="post" asp-action="UpdateReview" class="review-update-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ReviewId" value="@item.ReviewId.Value" />
                                                    <input type="hidden" name="status" value="@Model.StatusFilter" />
                                                    <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                                    <label class="form-label">Yorum metni</label>
                                                    <textarea name="Comment" class="form-control" rows="4" maxlength="4000" minlength="20" required>@item.ReviewText</textarea>
                                                    <small class="text-muted">En az 20 karakter. @item.EditLimitText tarihine kadar düzenlenebilir.</small>
                                                    <div class="review-edit-panel-foot">
                                                        <button type="submit" class="btn btn-primary-ap btn-sm">Kaydet</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </details>
                                        <form method="post" asp-action="DeleteReview" class="review-delete-inline" onsubmit="return confirm('Yorumu silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ReviewId" value="@item.ReviewId.Value" />
                                            <input type="hidden" name="status" value="@Model.StatusFilter" />
                                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                            <button type="submit" class="btn btn-outline-ap btn-sm review-delete-btn"><i class="fas fa-trash" aria-hidden="true"></i> Sil</button>
                                        </form>
                                    }
                                    else if (item.HasReview && !item.CanEditReview)
                                    {
                                        <span class="review-locked-inline text-muted small"><i class="fas fa-lock" aria-hidden="true"></i> 7 günlük düzenleme süresi doldu</span>
                                    }
                                    else if (!item.HasReview && !item.CanWriteReview)
                                    {
                                        <span class="review-closed-inline text-muted small"><i class="fas fa-ban" aria-hidden="true"></i> Yorum kapalı</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }

        <div class="reviews-pager">
            <div class="reviews-pager-meta">@pageStart-@pageEnd arası · @Model.TotalCount kayıt</div>
            <div class="reviews-pager-actions">
                <a asp-action="Reviews" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Math.Max(1, Model.Page - 1))" class="btn btn-outline-ap btn-sm @(Model.Page <= 1 ? "disabled" : string.Empty)">
                    <i class="fas fa-chevron-left" aria-hidden="true"></i> Önceki
                </a>
                <a asp-action="Reviews" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Math.Min(Model.TotalPages, Model.Page + 1))" class="btn btn-outline-ap btn-sm @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                    Sonraki <i class="fas fa-chevron-right" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </section>
</div>
