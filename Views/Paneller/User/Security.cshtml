@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Güvenlik ve Giriş";
}

<section class="form-stack">
    <article class="panel-card">
        <div class="section-head"><h2>Şifre Guncelle</h2></div>
        <div class="form-grid">
            <label><span>Mevcut Şifre</span><input type="password" value="12345678" /></label>
            <label><span>Yeni Şifre</span><input type="password" value="12345678" /></label>
            <label class="full"><span>Yeni Şifre Tekrar</span><input type="password" value="12345678" /></label>
        </div>
        <div class="save-row"><button type="button" class="primary-btn">Şifreyi Guncelle</button></div>
    </article>

    <article class="panel-card">
        <div class="section-head"><h2>Aktif Oturumlar</h2></div>
        <div class="session-list">
            <div><strong>Windows / Chrome</strong><span>Istanbul · Su an aktif</span></div>
            <div><strong>iPhone / Safari</strong><span>Istanbul · 2 saat once</span></div>
            <div><strong>MacBook / Edge</strong><span>Ankara · 3 gun once</span></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="section-head"><h2>Iki Asamali Dogrulama</h2></div>
        <div class="toggle-row no-border">
            <div><h3>2FA koruması</h3><p>Hesap guvenligini SMS veya uygulama kodu ile guclendir.</p></div>
            <span class="fake-toggle"></span>
        </div>
    </article>
</section>


