@model otelturizmnew.Models.Paneller.User.UserSecurityPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Güvenlik ve Giriş";
}

<div class="user-security-page">
    <section class="security-hero">
        <div>
            <p class="page-pretitle">GÜVENLİK MERKEZİ</p>
            <h1>Hesap erişimini ve doğrulama kanallarını yönet</h1>
            <p>Şifre, aktif oturumlar ve iki aşamalı doğrulama ayarları tek ekranda toplandı.</p>
        </div>
        <div class="security-state-card @(Model.TwoFactorEnabled ? "is-on" : "is-off")">
            <span><i class="fas fa-shield-halved"></i></span>
            <strong>@(Model.TwoFactorEnabled ? "2FA Aktif" : "2FA Kapalı")</strong>
            <small>@(Model.TwoFactorEnabled ? $"Kanal: {Model.SelectedTwoFactorChannel}" : "E-posta doğrulaması önerilir")</small>
        </div>
    </section>

    <form method="post" asp-action="ChangePassword" class="security-panel">
        @Html.AntiForgeryToken()
        <div class="security-panel-head">
            <div>
                <h2>Şifre Güncelle</h2>
                <p>Harf ve rakam içeren güçlü bir şifre kullan.</p>
            </div>
            <button type="submit" class="btn btn-primary">Şifreyi Güncelle</button>
        </div>
        <div class="security-form-grid">
            <label><span>Mevcut Şifre</span><input class="form-control" name="CurrentPassword" type="password" autocomplete="current-password" /></label>
            <label><span>Yeni Şifre</span><input class="form-control" name="NewPassword" type="password" autocomplete="new-password" /></label>
            <label><span>Yeni Şifre Tekrar</span><input class="form-control" name="ConfirmPassword" type="password" autocomplete="new-password" /></label>
        </div>
    </form>

    <form method="post" asp-action="SaveTwoFactor" class="security-panel security-twofactor-form" data-twofactor-form data-enabled="@(Model.TwoFactorEnabled ? "1" : "0")">
        @Html.AntiForgeryToken()
        <div class="security-panel-head">
            <div>
                <h2>İki Aşamalı Doğrulama</h2>
                <p>Girişte şifreden sonra ikinci güvenlik adımı istenir.</p>
            </div>
            <button type="submit" class="btn btn-primary">Güvenlik tercihini kaydet</button>
        </div>

        <label class="security-master-switch">
            <input name="Enabled" type="hidden" value="false" />
            <input name="Enabled" type="checkbox" value="true" @(Model.TwoFactorEnabled ? "checked" : null) />
            <span></span>
            <div>
                <strong>2FA koruması</strong>
                <small>Hesabına girişte ek doğrulama katmanı kullan.</small>
            </div>
        </label>

        <div class="security-channel-grid">
            <label class="security-channel-card @(!Model.EmailUsableForTwoFactor ? "is-disabled" : string.Empty)">
                <input type="radio" name="Channel" value="email" @(Model.SelectedTwoFactorChannel == "email" ? "checked" : null) @(!Model.EmailUsableForTwoFactor ? "disabled" : null) />
                <span class="security-channel-switch"></span>
                <div>
                    <strong>E-posta güvenlik kodu</strong>
                    <small>@(Model.EmailUsableForTwoFactor ? $"Aktif adres: {Model.MaskedEmailAddress}" : "Önce e-posta doğrulaması tamamlanmalı.")</small>
                </div>
                <button class="security-info-button" type="button" data-security-info="email"><i class="fas fa-circle-question"></i>Nasıl çalışır?</button>
            </label>
            <label class="security-channel-card is-disabled">
                <input type="radio" name="Channel" value="whatsapp" disabled />
                <span class="security-channel-switch"></span>
                <div>
                    <strong>Telefon / WhatsApp kodu</strong>
                    <small>Doğrulanmış telefon kanalı geliştirme aşamasında.</small>
                </div>
                <button class="security-info-button" type="button" data-security-info="whatsapp"><i class="fas fa-circle-info"></i>Geliştirme notu</button>
            </label>
            <label class="security-channel-card is-disabled">
                <input type="radio" name="Channel" value="app" disabled />
                <span class="security-channel-switch"></span>
                <div>
                    <strong>Authenticator uygulaması</strong>
                    <small>Uygulama tabanlı doğrulama sonraki geliştirme aşamasında.</small>
                </div>
                <button class="security-info-button" type="button" data-security-info="app"><i class="fas fa-circle-info"></i>Geliştirme notu</button>
            </label>
        </div>
    </form>

    <article class="security-panel">
        <div class="security-panel-head">
            <div>
                <h2>Aktif Oturumlar</h2>
                <p>Son cihaz ve giriş hareketlerini takip et.</p>
            </div>
        </div>
        <div class="security-session-list">
            @if (Model.Sessions.Count == 0)
            {
                <div class="security-session-row">
                    <span><i class="fas fa-laptop"></i></span>
                    <div><strong>Aktif oturum kaydı yok</strong><small>Yeni cihaz girişleri burada görünecek.</small></div>
                </div>
            }
            else
            {
                foreach (var session in Model.Sessions)
                {
                    <div class="security-session-row">
                        <span><i class="fas fa-laptop"></i></span>
                        <div>
                            <strong>@session.DeviceLabel</strong>
                            <small>@session.IpAddress · @session.LoginAtText · @Math.Max(1, session.OpenMinutes) dk açık</small>
                            <small>@session.ActivityText · @session.RememberText</small>
                        </div>
                    </div>
                }
            }
        </div>
    </article>

    <article class="security-panel">
        <div class="security-panel-head">
            <div>
                <h2>Sözleşmeler</h2>
                <p>Hesabınla ilgili sözleşme ve aydınlatma metinlerine buradan erişebilirsin.</p>
            </div>
        </div>
        <div class="security-session-list">
            <div class="security-session-row">
                <span><i class="fas fa-file-signature"></i></span>
                <div>
                    <strong><a class="link-primary" href="/sozlesmeler/kullanici-kullanim-kosullari" target="_blank" rel="noopener">Kullanıcı Kullanım Koşulları</a></strong>
                    <small>Platform üyeliği ve rezervasyon kullanım kuralları.</small>
                </div>
            </div>
            <div class="security-session-row">
                <span><i class="fas fa-shield-halved"></i></span>
                <div>
                    <strong><a class="link-primary" href="/sozlesmeler/kullanici-kvkk-aydinlatma" target="_blank" rel="noopener">Kullanıcı KVKK Aydınlatma Metni</a></strong>
                    <small>6698 sayılı Kanun kapsamında aydınlatma metni.</small>
                </div>
            </div>
        </div>
    </article>
</div>

<dialog class="security-info-dialog" id="securityInfoDialog">
    <div class="security-info-content">
        <button type="button" class="btn btn-icon btn-outline-primary" data-close-security-info aria-label="Kapat"><i class="fas fa-xmark"></i></button>
        <p class="page-pretitle" id="securityInfoPretitle">DOĞRULAMA KANALI</p>
        <h3 id="securityInfoTitle">E-posta doğrulama nasıl çalışır?</h3>
        <p id="securityInfoText">E-posta kanalını açtığınızda girişte şifre doğrulandıktan sonra kayıtlı e-posta adresinize tek kullanımlık güvenlik kodu gönderilir. Kod belirli süre geçerlidir ve başarılı doğrulama sonrası oturum açılır.</p>
    </div>
</dialog>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
(() => {
    const dialog = document.getElementById('securityInfoDialog');
    if (!dialog) return;
    const title = document.getElementById('securityInfoTitle');
    const text = document.getElementById('securityInfoText');
    const content = {
        email: ['E-posta doğrulama nasıl çalışır?', 'E-posta kanalını açtığınızda girişte şifre doğrulandıktan sonra kayıtlı e-posta adresinize tek kullanımlık güvenlik kodu gönderilir. Kod belirli süre geçerlidir ve başarılı doğrulama sonrası oturum açılır.'],
        whatsapp: ['Telefon / WhatsApp kanalı', 'Telefon doğrulama kanalı geliştirme aşamasındadır. Aktif edildiğinde doğrulanmış telefon numaranıza giriş kodu gönderilecek.'],
        app: ['Authenticator uygulaması', 'Uygulama tabanlı doğrulama sonraki geliştirme aşamasındadır. Hazır olduğunda QR kurulum ve yedek kod akışı eklenecek.']
    };
    document.querySelectorAll('[data-security-info]').forEach((button) => {
        button.addEventListener('click', (event) => {
            event.preventDefault();
            const item = content[button.getAttribute('data-security-info')] || content.email;
            title.textContent = item[0];
            text.textContent = item[1];
            dialog.showModal();
        });
    });
    dialog.querySelectorAll('[data-close-security-info]').forEach((button) => button.addEventListener('click', () => dialog.close()));
    dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
    });

    const master = document.querySelector('.security-master-switch input[type="checkbox"]');
    const twoFactorForm = document.querySelector('[data-twofactor-form]');
    const channelRadios = Array.from(document.querySelectorAll('.security-channel-card input[type="radio"][name="Channel"]'));
    const syncTwoFactorUi = () => {
        if (!twoFactorForm || !master) return;
        const enabled = !!master.checked;
        twoFactorForm.setAttribute('data-enabled', enabled ? '1' : '0');
        channelRadios.forEach((radio) => {
            if (!(radio instanceof HTMLInputElement)) return;
            if (radio.disabled) return;
            // Master kapalıyken kanalı seçtirmeyelim; seçim korunur, sadece UI kapalı görünür.
            radio.tabIndex = enabled ? 0 : -1;
        });
    };
    if (master) {
        master.addEventListener('change', syncTwoFactorUi);
    }
    syncTwoFactorUi();
    document.querySelectorAll('.security-channel-card:not(.is-disabled)').forEach((card) => {
        card.addEventListener('click', (event) => {
            if (event.target.closest('[data-security-info]')) return;
            const input = card.querySelector('input[type="radio"]');
            if (input) input.checked = true;
            if (master) master.checked = true;
            syncTwoFactorUi();
        });
    });
})();
</script>
