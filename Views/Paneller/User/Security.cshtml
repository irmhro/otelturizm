@model otelturizmnew.Models.Paneller.User.UserSecurityPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Güvenlik ve Giriş";
}

<section class="form-stack">
    <form method="post" asp-action="ChangePassword" class="panel-card">
        @Html.AntiForgeryToken()
        <div class="section-head"><h2>Şifre Güncelle</h2></div>
        <div class="form-grid">
            <label><span>Mevcut Şifre</span><input name="CurrentPassword" type="password" autocomplete="current-password" /></label>
            <label><span>Yeni Şifre</span><input name="NewPassword" type="password" autocomplete="new-password" /></label>
            <label class="full"><span>Yeni Şifre Tekrar</span><input name="ConfirmPassword" type="password" autocomplete="new-password" /></label>
        </div>
        <div class="save-row"><button type="submit" class="primary-btn">Şifreyi Güncelle</button></div>
    </form>

    <article class="panel-card">
        <div class="section-head"><h2>Aktif Oturumlar</h2></div>
        <div class="session-list">
            @if (Model.Sessions.Count == 0)
            {
                <div><strong>Aktif oturum kaydı yok</strong><span>Yeni cihaz girişleri burada görünecek.</span></div>
            }
            else
            {
                foreach (var session in Model.Sessions)
                {
                    <div>
                        <strong>@session.DeviceLabel</strong>
                        <span>@session.IpAddress · @session.LoginAtText · @Math.Max(1, session.OpenMinutes) dk açık</span>
                        <span>@session.ActivityText · @session.RememberText</span>
                    </div>
                }
            }
        </div>
    </article>

    <form method="post" asp-action="SaveTwoFactor" class="panel-card">
        @Html.AntiForgeryToken()
        <div class="section-head"><h2>İki Aşamalı Doğrulama</h2></div>
        <label class="toggle-row no-border">
            <div><h3>2FA koruması</h3><p>Hesap güvenliğini ikinci doğrulama katmanı ile güçlendir.</p></div>
            <input name="Enabled" type="checkbox" value="true" @(Model.TwoFactorEnabled ? "checked" : null) />
        </label>
        <input name="Enabled" type="hidden" value="false" />
        <div class="form-grid" style="margin-top:18px;">
            <label class="full">
                <span>Doğrulama kanalı</span>
                <div class="radio-stack">
                    <label class="radio-option @(!Model.EmailUsableForTwoFactor ? "is-disabled" : string.Empty)">
                        <input type="radio" name="Channel" value="email" @(Model.SelectedTwoFactorChannel == "email" ? "checked" : null) @(!Model.EmailUsableForTwoFactor ? "disabled" : null) />
                        <span>
                            <strong>E-posta güvenlik kodu</strong>
                            <small>@(Model.EmailUsableForTwoFactor ? $"Aktif adres: {Model.MaskedEmailAddress}" : "Önce e-posta doğrulaması tamamlanmalı.")</small>
                        </span>
                        <span class="twofactor-status @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "on" : "off")">
                            <i class="fas @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "fa-toggle-on" : "fa-toggle-off")"></i>
                            @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "Açık" : "Kapalı")
                        </span>
                    </label>
                    <label class="radio-option @(!Model.PhoneUsableForTwoFactor ? "is-disabled" : string.Empty)">
                        <input type="radio" name="Channel" value="whatsapp" @(Model.SelectedTwoFactorChannel == "whatsapp" ? "checked" : null) @(!Model.PhoneUsableForTwoFactor ? "disabled" : null) />
                        <span>
                            <strong>Telefon / WhatsApp kodu</strong>
                            <small>@(Model.PhoneUsableForTwoFactor ? $"Doğrulanmış numara: {Model.MaskedPhoneNumber}" : "Telefon / WhatsApp altyapısı geliştirilmekte. Doğrulanmış numara gerektirir.")</small>
                        </span>
                        <span class="twofactor-status @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "whatsapp" ? "on" : "off")">
                            <i class="fas @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "whatsapp" ? "fa-toggle-on" : "fa-toggle-off")"></i>
                            @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "whatsapp" ? "Açık" : "Kapalı")
                        </span>
                    </label>
                </div>
            </label>
        </div>
        <p class="auth-inline-hint" style="margin-top:14px;">E-posta kanalını seçerseniz girişte şifre sonrası e-posta kutunuza gelen güvenlik kodunu girersiniz. WhatsApp kanalı beta destek olarak sunulur.</p>
        <div class="save-row"><button type="submit" class="primary-btn">Güvenlik tercihini kaydet</button></div>
    </form>
</section>
