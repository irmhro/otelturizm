@model otelturizmnew.Models.Paneller.User.UserDashboardPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    string MapStatusBadge(string tone) => tone switch
    {
        "danger" => "status-cancel",
        "completed" or "ok" => "status-confirmed",
        "info" => "status-info",
        _ => "status-pending"
    };
}

<section class="kullanici-panel-dashboard">
    <div class="page-header">
        <div>
            <div class="ap-page-pretitle">Misafir Portalı · Kişisel Kokpit</div>
            <h1>Hoş geldin — rezervasyonlarını tek ekrandan yönet</h1>
            <p>Yaklaşan konaklamalar, favori oteller, mesajlar ve tasarruf bilgileri canlı verilerle özetlenir.</p>
        </div>
        <div class="dashboard-header-actions d-flex gap-2">
            <a class="btn-primary-ap" href="/oteller"><i class="fas fa-magnifying-glass"></i> Otel Keşfet</a>
            <a class="btn-outline-ap" href="/panel/user/rezervasyonlarim"><i class="fas fa-calendar-check"></i> Rezervasyonlarım</a>
        </div>
    </div>

    <div class="kpi-grid-pro">
        <a class="kpi-card-pro kpi-warning" href="/panel/user/rezervasyonlarim">
            <div class="kpi-top">
                <span class="kpi-title">Yaklaşan Konaklama</span>
                <div class="kpi-icon icon-warning"><i class="fas fa-suitcase"></i></div>
            </div>
            <div class="kpi-value">@Model.UpcomingReservationCount</div>
            <div class="kpi-bottom up"><i class="fas fa-route"></i> Aktif planlar</div>
        </a>
        <a class="kpi-card-pro kpi-pink" href="/panel/user/favorilerim">
            <div class="kpi-top">
                <span class="kpi-title">Favori Otel</span>
                <div class="kpi-icon icon-pink"><i class="fas fa-heart"></i></div>
            </div>
            <div class="kpi-value">@Model.FavoriteCount</div>
            <div class="kpi-bottom up"><i class="fas fa-bookmark"></i> Kayıtlı tesisler</div>
        </a>
    </div>

    <div class="complex-grid">
        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-calendar-check"></i> Yaklaşan / Son Rezervasyonlar</h3>
                <a class="btn-outline-ap" style="height:28px;font-size:11px;padding:0 10px;" href="/panel/user/rezervasyonlarim">Tümünü Gör</a>
            </div>
            <form method="get" action="/panel/user" class="generic-form-grid" data-user-dashboard-filter-form>
                <input type="hidden" name="favoriteSort" value="@Model.FavoriteSortFilter" />
                <div class="form-group">
                    <label>Giriş tarihi</label>
                    <input class="form-control" type="date" name="reservationStartDate" value="@Model.ReservationStartDateText" />
                </div>
                <div class="form-group">
                    <label>Çıkış tarihi</label>
                    <input class="form-control" type="date" name="reservationEndDate" value="@Model.ReservationEndDateText" />
                </div>
                <div class="form-group">
                    <label>Durum</label>
                    <select class="form-control" name="reservationStatus">
                        <option value="all" selected="@(Model.ReservationStatusFilter == "all")">Tüm durumlar</option>
                        <option value="completed" selected="@(Model.ReservationStatusFilter == "completed")">Tamamlandı</option>
                        <option value="pending" selected="@(Model.ReservationStatusFilter == "pending")">Bekliyor</option>
                        <option value="rejected" selected="@(Model.ReservationStatusFilter == "rejected")">Reddedildi</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Sayfa başı</label>
                    <select class="form-control" name="reservationPageSize">
                        @foreach (var option in new[] { 5, 10, 15, 20 })
                        {
                            <option value="@option" selected="@(Model.ReservationPageSize == option)">@option</option>
                        }
                    </select>
                </div>
                <div class="form-actions" style="grid-column: 1 / -1;">
                    <input type="hidden" name="reservationPage" value="1" />
                    <a class="btn-outline-ap" href="/panel/user">Temizle</a>
                    <button type="submit" class="btn-primary-ap"><i class="fas fa-filter"></i> Filtrele</button>
                </div>
            </form>
            <div class="panel-body">
                @if (Model.RecentReservations.Count == 0)
                {
                    <div class="panel-body-padded">
                        <div class="ap-empty-state">
                            <i class="fas fa-calendar-xmark"></i>
                            <strong>Rezervasyon bulunmuyor</strong>
                            <p>Otel arayarak ilk rezervasyonunu oluşturabilirsin.</p>
                            <a class="btn-primary-ap" href="/oteller">Otel Ara</a>
                        </div>
                    </div>
                }
                else
                {
                    <table class="pro-table">
                        <thead>
                            <tr>
                                <th>Rezervasyon</th>
                                <th>Otel</th>
                                <th>Konaklama</th>
                                <th>Durum</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Aksiyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reservation in Model.RecentReservations)
                            {
                                <tr>
                                    <td>
                                        <div class="item-info">
                                            <span class="item-name">@reservation.ReservationNo</span>
                                            <span class="item-meta">#@reservation.ReservationId · @reservation.RoomName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="item-info">
                                            <span class="item-name">@reservation.HotelName</span>
                                            <span class="item-meta">@reservation.District, @reservation.City</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="item-info">
                                            <span class="item-name">@reservation.StayDateText</span>
                                            <span class="item-meta">@reservation.GuestText · @reservation.MealOrRoomText</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="status-badge @MapStatusBadge(reservation.StatusTone)">@reservation.StatusText</span>
                                    </td>
                                    <td class="text-end fw-bold">@reservation.TotalText</td>
                                    <td class="text-end">
                                        <a href="/oteller/@reservation.HotelSlug" class="btn-outline-ap" style="height:28px;font-size:11px;padding:0 10px;">Detay</a>
                                        <a href="/panel/user/mesajlarim" class="btn-primary-ap" style="height:28px;font-size:11px;padding:0 10px;">Mesaj</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            @if (Model.ReservationTotalPages > 1)
            {
                <div class="form-actions">
                    <span class="text-muted" style="font-size:12px;margin-right:auto;">
                        Toplam <strong>@Model.ReservationTotalCount</strong> kayıt · Sayfa <strong>@Model.ReservationPage</strong> / <strong>@Model.ReservationTotalPages</strong>
                    </span>
                    <a class="btn-outline-ap @(Model.ReservationPage <= 1 ? "disabled" : string.Empty)"
                       href="/panel/user?reservationStatus=@Model.ReservationStatusFilter&reservationStartDate=@Model.ReservationStartDateText&reservationEndDate=@Model.ReservationEndDateText&reservationPageSize=@Model.ReservationPageSize&reservationPage=@(Math.Max(1, Model.ReservationPage - 1))&favoriteSort=@Model.FavoriteSortFilter">
                        <i class="fas fa-chevron-left"></i> Önceki
                    </a>
                    <a class="btn-outline-ap @(Model.ReservationPage >= Model.ReservationTotalPages ? "disabled" : string.Empty)"
                       href="/panel/user?reservationStatus=@Model.ReservationStatusFilter&reservationStartDate=@Model.ReservationStartDateText&reservationEndDate=@Model.ReservationEndDateText&reservationPageSize=@Model.ReservationPageSize&reservationPage=@(Math.Min(Model.ReservationTotalPages, Model.ReservationPage + 1))&favoriteSort=@Model.FavoriteSortFilter">
                        Sonraki <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-heart" style="color:var(--ap-pink);"></i> Favori Oteller</h3>
                <a class="btn-outline-ap" style="height:28px;font-size:11px;padding:0 10px;" href="/panel/user/favorilerim">@Model.FavoriteCount kayıt</a>
            </div>
            <div class="panel-body panel-body-padded">
                <form method="get" action="/panel/user/dashboard" data-user-dashboard-favorite-form style="margin-bottom:12px;">
                    <input type="hidden" name="reservationStatus" value="@Model.ReservationStatusFilter" />
                    <input type="hidden" name="reservationStartDate" value="@Model.ReservationStartDateText" />
                    <input type="hidden" name="reservationEndDate" value="@Model.ReservationEndDateText" />
                    <input type="hidden" name="reservationPageSize" value="@Model.ReservationPageSize" />
                    <div class="form-group">
                        <label>Sıralama</label>
                        <select class="form-control" name="favoriteSort" aria-label="Favori otel sıralama">
                            <option value="newest" selected="@(Model.FavoriteSortFilter == "newest")">En yeni</option>
                            <option value="oldest" selected="@(Model.FavoriteSortFilter == "oldest")">En eski</option>
                            <option value="frequent" selected="@(Model.FavoriteSortFilter == "frequent")">Sık rezervasyon</option>
                        </select>
                    </div>
                </form>

                @if (Model.FavoriteHotels.Count == 0)
                {
                    <div class="ap-empty-state">
                        <i class="fas fa-heart"></i>
                        <strong>Henüz favori otelin yok</strong>
                        <p>Beğendiğin tesisleri favorilerine ekleyerek burada takip edebilirsin.</p>
                    </div>
                }
                else
                {
                    <div class="dashboard-favorite-grid">
                        @foreach (var hotel in Model.FavoriteHotels.Take(5))
                        {
                            <a class="dashboard-favorite-card" href="/oteller/@hotel.HotelSlug">
                                <div class="dashboard-favorite-card-media">
                                    @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                                    {
                                        <img src="@hotel.ImageUrl" alt="@hotel.HotelName" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="dashboard-favorite-card-fallback" aria-hidden="true"><i class="fas fa-hotel"></i></span>
                                    }
                                </div>
                                <div class="dashboard-favorite-card-body">
                                    <strong class="dashboard-favorite-card-name">@hotel.HotelName</strong>
                                    <span class="dashboard-favorite-card-location"><i class="fas fa-location-dot" aria-hidden="true"></i>@hotel.District, @hotel.City</span>
                                    <span class="dashboard-favorite-card-rating"><i class="fas fa-star" aria-hidden="true"></i>@hotel.RatingText</span>
                                </div>
                                <i class="fas fa-chevron-right dashboard-favorite-card-chevron" aria-hidden="true"></i>
                            </a>
                        }
                    </div>
                }

                <div class="ai-alert-box" style="margin-top:16px;">
                    <div class="ai-alert-header"><span><i class="fas fa-bolt"></i> Kişisel Fırsatlar</span></div>
                    <p class="ai-alert-text">Favorilerin, rezervasyon davranışın ve puan seviyene göre şekillenen kampanya önerilerini tek panelde topla.</p>
                    <div class="dashboard-deals-actions d-flex gap-2">
                        <a class="btn-primary-ap" href="/panel/user/puanlarim">Fırsatlar</a>
                        <a class="btn-outline-ap" href="/panel/user/favorilerim">Favoriler</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
(() => {
    document.querySelectorAll('[data-user-dashboard-filter-form] select[name="reservationStatus"], [data-user-dashboard-filter-form] select[name="reservationPageSize"], [data-user-dashboard-favorite-form] select[name="favoriteSort"]').forEach((select) => {
        select.addEventListener('change', () => select.form?.requestSubmit());
    });
})();
</script>
}
