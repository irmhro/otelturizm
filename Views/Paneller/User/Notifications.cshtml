@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Bildirim Tercihleri";
}

<section class="form-stack">
    <article class="panel-card">
        <div class="section-head"><h2>Rezervasyon Bildirimleri</h2></div>
        <div class="toggle-list">
            <div class="toggle-row"><div><h3>Rezervasyon onayi</h3><p>E-posta ve uygulama ici bildirim al.</p></div><span class="fake-toggle active"></span></div>
            <div class="toggle-row"><div><h3>Check-in hatırlatma</h3><p>Konaklama oncesi otomatik hatırlatici.</p></div><span class="fake-toggle active"></span></div>
            <div class="toggle-row"><div><h3>İptal ve degisiklik</h3><p>Rezervasyon hareketleri aninda bilgilendirilsin.</p></div><span class="fake-toggle active"></span></div>
        </div>
    </article>

    <article class="panel-card">
        <div class="section-head"><h2>Pazarlama ve Kampanya</h2></div>
        <div class="toggle-list">
            <div class="toggle-row"><div><h3>Fırsat e-postalari</h3><p>Ozel fiyatlar ve uye kampanyalari.</p></div><span class="fake-toggle"></span></div>
            <div class="toggle-row"><div><h3>SMS bilgilendirmeleri</h3><p>Kisa kampanya ve kupon duyurulari.</p></div><span class="fake-toggle"></span></div>
        </div>
    </article>
</section>


