@model otelturizmnew.Models.Paneller.User.UserNotificationsPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Bildirim Tercihleri";
    var activeCount = 0;
    if (Model.Form.ReservationEmail) activeCount++;
    if (Model.Form.ReservationPush) activeCount++;
    if (Model.Form.CheckInReminder) activeCount++;
    if (Model.Form.CancellationChanges) activeCount++;
    if (Model.Form.CampaignEmail) activeCount++;
    if (Model.Form.CampaignSms) activeCount++;
    if (Model.Form.SystemNotifications) activeCount++;
}

<div class="user-notifications-page notifications-page">
<section class="notifications-hero">
    <div>
        <span class="panel-eyebrow">Bildirim merkezi</span>
        <h1>Bildirim Tercihleri</h1>
        <p>Rezervasyon, kampanya ve güvenlik bildirimlerini kanal bazında yönet.</p>
    </div>
    <div class="notification-hero-metric">
        <strong>@activeCount</strong>
        <span>Aktif tercih</span>
    </div>
</section>

@if (TempData["UserNotificationSuccess"] is string success)
{
    <div class="notification-alert success">@success</div>
}

<section class="notifications-grid">
    <form method="post" asp-action="SaveNotifications" class="notification-panel">
        @Html.AntiForgeryToken()
        <div class="notification-panel-head">
            <div>
                <h2>Tercihler</h2>
                <p>Kritik rezervasyon ve güvenlik bildirimlerini kapatmamanız önerilir.</p>
            </div>
            <button type="submit" class="btn-primary-solid">
                <i class="fas fa-save"></i>
                Kaydet
            </button>
        </div>
        <div class="toggle-list">
            <label class="toggle-row"><div><h3>Rezervasyon e-postaları</h3><p>Onay ve önemli rezervasyon güncellemeleri e-posta ile gelsin.</p></div><input asp-for="Form.ReservationEmail" type="checkbox" /></label>
            <label class="toggle-row"><div><h3>Rezervasyon push bildirimleri</h3><p>Uygulama içi hızlı uyarıları açık tut.</p></div><input asp-for="Form.ReservationPush" type="checkbox" /></label>
            <label class="toggle-row"><div><h3>Check-in hatırlatma</h3><p>Konaklama öncesi otomatik hatırlatıcı gönderilsin.</p></div><input asp-for="Form.CheckInReminder" type="checkbox" /></label>
            <label class="toggle-row"><div><h3>İptal ve değişiklikler</h3><p>Rezervasyon hareketlerinden anında haberdar ol.</p></div><input asp-for="Form.CancellationChanges" type="checkbox" /></label>
            <label class="toggle-row"><div><h3>Fırsat e-postaları</h3><p>Özel kampanyalar ve kullanıcı fırsatları e-posta ile gelsin.</p></div><input asp-for="Form.CampaignEmail" type="checkbox" /></label>
            <label class="toggle-row"><div><h3>SMS bilgilendirmeleri</h3><p>Kısa kampanya ve kupon duyurularını SMS ile al.</p></div><input asp-for="Form.CampaignSms" type="checkbox" /></label>
            <label class="toggle-row no-border"><div><h3>Sistem bildirimleri</h3><p>Güvenlik ve hesap hareketleri için uygulama içi uyarılar açık olsun.</p></div><input asp-for="Form.SystemNotifications" type="checkbox" /></label>
        </div>
        <div class="notification-save-bar">
            <button type="submit" class="btn-primary-solid">
                <i class="fas fa-save"></i>
                Kaydet
            </button>
        </div>
    </form>

    <article class="notification-panel">
        <div class="notification-panel-head">
            <div>
                <h2>Son Bildirimler</h2>
                <p>Hesabınıza ait son sistem ve rezervasyon bildirimleri.</p>
            </div>
            <span class="notification-count-pill">@Model.RecentNotifications.Count kayıt</span>
        </div>
        <div class="notification-list">
            @if (Model.RecentNotifications.Count == 0)
            {
                <div class="notification-empty">
                    <i class="fas fa-bell-slash"></i>
                    <strong>Henüz bildirim yok</strong>
                    <span>Aktif bildirim oluştuğunda burada listelenecek.</span>
                </div>
            }
            else
            {
                foreach (var notification in Model.RecentNotifications)
                {
                    <div class="notification-row">
                        <div class="notification-icon"><i class="fas fa-bell"></i></div>
                        <div>
                            <h3>@notification.Title</h3>
                            <p>@notification.Message</p>
                        </div>
                        <div class="notification-meta">
                            <strong>@notification.TypeText</strong>
                            <span>@notification.TimeText</span>
                        </div>
                    </div>
                }
            }
        </div>
    </article>
</section>
</div>
