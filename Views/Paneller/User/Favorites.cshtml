@model otelturizmnew.Models.Paneller.User.UserFavoritesPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Favorilerim";
    var minDate = DateTime.Today.ToString("yyyy-MM-dd");
    var alertCount = Model.Hotels.Count(x => x.PriceAlertEnabled);
    var reservationCount = Model.Hotels.Sum(x => x.ReservationCount);
    var pendingReviewCount = Model.Hotels.Sum(x => x.ReviewPendingCount);
    var sortOptions = new Dictionary<string, string>
    {
        ["latest-reservation"] = "Son rezervasyon otellerim",
        ["most-reserved"] = "En çok rezervasyon yaptıklarım",
        ["review-waiting"] = "Yorum bekleyenler",
        ["highest-rating"] = "En yüksek puanlılar",
        ["newest-favorite"] = "En yeni favoriler"
    };
}

<div class="user-favorites-page">
    @if (TempData["UserFavoriteAlertSuccess"] is string favoriteAlertSuccess && !string.IsNullOrWhiteSpace(favoriteAlertSuccess))
    {
        <div class="favorite-banner favorite-banner--success"><i class="fas fa-circle-check"></i><span>@favoriteAlertSuccess</span></div>
    }
    @if (TempData["UserFavoriteAlertError"] is string favoriteAlertError && !string.IsNullOrWhiteSpace(favoriteAlertError))
    {
        <div class="favorite-banner favorite-banner--danger"><i class="fas fa-circle-exclamation"></i><span>@favoriteAlertError</span></div>
    }

    <section class="favorites-hero">
        <div>
            <div class="page-pretitle">KAYITLI OTELLER</div>
            <h1 class="page-title">Favorilerim</h1>
            <p class="text-muted mb-0">Rezervasyon yaptığın oteller otomatik favorilerine eklenir; son konakladığın ve sık tercih ettiğin otellere hızlı dön.</p>
        </div>
        <div class="favorites-hero-actions">
            <a class="btn btn-primary btn-pill" href="/oteller"><i class="fas fa-magnifying-glass me-2"></i>Otel Ara</a>
            <a class="btn btn-outline-primary btn-pill" href="/panel/user/rezervasyonlarim"><i class="fas fa-calendar-check me-2"></i>Rezervasyonlarım</a>
        </div>
    </section>

    <section class="favorite-stat-grid" aria-label="Favori özetleri">
        <article><span><i class="fas fa-heart"></i></span><div><strong>@Model.FavoriteCount</strong><small>Favori otel</small></div></article>
        <article><span><i class="fas fa-calendar-check"></i></span><div><strong>@reservationCount</strong><small>Favorilerde rezervasyon</small></div></article>
        <article><span><i class="fas fa-bell"></i></span><div><strong>@alertCount</strong><small>Aktif fiyat alarmı</small></div></article>
        <article><span><i class="fas fa-comment-dots"></i></span><div><strong>@pendingReviewCount</strong><small>Yorum bekleyen konaklama</small></div></article>
    </section>

    <section class="favorite-filter-panel">
        <form method="get" action="/panel/user/favorilerim" class="favorite-filter-form">
            <div>
                <label class="form-label" for="favoriteSearch">Otel, il veya ilçe ara</label>
                <input class="form-control" id="favoriteSearch" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Demo Test Otel, Kartal..." />
            </div>
            <div>
                <label class="form-label" for="favoriteSort">Listeleme</label>
                <select class="form-select" id="favoriteSort" name="sort">
                    @foreach (var option in sortOptions)
                    {
                        <option value="@option.Key" selected="@(Model.Sort == option.Key)">@option.Value</option>
                    }
                </select>
            </div>
            <button class="btn btn-primary" type="submit"><i class="fas fa-filter me-2"></i>Filtrele</button>
            <a class="btn btn-outline-primary" href="/panel/user/favorilerim">Temizle</a>
        </form>
    </section>

    @if (Model.Hotels.Count == 0)
    {
        <section class="card favorite-empty-card">
            <div class="empty">
                <div class="empty-icon"><i class="far fa-heart"></i></div>
                <p class="empty-title">Bu filtrede favori otel bulunamadı</p>
                <p class="empty-subtitle text-muted">Yeni rezervasyon yaptığın oteller otomatik favorilerine eklenir; dilersen otel detayından da favori ekleyebilirsin.</p>
                <div class="empty-action"><a href="/oteller" class="btn btn-primary">Otel Keşfet</a></div>
            </div>
        </section>
    }
    else
    {
        <section class="favorite-list-card">
            <div class="favorite-list-head">
                <div>
                    <h2>Favori Oteller</h2>
                    <p>@Model.TotalCount kayıt içinden sayfa başı @Model.PageSize otel listeleniyor.</p>
                </div>
                <span>Sayfa @Model.Page / @Model.TotalPages</span>
            </div>
            <div class="favorite-list">
            @foreach (var hotel in Model.Hotels)
            {
                <article class="favorite-row">
                    <a href="/oteller/@hotel.Slug" class="favorite-row-media">
                        @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                        {
                            <img src="@hotel.ImageUrl" alt="@hotel.Name" />
                        }
                        else
                        {
                            <span><i class="fas fa-hotel"></i></span>
                        }
                    </a>
                    <div class="favorite-row-main">
                        <div class="favorite-row-title">
                            <h3><a href="/oteller/@hotel.Slug">@hotel.Name</a></h3>
                            <p><i class="fas fa-location-dot"></i>@hotel.District, @hotel.City</p>
                        </div>
                        <div class="favorite-row-meta">
                            <span><i class="far fa-calendar-check"></i>@hotel.LastReservationDateText</span>
                            <span><i class="far fa-heart"></i>@hotel.AddedDateText</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(hotel.AvailabilityNote))
                        {
                            <div class="favorite-info-line"><i class="fas fa-circle-info"></i><span>@hotel.AvailabilityNote</span></div>
                        }
                        @if (hotel.ReviewPendingCount > 0)
                        {
                            <div class="favorite-review-callout">
                                <div>
                                    <strong>@hotel.ReviewPendingText</strong>
                                    <small>Her konaklama yorumu, sonraki misafirler ve otel kalitesi için değerlidir.</small>
                                </div>
                                @if (hotel.FirstEligibleReviewReservationId is long revId && revId > 0)
                                {
                                    <a asp-controller="UserPanel" asp-action="ReservationReview" asp-route-reservationId="@revId" class="btn btn-outline-primary btn-sm">Yorum Ver</a>
                                }
                                else
                                {
                                    <a asp-controller="UserPanel" asp-action="Reviews" asp-route-status="waiting" asp-route-searchTerm="@hotel.Name" asp-route-page="1" class="btn btn-outline-primary btn-sm">Yorum Ver</a>
                                }
                            </div>
                        }
                        @if (hotel.PriceAlertEnabled)
                        {
                            <div class="favorite-alert-summary">
                                <span>Hedef: @(hotel.PriceAlertTargetText ?? "-")</span>
                                <span>Tarih: @(hotel.PriceAlertDateRangeText ?? "-")</span>
                                @if (!string.IsNullOrWhiteSpace(hotel.PriceAlertLastTriggeredText))
                                {
                                    <span>Son bildirim: @hotel.PriceAlertLastTriggeredText</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="favorite-row-stats" aria-label="@hotel.Name kullanıcı özeti">
                        <span><strong>@hotel.ReservationCount</strong><small>Rezervasyon</small></span>
                        <span><strong>@hotel.ReviewGivenCount</strong><small>Yorum</small></span>
                        <span><strong>@hotel.UserAverageRatingText</strong><small>Puanınız</small></span>
                        <span><strong>@(hotel.Rating > 0 ? hotel.Rating.ToString("0.0") : "-")</strong><small>Otel puanı</small></span>
                    </div>
                    <div class="favorite-row-side">
                        <small>Başlangıç fiyatı</small>
                        <strong>@hotel.PriceText</strong>
                        @if (hotel.PriceAlertEnabled)
                        {
                            <span class="favorite-alert-pill">Alarm aktif</span>
                        }
                        <a href="/oteller/@hotel.Slug" class="btn btn-primary btn-sm">Rezervasyon</a>
                        <button type="button"
                                class="btn btn-outline-primary btn-sm"
                                data-alert-config
                                data-hotel-id="@hotel.HotelId"
                                data-hotel-name="@hotel.Name"
                                data-target-price="@(hotel.PriceAlertTargetAmount?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                data-start-date="@hotel.PriceAlertStartDateValue"
                                data-end-date="@hotel.PriceAlertEndDateValue"
                                data-enabled="@(hotel.PriceAlertEnabled ? "1" : "0")">
                            <i class="fas fa-bell me-2"></i>Fiyat Alarmı
                        </button>
                        @if (hotel.PriceAlertEnabled)
                        {
                            <form method="post" action="/panel/user/favorilerim/fiyat-alarmi/sil" class="favorite-alert-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="hotelId" value="@hotel.HotelId" />
                                <button type="submit" class="favorite-alert-delete-btn"><i class="fas fa-trash-can"></i>Alarmı kaldır</button>
                            </form>
                        }
                    </div>
                </article>
            }
            </div>
            <div class="favorite-pagination">
                <span>@Model.TotalCount kayıt · Sayfa @Model.Page / @Model.TotalPages</span>
                <div>
                    <a class="btn btn-outline-primary btn-sm @(Model.HasPreviousPage ? "" : "disabled")" href="/panel/user/favorilerim?page=@(Model.Page - 1)&sort=@Model.Sort&searchTerm=@System.Uri.EscapeDataString(Model.SearchTerm)">Önceki</a>
                    <a class="btn btn-outline-primary btn-sm @(Model.HasNextPage ? "" : "disabled")" href="/panel/user/favorilerim?page=@(Model.Page + 1)&sort=@Model.Sort&searchTerm=@System.Uri.EscapeDataString(Model.SearchTerm)">Sonraki</a>
                </div>
            </div>
        </section>
    }
</div>

<dialog class="favorite-alert-dialog" id="favoriteAlertDialog">
    <form method="post" action="/panel/user/favorilerim/fiyat-alarmi" class="favorite-alert-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="HotelId" id="favoriteAlertHotelId" />
        <div class="favorite-alert-form-head">
            <div>
                <p class="page-pretitle">FİYAT ALARMI</p>
                <h3 id="favoriteAlertHotelName">Fiyat alarmı ayarı</h3>
            </div>
            <button type="button" class="btn btn-icon btn-outline-primary" data-close-alert-dialog aria-label="Kapat"><i class="fas fa-xmark"></i></button>
        </div>
        <label class="favorite-alert-checkbox">
            <input type="checkbox" name="Enabled" id="favoriteAlertEnabled" value="true" />
            <span>Bu otel için fiyat alarmı aktif olsun</span>
        </label>
        <input type="hidden" name="Enabled" value="false" />
        <label class="form-label" for="favoriteAlertTargetPrice">Beklenen maksimum gece fiyatı (TRY)</label>
        <input class="form-control" type="number" name="TargetPriceText" id="favoriteAlertTargetPrice" min="1" step="0.01" required />
        <div class="favorite-alert-date-grid">
            <div>
                <label class="form-label" for="favoriteAlertStartDate">Başlangıç tarihi</label>
                <input class="form-control" type="date" name="StartDateText" id="favoriteAlertStartDate" min="@minDate" required />
            </div>
            <div>
                <label class="form-label" for="favoriteAlertEndDate">Bitiş tarihi</label>
                <input class="form-control" type="date" name="EndDateText" id="favoriteAlertEndDate" min="@minDate" required />
            </div>
        </div>
        <div class="favorite-alert-actions">
            <button type="button" class="btn btn-outline-primary" data-close-alert-dialog>Vazgeç</button>
            <button type="submit" class="btn btn-primary">Kaydet</button>
        </div>
    </form>
</dialog>

@section Scripts {
@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
(() => {
    const dialog = document.getElementById('favoriteAlertDialog');
    if (!dialog) return;
    const hotelIdInput = document.getElementById('favoriteAlertHotelId');
    const hotelName = document.getElementById('favoriteAlertHotelName');
    const enabledInput = document.getElementById('favoriteAlertEnabled');
    const targetPriceInput = document.getElementById('favoriteAlertTargetPrice');
    const startDateInput = document.getElementById('favoriteAlertStartDate');
    const endDateInput = document.getElementById('favoriteAlertEndDate');
    const syncRequirement = () => {
        const active = enabledInput.checked;
        targetPriceInput.required = active;
        startDateInput.required = active;
        endDateInput.required = active;
        targetPriceInput.disabled = !active;
        startDateInput.disabled = !active;
        endDateInput.disabled = !active;
    };
    document.querySelectorAll('[data-alert-config]').forEach((button) => {
        button.addEventListener('click', () => {
            hotelIdInput.value = button.getAttribute('data-hotel-id') || '';
            hotelName.textContent = (button.getAttribute('data-hotel-name') || 'Otel') + ' fiyat alarmı';
            enabledInput.checked = button.getAttribute('data-enabled') === '1';
            targetPriceInput.value = button.getAttribute('data-target-price') || '';
            startDateInput.value = button.getAttribute('data-start-date') || '';
            endDateInput.value = button.getAttribute('data-end-date') || '';
            syncRequirement();
            dialog.showModal();
        });
    });
    dialog.querySelectorAll('[data-close-alert-dialog]').forEach((button) => {
        button.addEventListener('click', () => dialog.close());
    });
    dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
    });
    startDateInput.addEventListener('change', () => {
        endDateInput.min = startDateInput.value || '@minDate';
        if (endDateInput.value && startDateInput.value && endDateInput.value < startDateInput.value) {
            endDateInput.value = startDateInput.value;
        }
    });
    enabledInput.addEventListener('change', syncRequirement);
})();
</script>
}
