@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsAct(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
}
<nav class="admin-mobile-nav user-mobile-nav" aria-label="Alt menü">
    <a asp-controller="UserPanel" asp-action="Dashboard" class="@(IsAct("Dashboard") ? "active" : null)"><i class="fas fa-th-large" aria-hidden="true"></i><span>Panel</span></a>
    <a asp-controller="UserPanel" asp-action="Reservations" class="@(IsAct("Reservations") || IsAct("ReservationReview") ? "active" : null)"><i class="fas fa-suitcase" aria-hidden="true"></i><span>Rez.</span></a>
    <a asp-controller="UserPanel" asp-action="Favorites" class="@(IsAct("Favorites") ? "active" : null)"><i class="fas fa-heart" aria-hidden="true"></i><span>Favori</span></a>
    <a asp-controller="UserPanel" asp-action="Messages" class="@(IsAct("Messages") ? "active" : null)"><i class="fas fa-envelope" aria-hidden="true"></i><span>Mesaj</span></a>
    <a asp-controller="UserPanel" asp-action="Profile" class="@(IsAct("Profile") ? "active" : null)"><i class="fas fa-user" aria-hidden="true"></i><span>Profil</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket" aria-hidden="true"></i><span>Çıkış</span></button>
    </form>
</nav>
