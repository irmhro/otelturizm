@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
    var fullName = User.FindFirst("otelturizm:full_name")?.Value ?? User.Identity?.Name ?? "Kullanıcı";
    var displayName = System.Text.RegularExpressions.Regex.Replace(
        (fullName ?? string.Empty).Trim(),
        @"^\s*[\p{Lu}]{1,3}[\s\.\-_]+",
        string.Empty).Trim();
    if (string.IsNullOrWhiteSpace(displayName)) { displayName = "Kullanıcı"; }
    var favoriteCount = ViewData["FavoriteCount"] is int fav ? fav : 0;
    var reservationCount = ViewData["ReservationCount"] is int res ? res : 0;
    var messageCount = ViewData["MessageCount"] is int msg ? msg : 0;
    var profileImageUrl = ViewData["UserProfileImageUrl"] as string ?? string.Empty;
    var initial = displayName.Length > 0 ? displayName[0].ToString().ToUpperInvariant() : "K";

    bool IsCurrent(params string[] actions) => actions.Any(a => string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase));
    bool IsPath(params string[] paths) => paths.Any(p => currentPath.Equals(p, StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase));
    string ActivePath(params string[] paths) => IsPath(paths) ? "active" : string.Empty;

    var dashboardActive = IsCurrent("Dashboard") || IsPath("/panel/user", "/panel/user/dashboard");
    var tripOpen = IsCurrent("Reservations", "ReservationReview", "Reviews") || IsPath("/panel/user/rezervasyonlarim", "/panel/user/yorumlarim");
    var financeOpen = IsCurrent("Invoices", "PaymentMethods") || IsPath("/panel/user/faturalarim", "/panel/user/odeme-yontemleri");
    var accountOpen = IsCurrent("Profile", "Notifications", "Security") || IsPath("/panel/user/profil-bilgilerim", "/panel/user/bildirim-tercihleri", "/panel/user/guvenlik-ve-giris");
}
<aside class="admin-sidebar" id="appSidebar" aria-label="Kullanıcı menüsü">
    <div class="sidebar-header">
        <a href="/panel/user/dashboard" class="logo-wordmark-wrapper">
            <span class="logo-otel">Misafir</span>
            <div class="logo-sep"></div>
            <span class="logo-turizm">Portal</span>
        </a>
    </div>

    <div class="sidebar-scroll">
        <div class="sidebar-user-line">
            @if (!string.IsNullOrWhiteSpace(profileImageUrl))
            {
                <img src="@profileImageUrl" alt="" class="header-avatar" />
            }
            else
            {
                <span class="header-avatar">@initial</span>
            }
            <div>
                <strong>@displayName</strong>
                <span>@email</span>
            </div>
        </div>

        <span class="sidebar-group-label">Kişisel Kokpit</span>
        <div class="nav-menu-item @(dashboardActive ? "active" : "")">
            <a class="nav-main-link" href="/panel/user/dashboard">
                <div class="nav-link-left"><i class="fas fa-th-large ic-core"></i><span>Genel Bakış</span></div>
            </a>
        </div>

        <span class="sidebar-group-label">Seyahatlerim</span>
        <div class="nav-menu-item @(tripOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-user-nav-toggle aria-expanded="@(tripOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-suitcase ic-trip"></i><span>Rezervasyonlarım</span></div>
                @if (reservationCount > 0)
                {
                    <span class="ap-nav-badge">@reservationCount</span>
                }
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/user/rezervasyonlarim")" href="/panel/user/rezervasyonlarim">Aktif & Geçmiş Seyahatler</a>
                <a class="@ActivePath("/panel/user/yorumlarim")" href="/panel/user/yorumlarim">Yorumlarım</a>
            </div>
        </div>

        <span class="sidebar-group-label">Keşif & Planlama</span>
        <div class="nav-menu-item @(IsCurrent("Favorites") ? "active" : "")">
            <a class="nav-main-link" href="/panel/user/favorilerim">
                <div class="nav-link-left"><i class="fas fa-heart ic-fav"></i><span>Favori Otellerim</span></div>
                @if (favoriteCount > 0)
                {
                    <span class="ap-nav-badge">@favoriteCount</span>
                }
            </a>
        </div>
        <div class="nav-menu-item @(IsCurrent("Loyalty") ? "active" : "")">
            <a class="nav-main-link" href="/panel/user/puanlarim">
                <div class="nav-link-left"><i class="fas fa-gift ic-fav"></i><span>Puan & Ödüllerim</span></div>
            </a>
        </div>

        <span class="sidebar-group-label">Ödemeler & Finans</span>
        <div class="nav-menu-item @(financeOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-user-nav-toggle aria-expanded="@(financeOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-wallet ic-wallet"></i><span>Dijital Cüzdan</span></div>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/user/faturalarim")" href="/panel/user/faturalarim">Faturalarım</a>
                <a class="@ActivePath("/panel/user/odeme-yontemleri")" href="/panel/user/odeme-yontemleri">Ödeme Yöntemleri</a>
            </div>
        </div>

        <span class="sidebar-group-label">Müşteri İlişkileri</span>
        <div class="nav-menu-item @(IsCurrent("Messages") ? "active" : "")">
            <a class="nav-main-link" href="/panel/user/mesajlarim">
                <div class="nav-link-left"><i class="fas fa-headset ic-support"></i><span>Mesajlarım</span></div>
                @if (messageCount > 0)
                {
                    <span class="ap-nav-badge">@messageCount</span>
                }
            </a>
        </div>
        <div class="nav-menu-item">
            <a class="nav-main-link" href="/yardim-merkezi" target="_blank" rel="noopener">
                <div class="nav-link-left"><i class="fas fa-circle-question ic-support"></i><span>Yardım Merkezi</span></div>
            </a>
        </div>

        <span class="sidebar-group-label">Hesap Yapılandırma</span>
        <div class="nav-menu-item @(accountOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-user-nav-toggle aria-expanded="@(accountOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-user-cog ic-settings"></i><span>Profil Ayarları</span></div>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/user/profil-bilgilerim")" href="/panel/user/profil-bilgilerim">Kişisel Bilgiler</a>
                <a class="@ActivePath("/panel/user/bildirim-tercihleri")" href="/panel/user/bildirim-tercihleri">Bildirim Tercihleri</a>
                <a class="@ActivePath("/panel/user/guvenlik-ve-giris")" href="/panel/user/guvenlik-ve-giris">Güvenlik ve Giriş</a>
            </div>
        </div>
    </div>

    <div class="admin-sidebar-footer">
        <div class="admin-sidebar-footer-actions">
            <a href="/oteller" class="ap-btn-sidebar primary">
                <i class="fas fa-magnifying-glass"></i> Otel Ara
            </a>
            <a href="/" class="ap-btn-sidebar">
                <i class="fas fa-arrow-left"></i> Site
            </a>
            <form method="post" action="/cikis-yap" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="ap-btn-sidebar danger w-100">
                    <i class="fas fa-right-from-bracket"></i> Çıkış
                </button>
            </form>
        </div>
    </div>
</aside>
