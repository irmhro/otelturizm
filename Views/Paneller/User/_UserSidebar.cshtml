@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
    var fullName = User.FindFirst("otelturizm:full_name")?.Value ?? User.Identity?.Name ?? "Kullanıcı";
    var displayName = System.Text.RegularExpressions.Regex.Replace(
        (fullName ?? string.Empty).Trim(),
        @"^\s*[\p{Lu}]{1,3}[\s\.\-_]+",
        string.Empty).Trim();
    if (string.IsNullOrWhiteSpace(displayName)) { displayName = "Kullanıcı"; }
    var favoriteCount = ViewData["FavoriteCount"] is int count ? count : (int?)null;
    var reservationCount = ViewData["ReservationCount"] is int reservationBadge ? reservationBadge : (int?)null;
    var messageCount = ViewData["MessageCount"] is int messageBadge ? messageBadge : (int?)null;
    var profileImageUrl = ViewData["UserProfileImageUrl"] as string ?? string.Empty;
    bool IsCurrent(params string[] actions) => actions.Any(a => string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase));
    bool IsPath(params string[] paths) => paths.Any(p => currentPath.Equals(p, StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase));
}
<aside class="navbar navbar-vertical navbar-expand-lg user-sidebar" id="userSidebar" aria-label="Kullanıcı menüsü">
    <div class="container-fluid">
        <button class="navbar-toggler user-sidebar-close" type="button" data-user-sidebar-toggle aria-controls="userSidebarMenu" aria-expanded="false" aria-label="Menüyü kapat">
            <i class="fas fa-xmark"></i>
        </button>

        <h1 class="navbar-brand navbar-brand-autodark">
            <a href="/panel/user" class="user-brand-link">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="user-brand-logo" />
            </a>
        </h1>

        <div class="collapse navbar-collapse" id="userSidebarMenu">
            <div class="user-sidebar-profile">
                @if (!string.IsNullOrWhiteSpace(profileImageUrl))
                {
                    <span class="avatar bg-blue-lt text-blue" style="background-image:url('@profileImageUrl')"></span>
                }
                else
                {
                    <span class="avatar bg-blue-lt text-blue">@displayName[0].ToString().ToUpperInvariant()</span>
                }
                <div class="min-w-0">
                    <strong>@displayName</strong>
                    <small>@email</small>
                </div>
            </div>

            <div class="user-sidebar-scroll">
                <ul class="navbar-nav user-sidebar-nav">
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Dashboard") ? "active" : string.Empty)" href="/panel/user/dashboard">
                            <span class="nav-link-icon"><i class="fas fa-house"></i></span>
                            <span class="nav-link-title">Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Reservations", "ReservationReview") || IsPath("/panel/user/rezervasyonlarim") ? "active" : string.Empty)" href="/panel/user/rezervasyonlarim">
                            <span class="nav-link-icon"><i class="fas fa-calendar-check"></i></span>
                            <span class="nav-link-title">Rezervasyonlarım</span>
                            @if (reservationCount.HasValue && reservationCount.Value > 0) { <span class="badge bg-primary-lt text-primary ms-auto">@reservationCount.Value</span> }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Favorites") ? "active" : string.Empty)" href="/panel/user/favorilerim">
                            <span class="nav-link-icon"><i class="fas fa-heart"></i></span>
                            <span class="nav-link-title">Favorilerim</span>
                            @if (favoriteCount.HasValue) { <span class="badge bg-success-lt text-success ms-auto">@favoriteCount.Value</span> }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Reviews", "ReservationReview") || IsPath("/panel/user/yorumlarim") ? "active" : string.Empty)" href="/panel/user/yorumlarim">
                            <span class="nav-link-icon"><i class="fas fa-comment-dots"></i></span>
                            <span class="nav-link-title">Yorumlarım</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Loyalty") ? "active" : string.Empty)" href="/panel/user/puanlarim">
                            <span class="nav-link-icon"><i class="fas fa-star"></i></span>
                            <span class="nav-link-title">Puanlarım</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Messages") ? "active" : string.Empty)" href="/panel/user/mesajlarim">
                            <span class="nav-link-icon"><i class="fas fa-envelope"></i></span>
                            <span class="nav-link-title">Mesajlarım</span>
                            @if (messageCount.HasValue && messageCount.Value > 0) { <span class="badge bg-orange-lt text-orange ms-auto">@messageCount.Value</span> }
                        </a>
                    </li>

                    <li class="nav-item user-nav-section">Hesap</li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Profile") ? "active" : string.Empty)" href="/panel/user/profil-bilgilerim">
                            <span class="nav-link-icon"><i class="fas fa-user-circle"></i></span>
                            <span class="nav-link-title">Profil Bilgilerim</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("PaymentMethods") ? "active" : string.Empty)" href="/panel/user/odeme-yontemleri">
                            <span class="nav-link-icon"><i class="fas fa-credit-card"></i></span>
                            <span class="nav-link-title">Ödeme Yöntemleri</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Notifications") ? "active" : string.Empty)" href="/panel/user/bildirim-tercihleri">
                            <span class="nav-link-icon"><i class="fas fa-bell"></i></span>
                            <span class="nav-link-title">Bildirim Tercihleri</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsCurrent("Security") ? "active" : string.Empty)" href="/panel/user/guvenlik-ve-giris">
                            <span class="nav-link-icon"><i class="fas fa-shield-halved"></i></span>
                            <span class="nav-link-title">Güvenlik ve Giriş</span>
                        </a>
                    </li>
                </ul>
            </div>

            <div class="user-sidebar-footer">
                <a class="btn btn-primary w-100" href="/oteller"><i class="fas fa-magnifying-glass me-2"></i>Otel Ara</a>
                <div class="user-footer-actions">
                    <a class="btn btn-outline-light" href="/"><i class="fas fa-arrow-left me-2"></i>Site</a>
                    <form method="post" action="/cikis-yap" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light"><i class="fas fa-right-from-bracket me-2"></i>Çıkış</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</aside>
