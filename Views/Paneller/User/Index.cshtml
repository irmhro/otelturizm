@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Kullanıcı Paneli";
}

<section class="quick-actions">
    <a asp-action="Reservations" class="quick-card">
        <div class="quick-icon blue"><i class="fas fa-calendar-plus"></i></div>
        <div><h3>Rezervasyonlarim</h3><p>Yaklasan konaklamalari yonet</p></div>
    </a>
    <a asp-action="Favorites" class="quick-card">
        <div class="quick-icon rose"><i class="fas fa-heart"></i></div>
        <div><h3>Favorilerim</h3><p>Kayıtli otelleri incele</p></div>
    </a>
    <a asp-action="Loyalty" class="quick-card">
        <div class="quick-icon gold"><i class="fas fa-gift"></i></div>
        <div><h3>OtelPuan</h3><p>Odullerini gor</p></div>
    </a>
    <a asp-action="Messages" class="quick-card">
        <div class="quick-icon green"><i class="fas fa-headset"></i></div>
        <div><h3>Mesajlarim</h3><p>Destek ve otel yazismalari</p></div>
    </a>
</section>

<section class="stats-grid">
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon blue"><i class="fas fa-calendar-alt"></i></div>
            <span class="trend up"><i class="fas fa-arrow-up"></i> +2</span>
        </div>
        <strong>12</strong>
        <p>Toplam Rezervasyon</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon yellow"><i class="fas fa-clock"></i></div>
            <span class="trend up"><i class="fas fa-arrow-up"></i> 1</span>
        </div>
        <strong>3</strong>
        <p>Yaklasan Konaklama</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon gold"><i class="fas fa-star"></i></div>
        </div>
        <strong>1.250</strong>
        <p>OtelPuan Bakiyesi</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon green"><i class="fas fa-tag"></i></div>
        </div>
        <strong>TRY 450</strong>
        <p>Kullanilabilir Indirim</p>
    </article>
</section>

<section class="content-grid">
    <div class="panel-card">
        <div class="section-head">
            <div>
                <p class="mini-label">YAKLASAN REZERVASYONLAR</p>
                <h2>Son konaklama planlarin</h2>
            </div>
            <a asp-action="Reservations">Tümünü Gor</a>
        </div>

        <div class="chip-row">
            <button type="button" class="chip active">Tümu</button>
            <button type="button" class="chip">Onaylandi</button>
            <button type="button" class="chip">Onay Bekliyor</button>
            <button type="button" class="chip">Check-in Yakin</button>
        </div>

        <article class="reservation-card">
            <img src="https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Swissotel" />
            <div class="reservation-body">
                <div class="reservation-top">
                    <div>
                        <h3>Swissotel The Bosphorus</h3>
                        <p>Besiktas, Istanbul</p>
                    </div>
                    <span class="status ok">Onaylandi</span>
                </div>
                <div class="reservation-meta">
                    <span><i class="far fa-calendar"></i> 15 Nis - 18 Nis 2025</span>
                    <span><i class="far fa-user"></i> 2 Yetiskin, 1 Cocuk</span>
                    <span><i class="far fa-moon"></i> Deluxe Oda</span>
                </div>
                <div class="reservation-footer">
                    <strong>TRY 12.750</strong>
                    <div class="action-row">
                        <button type="button" class="ghost-btn">Detay</button>
                        <button type="button" class="ghost-btn">Degistir</button>
                    </div>
                </div>
            </div>
        </article>

        <article class="reservation-card">
            <img src="https://images.pexels.com/photos/261169/pexels-photo-261169.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Rixos" />
            <div class="reservation-body">
                <div class="reservation-top">
                    <div>
                        <h3>Rixos Premium Belek</h3>
                        <p>Belek, Antalya</p>
                    </div>
                    <span class="status wait">Onay Bekliyor</span>
                </div>
                <div class="reservation-meta">
                    <span><i class="far fa-calendar"></i> 22 May - 29 May 2025</span>
                    <span><i class="far fa-user"></i> 2 Yetiskin</span>
                    <span><i class="fas fa-utensils"></i> Her Sey Dahil</span>
                </div>
                <div class="reservation-footer">
                    <strong>TRY 40.600</strong>
                    <div class="action-row">
                        <button type="button" class="ghost-btn">Detay</button>
                        <button type="button" class="ghost-btn danger">İptal</button>
                    </div>
                </div>
            </div>
        </article>
    </div>

    <div class="side-stack">
        <section class="panel-card">
            <div class="section-head compact">
                <h2>Kayıtli Oteller</h2>
                <a asp-action="Favorites">8 Otel</a>
            </div>

            <div class="favorite-item">
                <div class="favorite-thumb"></div>
                <div>
                    <h4>Four Seasons Bosphorus</h4>
                    <p>Besiktas, Istanbul</p>
                    <strong>9.7 Puan</strong>
                </div>
            </div>
            <div class="favorite-item">
                <div class="favorite-thumb second"></div>
                <div>
                    <h4>D Maris Bay</h4>
                    <p>Marmaris, Mugla</p>
                    <strong>9.3 Puan</strong>
                </div>
            </div>
            <div class="favorite-item">
                <div class="favorite-thumb third"></div>
                <div>
                    <h4>Hilton Istanbul Bomonti</h4>
                    <p>Sisli, Istanbul</p>
                    <strong>8.9 Puan</strong>
                </div>
            </div>
        </section>

        <section class="reward-panel">
            <p class="mini-label light">OZEL FIRSAT</p>
            <h2>Gold uye avantajlari aktif</h2>
            <p>1.250 puanin var. 1.250 puan daha kazan, Platinum seviyeye gec ve daha güçlü indirimler ac.</p>
            <a asp-action="Loyalty" class="reward-link">Fırsatları Keşfet</a>
        </section>
    </div>
</section>


