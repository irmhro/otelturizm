@model otelturizmnew.Models.Paneller.User.UserDashboardPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Kullanıcı Paneli";
}

<section class="quick-actions">
    <a asp-action="Reservations" class="quick-card">
        <div class="quick-icon blue"><i class="fas fa-calendar-plus"></i></div>
        <div><h3>Rezervasyonlarım</h3><p>Yaklaşan ve geçmiş konaklamalarını yönet</p></div>
    </a>
    <a asp-action="Favorites" class="quick-card">
        <div class="quick-icon rose"><i class="fas fa-heart"></i></div>
        <div><h3>Favorilerim</h3><p>Kaydettiğin otelleri yeniden incele</p></div>
    </a>
    <a asp-action="Loyalty" class="quick-card">
        <div class="quick-icon gold"><i class="fas fa-gift"></i></div>
        <div><h3>OtelPuan</h3><p>Sadakat ayrıcalıklarını takip et</p></div>
    </a>
    <a asp-action="Messages" class="quick-card">
        <div class="quick-icon green"><i class="fas fa-headset"></i></div>
        <div><h3>Mesajlarım</h3><p>Otel ve destek konuşmalarını görüntüle</p></div>
    </a>
</section>

<section class="stats-grid">
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon blue"><i class="fas fa-calendar-alt"></i></div>
            <div class="stats-head-right">
                <strong class="stats-value">@Model.TotalReservationCount</strong>
                <span class="trend up"><i class="fas fa-list"></i> Toplam</span>
            </div>
        </div>
        <p>Toplam rezervasyon</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon yellow"><i class="fas fa-clock"></i></div>
            <div class="stats-head-right">
                <strong class="stats-value">@Model.UpcomingReservationCount</strong>
                <span class="trend up"><i class="fas fa-suitcase"></i> Aktif</span>
            </div>
        </div>
        <p>Yaklaşan konaklama</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon rose"><i class="fas fa-heart"></i></div>
            <div class="stats-head-right">
                <strong class="stats-value">@Model.FavoriteCount</strong>
                <span class="trend up"><i class="fas fa-heart"></i> Favori</span>
            </div>
        </div>
        <p>Favori otel</p>
    </article>
    <article class="stats-card">
        <div class="stats-head">
            <div class="stats-icon green"><i class="fas fa-tag"></i></div>
            <div class="stats-head-right">
                <strong class="stats-value">@Model.DiscountText</strong>
                <span class="trend up"><i class="fas fa-tag"></i> Tasarruf</span>
            </div>
        </div>
        <p>Toplam tasarruf</p>
    </article>
</section>

<section class="content-grid">
    <div class="panel-card">
        <div class="section-head">
            <div>
                <p class="mini-label">YAKLAŞAN REZERVASYONLAR</p>
                <h2>Son konaklama planların</h2>
            </div>
            <a asp-action="Reservations">Tümünü Gör</a>
        </div>

        <div class="chip-row">
            <a asp-action="Index"
               asp-route-reservationStatus="all"
               asp-route-reservationStartDate="@Model.ReservationStartDateText"
               asp-route-reservationEndDate="@Model.ReservationEndDateText"
               asp-route-reservationPage="1"
               asp-route-reservationPageSize="@Model.ReservationPageSize"
               class="chip @(Model.ReservationStatusFilter == "all" ? "active" : string.Empty)">Tümü</a>
            <a asp-action="Index"
               asp-route-reservationStatus="approved"
               asp-route-reservationStartDate="@Model.ReservationStartDateText"
               asp-route-reservationEndDate="@Model.ReservationEndDateText"
               asp-route-reservationPage="1"
               asp-route-reservationPageSize="@Model.ReservationPageSize"
               class="chip @(Model.ReservationStatusFilter == "approved" ? "active" : string.Empty)">Onaylı</a>
            <a asp-action="Index"
               asp-route-reservationStatus="pending"
               asp-route-reservationStartDate="@Model.ReservationStartDateText"
               asp-route-reservationEndDate="@Model.ReservationEndDateText"
               asp-route-reservationPage="1"
               asp-route-reservationPageSize="@Model.ReservationPageSize"
               class="chip @(Model.ReservationStatusFilter == "pending" ? "active" : string.Empty)">Bekleyen</a>
        </div>
        <form method="get" asp-action="Index" class="reservation-filter-form">
            <input type="hidden" name="reservationStatus" value="@Model.ReservationStatusFilter" />
            <input type="hidden" name="reservationPage" value="1" />
            <label>
                <span>Giriş başlangıç</span>
                <input type="date" name="reservationStartDate" value="@Model.ReservationStartDateText" />
            </label>
            <label>
                <span>Giriş bitiş</span>
                <input type="date" name="reservationEndDate" value="@Model.ReservationEndDateText" />
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="reservationPageSize">
                    @foreach (var option in new[] { 5, 10, 15, 20 })
                    {
                        <option value="@option" selected="@(Model.ReservationPageSize == option)">@option</option>
                    }
                </select>
            </label>
            <div class="reservation-filter-actions">
                <button type="submit" class="ghost-btn">Filtreyi uygula</button>
                <a asp-action="Index" class="ghost-btn">Temizle</a>
            </div>
        </form>

        @if (Model.RecentReservations.Count == 0)
        {
            <article class="reservation-card">
                <div class="favorite-card-image-fallback"></div>
                <div class="reservation-body">
                    <div class="reservation-top">
                        <div>
                            <h3>Henüz rezervasyonun yok</h3>
                            <p>Keşfet alanından sana uygun otelleri inceleyip ilk rezervasyonunu oluşturabilirsin.</p>
                        </div>
                        <span class="status info">Hazır</span>
                    </div>
                    <div class="reservation-footer">
                        <strong>Yeni plan oluştur</strong>
                        <div class="action-row">
                            <a href="/" class="ghost-btn">Keşfete dön</a>
                        </div>
                    </div>
                </div>
            </article>
        }
        else
        {
            foreach (var reservation in Model.RecentReservations)
            {
                <article class="reservation-card">
                    @if (!string.IsNullOrWhiteSpace(reservation.ImageUrl))
                    {
                        <img src="@reservation.ImageUrl" alt="@reservation.HotelName" />
                    }
                    else
                    {
                        <div class="favorite-card-image-fallback"></div>
                    }
                    <div class="reservation-body">
                        <div class="reservation-top">
                            <div>
                                <h3>@reservation.HotelName</h3>
                                <p>@reservation.District, @reservation.City</p>
                            </div>
                            <span class="status @reservation.StatusTone">@reservation.StatusText</span>
                        </div>
                        <div class="reservation-meta">
                            <span><i class="far fa-calendar"></i> @reservation.StayDateText</span>
                            <span><i class="far fa-user"></i> @reservation.GuestText</span>
                            <span><i class="far fa-moon"></i> @reservation.RoomName</span>
                        </div>
                        <p class="sub-note @reservation.SubNoteTone">@reservation.SubNote</p>
                        <div class="reservation-footer">
                            <strong>@reservation.TotalText</strong>
                            <div class="action-row">
                                <a href="/oteller/@reservation.HotelSlug" class="ghost-btn">Detay</a>
                                <a asp-action="Messages" class="ghost-btn">Otelle iletişim</a>
                            </div>
                        </div>
                    </div>
                </article>
            }
        }
        @if (Model.ReservationTotalPages > 1)
        {
            <div class="reservation-pager">
                <a asp-action="Index"
                   asp-route-reservationStatus="@Model.ReservationStatusFilter"
                   asp-route-reservationStartDate="@Model.ReservationStartDateText"
                   asp-route-reservationEndDate="@Model.ReservationEndDateText"
                   asp-route-reservationPageSize="@Model.ReservationPageSize"
                   asp-route-reservationPage="@(Math.Max(1, Model.ReservationPage - 1))"
                   class="pager-link @(Model.ReservationPage <= 1 ? "disabled" : string.Empty)">Önceki</a>
                <span>Sayfa @Model.ReservationPage / @Model.ReservationTotalPages</span>
                <a asp-action="Index"
                   asp-route-reservationStatus="@Model.ReservationStatusFilter"
                   asp-route-reservationStartDate="@Model.ReservationStartDateText"
                   asp-route-reservationEndDate="@Model.ReservationEndDateText"
                   asp-route-reservationPageSize="@Model.ReservationPageSize"
                   asp-route-reservationPage="@(Math.Min(Model.ReservationTotalPages, Model.ReservationPage + 1))"
                   class="pager-link @(Model.ReservationPage >= Model.ReservationTotalPages ? "disabled" : string.Empty)">Sonraki</a>
            </div>
        }
    </div>

    <div class="side-stack">
        <section class="panel-card">
            <div class="section-head compact">
                <h2>Favori oteller</h2>
                <a asp-action="Favorites">@Model.FavoriteCount kayıt</a>
            </div>

            @if (Model.FavoriteHotels.Count == 0)
            {
                <div class="favorite-empty">
                    <div class="favorite-thumb"></div>
                    <div class="favorite-empty-copy">
                        <h4>Henüz favori otelin yok</h4>
                        <p>Kalp butonunu kullanarak beğendiğin tesisleri burada toplayabilirsin.</p>
                        <a asp-controller="Oteller" asp-action="OtelListeleme" class="ghost-btn">Otel keşfet</a>
                    </div>
                </div>
            }
            else
            {
                <div class="favorite-hotel-list">
                @foreach (var hotel in Model.FavoriteHotels.Take(3))
                {
                    <article class="favorite-hotel-row">
                        @if (!string.IsNullOrWhiteSpace(hotel.ImageUrl))
                        {
                            <img class="favorite-thumb" src="@hotel.ImageUrl" alt="@hotel.HotelName" />
                        }
                        else
                        {
                            <div class="favorite-thumb"></div>
                        }
                        <div class="favorite-row-copy">
                            <h4>@hotel.HotelName</h4>
                            <p>@hotel.District, @hotel.City</p>
                            <div class="favorite-meta-row">
                                <strong>@hotel.RatingText</strong>
                                <a asp-action="Favorites">Detayı aç</a>
                            </div>
                        </div>
                    </article>
                }
                </div>
            }
        </section>

        <section class="reward-panel">
            <p class="mini-label light">ÖZEL FIRSAT</p>
            <h2>Kişisel fırsatlarını akıllı şekilde takip et</h2>
            <p>Favorilerin, rezervasyon davranışın ve puan seviyene göre şekillenen kampanya önerilerini tek panelde topla.</p>
            <div class="reward-highlights">
                <article>
                    <i class="fas fa-bolt"></i>
                    <div>
                        <strong>Hafta sonu hızlı fırsat</strong>
                        <span>Son 48 saat içinde biten seçili kampanyalar</span>
                    </div>
                </article>
                <article>
                    <i class="fas fa-gem"></i>
                    <div>
                        <strong>Puanla ekstra indirim</strong>
                        <span>Sadakat puanı ile aktive edilen özel kuponlar</span>
                    </div>
                </article>
            </div>
            <div class="reward-actions">
                <a asp-action="Loyalty" class="reward-link">Fırsatları keşfet</a>
                <a asp-action="Favorites" class="reward-link secondary">Favorilerden devam et</a>
            </div>
        </section>
    </div>
</section>
