@model otelturizmnew.Models.Paneller.User.UserPaymentMethodsPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Ödeme Yöntemleri";
}

<section class="payment-hero">
    <div>
        <span class="panel-eyebrow">Ödeme merkezi</span>
        <h1>Ödeme Yöntemleri</h1>
        <p>Kayıtlı kartlarını, varsayılan ödeme tercihini ve fatura bilgilerini tek ekrandan yönet.</p>
    </div>
    <div class="payment-hero-metric">
        <strong>@Model.Methods.Count</strong>
        <span>Kayıtlı kart</span>
    </div>
</section>

@if (TempData["UserPaymentSuccess"] is string success)
{
    <div class="payment-alert success">@success</div>
}
@if (TempData["UserPaymentError"] is string error)
{
    <div class="payment-alert danger">@error</div>
}

<section class="payment-grid">
    <article class="payment-panel payment-panel--cards">
        <div class="payment-panel-head">
            <div>
                <h2>Kayıtlı Kartlar</h2>
                <p>Ödeme sırasında kullanabileceğin güvenli kart kayıtları.</p>
            </div>
            <span class="payment-count-pill">@Model.Methods.Count kart</span>
        </div>

        <div class="payment-card-list">
            @if (Model.Methods.Count == 0)
            {
                <div class="payment-empty">
                    <i class="fas fa-credit-card"></i>
                    <strong>Henüz kayıtlı kart yok</strong>
                    <span>Aşağıdaki formdan yeni ödeme yöntemi ekleyebilirsin.</span>
                </div>
            }
            else
            {
                foreach (var method in Model.Methods)
                {
                    <div class="payment-method-row">
                        <div class="payment-card-icon"><i class="fas fa-credit-card"></i></div>
                        <div>
                            <h3>@method.Label</h3>
                            <p>@method.DetailText</p>
                        </div>
                        <div class="action-row">
                            @if (method.IsDefault)
                            {
                                <span class="payment-status-pill">Varsayılan</span>
                            }
                            <form method="post" asp-action="DeletePaymentMethod">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="paymentMethodId" value="@method.PaymentMethodId" />
                                <button type="submit" class="btn-danger-soft">Sil</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </article>

    <form method="post" asp-action="SavePaymentMethod" class="payment-panel">
        @Html.AntiForgeryToken()
        <div class="payment-panel-head">
            <div>
                <h2>Yeni Kart Ekle</h2>
                <p>Kart bilgilerini maskeleme standardına uygun şekilde kaydet.</p>
            </div>
            <button type="submit" class="btn-primary-solid">
                <i class="fas fa-save"></i>
                Kaydet
            </button>
        </div>
        <div class="form-grid">
            <label><span>Kart Etiketi</span><input asp-for="Form.CardLabel" type="text" placeholder="Kişisel Kart" /></label>
            <label><span>Kart Sahibi</span><input asp-for="Form.CardHolder" type="text" placeholder="Ad Soyad" /></label>
            <label><span>Marka</span><input asp-for="Form.Brand" type="text" placeholder="Visa / Mastercard" /></label>
            <label><span>Son 4 Hane</span><input asp-for="Form.LastFourDigits" type="text" maxlength="4" inputmode="numeric" /></label>
            <label><span>Son Kullanım Ay</span><input asp-for="Form.ExpiryMonth" type="number" min="1" max="12" /></label>
            <label><span>Son Kullanım Yıl</span><input asp-for="Form.ExpiryYear" type="number" min="2026" max="2100" /></label>
        </div>
        <label class="toggle-row no-border">
            <div>
                <h3>Varsayılan kart yap</h3>
                <p>Ödeme sırasında öncelikli kart olarak kullanılsın.</p>
            </div>
            <input asp-for="Form.SetAsDefault" type="checkbox" />
        </label>
    </form>
</section>

<section class="payment-panel">
    <div class="payment-panel-head">
        <div>
            <h2>Fatura Bilgileri</h2>
            <p>Rezervasyon faturalarında kullanılacak temel bilgiler.</p>
        </div>
    </div>
    <form method="post" asp-action="SaveBilling" class="form-grid">
        @Html.AntiForgeryToken()
        <label><span>Fatura Ünvanı</span><input asp-for="BillingForm.InvoiceName" type="text" required /></label>
        <label><span>Adres</span><input asp-for="BillingForm.AddressLine" type="text" /></label>
        <label><span>İlçe</span><input asp-for="BillingForm.District" type="text" /></label>
        <label><span>Şehir</span><input asp-for="BillingForm.City" type="text" /></label>
        <label><span>E-posta</span><input asp-for="BillingForm.Email" type="email" readonly disabled /></label>
        <div class="payment-panel-head" style="grid-column: 1 / -1; margin-top: 8px;">
            <button type="submit" class="btn-primary-solid"><i class="fas fa-save"></i> Fatura Bilgilerini Kaydet</button>
        </div>
    </form>
</section>
