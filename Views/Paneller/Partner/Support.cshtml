@model otelturizmnew.Models.Paneller.Partner.PartnerSupportPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["Title"] = "Partner 7/24 Destek";
    ViewData["PageCssPath"] = "paneller/partner/support";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Partner</div>
            <h2 class="page-title">7/24 Destek Merkezi</h2>
            <div class="text-muted mt-1">Destek taleplerinizi yönetin, mesajlaşın ve bilgi bankasına hızlı erişin.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <div class="btn-list">
                <a class="btn btn-primary" href="#destek-talebi">
                    <i class="fas fa-plus me-2" aria-hidden="true"></i>Yeni Talep
                </a>
                <a class="btn btn-outline-primary" href="/yardim-merkezi">
                    <i class="fas fa-book-open me-2" aria-hidden="true"></i>Yardım Merkezi
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <span class="avatar bg-@card.ToneClass-lt text-@card.ToneClass me-3">
                            <i class="fas @card.IconClass" aria-hidden="true"></i>
                        </span>
                        <div>
                            <div class="h3 m-0">@card.Value</div>
                            <div class="text-muted">@card.Label</div>
                        </div>
                    </div>
                    <div class="text-muted mt-2 small">@card.Description</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row row-cards mt-2">
    <div class="col-12 col-xl-4">
        <div class="card support-ticket-card">
            <div class="card-header">
                <div>
                    <h3 class="card-title">Destek Talepleri</h3>
                    <div class="text-muted">Son güncellenen kayıtlar</div>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Tickets.Count == 0)
                {
                    <div class="empty py-6">
                        <div class="empty-icon"><i class="fas fa-life-ring"></i></div>
                        <p class="empty-title">Henüz destek talebi yok</p>
                        <p class="empty-subtitle text-muted">Yeni bir talep oluşturarak destek ekibine ulaşabilirsiniz.</p>
                        <div class="empty-action">
                            <a href="#destek-talebi" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Talep Oluştur
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush support-ticket-list">
                        @foreach (var t in Model.Tickets)
                        {
                            <a class="list-group-item list-group-item-action support-ticket-item @(t.IsSelected ? "active" : string.Empty)"
                               href="/panel/partner/724-destek?otelId=@Model.Shell.SelectedHotelId&ticketId=@t.TicketId">
                                <div class="d-flex w-100 justify-content-between align-items-start gap-2">
                                    <div class="support-ticket-title">
                                        <div class="support-ticket-no">@t.TicketNo</div>
                                        <div class="fw-bold text-truncate">@t.Subject</div>
                                        <div class="text-muted small">@t.Category · @t.Priority</div>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-secondary-lt text-secondary">@t.Status</span>
                                        <div class="text-muted small mt-1">@t.UpdatedText</div>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h3 class="card-title">Bilgi Bankası</h3>
            </div>
            <div class="card-body">
                @if (Model.KnowledgeBaseArticles.Count == 0)
                {
                    <div class="text-muted">Şu an önerilen makale bulunamadı.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var a in Model.KnowledgeBaseArticles)
                        {
                            <a class="list-group-item list-group-item-action" href="@a.Url">
                                <div class="fw-bold">@a.Title</div>
                                <div class="text-muted small">@a.Summary</div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card support-chat-card">
            <div class="card-header">
                @if (Model.SelectedTicket is null)
                {
                    <div>
                        <h3 class="card-title">Mesajlar</h3>
                        <div class="text-muted">Bir talep seçin</div>
                    </div>
                }
                else
                {
                    <div class="support-chat-head">
                        <div>
                            <div class="support-chat-kicker">@Model.SelectedTicket.TicketNo · @Model.SelectedTicket.Category · @Model.SelectedTicket.Priority</div>
                            <h3 class="card-title mb-0">@Model.SelectedTicket.Subject</h3>
                            <div class="text-muted small">Durum: <strong>@Model.SelectedTicket.Status</strong> · Son güncelleme: @Model.SelectedTicket.UpdatedText</div>
                        </div>
                        <div class="support-chat-actions">
                            <form method="post" action="/panel/partner/724-destek/kapat" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="hotelId" value="@Model.SendMessageForm.HotelId" />
                                <input type="hidden" name="ticketId" value="@Model.SelectedTicket.TicketId" />
                                <button type="submit" class="btn btn-outline-success">
                                    <i class="fas fa-circle-check me-2"></i>Çözüldü
                                </button>
                            </form>
                            <a href="#destek-talebi" class="btn btn-outline-primary">
                                <i class="fas fa-plus me-2"></i>Yeni Talep
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="card-body support-chat-body">
                @if (Model.SelectedTicket is null)
                {
                    <div class="empty py-6">
                        <div class="empty-icon"><i class="fas fa-comments"></i></div>
                        <p class="empty-title">Mesajlaşmayı başlatmak için bir talep seçin</p>
                        <p class="empty-subtitle text-muted">Sol taraftaki talepler listesinden bir kayıt seçebilirsiniz.</p>
                    </div>
                }
                else if (Model.Messages.Count == 0)
                {
                    <div class="empty py-6">
                        <div class="empty-icon"><i class="fas fa-message"></i></div>
                        <p class="empty-title">Henüz mesaj yok</p>
                        <p class="empty-subtitle text-muted">Aşağıdaki alandan ilk mesajı gönderebilirsiniz.</p>
                    </div>
                }
                else
                {
                    <div class="support-chat-stream" id="supportChatStream">
                        @foreach (var m in Model.Messages)
                        {
                            <div class="support-msg @(m.IsFromPartner ? "is-me" : "is-them")">
                                <div class="support-msg-bubble">
                                    <div class="support-msg-meta">
                                        <strong>@m.SenderLabel</strong>
                                        <span>@m.TimeText</span>
                                    </div>
                                    <div class="support-msg-text">@m.Body</div>
                                    @if (!string.IsNullOrWhiteSpace(m.AttachmentUrl))
                                    {
                                        <a class="support-msg-attachment" href="@m.AttachmentUrl" target="_blank" rel="noopener">
                                            <i class="fas fa-paperclip me-2"></i>Ek dosyayı aç
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (Model.SelectedTicket is not null)
            {
                <div class="card-footer support-chat-footer">
                    <form method="post" action="/panel/partner/724-destek/mesaj-gonder" enctype="multipart/form-data" class="support-chat-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="HotelId" value="@Model.SendMessageForm.HotelId" />
                        <input type="hidden" name="TicketId" value="@Model.SelectedTicket.TicketId" />
                        <div class="support-chat-inputs">
                            <textarea class="form-control" name="Message" rows="2" placeholder="Mesaj yazın..." required></textarea>
                            <div class="support-chat-tools">
                                <label class="btn btn-outline-secondary btn-sm mb-0">
                                    <i class="fas fa-paperclip me-2"></i>Dosya
                                    <input type="file" name="File" hidden />
                                </label>
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="fas fa-paper-plane me-2"></i>Gönder
                                </button>
                            </div>
                        </div>
                        <div class="text-muted small mt-2">Dosya ekleri en fazla 10MB.</div>
                    </form>
                </div>
            }
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h3 class="card-title">Destek Kanalları</h3>
                <div class="text-muted">Alternatif bağlantı seçenekleri</div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var channel in Model.Channels)
                    {
                        var normalizedValue = channel.Value?.Trim() ?? string.Empty;
                        var actionHref = normalizedValue.Contains('@')
                            ? $"mailto:{normalizedValue}"
                            : normalizedValue.StartsWith("+")
                                ? $"tel:{normalizedValue.Replace(" ", string.Empty)}"
                                : "#destek-talebi";
                        <div class="col-12 col-md-6">
                            <div class="support-channel">
                                <span class="support-channel-ico"><i class="fas @channel.IconClass" aria-hidden="true"></i></span>
                                <div class="support-channel-copy">
                                    <strong>@channel.Name</strong>
                                    <div class="text-muted small">@channel.Value</div>
                                    <div class="text-muted small">@channel.Description</div>
                                </div>
                                <a href="@actionHref" class="btn btn-outline-primary btn-sm">Bağlan</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3" id="destek-talebi">
    <div class="card-header">
        <h3 class="card-title">Destek Talebi Oluştur</h3>
        <div class="text-muted">Konu, kategori ve mesaj ile yeni bir kayıt oluşturun.</div>
    </div>
    <div class="card-body">
        <form method="post" action="/panel/partner/724-destek/talep-olustur">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.CreateTicketForm.HotelId" />
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Konu</label>
                    <input class="form-control" type="text" name="Subject" placeholder="Örn. Fiyat güncelleme ekranı hata veriyor" required />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Kategori</label>
                    <select class="form-select" name="Category">
                        <option>Operasyon</option>
                        <option>Panel</option>
                        <option>Fiyat/Stok</option>
                        <option>Medya</option>
                        <option>Rezervasyon</option>
                        <option>Ödeme</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Öncelik</label>
                    <select class="form-select" name="Priority">
                        <option>Normal</option>
                        <option>Yüksek</option>
                        <option>Kritik</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Mesaj</label>
                    <textarea class="form-control" name="Message" rows="4" placeholder="Detayları yazın..." required></textarea>
                </div>
                <div class="col-12">
                    <button class="btn btn-primary">
                        <i class="fas fa-life-ring me-2"></i>Talep Aç
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const stream = document.getElementById('supportChatStream');
            if (stream) {
                stream.scrollTop = stream.scrollHeight;
            }
        })();
    </script>
}
