@model otelturizmnew.Models.Paneller.Partner.PartnerSupportPageViewModel
@{ Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml"; ViewData["PartnerShell"] = Model.Shell; }
<section class="partner-grid">
@foreach (var card in Model.SummaryCards)
{
    <article class="partner-stat-card @card.ToneClass"><i class="fas @card.IconClass"></i><strong>@card.Value</strong><span>@card.Label</span><p>@card.Description</p></article>
}
</section>
<section class="partner-two-column">
    <article class="partner-section-card">
        <h2>Açık Destek Talepleri</h2>
        @if (Model.Tickets.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Henüz açık talep yok</strong>
                <p>Yeni destek talepleriniz bu alanda listelenecek.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var item in Model.Tickets)
                {
                    <div class="partner-list-row">
                        <strong>@item.TicketNo - @item.Subject</strong>
                        <span>@item.Category / @item.Priority</span>
                        <small>@item.Status</small>
                        <b>@item.UpdatedText</b>
                    </div>
                }
            </div>
        }
    </article>
    <article class="partner-section-card">
        <h2>Bilgi Bankası</h2>
        @if (Model.KnowledgeBaseArticles.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Bilgi bankası makalesi bulunamadı</strong>
                <p>Destek içerikleri eklendikçe burada hızlı bağlantılar göreceksiniz.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var article in Model.KnowledgeBaseArticles)
                {
                    <a href="@article.Url" class="partner-list-row partner-inline-link">
                        <strong>@article.Title</strong>
                        <span>@article.Summary</span>
                    </a>
                }
            </div>
        }
    </article>
</section>
<section class="partner-section-card">
        <h2>Destek Kanalları</h2>
    <div class="partner-support-channels">
        @foreach (var channel in Model.Channels)
        {
            var normalizedValue = channel.Value?.Trim() ?? string.Empty;
            var actionHref = normalizedValue.Contains('@')
                ? $"mailto:{normalizedValue}"
                : normalizedValue.StartsWith("+")
                    ? $"tel:{normalizedValue.Replace(" ", string.Empty)}"
                    : "#destek-talebi";
            <article class="partner-support-channel">
                <i class="fas @channel.IconClass"></i>
                <div>
                    <strong>@channel.Name</strong>
                    <span>@channel.Value</span>
                    <p>@channel.Description</p>
                </div>
                <a href="@actionHref" class="partner-secondary-btn partner-inline-btn">Bağlan</a>
            </article>
        }
    </div>
</section>
<section class="partner-two-column">
    <article class="partner-section-card">
        <h2>Hızlı destek aksiyonları</h2>
        <div class="partner-list">
            <a href="#destek-talebi" class="partner-list-row partner-inline-link">
                <strong>Teknik destek talebi aç</strong>
                <span>Panel, fiyat veya medya akışlarındaki sorunları anında iletin.</span>
            </a>
            <a href="#destek-talebi" class="partner-list-row partner-inline-link">
                <strong>Demo randevusu iste</strong>
                <span>Operasyon ekibinden panel kullanım demosu talep edin.</span>
            </a>
            <a href="/yardim-merkezi" class="partner-list-row partner-inline-link">
                <strong>Yardım merkezine git</strong>
                <span>SSS, fiyat güncelleme ve entegrasyon rehberlerine ulaşın.</span>
            </a>
        </div>
    </article>
    <article class="partner-section-card">
        <h2>Hızlı SSS</h2>
        <div class="partner-list">
            <div class="partner-list-row">
                <strong>Fiyatları toplu nasıl güncellerim?</strong>
                <span>Takvim ve Fiyatlar ekranındaki çoklu fiyat güncelleme panelinden tarih ve oda seçerek.</span>
            </div>
            <div class="partner-list-row">
                <strong>Kapak fotoğrafını nasıl değiştiririm?</strong>
                <span>Fotoğraflar ekranında ilgili görsel kartından Kapak yap aksiyonunu kullanarak.</span>
            </div>
            <div class="partner-list-row">
                <strong>Misafire nasıl mesaj gönderirim?</strong>
                <span>Rezervasyonlar ekranındaki zarf ikonundan rezervasyon bazlı mesaj panelini açarak.</span>
            </div>
        </div>
    </article>
</section>
<section id="destek-talebi" class="partner-section-card">
    <h2>Destek Talebi Oluştur</h2>
    <form method="post" action="/panel/partner/724-destek/talep-olustur" class="partner-form-grid">
        @Html.AntiForgeryToken()
        <input type="hidden" name="HotelId" value="@Model.CreateTicketForm.HotelId" />
        <input type="text" name="Subject" placeholder="Konu" />
        <input type="text" name="Category" placeholder="Kategori" value="Operasyon" />
        <input type="text" name="Priority" placeholder="Öncelik" value="Normal" />
        <textarea name="Message" placeholder="Mesajınız"></textarea>
        <button type="submit" class="partner-primary-btn">Talep Aç</button>
    </form>
</section>
