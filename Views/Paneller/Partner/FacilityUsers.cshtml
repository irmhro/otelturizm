@model otelturizmnew.Models.Paneller.Partner.PartnerFacilityUsersPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Güvenlik</div>
            <h2 class="page-title">Tesis Kullanıcıları</h2>
            <div class="text-muted mt-1">
                <strong class="text-body">@Model.HotelName</strong> için kullanıcı yetkilerini yönetin (çoklu kullanıcı + süreli erişim + e‑posta onayı).
            </div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <div class="btn-list">
                <a class="btn btn-outline-primary" href="/panel/partner/guvenlik?otelId=@Model.HotelId">
                    <i class="fas fa-arrow-left me-2"></i>Güvenlik
                </a>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Warning))
{
    <div class="alert alert-warning" role="alert">
        <div class="d-flex">
            <div class="me-3"><i class="fas fa-triangle-exclamation"></i></div>
            <div>@Model.Warning</div>
        </div>
    </div>
}

<div class="row row-cards">
    <div class="col-12 col-xl-5">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Yeni kullanıcı daveti</h3>
            </div>
            <div class="card-body">
                <form method="post" action="/panel/partner/guvenlik/tesis-kullanicilari/davet">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.HotelId" />
                    <div class="mb-3">
                        <label class="form-label">Kullanıcı e‑posta</label>
                        <input class="form-control" name="Email" type="email" placeholder="ornek@firma.com" required />
                        <div class="form-hint">Kullanıcı hesabı mevcut olmalı ve e‑posta doğrulaması tamamlanmış olmalı.</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Başlangıç</label>
                            <input class="form-control" name="StartDate" type="date" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Bitiş</label>
                            <input class="form-control" name="EndDate" type="date" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-primary w-100" type="submit">
                            <i class="fas fa-paper-plane me-2"></i>Davet gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Yetkili kullanıcılar</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>Durum</th>
                        <th>Süre</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr>
                            <td colspan="4">
                                <div class="empty">
                                    <div class="empty-icon"><i class="fas fa-user-shield"></i></div>
                                    <p class="empty-title">Henüz tesis kullanıcısı yok</p>
                                    <p class="empty-subtitle text-muted">E‑posta ile davet göndererek yeni kullanıcı ekleyebilirsiniz.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var u in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@(!string.IsNullOrWhiteSpace(u.FullName) ? u.FullName : $"Kullanıcı #{u.UserId}")</div>
                                    <div class="text-muted">@u.Email @(!u.EmailVerified ? "· doğrulanmamış" : "")</div>
                                    @if (!string.IsNullOrWhiteSpace(u.InviteSentAtText))
                                    {
                                        <div class="text-muted small">Davet: @u.InviteSentAtText</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(u.ApprovedAtText))
                                    {
                                        <div class="text-muted small">Onay: @u.ApprovedAtText</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(u.Status == "Aktif" ? "bg-success-lt text-success" : u.Status == "Beklemede" ? "bg-warning-lt text-warning" : "bg-muted-lt text-muted")">
                                        @u.Status
                                    </span>
                                </td>
                                <td class="text-muted">
                                    @(string.IsNullOrWhiteSpace(u.StartDateText) ? "-" : u.StartDateText)
                                    —
                                    @(string.IsNullOrWhiteSpace(u.EndDateText) ? "-" : u.EndDateText)
                                </td>
                                <td class="text-end">
                                    <form method="post" action="/panel/partner/guvenlik/tesis-kullanicilari/iptal" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="HotelId" value="@Model.HotelId" />
                                        <input type="hidden" name="AssignmentId" value="@u.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-ban me-1"></i>İptal
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

