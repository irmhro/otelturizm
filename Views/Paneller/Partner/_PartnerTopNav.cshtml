@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Partner
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@model PartnerShellViewModel
@{
    var fn = Model.FullName?.Trim() ?? string.Empty;
    var initial = fn.Length > 0 ? char.ToUpper(fn[0]).ToString() : "P";
    var hotelQuery = Model.SelectedHotelId.HasValue ? $"?otelId={Model.SelectedHotelId.Value}" : string.Empty;
    string PartnerUrl(string path) => $"{path}{hotelQuery}";
    var selectedHotelName = string.IsNullOrWhiteSpace(Model.SelectedHotelName) ? "Partner Oteli" : Model.SelectedHotelName;
    var partnerUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var partnerUserId = long.TryParse(partnerUserRaw, out var parsedPartnerUserId) ? parsedPartnerUserId : 0;
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.Partner, partnerUserId, Context.RequestAborted);
}
<header class="global-topbar" role="banner">
    <div class="topbar-left">
        <button type="button" class="menu-trigger" id="partnerSidebarToggle" aria-label="Menüyü aç/kapat">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <div class="pp-hotel-chip d-none d-lg-inline-flex" title="@selectedHotelName">
            <i class="fas fa-hotel"></i>
            <span>@selectedHotelName</span>
        </div>
        <div class="header-search">
            <i class="fas fa-search"></i>
            <input type="search" id="partnerGlobalSearch" placeholder="Rezervasyon, misafir veya oda ara..." autocomplete="off"
                   data-partner-search-base="/panel/partner/rezervasyonlar"
                   data-partner-hotel-id="@(Model.SelectedHotelId?.ToString() ?? string.Empty)" />
        </div>
    </div>

    <div class="topbar-right">
        <a class="btn-outline-ap d-none d-md-inline-flex" style="height:34px;font-size:12px;padding:0 10px;" href="@PartnerUrl("/panel/partner/otel-bilgileri")">
            <i class="fas fa-pen-to-square"></i> Tesis
        </a>
        <button type="button" class="utility-btn d-none d-md-flex" data-bs-toggle="offcanvas" data-bs-target="#partnerThemeSettings" aria-label="Tema ayarları">
            <i class="fas fa-palette"></i>
        </button>
        <a class="pp-topbar-favorites d-none d-lg-inline-flex" href="@PartnerUrl("/panel/partner/pazarlama/favori-misafirler")" title="@Model.FavoriteSummaryText">
            <i class="fas fa-heart"></i>
            <span>@Model.FavoriteCount</span>
        </a>
        <div class="header-bildiri partner-header-bildiri" data-header-bildiri data-panel-key="@headerBildiri.PanelKey" data-unread-count="@headerBildiri.UnreadCount" data-open="false">
            @Html.AntiForgeryToken()
            <button class="header-bildiri-btn utility-btn" type="button" data-header-bildiri-toggle aria-expanded="false" aria-label="Bildirimleri aç">
                <i class="far fa-bell"></i>
                @if (headerBildiri.UnreadCount > 0)
                {
                    <span class="bell-dot"></span>
                }
            </button>
            <div class="header-bildiri-dropdown" role="dialog" aria-label="Partner bildirimleri">
                <div class="header-bildiri-head">
                    <strong>Bildirimler</strong>
                    <span>@headerBildiri.UnreadCount okunmamış</span>
                </div>
                <ul class="header-bildiri-list">
                    @foreach (var item in headerBildiri.Items)
                    {
                        <li class="header-bildiri-item tone-@item.Tone @(item.IsRead ? "is-read" : "is-unread")"
                            data-header-item-key="@item.ItemKey"
                            data-header-item-read="@(item.IsRead ? "1" : "0")">
                            <a href="@item.Url" data-header-item-link>
                                <i class="fas @item.IconClass"></i>
                                <span class="header-bildiri-content">
                                    <strong>@item.Title</strong>
                                    <p>@item.Description</p>
                                    <span class="header-bildiri-time">
                                        <span class="header-bildiri-time-chip">@item.TimeLabel</span>
                                    </span>
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <a class="btn-quick-add" href="@PartnerUrl("/panel/partner/takvim-fiyatlar")">
            <i class="fas fa-plus"></i>
            <span>Fiyat Güncelle</span>
        </a>

        <div class="profile-dropdown-wrapper">
            <div class="avatar-trigger" id="partnerAvatarBtn" role="button" tabindex="0" aria-haspopup="true">
                <span class="header-avatar">@initial</span>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="profile-dropdown" id="partnerProfileDropdown">
                <div class="dropdown-header">
                    <strong>@Model.FullName</strong>
                    <span>@Model.Email</span>
                </div>
                <ul class="dropdown-menu-list">
                    <li><a href="@PartnerUrl("/panel/partner/hesap-bilgileri")"><i class="fas fa-user-circle"></i> Hesabım</a></li>
                    <li><a href="@PartnerUrl("/panel/partner/dashboard")"><i class="fas fa-chart-pie"></i> Kokpit</a></li>
                    <li><a href="@PartnerUrl("/panel/partner/724-destek")"><i class="fas fa-headset"></i> 7/24 Destek</a></li>
                    <li><div class="dropdown-divider"></div></li>
                    <li>
                        <form method="post" action="/cikis-yap" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-danger"><i class="fas fa-sign-out-alt"></i> Güvenli Çıkış</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>
