@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerDashboardViewModel
@{ Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml"; ViewData["PartnerShell"] = Model.Shell; }
<section class="partner-grid partner-dashboard-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="partner-stat-card @card.ToneClass">
            <i class="fas @card.IconClass"></i>
            <strong>@card.Value</strong>
            <span>@card.Label</span>
            <p>@card.Description</p>
        </article>
    }
</section>
<section class="partner-dashboard-actions">
    @foreach (var action in Model.QuickActions)
    {
        <a href="@action.Url" class="partner-dashboard-action-card @action.ToneClass">
            <i class="fas @action.IconClass"></i>
            <div>
                <strong>@action.Title</strong>
                <p>@action.Description</p>
            </div>
        </a>
    }
</section>
<section class="partner-two-column">
    <article class="partner-section-card partner-revenue-card">
        <h2>Gelir Trendi</h2>
        @if (Model.RevenueTrend.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Henüz gelir verisi yok</strong>
                <p>Rezervasyon ve odeme verileri geldikce grafikler burada dolacak.</p>
            </div>
        }
        else
        {
            <div class="partner-chart-bars">
                @foreach (var point in Model.RevenueTrend)
                {
                    <div class="chart-col">
                        <span class="chart-bar" style="height:@(point.HeightPercent)%"></span>
                        <strong>@point.Label</strong>
                        <small>@point.ReservationCount rezervasyon</small>
                        <em>@point.RevenueAmount.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))</em>
                    </div>
                }
            </div>
        }
    </article>
    <article class="partner-section-card">
        <h2>Yaklasan Rezervasyonlar</h2>
        @if (Model.UpcomingReservations.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Yaklasan rezervasyon yok</strong>
                <p>Yeni rezervasyonlar geldiginde burada goreceksiniz.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var item in Model.UpcomingReservations)
                {
                    <div class="partner-list-row partner-list-row-rich">
                        <div>
                            <strong>@item.GuestName</strong>
                            <span>@item.StayText</span>
                            <small>@item.StatusLabel · @item.PaymentStatusLabel</small>
                        </div>
                        <div class="partner-list-actions">
                            <b>@item.TotalText</b>
                            @if (item.CanApprove)
                            {
                                <form method="post" action="/panel/partner/rezervasyonlar/durum" class="partner-quick-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
                                    <input type="hidden" name="ReservationId" value="@item.ReservationId" />
                                    <input type="hidden" name="ActionType" value="approve" />
                                    <button type="submit" class="partner-dashboard-action-btn is-success">
                                        <i class="fas fa-circle-check"></i>
                                        Onayla
                                    </button>
                                </form>
                            }
                            @if (item.CanReject)
                            {
                                <form method="post" action="/panel/partner/rezervasyonlar/durum" class="partner-quick-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
                                    <input type="hidden" name="ReservationId" value="@item.ReservationId" />
                                    <input type="hidden" name="ActionType" value="reject" />
                                    <input type="hidden" name="Reason" value="Panel hızlı aksiyonundan reddedildi." />
                                    <button type="submit" class="partner-dashboard-action-btn is-danger">
                                        <i class="fas fa-circle-xmark"></i>
                                        Reddet
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </article>
</section>
<section class="partner-two-column">
    <article class="partner-section-card">
        <h2>Müsaitlik Uyarıları</h2>
        @if (Model.InventoryAlerts.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Kritik stok uyarısı yok</strong>
                <p>Düşük stok veya kapalı satış günleri burada listelenecek.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var alert in Model.InventoryAlerts)
                {
                    <div class="partner-list-row"><strong>@alert.RoomName</strong><span>@alert.DateText</span><b>@alert.AvailabilityText</b></div>
                }
            </div>
        }
    </article>
    <article class="partner-section-card">
        <h2>Son Yorumlar</h2>
        @if (Model.RecentReviews.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Yorum bulunmuyor</strong>
                <p>Onaylı veya bekleyen yorumlar bu alanda hızlıca görünür.</p>
            </div>
        }
        else
        {
            <div class="partner-review-stack">
                @foreach (var review in Model.RecentReviews)
                {
                    <article class="partner-review-card">
                        <strong>@review.GuestName - @review.ScoreText</strong>
                        <span>@review.Title</span>
                        <p>@review.Comment</p>
                    </article>
                }
            </div>
        }
    </article>
</section>
