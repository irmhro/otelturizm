@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerDashboardViewModel
@{ Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml"; ViewData["PartnerShell"] = Model.Shell; }
<section class="partner-grid partner-dashboard-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="partner-stat-card @card.ToneClass">
            <i class="fas @card.IconClass"></i>
            <strong>@card.Value</strong>
            <span>@card.Label</span>
            <p>@card.Description</p>
        </article>
    }
</section>
<section class="partner-dashboard-actions">
    @foreach (var action in Model.QuickActions)
    {
        <a href="@action.Url" class="partner-dashboard-action-card @action.ToneClass">
            <i class="fas @action.IconClass"></i>
            <div>
                <strong>@action.Title</strong>
                <p>@action.Description</p>
            </div>
        </a>
    }
</section>
<section class="partner-two-column">
    <article class="partner-section-card partner-revenue-card">
        <h2>Gelir Trendi</h2>
        @if (Model.RevenueTrend.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Henüz gelir verisi yok</strong>
                <p>Rezervasyon ve odeme verileri geldikce grafikler burada dolacak.</p>
            </div>
        }
        else
        {
            <div class="partner-chart-bars">
                @foreach (var point in Model.RevenueTrend)
                {
                    <div class="chart-col">
                        <span class="chart-bar" style="height:@(point.HeightPercent)%"></span>
                        <strong>@point.Label</strong>
                        <small>@point.ReservationCount rezervasyon</small>
                        <em>@point.RevenueAmount.ToString("C0", CultureInfo.GetCultureInfo("tr-TR"))</em>
                    </div>
                }
            </div>
        }
    </article>
    <article class="partner-section-card">
        <h2>Yaklasan Rezervasyonlar</h2>
        <div class="partner-policy-alert @(Model.PenaltyActive ? "is-critical" : Model.RejectCountLast30Days >= 3 ? "is-warning" : string.Empty)">
            <h4>Rezervasyon onay ve red politikasi</h4>
            <p>Son 30 gundeki red sayiniz: <strong>@Model.RejectCountLast30Days</strong>. Her red icin nedeni detayli ve aydinlatici sekilde yazmaniz zorunludur.</p>
            <ul>
                <li>3 red ve uzeri: sistem tesisi 3 gun sureyle listelemeden otomatik kapatir.</li>
                <li>5 red ve uzeri: kontenjan ve fiyat stratejisinin tekrar yapilandirilmasi onerilir.</li>
                <li>Onay ve red islemlerinde misafire e-posta bildirimi otomatik gonderilir.</li>
            </ul>
            @if (Model.PenaltyActive && !string.IsNullOrWhiteSpace(Model.PenaltyEndText))
            {
                <p class="partner-policy-meta">Cezai kapatma bitis tarihi: <strong>@Model.PenaltyEndText</strong></p>
            }
        </div>
        @if (Model.UpcomingReservations.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Yaklasan rezervasyon yok</strong>
                <p>Yeni rezervasyonlar geldiginde burada goreceksiniz.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var item in Model.UpcomingReservations)
                {
                    <div class="partner-list-row partner-list-row-rich">
                        <div>
                            <strong>@item.GuestName</strong>
                            <span>@item.StayText</span>
                            <small>@item.StatusLabel · @item.PaymentStatusLabel</small>
                        </div>
                        <div class="partner-list-actions">
                            <b>@item.TotalText</b>
                            @if (item.CanApprove)
                            {
                                <form method="post" action="/panel/partner/rezervasyonlar/durum" class="partner-quick-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
                                    <input type="hidden" name="ReservationId" value="@item.ReservationId" />
                                    <input type="hidden" name="ActionType" value="approve" />
                                    <input type="hidden" name="ReturnUrl" value="/panel/partner/dashboard?otelId=@Model.Shell.SelectedHotelId" />
                                    <button type="submit" class="partner-dashboard-action-btn is-success">
                                        <i class="fas fa-circle-check"></i>
                                        Onayla
                                    </button>
                                </form>
                            }
                            @if (item.CanReject)
                            {
                                <button type="button"
                                        class="partner-dashboard-action-btn is-danger"
                                        data-dashboard-reservation-reject
                                        data-reservation-id="@item.ReservationId"
                                        data-reservation-no="@item.ReservationNo"
                                        data-guest-name="@item.GuestName">
                                    <i class="fas fa-circle-xmark"></i>
                                    Reddet
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </article>
</section>

<dialog id="partner-dashboard-reject-dialog" class="partner-dialog">
    <div class="partner-dialog-card">
        <div class="partner-dialog-head">
            <div>
                <p class="partner-dialog-kicker">Rezervasyon reddet</p>
                <h3 id="dashboard-reject-title">Red sebebini belirtin</h3>
            </div>
            <button type="button" class="partner-icon-btn" data-close-dashboard-dialog>
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <div class="partner-policy-alert @(Model.PenaltyActive ? "is-critical" : Model.RejectCountLast30Days >= 3 ? "is-warning" : string.Empty)">
            <p>Bu islem misafire aciklayici bir neden ile bildirilir. Son 30 gunde <strong>@Model.RejectCountLast30Days</strong> red gorunuyor.</p>
            <ul>
                <li>3 red ve uzeri durumunda tesis 3 gun otomatik kapanir.</li>
                <li>5 red ve uzeri durumunda fiyat ve kontenjan stratejisi gozden gecirilmelidir.</li>
            </ul>
        </div>
        <form method="post" action="/panel/partner/rezervasyonlar/durum" class="partner-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
            <input type="hidden" name="ReservationId" id="dashboard-reject-id" value="0" />
            <input type="hidden" name="ActionType" value="reject" />
            <input type="hidden" name="ReturnUrl" value="/panel/partner/dashboard?otelId=@Model.Shell.SelectedHotelId" />
            <label class="partner-form-span">
                <span>Misafire gidecek detayli red aciklamasi</span>
                <textarea name="Reason" id="dashboard-reject-reason" rows="6" minlength="15" required placeholder="Odayi neden onaylayamadiginizi, alternatif oneriniz varsa bunu ve misafirin ne yapmasi gerektigini acikca yazin."></textarea>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-ban"></i>
                Red sebebi ile kaydet
            </button>
        </form>
    </div>
</dialog>
<section class="partner-two-column">
    <article class="partner-section-card">
        <h2>Müsaitlik Uyarıları</h2>
        @if (Model.InventoryAlerts.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Kritik stok uyarısı yok</strong>
                <p>Düşük stok veya kapalı satış günleri burada listelenecek.</p>
            </div>
        }
        else
        {
            <div class="partner-list">
                @foreach (var alert in Model.InventoryAlerts)
                {
                    <div class="partner-list-row"><strong>@alert.RoomName</strong><span>@alert.DateText</span><b>@alert.AvailabilityText</b></div>
                }
            </div>
        }
    </article>
    <article class="partner-section-card">
        <div class="partner-section-card-head">
            <div>
                <h2>Son Yorumlar</h2>
                <p>En güncel 2 misafir yorumunu buradan izleyin.</p>
            </div>
            <a class="partner-section-link" href="/panel/partner/degerlendirmeler?otelId=@Model.Shell.SelectedHotelId">Tüm Yorumlar</a>
        </div>
        @if (Model.RecentReviews.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Yorum bulunmuyor</strong>
                <p>Onaylı veya bekleyen yorumlar bu alanda hızlıca görünür.</p>
            </div>
        }
        else
        {
            <div class="partner-review-stack">
                @foreach (var review in Model.RecentReviews)
                {
                    <article class="partner-review-card">
                        <strong>@review.GuestName - @review.ScoreText</strong>
                        <small>@review.CreatedText</small>
                        <span>@review.Title</span>
                        <p>@review.Comment</p>
                    </article>
                }
            </div>
        }
    </article>
</section>

@section Scripts {
<script>
(() => {
    const rejectDialog = document.getElementById('partner-dashboard-reject-dialog');
    if (!rejectDialog) {
        return;
    }

    document.querySelectorAll('[data-dashboard-reservation-reject]').forEach((button) => {
        button.addEventListener('click', () => {
            document.getElementById('dashboard-reject-id').value = button.dataset.reservationId || '0';
            document.getElementById('dashboard-reject-title').textContent = `${button.dataset.reservationNo || 'Rezervasyon'} / ${button.dataset.guestName || 'Misafir'} icin red sebebi`;
            document.getElementById('dashboard-reject-reason').value = '';
            rejectDialog.showModal();
        });
    });

    document.querySelectorAll('[data-close-dashboard-dialog]').forEach((button) => {
        button.addEventListener('click', () => {
            button.closest('dialog')?.close();
        });
    });

    rejectDialog.addEventListener('click', (event) => {
        const rect = rejectDialog.getBoundingClientRect();
        const inDialog = rect.top <= event.clientY && event.clientY <= rect.top + rect.height && rect.left <= event.clientX && event.clientX <= rect.left + rect.width;
        if (!inDialog) {
            rejectDialog.close();
        }
    });
})();
</script>
}
