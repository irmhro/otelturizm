@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["Title"] = ViewData["Title"] as string ?? "Partner Paneli";
}

<section class="partner-section-card" style="max-width: 760px; margin: 0 auto;">
    <h2 style="margin-top:0;">Bu hesap için otel yetkisi tanımlı değil</h2>
    <p style="margin: 0; color: rgba(15,23,42,.72); line-height: 1.65;">
        Partner paneli, <strong>otel yetkisi</strong> tanımlı kullanıcılar için çalışır.
        Bu kullanıcıya henüz <strong>otel_kullanici_sahiplikleri</strong> kaydı bulunamadı.
    </p>
    <div style="margin-top: 16px; display: flex; flex-wrap: wrap; gap: 10px;">
        <a class="partner-secondary-btn" href="/partner-giris">
            <i class="fas fa-right-to-bracket"></i>
            Partner girişe dön
        </a>
        <a class="partner-secondary-btn" href="/">
            <i class="fas fa-arrow-left"></i>
            Ana sayfaya dön
        </a>
    </div>
    <div class="partner-empty-state" style="margin-top: 16px;">
        <strong>Ne yapılmalı?</strong>
        <p style="margin: 0;">
            Bu kullanıcıya bir otel tanımlanınca panel otomatik açılır.
        </p>
    </div>
</section>

