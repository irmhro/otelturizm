@model otelturizmnew.Models.Paneller.Partner.PartnerReservationGuestInvoicesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/finance";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Finans</div>
            <h2 class="page-title">Misafir Faturaları</h2>
            <div class="text-muted mt-1">Konaklaması tamamlanan rezervasyonlarda misafir faturası eksiklerini takip edip yükleyin.</div>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-primary btn-sm" href="/panel/partner/finans?otelId=@Model.Shell.SelectedHotelId">Finans merkezine dön</a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Rezervasyon listesi</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Rez. No</th>
                    <th>Misafir</th>
                    <th>Konaklama</th>
                    <th>Toplam</th>
                    <th>Durum</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="6" class="text-muted p-3">Tamamlanmış rezervasyon bulunmuyor.</td></tr>
            }
            else
            {
                foreach (var row in Model.Rows)
                {
                    <tr>
                        <td class="fw-bold">@row.ReservationNo</td>
                        <td>@row.GuestName</td>
                        <td class="text-muted">@row.StayText</td>
                        <td class="fw-bold">@row.TotalText</td>
                        <td>
                            @if (row.HasInvoice)
                            {
                                <span class="badge bg-success">Yüklendi</span>
                                @if (!string.IsNullOrWhiteSpace(row.UploadedAtText))
                                {
                                    <div class="small text-muted">@row.UploadedAtText</div>
                                }
                            }
                            else
                            {
                                <span class="badge bg-warning">Eksik</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (row.HasInvoice && !string.IsNullOrWhiteSpace(row.DownloadUrl))
                            {
                                <a class="btn btn-outline-primary btn-sm" href="@row.DownloadUrl">İndir</a>
                            }
                            else if (!row.HasInvoice && row.ReservationId > 0)
                            {
                                <form method="post" action="/panel/partner/finans/misafir-faturalari/yukle" enctype="multipart/form-data" class="d-inline-flex gap-2 align-items-center justify-content-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="hotelId" value="@Model.Shell.SelectedHotelId" />
                                    <input type="hidden" name="reservationId" value="@row.ReservationId" />
                                    <input type="file" name="invoiceFile" accept=".pdf,image/*" class="form-control form-control-sm" style="max-width: 240px;" required />
                                    <button type="submit" class="btn btn-primary btn-sm">Yükle</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

