@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerPricingPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var maxPricingDate = DateTime.Today.AddDays(365).ToString("yyyy-MM-dd");
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Fiyat</div>
            <h2 class="page-title">Süper fiyat (indirimli fiyat) uygulama</h2>
            <div class="text-muted mt-1">Seçili tarih aralığında indirimli fiyatı girin; isterseniz bir indirim etiketi seçip vitrin etiketini belirleyin.</div>
        </div>
        <div class="col-auto ms-auto">
            <a class="btn btn-outline-primary" href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@Model.SelectedRoomId&month=@Model.MonthKey">
                <i class="fas fa-calendar-days me-2"></i>Takvim & Fiyatlar
            </a>
        </div>
    </div>
</div>

<div class="row row-cards mt-2">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3 class="card-title mb-0">Toplu süper fiyat güncelleme</h3>
                    <div class="text-muted small">Bu form yalnızca indirimli fiyat/indirim etiketi ve satış durumunu etkiler.</div>
                </div>
            </div>
            <div class="card-body">
                <form method="post" action="/panel/partner/fiyat/super-fiyat/uygula" id="partnerSuperPriceForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <input type="hidden" name="ViewRoomId" value="@Model.SelectedRoomId" />
                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />

                    <div class="mb-3">
                        <div class="form-label">Güncelleme uygulanacak odalar</div>
                        <div class="row g-2">
                            @foreach (var room in Model.Rooms.Where(x => x.IsActive))
                            {
                                var isChecked = Model.BulkForm.SelectedRoomIds.Contains(room.RoomId);
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-check super-room-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoomIds" value="@room.RoomId" checked="@(isChecked ? "checked" : null)" />
                                        <span class="form-check-label">
                                            <span class="fw-bold">@room.RoomName</span>
                                            <span class="text-muted d-block small">@room.BasePriceText · @room.StockText</span>
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih başlangıcı</label>
                            <input class="form-control" type="date" name="DateFrom" value="@Model.BulkForm.DateFrom.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih bitişi</label>
                            <input class="form-control" type="date" name="DateTo" value="@Model.BulkForm.DateTo.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">İndirimli fiyat (vergi dahil)</label>
                            <input class="form-control" type="number" step="0.01" name="DiscountPrice" id="superDiscountPrice"
                                   value="@(Model.BulkForm.DiscountPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                                   placeholder="Mevcut kalsın" inputmode="decimal" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">İndirim seçimi</label>
                            <select class="form-select" name="DiscountId" id="superDiscountId">
                                <option value="">İndirim uygulanmayacak</option>
                                @foreach (var discount in Model.AvailableDiscounts)
                                {
                                    <option value="@discount.DiscountId">@discount.DiscountName</option>
                                }
                            </select>
                            <div class="form-hint text-danger" id="superDiscountHint" style="display:none;">
                                İndirimli fiyat girdiyseniz indirim seçimi zorunludur.
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-4">
                            <label class="form-label">Vitrin etiketi (opsiyonel)</label>
                            <input class="form-control" type="text" name="CampaignLabel" maxlength="120" placeholder="Örn. Süper Fırsat" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-4">
                            <label class="form-label">Satış durumu</label>
                            <select class="form-select" name="SaleStatusAction">
                                <option value="keep" selected>Mevcut durum korunsun</option>
                                <option value="open">Satışa aç</option>
                                <option value="close">Satışa kapat</option>
                            </select>
                        </div>
                        <div class="col-12 col-xl-4 d-flex justify-content-between align-items-center gap-3">
                            <label class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" name="ClearDiscountPrice" value="true" id="superClearDiscount" />
                                <span class="form-check-label">İndirimli fiyatı temizle</span>
                            </label>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-floppy-disk me-2"></i>Uygula
                            </button>
                        </div>
                    </div>
                </form>
                <div class="mt-3 small text-muted">
                    Not: İndirimli fiyat, takvim ekranında “kampanyalı / indirimli” tonu ile işaretlenir. İndirimli fiyat temizlenirse standart fiyat geçerli olur.
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        const form = document.getElementById('partnerSuperPriceForm');
        if (!form) return;
        const price = document.getElementById('superDiscountPrice');
        const discount = document.getElementById('superDiscountId');
        const hint = document.getElementById('superDiscountHint');
        const clear = document.getElementById('superClearDiscount');

        function validate() {
            const hasPrice = !!(price && price.value && price.value.trim());
            const wantsClear = !!(clear && clear.checked);
            const hasDiscount = !!(discount && discount.value && discount.value.trim());
            const ok = wantsClear || !hasPrice || hasDiscount;
            if (hint) hint.style.display = ok ? 'none' : 'block';
            return ok;
        }

        form.addEventListener('submit', function (e) {
            if (!validate()) {
                e.preventDefault();
            }
        });
        if (price) price.addEventListener('input', validate);
        if (discount) discount.addEventListener('change', validate);
        if (clear) clear.addEventListener('change', validate);
        validate();
    })();
</script>

