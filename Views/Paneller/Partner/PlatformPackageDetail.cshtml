@model otelturizmnew.Models.Paneller.PartnerPlatformPackageDetailPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/platform-packages";
    var p = Model.Package;
}

<section class="partner-platform-package-detail">
    <a class="partner-muted" href="/panel/partner/platform-paketleri?otelId=@Model.SelectedHotelId">&larr; Kataloğa dön</a>

    <div class="partner-platform-package-detail__hero ot-card">
        <div class="partner-platform-package-detail__gallery">
            @if (!string.IsNullOrWhiteSpace(p.CoverImageUrl))
            {
                <img src="@p.CoverImageUrl" alt="@p.Title" />
            }
            @foreach (var url in p.GalleryUrls.Where(u => u != p.CoverImageUrl))
            {
                <img src="@url" alt="" loading="lazy" />
            }
        </div>
        <div>
            <span class="ot-badge ot-badge--info">@p.CategoryTitle</span>
            <h2>@p.Title</h2>
            <p class="partner-platform-package-detail__price">@p.PriceText</p>
            <p>@p.DetailText</p>
            @if (p.Features.Count > 0)
            {
                <ul class="partner-platform-package-detail__features">
                    @foreach (var f in p.Features)
                    {
                        <li><i class="fas fa-check text-success"></i> @f</li>
                    }
                </ul>
            }
            @if (!string.IsNullOrWhiteSpace(p.ContractUrl))
            {
                <p><a href="@p.ContractUrl" target="_blank" rel="noopener">Sözleşme şartları</a></p>
            }
        </div>
    </div>

    @if (!Model.Eligible)
    {
        <div class="partner-alert is-warning">@Model.EligibilityMessage</div>
    }
    else
    {
        <div class="partner-section-card ot-card">
            <h3>Başvuru formu</h3>
            <p class="partner-muted">Otel: <strong>@Model.SelectedHotelName</strong></p>
            <form method="post" action="/panel/partner/platform-paketleri/basvuru-olustur" class="partner-form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="HotelId" value="@Model.Form.HotelId" />
                <input type="hidden" name="PackageId" value="@Model.Form.PackageId" />
                <label class="partner-form-span">
                    <span>Otelde 5661 loglama sistemi kurulu mu?</span>
                    <select name="Hotel5661InstalledDeclaration">
                        <option value="false">Hayır / emin değilim</option>
                        <option value="true">Evet, kurulu</option>
                    </select>
                </label>
                <label>
                    <span>İletişim adı</span>
                    <input type="text" name="ContactName" />
                </label>
                <label>
                    <span>Telefon</span>
                    <input type="tel" name="ContactPhone" />
                </label>
                <label>
                    <span>E-posta</span>
                    <input type="email" name="ContactEmail" />
                </label>
                <label class="partner-form-span">
                    <span>Partner notu</span>
                    <textarea name="PartnerNote" rows="3" placeholder="Kurulum tercihi, mevcut altyapı..."></textarea>
                </label>
                <div class="partner-form-span partner-form-actions">
                    <button type="submit" class="partner-primary-btn ot-btn ot-btn--primary">
                        <i class="fas fa-paper-plane"></i> Başvuru gönder
                    </button>
                </div>
            </form>
        </div>
    }
</section>
