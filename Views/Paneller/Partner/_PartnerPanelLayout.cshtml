@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Partner
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string;
    var shell = ViewData["PartnerShell"] as PartnerShellViewModel ?? Model as PartnerShellViewModel;
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Partner Panel";
    var partnerUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var partnerUserId = long.TryParse(partnerUserRaw, out var parsedPartnerUserId) ? parsedPartnerUserId : 0;
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.Partner, partnerUserId, Context.RequestAborted);
    var theme = shell?.Theme;
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme is not ("light" or "dark" or "auto")) { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";
    var hotelQuery = shell?.SelectedHotelId is long hid ? $"?otelId={hid}" : string.Empty;
    string PartnerUrl(string path) => $"{path}{hotelQuery}";
    var selectedHotelName = string.IsNullOrWhiteSpace(shell?.SelectedHotelName) ? "Partner Oteli" : shell!.SelectedHotelName;

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var primaryHex = !string.IsNullOrWhiteSpace(theme?.PrimaryHex) ? theme!.PrimaryHex : theme?.AccentHex;
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : primaryHex;
        // Ana renk sadece aksiyon/buton tonunu etkilemeli (Tabler'ın global primary rengini ezmeyelim).
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--partner-accent: {accentHex};");
        // Sidebar rengi sadece açıkça kaydedilmişse uygulanır (ana renkle otomatik bağlama yok).
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--partner-sidebar-bg: {theme!.SidebarBgHex}; --partner-sidebar-bg-2: color-mix(in srgb, {theme.SidebarBgHex} 76%, #ffffff 24%);");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily)) parts.Add($"--tblr-font-sans-serif: {theme!.FontFamily};");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/tabler-bridge.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-standards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/developer-feedback.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body class="layout-fluid partner-panel-v2" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)" dir="@dir" style="@BuildThemeStyle()">
    <div class="page">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Partner/_PartnerSidebar.cshtml" model="shell" />
        }

        <div class="page-wrapper">
            @if (shell is not null)
            {
                <header class="navbar navbar-expand-md d-print-none partner-topbar" role="banner">
                    <div class="container-fluid">
                        <button class="navbar-toggler d-lg-none me-2" type="button" data-bs-toggle="collapse" data-bs-target="#partnerSidebarMenu" aria-controls="partnerSidebarMenu" aria-expanded="false" aria-label="Menüyü aç">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="navbar-brand d-lg-none">
                            <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="partner-topbar-logo" />
                        </div>
                        <div class="d-none d-lg-flex align-items-center gap-3">
                            <span class="avatar bg-primary-lt text-primary"><i class="fas fa-hotel"></i></span>
                            <div>
                                <div class="text-muted small">Seçili tesis</div>
                                <div class="fw-bold">@selectedHotelName</div>
                            </div>
                        </div>
                        <div class="navbar-nav flex-row ms-auto align-items-center gap-2">
                            <a class="btn btn-outline-primary btn-pill d-none d-md-inline-flex" href="@PartnerUrl("/panel/partner/otel-bilgileri")">
                                <i class="fas fa-pen-to-square me-2"></i>Tesis Bilgileri
                            </a>
                            <a class="btn btn-primary btn-pill d-none d-md-inline-flex" href="@PartnerUrl("/panel/partner/takvim-fiyatlar")">
                                <i class="fas fa-calendar-days me-2"></i>Fiyat Güncelle
                            </a>
                            <button class="btn btn-icon btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#partnerThemeSettings" aria-label="Tema ayarları">
                                <i class="fas fa-palette"></i>
                            </button>
                            <div class="partner-topbar-favorites" title="@shell.FavoriteSummaryText" aria-label="@shell.FavoriteSummaryText">
                                <span class="partner-topbar-favorite-icon">
                                    <i class="fas fa-heart"></i>
                                    <span>@shell.FavoriteCount</span>
                                </span>
                                <small class="d-none d-xxl-inline">@shell.FavoriteSummaryText</small>
                            </div>
                            <partial name="~/Views/Paneller/Common/_DeveloperFeedbackWidget.cshtml" />
                            <div class="header-bildiri partner-header-bildiri" data-header-bildiri data-panel-key="@headerBildiri.PanelKey" data-unread-count="@headerBildiri.UnreadCount" data-open="false">
                                @Html.AntiForgeryToken()
                                <button class="header-bildiri-btn" type="button" data-header-bildiri-toggle aria-expanded="false" aria-label="Bildirimleri aç">
                                    <i class="fas fa-bell"></i>
                                    @if (headerBildiri.UnreadCount > 0)
                                    {
                                        <span class="header-bildiri-count">@headerBildiri.UnreadCount</span>
                                    }
                                </button>
                                <div class="header-bildiri-dropdown" role="dialog" aria-label="Partner bildirimleri">
                                    <div class="header-bildiri-head">
                                        <strong>Bildirimler</strong>
                                        <span>@headerBildiri.UnreadCount okunmamış</span>
                                    </div>
                                    <ul class="header-bildiri-list">
                                        @foreach (var item in headerBildiri.Items)
                                        {
                                            <li class="header-bildiri-item tone-@item.Tone @(item.IsRead ? "is-read" : "is-unread")"
                                                data-header-item-key="@item.ItemKey"
                                                data-header-item-read="@(item.IsRead ? "1" : "0")">
                                                <a href="@item.Url" data-header-item-link>
                                                    <i class="fas @item.IconClass"></i>
                                                    <span class="header-bildiri-content">
                                                        <strong>@item.Title</strong>
                                                        <p>@item.Description</p>
                                                        <span class="header-bildiri-time">
                                                            <span class="header-bildiri-time-chip">@item.TimeLabel</span>
                                                        </span>
                                                    </span>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown" aria-label="Kullanıcı menüsü">
                                    <span class="avatar avatar-sm bg-blue-lt text-blue">@((shell.FullName.FirstOrDefault().ToString() ?? "P").ToUpperInvariant())</span>
                                    <div class="d-none d-xl-block ps-2">
                                        <div class="fw-bold">@shell.FullName</div>
                                        <div class="small text-muted">@shell.Email</div>
                                    </div>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                                    <a class="dropdown-item" href="@PartnerUrl("/panel/partner/tercihler")"><i class="fas fa-sliders me-2"></i>Tercihler</a>
                                    <a class="dropdown-item" href="@PartnerUrl("/panel/partner/guvenlik")"><i class="fas fa-shield-halved me-2"></i>Güvenlik</a>
                                    <div class="dropdown-divider"></div>
                                    <form method="post" action="/cikis-yap" class="px-2">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger w-100"><i class="fas fa-right-from-bracket me-2"></i>Çıkış</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>
            }

            <div class="page-body">
                <div class="container-fluid">
                    <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
                    @RenderBody()
                </div>
            </div>

            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Partner/_PartnerPanelFooter.cshtml" model="shell" />
                <div class="offcanvas offcanvas-end" tabindex="-1" id="partnerThemeSettings" aria-labelledby="partnerThemeSettingsLabel">
                    <div class="offcanvas-header">
                        <h2 class="offcanvas-title" id="partnerThemeSettingsLabel">Tema Ayarları</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
                    </div>
                    <div class="offcanvas-body">
                        <form method="post" action="/panel/partner/tema/kaydet">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="otelId" value="@(shell.SelectedHotelId ?? 0)" />
                            <input type="hidden" name="scope" value="user" />
                            @if (requestPath.Contains("/panel/partner/tercihler", StringComparison.OrdinalIgnoreCase))
                            {
                                <input type="hidden" name="returnUrl" value="/panel/partner/tercihler" />
                            }
                            <input type="hidden" name="PrimaryHex" id="themePrimaryHex" value="@(shell.Theme.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="AccentHex" id="themeAccentHex" value="@(shell.Theme.AccentHex ?? shell.Theme.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="SidebarBgHex" id="themeSidebarBgHex" value="@(shell.Theme.SidebarBgHex ?? string.Empty)" />
                            <label class="form-label">Renk modu</label>
                            <div class="form-selectgroup-boxes row g-2 mb-3">
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="light" class="form-selectgroup-input" @(string.Equals(shell.Theme.BsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-sun me-2"></i>Açık</span>
                                </label>
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="dark" class="form-selectgroup-input" @(string.Equals(shell.Theme.BsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-moon me-2"></i>Koyu</span>
                                </label>
                            </div>
                            <label class="form-label">Ana renk</label>
                            <div class="d-flex flex-wrap gap-2 mb-3" data-color-palette="primary">
                                @foreach (var color in new[] { "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#334155" })
                                {
                                    <button type="button" class="btn btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                                }
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Temayı Kaydet</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <audio id="partnerNotificationAudio" preload="auto"><source src="~/uploads/ses/partner-bildiri.wav" type="audio/wav" /></audio>
    <script src="~/paneltematabler/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/developer-feedback.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
    (() => {
        const primaryInput = document.getElementById('themePrimaryHex');
        const accentInput = document.getElementById('themeAccentHex');
        const sidebarInput = document.getElementById('themeSidebarBgHex');
        const body = document.body;
        const root = document.documentElement;
        const applyThemePreview = ({ mode, accent, sidebar }) => {
            if (mode) {
                root.setAttribute('data-bs-theme', mode);
                body.setAttribute('data-bs-theme', mode);
            }
            if (accent) root.style.setProperty('--partner-accent', accent);
            if (sidebar) {
                root.style.setProperty('--partner-sidebar-bg', sidebar);
                root.style.setProperty('--partner-sidebar-bg-2', `color-mix(in srgb, ${sidebar} 76%, #ffffff 24%)`);
            }
        };
        document.querySelectorAll('[data-color-palette="primary"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                applyThemePreview({
                    mode: document.querySelector('input[name="BsTheme"]:checked')?.value || 'light',
                    accent: hex,
                    sidebar: sidebarInput?.value || ''
                });
            });
        });
        document.querySelectorAll('input[name="BsTheme"]').forEach((input) => {
            input.addEventListener('change', () => {
                const value = input.value || 'light';
                const accent = accentInput?.value || primaryInput?.value || '';
                applyThemePreview({ mode: value, accent, sidebar: sidebarInput?.value || '' });
            });
        });
    })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
