@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Partner
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string;
    var shell = ViewData["PartnerShell"] as PartnerShellViewModel ?? Model as PartnerShellViewModel;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Partner Panel";
    var partnerUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var partnerUserId = long.TryParse(partnerUserRaw, out var parsedPartnerUserId) ? parsedPartnerUserId : 0;
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.Partner, partnerUserId, Context.RequestAborted);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    
    
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body>
    <div class="partner-panel-shell">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Partner/_PartnerSidebar.cshtml" model="shell" />
        }

        <main class="partner-panel-main">
            @if (shell is not null)
            {
                <header class="partner-page-header partner-page-header-sticky">
                    <div>
                        <p class="partner-kicker">PARTNER PANEL</p>
                        <h1>@shell.PanelTitle</h1>
                        <p class="partner-subtitle">@shell.PanelSubtitle</p>
                    </div>
                    <div class="partner-header-badges">
                        <span><i class="fas fa-hourglass-half"></i> @shell.PendingReservations bekleyen</span>
                        <span><i class="fas fa-bell"></i> @shell.OpenSupportTickets destek</span>
                        <span><i class="fas fa-box-open"></i> @shell.LowStockAlerts stok uyarısı</span>
                        @if (headerBildiri.UnreadCount > 0)
                        {
                            <span class="partner-unread-chip"><i class="fas fa-circle-exclamation"></i> @headerBildiri.UnreadCount okunmamış bildiri</span>
                        }
                        <partial name="~/Views/Shared/_HeaderBildiri.cshtml" model="headerBildiri" />
                        <form method="post" action="/cikis-yap" class="panel-header-logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="panel-header-logout-btn">
                                <i class="fas fa-right-from-bracket"></i>
                                <span>Çıkış Yap</span>
                            </button>
                        </form>
                    </div>
                </header>
            }

            @if (TempData["PartnerSuccess"] is string success)
            {
                <div class="partner-flash success">@success</div>
            }
            @if (TempData["PartnerError"] is string error)
            {
                <div class="partner-flash error">@error</div>
            }

            @RenderBody()

            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Partner/_PartnerPanelFooter.cshtml" model="shell" />
            }
        </main>
    </div>

    @if (shell is not null)
    {
        <partial name="~/Views/Paneller/Partner/_PartnerMobileNav.cshtml" model="shell" />
    }
    <audio id="partnerNotificationAudio" preload="auto">
        <source src="~/uploads/ses/partner-bildiri.wav" type="audio/wav" />
    </audio>
    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

