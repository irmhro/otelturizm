@model otelturizmnew.Models.Paneller.Partner.PartnerNotificationPreferencesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["Title"] = "Bildirim Tercihleri";
    ViewData["PageCssPath"] = "paneller/partner/notification-preferences";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Partner</div>
            <h2 class="page-title">Bildirim Tercihleri</h2>
            <div class="text-muted mt-1">Bildirim kanallarını ve görünürlük ayarlarını yönetin.</div>
        </div>
    </div>
</div>

<form class="notify-card" id="partnerNotifyForm">
    @Html.AntiForgeryToken()
    <div class="notify-grid">
        <section class="card notify-section">
            <div class="card-header">
                <div>
                    <h3 class="card-title">E‑posta Bildirimleri</h3>
                    <div class="text-muted">Firma/partner hesabınıza gönderilecek e‑posta bildirimlerini yönetin.</div>
                </div>
            </div>
            <div class="card-body">
                <div class="notify-row">
                    <div class="notify-left">
                        <span class="notify-ico tone-success"><i class="fas fa-calendar-check" aria-hidden="true"></i></span>
                        <div class="notify-copy">
                            <strong>Rezervasyonlarımı e‑posta ile gönder</strong>
                            <small>Yeni rezervasyon ve iptal durumlarında bilgilendirme alırsınız.</small>
                        </div>
                    </div>
                    <label class="notify-toggle">
                        <input type="checkbox" name="ReservationEmail" value="true" @(Model.Form.ReservationEmail ? "checked" : null) />
                        <span aria-hidden="true"></span>
                    </label>
                </div>

                <div class="notify-row">
                    <div class="notify-left">
                        <span class="notify-ico tone-primary"><i class="fas fa-bullhorn" aria-hidden="true"></i></span>
                        <div class="notify-copy">
                            <strong>Kampanyaları bildir</strong>
                            <small>Yeni kampanya ve promosyon duyurularını e‑posta ile alırsınız.</small>
                        </div>
                    </div>
                    <label class="notify-toggle">
                        <input type="checkbox" name="CampaignEmail" value="true" @(Model.Form.CampaignEmail ? "checked" : null) />
                        <span aria-hidden="true"></span>
                    </label>
                </div>

                <div class="notify-row">
                    <div class="notify-left">
                        <span class="notify-ico tone-warning"><i class="fas fa-shield-halved" aria-hidden="true"></i></span>
                        <div class="notify-copy">
                            <strong>Giriş yaptığımda e‑posta ile bildir</strong>
                            <small>Hesabınıza yeni bir giriş olduğunda uyarı alırsınız.</small>
                        </div>
                    </div>
                    <label class="notify-toggle">
                        <input type="checkbox" name="LoginEmail" value="true" @(Model.Form.LoginEmail ? "checked" : null) />
                        <span aria-hidden="true"></span>
                    </label>
                </div>
            </div>
        </section>

        <section class="card notify-section">
            <div class="card-header">
                <div>
                    <h3 class="card-title">Güvenlik Görünümü</h3>
                    <div class="text-muted">Bu ekran sadece görünürlük ayarıdır; bildirim tercihleriniz kaydolur.</div>
                </div>
            </div>
            <div class="card-body">
                <div class="notify-row">
                    <div class="notify-left">
                        <span class="notify-ico tone-info"><i class="fas fa-clock-rotate-left" aria-hidden="true"></i></span>
                        <div class="notify-copy">
                            <strong>Geçmiş girişlerimi göster</strong>
                            <small>Son 5 giriş: zaman, IP ve oturum süresi.</small>
                        </div>
                    </div>
                    <label class="notify-toggle">
                        <input type="checkbox" id="showLoginHistoryToggle" value="true" />
                        <span aria-hidden="true"></span>
                    </label>
                </div>

                <div class="notify-login-history" id="loginHistoryPanel" hidden>
                    @if (Model.RecentLogins.Count == 0)
                    {
                        <div class="empty tiny">
                            <div class="empty-icon"><i class="fas fa-user-clock"></i></div>
                            <p class="empty-title">Giriş kaydı bulunamadı</p>
                            <p class="empty-subtitle text-muted">Yeni girişlerden sonra burada son 5 kayıt gösterilir.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-vcenter">
                                <thead>
                                <tr>
                                    <th>Zaman</th>
                                    <th>IP</th>
                                    <th>Cihaz</th>
                                    <th class="text-end">Oturum süresi</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var row in Model.RecentLogins.Take(5))
                                {
                                    <tr>
                                        <td class="text-muted">@row.TimeText</td>
                                        <td class="text-muted">@row.IpAddress</td>
                                        <td class="text-muted">@row.DeviceLabel</td>
                                        <td class="text-end text-muted">@row.DurationText</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>
</form>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const form = document.getElementById('partnerNotifyForm');
            const token = form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const loginToggle = document.getElementById('showLoginHistoryToggle');
            const loginPanel = document.getElementById('loginHistoryPanel');

            const setLoginPanel = (open) => {
                if (!loginPanel) return;
                loginPanel.hidden = !open;
            };

            if (loginToggle) {
                loginToggle.checked = false;
                setLoginPanel(false);
                loginToggle.addEventListener('change', () => setLoginPanel(loginToggle.checked));
            }

            const post = async () => {
                if (!form || !token) return;
                const fd = new FormData(form);
                // unchecked checkbox'lar gelmediği için default false setleri
                const toBool = (name) => fd.get(name) === 'true';
                const payload = {
                    ReservationEmail: toBool('ReservationEmail'),
                    ReservationPush: false,
                    CheckInReminder: false,
                    CancellationChanges: false,
                    CampaignEmail: toBool('CampaignEmail'),
                    CampaignSms: false,
                    SystemNotifications: true,
                    LoginEmail: toBool('LoginEmail')
                };

                const body = new URLSearchParams();
                body.set('__RequestVerificationToken', token);
                Object.keys(payload).forEach((k) => body.set(k, payload[k] ? 'true' : 'false'));

                const res = await fetch('/panel/partner/bildirim-tercihleri/kaydet-inline', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body.toString()
                });
                const data = await res.json();
                if (!data || !data.success) {
                    alert((data && data.message) ? data.message : 'Tercihler kaydedilemedi.');
                }
            };

            form?.querySelectorAll('input[type="checkbox"][name]').forEach((input) => {
                input.addEventListener('change', () => { post(); }, { passive: true });
            });
        })();
    </script>
}

