@model otelturizmnew.Models.Paneller.Partner.PartnerRoomManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var roomCategories = new[]
    {
        "Standart", "Superior", "Deluxe", "Junior Suite", "Suite", "Executive Suite", "Presidential Suite", "Aile Odası", "Engelli Odası", "Villa"
    };
    var bedTypes = new[]
    {
        "Tek Kişilik", "Çift Kişilik", "Queen Size", "King Size", "Super King Size", "Ranza", "Çekyat"
    };
    var viewTypes = new[] { "Yok", "Deniz", "Havuz", "Bahçe", "Dağ", "Şehir", "Göl", "İç Avlu" };
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Oda Yönetimi</div>
            <h2 class="page-title">Oda tipleri, stok ve fiyat özeti</h2>
            <div class="text-muted mt-1">@Model.Shell.SelectedHotelName için tüm oda tiplerini tek yerden düzenleyebilir, pasife alabilir ve fiyat akışını kontrol edebilirsiniz.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <div class="btn-list">
                <a class="btn btn-primary" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId#room-form">
                    <i class="fas fa-plus me-2"></i>Yeni oda tipi
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards">
    @if (Model.Rooms.Count == 0)
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon"><i class="fas fa-bed"></i></div>
                        <p class="empty-title">Henüz oda tipi tanımlanmamış</p>
                        <p class="empty-subtitle text-muted">İlk oda tipini ekleyerek satış takvimini aktif hale getirebilirsiniz.</p>
                        <div class="empty-action">
                            <a class="btn btn-primary" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId#room-form">
                                <i class="fas fa-plus me-2"></i>Oda tipi ekle
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div>
                        <h3 class="card-title mb-0">Oda tipleri</h3>
                        <div class="text-muted small">Aktif/pasif durumu, stok ve fiyat özetini tek tabloda görün.</div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Oda</th>
                                    <th>Durum</th>
                                    <th class="text-end">Fiyat</th>
                                    <th class="text-end">Stok</th>
                                    <th>Kapasite</th>
                                    <th>İndirim</th>
                                    <th class="text-end">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var room in Model.Rooms)
                                {
                                    <tr class="@(Model.SelectedRoomId == room.RoomId ? "table-primary" : string.Empty)">
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div style="width:56px; height:40px; border-radius:10px; overflow:hidden; background:#f3f4f6; flex: 0 0 auto;">
                                                    @if (!string.IsNullOrWhiteSpace(room.CoverPhotoUrl))
                                                    {
                                                        <img src="@room.CoverPhotoUrl" alt="@room.RoomName" style="width:100%; height:100%; object-fit:cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-items-center justify-content-center h-100">
                                                            <i class="fas fa-bed text-muted"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="min-w-0">
                                                    <div class="fw-bold text-truncate">@room.RoomName</div>
                                                    <div class="text-muted small">@room.Category</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @(room.IsActive ? "bg-success-lt text-success" : "bg-secondary-lt text-secondary")">
                                                @(room.IsActive ? "Aktif" : "Pasif")
                                            </span>
                                            @if (Model.SelectedRoomId == room.RoomId)
                                            {
                                                <span class="badge bg-primary-lt text-primary ms-2">
                                                    <i class="fas fa-circle-check me-1"></i>Düzenleniyor
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end fw-bold">@room.BasePriceText</td>
                                        <td class="text-end">@room.StockText</td>
                                        <td>@room.CapacityText</td>
                                        <td>@room.DiscountPriceText</td>
                                        <td class="text-end">
                                            <div class="btn-list justify-content-end">
                                                <a href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId&roomId=@room.RoomId#room-form" class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-pen me-1"></i>Düzenle
                                                </a>
                                                <a href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@room.RoomId" class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-calendar-days me-1"></i>Takvim
                                                </a>
                                                <form method="post" action="/panel/partner/oda-yonetimi/sil" class="d-inline" onsubmit="return confirm('Bu oda tipini silmek istediğinize emin misiniz? Odaya bağlı fiyat, takvim, görsel ve ilişki verileri temizlenecektir.');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                                    <input type="hidden" name="roomId" value="@room.RoomId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                        <i class="fas fa-trash me-1"></i>Sil
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row row-cards mt-2">
    <div class="col-12 col-xl-5">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Oda stok özeti</h3>
                <div class="text-muted">Yakın dönem stok, satılabilir oda ve fiyat aralığı görünümü.</div>
            </div>
            <div class="card-body">
                @if (Model.InventoryRows.Count == 0)
                {
                    <div class="empty">
                        <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                        <p class="empty-title">Stok özeti oluşturulamadı</p>
                        <p class="empty-subtitle text-muted">Oda tipleri eklendikten sonra takvim verileri burada otomatik görünecek.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-vcenter">
                            <thead>
                                <tr>
                                    <th>Oda tipi</th>
                                    <th class="text-end">Toplam</th>
                                    <th class="text-end">Satılabilir</th>
                                    <th class="text-end">Bakım</th>
                                    <th class="text-end">Min</th>
                                    <th class="text-end">Max</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.InventoryRows)
                                {
                                    <tr>
                                        <td class="fw-bold">@row.RoomName</td>
                                        <td class="text-end">@row.TotalRooms</td>
                                        <td class="text-end">@row.SellableRooms</td>
                                        <td class="text-end">@row.MaintenanceRooms</td>
                                        <td class="text-end">@row.MinPriceText</td>
                                        <td class="text-end">@row.MaxPriceText</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card" id="room-form">
        <div class="partner-section-head">
            <div>
                <h2>@(Model.IsEditingRoom ? "Oda tipini düzenle" : "Yeni oda tipi ekle")</h2>
                <p>Form doğrudan veritabanındaki `oda_tipleri` yapısına kayıt atar.</p>
            </div>
            @if (Model.IsEditingRoom)
            {
                <a href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId#room-form" class="partner-text-link">Yeni kayıt moduna dön</a>
            }
        </div>
        <div class="card-header">
            <h3 class="card-title">@(Model.IsEditingRoom ? "Oda tipini düzenle" : "Yeni oda tipi ekle")</h3>
            <div class="card-actions">
                @if (Model.IsEditingRoom)
                {
                    <a href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId#room-form" class="btn btn-outline-primary btn-sm">Yeni kayıt moduna dön</a>
                }
            </div>
        </div>
        <form method="post" action="/panel/partner/oda-yonetimi/kaydet" id="partnerRoomForm" class="card-body">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="RoomId" value="@Model.Form.RoomId" />

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Oda adı</label>
                    <input class="form-control" type="text" name="RoomName" value="@Model.Form.RoomName" placeholder="Örn. Deluxe Deniz Manzaralı Oda" required />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Oda kategorisi</label>
                    <select class="form-select" name="RoomCategory">
                    @foreach (var category in roomCategories)
                    {
                        if (Model.Form.RoomCategory == category)
                        {
                            <option value="@category" selected="selected">@category</option>
                        }
                        else
                        {
                            <option value="@category">@category</option>
                        }
                    }
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Gece fiyatı (vergi dahil)</label>
                    <input class="form-control" type="number" step="0.01" name="BasePrice" value="@Model.Form.BasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)" min="0.01" required aria-describedby="basePriceHelp" />
                    <div id="basePriceHelp" class="form-hint">Misafirin göreceği tutardır; KDV ve konaklama vergisi bu tutarın içindedir. Sistem kayıtta net oda tutarını saklar.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Toplam oda</label>
                    <input class="form-control" type="number" name="TotalRooms" value="@Model.Form.TotalRooms" min="1" required />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Maks. yetişkin</label>
                    <input class="form-control" type="number" name="MaxAdults" value="@Model.Form.MaxAdults" min="1" max="20" required />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Maks. çocuk</label>
                    <input class="form-control" type="number" name="MaxChildren" value="@Model.Form.MaxChildren" min="0" max="20" required />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Bebek kapasitesi</label>
                    <input class="form-control" type="number" name="MaxBabies" value="@Model.Form.MaxBabies" min="0" max="20" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Kişi kapasitesi özeti</label>
                    <input class="form-control" type="text" id="roomCapacitySummary" value="@(Math.Max(1, Model.Form.MaxAdults + Model.Form.MaxChildren + Model.Form.MaxBabies)) kişi (Yetişkin: @Model.Form.MaxAdults, Çocuk: @Model.Form.MaxChildren, Bebek: @Model.Form.MaxBabies)" readonly />
                    <div class="form-hint">Toplam kişi kapasitesi otomatik hesaplanır ve rezervasyon tarafında bu sınır uygulanır.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Oda büyüklüğü (m²)</label>
                    <input class="form-control" type="number" name="RoomSize" value="@Model.Form.RoomSize" min="0" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Yatak tipi</label>
                    <select class="form-select" name="BedType">
                    <option value="">Seçiniz</option>
                    @foreach (var bedType in bedTypes)
                    {
                        if (Model.Form.BedType == bedType)
                        {
                            <option value="@bedType" selected="selected">@bedType</option>
                        }
                        else
                        {
                            <option value="@bedType">@bedType</option>
                        }
                    }
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Manzara tipi</label>
                    <select class="form-select" name="ViewType">
                    <option value="">Seçiniz</option>
                    @foreach (var viewType in viewTypes)
                    {
                        if (Model.Form.ViewType == viewType)
                        {
                            <option value="@viewType" selected="selected">@viewType</option>
                        }
                        else
                        {
                            <option value="@viewType">@viewType</option>
                        }
                    }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Kapak fotoğrafı yolu</label>
                    <input class="form-control" type="text" name="CoverPhotoPath" value="@Model.Form.CoverPhotoPath" placeholder="/uploads/images/73/rooms/182/oda-1.webp" />
                </div>
                <div class="col-12">
                    <label class="form-label">Oda özellikleri</label>
                    @if (Model.AvailableRoomFeatures.Count == 0)
                    {
                        <div class="text-muted">Özellik sözlüğü bulunamadı.</div>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var group in Model.AvailableRoomFeatures
                                         .OrderBy(x => x.Category)
                                         .ThenBy(x => x.Order)
                                         .GroupBy(x => x.Category))
                            {
                                <div class="col-12">
                                    <div class="fw-bold mb-2">@group.Key</div>
                                    <div class="row g-2">
                                        @foreach (var opt in group)
                                        {
                                            var isChecked = Model.SelectedRoomFeatureIds.Contains(opt.FeatureId);
                                            <div class="col-12 col-md-6 col-xl-4">
                                                <label class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="SelectedFeatureIds" value="@opt.FeatureId" checked="@(isChecked ? "checked" : null)" />
                                                    <span class="form-check-label">
                                                        @if (!string.IsNullOrWhiteSpace(opt.IconClass))
                                                        {
                                                            <i class="fas @opt.IconClass me-2 text-muted"></i>
                                                        }
                                                        @opt.Name
                                                    </span>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="form-hint">Bu liste, `panel/partner/oda/ozellikler` ekranındaki sözlükten beslenir.</div>
                    }
                </div>
                <div class="col-12">
                    <label class="form-check">
                        @if (Model.Form.IsActive)
                        {
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="checked" />
                        }
                        else
                        {
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" />
                        }
                        <span class="form-check-label">Bu oda tipi satışta aktif olsun</span>
                    </label>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-floppy-disk me-2"></i>@(Model.IsEditingRoom ? "Oda tipini güncelle" : "Oda tipini kaydet")
                    </button>
                </div>
            </div>
        </form>

        @if (Model.SelectedRoomId.HasValue)
        {
            <div class="card mt-3" id="room-gallery">
                <div class="card-header">
                    <h3 class="card-title">Oda görselleri ve vitrin yönetimi</h3>
                    <div class="text-muted">Seçili oda için birden fazla görsel yükleyebilir, vitrin görselini belirleyebilir ve kullanılmayan dosyaları temizleyebilirsiniz.</div>
                </div>

                <div class="card-body">
                    <form method="post" action="/panel/partner/oda-yonetimi/gorsel-yukle" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="HotelId" value="@Model.PhotoUploadForm.HotelId" />
                        <input type="hidden" name="RoomId" value="@Model.PhotoUploadForm.RoomId" />
                        <div class="row g-3 align-items-end">
                            <div class="col-12 col-md">
                                <label class="form-label">Oda görselleri</label>
                                <input class="form-control" type="file" name="Files" accept="image/*" multiple />
                                <div class="form-hint">Yüklenen tüm görseller optimize edilerek WebP formatına dönüştürülür.</div>
                            </div>
                            <div class="col-12 col-md-auto">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-cloud-arrow-up me-2"></i>Görselleri yükle
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                @if (Model.SelectedRoomPhotos.Count == 0)
                {
                    <div class="card-body">
                        <div class="empty">
                            <div class="empty-icon"><i class="fas fa-image"></i></div>
                            <p class="empty-title">Henüz oda görseli yok</p>
                            <p class="empty-subtitle text-muted">Vitrin ve galeri görselleri eklediğinizde public otel detay sayfasında oda kartında otomatik görünür.</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var photo in Model.SelectedRoomPhotos)
                            {
                                <div class="col-12 col-md-6 col-xl-4">
                                    <div class="card @(photo.IsCover ? "border-warning" : string.Empty)">
                                        <div class="card-img-top" style="position:relative;">
                                            <img src="@photo.Url" alt="@photo.Title" style="width:100%; height:180px; object-fit:cover;" />
                                            @if (photo.IsCover)
                                            {
                                                <span class="badge bg-warning-lt text-warning" style="position:absolute; top:12px; left:12px;">
                                                    <i class="fas fa-star me-1"></i>Vitrin
                                                </span>
                                            }
                                        </div>
                                        <div class="card-body">
                                            <div class="fw-bold">@(!string.IsNullOrWhiteSpace(photo.Title) ? photo.Title : $"Oda Görseli #{photo.PhotoId}")</div>
                                            <div class="text-muted mt-1">Sıralama: @photo.DisplayOrder</div>
                                        </div>
                                        <div class="card-footer">
                                            <div class="btn-list">
                                                @if (!photo.IsCover)
                                                {
                                                    <form method="post" action="/panel/partner/oda-yonetimi/gorsel-kapak-yap" class="m-0">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                                        <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
                                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                                            <i class="fas fa-image me-1"></i>Vitrin yap
                                                        </button>
                                                    </form>
                                                }
                                                <form method="post" action="/panel/partner/oda-yonetimi/gorsel-sil" class="m-0 ms-auto" onsubmit="return confirm('Bu oda görselini silmek istediğinize emin misiniz?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                                    <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
                                                    <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                        <i class="fas fa-trash me-1"></i>Sil
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        </div>
    </div>
</div>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
    (function () {
        const roomForm = document.getElementById('partnerRoomForm');
        if (!roomForm) {
            return;
        }

        const maxAdultsInput = roomForm.querySelector('input[name="MaxAdults"]');
        const maxChildrenInput = roomForm.querySelector('input[name="MaxChildren"]');
        const maxBabiesInput = roomForm.querySelector('input[name="MaxBabies"]');
        const totalRoomsInput = roomForm.querySelector('input[name="TotalRooms"]');
        const capacitySummary = document.getElementById('roomCapacitySummary');

        function parseByte(input, fallback) {
            const value = parseInt(input?.value || String(fallback), 10);
            if (Number.isNaN(value)) {
                return fallback;
            }

            return Math.max(0, value);
        }

        function refreshCapacitySummary() {
            const adults = Math.max(1, parseByte(maxAdultsInput, 1));
            const children = parseByte(maxChildrenInput, 0);
            const babies = parseByte(maxBabiesInput, 0);
            const total = adults + children + babies;

            if (capacitySummary) {
                capacitySummary.value = total + ' kişi (Yetişkin: ' + adults + ', Çocuk: ' + children + ', Bebek: ' + babies + ')';
            }
        }

        function validateRoomCapacity() {
            const adults = Math.max(1, parseByte(maxAdultsInput, 1));
            const children = parseByte(maxChildrenInput, 0);
            const babies = parseByte(maxBabiesInput, 0);
            const totalRooms = Math.max(1, parseInt(totalRoomsInput?.value || '1', 10) || 1);
            const total = adults + children + babies;

            if (totalRooms < 1) {
                alert('Toplam oda sayısı en az 1 olmalıdır.');
                totalRoomsInput?.focus();
                return false;
            }

            if (adults < 1) {
                alert('Maksimum yetişkin sayısı en az 1 olmalıdır.');
                maxAdultsInput?.focus();
                return false;
            }

            if (total < 1) {
                alert('Toplam kişi kapasitesi en az 1 olmalıdır.');
                maxAdultsInput?.focus();
                return false;
            }

            return true;
        }

        [maxAdultsInput, maxChildrenInput, maxBabiesInput].forEach(function (input) {
            input?.addEventListener('input', refreshCapacitySummary);
        });

        roomForm.addEventListener('submit', function (event) {
            if (!validateRoomCapacity()) {
                event.preventDefault();
                return;
            }

            refreshCapacitySummary();
        });

        refreshCapacitySummary();
    })();
</script>
