@model otelturizmnew.Models.Paneller.Partner.PartnerRoomManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var roomCategories = new[]
    {
        "Standart", "Superior", "Deluxe", "Junior Suite", "Suite", "Executive Suite", "Presidential Suite", "Aile Odası", "Engelli Odası", "Villa"
    };
    var bedTypes = new[]
    {
        "Tek Kişilik", "Çift Kişilik", "Queen Size", "King Size", "Super King Size", "Ranza", "Çekyat"
    };
    var viewTypes = new[] { "Yok", "Deniz", "Havuz", "Bahçe", "Dağ", "Şehir", "Göl", "İç Avlu" };
}

<section class="partner-room-toolbar">
    <div>
        <p class="partner-room-kicker">Oda envanteri</p>
        <h2>Oda tipleri, stok ve fiyat özeti</h2>
        <p>@Model.Shell.SelectedHotelName için tüm oda tiplerini tek yerden düzenleyebilir, pasife alabilir ve fiyat akışını kontrol edebilirsiniz.</p>
    </div>
    <a class="partner-primary-btn partner-toolbar-link" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId">
        <i class="fas fa-plus"></i>
        Yeni oda tipi
    </a>
</section>

<section class="partner-room-card-grid">
    @if (Model.Rooms.Count == 0)
    {
        <article class="partner-empty-state">
            <strong>Henüz oda tipi tanımlanmamış</strong>
            <p>İlk oda tipini sağdaki formdan ekleyerek satış takvimini aktif hale getirebilirsiniz.</p>
        </article>
    }
    else
    {
        @foreach (var room in Model.Rooms)
        {
            <article class="partner-room-card @(room.IsActive ? string.Empty : "is-passive") @(Model.SelectedRoomId == room.RoomId ? "is-selected" : string.Empty)">
                <div class="partner-room-card-media">
                    @if (!string.IsNullOrWhiteSpace(room.CoverPhotoUrl))
                    {
                        <img src="@room.CoverPhotoUrl" alt="@room.RoomName" />
                    }
                    else
                    {
                        <div class="partner-room-card-placeholder">
                            <i class="fas fa-bed"></i>
                        </div>
                    }
                    <span class="partner-room-status @(room.IsActive ? "is-active" : "is-passive")">
                        @(room.IsActive ? "Aktif" : "Pasif")
                    </span>
                </div>
                <div class="partner-room-card-body">
                    <div class="partner-room-card-head">
                        <div>
                            <h3>@room.RoomName</h3>
                            <p>@room.Category</p>
                        </div>
                        <strong>@room.BasePriceText</strong>
                    </div>
                    <ul class="partner-room-meta">
                        <li><i class="fas fa-users"></i> @room.CapacityText</li>
                        <li><i class="fas fa-box-open"></i> @room.StockText</li>
                        <li><i class="fas fa-tag"></i> @room.DiscountPriceText</li>
                    </ul>
                    @if (Model.SelectedRoomId == room.RoomId)
                    {
                        <div class="partner-room-selected-badge">
                            <i class="fas fa-circle-check"></i>
                            Düzenlenen oda tipi
                        </div>
                    }
                    <div class="partner-room-actions">
                        <a href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId&roomId=@room.RoomId#room-form" class="partner-secondary-btn">
                            <i class="fas fa-pen"></i>
                            Düzenle
                        </a>
                        <a href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@room.RoomId" class="partner-secondary-btn">
                            <i class="fas fa-calendar-days"></i>
                            Takvim
                        </a>
                        <form method="post" action="/panel/partner/oda-yonetimi/sil" onsubmit="return confirm('Bu oda tipini silmek istediğinize emin misiniz? Odaya bağlı fiyat, takvim, görsel ve ilişki verileri temizlenecektir.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                            <input type="hidden" name="roomId" value="@room.RoomId" />
                            <button type="submit" class="partner-danger-btn">
                                <i class="fas fa-trash"></i>
                                Sil ve temizle
                            </button>
                        </form>
                    </div>
                </div>
            </article>
        }
    }
</section>

<section class="partner-two-column partner-room-layout">
    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Oda stok özeti</h2>
                <p>Yakın dönem stok, satılabilir oda ve fiyat aralığı görünümü.</p>
            </div>
        </div>
        @if (Model.InventoryRows.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Stok özeti oluşturulamadı</strong>
                <p>Oda tipleri eklendikten sonra takvim verileri burada otomatik görünecek.</p>
            </div>
        }
        else
        {
            <div class="partner-table-wrap">
                <table class="partner-table">
                    <thead>
                        <tr>
                            <th>Oda tipi</th>
                            <th>Toplam oda</th>
                            <th>Satılabilir</th>
                            <th>Bakım / kapalı gün</th>
                            <th>Min fiyat</th>
                            <th>Max fiyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.InventoryRows)
                        {
                            <tr>
                                <td>@row.RoomName</td>
                                <td>@row.TotalRooms</td>
                                <td>@row.SellableRooms</td>
                                <td>@row.MaintenanceRooms</td>
                                <td>@row.MinPriceText</td>
                                <td>@row.MaxPriceText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="partner-section-card partner-room-form-card" id="room-form">
        <div class="partner-section-head">
            <div>
                <h2>@(Model.IsEditingRoom ? "Oda tipini düzenle" : "Yeni oda tipi ekle")</h2>
                <p>Form doğrudan veritabanındaki `oda_tipleri` yapısına kayıt atar.</p>
            </div>
            @if (Model.IsEditingRoom)
            {
                <a href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId#room-form" class="partner-text-link">Yeni kayıt moduna dön</a>
            }
        </div>
        <form method="post" action="/panel/partner/oda-yonetimi/kaydet" class="partner-form-grid" id="partnerRoomForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="RoomId" value="@Model.Form.RoomId" />

            <label>
                <span>Oda adı</span>
                <input type="text" name="RoomName" value="@Model.Form.RoomName" placeholder="Örn. Deluxe Deniz Manzaralı Oda" required />
            </label>
            <label>
                <span>Oda kategorisi</span>
                <select name="RoomCategory">
                    @foreach (var category in roomCategories)
                    {
                        if (Model.Form.RoomCategory == category)
                        {
                            <option value="@category" selected="selected">@category</option>
                        }
                        else
                        {
                            <option value="@category">@category</option>
                        }
                    }
                </select>
            </label>
            <label>
                <span>Taban fiyat</span>
                <input type="number" step="0.01" name="BasePrice" value="@Model.Form.BasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)" min="0.01" required />
            </label>
            <label>
                <span>Toplam oda</span>
                <input type="number" name="TotalRooms" value="@Model.Form.TotalRooms" min="1" required />
            </label>
            <label>
                <span>Maks. yetişkin</span>
                <input type="number" name="MaxAdults" value="@Model.Form.MaxAdults" min="1" max="20" required />
            </label>
            <label>
                <span>Maks. çocuk</span>
                <input type="number" name="MaxChildren" value="@Model.Form.MaxChildren" min="0" max="20" required />
            </label>
            <label>
                <span>Bebek kapasitesi</span>
                <input type="number" name="MaxBabies" value="@Model.Form.MaxBabies" min="0" max="20" required />
            </label>
            <label class="partner-form-span">
                <span>Kişi kapasitesi özeti</span>
                <input type="text" id="roomCapacitySummary" value="@(Math.Max(1, Model.Form.MaxAdults + Model.Form.MaxChildren + Model.Form.MaxBabies)) kişi (Yetişkin: @Model.Form.MaxAdults, Çocuk: @Model.Form.MaxChildren, Bebek: @Model.Form.MaxBabies)" readonly />
                <small>Toplam kişi kapasitesi otomatik hesaplanır ve rezervasyon tarafında bu sınır uygulanır.</small>
            </label>
            <label>
                <span>Oda büyüklüğü (m²)</span>
                <input type="number" name="RoomSize" value="@Model.Form.RoomSize" min="0" />
            </label>
            <label>
                <span>Yatak tipi</span>
                <select name="BedType">
                    <option value="">Seçiniz</option>
                    @foreach (var bedType in bedTypes)
                    {
                        if (Model.Form.BedType == bedType)
                        {
                            <option value="@bedType" selected="selected">@bedType</option>
                        }
                        else
                        {
                            <option value="@bedType">@bedType</option>
                        }
                    }
                </select>
            </label>
            <label>
                <span>Manzara tipi</span>
                <select name="ViewType">
                    <option value="">Seçiniz</option>
                    @foreach (var viewType in viewTypes)
                    {
                        if (Model.Form.ViewType == viewType)
                        {
                            <option value="@viewType" selected="selected">@viewType</option>
                        }
                        else
                        {
                            <option value="@viewType">@viewType</option>
                        }
                    }
                </select>
            </label>
            <label class="partner-form-span">
                <span>Kapak fotoğrafı yolu</span>
                <input type="text" name="CoverPhotoPath" value="@Model.Form.CoverPhotoPath" placeholder="/uploads/hotels/partner/29/oda-1.webp" />
            </label>
            <label class="partner-form-span">
                <span>Oda özellikleri</span>
                <textarea name="RoomFeaturesText" placeholder="Örn. Klima, Balkon, Mini bar, Akıllı TV">@Model.Form.RoomFeaturesText</textarea>
            </label>
            <label class="partner-checkbox-inline partner-form-span">
                @if (Model.Form.IsActive)
                {
                    <input type="checkbox" name="IsActive" value="true" checked="checked" />
                }
                else
                {
                    <input type="checkbox" name="IsActive" value="true" />
                }
                <span>Bu oda tipi satışta aktif olsun</span>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-floppy-disk"></i>
                @(Model.IsEditingRoom ? "Oda tipini güncelle" : "Oda tipini kaydet")
            </button>
        </form>

        @if (Model.SelectedRoomId.HasValue)
        {
            <section class="partner-room-gallery-section" id="room-gallery">
                <div class="partner-section-head">
                    <div>
                        <h2>Oda görselleri ve vitrin yönetimi</h2>
                        <p>Seçili oda için birden fazla görsel yükleyebilir, vitrin görselini belirleyebilir ve kullanılmayan dosyaları temizleyebilirsiniz.</p>
                    </div>
                </div>

                <form method="post" action="/panel/partner/oda-yonetimi/gorsel-yukle" enctype="multipart/form-data" class="partner-room-upload-box">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.PhotoUploadForm.HotelId" />
                    <input type="hidden" name="RoomId" value="@Model.PhotoUploadForm.RoomId" />
                    <label class="partner-room-upload-field">
                        <span>Oda görselleri</span>
                        <input type="file" name="Files" accept="image/*" multiple />
                        <small>Yüklenen tüm görseller optimize edilerek WebP formatına dönüştürülür.</small>
                    </label>
                    <button type="submit" class="partner-primary-btn">
                        <i class="fas fa-cloud-arrow-up"></i>
                        Oda görsellerini yükle
                    </button>
                </form>

                @if (Model.SelectedRoomPhotos.Count == 0)
                {
                    <div class="partner-empty-state partner-room-gallery-empty">
                        <strong>Henüz oda görseli yok</strong>
                        <p>Bu odaya vitrin ve galeri görselleri eklediğinizde public otel detay sayfasında oda kartında otomatik görünür.</p>
                    </div>
                }
                else
                {
                    <div class="partner-room-photo-grid">
                        @foreach (var photo in Model.SelectedRoomPhotos)
                        {
                            <article class="partner-room-photo-card @(photo.IsCover ? "is-cover" : string.Empty)">
                                <div class="partner-room-photo-media">
                                    <img src="@photo.Url" alt="@photo.Title" />
                                    @if (photo.IsCover)
                                    {
                                        <span class="partner-room-photo-badge">
                                            <i class="fas fa-star"></i>
                                            Vitrin
                                        </span>
                                    }
                                </div>
                                <div class="partner-room-photo-body">
                                    <div>
                                        <strong>@(!string.IsNullOrWhiteSpace(photo.Title) ? photo.Title : $"Oda Gorseli #{photo.PhotoId}")</strong>
                                        <small>Siralama: @photo.DisplayOrder</small>
                                    </div>
                                    <div class="partner-room-photo-actions">
                                        @if (!photo.IsCover)
                                        {
                                            <form method="post" action="/panel/partner/oda-yonetimi/gorsel-kapak-yap">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                                <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
                                                <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                                <button type="submit" class="partner-secondary-btn">
                                                    <i class="fas fa-image"></i>
                                                    Vitrin yap
                                                </button>
                                            </form>
                                        }
                                        <form method="post" action="/panel/partner/oda-yonetimi/gorsel-sil" onsubmit="return confirm('Bu oda görselini silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                            <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
                                            <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                            <button type="submit" class="partner-danger-btn">
                                                <i class="fas fa-trash"></i>
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    </article>
</section>

<script>
    (function () {
        const roomForm = document.getElementById('partnerRoomForm');
        if (!roomForm) {
            return;
        }

        const maxAdultsInput = roomForm.querySelector('input[name="MaxAdults"]');
        const maxChildrenInput = roomForm.querySelector('input[name="MaxChildren"]');
        const maxBabiesInput = roomForm.querySelector('input[name="MaxBabies"]');
        const totalRoomsInput = roomForm.querySelector('input[name="TotalRooms"]');
        const capacitySummary = document.getElementById('roomCapacitySummary');

        function parseByte(input, fallback) {
            const value = parseInt(input?.value || String(fallback), 10);
            if (Number.isNaN(value)) {
                return fallback;
            }

            return Math.max(0, value);
        }

        function refreshCapacitySummary() {
            const adults = Math.max(1, parseByte(maxAdultsInput, 1));
            const children = parseByte(maxChildrenInput, 0);
            const babies = parseByte(maxBabiesInput, 0);
            const total = adults + children + babies;

            if (capacitySummary) {
                capacitySummary.value = total + ' kişi (Yetişkin: ' + adults + ', Çocuk: ' + children + ', Bebek: ' + babies + ')';
            }
        }

        function validateRoomCapacity() {
            const adults = Math.max(1, parseByte(maxAdultsInput, 1));
            const children = parseByte(maxChildrenInput, 0);
            const babies = parseByte(maxBabiesInput, 0);
            const totalRooms = Math.max(1, parseInt(totalRoomsInput?.value || '1', 10) || 1);
            const total = adults + children + babies;

            if (totalRooms < 1) {
                alert('Toplam oda sayısı en az 1 olmalıdır.');
                totalRoomsInput?.focus();
                return false;
            }

            if (adults < 1) {
                alert('Maksimum yetişkin sayısı en az 1 olmalıdır.');
                maxAdultsInput?.focus();
                return false;
            }

            if (total < 1) {
                alert('Toplam kişi kapasitesi en az 1 olmalıdır.');
                maxAdultsInput?.focus();
                return false;
            }

            return true;
        }

        [maxAdultsInput, maxChildrenInput, maxBabiesInput].forEach(function (input) {
            input?.addEventListener('input', refreshCapacitySummary);
        });

        roomForm.addEventListener('submit', function (event) {
            if (!validateRoomCapacity()) {
                event.preventDefault();
                return;
            }

            refreshCapacitySummary();
        });

        refreshCapacitySummary();
    })();
</script>
