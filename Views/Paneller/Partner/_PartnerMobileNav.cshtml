@model otelturizmnew.Models.Paneller.Partner.PartnerShellViewModel
@{
    var selectedHotelId = Model.SelectedHotelId;
    var hotelQuery = selectedHotelId.HasValue ? $"?otelId={selectedHotelId.Value}" : string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}
<nav class="partner-mobile-nav">
    <a href="/panel/partner/dashboard@(hotelQuery)" class="@(currentAction == "Index" ? "active" : string.Empty)"><i class="fas fa-grid-2"></i><span>Panel</span></a>
    <a href="/panel/partner/rezervasyonlar@(hotelQuery)" class="@(currentAction == "Reservations" ? "active" : string.Empty)"><i class="fas fa-calendar-check"></i><span>Rez.</span></a>
    <a href="/panel/partner/takvim-fiyatlar@(hotelQuery)" class="@(currentAction == "Pricing" ? "active" : string.Empty)"><i class="fas fa-calendar-days"></i><span>Fiyat</span></a>
    <a href="/panel/partner/fotograflar@(hotelQuery)" class="@(currentAction == "Photos" ? "active" : string.Empty)"><i class="fas fa-images"></i><span>Galeri</span></a>
    <a href="/panel/partner/724-destek@(hotelQuery)" class="@(currentAction == "Support" ? "active" : string.Empty)"><i class="fas fa-headset"></i><span>Destek</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket"></i><span>Cikis</span></button>
    </form>
</nav>
