@model otelturizmnew.Models.Paneller.Partner.PartnerHotelInfoPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/hotel-info";
    var form = Model.Form;
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Tesis yönetimi</div>
            <h2 class="page-title">Tesis Özellikleri</h2>
            <div class="text-muted mt-1">Otel listeleme, detay ve filtreleme alanlarında görünen tesis özelliklerini seçin.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <div class="btn-list">
                <a class="btn btn-outline-primary" href="/panel/partner/otel-bilgileri?otelId=@form.HotelId#ozellikler">
                    <i class="fas fa-arrow-up-right-from-square me-2"></i>Tesis veri merkezini aç
                </a>
            </div>
        </div>
    </div>
</div>

<form method="post" action="/panel/partner/tesis/ozellikler/kaydet">
    @Html.AntiForgeryToken()
    <input type="hidden" name="HotelId" value="@form.HotelId" />

    <div class="row row-cards">
        <div class="col-12">
            <div class="card" id="ozellikler">
                <div class="card-header">
                    <div>
                        <h3 class="card-title mb-0">Özellikler</h3>
                        <div class="text-muted small">Seçili: <strong>@Model.AvailableAmenities.Count(x => x.IsSelected)</strong></div>
                    </div>
                    <div class="card-actions">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-floppy-disk me-2"></i>Kaydet
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="hotel-amenity-categories">
                        @foreach (var group in Model.AvailableAmenities.GroupBy(x => x.CategoryName).OrderBy(x => x.Key))
                        {
                            <div class="hotel-amenity-category">
                                <h3>@group.Key</h3>
                                <div class="hotel-amenity-grid">
                                    @foreach (var amenity in group)
                                    {
                                        <label class="amenity-chip">
                                            <input type="checkbox" name="SelectedAmenityIds" value="@amenity.AmenityId" checked="@amenity.IsSelected" />
                                            <i class="fas @amenity.IconClass"></i>
                                            <span>@amenity.Name</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-floppy-disk me-2"></i>Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

