@model otelturizmnew.Models.Paneller.Partner.PartnerReservationsPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var hasPrevPage = Model.CurrentPage > 1;
    var hasNextPage = Model.CurrentPage < Model.TotalPages;
}

<section class="partner-grid">
@foreach (var card in Model.SummaryCards)
{
    <article class="partner-stat-card @card.ToneClass">
        <i class="fas @card.IconClass"></i>
        <strong>@card.Value</strong>
        <span>@card.Label</span>
        <p>@card.Description</p>
    </article>
}
</section>

<section class="partner-section-card">
    <div class="partner-section-head partner-reservation-toolbar">
        <div>
            <h2>Rezervasyon Listesi</h2>
            <p>Onay, red, detay ve misafir mesajı aksiyonlarını tek ekranda yönetin.</p>
        </div>
        <div class="partner-reservation-toolbar-actions">
            <a href="/panel/partner/rezervasyonlar/disa-aktar?otelId=@Model.Shell.SelectedHotelId" class="partner-secondary-btn ot-btn ot-btn--ghost">
                <i class="fas fa-download"></i>
                Dışa aktar
            </a>
        </div>
    </div>
    <form method="get" action="/panel/partner/rezervasyonlar" class="partner-reservation-filters">
        <input type="hidden" name="otelId" value="@Model.Shell.SelectedHotelId" />
        <label>
            <span>Giriş tarihi (başlangıç)</span>
            <input type="date" name="dateFrom" value="@Model.Filters.DateFrom" />
        </label>
        <label>
            <span>Çıkış tarihi (bitiş)</span>
            <input type="date" name="dateTo" value="@Model.Filters.DateTo" />
        </label>
        <label>
            <span>Durum</span>
            <select name="status">
                <option value="all" selected="@(Model.Filters.Status == "all")">Tüm durumlar</option>
                <option value="pending" selected="@(Model.Filters.Status == "pending")">Bekleyen</option>
                <option value="approved" selected="@(Model.Filters.Status == "approved")">Onaylı</option>
                <option value="rejected" selected="@(Model.Filters.Status == "rejected")">Red / İptal</option>
            </select>
        </label>
        <label>
            <span>Ödeme tipi</span>
            <select name="paymentMethod">
                <option value="all" selected="@(Model.Filters.PaymentMethod == "all")">Tumu</option>
                <option value="card" selected="@(Model.Filters.PaymentMethod == "card")">Kart ile ode</option>
                <option value="cash" selected="@(Model.Filters.PaymentMethod == "cash")">Kapıda ödeme / nakit</option>
                <option value="transfer" selected="@(Model.Filters.PaymentMethod == "transfer")">Havale / EFT</option>
                <option value="mixed" selected="@(Model.Filters.PaymentMethod == "mixed")">Karma ödeme</option>
            </select>
        </label>
        <label>
            <span>Sayfa başı</span>
            <select name="pageSize">
                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                <option value="20" selected="@(Model.PageSize == 20)">20</option>
                <option value="30" selected="@(Model.PageSize == 30)">30</option>
            </select>
        </label>
        <input type="hidden" name="page" value="1" />
        <button type="submit" class="partner-primary-btn ot-btn ot-btn--primary">
            <i class="fas fa-filter"></i>
            Filtrele
        </button>
    </form>
    <div class="partner-policy-alert @(Model.PenaltyActive ? "is-critical" : Model.RejectCountLast30Days >= 3 ? "is-warning" : string.Empty)">
        <h4>Rezervasyon onay ve red politikası</h4>
        <p>Son 30 gündeki red sayınız: <strong>@Model.RejectCountLast30Days</strong>. Her red için nedeni detaylı ve aydınlatıcı şekilde yazmanız zorunludur.</p>
        <ul>
            <li>3 red ve üzeri: sistem tesisi 3 gün süreyle listelemeden otomatik kapatır.</li>
            <li>5 red ve üzeri: kontenjan ve fiyat stratejisinin tekrar yapılandırılması önerilir.</li>
            <li>Onay ve red işlemlerinde misafire e-posta bildirimi otomatik gönderilir.</li>
        </ul>
        @if (Model.PenaltyActive && !string.IsNullOrWhiteSpace(Model.PenaltyEndText))
        {
            <p class="partner-policy-meta">Cezai kapatma bitiş tarihi: <strong>@Model.PenaltyEndText</strong></p>
        }
    </div>
    <div class="partner-table-wrap">
        <table class="partner-table partner-reservation-table">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Misafir</th>
                    <th>Oda</th>
                    <th>Konaklama</th>
                    <th>Durum</th>
                    <th>Odeme</th>
                    <th>Tutar</th>
                    <th>Olusturma</th>
                    <th>Aksiyon</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Reservations)
            {
                <tr class="partner-reservation-row" data-reservation-search="@($"{row.ReservationNo} {row.GuestName} {row.GuestEmail} {row.GuestPhone} {row.RoomName}".ToLowerInvariant())">
                    <td>
                        <strong>@row.ReservationNo</strong>
                        <small>@(row.SourceLabel ?? "Web")</small>
                    </td>
                    <td>
                        <strong>@row.GuestName</strong>
                        <small>@row.GuestEmail</small>
                    </td>
                    <td>
                        <strong>@(row.RoomName ?? "Oda bilgisi yok")</strong>
                        <small>@row.AdultCount yetiskin / @row.ChildCount cocuk</small>
                    </td>
                    <td>
                        <strong>@row.StayText</strong>
                        <small>@row.NightCount gece</small>
                    </td>
                    <td>
                        <span class="partner-status-pill ot-badge">@row.StatusLabel</span>
                        @if (!string.IsNullOrWhiteSpace(row.CancellationReason))
                        {
                            <small>Iptal: @row.CancellationReason</small>
                        }
                    </td>
                    <td>
                        <strong>@row.PaymentStatusLabel</strong>
                        <small>
                            @(row.PaymentMethodLabel ?? "Yontem belirtilmedi")
                            @if (row.PaymentLineCount > 1 && !string.IsNullOrWhiteSpace(row.PaymentMixSummary))
                            {
                                <span> · @row.PaymentMixSummary</span>
                            }
                        </small>
                    </td>
                    <td>@row.TotalText</td>
                    <td>@row.CreatedText</td>
                    <td>
                        <div class="partner-table-actions">
                            @if (row.CanApprove)
                            {
                                <form method="post" action="/panel/partner/rezervasyonlar/durum">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
                                    <input type="hidden" name="ReservationId" value="@row.ReservationId" />
                                    <input type="hidden" name="ActionType" value="approve" />
                                    <button type="submit" class="partner-icon-btn is-success ot-btn ot-btn--success" title="Onayla">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </form>
                            }
                            @if (row.CanReject)
                            {
                                <button type="button"
                                        class="partner-icon-btn is-danger ot-btn ot-btn--danger"
                                        title="Reddet"
                                        data-reservation-reject
                                        data-reservation-id="@row.ReservationId"
                                        data-reservation-no="@row.ReservationNo"
                                        data-guest-name="@row.GuestName">
                                    <i class="fas fa-times"></i>
                                </button>
                            }
                            <button type="button"
                                    class="partner-icon-btn ot-btn ot-btn--ghost"
                                    title="Detay gor"
                                    data-reservation-detail
                                    data-reservation-no="@row.ReservationNo"
                                    data-guest-name="@row.GuestName"
                                    data-guest-email="@row.GuestEmail"
                                    data-guest-phone="@row.GuestPhone"
                                    data-room-name="@(row.RoomName ?? string.Empty)"
                                    data-stay-text="@row.StayText"
                                    data-status="@row.StatusLabel"
                                    data-payment-status="@row.PaymentStatusLabel"
                                    data-payment-method="@(row.PaymentMethodLabel ?? string.Empty)"
                                    data-source="@(row.SourceLabel ?? string.Empty)"
                                    data-total="@row.TotalText"
                                    data-created="@row.CreatedText"
                                    data-guest-note="@(row.GuestNote ?? string.Empty)"
                                    data-request-note="@(row.RequestNote ?? string.Empty)"
                                    data-cancellation-reason="@(row.CancellationReason ?? string.Empty)"
                                    data-cancellation-time="@(row.CancellationTimeText ?? string.Empty)">
                                <i class="fas fa-eye"></i>
                            </button>
                            @if (row.CanMessageGuest)
                            {
                                <button type="button"
                                        class="partner-icon-btn is-info ot-btn ot-btn--primary"
                                        title="Misafire mesaj"
                                        data-reservation-message
                                        data-reservation-id="@row.ReservationId"
                                        data-reservation-no="@row.ReservationNo"
                                        data-guest-name="@row.GuestName">
                                    <i class="fas fa-envelope"></i>
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="partner-pagination">
        <div class="partner-pagination-meta">
            Toplam <strong>@Model.TotalCount</strong> kayit · Sayfa <strong>@Model.CurrentPage</strong> / <strong>@Model.TotalPages</strong>
        </div>
        <div class="partner-pagination-actions">
            <a class="partner-secondary-btn @(hasPrevPage ? string.Empty : "is-disabled") ot-btn ot-btn--ghost"
               href="@(hasPrevPage ? $"/panel/partner/rezervasyonlar?otelId={Model.Shell.SelectedHotelId}&dateFrom={Model.Filters.DateFrom}&dateTo={Model.Filters.DateTo}&status={Model.Filters.Status}&paymentMethod={Model.Filters.PaymentMethod}&pageSize={Model.PageSize}&conversationId={Model.SelectedConversationId}&page={Model.CurrentPage - 1}" : "#")">
                <i class="fas fa-chevron-left"></i>
                Onceki
            </a>
            <a class="partner-secondary-btn @(hasNextPage ? string.Empty : "is-disabled") ot-btn ot-btn--ghost"
               href="@(hasNextPage ? $"/panel/partner/rezervasyonlar?otelId={Model.Shell.SelectedHotelId}&dateFrom={Model.Filters.DateFrom}&dateTo={Model.Filters.DateTo}&status={Model.Filters.Status}&paymentMethod={Model.Filters.PaymentMethod}&pageSize={Model.PageSize}&conversationId={Model.SelectedConversationId}&page={Model.CurrentPage + 1}" : "#")">
                Sonraki
                <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    </div>
</section>

<section class="partner-section-card partner-chat-shell" id="partner-reservation-chat">
    <div class="partner-section-head">
        <div>
            <h2>Partner Sohbet Alani</h2>
            <p>Misafir mesajlari burada anlik listelenir. Konusma secip yanit verebilirsiniz.</p>
        </div>
    </div>
    @if (Model.Conversations.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Henüz mesaj konuşması yok</strong>
            <p>Misafir bir mesaj gonderdiginde veya siz rezervasyondan mesaj attiginizda bu alanda sohbet gorunur.</p>
        </div>
    }
    else
    {
        <div class="partner-chat-grid">
            <aside class="partner-chat-thread-list">
                @foreach (var thread in Model.Conversations)
                {
                    <a href="/panel/partner/rezervasyonlar?otelId=@Model.Shell.SelectedHotelId&dateFrom=@Model.Filters.DateFrom&dateTo=@Model.Filters.DateTo&status=@Model.Filters.Status&paymentMethod=@Model.Filters.PaymentMethod&pageSize=@Model.PageSize&page=@Model.CurrentPage&conversationId=@thread.ConversationId#partner-reservation-chat"
                       class="partner-chat-thread @(thread.IsSelected ? "is-selected" : string.Empty)">
                        <div>
                            <strong>@thread.GuestName</strong>
                            <small>@thread.ReservationNo</small>
                        </div>
                        @if (thread.UnreadCount > 0)
                        {
                            <span class="partner-chat-unread">@thread.UnreadCount</span>
                        }
                        <p>@thread.LastMessagePreview</p>
                        <small>@thread.LastMessageTimeText</small>
                    </a>
                }
            </aside>
            <div class="partner-chat-panel">
                <div class="partner-chat-messages">
                    @foreach (var message in Model.ConversationMessages)
                    {
                        <article class="partner-chat-bubble @(message.IsFromHotel ? "is-self" : "is-guest")">
                            <header>
                                <strong>@message.SenderLabel</strong>
                                <small>@message.TimeText</small>
                            </header>
                            <p>@message.Body</p>
                        </article>
                    }
                </div>
                @if (Model.MessageForm.ReservationId > 0)
                {
                    <form method="post" action="/panel/partner/rezervasyonlar/misafire-mesaj" class="partner-chat-reply-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
                        <input type="hidden" name="ReservationId" value="@Model.MessageForm.ReservationId" />
                        <input type="hidden" name="ConversationId" value="@Model.SelectedConversationId" />
                        <input type="hidden" name="Subject" value="Rezervasyon bilgilendirmesi" />
                        <textarea name="Message" rows="3" minlength="2" required placeholder="Misafire yanit yazin..."></textarea>
                        <button type="submit" class="partner-primary-btn">
                            <i class="fas fa-paper-plane"></i>
                            Yanit gonder
                        </button>
                    </form>
                }
            </div>
        </div>
    }
</section>

<dialog id="partner-reservation-detail-dialog" class="partner-dialog">
    <div class="partner-dialog-card">
        <div class="partner-dialog-head">
            <div>
                <p class="partner-dialog-kicker">Rezervasyon detaylari</p>
                <h3 id="reservation-detail-no">-</h3>
            </div>
            <button type="button" class="partner-icon-btn" data-close-dialog>
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <div class="partner-dialog-grid">
            <article class="partner-dialog-panel">
                <h4>Misafir</h4>
                <dl>
                    <div><dt>Ad Soyad</dt><dd id="reservation-detail-guest-name">-</dd></div>
                    <div><dt>E-posta</dt><dd id="reservation-detail-guest-email">-</dd></div>
                    <div><dt>Telefon</dt><dd id="reservation-detail-guest-phone">-</dd></div>
                </dl>
            </article>
            <article class="partner-dialog-panel">
                <h4>Konaklama</h4>
                <dl>
                    <div><dt>Oda</dt><dd id="reservation-detail-room-name">-</dd></div>
                    <div><dt>Tarih</dt><dd id="reservation-detail-stay">-</dd></div>
                    <div><dt>Durum</dt><dd id="reservation-detail-status">-</dd></div>
                </dl>
            </article>
            <article class="partner-dialog-panel">
                <h4>Odeme</h4>
                <dl>
                    <div><dt>Odeme durumu</dt><dd id="reservation-detail-payment-status">-</dd></div>
                    <div><dt>Yontem</dt><dd id="reservation-detail-payment-method">-</dd></div>
                    <div><dt>Tutar</dt><dd id="reservation-detail-total">-</dd></div>
                </dl>
            </article>
            <article class="partner-dialog-panel">
                <h4>Kayit</h4>
                <dl>
                    <div><dt>Kanal</dt><dd id="reservation-detail-source">-</dd></div>
                    <div><dt>Olusturma</dt><dd id="reservation-detail-created">-</dd></div>
                    <div><dt>Iptal tarihi</dt><dd id="reservation-detail-cancel-time">-</dd></div>
                    <div><dt>Iptal nedeni</dt><dd id="reservation-detail-cancel-reason">-</dd></div>
                </dl>
            </article>
        </div>
        <div class="partner-dialog-notes">
            <article class="partner-dialog-panel">
                <h4>Misafir notu</h4>
                <p id="reservation-detail-guest-note">-</p>
            </article>
            <article class="partner-dialog-panel">
                <h4>Talep notu</h4>
                <p id="reservation-detail-request-note">-</p>
            </article>
        </div>
    </div>
</dialog>

<dialog id="partner-reservation-reject-dialog" class="partner-dialog">
    <div class="partner-dialog-card">
        <div class="partner-dialog-head">
            <div>
                <p class="partner-dialog-kicker">Rezervasyon reddet</p>
                <h3 id="reservation-reject-title">Red sebebini belirtin</h3>
            </div>
            <button type="button" class="partner-icon-btn" data-close-dialog>
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <form method="post" action="/panel/partner/rezervasyonlar/durum" class="partner-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
            <input type="hidden" name="ReservationId" id="reservation-reject-id" value="0" />
            <input type="hidden" name="ActionType" value="reject" />
            <label class="partner-form-span">
                <span>Detayli red sebebi</span>
                <textarea name="Reason" id="reservation-reject-reason" rows="6" minlength="15" required placeholder="Misafire aciklayici bir red nedeni yazin (en az 15 karakter)."></textarea>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-ban"></i>
                Red sebebi ile kaydet
            </button>
        </form>
    </div>
</dialog>

<dialog id="partner-reservation-message-dialog" class="partner-dialog">
    <div class="partner-dialog-card">
        <div class="partner-dialog-head">
            <div>
                <p class="partner-dialog-kicker">Misafire mesaj</p>
                <h3 id="reservation-message-title">Mesaj paneli</h3>
            </div>
            <button type="button" class="partner-icon-btn" data-close-dialog>
                <i class="fas fa-xmark"></i>
            </button>
        </div>
        <form method="post" action="/panel/partner/rezervasyonlar/misafire-mesaj" class="partner-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.Shell.SelectedHotelId" />
            <input type="hidden" name="ReservationId" id="reservation-message-id" value="0" />
            <input type="hidden" name="ConversationId" value="@Model.SelectedConversationId" />
            <label>
                <span>Konu</span>
                <input type="text" name="Subject" id="reservation-message-subject" value="Konaklama bilgilendirmesi" />
            </label>
            <label class="partner-form-span">
                <span>Mesaj</span>
                <textarea name="Message" rows="5" placeholder="Misafire gonderilecek mesaj"></textarea>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-paper-plane"></i>
                Mesaji gonder
            </button>
        </form>
    </div>
</dialog>

@section Scripts {
<script>
(() => {
    const detailDialog = document.getElementById('partner-reservation-detail-dialog');
    const rejectDialog = document.getElementById('partner-reservation-reject-dialog');
    const messageDialog = document.getElementById('partner-reservation-message-dialog');

    document.querySelectorAll('[data-reservation-detail]').forEach((button) => {
        button.addEventListener('click', () => {
            if (!detailDialog) return;
            document.getElementById('reservation-detail-no').textContent = button.dataset.reservationNo || '-';
            document.getElementById('reservation-detail-guest-name').textContent = button.dataset.guestName || '-';
            document.getElementById('reservation-detail-guest-email').textContent = button.dataset.guestEmail || '-';
            document.getElementById('reservation-detail-guest-phone').textContent = button.dataset.guestPhone || '-';
            document.getElementById('reservation-detail-room-name').textContent = button.dataset.roomName || '-';
            document.getElementById('reservation-detail-stay').textContent = button.dataset.stayText || '-';
            document.getElementById('reservation-detail-status').textContent = button.dataset.status || '-';
            document.getElementById('reservation-detail-payment-status').textContent = button.dataset.paymentStatus || '-';
            document.getElementById('reservation-detail-payment-method').textContent = button.dataset.paymentMethod || '-';
            document.getElementById('reservation-detail-source').textContent = button.dataset.source || '-';
            document.getElementById('reservation-detail-total').textContent = button.dataset.total || '-';
            document.getElementById('reservation-detail-created').textContent = button.dataset.created || '-';
            document.getElementById('reservation-detail-cancel-time').textContent = button.dataset.cancellationTime || '-';
            document.getElementById('reservation-detail-cancel-reason').textContent = button.dataset.cancellationReason || '-';
            document.getElementById('reservation-detail-guest-note').textContent = button.dataset.guestNote || 'Misafir notu bulunmuyor.';
            document.getElementById('reservation-detail-request-note').textContent = button.dataset.requestNote || 'Ek talep bulunmuyor.';
            detailDialog.showModal();
        });
    });

    document.querySelectorAll('[data-reservation-message]').forEach((button) => {
        button.addEventListener('click', () => {
            if (!messageDialog) return;
            document.getElementById('reservation-message-id').value = button.dataset.reservationId || '0';
            document.getElementById('reservation-message-title').textContent = `${button.dataset.guestName || 'Misafir'} icin mesaj`;
            document.getElementById('reservation-message-subject').value = `${button.dataset.reservationNo || 'Rezervasyon'} bilgilendirmesi`;
            messageDialog.showModal();
        });
    });

    document.querySelectorAll('[data-reservation-reject]').forEach((button) => {
        button.addEventListener('click', () => {
            if (!rejectDialog) return;
            document.getElementById('reservation-reject-id').value = button.dataset.reservationId || '0';
            document.getElementById('reservation-reject-title').textContent = `${button.dataset.reservationNo || 'Rezervasyon'} / ${button.dataset.guestName || 'Misafir'} icin red sebebi`;
            document.getElementById('reservation-reject-reason').value = '';
            rejectDialog.showModal();
        });
    });

    document.querySelectorAll('[data-close-dialog]').forEach((button) => {
        button.addEventListener('click', () => {
            button.closest('dialog')?.close();
        });
    });

    [detailDialog, rejectDialog, messageDialog].forEach((dialog) => {
        if (!dialog) return;
        dialog.addEventListener('click', (event) => {
            const rect = dialog.getBoundingClientRect();
            const inDialog = rect.top <= event.clientY && event.clientY <= rect.top + rect.height && rect.left <= event.clientX && event.clientX <= rect.left + rect.width;
            if (!inDialog) {
                dialog.close();
            }
        });
    });
})();
</script>
}
