@model otelturizmnew.Models.Paneller.Partner.PartnerPhotosPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var photoTypes = new[] { "Dış Cephe", "Lobi", "Restoran", "Havuz", "Plaj", "Oda", "Banyo", "Spor Salonu", "SPA", "Toplantı Odası", "Genel Alan", "Yemek", "Manzara" };
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Otel Medya</div>
            <h2 class="page-title">Fotoğraflar</h2>
            <div class="text-muted mt-1">Yeni galeri görsellerini yükleyin, kapağa alın ve medya alanlarını doldurun.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <div class="btn-list">
                <a class="btn btn-primary" href="#fotograf-yukle">
                    <i class="fas fa-cloud-arrow-up me-2"></i>Fotoğraf yükle
                </a>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#tab-hotel-photos">Otel Fotoğrafları</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#tab-room-photos">Oda Fotoğrafları</a>
    </li>
</ul>

<div class="tab-content">
<div class="tab-pane fade show active" id="tab-hotel-photos">

<div class="row row-cards">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted text-uppercase fw-bold" style="letter-spacing:.06em; font-size:12px;">@card.Label</div>
                            <div class="h1 m-0 mt-2">@card.Value</div>
                            <div class="text-muted mt-1">@card.Description</div>
                        </div>
                        <span class="avatar bg-primary-lt text-primary">
                            <i class="fas @card.IconClass" aria-hidden="true"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row row-cards mt-2">
    <div class="col-12 col-xl-6">
        <div class="card" id="fotograf-yukle">
            <div class="card-header">
                <h3 class="card-title">Fotoğraf yükle</h3>
            </div>
            <form id="partner-photo-upload-form" method="post" action="/panel/partner/fotograflar/yukle" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Başlık</label>
                            <input class="form-control" type="text" name="Title" value="@Model.UploadForm.Title" placeholder="Örn. Giriş cephesi gün batımı çekimi" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Görsel tipi</label>
                            <select class="form-select" name="PhotoType">
                                @foreach (var photoType in photoTypes)
                                {
                                    <option value="@photoType" selected="@(Model.UploadForm.PhotoType == photoType)">@photoType</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" name="Description" rows="4" placeholder="Misafirlerin galeride göreceği kısa açıklama">@Model.UploadForm.Description</textarea>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Sıralama</label>
                            <input class="form-control" type="number" name="DisplayOrder" value="@Model.UploadForm.DisplayOrder" min="0" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Dosyalar</label>
                            <input id="partner-photo-files" class="form-control" type="file" name="Files" multiple accept="image/*" />
                        </div>
                        <div class="col-12 partner-upload-meta" id="partner-upload-meta" hidden>
                            <div class="d-flex justify-content-between">
                                <strong id="partner-upload-count">0 dosya seçildi</strong>
                                <span class="text-muted" id="partner-upload-size">0 MB</span>
                            </div>
                            <div class="progress mt-2" hidden id="partner-upload-progress-shell">
                                <div class="progress-bar" id="partner-upload-progress-bar" style="width:0%"></div>
                            </div>
                            <div class="text-muted mt-2" id="partner-upload-help">Seçilen görseller yüklenmeye hazır.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" name="MakeCover" value="true" checked="@(Model.UploadForm.MakeCover)" />
                                <span class="form-check-label">İlk yüklenen görseli kapak fotoğrafı yap</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary w-100" id="partner-upload-submit">
                        <i class="fas fa-cloud-arrow-up me-2"></i>Fotoğrafları yükle
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">@(Model.IsEditingPhoto ? "Fotoğrafı düzenle" : "Galeri kartı seçin")</h3>
                <div class="card-actions">
                    @if (Model.IsEditingPhoto)
                    {
                        <a href="/panel/partner/fotograflar?otelId=@Model.SelectedHotelId" class="btn btn-outline-primary btn-sm">Seçimi temizle</a>
                    }
                </div>
            </div>
            <form method="post" action="/panel/partner/fotograflar/guncelle">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <input type="hidden" name="PhotoId" value="@Model.EditForm.PhotoId" />
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Başlık</label>
                            <input class="form-control" type="text" name="Title" value="@Model.EditForm.Title" placeholder="Galeri başlığı" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Görsel tipi</label>
                            <select class="form-select" name="PhotoType">
                                @foreach (var photoType in photoTypes)
                                {
                                    <option value="@photoType" selected="@(Model.EditForm.PhotoType == photoType)">@photoType</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Sıralama</label>
                            <input class="form-control" type="number" name="DisplayOrder" value="@Model.EditForm.DisplayOrder" min="0" />
                        </div>
                        <div class="col-12 col-md-6 d-flex align-items-end">
                            <label class="form-check m-0">
                                <input class="form-check-input" type="checkbox" name="MarkAsFeatured" value="true" checked="@(Model.EditForm.MarkAsFeatured)" />
                                <span class="form-check-label">Öne çıkan görsel olarak işaretle</span>
                            </label>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" name="Description" rows="4" placeholder="Kısa açıklama">@Model.EditForm.Description</textarea>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary w-100" @(Model.IsEditingPhoto ? null : "disabled")>
                        <i class="fas fa-floppy-disk me-2"></i>Fotoğrafı güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<section class="partner-section-card">
    <div class="partner-section-head">
        <div>
            <h2>Galeri</h2>
            <p>Kapak, öne çıkan ve kategori bazlı tüm görselleri tek ekranda yönetin.</p>
        </div>
        <button type="button" class="partner-secondary-btn" id="partner-photo-bulk-toggle">
            <i class="fas fa-check-double"></i>
            Toplu seçim
        </button>
    </div>
    @if (Model.Photos.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Henüz galeri görseli yok</strong>
            <p>Yüklediğiniz tüm otel fotoğrafları bu alanda kart düzeninde listelenecek.</p>
        </div>
    }
    else
    {
        <form id="partner-photo-bulk-form" method="post" action="/panel/partner/fotograflar/toplu-sil" class="partner-photo-bulk-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <div class="partner-photo-bulk-bar" hidden>
                <strong id="partner-photo-bulk-count">0 görsel seçildi</strong>
                <button type="submit" class="partner-danger-btn" onclick="return confirm('Seçilen görseller kalıcı olarak silinsin mi?');">
                    <i class="fas fa-trash"></i>
                    Seçilenleri sil
                </button>
            </div>
            <div class="partner-photo-gallery">
                @foreach (var photo in Model.Photos)
                {
                    <article class="partner-photo-card @(photo.IsCover ? "is-cover" : string.Empty)">
                        <div class="partner-photo-visual">
                            <label class="partner-photo-selector" hidden>
                                <input type="checkbox" name="PhotoIds" value="@photo.PhotoId" />
                                <span><i class="fas fa-check"></i></span>
                            </label>
                            <img src="@photo.Url" alt="@photo.Title" />
                            <div class="partner-photo-badges">
                                @if (photo.IsCover)
                                {
                                    <span class="partner-chip is-cover">Kapak</span>
                                }
                                @if (photo.IsApproved)
                                {
                                    <span class="partner-chip is-approved">Onaylı</span>
                                }
                                <span class="partner-chip">@photo.Type</span>
                            </div>
                        </div>
                        <div class="partner-photo-card-content">
                            <div class="partner-photo-head">
                                <div>
                                    <strong>@photo.Title</strong>
                                    <p>@photo.SortText</p>
                                </div>
                            </div>
                            <p class="partner-photo-description">@(string.IsNullOrWhiteSpace(photo.Description) ? "Bu görsel için açıklama eklenmemiş." : photo.Description)</p>
                            <div class="partner-photo-card-actions">
                                <a href="/panel/partner/fotograflar?otelId=@Model.SelectedHotelId&photoId=@photo.PhotoId" class="partner-secondary-btn">
                                    <i class="fas fa-pen"></i>
                                    Düzenle
                                </a>
                                <form method="post" action="/panel/partner/fotograflar/kapak-yap">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                    <button type="submit" class="partner-secondary-btn">
                                        <i class="fas fa-image-portrait"></i>
                                        Kapak yap
                                    </button>
                                </form>
                                <form method="post" action="/panel/partner/fotograflar/sil" onsubmit="return confirm('Bu fotoğraf galeriden kalıcı olarak silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                    <button type="submit" class="partner-danger-btn">
                                        <i class="fas fa-trash"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </form>
    }
</section>

@section Scripts {
@{
    var nonce = Context.Items["CspNonce"] as string;
}

</div>

<div class="tab-pane fade" id="tab-room-photos">
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title mb-0">Oda fotoğraf yönetimi</h3>
                <div class="text-muted small">Oda görselleri oda bazlı yönetilir. Aşağıdan oda seçip ilgili galeri alanına geçebilirsiniz.</div>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Rooms.Count == 0)
            {
                <div class="text-muted">Henüz oda tipi tanımlanmadığı için oda fotoğrafı yönetimi açılamıyor.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var room in Model.Rooms)
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:64px; height:48px; border-radius:12px; overflow:hidden; background:#f3f4f6; flex: 0 0 auto;">
                                            @if (!string.IsNullOrWhiteSpace(room.CoverPhotoUrl))
                                            {
                                                <img src="@room.CoverPhotoUrl" alt="@room.RoomName" style="width:100%; height:100%; object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center h-100">
                                                    <i class="fas fa-bed text-muted"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="min-w-0">
                                            <div class="fw-bold text-truncate">@room.RoomName</div>
                                            <div class="text-muted small">Stok: @room.TotalRooms · @(room.IsActive ? "Aktif" : "Pasif")</div>
                                        </div>
                                    </div>
                                    <div class="mt-3 d-flex justify-content-end">
                                        <a class="btn btn-outline-primary btn-sm" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId&roomId=@room.RoomId#room-gallery">
                                            <i class="fas fa-images me-1"></i>Oda görsellerini yönet
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
</div>
<script nonce="@nonce">
(() => {
    const form = document.getElementById('partner-photo-upload-form');
    const fileInput = document.getElementById('partner-photo-files');
    const meta = document.getElementById('partner-upload-meta');
    const countText = document.getElementById('partner-upload-count');
    const sizeText = document.getElementById('partner-upload-size');
    const helpText = document.getElementById('partner-upload-help');
    const progressShell = document.getElementById('partner-upload-progress-shell');
    const progressBar = document.getElementById('partner-upload-progress-bar');
    const submitButton = document.getElementById('partner-upload-submit');
    const bulkToggleButton = document.getElementById('partner-photo-bulk-toggle');
    const bulkForm = document.getElementById('partner-photo-bulk-form');
    const bulkBar = bulkForm?.querySelector('.partner-photo-bulk-bar');
    const bulkCount = document.getElementById('partner-photo-bulk-count');
    const selectors = Array.from(document.querySelectorAll('.partner-photo-selector'));
    let bulkMode = false;

    if (!form || !fileInput || !meta || !countText || !sizeText || !helpText || !progressShell || !progressBar || !submitButton) {
        return;
    }

    const formatMb = (bytes) => `${(bytes / 1024 / 1024).toFixed(2)} MB`;

    fileInput.addEventListener('change', () => {
        const files = Array.from(fileInput.files || []);
        if (files.length === 0) {
            meta.hidden = true;
            progressShell.hidden = true;
            progressBar.style.width = '0%';
            helpText.textContent = 'Secilen gorseller yuklenmeye hazir.';
            return;
        }

        const totalSize = files.reduce((sum, file) => sum + file.size, 0);
        meta.hidden = false;
        progressShell.hidden = true;
        progressBar.style.width = '0%';
        countText.textContent = `${files.length} dosya secildi`;
        sizeText.textContent = formatMb(totalSize);
        helpText.textContent = 'Toplu yukleme hazir. Gorseller WebP formatina cevrilerek kaydedilecek.';
    });

    form.addEventListener('submit', (event) => {
        event.preventDefault();

        if (!fileInput.files || fileInput.files.length === 0) {
            meta.hidden = false;
            helpText.textContent = 'Lutfen en az bir gorsel secin.';
            helpText.classList.add('is-error');
            return;
        }

        helpText.classList.remove('is-error');
        submitButton.disabled = true;
        progressShell.hidden = false;
        progressBar.style.width = '0%';
        helpText.textContent = 'Yukleme basladi. Gorseller optimize edilip WebP formatina donusturuluyor...';

        const formData = new FormData(form);
        const xhr = new XMLHttpRequest();
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.upload.addEventListener('progress', (progressEvent) => {
            if (!progressEvent.lengthComputable) {
                return;
            }

            const percent = Math.min(100, Math.round((progressEvent.loaded / progressEvent.total) * 100));
            progressBar.style.width = `${percent}%`;
            helpText.textContent = `Yukleme suruyor... %${percent}`;
        });

        xhr.onload = () => {
            submitButton.disabled = false;

            let payload = null;
            try {
                payload = JSON.parse(xhr.responseText);
            } catch (_) {
                payload = null;
            }

            if (xhr.status >= 200 && xhr.status < 300 && payload?.success) {
                progressBar.style.width = '100%';
                helpText.textContent = payload.message || 'Fotoğraflar başarıyla yüklendi.';
                window.location.href = payload.redirectUrl || `/panel/partner/fotograflar?otelId=@Model.SelectedHotelId`;
                return;
            }

            helpText.textContent = payload?.message || 'Toplu gorsel yukleme sirasinda bir hata olustu.';
            helpText.classList.add('is-error');
        };

        xhr.onerror = () => {
            submitButton.disabled = false;
            helpText.textContent = 'Yukleme baglantisi kurulamadi. Lutfen tekrar deneyin.';
            helpText.classList.add('is-error');
        };

        xhr.send(formData);
    });

    const updateBulkState = () => {
        if (!bulkBar || !bulkCount) {
            return;
        }

        const selected = Array.from(document.querySelectorAll('.partner-photo-selector input:checked'));
        bulkBar.hidden = !bulkMode;
        bulkCount.textContent = `${selected.length} gorsel secildi`;
    };

    bulkToggleButton?.addEventListener('click', () => {
        bulkMode = !bulkMode;
        selectors.forEach((selector) => {
            selector.hidden = !bulkMode;
            if (!bulkMode) {
                const checkbox = selector.querySelector('input');
                if (checkbox) {
                    checkbox.checked = false;
                }
            }
        });
        bulkToggleButton.classList.toggle('is-active', bulkMode);
        updateBulkState();
    });

    document.querySelectorAll('.partner-photo-selector input').forEach((input) => {
        input.addEventListener('change', updateBulkState);
    });

    bulkForm?.addEventListener('submit', (event) => {
        const selectedCount = document.querySelectorAll('.partner-photo-selector input:checked').length;
        if (selectedCount === 0) {
            event.preventDefault();
            alert('Lutfen once silinecek gorselleri secin.');
        }
    });
})();
</script>
}
