@model otelturizmnew.Models.Paneller.Partner.PartnerPhotosPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/photos";
    var photoTypes = new[] { "Dış Cephe", "Lobi", "Restoran", "Havuz", "Plaj", "Oda", "Banyo", "Spor Salonu", "SPA", "Toplantı Odası", "Genel Alan", "Yemek", "Manzara" };
}

<div class="partner-media-page">
    <div class="partner-media-hero">
        <div>
            <div class="page-pretitle">Otel medya merkezi</div>
            <h2 class="page-title">Fotoğraflar</h2>
            <p>Otel galerisini minimal kartlarla yönetin. Seçimler, kategori ve açıklama değişiklikleri anlık kaydedilir.</p>
        </div>
        <a class="btn btn-primary" href="#fotograf-yukle">
            <i class="fas fa-plus me-2"></i>Görsel ekle
        </a>
    </div>

    <div class="partner-media-stats">
        @foreach (var card in Model.SummaryCards)
        {
            <div class="partner-media-stat">
                <span class="avatar bg-primary-lt text-primary"><i class="fas @card.IconClass"></i></span>
                <div>
                    <small>@card.Label</small>
                    <strong>@card.Value</strong>
                    <em>@card.Description</em>
                </div>
            </div>
        }
    </div>

    <div class="partner-auto-save-status" id="partner-photo-save-status" role="status" aria-live="polite" hidden>
        <i class="fas fa-circle-notch fa-spin"></i>
        <span>Kaydediliyor...</span>
    </div>

    <ul class="nav nav-tabs partner-media-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link active" data-bs-toggle="tab" href="#tab-hotel-photos" role="tab">
                <i class="fas fa-hotel me-2"></i>Otel görselleri
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" data-bs-toggle="tab" href="#tab-room-photos" role="tab">
                <i class="fas fa-bed me-2"></i>Oda görselleri
            </a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-hotel-photos" role="tabpanel">
            <section class="partner-section-card partner-upload-panel" id="fotograf-yukle">
                <div class="partner-section-head">
                    <div>
                        <h2>Yeni görsel ekle</h2>
                        <p>Görseller WebP formatına çevrilir; kapak seçimi aktifse ilk görsel otomatik kapak olur.</p>
                    </div>
                </div>
                <form id="partner-photo-upload-form" class="panel-form-ux-upload-form" method="post" action="/panel/partner/fotograflar/yukle" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <div class="partner-upload-grid">
                        <label>
                            <span>Başlık</span>
                            <input class="form-control" type="text" name="Title" value="@Model.UploadForm.Title" placeholder="Örn. Lobi alanı" />
                        </label>
                        <label>
                            <span>Görsel tipi</span>
                            <select class="form-select" name="PhotoType">
                                @foreach (var photoType in photoTypes)
                                {
                                    <option value="@photoType" selected="@(Model.UploadForm.PhotoType == photoType)">@photoType</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>Sıralama</span>
                            <input class="form-control" type="number" name="DisplayOrder" value="@Model.UploadForm.DisplayOrder" min="0" />
                        </label>
                        <label class="partner-upload-file panel-form-ux-upload">
                            <span>Dosyalar</span>
                            <input id="partner-photo-files" class="form-control panel-form-ux-upload-file" type="file" name="Files" multiple accept="image/*" />
                            <p class="panel-form-ux-upload-help">Sürükleyip bırakın veya tıklayın · JPG/PNG/WebP · çoklu seçim</p>
                        </label>
                        <label class="partner-upload-description">
                            <span>Açıklama</span>
                            <textarea class="form-control" name="Description" rows="2" placeholder="Kısa açıklama">@Model.UploadForm.Description</textarea>
                        </label>
                        <label class="partner-switch-row">
                            <input class="form-check-input" type="checkbox" name="MakeCover" value="true" checked="@(Model.UploadForm.MakeCover)" />
                            <span>İlk görseli kapak yap</span>
                        </label>
                    </div>
                    <div class="partner-upload-meta" id="partner-upload-meta" hidden>
                        <div class="partner-upload-meta-row">
                            <strong id="partner-upload-count">0 dosya seçildi</strong>
                            <span id="partner-upload-size">0 MB</span>
                        </div>
                        <div class="partner-upload-progress-shell" hidden id="partner-upload-progress-shell">
                            <div class="partner-upload-progress-bar" id="partner-upload-progress-bar"></div>
                        </div>
                        <p class="partner-upload-help" id="partner-upload-help">Seçilen görseller yüklenmeye hazır.</p>
                    </div>
                    <button type="submit" class="btn btn-primary partner-upload-submit panel-form-ux-upload-btn" id="partner-upload-submit">
                        <i class="fas fa-cloud-arrow-up me-2"></i>Yükle
                    </button>
                </form>
            </section>

            <section class="partner-section-card">
                <div class="partner-section-head">
                    <div>
                        <h2>Otel galerisi</h2>
                        <p>Kart üzerindeki alanları değiştirince otomatik kaydedilir; kapak ve sil işlemleri ayrıca bildirilir.</p>
                    </div>
                    <button type="button" class="partner-secondary-btn" id="partner-photo-bulk-toggle">
                        <i class="fas fa-check-double"></i>Toplu seçim
                    </button>
                </div>

                @if (Model.Photos.Count == 0)
                {
                    <div class="partner-empty-state">
                        <strong>Henüz galeri görseli yok</strong>
                        <p>Yüklediğiniz otel fotoğrafları bu alanda kompakt kartlarla listelenecek.</p>
                    </div>
                }
                else
                {
                    <form id="partner-photo-bulk-form" method="post" action="/panel/partner/fotograflar/toplu-sil" class="partner-photo-bulk-shell">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                        <div class="partner-photo-bulk-bar" hidden>
                            <strong id="partner-photo-bulk-count">0 görsel seçildi</strong>
                            <button type="submit" class="partner-danger-btn" onclick="return confirm('Seçilen görseller kalıcı olarak silinsin mi?');">
                                <i class="fas fa-trash"></i>Seçilenleri sil
                            </button>
                        </div>
                    </form>

                    <div class="partner-photo-gallery">
                        @foreach (var photo in Model.Photos)
                        {
                            <article class="partner-photo-card @(photo.IsCover ? "is-cover" : string.Empty)" data-photo-card="@photo.PhotoId">
                                <div class="partner-photo-visual">
                                    <label class="partner-photo-selector" hidden>
                                        <input form="partner-photo-bulk-form" type="checkbox" name="PhotoIds" value="@photo.PhotoId" />
                                        <span><i class="fas fa-check"></i></span>
                                    </label>
                                    <img src="@photo.Url" alt="@photo.Title" />
                                    <div class="partner-photo-badges">
                                        @if (photo.IsCover) { <span class="partner-chip is-cover">Kapak</span> }
                                        @if (photo.IsFeatured) { <span class="partner-chip is-featured">Öne çıkan</span> }
                                        @if (photo.IsApproved) { <span class="partner-chip is-approved">Onaylı</span> }
                                    </div>
                                </div>

                                <form class="partner-photo-inline-form" method="post" action="/panel/partner/fotograflar/guncelle" data-photo-save>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="PhotoId" value="@photo.PhotoId" />

                                    <div class="partner-photo-card-content">
                                        <div class="partner-photo-head">
                                            <label>
                                                <span>Başlık</span>
                                                <input class="form-control" type="text" name="Title" value="@photo.Title" autocomplete="off" data-photo-autosave="blur" />
                                            </label>
                                            <label>
                                                <span>Sıra</span>
                                                <input class="form-control" type="number" name="DisplayOrder" value="@photo.DisplayOrder" min="0" data-photo-autosave="change" />
                                            </label>
                                        </div>

                                        <div class="partner-photo-mini-grid">
                                            <label>
                                                <span>Kategori</span>
                                                <select class="form-select" name="PhotoType" data-photo-autosave="change">
                                                    @foreach (var photoType in photoTypes)
                                                    {
                                                        <option value="@photoType" selected="@(photo.Type == photoType)">@photoType</option>
                                                    }
                                                </select>
                                            </label>
                                            <label class="partner-switch-row">
                                                <input class="form-check-input" type="checkbox" name="MarkAsFeatured" value="true" checked="@photo.IsFeatured" data-photo-autosave="change" />
                                                <span>Öne çıkar</span>
                                            </label>
                                        </div>

                                        <details class="partner-photo-details">
                                            <summary><i class="fas fa-pen"></i>Düzenle</summary>
                                            <label>
                                                <span>Açıklama</span>
                                                <textarea class="form-control" name="Description" rows="3" data-photo-autosave="blur">@(photo.Description ?? string.Empty)</textarea>
                                            </label>
                                        </details>
                                    </div>
                                </form>

                                <div class="partner-photo-card-actions">
                                    <form method="post" action="/panel/partner/fotograflar/kapak-yap" data-photo-action="cover">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                        <button type="submit" class="partner-secondary-btn" @(photo.IsCover ? "disabled" : null)>
                                            <i class="fas fa-image-portrait"></i>Kapak
                                        </button>
                                    </form>
                                    <a href="@photo.Url" target="_blank" rel="noopener" class="partner-secondary-btn">
                                        <i class="fas fa-up-right-from-square"></i>Gör
                                    </a>
                                    <form method="post" action="/panel/partner/fotograflar/sil" data-photo-action="delete">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                        <button type="submit" class="partner-danger-btn">
                                            <i class="fas fa-trash"></i>Sil
                                        </button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="tab-pane fade" id="tab-room-photos" role="tabpanel">
            <div class="card partner-room-photo-manager">
                <div class="card-header">
                    <div>
                        <h3 class="card-title mb-0">Oda fotoğraf yönetimi</h3>
                        <div class="text-muted small">Odayı seçin ve doğrudan oda galerisi alanına geçin.</div>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Rooms.Count == 0)
                    {
                        <div class="partner-empty-state">
                            <strong>Henüz oda tipi yok</strong>
                            <p>Oda görseli yükleyebilmek için önce oda tipi oluşturun.</p>
                        </div>
                    }
                    else
                    {
                        <div class="partner-room-photo-list">
                            @foreach (var room in Model.Rooms)
                            {
                                <a class="partner-room-photo-row" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId&roomId=@room.RoomId#room-gallery">
                                    <span class="partner-room-photo-thumb">
                                        @if (!string.IsNullOrWhiteSpace(room.CoverPhotoUrl))
                                        {
                                            <img src="@room.CoverPhotoUrl" alt="@room.RoomName" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-bed"></i>
                                        }
                                    </span>
                                    <span>
                                        <strong>@room.RoomName</strong>
                                        <small>Stok: @room.TotalRooms · @(room.IsActive ? "Aktif" : "Pasif")</small>
                                    </span>
                                    <em>Oda görsellerini yönet</em>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
(() => {
    const form = document.getElementById('partner-photo-upload-form');
    const fileInput = document.getElementById('partner-photo-files');
    const meta = document.getElementById('partner-upload-meta');
    const countText = document.getElementById('partner-upload-count');
    const sizeText = document.getElementById('partner-upload-size');
    const helpText = document.getElementById('partner-upload-help');
    const progressShell = document.getElementById('partner-upload-progress-shell');
    const progressBar = document.getElementById('partner-upload-progress-bar');
    const submitButton = document.getElementById('partner-upload-submit');
    const bulkToggleButton = document.getElementById('partner-photo-bulk-toggle');
    const bulkForm = document.getElementById('partner-photo-bulk-form');
    const bulkBar = bulkForm?.querySelector('.partner-photo-bulk-bar');
    const bulkCount = document.getElementById('partner-photo-bulk-count');
    const selectors = Array.from(document.querySelectorAll('.partner-photo-selector'));
    const statusBox = document.getElementById('partner-photo-save-status');
    let bulkMode = false;
    let statusTimer = 0;

    const formatMb = (bytes) => `${(bytes / 1024 / 1024).toFixed(2)} MB`;
    const showStatus = (message, tone = 'info') => {
        if (!statusBox) return;
        window.clearTimeout(statusTimer);
        statusBox.hidden = false;
        statusBox.dataset.tone = tone;
        statusBox.querySelector('span').textContent = message;
        const icon = statusBox.querySelector('i');
        icon.className = tone === 'success' ? 'fas fa-circle-check' : tone === 'danger' ? 'fas fa-triangle-exclamation' : 'fas fa-circle-notch fa-spin';
        statusTimer = window.setTimeout(() => { statusBox.hidden = true; }, tone === 'info' ? 2200 : 3600);
    };

    const postForm = async (targetForm) => {
        const response = await fetch(targetForm.action, {
            method: 'POST',
            body: new FormData(targetForm),
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const payload = await response.json().catch(() => ({ success: false, message: 'İşlem sonucu okunamadı.' }));
        if (!response.ok || !payload.success) throw new Error(payload.message || 'İşlem tamamlanamadı.');
        return payload;
    };

    fileInput?.addEventListener('change', () => {
        const files = Array.from(fileInput.files || []);
        if (!meta || !progressShell || !progressBar || !helpText || !countText || !sizeText) return;
        if (files.length === 0) {
            meta.hidden = true;
            progressShell.hidden = true;
            progressBar.style.width = '0%';
            helpText.textContent = 'Seçilen görseller yüklenmeye hazır.';
            return;
        }

        const totalSize = files.reduce((sum, file) => sum + file.size, 0);
        meta.hidden = false;
        progressShell.hidden = true;
        progressBar.style.width = '0%';
        countText.textContent = `${files.length} dosya seçildi`;
        sizeText.textContent = formatMb(totalSize);
        helpText.textContent = 'Toplu yükleme hazır. Görseller WebP formatına çevrilerek kaydedilecek.';
    });

    form?.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!fileInput?.files || fileInput.files.length === 0) {
            if (meta) meta.hidden = false;
            if (helpText) {
                helpText.textContent = 'Lütfen en az bir görsel seçin.';
                helpText.classList.add('is-error');
            }
            return;
        }

        helpText?.classList.remove('is-error');
        if (submitButton) submitButton.disabled = true;
        if (progressShell) progressShell.hidden = false;
        if (progressBar) progressBar.style.width = '0%';
        if (helpText) helpText.textContent = 'Yükleme başladı. Görseller optimize ediliyor...';

        const formData = new FormData(form);
        const xhr = new XMLHttpRequest();
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.upload.addEventListener('progress', (progressEvent) => {
            if (!progressEvent.lengthComputable || !progressBar || !helpText) return;
            const percent = Math.min(100, Math.round((progressEvent.loaded / progressEvent.total) * 100));
            progressBar.style.width = `${percent}%`;
            helpText.textContent = `Yükleme sürüyor... %${percent}`;
        });

        xhr.onload = () => {
            if (submitButton) submitButton.disabled = false;
            let payload = null;
            try { payload = JSON.parse(xhr.responseText); } catch (_) { payload = null; }
            if (xhr.status >= 200 && xhr.status < 300 && payload?.success) {
                if (progressBar) progressBar.style.width = '100%';
                if (helpText) helpText.textContent = payload.message || 'Fotoğraflar başarıyla yüklendi.';
                window.location.href = payload.redirectUrl || `/panel/partner/fotograflar?otelId=@Model.SelectedHotelId`;
                return;
            }
            if (helpText) {
                helpText.textContent = payload?.message || 'Toplu görsel yükleme sırasında bir hata oluştu.';
                helpText.classList.add('is-error');
            }
        };

        xhr.onerror = () => {
            if (submitButton) submitButton.disabled = false;
            if (helpText) {
                helpText.textContent = 'Yükleme bağlantısı kurulamadı. Lütfen tekrar deneyin.';
                helpText.classList.add('is-error');
            }
        };

        xhr.send(formData);
    });

    document.querySelectorAll('[data-photo-save]').forEach((saveForm) => {
        let saveTimer = 0;
        const save = async () => {
            window.clearTimeout(saveTimer);
            showStatus('Fotoğraf bilgisi kaydediliyor...', 'info');
            try {
                const payload = await postForm(saveForm);
                showStatus(payload.message || 'Fotoğraf bilgisi güncellendi.', 'success');
            } catch (error) {
                showStatus(error.message, 'danger');
            }
        };

        saveForm.querySelectorAll('[data-photo-autosave="change"]').forEach((field) => {
            field.addEventListener('change', save);
        });

        saveForm.querySelectorAll('[data-photo-autosave="blur"]').forEach((field) => {
            field.addEventListener('blur', save);
            field.addEventListener('keydown', (event) => {
                if (event.key !== 'Enter' || field.tagName === 'TEXTAREA') return;
                event.preventDefault();
                field.blur();
            });
        });
    });

    document.querySelectorAll('[data-photo-action]').forEach((actionForm) => {
        actionForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            const action = actionForm.dataset.photoAction;
            if (action === 'delete' && !confirm('Bu fotoğraf galeriden kalıcı olarak silinsin mi?')) return;
            showStatus(action === 'delete' ? 'Fotoğraf siliniyor...' : 'Kapak güncelleniyor...', 'info');
            try {
                const payload = await postForm(actionForm);
                showStatus(payload.message || 'İşlem tamamlandı.', 'success');
                window.setTimeout(() => window.location.reload(), 650);
            } catch (error) {
                showStatus(error.message, 'danger');
            }
        });
    });

    const updateBulkState = () => {
        if (!bulkBar || !bulkCount) return;
        const selected = Array.from(document.querySelectorAll('.partner-photo-selector input:checked'));
        bulkBar.hidden = !bulkMode;
        bulkCount.textContent = `${selected.length} görsel seçildi`;
    };

    bulkToggleButton?.addEventListener('click', () => {
        bulkMode = !bulkMode;
        selectors.forEach((selector) => {
            selector.hidden = !bulkMode;
            if (!bulkMode) {
                const checkbox = selector.querySelector('input');
                if (checkbox) checkbox.checked = false;
            }
        });
        bulkToggleButton.classList.toggle('is-active', bulkMode);
        updateBulkState();
    });

    document.querySelectorAll('.partner-photo-selector input').forEach((input) => input.addEventListener('change', updateBulkState));
    bulkForm?.addEventListener('submit', (event) => {
        if (document.querySelectorAll('.partner-photo-selector input:checked').length === 0) {
            event.preventDefault();
            alert('Lütfen önce silinecek görselleri seçin.');
        }
    });
})();
</script>
}
