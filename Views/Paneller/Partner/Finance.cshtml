@model otelturizmnew.Models.Paneller.Partner.PartnerFinancePageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
}

<section class="partner-grid">
@foreach (var card in Model.SummaryCards)
{
    <article class="partner-stat-card @card.ToneClass">
        <i class="fas @card.IconClass"></i>
        <strong>@card.Value</strong>
        <span>@card.Label</span>
        <p>@card.Description</p>
    </article>
}
</section>

<section class="partner-section-card">
    <div class="partner-section-head partner-finance-toolbar">
        <div>
            <h2>Finans merkezi</h2>
            <p>Tahsilatlar, faturalar ve banka aktarim bilgileri tek akista yonetilir.</p>
        </div>
        <a href="/panel/partner/finans/disa-aktar?otelId=@Model.Shell.SelectedHotelId" class="partner-secondary-btn">
            <i class="fas fa-file-export"></i>
            Finans disa aktar
        </a>
    </div>
</section>

<section class="partner-two-column">
    <article class="partner-section-card">
        <h2>Son finans hareketleri</h2>
        @if (Model.Transactions.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Henuz finans hareketi yok</strong>
                <p>Rezervasyon odemeleri geldikce tahsilat ve net odeme akisi burada listelenecek.</p>
            </div>
        }
        else
        {
            <div class="partner-table-wrap">
                <table class="partner-table">
                    <thead>
                        <tr>
                            <th>Kayit</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                            <th>Tutar</th>
                            <th>Detay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Transactions)
                        {
                            <tr>
                                <td>@item.Label</td>
                                <td>@item.DateText</td>
                                <td>@item.StatusText</td>
                                <td>@item.AmountText</td>
                                <td>@item.DetailText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
    <article class="partner-section-card">
        <h2>Finans notu</h2>
        <p>@Model.PayoutNote</p>
        <div class="partner-finance-callout">
            <i class="fas fa-circle-info"></i>
            <span>Partner panelindeki banka bilgileri guncel tutulursa odeme operasyonlari hizlanir.</span>
        </div>
    </article>
</section>

<section class="partner-two-column">
    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Faturalar</h2>
                <p>Kesilen faturalari indirip donem bazli takip edebilirsiniz.</p>
            </div>
        </div>
        @if (Model.Invoices.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Fatura kaydi bulunmuyor</strong>
                <p>Fatura olustukca bu alanda indirilebilir dokumanlar listelenecek.</p>
            </div>
        }
        else
        {
            <div class="partner-table-wrap">
                <table class="partner-table">
                    <thead>
                        <tr>
                            <th>Fatura No</th>
                            <th>Tarih</th>
                            <th>Tur</th>
                            <th>Durum</th>
                            <th>Toplam</th>
                            <th>Alici</th>
                            <th>Indir</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Invoices)
                        {
                            <tr>
                                <td>@item.InvoiceNo</td>
                                <td>@item.InvoiceDateText</td>
                                <td>@item.InvoiceTypeText</td>
                                <td>@item.InvoiceStatusText</td>
                                <td>@item.TotalText</td>
                                <td>@item.RecipientText</td>
                                <td>
                                    <a class="partner-secondary-btn partner-inline-btn" href="/panel/partner/finans/fatura-indir?hotelId=@Model.Shell.SelectedHotelId&invoiceId=@item.InvoiceId">
                                        <i class="fas fa-download"></i>
                                        Dokuman
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Banka hesap bilgileri</h2>
                <p>Partner odemeleri bu hesap bilgilerine gore planlanir.</p>
            </div>
        </div>
        <form method="post" action="/panel/partner/finans/banka-kaydet" class="partner-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.BankInfoForm.HotelId" />
            <label>
                <span>Banka</span>
                <input type="text" name="BankName" value="@Model.BankInfoForm.BankName" placeholder="Banka adi" />
            </label>
            <label>
                <span>Sube</span>
                <input type="text" name="BranchName" value="@Model.BankInfoForm.BranchName" placeholder="Sube adi" />
            </label>
            <label class="partner-form-span">
                <span>IBAN</span>
                <input type="text" name="Iban" value="@Model.BankInfoForm.Iban" placeholder="TR..." />
            </label>
            <label>
                <span>Hesap sahibi</span>
                <input type="text" name="AccountHolderName" value="@Model.BankInfoForm.AccountHolderName" placeholder="Hesap sahibi unvani" />
            </label>
            <label>
                <span>Para birimi</span>
                <select name="Currency">
                    <option value="TRY" selected="@(Model.BankInfoForm.Currency == "TRY")">TRY</option>
                    <option value="USD" selected="@(Model.BankInfoForm.Currency == "USD")">USD</option>
                    <option value="EUR" selected="@(Model.BankInfoForm.Currency == "EUR")">EUR</option>
                </select>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-building-columns"></i>
                Banka bilgilerini guncelle
            </button>
        </form>
    </article>
</section>
