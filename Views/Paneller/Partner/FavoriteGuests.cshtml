@model otelturizmnew.Models.Paneller.Partner.PartnerFavoriteGuestsPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
}

<section class="partner-growth-hero">
    <div>
        <p class="partner-room-kicker">Favori kitlesi</p>
        <h2>Sizi favorilerine ekleyen misafirler</h2>
        <p>@Model.PrivacyNote</p>
    </div>
    <div class="partner-chip ot-badge ot-badge--info">Otel ID: <strong>@Model.SelectedHotelId</strong></div>
</section>

<section class="partner-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="partner-stat-card @card.ToneClass">
            <i class="fas @card.IconClass"></i>
            <strong>@card.Value</strong>
            <span>@card.Label</span>
            <p>@card.Description</p>
        </article>
    }
</section>

<section class="partner-section-card">
    <div class="partner-section-head">
        <div>
            <h2>Favori listesi</h2>
            <p><code>user_favori_oteller</code> ve üye profili (şehir, kaynak sayfa) ile eşleşen kayıtlar.</p>
        </div>
    </div>
    @if (Model.Rows.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Henüz favori kaydı yok</strong>
            <p>Misafirler oteli favorilediğinde kayıtlar burada listelenir.</p>
        </div>
    }
    else
    {
        <div class="partner-table-wrap">
            <table class="partner-table">
                <thead>
                    <tr>
                        <th>Misafir</th>
                        <th>İletişim</th>
                        <th>Şehir</th>
                        <th>Kaynak</th>
                        <th>Cihaz</th>
                        <th>Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>
                                <strong>@row.DisplayName</strong>
                                <div class="partner-table-note">#@row.UserId</div>
                            </td>
                            <td>@row.MaskedEmail</td>
                            <td>@(string.IsNullOrWhiteSpace(row.UserCity) ? "—" : row.UserCity)</td>
                            <td>@(string.IsNullOrWhiteSpace(row.SourcePage) ? "—" : row.SourcePage)</td>
                            <td>@(string.IsNullOrWhiteSpace(row.DeviceType) ? "—" : row.DeviceType)</td>
                            <td>@row.AddedText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
