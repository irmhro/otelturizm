@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerPricingPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/pricing";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    var weekdays = new[] { "Pzt", "Sal", "Çar", "Per", "Cum", "Cmt", "Paz" };
    var hotelQuery = $"otelId={Model.SelectedHotelId}";
    var roomQuery = Model.SelectedRoomId.HasValue ? $"&roomId={Model.SelectedRoomId.Value}" : string.Empty;
    var nonce = Context.Items["CspNonce"] as string;
    var maxPricingDate = DateTime.Today.AddDays(365).ToString("yyyy-MM-dd");
    var selectedRoom = Model.SelectedRoomId.HasValue ? Model.Rooms.FirstOrDefault(x => x.RoomId == Model.SelectedRoomId.Value) : null;
    var selectedRoomName = selectedRoom?.RoomName ?? "Oda seçilmedi";
}

<div class="partner-pricing-hero">
    <div>
        <div class="page-pretitle">Fiyat Yönetimi</div>
        <h2 class="page-title">Takvim ve Kontenjan</h2>
        <p>Oda seçin; gün bazında fiyat, indirim, satış durumu ve kontenjanı FullCalendar düzeninde yönetin.</p>
    </div>
    <div class="partner-pricing-hero-actions">
        <a class="btn btn-outline-primary" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.PreviousMonthKey">
            <i class="fas fa-chevron-left me-2"></i>Önceki ay
        </a>
        <form method="get" action="/panel/partner/takvim-fiyatlar" class="partner-calendar-month-form">
            <input type="hidden" name="otelId" value="@Model.SelectedHotelId" />
            @if (Model.SelectedRoomId.HasValue)
            {
                <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
            }
            <label for="partnerHeroMonthPicker">Ay</label>
            <select id="partnerHeroMonthPicker" name="month" onchange="this.form.submit()">
                @foreach (var monthOption in Model.MonthOptions)
                {
                    <option value="@monthOption.MonthKey" selected="@(monthOption.IsCurrent ? "selected" : null)">@monthOption.Label</option>
                }
            </select>
        </form>
        <a class="btn btn-outline-primary" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.NextMonthKey">
            Sonraki ay<i class="fas fa-chevron-right ms-2"></i>
        </a>
    </div>
</div>

<div class="row row-cards partner-pricing-summary-grid">
    @foreach (var item in Model.SummaryCards)
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card partner-pricing-stat is-@item.ToneClass">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="partner-pricing-stat-label">@item.Label</div>
                            <div class="h1 m-0 mt-2">@item.Value</div>
                            <div class="text-muted mt-1">@item.Description</div>
                        </div>
                        <span class="avatar bg-primary-lt text-primary">
                            <i class="fas @item.IconClass" aria-hidden="true"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row row-cards mt-2">
    <div class="col-12">
        <div class="card partner-room-overview-card">
            <div class="card-header">
                <div>
                    <h3 class="card-title">Görüntülenen oda tipi</h3>
                    <div class="text-muted">Renkler oda tiplerini ayırır; ay bazlı rezervasyon ve indirim sayısı her oda kartında görünür.</div>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    @foreach (var room in Model.Rooms)
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <a href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@room.RoomId&month=@Model.MonthKey"
                               class="partner-room-month-card @room.ToneClass @(room.RoomId == Model.SelectedRoomId ? "is-selected" : string.Empty)">
                                <div class="partner-room-month-card-head">
                                    <div>
                                        <div class="partner-room-month-title">@room.RoomName</div>
                                        <div class="partner-room-month-meta">@room.BasePriceText · @room.StockText</div>
                                    </div>
                                    <span>@(room.IsActive ? "Aktif" : "Pasif")</span>
                                </div>
                                <div class="partner-room-month-stats">
                                    <strong>@room.MonthlyReservationCount</strong>
                                    <small>aylık rezervasyon</small>
                                    <strong>@room.MonthlyDiscountDayCount</strong>
                                    <small>indirimli gün</small>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards mt-2">
    <div class="col-12">
        <details class="card partner-pricing-bulk-wide partner-pricing-bulk-disclosure">
            <summary>
                <span>
                    <strong>Çoklu fiyat güncelleme</strong>
                    <small>Birden fazla oda ve tarih aralığı için fiyat, indirim, stok ve satış durumunu toplu güncelleyin.</small>
                </span>
                <b><i class="fas fa-sliders me-2"></i>Aç / düzenle</b>
            </summary>
            <div class="card-body partner-pricing-bulk-body">
                <div class="form-hint mb-3">Geçmiş 60 gün sistem tarafından otomatik temizlenir. Yeni fiyat ve müsaitlik girişi en fazla @maxPricingDate tarihine kadar yapılabilir.</div>
                <form method="post" action="/panel/partner/takvim-fiyatlar/toplu-guncelle" id="partnerBulkPricingForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <input type="hidden" name="ViewRoomId" value="@Model.SelectedRoomId" />
                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />

                    <div class="mb-3">
                        <div class="form-label">Güncelleme uygulanacak odalar</div>
                        <div class="row g-2">
                            @foreach (var room in Model.Rooms.Where(x => x.IsActive))
                            {
                                var isChecked = Model.BulkForm.SelectedRoomIds.Contains(room.RoomId);
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-check partner-pricing-room-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoomIds" value="@room.RoomId" checked="@(isChecked ? "checked" : null)" />
                                        <span class="form-check-label">
                                            <span class="fw-bold">@room.RoomName</span>
                                            <span class="text-muted d-block small">@room.BasePriceText · @room.StockText</span>
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih başlangıcı</label>
                            <input class="form-control" type="date" name="DateFrom" value="@Model.BulkForm.DateFrom.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih bitişi</label>
                            <input class="form-control" type="date" name="DateTo" value="@Model.BulkForm.DateTo.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Normal fiyat (vergi dahil)</label>
                            <input class="form-control" type="number" step="0.01" name="BasePrice" value="@(Model.BulkForm.BasePrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Mevcut fiyat kalsın" title="KDV ve konaklama vergisi dahil gece tutarı" inputmode="decimal" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">İndirimli fiyat (vergi dahil)</label>
                            <input class="form-control" type="number" step="0.01" name="DiscountPrice" id="partnerBulkDiscountPrice" value="@(Model.BulkForm.DiscountPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Opsiyonel" title="KDV ve konaklama vergisi dahil" inputmode="decimal" />
                        </div>
                        <div class="col-12 col-md-4 col-xl-2">
                            <label class="form-label">Satışa açık oda</label>
                            <input class="form-control" type="number" name="TotalRooms" min="0" value="@(Model.BulkForm.TotalRooms?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Stok korunacak" />
                        </div>
                        <div class="col-12 col-md-4 col-xl-2">
                            <label class="form-label">Minimum geceleme</label>
                            <input class="form-control" type="number" name="MinStay" min="1" value="@(Model.BulkForm.MinStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Değiştirme" />
                        </div>
                        <div class="col-12 col-md-4 col-xl-2">
                            <label class="form-label">Maksimum geceleme</label>
                            <input class="form-control" type="number" name="MaxStay" min="1" value="@(Model.BulkForm.MaxStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Değiştirme" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Satış durumu</label>
                            <select class="form-select" name="SaleStatusAction">
                                <option value="keep" selected>Mevcut durum korunsun</option>
                                <option value="open">Satışa aç</option>
                                <option value="close">Satışa kapat</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">İndirim seçimi</label>
                            <select class="form-select" name="DiscountId" id="partnerBulkDiscountId">
                                <option value="">İndirim uygulanmayacak</option>
                                @foreach (var discount in Model.AvailableDiscounts)
                                {
                                    <option value="@discount.DiscountId">@discount.DiscountName</option>
                                }
                            </select>
                            <div class="form-hint" id="partnerBulkDiscountHint" style="display:none;">
                                İndirimli fiyat girdiyseniz indirim seçimi zorunludur.
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">İndirim etiketi (opsiyonel)</label>
                            <input class="form-control" type="text" name="CampaignLabel" maxlength="120" placeholder="Örn. Yaz Fırsatı" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Takvim notu</label>
                            <textarea class="form-control" name="PriceNote" rows="2" placeholder="Örn. Bu tarihte kahvaltı dahil fiyat uygulanıyor."></textarea>
                        </div>
                        <div class="col-12 d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <label class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" name="ClearDiscountPrice" value="true" id="partnerBulkClearDiscount" />
                                <span class="form-check-label">İndirimli fiyatı temizle</span>
                            </label>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-floppy-disk me-2"></i>Takvim ve fiyat kurallarını uygula
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </details>
    </div>
</div>

<div class="row row-cards mt-2">
    <div class="col-12">
        <div class="card partner-calendar-card">
            <div class="card-header partner-calendar-card-header">
                <div>
                    <div class="page-pretitle">Aylık fiyat takvimi</div>
                    <h3 class="card-title partner-fc-title">@Model.MonthLabel</h3>
                    <div class="text-muted">@selectedRoomName · fiyat, indirim ve kontenjan görünümü</div>
                </div>
                <div class="partner-calendar-toolbar">
                    <a class="btn btn-outline-primary btn-sm" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.PreviousMonthKey">
                        <i class="fas fa-chevron-left me-2"></i>Önceki ay
                    </a>
                    <form method="get" action="/panel/partner/takvim-fiyatlar" class="partner-calendar-month-form">
                        <input type="hidden" name="otelId" value="@Model.SelectedHotelId" />
                        @if (Model.SelectedRoomId.HasValue)
                        {
                            <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
                        }
                        <label for="partnerMonthPicker">Ay</label>
                        <select id="partnerMonthPicker" name="month" onchange="this.form.submit()">
                            @foreach (var monthOption in Model.MonthOptions)
                            {
                                <option value="@monthOption.MonthKey" selected="@(monthOption.IsCurrent ? "selected" : null)">@monthOption.Label</option>
                            }
                        </select>
                    </form>
                    <a class="btn btn-outline-primary btn-sm" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.NextMonthKey">
                        Sonraki ay<i class="fas fa-chevron-right ms-2"></i>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="partner-calendar-legend">
                    <span class="is-open"><i class="fas fa-circle"></i>Satışa açık</span>
                    <span class="is-discount"><i class="fas fa-circle"></i>Kampanyalı / indirimli</span>
                    <span class="is-closed"><i class="fas fa-circle"></i>Satışa kapalı</span>
                </div>
                <div class="alert alert-info" role="alert">
                    <div class="d-flex">
                        <div class="me-2"><i class="fas fa-circle-info"></i></div>
                        <div>Anasayfa, favoriler ve detay fiyatları bu takvimdeki açık satış günlerinin en düşük efektif fiyatına göre hesaplanır (indirimli fiyat varsa önce o kullanılır).</div>
                    </div>
                </div>

        @if (Model.CalendarDays.Count == 0)
        {
            <div class="empty">
                <div class="empty-icon"><i class="fas fa-calendar"></i></div>
                <p class="empty-title">Takvim verisi hazır değil</p>
                <p class="empty-subtitle text-muted">Bu otel için önce oda tipi seçin veya aktif oda tipleri tanımlayın.</p>
            </div>
        }
        else
        {
            <div class="partner-calendar-month-scroll">
            <div class="partner-calendar-weekdays">
                @foreach (var day in weekdays)
                {
                    <div>@day</div>
                }
            </div>
            <div class="partner-calendar-month-grid">
                @{
                    var today = DateOnly.FromDateTime(DateTime.Today);
                }
                @foreach (var day in Model.CalendarDays)
                {
                    var isPast = day.Date < today;
                    <article class="partner-calendar-cell is-@day.ToneClass @(day.IsCurrentMonth ? string.Empty : "is-other-month") @(day.IsToday ? "is-today" : string.Empty) @(day.IsHighlighted ? "is-highlighted" : string.Empty) @(day.IsClosed ? "is-closed" : string.Empty) @(isPast ? "is-past" : string.Empty)"
                             data-date="@day.Date.ToString("yyyy-MM-dd")"
                             data-base-price="@day.BasePriceAmount.ToString(CultureInfo.InvariantCulture)"
                             data-discount-price="@(day.DiscountPriceAmount?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                             data-total-rooms="@day.TotalRooms"
                             data-min-stay="@day.MinStay"
                             data-max-stay="@day.MaxStay"
                             data-is-closed="@(day.IsClosed ? "true" : "false")"
                            data-discount-id="@(day.DiscountId?.ToString() ?? string.Empty)"
                             data-price-note="@day.PriceNote">
                        <div class="partner-calendar-cell-head">
                            <div>
                                <strong>@day.DayLabel</strong>
                                <span>@day.WeekdayLabel</span>
                            </div>
                            <b class="partner-calendar-status ot-badge">@day.StatusText</b>
                        </div>
                        <div class="partner-calendar-date-text">@day.Date.ToString("dd.MM.yyyy")</div>
                        <div class="partner-calendar-event">
                            <div class="partner-calendar-room-line">
                                <i class="fas fa-bed"></i>
                                <span>@selectedRoomName</span>
                            </div>
                            <div class="partner-calendar-price-block">
                                @if (day.HasDiscount)
                                {
                                    <div class="partner-calendar-discount-line">
                                        <small>@day.BasePriceText</small>
                                        <span>@day.DiscountPercentText</span>
                                    </div>
                                    <strong>@day.DiscountPriceText</strong>
                                    <em>@(string.IsNullOrWhiteSpace(day.CampaignLabel) ? "İndirimli gün" : day.CampaignLabel)</em>
                                }
                                else
                                {
                                    <strong>@day.PriceText</strong>
                                }
                            </div>
                            <div class="partner-calendar-capacity-line">
                                <span><i class="fas fa-door-open"></i>@day.AvailabilityText</span>
                                <span><i class="fas fa-receipt"></i>@day.SoldText</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(day.CampaignLabel))
                        {
                            <span class="partner-calendar-tag">@day.CampaignLabel</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(day.PriceNote))
                        {
                            <p class="partner-calendar-note">@day.PriceNote</p>
                        }
                        @if (Model.SelectedRoomId.HasValue && day.IsCurrentMonth && !isPast)
                        {
                        <div class="partner-calendar-actions">
                                <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="partner-calendar-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="RoomId" value="@Model.SelectedRoomId.Value" />
                                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
                                    <input type="hidden" name="Date" value="@day.Date.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="SaleStatusAction" value="open" />
                                <button type="submit" class="partner-calendar-inline-btn is-open">
                                    <i class="fas fa-lock-open me-1"></i>Satışa aç
                                    </button>
                                </form>
                                <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="partner-calendar-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="RoomId" value="@Model.SelectedRoomId.Value" />
                                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
                                    <input type="hidden" name="Date" value="@day.Date.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="SaleStatusAction" value="close" />
                                <button type="submit" class="partner-calendar-inline-btn is-close">
                                    <i class="fas fa-lock me-1"></i>Satışa kapat
                                    </button>
                                </form>
                            <button type="button" class="partner-calendar-edit-btn"
                                        data-open-daily-editor="true"
                                        data-date="@day.Date.ToString("yyyy-MM-dd")">
                                <i class="fas fa-pen me-1"></i>Günü düzenle
                                </button>
                            </div>
                        }
                    </article>
                }
            </div>
            </div>
        }
            </div>
        </div>
    </div>
</div>

@if (Model.SelectedRoomId.HasValue)
{
    <div class="partner-daily-editor-backdrop" id="partnerDailyEditorBackdrop" hidden></div>
    <section class="partner-daily-editor-modal" id="partnerDailyEditorModal" hidden aria-hidden="true">
        <div class="card">
            <div class="card-header">
                <div>
                    <div class="text-muted small">Günlük fiyat düzenleme</div>
                    <h3 class="card-title" id="partnerDailyEditorTitle">Seçili günü düzenle</h3>
                    <div class="text-muted">@Model.Rooms.FirstOrDefault(x => x.RoomId == Model.SelectedRoomId)?.RoomName</div>
                </div>
                <div class="card-actions">
                    <button type="button" class="btn btn-icon btn-outline-primary" id="partnerDailyEditorClose" aria-label="Kapat">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

        <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="card-body">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="RoomId" value="@Model.SelectedRoomId" />
            <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
            <input type="hidden" name="Date" id="dailyEditorDateInput" value="@Model.DailyForm.Date.ToString("yyyy-MM-dd")" />

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Tarih</label>
                    <input class="form-control" type="text" id="dailyEditorDateDisplay" value="@Model.DailyForm.Date.ToString("dd.MM.yyyy")" readonly />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Normal fiyat (vergi dahil)</label>
                    <input class="form-control" type="number" step="0.01" name="BasePrice" id="dailyEditorBasePrice" value="@(Model.DailyForm.BasePrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" title="KDV ve konaklama vergisi dahil gece tutarı" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">İndirimli fiyat (vergi dahil)</label>
                    <input class="form-control" type="number" step="0.01" name="DiscountPrice" id="dailyEditorDiscountPrice" value="@(Model.DailyForm.DiscountPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" title="KDV ve konaklama vergisi dahil" />
                </div>
                <div class="col-12">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="ClearDiscountPrice" value="true" id="dailyEditorClearDiscount" />
                        <span class="form-check-label">İndirimli fiyatı temizle</span>
                    </label>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Satışa açık oda</label>
                    <input class="form-control" type="number" name="TotalRooms" min="0" id="dailyEditorTotalRooms" value="@(Model.DailyForm.TotalRooms?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Minimum geceleme</label>
                    <input class="form-control" type="number" name="MinStay" min="1" id="dailyEditorMinStay" value="@(Model.DailyForm.MinStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Maksimum geceleme</label>
                    <input class="form-control" type="number" name="MaxStay" min="1" id="dailyEditorMaxStay" value="@(Model.DailyForm.MaxStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Satış durumu</label>
                    <select class="form-select" name="SaleStatusAction" id="dailyEditorSaleStatus">
                        <option value="keep">Mevcut durum korunsun</option>
                        <option value="open">Satışa aç</option>
                        <option value="close">Satışa kapat</option>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">İndirim seçimi</label>
                    <select class="form-select" name="DiscountId" id="dailyEditorDiscountId">
                        <option value="">İndirim uygulanmayacak</option>
                        @foreach (var discount in Model.AvailableDiscounts)
                        {
                            <option value="@discount.DiscountId">@discount.DiscountName</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Takvim notu</label>
                    <textarea class="form-control" name="PriceNote" id="dailyEditorPriceNote" rows="4" placeholder="Bu gün için not ekleyin.">@Model.DailyForm.PriceNote</textarea>
                </div>
            </div>
            <div class="mt-3 d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-primary" id="partnerDailyEditorCloseAlt">Vazgeç</button>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-floppy-disk me-2"></i>Günü Kaydet
                </button>
            </div>
        </form>
        </div>
    </section>

    <script nonce="@nonce">
        (function () {
            const modal = document.getElementById('partnerDailyEditorModal');
            const backdrop = document.getElementById('partnerDailyEditorBackdrop');
            const closeButton = document.getElementById('partnerDailyEditorClose');
            const closeButtonAlt = document.getElementById('partnerDailyEditorCloseAlt');
            const title = document.getElementById('partnerDailyEditorTitle');
            const dateInput = document.getElementById('dailyEditorDateInput');
            const dateDisplay = document.getElementById('dailyEditorDateDisplay');
            const basePriceInput = document.getElementById('dailyEditorBasePrice');
            const discountPriceInput = document.getElementById('dailyEditorDiscountPrice');
            const clearDiscountInput = document.getElementById('dailyEditorClearDiscount');
            const totalRoomsInput = document.getElementById('dailyEditorTotalRooms');
            const minStayInput = document.getElementById('dailyEditorMinStay');
            const maxStayInput = document.getElementById('dailyEditorMaxStay');
            const saleStatusSelect = document.getElementById('dailyEditorSaleStatus');
            const campaignSelect = document.getElementById('dailyEditorDiscountId');
            const priceNoteInput = document.getElementById('dailyEditorPriceNote');

            if (!modal || !backdrop) {
                return;
            }

            const culture = new Intl.DateTimeFormat('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });

            function openEditor(cell) {
                const date = cell.dataset.date || '';
                const dateValue = date ? new Date(date + 'T00:00:00') : null;
                dateInput.value = date;
                dateDisplay.value = dateValue ? culture.format(dateValue) : '';
                title.textContent = (dateValue ? culture.format(dateValue) : 'Secili gun') + ' gununu duzenle';
                basePriceInput.value = cell.dataset.basePrice || '';
                discountPriceInput.value = cell.dataset.discountPrice || '';
                clearDiscountInput.checked = false;
                totalRoomsInput.value = cell.dataset.totalRooms || '';
                minStayInput.value = cell.dataset.minStay || '';
                maxStayInput.value = cell.dataset.maxStay || '';
                saleStatusSelect.value = cell.dataset.isClosed === 'true' ? 'close' : 'open';
                const selectedId = cell.dataset.discountId || '';
                if (campaignSelect) {
                    campaignSelect.value = '';
                }
                if (selectedId && campaignSelect && campaignSelect.querySelector('option[value="' + selectedId + '"]')) {
                    campaignSelect.value = selectedId;
                }
                priceNoteInput.value = cell.dataset.priceNote || '';
                modal.hidden = false;
                backdrop.hidden = false;
                requestAnimationFrame(function () {
                    modal.classList.add('is-open');
                    backdrop.classList.add('is-open');
                    modal.setAttribute('aria-hidden', 'false');
                });
                document.body.style.overflow = 'hidden';
            }

            function closeEditor() {
                modal.classList.remove('is-open');
                backdrop.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
                window.setTimeout(function () {
                    modal.hidden = true;
                    backdrop.hidden = true;
                    document.body.style.overflow = '';
                }, 180);
            }

            document.querySelectorAll('[data-open-daily-editor="true"]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const cell = button.closest('.partner-calendar-cell');
                    if (!cell) {
                        return;
                    }

                    openEditor(cell);
                });
            });

            closeButton?.addEventListener('click', closeEditor);
            closeButtonAlt?.addEventListener('click', closeEditor);
            backdrop.addEventListener('click', closeEditor);
            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && modal.classList.contains('is-open')) {
                    closeEditor();
                }
            });

            // Bulk form: indirimli fiyat -> indirim seçimi zorunlu.
            const bulkDiscountPrice = document.getElementById('partnerBulkDiscountPrice');
            const bulkDiscountId = document.getElementById('partnerBulkDiscountId');
            const bulkClear = document.getElementById('partnerBulkClearDiscount');
            const bulkHint = document.getElementById('partnerBulkDiscountHint');

            function bulkSyncDiscountRequired() {
                if (!bulkDiscountPrice || !bulkDiscountId || !bulkClear) return;
                const hasDiscountPrice = String(bulkDiscountPrice.value || '').trim().length > 0 && Number(bulkDiscountPrice.value) > 0;
                const clearing = !!bulkClear.checked;
                const hasDiscount = String(bulkDiscountId.value || '').trim().length > 0;
                const required = hasDiscountPrice && !clearing && !hasDiscount;
                bulkDiscountId.required = required;
                if (bulkHint) bulkHint.style.display = required ? 'block' : 'none';
            }
            bulkDiscountPrice?.addEventListener('input', bulkSyncDiscountRequired);
            bulkClear?.addEventListener('change', bulkSyncDiscountRequired);
            bulkDiscountId?.addEventListener('change', bulkSyncDiscountRequired);
            bulkSyncDiscountRequired();

            document.getElementById('partnerBulkPricingForm')?.addEventListener('submit', function (event) {
                const hasDiscountPrice = String(bulkDiscountPrice?.value || '').trim().length > 0 && Number(bulkDiscountPrice.value) > 0;
                const clearing = !!bulkClear?.checked;
                const hasDiscount = String(bulkDiscountId?.value || '').trim().length > 0;
                if (hasDiscountPrice && !clearing && !hasDiscount) {
                    event.preventDefault();
                    if (bulkHint) {
                        bulkHint.style.display = 'block';
                    }
                    bulkDiscountId?.focus();
                }
            });

            // Daily editor: indirimli fiyat -> indirim seçimi zorunlu.
            function dailySyncDiscountRequired() {
                const hasDiscount = String(discountPriceInput?.value || '').trim().length > 0 && Number(discountPriceInput.value) > 0;
                const clearing = !!clearDiscountInput?.checked;
                const selectedDiscount = String(campaignSelect?.value || '').trim().length > 0;
                const required = hasDiscount && !clearing && !selectedDiscount;
                if (campaignSelect) campaignSelect.required = required;
            }
            discountPriceInput?.addEventListener('input', dailySyncDiscountRequired);
            clearDiscountInput?.addEventListener('change', dailySyncDiscountRequired);
            campaignSelect?.addEventListener('change', dailySyncDiscountRequired);
            dailySyncDiscountRequired();
        })();
    </script>
}
