@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerPricingPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    var weekdays = new[] { "Pzt", "Sal", "Çar", "Per", "Cum", "Cmt", "Paz" };
    var hotelQuery = $"otelId={Model.SelectedHotelId}";
    var roomQuery = Model.SelectedRoomId.HasValue ? $"&roomId={Model.SelectedRoomId.Value}" : string.Empty;
}

<section class="partner-pricing-toolbar">
    <div>
        <p class="partner-room-kicker">Gelişmiş fiyat yönetimi</p>
        <h2>Takvim üzerinden fiyat, kampanya ve satış durumu yönetin</h2>
        <p>Oda seçin, ayı değiştirin ve seçili tarih aralığında birden fazla oda tipi için tek seferde güncelleme yapın.</p>
    </div>
    <div class="partner-pricing-month-nav">
        <a class="partner-secondary-btn ot-btn ot-btn--ghost" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.PreviousMonthKey">
            <i class="fas fa-chevron-left"></i>
            Önceki ay
        </a>
        <div class="partner-pricing-month-pill ot-badge ot-badge--info">@Model.MonthLabel</div>
        <a class="partner-secondary-btn ot-btn ot-btn--ghost" href="/panel/partner/takvim-fiyatlar?@hotelQuery@roomQuery&month=@Model.NextMonthKey">
            Sonraki ay
            <i class="fas fa-chevron-right"></i>
        </a>
        <form method="get" action="/panel/partner/takvim-fiyatlar" class="partner-month-picker-form">
            <input type="hidden" name="otelId" value="@Model.SelectedHotelId" />
            @if (Model.SelectedRoomId.HasValue)
            {
                <input type="hidden" name="roomId" value="@Model.SelectedRoomId" />
            }
            <label for="partnerMonthPicker">Ayı seç</label>
            <select id="partnerMonthPicker" name="month" onchange="this.form.submit()">
                @foreach (var monthOption in Model.MonthOptions)
                {
                    <option value="@monthOption.MonthKey" selected="@(monthOption.IsCurrent ? "selected" : null)">@monthOption.Label</option>
                }
            </select>
        </form>
    </div>
</section>

<section class="partner-grid partner-pricing-summary-grid">
    @foreach (var item in Model.SummaryCards)
    {
        <article class="partner-stat-card partner-pricing-stat @item.ToneClass">
            <i class="fas @item.IconClass"></i>
            <strong>@item.Value</strong>
            <span>@item.Label</span>
            <p>@item.Description</p>
        </article>
    }
</section>

<section class="partner-section-card partner-pricing-room-filter ot-card">
    <div class="partner-section-head">
        <div>
            <h2>Görüntülenen oda tipi</h2>
            <p>Takvim gridi tek odanın detayını gösterir; toplu güncelleme alttaki seçim listesiyle birden fazla odaya uygulanabilir.</p>
        </div>
    </div>
    <div class="partner-room-chip-list">
        @foreach (var room in Model.Rooms)
        {
            <a href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@room.RoomId&month=@Model.MonthKey"
               class="partner-room-chip @(room.RoomId == Model.SelectedRoomId ? "active" : string.Empty) ot-card">
                <span class="partner-room-chip-title">@room.RoomName</span>
                <span class="partner-room-chip-meta">@room.BasePriceText · @room.StockText</span>
            </a>
        }
    </div>
</section>

<section class="partner-pricing-layout">
    <article class="partner-section-card partner-calendar-panel ot-card">
        <div class="partner-section-head partner-calendar-head">
            <div>
                <h2>Aylık fiyat takvimi</h2>
                <p>@(Model.SelectedRoomId.HasValue ? Model.Rooms.FirstOrDefault(x => x.RoomId == Model.SelectedRoomId.Value)?.RoomName : "Oda seçiniz")</p>
            </div>
            <div class="partner-calendar-legend">
                <span class="ot-badge"><i class="fas fa-circle legend-discount"></i> Kampanyalı</span>
                <span class="ot-badge"><i class="fas fa-circle legend-warning"></i> Son odalar</span>
                <span class="ot-badge ot-badge--danger"><i class="fas fa-circle legend-closed"></i> Satışa kapalı</span>
            </div>
        </div>
        <div class="partner-calendar-insight">
            <i class="fas fa-circle-info"></i>
            <p>Anasayfa, favoriler ve detay fiyatları bu takvimdeki açık satış günlerinin en düşük efektif fiyatına göre hesaplanır (kampanyalı fiyat varsa önce o kullanılır).</p>
        </div>

        @if (Model.CalendarDays.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Takvim verisi hazır değil</strong>
                <p>Bu otel için önce oda tipi seçin veya aktif oda tipleri tanımlayın.</p>
            </div>
        }
        else
        {
            <div class="partner-calendar-weekdays">
                @foreach (var day in weekdays)
                {
                    <div>@day</div>
                }
            </div>
            <div class="partner-calendar-month-grid">
                @foreach (var day in Model.CalendarDays)
                {
                    <article class="partner-calendar-cell @(day.IsCurrentMonth ? string.Empty : "is-other-month") @(day.IsToday ? "is-today" : string.Empty) @(day.IsHighlighted ? "is-highlighted" : string.Empty) @(day.IsClosed ? "is-closed" : string.Empty)"
                             data-date="@day.Date.ToString("yyyy-MM-dd")"
                             data-base-price="@day.BasePriceAmount.ToString(CultureInfo.InvariantCulture)"
                             data-discount-price="@(day.DiscountPriceAmount?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                             data-total-rooms="@day.TotalRooms"
                             data-min-stay="@day.MinStay"
                             data-max-stay="@day.MaxStay"
                             data-is-closed="@(day.IsClosed ? "true" : "false")"
                             data-discount-id="@(day.CampaignId?.ToString() ?? string.Empty)"
                             data-price-note="@day.PriceNote">
                        <div class="partner-calendar-cell-head">
                            <div>
                                <strong>@day.Date.ToString("dd-MM-yyyy")</strong>
                                <span>@day.WeekdayLabel</span>
                            </div>
                            <b class="partner-calendar-status ot-badge">@day.StatusText</b>
                        </div>
                        <div class="partner-calendar-price-block">
                            @if (day.HasDiscount)
                            {
                                <small>@day.BasePriceText</small>
                                <strong>@day.DiscountPriceText</strong>
                            }
                            else
                            {
                                <strong>@day.PriceText</strong>
                            }
                        </div>
                        <div class="partner-calendar-meta">
                            <span>@day.AvailabilityText</span>
                            <span>@day.SoldText</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(day.CampaignLabel))
                        {
                            <span class="partner-calendar-tag ot-badge ot-badge--info">@day.CampaignLabel</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(day.PriceNote))
                        {
                            <p class="partner-calendar-note">@day.PriceNote</p>
                        }
                        @if (Model.SelectedRoomId.HasValue && day.IsCurrentMonth)
                        {
                            <div class="partner-calendar-actions">
                                <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="partner-calendar-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="RoomId" value="@Model.SelectedRoomId.Value" />
                                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
                                    <input type="hidden" name="Date" value="@day.Date.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="SaleStatusAction" value="open" />
                                    <button type="submit" class="partner-calendar-inline-btn is-open ot-btn ot-btn--success">
                                        <i class="fas fa-lock-open"></i> Satisa Ac
                                    </button>
                                </form>
                                <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="partner-calendar-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="RoomId" value="@Model.SelectedRoomId.Value" />
                                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
                                    <input type="hidden" name="Date" value="@day.Date.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="SaleStatusAction" value="close" />
                                    <button type="submit" class="partner-calendar-inline-btn is-close ot-btn ot-btn--danger">
                                        <i class="fas fa-lock"></i> Satisa Kapat
                                    </button>
                                </form>
                                <button type="button" class="partner-calendar-edit-btn ot-btn ot-btn--ghost"
                                        data-open-daily-editor="true"
                                        data-date="@day.Date.ToString("yyyy-MM-dd")">
                                    <i class="fas fa-pen"></i>
                                    Gunu Duzenle
                                </button>
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </article>

    <aside class="partner-section-card partner-bulk-panel ot-card">
        <div class="partner-section-head">
            <div>
                <h2>Çoklu fiyat güncelleme</h2>
                <p>Secili tarih araliginda bir veya birden fazla oda tipine ayni anda fiyat, kampanya ve stok kurali uygulayin.</p>
            </div>
        </div>

        <form method="post" action="/panel/partner/takvim-fiyatlar/toplu-guncelle" class="partner-pricing-form-grid" id="partnerBulkPricingForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="ViewRoomId" value="@Model.SelectedRoomId" />
            <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />

            <div class="partner-multi-room-box">
                <span class="partner-field-label">Guncelleme uygulanacak odalar</span>
                <div class="partner-room-checkbox-list">
                    @foreach (var room in Model.Rooms.Where(x => x.IsActive))
                    {
                        var isChecked = Model.BulkForm.SelectedRoomIds.Contains(room.RoomId);
                        <label class="partner-room-checkbox @(room.RoomId == Model.SelectedRoomId ? "is-focused" : string.Empty)">
                            <input type="checkbox" name="SelectedRoomIds" value="@room.RoomId" checked="@(isChecked ? "checked" : null)" />
                            <span>
                                <strong>@room.RoomName</strong>
                                <small>@room.BasePriceText · @room.StockText</small>
                            </span>
                        </label>
                    }
                </div>
            </div>

            <label>
                <span>Tarih baslangici</span>
                <input type="date" name="DateFrom" value="@Model.BulkForm.DateFrom.ToString("yyyy-MM-dd")" />
            </label>
            <label>
                <span>Tarih bitisi</span>
                <input type="date" name="DateTo" value="@Model.BulkForm.DateTo.ToString("yyyy-MM-dd")" />
            </label>
            <label>
                <span>Normal fiyat (vergi dahil)</span>
                <input type="number" step="0.01" name="BasePrice" value="@(Model.BulkForm.BasePrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Bos birak: mevcut fiyat kalsin" title="KDV ve konaklama vergisi dahil gece tutari" inputmode="decimal" />
            </label>
            <label>
                <span>Kampanyali fiyat (vergi dahil)</span>
                <input type="number" step="0.01" name="DiscountPrice" id="partnerBulkDiscountPrice" value="@(Model.BulkForm.DiscountPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Opsiyonel" title="KDV ve konaklama vergisi dahil" inputmode="decimal" />
            </label>
            <label class="partner-inline-toggle">
                <input type="checkbox" name="ClearDiscountPrice" value="true" id="partnerBulkClearDiscount" />
                <span>Kampanyali fiyati temizle</span>
            </label>
            <label>
                <span>Satisa acik oda</span>
                <input type="number" name="TotalRooms" min="0" value="@(Model.BulkForm.TotalRooms?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Stok korunacak" />
            </label>
            <label>
                <span>Minimum geceleme</span>
                <input type="number" name="MinStay" min="1" value="@(Model.BulkForm.MinStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Degistirme" />
            </label>
            <label>
                <span>Maksimum geceleme</span>
                <input type="number" name="MaxStay" min="1" value="@(Model.BulkForm.MaxStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Degistirme" />
            </label>
            <label>
                <span>Satis durumu</span>
                <select name="SaleStatusAction">
                    <option value="keep" selected>Mevcut durum korunsun</option>
                    <option value="open">Satisa ac</option>
                    <option value="close">Satisa kapat</option>
                </select>
            </label>
            <label>
                <span>İndirim seçimi</span>
                <select name="DiscountId" id="partnerBulkDiscountId">
                    <option value="">İndirim uygulanmayacak</option>
                    @foreach (var discount in Model.AvailableDiscounts)
                    {
                        <option value="@discount.DiscountId">@discount.DiscountName</option>
                    }
                </select>
                <small class="partner-field-hint" id="partnerBulkDiscountHint" style="display:none;">
                    İndirimli fiyat girdiyseniz indirim seçimi zorunludur.
                </small>
            </label>
            <label>
                <span>İndirim etiketi (opsiyonel)</span>
                <input type="text" name="CampaignLabel" maxlength="120" placeholder="Orn. Yaz Firsati" />
            </label>
            <label class="partner-form-span">
                <span>Takvim notu</span>
                <textarea name="PriceNote" placeholder="Orn. Bu tarihte kahvalti dahil fiyat uygulaniyor."></textarea>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span ot-btn ot-btn--primary">
                <i class="fas fa-floppy-disk"></i>
                Takvim ve fiyat kurallarini uygula
            </button>
        </form>
    </aside>
</section>

@if (Model.SelectedRoomId.HasValue)
{
    <div class="partner-daily-editor-backdrop" id="partnerDailyEditorBackdrop" hidden></div>
    <section class="partner-daily-editor-modal" id="partnerDailyEditorModal" hidden aria-hidden="true">
        <div class="partner-daily-editor-head">
            <div>
                <span class="partner-daily-editor-kicker">Gunluk fiyat duzenleme</span>
                <h3 id="partnerDailyEditorTitle">Secili gunu duzenle</h3>
                <p>@Model.Rooms.FirstOrDefault(x => x.RoomId == Model.SelectedRoomId)?.RoomName</p>
            </div>
            <button type="button" class="partner-daily-editor-close" id="partnerDailyEditorClose" aria-label="Kapat">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <form method="post" action="/panel/partner/takvim-fiyatlar/gun-guncelle" class="partner-daily-editor-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="RoomId" value="@Model.SelectedRoomId" />
            <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />
            <input type="hidden" name="Date" id="dailyEditorDateInput" value="@Model.DailyForm.Date.ToString("yyyy-MM-dd")" />

            <label>
                <span>Tarih</span>
                <input type="text" id="dailyEditorDateDisplay" value="@Model.DailyForm.Date.ToString("dd.MM.yyyy")" readonly />
            </label>
            <label>
                <span>Normal fiyat (vergi dahil)</span>
                <input type="number" step="0.01" name="BasePrice" id="dailyEditorBasePrice" value="@(Model.DailyForm.BasePrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" title="KDV ve konaklama vergisi dahil gece tutari" />
            </label>
            <label>
                <span>Kampanyali fiyat (vergi dahil)</span>
                <input type="number" step="0.01" name="DiscountPrice" id="dailyEditorDiscountPrice" value="@(Model.DailyForm.DiscountPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" title="KDV ve konaklama vergisi dahil" />
            </label>
            <label class="partner-inline-toggle">
                <input type="checkbox" name="ClearDiscountPrice" value="true" id="dailyEditorClearDiscount" />
                <span>Kampanyali fiyati temizle</span>
            </label>
            <label>
                <span>Satisa acik oda</span>
                <input type="number" name="TotalRooms" min="0" id="dailyEditorTotalRooms" value="@(Model.DailyForm.TotalRooms?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
            </label>
            <label>
                <span>Minimum geceleme</span>
                <input type="number" name="MinStay" min="1" id="dailyEditorMinStay" value="@(Model.DailyForm.MinStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
            </label>
            <label>
                <span>Maksimum geceleme</span>
                <input type="number" name="MaxStay" min="1" id="dailyEditorMaxStay" value="@(Model.DailyForm.MaxStay?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
            </label>
            <label>
                <span>Satis durumu</span>
                <select name="SaleStatusAction" id="dailyEditorSaleStatus">
                    <option value="keep">Mevcut durum korunsun</option>
                    <option value="open">Satisa ac</option>
                    <option value="close">Satisa kapat</option>
                </select>
            </label>
            <label>
                <span>İndirim seçimi</span>
                <select name="DiscountId" id="dailyEditorDiscountId">
                    <option value="">İndirim uygulanmayacak</option>
                    @foreach (var discount in Model.AvailableDiscounts)
                    {
                        <option value="@discount.DiscountId">@discount.DiscountName</option>
                    }
                </select>
            </label>
            <label class="partner-form-span">
                <span>Takvim notu</span>
                <textarea name="PriceNote" id="dailyEditorPriceNote" placeholder="Bu gun icin not ekleyin.">@Model.DailyForm.PriceNote</textarea>
            </label>
            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-floppy-disk"></i>
                Gunu Kaydet
            </button>
        </form>
    </section>

    <script>
        (function () {
            const modal = document.getElementById('partnerDailyEditorModal');
            const backdrop = document.getElementById('partnerDailyEditorBackdrop');
            const closeButton = document.getElementById('partnerDailyEditorClose');
            const title = document.getElementById('partnerDailyEditorTitle');
            const dateInput = document.getElementById('dailyEditorDateInput');
            const dateDisplay = document.getElementById('dailyEditorDateDisplay');
            const basePriceInput = document.getElementById('dailyEditorBasePrice');
            const discountPriceInput = document.getElementById('dailyEditorDiscountPrice');
            const clearDiscountInput = document.getElementById('dailyEditorClearDiscount');
            const totalRoomsInput = document.getElementById('dailyEditorTotalRooms');
            const minStayInput = document.getElementById('dailyEditorMinStay');
            const maxStayInput = document.getElementById('dailyEditorMaxStay');
            const saleStatusSelect = document.getElementById('dailyEditorSaleStatus');
            const campaignSelect = document.getElementById('dailyEditorDiscountId');
            const priceNoteInput = document.getElementById('dailyEditorPriceNote');

            if (!modal || !backdrop) {
                return;
            }

            const culture = new Intl.DateTimeFormat('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });

            function openEditor(cell) {
                const date = cell.dataset.date || '';
                const dateValue = date ? new Date(date + 'T00:00:00') : null;
                dateInput.value = date;
                dateDisplay.value = dateValue ? culture.format(dateValue) : '';
                title.textContent = (dateValue ? culture.format(dateValue) : 'Secili gun') + ' gununu duzenle';
                basePriceInput.value = cell.dataset.basePrice || '';
                discountPriceInput.value = cell.dataset.discountPrice || '';
                clearDiscountInput.checked = false;
                totalRoomsInput.value = cell.dataset.totalRooms || '';
                minStayInput.value = cell.dataset.minStay || '';
                maxStayInput.value = cell.dataset.maxStay || '';
                saleStatusSelect.value = cell.dataset.isClosed === 'true' ? 'close' : 'open';
                campaignSelect.value = cell.dataset.discountId || '';
                priceNoteInput.value = cell.dataset.priceNote || '';
                modal.hidden = false;
                backdrop.hidden = false;
                requestAnimationFrame(function () {
                    modal.classList.add('is-open');
                    backdrop.classList.add('is-open');
                    modal.setAttribute('aria-hidden', 'false');
                });
                document.body.style.overflow = 'hidden';
            }

            function closeEditor() {
                modal.classList.remove('is-open');
                backdrop.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
                window.setTimeout(function () {
                    modal.hidden = true;
                    backdrop.hidden = true;
                    document.body.style.overflow = '';
                }, 180);
            }

            document.querySelectorAll('[data-open-daily-editor="true"]').forEach(function (button) {
                button.addEventListener('click', function () {
                    const cell = button.closest('.partner-calendar-cell');
                    if (!cell) {
                        return;
                    }

                    openEditor(cell);
                });
            });

            closeButton?.addEventListener('click', closeEditor);
            backdrop.addEventListener('click', closeEditor);
            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && modal.classList.contains('is-open')) {
                    closeEditor();
                }
            });

            // Bulk form: indirimli fiyat -> indirim seçimi zorunlu.
            const bulkDiscountPrice = document.getElementById('partnerBulkDiscountPrice');
            const bulkDiscountId = document.getElementById('partnerBulkDiscountId');
            const bulkClear = document.getElementById('partnerBulkClearDiscount');
            const bulkHint = document.getElementById('partnerBulkDiscountHint');

            function bulkSyncDiscountRequired() {
                if (!bulkDiscountPrice || !bulkDiscountId || !bulkClear) return;
                const hasDiscountPrice = String(bulkDiscountPrice.value || '').trim().length > 0 && Number(bulkDiscountPrice.value) > 0;
                const clearing = !!bulkClear.checked;
                const required = hasDiscountPrice && !clearing;
                bulkDiscountId.required = required;
                if (bulkHint) bulkHint.style.display = required ? 'block' : 'none';
            }
            bulkDiscountPrice?.addEventListener('input', bulkSyncDiscountRequired);
            bulkClear?.addEventListener('change', bulkSyncDiscountRequired);
            bulkSyncDiscountRequired();

            // Daily editor: indirimli fiyat -> indirim seçimi zorunlu.
            function dailySyncDiscountRequired() {
                const hasDiscount = String(discountPriceInput?.value || '').trim().length > 0 && Number(discountPriceInput.value) > 0;
                const clearing = !!clearDiscountInput?.checked;
                if (campaignSelect) campaignSelect.required = hasDiscount && !clearing;
            }
            discountPriceInput?.addEventListener('input', dailySyncDiscountRequired);
            clearDiscountInput?.addEventListener('change', dailySyncDiscountRequired);
            dailySyncDiscountRequired();
        })();
    </script>
}
