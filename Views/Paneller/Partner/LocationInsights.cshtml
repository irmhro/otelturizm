@model otelturizmnew.Models.Paneller.Partner.PartnerLocationInsightsPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
}

<section class="partner-growth-hero">
    <div>
        <p class="partner-room-kicker">Konum analizi</p>
        <h2>Misafir şehir ve bölge dağılımı</h2>
        <p>@Model.InfoNote</p>
    </div>
    <div class="partner-chip ot-badge ot-badge--info">Tesis: <strong>@Model.HotelLocationLabel</strong></div>
</section>

<section class="partner-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="partner-stat-card @card.ToneClass">
            <i class="fas @card.IconClass"></i>
            <strong>@card.Value</strong>
            <span>@card.Label</span>
            <p>@card.Description</p>
        </article>
    }
</section>

<section class="partner-two-column partner-growth-layout">
    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Şehir dağılımı</h2>
                <p>Son 12 ay rezervasyonlarındaki misafir şehir bilgisi (iptal ve red hariç).</p>
            </div>
        </div>
        @if (Model.GuestCityRows.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Henüz şehir dağılımı oluşmadı</strong>
                <p>Rezervasyonlarda misafir şehir alanı doldukça tablo otomatik dolacak.</p>
            </div>
        }
        else
        {
            <div class="partner-table-wrap">
                <table class="partner-table">
                    <thead>
                        <tr>
                            <th>Şehir</th>
                            <th>Rezervasyon</th>
                            <th>Pay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.GuestCityRows)
                        {
                            <tr>
                                <td><strong>@row.CityLabel</strong></td>
                                <td>@row.ReservationCount</td>
                                <td>%@row.SharePercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Ülke dağılımı</h2>
                <p>Rezervasyondaki misafir ülke alanına göre özet.</p>
            </div>
        </div>
        @if (Model.GuestCountryRows.Count == 0)
        {
            <div class="partner-empty-state">
                <strong>Ülke verisi yok</strong>
                <p>misafir_ulke alanı boş veya girilmemiş olabilir.</p>
            </div>
        }
        else
        {
            <div class="partner-table-wrap">
                <table class="partner-table">
                    <thead>
                        <tr>
                            <th>Ülke</th>
                            <th>Rezervasyon</th>
                            <th>Pay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.GuestCountryRows)
                        {
                            <tr>
                                <td><strong>@row.CountryLabel</strong></td>
                                <td>@row.ReservationCount</td>
                                <td>%@row.SharePercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>

<section class="partner-section-card">
    <div class="partner-section-head">
        <div>
            <h2>Günlük istatistik özeti</h2>
            <p><code>otel_istatistikleri</code> tablosundan son kayıtlar (varsa).</p>
        </div>
    </div>
    @if (Model.DailyStatRows.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Günlük istatistik kaydı yok</strong>
            <p>Batch veya rapor işleri otel istatistikleri ürettiğinde bu tablo dolacak.</p>
        </div>
    }
    else
    {
        <div class="partner-table-wrap">
            <table class="partner-table">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Rezervasyon</th>
                        <th>Doluluk %</th>
                        <th>Net gelir</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.DailyStatRows)
                    {
                        <tr>
                            <td>@row.DateText</td>
                            <td>@row.Reservations</td>
                            <td>@(row.OccupancyPercent.HasValue ? row.OccupancyPercent.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "—")</td>
                            <td>@(row.NetRevenue.HasValue ? row.NetRevenue.Value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")) + " ₺" : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
