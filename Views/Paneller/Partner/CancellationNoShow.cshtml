@model otelturizmnew.Models.Paneller.Partner.PartnerCancellationNoShowPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/reservations";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Rezervasyon yönetimi</div>
            <h2 class="page-title">İptal & No-show</h2>
            <div class="text-muted mt-1">Politikaları görüntüleyin ve son 30 gün iptal/red özetini takip edin.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <a class="btn btn-outline-primary" href="/panel/partner/tesis/kosullar?otelId=@Model.SelectedHotelId">
                <i class="fas fa-pen-to-square me-2"></i>Politikayı düzenle
            </a>
        </div>
    </div>
</div>

<div class="row row-cards">
    <div class="col-12 col-xl-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Politika özeti</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="text-muted small">İptal politikası (özet)</div>
                    <div class="fw-bold">@(!string.IsNullOrWhiteSpace(Model.CancellationSummary) ? Model.CancellationSummary : "Henüz girilmedi.")</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Detaylı iptal koşulları</div>
                    <div style="white-space:pre-wrap;">@(!string.IsNullOrWhiteSpace(Model.CancellationDetails) ? Model.CancellationDetails : "Henüz girilmedi.")</div>
                </div>
                <div class="row g-2">
                    <div class="col-12 col-md-4">
                        <div class="border rounded-3 p-3">
                            <div class="text-muted small">Ücretsiz iptal (gün)</div>
                            <div class="fw-bold">@((Model.FreeCancellationDays?.ToString() ?? "-"))</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="border rounded-3 p-3">
                            <div class="text-muted small">Geç iptal cezası (%)</div>
                            <div class="fw-bold">@((Model.LateCancellationPenaltyPercent?.ToString("0.##") ?? "-"))</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="border rounded-3 p-3">
                            <div class="text-muted small">No-show cezası (%)</div>
                            <div class="fw-bold">@((Model.NoShowPenaltyPercent?.ToString("0.##") ?? "-"))</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title mb-0">Son 30 gün özeti</h3>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="border rounded-3 p-3">
                            <div class="text-muted small">İptal</div>
                            <div class="fw-bold">@Model.CancelCountLast30Days</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded-3 p-3">
                            <div class="text-muted small">Red</div>
                            <div class="fw-bold">@Model.RejectCountLast30Days</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">İptal nedenleri (son 30 gün)</h3>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.TopCancellationReasons.Count == 0)
                {
                    <div class="p-3 text-muted">İptal verisi yok.</div>
                }
                else
                {
                    @foreach (var row in Model.TopCancellationReasons)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between gap-2">
                                <div class="min-w-0 text-truncate">@row.Reason</div>
                                <span class="badge bg-danger-lt text-danger">@row.Count</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

