@model otelturizmnew.Models.Paneller.Partner.PartnerFinancePageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/finance";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Finans</div>
            <h2 class="page-title">Mutabakat</h2>
            <div class="text-muted mt-1">Tahsilat, komisyon ve net ödeme akışını özetleyip dönemsel kontrol edin.</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <a class="btn btn-outline-primary" href="/panel/partner/finans/disa-aktar?otelId=@Model.Shell.SelectedHotelId">
                <i class="fas fa-file-export me-2"></i>Dışa aktar
            </a>
        </div>
    </div>
</div>

<div class="row row-cards mb-3">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">@card.Label</div>
                    <div class="h2 mb-0">@card.Value</div>
                    <div class="text-muted small mt-1">@card.Description</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Son hareketler (mutabakat akışı)</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>Kayıt</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>Tutar</th>
                    <th>Detay</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Transactions.Count == 0)
                {
                    <tr><td colspan="5" class="text-muted p-3">Hareket bulunamadı.</td></tr>
                }
                else
                {
                    @foreach (var item in Model.Transactions)
                    {
                        <tr>
                            <td>@item.Label</td>
                            <td class="text-muted">@item.DateText</td>
                            <td>@item.StatusText</td>
                            <td class="fw-bold">@item.AmountText</td>
                            <td class="text-muted">@item.DetailText</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

