@model otelturizmnew.Models.Paneller.Satis.SalesPanelShellViewModel
<nav class="sales-mobile-nav">
    <a class="@(Model.ActiveSectionKey == "dashboard" ? "active" : string.Empty)" href="/panel/satis/dashboard"><i class="fas fa-chart-pie"></i><span>Panel</span></a>
    <a class="@(Model.ActiveSectionKey == "create" ? "active" : string.Empty)" href="/panel/satis/yeni-rezervasyon"><i class="fas fa-plus-circle"></i><span>Rezervasyon</span></a>
    <a class="@(Model.ActiveSectionKey == "customers" ? "active" : string.Empty)" href="/panel/satis/musteri-yonetimi"><i class="fas fa-users"></i><span>Müşteri</span></a>
    <a class="@(Model.ActiveSectionKey == "hotels" ? "active" : string.Empty)" href="/panel/satis/otel-rehberi"><i class="fas fa-hotel"></i><span>Oteller</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket"></i><span>Cikis</span></button>
    </form>
</nav>
