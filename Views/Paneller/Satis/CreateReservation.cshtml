@model otelturizmnew.Models.Paneller.Satis.SalesCreateReservationPageViewModel
@{
    Layout = "~/Views/Paneller/Satis/_SalesPanelLayout.cshtml";
    ViewData["SalesShell"] = Model.Shell;
}
<section class="sales-panel-card sales-search-card">
    <div class="sales-card-head sales-card-head-stack">
        <div>
            <h2>Otel Bulma Asistanı</h2>
            <span>Yazdıkça öner, tek tıkla seç, telefonu kapatmadan rezervasyonu tamamla.</span>
        </div>
        <div class="sales-inline-badges">
            <span class="sales-soft-pill"><i class="fas fa-magnifying-glass"></i> Canlı Öneri</span>
            <span class="sales-soft-pill"><i class="fas fa-location-dot"></i> İl / İlçe / Mahalle</span>
            <span class="sales-soft-pill"><i class="fas fa-turkish-lira-sign"></i> Fiyat Aralığı</span>
        </div>
    </div>
    <form method="get" class="sales-form-grid search-grid" data-sales-assistant-form>
        <input type="hidden" name="customerId" value="@Model.Form.CustomerId" />
        <div class="sales-assistant-search span-2">
            <input type="text" id="salesAssistantQuery" name="searchTerm" value="@Model.Form.SearchTerm" placeholder="Otel adı, semt veya telefonla gelen isteğe göre anahtar kelime girin" autocomplete="off" />
            <div class="sales-assistant-dropdown" id="salesAssistantDropdown" hidden></div>
        </div>
        <input type="text" name="city" value="@Model.Form.SearchCity" placeholder="İl" />
        <input type="text" name="district" value="@Model.Form.SearchDistrict" placeholder="İlçe" />
        <input type="text" name="neighborhood" value="@Model.Form.SearchNeighborhood" placeholder="Mahalle" />
        <input type="number" step="0.01" name="minPrice" value="@Model.Form.SearchMinPrice" placeholder="Min fiyat" />
        <input type="number" step="0.01" name="maxPrice" value="@Model.Form.SearchMaxPrice" placeholder="Max fiyat" />
        <input type="number" step="0.1" min="0" max="5" name="minimumRating" value="@Model.Form.SearchMinimumRating" placeholder="Min yıldız" />
        <input type="number" min="0" name="minimumReviewCount" value="@Model.Form.SearchMinimumReviewCount" placeholder="Min yorum" />
        <input type="text" name="feature" value="@Model.Form.SearchFeature" placeholder="Özellik" />
        <button type="submit">Filtrele</button>
    </form>
    <div class="sales-assistant-scenarios" data-sales-assistant-scenarios>
        <button type="button" class="sales-assistant-scenario" data-scenario="cheap">
            <i class="fas fa-tags"></i>
            <span>En ucuz 5</span>
        </button>
        <button type="button" class="sales-assistant-scenario" data-scenario="rating4">
            <i class="fas fa-star"></i>
            <span>4+ puan</span>
        </button>
        <button type="button" class="sales-assistant-scenario" data-scenario="center">
            <i class="fas fa-map-location-dot"></i>
            <span>Merkezde</span>
        </button>
        <button type="button" class="sales-assistant-scenario" data-scenario="reset">
            <i class="fas fa-rotate-left"></i>
            <span>Standart Liste</span>
        </button>
    </div>
    <p class="sales-muted-note sales-assistant-note">
        İpucu: Otel adının ilk 2-3 harfini yazmanız yeterli. Canlı öneriden seçince formda otel hızlıca aktif olur.
    </p>
    <div class="sales-hotel-search-results">
        @if (!Model.HasAssistantSearch)
        {
            <div class="sales-empty-state">
                <i class="fas fa-sliders"></i>
                <strong>Henüz arama yapılmadı</strong>
                <span>Otel adı, fiyat veya konum girerek satışa uygun otelleri listeleyin.</span>
            </div>
        }
        else if (!Model.HotelSearchResults.Any())
        {
            <div class="sales-empty-state">
                <i class="fas fa-hotel"></i>
                <strong>Filtreye uygun otel bulunamadı</strong>
                <span>Fiyat/konum filtrelerini biraz genişletip tekrar arayın.</span>
            </div>
        }
        else
        {
            @foreach (var hotel in Model.HotelSearchResults)
            {
                <article class="sales-hotel-card @(hotel.HotelId == Model.Form.HotelId ? "selected" : string.Empty)">
                    <div>
                        <strong>@hotel.HotelName</strong>
                        <p>@hotel.LocationText · @hotel.RatingText yıldız · @hotel.ReviewCountText</p>
                        <p>@hotel.Address</p>
                        <div class="sales-badges">
                            @foreach (var badge in hotel.FeatureBadges)
                            {
                                <span>@badge</span>
                            }
                        </div>
                    </div>
                    <div class="sales-hotel-card-side">
                        <span>@hotel.PriceText</span>
                        <small>@hotel.Phone</small>
                        <small>@hotel.TodayDemandText</small>
                        <a href="/panel/satis/yeni-rezervasyon?hotelId=@hotel.HotelId&customerId=@Model.Form.CustomerId&searchTerm=@Model.Form.SearchTerm&city=@Model.Form.SearchCity&district=@Model.Form.SearchDistrict&neighborhood=@Model.Form.SearchNeighborhood&feature=@Model.Form.SearchFeature&minimumRating=@Model.Form.SearchMinimumRating&minimumReviewCount=@Model.Form.SearchMinimumReviewCount&minPrice=@Model.Form.SearchMinPrice&maxPrice=@Model.Form.SearchMaxPrice">Bu oteli seç</a>
                    </div>
                </article>
            }
        }
    </div>
</section>
<section class="sales-grid cols-2">
    <article class="sales-panel-card">
        <div class="sales-card-head"><h2>Yeni Rezervasyon</h2><span>Müşteri ve oda bilgisi</span></div>
        @if (!string.IsNullOrWhiteSpace(Model.SelectedHotelSummary))
        {
            <div class="sales-selection-summary">
                <i class="fas fa-bolt"></i>
                <span>@Model.SelectedHotelSummary</span>
            </div>
        }
        <form method="post" action="/panel/satis/yeni-rezervasyon" class="sales-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.Form.HotelId" />
            <input type="hidden" name="CustomerId" value="@Model.Form.CustomerId" />
            <div>
                <label>Müşteri Ad Soyad</label>
                <input type="text" name="CustomerFullName" value="@Model.Form.CustomerFullName" required />
            </div>
            <div>
                <label>E-posta</label>
                <input type="email" name="CustomerEmail" value="@Model.Form.CustomerEmail" required />
            </div>
            <div>
                <label>Telefon</label>
                <input type="text" name="CustomerPhone" value="@Model.Form.CustomerPhone" required />
            </div>
            <div>
                <label>Şehir</label>
                <input type="text" name="CustomerCity" value="@Model.Form.CustomerCity" />
            </div>
            <div>
                <label>İlçe</label>
                <input type="text" name="CustomerDistrict" value="@Model.Form.CustomerDistrict" />
            </div>
            <div>
                <label>Mahalle</label>
                <input type="text" name="CustomerNeighborhood" value="@Model.Form.CustomerNeighborhood" />
            </div>
            <div class="span-2">
                <label>Açık Adres</label>
                <textarea name="CustomerAddress">@Model.Form.CustomerAddress</textarea>
            </div>
            <div>
                <label>Otel</label>
                <select name="HotelId">
                    @if (!Model.Hotels.Any())
                    {
                        <option value="0">Önce otel araması yapın</option>
                    }
                    @foreach (var hotel in Model.Hotels)
                    {
                        <option value="@hotel.Value" selected="@(hotel.Value == Model.Form.HotelId)">@hotel.Label</option>
                    }
                </select>
            </div>
            <div>
                <label>Oda Tipi</label>
                <select name="RoomTypeId">
                    @foreach (var room in Model.RoomTypes)
                    {
                        <option value="@room.Value" selected="@(room.Value == Model.Form.RoomTypeId)">@room.Label</option>
                    }
                </select>
            </div>
            <div>
                <label>Giriş</label>
                <input type="date" name="CheckInDate" value="@Model.Form.CheckInDate.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label>Çıkış</label>
                <input type="date" name="CheckOutDate" value="@Model.Form.CheckOutDate.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label>Yetişkin</label>
                <input type="number" name="AdultCount" value="@Model.Form.AdultCount" min="1" />
            </div>
            <div>
                <label>Çocuk</label>
                <input type="number" name="ChildCount" value="@Model.Form.ChildCount" min="0" />
            </div>
            <div>
                <label>Oda Sayısı</label>
                <input type="number" name="RoomCount" value="@Model.Form.RoomCount" min="1" />
            </div>
            <div class="span-2">
                <label>Müşteri Talep Notu</label>
                <textarea name="DemandNote">@Model.Form.DemandNote</textarea>
            </div>
            <div class="span-2 sales-form-actions">
                <button type="submit">Rezervasyonu Tamamla</button>
            </div>
        </form>
    </article>
    <article class="sales-panel-card">
        <div class="sales-card-head"><h2>Uygun Oda ve Fiyat Özeti</h2><span>Çağrı sırasında hızlı karar desteği</span></div>
        <div class="sales-room-list">
            @foreach (var room in Model.AvailableRooms)
            {
                <div class="sales-room-card @(room.RoomTypeId == Model.Form.RoomTypeId ? "selected" : string.Empty)">
                    <strong>@room.RoomName</strong>
                    <p>@room.CapacityText · @room.StockText</p>
                    <small>@room.FeaturesText</small>
                    <span>@room.PriceText</span>
                </div>
            }
        </div>
        <div class="sales-price-summary">
            <div><span>Oda toplamı</span><strong>@Model.Summary.BaseAmountText</strong></div>
            <div><span>Vergi</span><strong>@Model.Summary.TaxAmountText</strong></div>
            <div class="total"><span>Genel toplam</span><strong>@Model.Summary.TotalAmountText</strong></div>
        </div>
        @if (Model.Customers.Any())
        {
            <div class="sales-customer-shortcuts">
                <div class="sales-card-head"><h2>Tekrar Arayan Müşteriler</h2><span>Bir dokunuşla forma taşı</span></div>
                <div class="sales-mini-card-grid">
                    @foreach (var customer in Model.Customers)
                    {
                        <a class="sales-mini-customer-card" href="/panel/satis/yeni-rezervasyon?customerId=@customer.CustomerId&hotelId=@Model.Form.HotelId&roomTypeId=@Model.Form.RoomTypeId">
                            <strong>@customer.FullName</strong>
                            <span>@customer.Phone</span>
                            <small>@customer.ReservationCountText</small>
                        </a>
                    }
                </div>
            </div>
        }
    </article>
</section>
<script src="~/assets/js/paneller/satis/create-reservation.js" asp-append-version="true"></script>
