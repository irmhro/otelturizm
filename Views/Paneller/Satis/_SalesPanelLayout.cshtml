@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Satis
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@{
    Layout = null;
    var shell = ViewData["SalesShell"] as SalesPanelShellViewModel ?? Model as SalesPanelShellViewModel;
    var pageCssPath = ViewData["PageCssPath"] as string;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Satış Paneli";
    var salesUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var salesUserId = long.TryParse(salesUserRaw, out var parsedSalesUserId) ? parsedSalesUserId : 0;
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.Sales, salesUserId, Context.RequestAborted);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Otelturizm</title>
    
    
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-standards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/satis/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/satis/shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/developer-feedback.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body>
    <div class="sales-panel-shell">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Satis/_SalesSidebar.cshtml" model="shell" />
        }
        <main class="sales-panel-main">
            @if (shell is not null)
            {
                <header class="sales-page-header">
                    <div>
                        <p class="sales-kicker">SATIŞ PANELİ</p>
                        <h1>@shell.PanelTitle</h1>
                        <p class="sales-subtitle">@shell.PanelSubtitle</p>
                    </div>
                    <div class="sales-header-badges">
                        <span><i class="fas fa-check-circle"></i> @shell.TodayReservationCount bugün</span>
                        <span><i class="fas fa-money-bill-wave"></i> @shell.TodayRevenue.ToString("N0") TL</span>
                        <span><i class="fas fa-trophy"></i> @(shell.Ranking <= 0 ? "-" : $"#{shell.Ranking}") sıra</span>
                        <partial name="~/Views/Paneller/Common/_DeveloperFeedbackWidget.cshtml" />
                        <partial name="~/Views/Shared/_HeaderBildiri.cshtml" model="headerBildiri" />
                        <form method="post" action="/cikis-yap" class="panel-header-logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="panel-header-logout-btn">
                                <i class="fas fa-right-from-bracket"></i>
                                <span>Cikis Yap</span>
                            </button>
                        </form>
                    </div>
                </header>
                @if (!string.IsNullOrWhiteSpace(shell.SuccessMessage))
                {
                    <div class="sales-alert sales-alert-success"><i class="fas fa-circle-check"></i><span>@shell.SuccessMessage</span></div>
                }
                @if (!string.IsNullOrWhiteSpace(shell.ErrorMessage))
                {
                    <div class="sales-alert sales-alert-error"><i class="fas fa-triangle-exclamation"></i><span>@shell.ErrorMessage</span></div>
                }
            }
            <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
            @RenderBody()
            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Satis/_SalesPanelFooter.cshtml" model="shell" />
            }
        </main>
    </div>
    @if (shell is not null)
    {
        <partial name="~/Views/Paneller/Satis/_SalesMobileNav.cshtml" model="shell" />
    }
    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    <script src="~/assets/js/developer-feedback.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
</body>
</html>
