@model otelturizmnew.Models.Paneller.Satis.SalesCustomersPageViewModel
@{
    Layout = "~/Views/Paneller/Satis/_SalesPanelLayout.cshtml";
    ViewData["SalesShell"] = Model.Shell;
}
<section class="sales-grid cols-2 sales-customers-grid">
    <article class="sales-panel-card">
        <div class="sales-card-head sales-card-head-stack">
            <div>
                <h2>Müşteri Havuzu</h2>
                <span>Telefon, e-posta veya ad soyad ile müşteriyi bulun; tek tıkla yeni rezervasyona taşıyın.</span>
            </div>
        </div>
        <form method="get" class="sales-search-inline sales-search-inline-strong">
            <input type="text" name="search" value="@Model.Search" placeholder="Örn: 0555, ayşe yıldız, ayse@firma.com" />
            <button type="submit">Müşteriyi Bul</button>
        </form>
        <div class="sales-customer-list">
            @foreach (var item in Model.Customers)
            {
                <article class="sales-customer-card sales-customer-card-rich">
                    <div>
                        <strong>@item.FullName</strong>
                        <p>@item.Email · @item.Phone</p>
                        <small>@item.CustomerCode · @item.MembershipLevel</small>
                        <div class="sales-badges">
                            <span>@item.ReservationCountText</span>
                            <span>@item.TotalSpendText</span>
                            <span>@item.LocationText</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.LastRequestSummary))
                        {
                            <p class="sales-muted-note">@item.LastRequestSummary</p>
                        }
                    </div>
                    <div class="sales-hotel-card-side">
                        <span>Son işlem: @item.LastStayText</span>
                        <a href="/panel/satis/yeni-rezervasyon?customerId=@item.CustomerId">Bu müşteri ile rezervasyon aç</a>
                    </div>
                </article>
            }
        </div>
    </article>
    <article class="sales-panel-card">
        <div class="sales-card-head">
            <h2>Yeni Müşteri Ekle</h2>
            <span>Çağrı sırasında hızlı kayıt oluştur</span>
        </div>
        <form method="post" action="/panel/satis/musteri-yonetimi/yeni" class="sales-form-grid">
            @Html.AntiForgeryToken()
            <div><label>Ad Soyad</label><input type="text" name="FullName" required /></div>
            <div><label>E-posta</label><input type="email" name="Email" required /></div>
            <div><label>Telefon</label><input type="text" name="Phone" required /></div>
            <div><label>Şehir</label><input type="text" name="City" placeholder="Örn: İstanbul" /></div>
            <div>
                <label>Üyelik Seviyesi</label>
                <select name="MembershipLevel">
                    <option>Standart</option>
                    <option>Silver</option>
                    <option>Gold</option>
                    <option>Platinum</option>
                </select>
            </div>
            <div class="span-2"><label>Not</label><textarea name="Note" placeholder="Tercihleri, kurumsal bilgisi veya özel notlar"></textarea></div>
            <div class="span-2 sales-form-actions"><button type="submit">Müşteri Kaydet</button></div>
        </form>
    </article>
</section>
