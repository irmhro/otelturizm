@{
    Layout = "~/Views/Paneller/Satis/_SalesPanelLayout.cshtml";
    var reservationId = (long)(ViewData["ReservationId"] ?? 0L);
}

<section class="sales-panel-card ot-card">
    <div class="sales-card-head sales-card-head-stack">
        <div>
            <h2>Rezervasyon PDF Çıktısı</h2>
            <span>Bu sayfa e-posta olmayan misafirler için hızlı PDF üretir. İndirip WhatsApp / SMS / yazdırma ile iletebilirsiniz.</span>
        </div>
        <div class="sales-inline-badges">
            <span class="sales-soft-pill ot-badge ot-badge--info"><i class="fas fa-file-pdf"></i> PDFMake</span>
            <span class="sales-soft-pill ot-badge"><i class="fas fa-shield-halved"></i> Satış yetkisi</span>
        </div>
    </div>

    <div class="sales-pdf-actions">
        <button type="button" class="sales-primary-btn ot-btn ot-btn--primary" data-pdf-download>PDF indir</button>
        <button type="button" class="sales-secondary-btn ot-btn ot-btn--ghost" data-pdf-open>Yeni sekmede aç</button>
        <a class="sales-secondary-btn ot-btn ot-btn--ghost" href="/panel/satis/rezervasyonlarim">Rezervasyonlarım</a>
    </div>

    <div class="sales-pdf-status ot-badge ot-badge--warning" data-pdf-status>Hazırlanıyor...</div>
</section>

<script>
    window.__salesReservationPdfId = @reservationId;
</script>
<script src="~/vendor/AdminLTE-3.2.0/plugins/pdfmake/pdfmake.min.js"></script>
<script src="~/vendor/AdminLTE-3.2.0/plugins/pdfmake/vfs_fonts.js"></script>
<script src="~/assets/js/paneller/satis/reservation-pdf.js" asp-append-version="true"></script>

