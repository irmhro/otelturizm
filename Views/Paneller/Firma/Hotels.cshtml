@model otelturizmnew.Models.Paneller.Firma.FirmaHotelReportsPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/firma/hotels";
    ViewData["PageCssMobile"] = "paneller/firma/hotels.mobile";
}
<section class="firma-section-card">
    <h2>Otel Bazlı Firma Raporu</h2>
    <div class="firma-table-wrap">
        <table class="firma-table firma-table--cards">
            <thead><tr><th>Otel</th><th>Şehir</th><th>Rezervasyon</th><th>Toplam Tutar</th><th>Tasarruf</th></tr></thead>
            <tbody>
            @foreach (var item in Model.HotelReports)
            {
                <tr>
                    <td data-label="Otel">@item.HotelName</td>
                    <td data-label="Şehir">@item.CityText</td>
                    <td data-label="Rezervasyon">@item.ReservationCount</td>
                    <td data-label="Toplam">@item.GrossAmountText</td>
                    <td data-label="Tasarruf">@item.SavingsText</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
