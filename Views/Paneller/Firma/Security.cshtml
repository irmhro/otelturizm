@model otelturizmnew.Models.Paneller.User.UserSecurityPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
}

<section class="form-stack">
    <form method="post" action="/panel/firma/guvenlik/iki-asamali" class="panel-card">
        @Html.AntiForgeryToken()
        <div class="section-head"><h2>İki Aşamalı Doğrulama</h2></div>
        <label class="toggle-row no-border">
            <div><h3>Firma hesabı için 2FA</h3><p>Şifre sonrası ikinci güvenlik adımı zorunlu olsun.</p></div>
            <input name="Enabled" type="checkbox" value="true" @(Model.TwoFactorEnabled ? "checked" : null) />
        </label>
        <input name="Enabled" type="hidden" value="false" />
        <div class="form-grid" style="margin-top:18px;">
            <label class="full">
                <span>Doğrulama kanalı</span>
                <div class="radio-stack">
                    <label class="radio-option @(!Model.EmailUsableForTwoFactor ? "is-disabled" : string.Empty)">
                        <input type="radio" name="Channel" value="email" @(Model.SelectedTwoFactorChannel == "email" ? "checked" : null) @(!Model.EmailUsableForTwoFactor ? "disabled" : null) />
                        <span>
                            <strong>E-posta güvenlik kodu</strong>
                            <small>@(Model.EmailUsableForTwoFactor ? $"Aktif adres: {Model.MaskedEmailAddress}" : "Önce e-posta doğrulaması tamamlanmalı.")</small>
                        </span>
                        <span class="twofactor-status @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "on" : "off")">
                            <i class="fas @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "fa-toggle-on" : "fa-toggle-off")"></i>
                            @(Model.TwoFactorEnabled && Model.SelectedTwoFactorChannel == "email" ? "Açık" : "Kapalı")
                        </span>
                    </label>
                </div>
            </label>
        </div>
        <p class="auth-inline-hint" style="margin-top:14px;">Firma hesabı için 2FA doğrulaması e-posta kanalı ile yapılır. Telefon/WhatsApp doğrulaması bu panelde kullanılmaz.</p>
        <div class="save-row"><button type="submit" class="primary-btn">Güvenlik tercihini kaydet</button></div>
    </form>

    <div class="panel-card">
        <div class="section-head"><h2>Sözleşmeler</h2></div>
        <div class="form-grid" style="margin-top: 18px;">
            <label class="full">
                <span>Kullanıcı sözleşmeleri</span>
                <div class="radio-stack">
                    <a class="radio-option" href="/sozlesmeler/kullanici-kullanim-kosullari" target="_blank" rel="noopener">
                        <i class="fas fa-file-signature" style="width: 18px; text-align: center;"></i>
                        <span>
                            <strong>Kullanıcı Kullanım Koşulları</strong>
                            <small>Platform üyeliği ve rezervasyon kullanım kuralları.</small>
                        </span>
                        <span class="twofactor-status on">
                            <i class="fas fa-arrow-up-right-from-square"></i>
                            Aç
                        </span>
                    </a>
                    <a class="radio-option" href="/sozlesmeler/kullanici-kvkk-aydinlatma" target="_blank" rel="noopener">
                        <i class="fas fa-shield-halved" style="width: 18px; text-align: center;"></i>
                        <span>
                            <strong>Kullanıcı KVKK Aydınlatma Metni</strong>
                            <small>6698 sayılı Kanun kapsamında aydınlatma metni.</small>
                        </span>
                        <span class="twofactor-status on">
                            <i class="fas fa-arrow-up-right-from-square"></i>
                            Aç
                        </span>
                    </a>
                </div>
            </label>
        </div>
    </div>
</section>
