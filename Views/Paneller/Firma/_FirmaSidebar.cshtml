@model otelturizmnew.Models.Paneller.Firma.FirmaPanelShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    bool IsCurrent(params string[] actions) => actions.Any(a => string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase));
    bool IsPath(params string[] paths) => paths.Any(p => currentPath.Equals(p, StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase));
    string ActivePath(params string[] paths) => IsPath(paths) ? "active" : string.Empty;

    var dashboardActive = IsCurrent("Index") || IsPath("/panel/firma/dashboard");
    var travelOpen = IsPath("/panel/firma/firma-fiyatlari", "/panel/firma/yeni-rezervasyon", "/panel/firma/rezervasyonlar", "/panel/firma/mesajlar")
        || IsCurrent("Deals", "CompareDeals", "CreateReservation", "Reservations", "Messages");
    var orgOpen = IsPath("/panel/firma/calisanlar", "/panel/firma/limitler-onaylar", "/panel/firma/faturalar")
        || IsCurrent("Employees", "Limits", "Invoices");
    var reportOpen = IsPath("/panel/firma/harcama-raporlari", "/panel/firma/otel-bazli-rapor")
        || IsCurrent("Spending", "Hotels");
    var accountOpen = IsPath("/panel/firma/guvenlik") || IsCurrent("Security");
    var companyName = string.IsNullOrWhiteSpace(Model.CompanyName) ? "Kurumsal hesap" : Model.CompanyName;
}
<aside class="admin-sidebar" id="appSidebar" aria-label="Firma menüsü">
    <div class="sidebar-header">
        <a href="/panel/firma/dashboard" class="logo-wordmark-wrapper">
            <span class="logo-otel">B2B</span>
            <div class="logo-sep"></div>
            <span class="logo-turizm">Kurumsal</span>
        </a>
    </div>

    <div class="sidebar-scroll">
        <div class="sidebar-hotel-line">
            Aktif şirket
            <strong>@companyName</strong>
        </div>

        <span class="sidebar-group-label">Kurumsal Kokpit</span>
        <div class="nav-menu-item @(dashboardActive ? "active" : "")">
            <a class="nav-main-link" href="/panel/firma/dashboard">
                <div class="nav-link-left"><i class="fas fa-chart-line ic-core"></i><span>Genel Bakış</span></div>
            </a>
        </div>

        <span class="sidebar-group-label">Organizasyon</span>
        <div class="nav-menu-item @(orgOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-firma-nav-toggle aria-expanded="@(orgOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-users ic-staff"></i><span>Çalışan & Limitler</span></div>
                @if (Model.PendingApprovalCount > 0)
                {
                    <span class="ap-nav-badge">@Model.PendingApprovalCount</span>
                }
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/firma/calisanlar")" href="/panel/firma/calisanlar">
                    Çalışanlar
                    @if (Model.EmployeeCount > 0)
                    {
                        <span class="ap-nav-badge">@Model.EmployeeCount</span>
                    }
                </a>
                <a class="@ActivePath("/panel/firma/limitler-onaylar")" href="/panel/firma/limitler-onaylar">
                    Limitler & Onaylar
                    @if (Model.PendingApprovalCount > 0)
                    {
                        <span class="ap-nav-badge">@Model.PendingApprovalCount</span>
                    }
                </a>
                <a class="@ActivePath("/panel/firma/faturalar")" href="/panel/firma/faturalar">Faturalar</a>
            </div>
        </div>

        <span class="sidebar-group-label">Seyahat Operasyonları</span>
        <div class="nav-menu-item @(travelOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-firma-nav-toggle aria-expanded="@(travelOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-plane-departure ic-travel"></i><span>Rezervasyon Akışı</span></div>
                @if (Model.DealCount > 0)
                {
                    <span class="ap-nav-badge">@Model.DealCount</span>
                }
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@(IsCurrent("Deals", "CompareDeals") ? "active" : string.Empty)" href="/panel/firma/firma-fiyatlari">
                    Firma Fiyatları
                    @if (Model.DealCount > 0)
                    {
                        <span class="ap-nav-badge">@Model.DealCount</span>
                    }
                </a>
                <a class="@ActivePath("/panel/firma/yeni-rezervasyon")" href="/panel/firma/yeni-rezervasyon">Yeni Rezervasyon</a>
                <a class="@ActivePath("/panel/firma/rezervasyonlar")" href="/panel/firma/rezervasyonlar">Rezervasyonlar</a>
                <a class="@ActivePath("/panel/firma/mesajlar")" href="/panel/firma/mesajlar">Mesajlar</a>
            </div>
        </div>

        <span class="sidebar-group-label">Raporlar</span>
        <div class="nav-menu-item @(reportOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-firma-nav-toggle aria-expanded="@(reportOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-chart-column ic-report"></i><span>Analiz & Rapor</span></div>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/firma/harcama-raporlari")" href="/panel/firma/harcama-raporlari">Harcama Raporları</a>
                <a class="@ActivePath("/panel/firma/otel-bazli-rapor")" href="/panel/firma/otel-bazli-rapor">Otel Bazlı Rapor</a>
            </div>
        </div>

        <span class="sidebar-group-label">Hesap</span>
        <div class="nav-menu-item @(accountOpen ? "open active" : "")" data-nav-group>
            <button type="button" class="nav-main-link" data-firma-nav-toggle aria-expanded="@(accountOpen ? "true" : "false")">
                <div class="nav-link-left"><i class="fas fa-shield-halved ic-settings"></i><span>Güvenlik & Sözleşme</span></div>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </button>
            <div class="sub-links-container">
                <a class="@ActivePath("/panel/firma/guvenlik")" href="/panel/firma/guvenlik">Güvenlik</a>
                <a href="/panel/firma/guvenlik#firma-sozlesmeler-panel">Sözleşmeler</a>
            </div>
        </div>
    </div>

    <div class="admin-sidebar-footer">
        <div class="ap-sidebar-user">
            <strong>@Model.FullName</strong>
            @Model.Email
        </div>
        <div class="admin-sidebar-footer-actions">
            <a href="/panel/firma/yeni-rezervasyon" class="ap-btn-sidebar primary">
                <i class="fas fa-plus"></i> Yeni Rezervasyon
            </a>
            <a href="/firma" class="ap-btn-sidebar">
                <i class="fas fa-arrow-left"></i> Firma Sayfası
            </a>
            <form method="post" action="/cikis-yap" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="ap-btn-sidebar danger w-100">
                    <i class="fas fa-right-from-bracket"></i> Çıkış
                </button>
            </form>
        </div>
    </div>
</aside>
