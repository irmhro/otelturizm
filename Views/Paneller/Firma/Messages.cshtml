@model otelturizmnew.Models.Paneller.Firma.FirmaMessagesPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["Title"] = "Firma Mesajları";
    ViewData["FirmaShell"] = Model.Shell;
}

<section class="messages-layout">
    <aside class="message-list-panel">
        <div class="message-list-head">
            <h2>Kullanıcı Yazışmaları</h2>
            <span>@Model.Threads.Count konuşma</span>
        </div>

        @if (Model.Threads.Count == 0)
        {
            <div class="message-item active">
                <div class="message-avatar blue">FR</div>
                <div>
                    <h3>Henüz konuşma yok</h3>
                    <p>Kullanıcı talepleri bu alanda listelenir.</p>
                </div>
            </div>
        }
        else
        {
            foreach (var thread in Model.Threads)
            {
                <a class="message-item @(thread.IsActive ? "active" : string.Empty)" href="@thread.RouteUrl">
                    <div class="message-avatar @thread.AvatarTone">@thread.AvatarText</div>
                    <div class="message-thread-copy">
                        <h3>@thread.Title</h3>
                        <strong>@thread.Subtitle</strong>
                        <p>@thread.Preview</p>
                    </div>
                    @if (thread.UnreadCount > 0)
                    {
                        <span class="thread-unread-badge">@thread.UnreadCount</span>
                    }
                </a>
            }
        }
    </aside>

    <div class="chat-panel">
        <div class="chat-head">
            <div>
                <h2>@Model.SelectedTitle</h2>
                <p>@Model.SelectedSubtitle</p>
            </div>
        </div>

        <div class="chat-body">
            @if (Model.Messages.Count == 0)
            {
                <div class="bubble incoming">
                    <p>Bu konuşmada henüz mesaj bulunmuyor.</p>
                    <span>Şimdi</span>
                </div>
            }
            else
            {
                foreach (var message in Model.Messages)
                {
                    <div class="bubble @(message.IsOutgoing ? "outgoing" : "incoming") @(message.IsDeleted ? "deleted" : string.Empty)">
                        <div class="bubble-meta">
                            <strong>@message.SenderName</strong>
                            <span>@message.TimeText</span>
                        </div>
                        @if (message.IsDeleted)
                        {
                            <p class="deleted-text">@message.DeletedText</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(message.MessageText))
                        {
                            <p>@message.MessageText</p>
                        }

                        @if (message.Attachments.Count > 0)
                        {
                            <div class="message-attachments">
                                @foreach (var attachment in message.Attachments)
                                {
                                    <a href="@attachment.AccessUrl" class="message-attachment-card" target="_blank" rel="noopener">
                                        @if (attachment.IsImage)
                                        {
                                            <img src="@attachment.AccessUrl" alt="@attachment.DisplayName" />
                                        }
                                        else
                                        {
                                            <div class="attachment-icon"><i class="fas fa-file-shield"></i></div>
                                        }
                                        <div>
                                            <strong>@attachment.DisplayName</strong>
                                            <small>@attachment.SizeText</small>
                                        </div>
                                    </a>
                                }
                            </div>
                        }

                        @if (message.CanDelete && !message.IsDeleted)
                        {
                            <form method="post" action="/panel/firma/mesajlar/sil" class="message-delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ConversationId" value="@Model.SelectedConversationId" />
                                <input type="hidden" name="MessageId" value="@message.MessageId" />
                                <button type="submit" class="message-delete-btn">Sil</button>
                            </form>
                        }
                    </div>
                }
            }
        </div>

        @if (Model.SelectedConversationId.HasValue)
        {
            <form method="post" action="/panel/firma/mesajlar/gonder" enctype="multipart/form-data" class="chat-input-row chat-input-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ConversationId" value="@Model.SelectedConversationId" />
                <textarea name="Message" placeholder="Kullanıcıya güvenli mesaj gönder..." maxlength="2000"></textarea>
                <div class="chat-compose-actions">
                    <label class="attachment-picker">
                        <i class="fas fa-paperclip"></i>
                        <span>Belge / Görsel</span>
                        <input type="file" name="attachments" multiple accept=".jpg,.jpeg,.png,.webp,.pdf,.doc,.docx,.xls,.xlsx,.txt" />
                    </label>
                    <button type="submit" class="send-btn"><i class="fas fa-paper-plane"></i> Gönder</button>
                </div>
            </form>
        }
        else
        {
            <div class="chat-input-row">
                <input type="text" placeholder="Mesaj göndermek için önce bir konuşma seçin" disabled />
                <button type="button" class="send-btn" disabled><i class="fas fa-paper-plane"></i></button>
            </div>
        }
    </div>
</section>
