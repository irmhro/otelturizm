@model otelturizmnew.Models.Paneller.Firma.FirmaEmployeesPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/firma/employees";
    ViewData["PageCssMobile"] = "paneller/firma/employees.mobile";
}
<section class="firma-mini-stats">
    <article class="firma-mini-stat"><strong>@Model.TotalCount</strong><span>Toplam Çalışan</span></article>
    <article class="firma-mini-stat"><strong>@Model.TravelingEmployeeCount</strong><span>Rezervasyon Açan</span></article>
    <article class="firma-mini-stat"><strong>@Model.AverageLimitText</strong><span>Ortalama Limit</span></article>
    <button type="button" class="firma-action-btn" data-modal-open="employee-modal"><i class="fas fa-plus"></i> Çalışan Ekle</button>
</section>

<section class="firma-card">
    <form method="get" action="/panel/firma/calisanlar" class="firma-form-grid panel-form-ux" id="employeeFilterForm">
        <label>
            <span>Arama</span>
            <input type="text" name="q" value="@(Model.SearchTerm ?? string.Empty)" placeholder="İsim / e-posta / departman" autocomplete="off" id="employeeSearchInput" />
        </label>
        <label>
            <span>Departman</span>
            <select name="departman" id="employeeDepartmentSelect">
                <option value="">Tümü</option>
                @foreach (var dep in Model.Departments)
                {
                    if (string.Equals(Model.DepartmentFilter, dep, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@dep" selected>@dep</option>
                    }
                    else
                    {
                        <option value="@dep">@dep</option>
                    }
                }
            </select>
        </label>
        <label>
            <span>Sayfa başı</span>
            <select name="pageSize" id="employeePageSizeSelect">
                @if (Model.PageSize == 25) { <option value="25" selected>25</option> } else { <option value="25">25</option> }
                @if (Model.PageSize == 35) { <option value="35" selected>35</option> } else { <option value="35">35</option> }
                @if (Model.PageSize == 45) { <option value="45" selected>45</option> } else { <option value="45">45</option> }
            </select>
        </label>
        <input type="hidden" name="page" value="@Model.CurrentPage" id="employeePageHidden" />
        <div class="firma-form-actions" style="grid-column: 1 / -1; justify-content: flex-end;">
            <a class="firma-btn-light" href="/panel/firma/calisanlar">Sıfırla</a>
            <button type="submit" class="firma-btn-primary">Uygula</button>
        </div>
    </form>

    <div class="firma-table-wrap" style="margin-top:14px;">
        <table class="firma-table firma-table--cards">
            <thead>
            <tr>
                <th>Çalışan</th>
                <th>Departman</th>
                <th>Ünvan</th>
                <th>Rol</th>
                <th>Limit</th>
                <th>Akış</th>
                <th>Telefon</th>
                <th style="text-align:right;">Rez.</th>
                <th style="text-align:right;">Harcama</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Employees)
            {
                <tr class="@(item.IsActive ? string.Empty : "is-muted")" data-employee-row
                    data-user-id="@item.UserId"
                    data-full-name="@item.FullName"
                    data-phone="@(item.Phone ?? string.Empty)"
                    data-department="@item.Department"
                    data-title="@item.Title"
                    data-role="@item.RoleCode"
                    data-nightly-limit="@(item.NightlyLimit?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)"
                    data-approval-required="@(item.ApprovalRequired ? "true" : "false")"
                    data-is-active="@(item.IsActive ? "true" : "false")">
                    <td data-label="Çalışan">
                        <div class="firma-employee-cell">
                            <span class="firma-employee-avatar" style="width:34px; height:34px; font-size:12px;">@item.Initials</span>
                            <div>
                                <strong>@item.FullName</strong>
                                @if (!item.IsActive) { <span class="firma-pill secondary">Pasif</span> }
                                <br />
                                <small>@item.Email</small>
                            </div>
                        </div>
                    </td>
                    <td data-label="Departman">@item.Department</td>
                    <td data-label="Ünvan">@item.Title</td>
                    <td data-label="Rol"><span class="firma-pill @(item.IsManager ? "is-warning" : "secondary")">@item.RoleText</span></td>
                    <td data-label="Limit"><span class="firma-pill">@item.LimitText</span></td>
                    <td data-label="Akış"><span class="firma-pill @(item.ApprovalText.Contains("Onaylı") ? "is-warning" : "is-success")">@item.ApprovalText</span></td>
                    <td data-label="Telefon"><span class="firma-pill @item.PhoneVerificationToneClass">@item.PhoneVerificationText</span></td>
                    <td data-label="Rez." style="text-align:right;"><b>@item.ReservationCountText</b></td>
                    <td data-label="Harcama" style="text-align:right;"><b>@item.SpendText</b></td>
                    <td data-label="İşlem" style="text-align:right;">
                        <button type="button" class="firma-btn-light" data-employee-edit style="padding:6px 10px; font-size:12px;"><i class="fas fa-pen"></i> Düzenle</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        var prev = Math.Max(1, Model.CurrentPage - 1);
        var next = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
        <div class="firma-pagination" style="display:flex; gap:10px; align-items:center; justify-content:space-between; margin-top:14px;">
            <div class="firma-inline-note">Sayfa <b>@Model.CurrentPage</b> / <b>@Model.TotalPages</b> · Toplam <b>@Model.TotalCount</b> kayıt</div>
            <div style="display:flex; gap:8px; align-items:center;">
                <a class="firma-btn-light" href="@BuildEmployeesUrl(Model, 1)">İlk</a>
                <a class="firma-btn-light" href="@BuildEmployeesUrl(Model, prev)">Önceki</a>
                <a class="firma-btn-light" href="@BuildEmployeesUrl(Model, next)">Sonraki</a>
                <a class="firma-btn-light" href="@BuildEmployeesUrl(Model, Model.TotalPages)">Son</a>
            </div>
        </div>
    }
</section>

@if (Model.Employees.Count == 0)
{
    <section class="firma-empty-card">
        <i class="fas fa-users"></i>
        <h2>Henüz firma çalışanı yok</h2>
        <p>İlk çalışanı eklediğinizde harcama limiti ve onay akışı aynı ekrandan yönetilebilir hale gelir.</p>
    </section>
}

<div class="firma-modal-overlay" id="employee-modal">
    <div class="firma-modal-card">
        <div class="firma-row-between">
            <div>
                <p class="firma-kicker">FİRMA PERSONELİ</p>
                <h2>Çalışan Ekle</h2>
            </div>
            <button type="button" class="firma-icon-btn" data-modal-close="employee-modal"><i class="fas fa-times"></i></button>
        </div>
        <form method="post" action="/panel/firma/calisan-ekle" class="firma-form-grid panel-form-ux">
            @Html.AntiForgeryToken()
            <label><span>Ad Soyad</span><input type="text" name="FullName" value="@Model.CreateForm.FullName" required /></label>
            <label><span>E-posta</span><input type="email" name="Email" value="@Model.CreateForm.Email" required /></label>
            <label><span>Telefon</span><input type="text" name="Phone" value="@Model.CreateForm.Phone" /></label>
            <label><span>Departman</span><input type="text" name="Department" value="@Model.CreateForm.Department" placeholder="Satış / Operasyon / Finans" /></label>
            <label><span>Görev Ünvanı</span><input type="text" name="Title" value="@Model.CreateForm.Title" placeholder="Satış Müdürü" /></label>
            <label>
                <span>Rol</span>
                <select name="Role">
                    <option value="firma_staff">Firma Personeli</option>
                    <option value="firma_manager">Departman Yöneticisi</option>
                    <option value="firma_admin">Firma Yöneticisi</option>
                </select>
            </label>
            <label><span>Gecelik Limit</span><input type="number" step="0.01" min="0" name="NightlyLimit" value="@(Model.CreateForm.NightlyLimit?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" /></label>
            <label class="firma-checkbox"><input type="checkbox" name="ApprovalRequired" value="true" @(Model.CreateForm.ApprovalRequired ? "checked" : string.Empty) /><span>Rezervasyonları onaya düşsün</span></label>
            <div class="firma-form-actions">
                <button type="button" class="firma-btn-light" data-modal-close="employee-modal">Vazgeç</button>
                <button type="submit" class="firma-btn-primary">Çalışanı Oluştur</button>
            </div>
        </form>
        <p class="firma-inline-note">Yeni çalışana geçici bir başlangıç şifresi atanır. Kullanıcı ilk girişten sonra şifresini değiştirmelidir.</p>
    </div>
</div>

<div class="firma-modal-overlay" id="employee-edit-modal">
    <div class="firma-modal-card">
        <div class="firma-row-between">
            <div>
                <p class="firma-kicker">FİRMA PERSONELİ</p>
                <h2>Çalışan Düzenle</h2>
            </div>
            <button type="button" class="firma-icon-btn" data-modal-close="employee-edit-modal"><i class="fas fa-times"></i></button>
        </div>
        <form method="post" action="/panel/firma/calisan-guncelle" class="firma-form-grid panel-form-ux" id="employeeEditForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserId" id="editUserId" value="0" />
            <input type="hidden" name="ReturnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
            <label><span>Ad Soyad</span><input type="text" name="FullName" id="editFullName" required /></label>
            <label><span>Telefon</span><input type="text" name="Phone" id="editPhone" /></label>
            <label><span>Departman</span><input type="text" name="Department" id="editDepartment" /></label>
            <label><span>Görev Ünvanı</span><input type="text" name="Title" id="editTitle" /></label>
            <label>
                <span>Rol</span>
                <select name="Role" id="editRole">
                    <option value="firma_staff">Firma Personeli</option>
                    <option value="firma_manager">Departman Yöneticisi</option>
                    <option value="firma_admin">Firma Yöneticisi</option>
                </select>
            </label>
            <label><span>Gecelik Limit</span><input type="number" step="0.01" min="0" name="NightlyLimit" id="editNightlyLimit" /></label>
            <label class="firma-checkbox"><input type="hidden" name="ApprovalRequired" value="false" /><input type="checkbox" name="ApprovalRequired" id="editApprovalRequired" value="true" /><span>Rezervasyonları onaya düşsün</span></label>
            <label class="firma-checkbox"><input type="hidden" name="IsActive" value="false" /><input type="checkbox" name="IsActive" id="editIsActive" value="true" checked /><span>Hesap aktif</span></label>
            <div class="firma-form-actions">
                <button type="button" class="firma-btn-light" data-modal-close="employee-edit-modal">Vazgeç</button>
                <button type="submit" class="firma-btn-primary">Kaydet</button>
            </div>
        </form>
    </div>
</div>

@{
    var nonce = Context.Items["CspNonce"] as string;
}
<script nonce="@nonce">
function buildUrl(page) {
    const form = document.getElementById('employeeFilterForm');
    const q = form.querySelector('input[name="q"]').value || '';
    const departman = form.querySelector('select[name="departman"]').value || '';
    const pageSize = form.querySelector('select[name="pageSize"]').value || '25';
    const params = new URLSearchParams();
    if (q.trim()) params.set('q', q.trim());
    if (departman.trim()) params.set('departman', departman.trim());
    params.set('pageSize', pageSize);
    params.set('page', String(page || 1));
    return '/panel/firma/calisanlar?' + params.toString();
}

document.querySelectorAll('[data-modal-open]').forEach(button => {
    button.addEventListener('click', () => {
        const target = document.getElementById(button.getAttribute('data-modal-open'));
        if (target) target.classList.add('is-visible');
    });
});
document.querySelectorAll('[data-modal-close]').forEach(button => {
    button.addEventListener('click', () => {
        const target = document.getElementById(button.getAttribute('data-modal-close'));
        if (target) target.classList.remove('is-visible');
    });
});
document.querySelectorAll('.firma-modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', event => {
        if (event.target === overlay) overlay.classList.remove('is-visible');
    });
});

const searchInput = document.getElementById('employeeSearchInput');
const depSelect = document.getElementById('employeeDepartmentSelect');
const sizeSelect = document.getElementById('employeePageSizeSelect');
let searchTimer = null;
function autoApply() {
    window.location.href = buildUrl(1);
}
if (searchInput) {
    searchInput.addEventListener('input', () => {
        if (searchTimer) clearTimeout(searchTimer);
        searchTimer = setTimeout(autoApply, 350);
    });
}
if (depSelect) depSelect.addEventListener('change', autoApply);
if (sizeSelect) sizeSelect.addEventListener('change', autoApply);

document.querySelectorAll('[data-employee-edit]').forEach(function (button) {
    button.addEventListener('click', function () {
        var row = button.closest('[data-employee-row]');
        if (!row) return;
        document.getElementById('editUserId').value = row.getAttribute('data-user-id') || '0';
        document.getElementById('editFullName').value = row.getAttribute('data-full-name') || '';
        document.getElementById('editPhone').value = row.getAttribute('data-phone') || '';
        document.getElementById('editDepartment').value = row.getAttribute('data-department') || '';
        document.getElementById('editTitle').value = row.getAttribute('data-title') || '';
        document.getElementById('editRole').value = row.getAttribute('data-role') || 'firma_staff';
        document.getElementById('editNightlyLimit').value = row.getAttribute('data-nightly-limit') || '';
        document.getElementById('editApprovalRequired').checked = row.getAttribute('data-approval-required') === 'true';
        document.getElementById('editIsActive').checked = row.getAttribute('data-is-active') !== 'false';
        var modal = document.getElementById('employee-edit-modal');
        if (modal) modal.classList.add('is-visible');
    });
});
</script>

@functions
{
    private static string BuildEmployeesUrl(otelturizmnew.Models.Paneller.Firma.FirmaEmployeesPageViewModel model, int page)
    {
        var q = model.SearchTerm ?? string.Empty;
        var dep = model.DepartmentFilter ?? string.Empty;
        var qs = System.Web.HttpUtility.ParseQueryString(string.Empty);
        if (!string.IsNullOrWhiteSpace(q)) qs["q"] = q;
        if (!string.IsNullOrWhiteSpace(dep)) qs["departman"] = dep;
        qs["pageSize"] = (model.PageSize <= 0 ? 25 : model.PageSize).ToString(System.Globalization.CultureInfo.InvariantCulture);
        qs["page"] = (page <= 0 ? 1 : page).ToString(System.Globalization.CultureInfo.InvariantCulture);
        return "/panel/firma/calisanlar?" + qs.ToString();
    }
}
