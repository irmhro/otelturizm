@model otelturizmnew.Models.Paneller.Firma.FirmaDealsComparePageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
}

<section class="firma-section-card ot-card">
    <div class="firma-row-between">
        <div>
            <h2>Fiyat Karşılaştır</h2>
            <p class="firma-muted">Seçtiğiniz otellerin firmaya özel fiyatlarını oda tipine göre yan yana kıyaslayın.</p>
            @if (!string.IsNullOrWhiteSpace(Model.Hint))
            {
                <small class="firma-muted">@Model.Hint</small>
            }
        </div>
        <a class="firma-btn-light ot-btn ot-btn--ghost" href="/panel/firma/firma-fiyatlari"><i class="fas fa-tags"></i> Firma Fiyatlarına Dön</a>
    </div>

    <div style="margin-top:14px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <span class="ot-badge">Seçili otel: <b>@Model.Hotels.Count</b></span>
        <span class="ot-badge">Oda adedi: <b>@Model.RoomCount</b></span>
    </div>

    @if (Model.Hotels.Count == 0 || Model.Rows.Count == 0)
    {
        <div class="firma-empty-inline" style="margin-top:12px;">
            Karşılaştırma verisi bulunamadı. Lütfen 2-3 otel seçip tekrar deneyin.
        </div>
    }
    else
    {
        @foreach (var hotel in Model.Hotels.OrderBy(x => x.HotelName))
        {
            <article class="ot-card" style="margin-top:14px; padding:14px;">
                <div class="firma-row-between" style="gap:12px;">
                    <div>
                        <strong style="font-size:16px;">@hotel.HotelName</strong>
                        <div class="firma-muted">@hotel.CityText</div>
                    </div>
                    <a class="firma-btn-primary ot-btn ot-btn--primary"
                       href="/panel/firma/yeni-rezervasyon?hotelId=@hotel.HotelId&roomCount=@Model.RoomCount">Rezervasyon Yap</a>
                </div>

                <div style="margin-top:10px; overflow:auto;">
                    <table class="table" style="min-width:760px;">
                        <thead>
                            <tr>
                                <th>Oda Tipi</th>
                                <th>Kapasite</th>
                                <th>Firma (gecelik)</th>
                                <th>Standart (gecelik)</th>
                                <th>İndirim</th>
                                <th>Geçerlilik</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows.Where(x => x.HotelId == hotel.HotelId))
                            {
                                <tr>
                                    <td><b>@row.RoomName</b></td>
                                    <td class="text-muted">@row.CapacityText</td>
                                    <td>@row.CorporateNightlyText</td>
                                    <td class="text-muted">@row.StandardNightlyText</td>
                                    <td><span class="ot-badge ot-badge--success">@row.DiscountText</span></td>
                                    <td class="text-muted">@row.ValidityText</td>
                                    <td style="text-align:right;">
                                        <a class="ot-btn ot-btn--ghost"
                                           href="/panel/firma/yeni-rezervasyon?hotelId=@hotel.HotelId&roomTypeId=@row.RoomTypeId&roomCount=@Model.RoomCount">Seç</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        }
    }
</section>

