@model otelturizmnew.Models.Paneller.Firma.FirmaPanelShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    bool IsActive(params string[] actions)
    {
        foreach (var a in actions)
        {
            if (string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }
        return false;
    }
}
<nav class="firma-mobile-nav" aria-label="Firma mobil menü">
    <div class="firma-mobile-nav-scroll">
        <a href="/panel/firma/dashboard" class="@(IsActive("Index") ? "active" : string.Empty)"><i class="fas fa-chart-pie"></i><span>Özet</span></a>
        <a href="/panel/firma/firma-fiyatlari" class="@(IsActive("Deals", "CompareDeals") ? "active" : string.Empty)"><i class="fas fa-hotel"></i><span>Fiyat</span></a>
        <a href="/panel/firma/yeni-rezervasyon" class="@(IsActive("CreateReservation") ? "active" : string.Empty)"><i class="fas fa-plus-circle"></i><span>Yeni</span></a>
        <a href="/panel/firma/rezervasyonlar" class="@(IsActive("Reservations") ? "active" : string.Empty)"><i class="fas fa-calendar-check"></i><span>Rezerv.</span></a>
        <a href="/panel/firma/mesajlar" class="@(IsActive("Messages") ? "active" : string.Empty)"><i class="fas fa-envelope-open-text"></i><span>Mesaj</span></a>
        <a href="/panel/firma/calisanlar" class="@(IsActive("Employees") ? "active" : string.Empty)"><i class="fas fa-users"></i><span>Çalışan</span></a>
        <a href="/panel/firma/limitler-onaylar" class="@(IsActive("Limits") ? "active" : string.Empty)"><i class="fas fa-sliders"></i><span>Onay</span></a>
        <a href="/panel/firma/faturalar" class="@(IsActive("Invoices") ? "active" : string.Empty)"><i class="fas fa-file-invoice"></i><span>Fatura</span></a>
        <a href="/panel/firma/harcama-raporlari" class="@(IsActive("Spending") ? "active" : string.Empty)"><i class="fas fa-chart-column"></i><span>Harcama</span></a>
        <a href="/panel/firma/otel-bazli-rapor" class="@(IsActive("Hotels") ? "active" : string.Empty)"><i class="fas fa-building"></i><span>Otel</span></a>
        <a href="/panel/firma/guvenlik" class="@(IsActive("Security") ? "active" : string.Empty)"><i class="fas fa-shield-halved"></i><span>Güvenlik</span></a>
    </div>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form firma-mobile-logout">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket"></i><span>Çıkış</span></button>
    </form>
</nav>
