@model otelturizmnew.Models.Paneller.Firma.FirmaPanelShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    bool IsCurrent(params string[] actions) => actions.Any(a => string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase));
    bool IsPath(params string[] paths) => paths.Any(p => currentPath.Equals(p, StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith(p + "/", StringComparison.OrdinalIgnoreCase));

    var dashboardActive = IsCurrent("Index") || IsPath("/panel/firma/dashboard");
    var travelOpen = IsPath("/panel/firma/firma-fiyatlari", "/panel/firma/yeni-rezervasyon", "/panel/firma/rezervasyonlar", "/panel/firma/mesajlar")
        || IsCurrent("Deals", "CompareDeals", "CreateReservation", "Reservations", "Messages");
    var orgOpen = IsPath("/panel/firma/calisanlar", "/panel/firma/limitler-onaylar", "/panel/firma/faturalar")
        || IsCurrent("Employees", "Limits", "Invoices");
    var reportOpen = IsPath("/panel/firma/harcama-raporlari", "/panel/firma/otel-bazli-rapor")
        || IsCurrent("Spending", "Hotels");
}
<nav class="admin-mobile-nav firma-mobile-nav" aria-label="Firma mobil menü">
    <a href="/panel/firma/dashboard" class="@(dashboardActive ? "active" : null)"><i class="fas fa-chart-line" aria-hidden="true"></i><span>Kokpit</span></a>
    <a href="/panel/firma/firma-fiyatlari" class="@(travelOpen ? "active" : null)"><i class="fas fa-hotel" aria-hidden="true"></i><span>Fiyat</span></a>
    <a href="/panel/firma/yeni-rezervasyon" class="@(IsCurrent("CreateReservation") ? "active" : null)"><i class="fas fa-plus" aria-hidden="true"></i><span>Yeni</span></a>
    <a href="/panel/firma/rezervasyonlar" class="@(IsCurrent("Reservations") ? "active" : null)"><i class="fas fa-calendar-check" aria-hidden="true"></i><span>Rezerv.</span></a>
    <a href="/panel/firma/calisanlar" class="@(orgOpen ? "active" : null)"><i class="fas fa-users" aria-hidden="true"></i><span>Ekip</span></a>
    <a href="/panel/firma/harcama-raporlari" class="@(reportOpen ? "active" : null)"><i class="fas fa-chart-column" aria-hidden="true"></i><span>Rapor</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket" aria-hidden="true"></i><span>Çıkış</span></button>
    </form>
</nav>
