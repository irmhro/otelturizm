@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Firma
@inject otelturizmnew.Services.Abstractions.IPanelThemeService PanelThemeService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string ?? ViewData["PageCss"] as string;
    var pageCssMobilePath = ViewData["PageCssMobilePath"] as string ?? ViewData["PageCssMobile"] as string;
    var shell = ViewData["FirmaShell"] as FirmaPanelShellViewModel ?? Model as FirmaPanelShellViewModel;
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Firma Paneli";
    var firmaUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var firmaUserId = long.TryParse(firmaUserRaw, out var parsedFirmaUserId) ? parsedFirmaUserId : 0;
    var theme = firmaUserId > 0 ? await PanelThemeService.LoadAsync("firma", firmaUserId, Context.RequestAborted) : new otelturizmnew.Models.Paneller.Partner.PanelThemeViewModel();
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme is not ("light" or "dark" or "auto")) { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";
    var hideLayoutHeader = requestPath.Contains("/panel/firma/dashboard", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestPath.TrimEnd('/'), "/panel/firma", StringComparison.OrdinalIgnoreCase);

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var primaryHex = !string.IsNullOrWhiteSpace(theme?.PrimaryHex) ? theme!.PrimaryHex : theme?.AccentHex;
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : primaryHex;
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--fp-corporate-blue: {accentHex};");
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--partner-sidebar-bg: {theme!.SidebarBgHex}; --partner-sidebar-bg-2: color-mix(in srgb, {theme.SidebarBgHex} 76%, #ffffff 24%);");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily)) parts.Add($"--tblr-font-sans-serif: {theme!.FontFamily};");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-standards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-header-bildiri.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <partial name="~/Views/Shared/_VendorPlusJakartaFont.cshtml" />
    <link rel="stylesheet" href="~/assets/css/firmapanel_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/firmapanel_mobil.css" asp-append-version="true" media="(max-width: 991px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        var pageCssMobileHref = !string.IsNullOrWhiteSpace(pageCssMobilePath)
            ? $"~/assets/css/{pageCssMobilePath}.css"
            : $"~/assets/css/{pageCssPath}.mobile.css";
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="@pageCssMobileHref" asp-append-version="true" media="(max-width: 991px)" />
    }
</head>
<body class="layout-fluid firma-panel-v2 firmapanel-v6-shell" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)" dir="@dir" style="@BuildThemeStyle()">
    <div class="admin-shell-container">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Firma/_FirmaSidebar.cshtml" model="shell" />
            <div class="admin-sidebar-backdrop" id="firmaSidebarBackdrop" aria-hidden="true"></div>
        }

        <div class="main-layout">
            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Firma/_FirmaTopNav.cshtml" model="shell" />
            }

            <main class="content-body">
                @if (shell is not null && !hideLayoutHeader && !string.IsNullOrWhiteSpace(shell.PanelTitle))
                {
                    <div class="ap-page-header d-print-none">
                        <div>
                            <div class="ap-page-pretitle">B2B Kurumsal</div>
                            <h1>@shell.PanelTitle</h1>
                            @if (!string.IsNullOrWhiteSpace(shell.PanelSubtitle))
                            {
                                <p>@shell.PanelSubtitle</p>
                            }
                        </div>
                    </div>
                }
                <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
                @RenderBody()
            </main>

            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Firma/_FirmaPanelFooter.cshtml" model="shell" />
                <partial name="~/Views/Paneller/Firma/_FirmaMobileNav.cshtml" model="shell" />
                <div class="offcanvas offcanvas-end" tabindex="-1" id="firmaThemeSettings" aria-labelledby="firmaThemeSettingsLabel">
                    <div class="offcanvas-header">
                        <h2 class="offcanvas-title" id="firmaThemeSettingsLabel">Tema Ayarları</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
                    </div>
                    <div class="offcanvas-body">
                        <form method="post" action="/panel/firma/tema/kaydet">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="PrimaryHex" id="firmaThemePrimaryHex" value="@(theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="AccentHex" id="firmaThemeAccentHex" value="@(theme?.AccentHex ?? theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="SidebarBgHex" id="firmaThemeSidebarBgHex" value="@(theme?.SidebarBgHex ?? string.Empty)" />
                            <label class="form-label">Renk modu</label>
                            <div class="form-selectgroup-boxes row g-2 mb-3">
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="light" class="form-selectgroup-input" @(string.Equals(bsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-sun me-2"></i>Açık</span>
                                </label>
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="dark" class="form-selectgroup-input" @(string.Equals(bsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-moon me-2"></i>Koyu</span>
                                </label>
                            </div>
                            <label class="form-label">Ana renk</label>
                            <div class="d-flex flex-wrap gap-2 mb-3" data-color-palette="firma-primary">
                                @foreach (var color in new[] { "#1E3A8A", "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#ef4444", "#334155" })
                                {
                                    <button type="button" class="btn btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                                }
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Temayı Kaydet</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="~/assets/js/panel-header-bildiri.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
    <script src="~/assets/js/firmapanel-shell.js" asp-append-version="true"></script>
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
    (() => {
        const primaryInput = document.getElementById('firmaThemePrimaryHex');
        const accentInput = document.getElementById('firmaThemeAccentHex');
        const sidebarInput = document.getElementById('firmaThemeSidebarBgHex');
        const body = document.body;
        const root = document.documentElement;
        const applyThemePreview = ({ mode, accent, sidebar }) => {
            if (mode) {
                root.setAttribute('data-bs-theme', mode);
                body.setAttribute('data-bs-theme', mode);
            }
            if (accent) root.style.setProperty('--fp-corporate-blue', accent);
            if (sidebar) {
                root.style.setProperty('--partner-sidebar-bg', sidebar);
                root.style.setProperty('--partner-sidebar-bg-2', `color-mix(in srgb, ${sidebar} 76%, #ffffff 24%)`);
            }
        };
        document.querySelectorAll('[data-color-palette="firma-primary"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                applyThemePreview({
                    mode: document.querySelector('#firmaThemeSettings input[name="BsTheme"]:checked')?.value || 'light',
                    accent: hex,
                    sidebar: sidebarInput?.value || ''
                });
            });
        });
        document.querySelectorAll('#firmaThemeSettings input[name="BsTheme"]').forEach((input) => {
            input.addEventListener('change', () => {
                const value = input.value || 'light';
                const accent = accentInput?.value || primaryInput?.value || '';
                applyThemePreview({ mode: value, accent, sidebar: sidebarInput?.value || '' });
            });
        });

        const rootBody = document.querySelector('.firmapanel-v6-shell .content-body');
        if (rootBody) {
            rootBody.querySelectorAll('input').forEach(function (el) {
                var type = (el.getAttribute('type') || 'text').toLowerCase();
                if (type === 'checkbox' || type === 'radio') {
                    if (!el.classList.contains('form-check-input')) el.classList.add('form-check-input');
                    return;
                }
                if (!el.classList.contains('form-control') && type !== 'hidden') el.classList.add('form-control');
            });
            rootBody.querySelectorAll('select, textarea').forEach(function (el) {
                if (!el.classList.contains('form-control')) el.classList.add('form-control');
            });
        }
    })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
