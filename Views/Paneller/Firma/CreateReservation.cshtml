@model otelturizmnew.Models.Paneller.Firma.FirmaCreateReservationPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
}

<section class="firma-section-card">
    <div class="firma-row-between">
        <div>
            <h2>Yeni Rezervasyon Oluştur</h2>
            <p class="firma-muted">Otel seç, oda/tarih belirle, normal fiyat ile firma fiyatını karşılaştır ve kurumsal rezervasyonu oluştur.</p>
        </div>
        <a class="firma-btn-light ot-btn ot-btn--ghost" href="/panel/firma/firma-fiyatlari"><i class="fas fa-tags"></i> Firma Fiyatları</a>
    </div>

    <form method="get" action="/panel/firma/yeni-rezervasyon" class="firma-form-grid" style="margin-top:12px">
        <div class="span-2">
            <label>Otel Ara (İl / İlçe / Mahalle / Otel Adı)</label>
            <div style="display:flex; gap:10px; align-items:center">
                <input type="text" name="search" value="@Model.HotelSearch" placeholder="örn. İstanbul, Maltepe, Cevizli, Eagle Palace" />
                <button type="submit" class="firma-btn-light ot-btn ot-btn--ghost"><i class="fas fa-magnifying-glass"></i> Ara</button>
            </div>
            <small class="firma-muted">Arama, otel listesi ve konum alanlarını filtreler.</small>
        </div>
    </form>

    <form method="post" action="/panel/firma/yeni-rezervasyon" class="firma-form-grid">
        @Html.AntiForgeryToken()
        <div class="span-2">
            <label>Otel</label>
            <select name="HotelId" required onchange="window.location='/panel/firma/yeni-rezervasyon?search=@(Uri.EscapeDataString(Model.HotelSearch ?? string.Empty))&hotelId='+this.value">
                @foreach (var opt in Model.Hotels)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.Form.HotelId ? "selected" : null)">@opt.Label</option>
                }
            </select>
        </div>
        <div>
            <label>Oda Tipi</label>
            <select name="RoomTypeId" required onchange="window.location='/panel/firma/yeni-rezervasyon?search=@(Uri.EscapeDataString(Model.HotelSearch ?? string.Empty))&hotelId=@Model.Form.HotelId&roomTypeId='+this.value">
                @foreach (var opt in Model.RoomTypes)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.Form.RoomTypeId ? "selected" : null)">@opt.Label</option>
                }
            </select>
        </div>
        <div>
            <label>Oda Sayısı</label>
            <input type="number" name="RoomCount" min="1" value="@Model.Form.RoomCount" required />
            <small class="firma-muted">Firma fiyatı çoğu otelde min oda şartına bağlı olabilir.</small>
        </div>
        <div>
            <label>Giriş</label>
            <input type="date" name="CheckInDate" value="@Model.Form.CheckInDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div>
            <label>Çıkış</label>
            <input type="date" name="CheckOutDate" value="@Model.Form.CheckOutDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div>
            <label>Yetişkin</label>
            <input type="number" name="AdultCount" min="1" value="@Model.Form.AdultCount" />
        </div>
        <div>
            <label>Çocuk</label>
            <input type="number" name="ChildCount" min="0" value="@Model.Form.ChildCount" />
        </div>

        <div class="span-2">
            <label>Personel (opsiyonel)</label>
            <select name="EmployeeUserId">
                <option value="">Firma personeli seç (opsiyonel)</option>
                @foreach (var emp in Model.Employees)
                {
                    <option value="@emp.UserId" selected="@(emp.IsSelected ? "selected" : null)">@emp.FullName · @emp.Department · @emp.Email</option>
                }
            </select>
            <small class="firma-muted">Seçilirse rezervasyon “firma personeli” adına işlenir.</small>
        </div>

        <div class="span-2">
            <label>Personel E-postaları (opsiyonel)</label>
            <input type="text" name="EmployeeEmailsCsv" value="@Model.Form.EmployeeEmailsCsv" placeholder="ornek1@firma.com, ornek2@firma.com" />
            <small class="firma-muted">Rezervasyon bilgisi firma ve personel e-postalarına bildirilebilir.</small>
        </div>

        <div class="span-2">
            <label>Not</label>
            <textarea name="Note" rows="3" placeholder="Toplu konaklama notu / özel istek">@Model.Form.Note</textarea>
        </div>

        <div class="span-2">
            <div class="firma-price-compare">
                <div>
                    <small>@Model.Compare.NightCountText</small>
                    <h3>Fiyat Karşılaştırma</h3>
                    <p class="firma-muted">@Model.Compare.Note</p>
                </div>
                <div class="compare-grid">
                    <div class="compare-box">
                        <label>Standart Toplam</label>
                        <strong>@Model.Compare.StandardTotalText</strong>
                    </div>
                    <div class="compare-box is-primary">
                        <label>Firma Toplam</label>
                        <strong>@Model.Compare.CompanyTotalText</strong>
                    </div>
                    <div class="compare-box is-success">
                        <label>Tasarruf</label>
                        <strong>@Model.Compare.SavingsText</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="span-2 firma-form-actions">
            <button type="submit" class="firma-btn-primary ot-btn ot-btn--primary"><i class="fas fa-check"></i> Rezervasyonu Oluştur</button>
        </div>
    </form>
</section>

