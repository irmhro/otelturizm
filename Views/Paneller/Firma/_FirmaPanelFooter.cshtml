@model otelturizmnew.Models.Paneller.Firma.FirmaPanelShellViewModel
@inject otelturizmnew.Services.Abstractions.ITimeZoneService TimeZoneService
@{
    var localNow = TimeZoneService.ToLocal(DateTime.UtcNow);
}
<footer class="footer footer-transparent d-print-none firma-footer firma-footer-tabler">
    <div class="container-fluid">
        <div class="row align-items-center gy-2">
            <div class="col-md">
                <div class="text-muted">
                    &copy; @localNow.Year Otelturizm B2B Kurumsal
                    <span class="mx-2">·</span>
                    <span>@(string.IsNullOrWhiteSpace(Model.CompanyName) ? "Kurumsal hesap" : Model.CompanyName)</span>
                </div>
            </div>
            <div class="col-md-auto">
                <ul class="list-inline list-inline-dots mb-0">
                    <li class="list-inline-item text-muted">Firma ID: @Model.FirmaId</li>
                    <li class="list-inline-item text-muted">@localNow.ToString("dd.MM.yyyy HH:mm")</li>
                    <li class="list-inline-item"><a href="/sozlesmeler/firma-kurumsal-kullanim-kosullari" class="link-secondary">Kullanım Koşulları</a></li>
                    <li class="list-inline-item"><a asp-controller="Home" asp-action="Privacy" class="link-secondary">Gizlilik</a></li>
                </ul>
            </div>
        </div>
    </div>
</footer>

<script src="~/assets/js/konum-kordinat.js" asp-append-version="true"></script>
