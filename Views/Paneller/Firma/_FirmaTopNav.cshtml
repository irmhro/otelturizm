@using System.Security.Claims
@using otelturizmnew.Constants
@using otelturizmnew.Models.Paneller.Common
@using otelturizmnew.Models.Paneller.Firma
@inject otelturizmnew.Services.Abstractions.IHeaderBildiriService HeaderBildiriService
@model FirmaPanelShellViewModel
@{
    var fn = Model.FullName?.Trim() ?? string.Empty;
    var initial = fn.Length > 0 ? char.ToUpper(fn[0]).ToString() : "F";
    var companyInitial = !string.IsNullOrWhiteSpace(Model.CompanyName)
        ? string.Concat(Model.CompanyName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(static x => x[0]))
        : "B2B";
    var firmaUserRaw = Context.User.FindFirstValue(AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
    var firmaUserId = long.TryParse(firmaUserRaw, out var parsedFirmaUserId) ? parsedFirmaUserId : 0;
    var headerBildiri = await HeaderBildiriService.GetForPanelAsync(PanelHeaderAudience.Firma, firmaUserId, Context.RequestAborted);
}
<header class="global-topbar" role="banner">
    <div class="topbar-left">
        <button type="button" class="menu-trigger" id="firmaSidebarToggle" aria-label="Menüyü aç/kapat">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <div class="fp-company-chip d-none d-lg-inline-flex" title="@Model.CompanyName">
            <i class="fas fa-building"></i>
            <span>@Model.CompanyName</span>
        </div>
        <div class="header-search">
            <i class="fas fa-search"></i>
            <input type="search" id="firmaGlobalSearch" data-firma-search-base="/panel/firma/rezervasyonlar" placeholder="Rezervasyon, çalışan veya otel ara..." autocomplete="off" title="Enter: rezervasyon ara · Ctrl+K: odaklan" />
        </div>
    </div>

    <div class="topbar-right">
        <div class="currency-switcher d-none d-md-flex" role="group" aria-label="Para birimi (görüntüleme)">
            <button type="button" class="currency-btn active" data-currency="TRY" title="Görüntüleme tercihi">TL</button>
            <button type="button" class="currency-btn" data-currency="EUR">EUR</button>
            <button type="button" class="currency-btn" data-currency="USD">USD</button>
        </div>
        <button type="button" class="utility-btn d-none d-md-flex" data-bs-toggle="offcanvas" data-bs-target="#firmaThemeSettings" aria-label="Tema ayarları">
            <i class="fas fa-palette"></i>
        </button>
        <div class="header-bildiri firma-header-bildiri" data-header-bildiri data-panel-key="@headerBildiri.PanelKey" data-unread-count="@headerBildiri.UnreadCount" data-open="false">
            @Html.AntiForgeryToken()
            <button class="header-bildiri-btn utility-btn" type="button" data-header-bildiri-toggle aria-expanded="false" aria-label="Bildirimleri aç">
                <i class="far fa-bell"></i>
                @if (headerBildiri.UnreadCount > 0)
                {
                    <span class="bell-dot"></span>
                }
            </button>
            <div class="header-bildiri-dropdown" role="dialog" aria-label="Firma bildirimleri">
                <div class="header-bildiri-head">
                    <strong>Bildirimler</strong>
                    <span>@headerBildiri.UnreadCount okunmamış</span>
                </div>
                <ul class="header-bildiri-list">
                    @foreach (var item in headerBildiri.Items)
                    {
                        <li class="header-bildiri-item tone-@item.Tone @(item.IsRead ? "is-read" : "is-unread")"
                            data-header-item-key="@item.ItemKey"
                            data-header-item-read="@(item.IsRead ? "1" : "0")">
                            <a href="@item.Url" data-header-item-link>
                                <i class="fas @item.IconClass"></i>
                                <span class="header-bildiri-content">
                                    <strong>@item.Title</strong>
                                    <p>@item.Description</p>
                                    <span class="header-bildiri-time">
                                        <span class="header-bildiri-time-chip">@item.TimeLabel</span>
                                    </span>
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <a class="btn-quick-add" href="/panel/firma/yeni-rezervasyon">
            <i class="fas fa-plus"></i>
            <span>Yeni Rezervasyon</span>
        </a>

        <div class="profile-dropdown-wrapper">
            <div class="avatar-trigger" id="firmaAvatarBtn" role="button" tabindex="0" aria-haspopup="true">
                <span class="company-logo-mini">@companyInitial</span>
                <div class="comp-info d-none d-md-flex">
                    <span class="comp-name">@Model.CompanyName</span>
                    <span class="comp-role">@Model.UserRole</span>
                </div>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="profile-dropdown" id="firmaProfileDropdown">
                <div class="dropdown-header">
                    <strong>@Model.FullName</strong>
                    <span>@Model.Email</span>
                </div>
                <ul class="dropdown-menu-list">
                    <li><a href="/panel/firma/dashboard"><i class="fas fa-chart-line"></i> Kurumsal Kokpit</a></li>
                    <li><a href="/panel/firma/hesap-bilgileri"><i class="fas fa-user-circle"></i> Hesap Bilgileri</a></li>
                    <li><a href="/panel/firma/calisanlar"><i class="fas fa-users"></i> Çalışanlar</a></li>
                    <li><a href="/panel/firma/limitler-onaylar"><i class="fas fa-sliders"></i> Limitler & Onaylar</a></li>
                    <li><div class="dropdown-divider"></div></li>
                    <li>
                        <form method="post" action="/cikis-yap" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-danger"><i class="fas fa-sign-out-alt"></i> Güvenli Çıkış</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>
