@model otelturizmnew.Models.Paneller.Firma.FirmaInvoicesPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/firma/invoices";
    ViewData["PageCssMobile"] = "paneller/firma/invoices.mobile";
}
<section class="firma-section-card">
    <h2>Faturalar</h2>
    <div class="firma-table-wrap">
        <table class="firma-table firma-table--cards">
            <thead><tr><th>Fatura No</th><th>Tarih</th><th>Tür</th><th>Alıcı</th><th>Tutar</th><th>Durum</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model.Invoices)
            {
                <tr>
                    <td data-label="Fatura No">@item.InvoiceNo</td>
                    <td data-label="Tarih">@item.InvoiceDateText</td>
                    <td data-label="Tür">@item.InvoiceType</td>
                    <td data-label="Alıcı">@item.RecipientName</td>
                    <td data-label="Tutar">@item.TotalText</td>
                    <td data-label="Durum">@item.StatusText</td>
                    <td data-label="İndir">
                        @if (item.CanDownload)
                        {
                            <a class="firma-btn-light" href="/panel/firma/faturalar/indir?invoiceId=@item.InvoiceId"><i class="fas fa-download"></i> İndir</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.Invoices.Count == 0)
    {
        <div class="firma-empty-inline">Henüz fatura kaydı yok.</div>
    }
</section>
