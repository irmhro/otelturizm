@model otelturizmnew.Models.Paneller.Firma.FirmaDashboardPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["FirmaShell"] = Model.Shell;
    ViewData["PageCssPath"] ??= "firmapanel_dashboard_masaustu";
    ViewData["PageCssMobilePath"] ??= "firmapanel_dashboard_mobil";
}

<div class="firmapanel-dashboard-page">
@if (Model.LimitAlerts.Count > 0)
{
    <div class="firma-dash-alerts" role="status">
        @foreach (var line in Model.LimitAlerts)
        {
            <div class="firma-dash-alert">
                <i class="fas fa-triangle-exclamation" aria-hidden="true"></i>
                <p>@line</p>
                <a class="firma-dash-alert__cta" href="/panel/firma/limitler-onaylar">Limitlere git</a>
            </div>
        }
    </div>
}

<section class="firma-dash-identity">
    <div class="firma-dash-identity__left">
        <div class="firma-dash-identity__avatar" aria-hidden="true">@(string.IsNullOrWhiteSpace(Model.Shell.FullName) ? "?" : string.Concat(Model.Shell.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(static x => x[0])))</div>
        <div>
            <p class="firma-dash-identity__kicker">Aktif kurumsal hesap</p>
            <h2 class="firma-dash-identity__title">@Model.Shell.CompanyName</h2>
            <p class="firma-dash-identity__sub">@Model.Shell.FullName · @Model.Shell.Email</p>
        </div>
    </div>
    <div class="firma-dash-identity__metrics" aria-label="Bu ay özet metrikler">
        <div>
            <span class="firma-dash-metric__label">@Model.CurrentMonthLabel — toplam harcama</span>
            <strong class="firma-dash-metric__value">@Model.MonthSpendTotalText</strong>
        </div>
        <div>
            <span class="firma-dash-metric__label">Rezervasyon adedi</span>
            <strong class="firma-dash-metric__value">@Model.MonthReservationCount</strong>
        </div>
        <div>
            <span class="firma-dash-metric__label">Kurumsal tasarruf (tahmini)</span>
            <strong class="firma-dash-metric__value is-savings">@Model.MonthSavingsText</strong>
        </div>
    </div>
</section>

<section class="firma-grid firma-kpi-grid" aria-label="Operasyon göstergeleri">
@foreach (var card in Model.SummaryCards)
{
    <article class="firma-stat-card firma-kpi-tile @card.ToneClass">
        <div class="firma-kpi-tile__head"><i class="fas @card.IconClass" aria-hidden="true"></i><span class="firma-kpi-tile__label">@card.Label</span></div>
        <strong class="firma-kpi-tile__value">@card.Value</strong>
        <p class="firma-kpi-tile__desc">@card.Description</p>
    </article>
}
</section>

@if (Model.SpendTrend.Count > 0)
{
    <section class="firma-dash-trend" aria-label="Aylık harcama eğilimi">
        <div class="firma-dash-trend__head">
            <h2>Harcama eğilimi</h2>
            <p>Son dönem rezervasyon tutarları (oluşturulma tarihine göre).</p>
            <a class="firma-dash-trend__link" href="/panel/firma/harcama-raporlari">Detaylı rapor →</a>
        </div>
        <div class="firma-chart-bars firma-chart-bars--dashboard" role="img" aria-label="Aylık sütun grafiği">
            @foreach (var m in Model.SpendTrend)
            {
                <div class="chart-col">
                    <span style="height:@(m.HeightPercent)px" title="@m.Label: @m.Amount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("tr-TR"))"></span>
                    <small>@m.Label</small>
                    <span class="firma-chart-meta">@m.ReservationCount rez.</span>
                </div>
            }
        </div>
    </section>
}

<section class="firma-two-column">
    <article class="firma-section-card firma-section-card--lift">
        <h2>Firma fiyatları</h2>
        <div class="firma-list">
            @foreach (var deal in Model.HighlightDeals)
            {
                <div class="firma-list-row">
                    <strong>@deal.HotelName</strong>
                    <span>@deal.MinimumRoomText</span>
                    <b>@deal.CorporatePriceText</b>
                </div>
            }
        </div>
        <a class="firma-section-more" href="/panel/firma/firma-fiyatlari">Tüm anlaşmalı fiyatlar →</a>
    </article>
    <article class="firma-section-card firma-section-card--lift">
        <h2>Öne çıkan çalışanlar</h2>
        <div class="firma-list">
            @foreach (var item in Model.FeaturedEmployees)
            {
                <div class="firma-list-row">
                    <strong>@item.FullName</strong>
                    <span>@item.Department</span>
                    <b>@item.LimitText</b>
                </div>
            }
        </div>
        <a class="firma-section-more" href="/panel/firma/calisanlar">Çalışan yönetimi →</a>
    </article>
</section>

<section class="firma-section-card firma-section-card--lift">
    <h2>Son rezervasyonlar</h2>
    <div class="firma-table-wrap">
        <table class="firma-table firma-table--cards">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Çalışan</th>
                    <th>Otel</th>
                    <th>Konaklama</th>
                    <th>Durum</th>
                    <th>Tutar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RecentReservations)
                {
                    <tr>
                        <td data-label="No">@item.ReservationNo</td>
                        <td data-label="Çalışan">@item.EmployeeName</td>
                        <td data-label="Otel">@item.HotelName</td>
                        <td data-label="Konaklama">@item.StayText</td>
                        <td data-label="Durum">@item.ApprovalText</td>
                        <td data-label="Tutar">@item.TotalText</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a class="firma-section-more" href="/panel/firma/rezervasyonlar">Tüm rezervasyonlar →</a>
</section>
</div>
