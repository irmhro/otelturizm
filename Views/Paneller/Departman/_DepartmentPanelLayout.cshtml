@using System.Security.Claims
@using otelturizmnew.Models.Paneller.Departman
@inject otelturizmnew.Services.Abstractions.IPanelThemeService PanelThemeService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string;
    var shell = ViewData["DepartmentShell"] as DepartmentPanelShellViewModel;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Departman Paneli";
    var rawUserId = Context.User.FindFirstValue(otelturizmnew.Constants.AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var userId = long.TryParse(rawUserId, out var parsedUserId) ? parsedUserId : 0;
    var theme = userId > 0 ? await PanelThemeService.LoadAsync("departman", userId, Context.RequestAborted) : new otelturizmnew.Models.Paneller.Partner.PanelThemeViewModel();
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme != "light" && bsTheme != "dark" && bsTheme != "auto") { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var primaryHex = !string.IsNullOrWhiteSpace(theme?.PrimaryHex) ? theme!.PrimaryHex : theme?.AccentHex;
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : primaryHex;
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--partner-accent: {accentHex};");
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--partner-sidebar-bg: {theme!.SidebarBgHex}; --partner-sidebar-bg-2: color-mix(in srgb, {theme.SidebarBgHex} 76%, #ffffff 24%);");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily)) parts.Add($"--tblr-font-sans-serif: {theme!.FontFamily};");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-standards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/departman/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/departman/shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body class="department-panel" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)" dir="@dir" style="@BuildThemeStyle()">
    <input id="departmentMenuToggle" class="department-menu-toggle" type="checkbox" />
    <div class="department-shell">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Departman/_DepartmentSidebar.cshtml" model="shell" />
        }
        <main class="department-main">
            @if (shell is not null)
            {
                <header class="department-header">
                    <label class="department-menu-button" for="departmentMenuToggle" aria-label="Menüyü aç">
                        <i class="fas fa-bars"></i>
                    </label>
                    <div>
                        <p>Departman paneli</p>
                        <h1>@shell.PanelTitle</h1>
                        <span>@shell.PanelSubtitle</span>
                    </div>
                    <button class="btn btn-icon btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#departmentThemeSettings" aria-label="Tema ayarları">
                        <i class="fas fa-palette"></i>
                    </button>
                    <form method="post" action="/cikis-yap">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="department-logout"><i class="fas fa-right-from-bracket"></i> Çıkış</button>
                    </form>
                </header>
            }
            @RenderBody()
            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Departman/_DepartmentFooter.cshtml" model="shell" />
            }
        </main>
    </div>
    @if (shell is not null)
    {
        <partial name="~/Views/Paneller/Departman/_DepartmentMobileNav.cshtml" model="shell" />
        <div class="offcanvas offcanvas-end" tabindex="-1" id="departmentThemeSettings" aria-labelledby="departmentThemeSettingsLabel">
            <div class="offcanvas-header">
                <h2 class="offcanvas-title" id="departmentThemeSettingsLabel">Tema Ayarları</h2>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
            </div>
            <div class="offcanvas-body">
                <form method="post" action="/panel/departman/tema/kaydet">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <input type="hidden" name="PrimaryHex" id="departmentThemePrimaryHex" value="@(theme?.PrimaryHex ?? string.Empty)" />
                    <input type="hidden" name="AccentHex" id="departmentThemeAccentHex" value="@(theme?.AccentHex ?? theme?.PrimaryHex ?? string.Empty)" />
                    <input type="hidden" name="SidebarBgHex" id="departmentThemeSidebarBgHex" value="@(theme?.SidebarBgHex ?? string.Empty)" />
                    <label class="form-label">Renk modu</label>
                    <div class="form-selectgroup-boxes row g-2 mb-3">
                        <label class="form-selectgroup-item col-6">
                            <input type="radio" name="BsTheme" value="light" class="form-selectgroup-input" @(string.Equals(bsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                            <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-sun me-2"></i>Açık</span>
                        </label>
                        <label class="form-selectgroup-item col-6">
                            <input type="radio" name="BsTheme" value="dark" class="form-selectgroup-input" @(string.Equals(bsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                            <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-moon me-2"></i>Koyu</span>
                        </label>
                    </div>
                    <label class="form-label">Ana renk</label>
                    <div class="d-flex flex-wrap gap-2 mb-3" data-color-palette="department-primary">
                        @foreach (var color in new[] { "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#334155" })
                        {
                            <button type="button" class="btn btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                        }
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Temayı Kaydet</button>
                </form>
            </div>
        </div>
    }
    <script src="~/paneltematabler/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script nonce="@(Context.Items["CspNonce"] as string)">
    (() => {
        const primaryInput = document.getElementById('departmentThemePrimaryHex');
        const accentInput = document.getElementById('departmentThemeAccentHex');
        const sidebarInput = document.getElementById('departmentThemeSidebarBgHex');
        const body = document.body;
        const root = document.documentElement;
        const applyThemePreview = ({ mode, accent, sidebar }) => {
            if (mode) { root.setAttribute('data-bs-theme', mode); body.setAttribute('data-bs-theme', mode); }
            if (accent) root.style.setProperty('--partner-accent', accent);
            if (sidebar) { root.style.setProperty('--partner-sidebar-bg', sidebar); root.style.setProperty('--partner-sidebar-bg-2', `color-mix(in srgb, ${sidebar} 76%, #ffffff 24%)`); }
        };
        document.querySelectorAll('[data-color-palette=\"department-primary\"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                applyThemePreview({
                    mode: document.querySelector('#departmentThemeSettings input[name=\"BsTheme\"]:checked')?.value || 'light',
                    accent: hex,
                    sidebar: sidebarInput?.value || ''
                });
            });
        });
        document.querySelectorAll('#departmentThemeSettings input[name=\"BsTheme\"]').forEach((input) => {
            input.addEventListener('change', () => {
                const value = input.value || 'light';
                const accent = accentInput?.value || primaryInput?.value || '';
                applyThemePreview({ mode: value, accent, sidebar: sidebarInput?.value || '' });
            });
        });
    })();
    </script>
</body>
</html>
