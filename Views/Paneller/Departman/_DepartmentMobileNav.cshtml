@model otelturizmnew.Models.Paneller.Departman.DepartmentPanelShellViewModel
<nav class="department-mobile-nav">
    @foreach (var item in Model.Departments.Take(5))
    {
        <a class="@(item.IsActive ? "active" : null)" href="/panel/departman/@item.Key">
            <i class="fas @item.IconClass"></i>
            <span>@item.Label</span>
        </a>
    }
</nav>
