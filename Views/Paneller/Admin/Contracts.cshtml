@model otelturizmnew.Models.Paneller.Admin.AdminContractManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    @foreach (var item in Model.SummaryCards)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>@item.Value</h3>
                    <p>@item.Label</p>
                    <small>@item.Description</small>
                </div>
                <div class="icon"><i class="fas @item.IconClass"></i></div>
            </div>
        </div>
    }
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Kayıtlı sözleşmeler</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Başlık</th>
                            <th>Kitle</th>
                            <th>Tür</th>
                            <th>Versiyon</th>
                            <th>Yürürlük</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Contracts)
                        {
                            <tr>
                                <td><strong>@item.Title</strong><div>@item.Slug</div></td>
                                <td>@item.Audience</td>
                                <td>@item.ContractType</td>
                                <td>@item.VersionText</td>
                                <td>@item.EffectiveRangeText</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary mr-1" href="/admin/sozlesmeler?contractId=@item.ContractId">Düzenle</a>
                                    <form method="post" action="/admin/sozlesmeler/yeniden-gonder" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="contractId" value="@item.ContractId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Tekrar Gönder</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">@(Model.Form.ContractId.HasValue ? "Sözleşmeyi Düzenle" : "Yeni Sözleşme")</h3>
            </div>
            <form method="post" action="/admin/sozlesmeler/kaydet">
                <div class="card-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ContractId" value="@Model.Form.ContractId" />
                    <div class="row">
                        <div class="col-6 form-group">
                            <label>Hedef kitle</label>
                            <select name="Audience" class="form-control">
                                <option value="user" selected="@(Model.Form.Audience == "user")">Kullanıcı</option>
                                <option value="partner" selected="@(Model.Form.Audience == "partner")">Partner</option>
                                <option value="firma" selected="@(Model.Form.Audience == "firma")">Firma</option>
                            </select>
                        </div>
                        <div class="col-6 form-group">
                            <label>Sözleşme türü</label>
                            <select name="ContractType" class="form-control">
                                <option value="agreement" selected="@(Model.Form.ContractType == "agreement")">Ana sözleşme</option>
                                <option value="kvkk" selected="@(Model.Form.ContractType == "kvkk")">KVKK</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Başlık</label>
                        <input type="text" name="Title" class="form-control" value="@Model.Form.Title" required />
                    </div>
                    <div class="form-group">
                        <label>Slug</label>
                        <input type="text" name="Slug" class="form-control" value="@Model.Form.Slug" required />
                    </div>
                    <div class="form-group">
                        <label>Özet HTML</label>
                        <textarea name="SummaryHtml" rows="3" class="form-control">@Model.Form.SummaryHtml</textarea>
                    </div>
                    <div class="form-group">
                        <label>İçerik HTML</label>
                        <textarea name="ContentHtml" rows="8" class="form-control" required>@Model.Form.ContentHtml</textarea>
                    </div>
                    <div class="form-group clearfix">
                        <div class="icheck-primary d-inline mr-3">
                            <input type="checkbox" id="requiresAcceptance" name="RequiresAcceptance" value="true" @(Model.Form.RequiresAcceptance ? "checked" : null) />
                            <label for="requiresAcceptance">Kabul zorunlu</label>
                        </div>
                        <div class="icheck-primary d-inline mr-3">
                            <input type="checkbox" id="sendOnEmailVerification" name="SendOnEmailVerification" value="true" @(Model.Form.SendOnEmailVerification ? "checked" : null) />
                            <label for="sendOnEmailVerification">E-posta onayında gönder</label>
                        </div>
                        <div class="icheck-primary d-inline">
                            <input type="checkbox" id="isActive" name="IsActive" value="true" @(Model.Form.IsActive ? "checked" : null) />
                            <label for="isActive">Aktif</label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
