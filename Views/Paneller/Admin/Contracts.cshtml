@model otelturizmnew.Models.Paneller.Admin.AdminContractManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    ViewData["PageCssPath"] = "admin_panel_contracts_masaustu";
    var nonce = Context.Items["CspNonce"] as string;
}

<section class="admin-contracts-page">
    <article class="admin-contracts-hero">
        <p class="admin-contracts-kicker">HUKUK VE UYUM</p>
        <h1>Sözleşme merkezi</h1>
        <p>Kullanıcı, partner ve firma sözleşmelerini tek ekranda düzenleyin; HTML içerik, önizleme ve PDF eklerini üretim standardında yönetin.</p>
    </article>

    <section class="admin-contract-summary-grid">
        @foreach (var item in Model.SummaryCards)
        {
            <article class="admin-contract-summary-card">
                <small>@item.Label</small>
                <strong>@item.Value</strong>
                <span>@item.Description</span>
            </article>
        }
    </section>

    <section class="admin-contract-layout">
        <article class="admin-contract-list-card">
            <header>
                <h2>Kayıtlı sözleşmeler</h2>
                <p>Yayındaki kayıtları seçin, önizleyin veya tek tıkla düzenleme ekranına alın.</p>
            </header>

            <div class="admin-contract-table-wrap">
                <table class="admin-contract-table">
                    <thead>
                        <tr>
                            <th>Başlık</th>
                            <th>Kitle</th>
                            <th>Tür</th>
                            <th>Versiyon</th>
                            <th>Yürürlük</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Contracts)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Title</strong>
                                    <span>@item.Slug</span>
                                </td>
                                <td>@item.Audience</td>
                                <td>@item.ContractType</td>
                                <td>@item.VersionText</td>
                                <td>@item.EffectiveRangeText</td>
                                <td>
                                    <div class="admin-contract-actions">
                                        <a class="secondary-btn" href="/admin/sozlesmeler?contractId=@item.ContractId">Düzenle</a>
                                        <button type="button"
                                                class="ghost-btn"
                                                data-contract-preview
                                                data-contract-id="@item.ContractId"
                                                data-contract-title="@item.Title">
                                            Önizle
                                        </button>
                                        <form method="post" action="/admin/sozlesmeler/yeniden-gonder">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="contractId" value="@item.ContractId" />
                                            <button type="submit" class="primary-btn">Tekrar Gönder</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>

        <div class="admin-contract-side-stack">
            <article class="admin-contract-form-card">
                <header>
                    <h2>@(Model.Form.ContractId.HasValue ? "Sözleşmeyi Düzenle" : "Yeni Sözleşme")</h2>
                    <p>Slug, hedef kitle ve HTML içeriklerini aynı ekranda düzenleyin. TinyMCE canlı editör anahtarı bu sayfada tanımlıdır.</p>
                </header>

                <form method="post" action="/admin/sozlesmeler/kaydet" class="admin-contract-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ContractId" value="@Model.Form.ContractId" />

                    <div class="admin-contract-grid two">
                        <label>
                            <span>Hedef kitle</span>
                            <select name="Audience">
                                @if (Model.Form.Audience == "user") { <option value="user" selected>Kullanıcı</option> } else { <option value="user">Kullanıcı</option> }
                                @if (Model.Form.Audience == "partner") { <option value="partner" selected>Partner</option> } else { <option value="partner">Partner</option> }
                                @if (Model.Form.Audience == "firma") { <option value="firma" selected>Firma</option> } else { <option value="firma">Firma</option> }
                            </select>
                        </label>

                        <label>
                            <span>Sözleşme türü</span>
                            <select name="ContractType">
                                @if (Model.Form.ContractType == "agreement") { <option value="agreement" selected>Ana sözleşme</option> } else { <option value="agreement">Ana sözleşme</option> }
                                @if (Model.Form.ContractType == "kvkk") { <option value="kvkk" selected>KVKK</option> } else { <option value="kvkk">KVKK</option> }
                            </select>
                        </label>
                    </div>

                    <div class="admin-contract-grid two">
                        <label>
                            <span>Başlık</span>
                            <input type="text" name="Title" value="@Model.Form.Title" required />
                        </label>

                        <label>
                            <span>Slug</span>
                            <input type="text" name="Slug" value="@Model.Form.Slug" required />
                        </label>
                    </div>

                    <label>
                        <span>Özet HTML</span>
                        <small class="admin-contract-editor-note">Kısa açıklama, e-posta ön yüzü ve kayıt listesinde kullanılan özet alanıdır.</small>
                        <textarea id="SummaryHtmlEditor" name="SummaryHtml" rows="5">@Model.Form.SummaryHtml</textarea>
                    </label>

                    <label>
                        <span>İçerik HTML</span>
                        <small class="admin-contract-editor-note">Detay sözleşme sayfasında yayınlanan ana içerik. Başlık hiyerarşisi ve tablo yapısı korunmalıdır.</small>
                        <textarea id="ContentHtmlEditor" name="ContentHtml" rows="14" required>@Model.Form.ContentHtml</textarea>
                    </label>

                    <div class="admin-contract-checks">
                        <label class="admin-contract-inline-check">
                            <input type="hidden" name="RequiresAcceptance" value="false" />
                            <input type="checkbox" name="RequiresAcceptance" value="true" @(Model.Form.RequiresAcceptance ? "checked" : null) />
                            <div>
                                <span>Kabul zorunlu</span>
                                <small>Kullanıcı akışında onay kutusu zorunlu hale gelir.</small>
                            </div>
                        </label>

                        <label class="admin-contract-inline-check">
                            <input type="hidden" name="SendOnEmailVerification" value="false" />
                            <input type="checkbox" name="SendOnEmailVerification" value="true" @(Model.Form.SendOnEmailVerification ? "checked" : null) />
                            <div>
                                <span>E-posta onayında gönder</span>
                                <small>Doğrulama sonrası sözleşme paketine otomatik eklenir.</small>
                            </div>
                        </label>

                        <label class="admin-contract-inline-check">
                            <input type="hidden" name="IsActive" value="false" />
                            <input type="checkbox" name="IsActive" value="true" @(Model.Form.IsActive ? "checked" : null) />
                            <div>
                                <span>Aktif</span>
                                <small>Yayında kullanılacak sürüm olarak işaretlenir.</small>
                            </div>
                        </label>
                    </div>

                    <div class="admin-contract-form-actions">
                        <a class="ghost-btn" href="/admin/sozlesmeler">Temizle</a>
                        <button type="submit" class="primary-btn">Kaydet</button>
                    </div>
                </form>
            </article>

            @if (Model.Form.ContractId.HasValue && Model.Form.ContractId.Value > 0)
            {
                <article class="contract-pdf-upload-card">
                    <h3>PDF eki</h3>
                    <p>Sözleşme e-posta paketlerinde ek dosya olarak gönderilecek PDF’yi burada güncelleyebilirsiniz.</p>

                    <form method="post" action="/admin/sozlesmeler/pdf-yukle" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="contractId" value="@Model.Form.ContractId.Value" />
                        <div class="contract-pdf-upload-row">
                            <input type="file" name="pdfFile" accept="application/pdf" required />
                            <button type="submit" class="secondary-btn">PDF Yükle</button>
                        </div>
                    </form>
                </article>
            }
        </div>
    </section>
</section>

<div class="modal fade contract-admin-preview-modal" id="contractPreviewModal" tabindex="-1" aria-labelledby="contractPreviewTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl contract-preview-shell">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <div class="text-uppercase text-primary" style="font-size:.72rem;font-weight:800;letter-spacing:.08em;">SÖZLEŞME ÖNİZLEME</div>
                    <h5 class="modal-title mb-0" id="contractPreviewTitle">Sözleşme</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="contract-admin-preview-body" id="contractPreviewBody">
                <div class="text-muted">Yükleniyor...</div>
            </div>
        </div>
    </div>
</div>

<script src="~/assets/vendor/tinymce/tinymce.min.js" asp-append-version="true"></script>
<script nonce="@nonce">
    (() => {
        function initEditor(selector, height) {
            if (!window.tinymce) return;
            const target = document.querySelector(selector);
            if (!target) return;

            const existing = tinymce.get(target.id);
            if (existing) existing.remove();

            tinymce.init({
                selector,
                height,
                base_url: '/assets/vendor/tinymce',
                suffix: '.min',
                promotion: false,
                branding: false,
                menubar: 'file edit view insert format tools table help',
                plugins: [
                    'anchor', 'autolink', 'charmap', 'codesample', 'emoticons', 'link', 'lists', 'media', 'searchreplace', 'table', 'visualblocks', 'wordcount',
                    'code', 'fullscreen', 'help', 'image', 'preview'
                ],
                toolbar: 'undo redo | blocks | bold italic underline strikethrough | link media table | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat | code preview',
                quickbars_selection_toolbar: 'bold italic | quicklink blockquote',
                content_style: 'body{font-family:Inter,Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;color:#0f172a;} h1,h2,h3{letter-spacing:-.01em;color:#0f172a;} table{border-collapse:collapse;width:100%;} table td,table th{border:1px solid #cbd5e1;padding:8px;}',
                setup(editor) {
                    editor.on('init', () => editor.getContainer()?.classList.add('contract-editor-ready'));
                }
            });
        }

        initEditor('#SummaryHtmlEditor', 320);
        initEditor('#ContentHtmlEditor', 640);

        const modalEl = document.getElementById('contractPreviewModal');
        const titleEl = document.getElementById('contractPreviewTitle');
        const bodyEl = document.getElementById('contractPreviewBody');
        if (!modalEl || !titleEl || !bodyEl) return;

        async function openPreview(contractId, contractTitle) {
            titleEl.textContent = contractTitle || 'Sözleşme';
            bodyEl.innerHTML = '<div class="text-muted">Yükleniyor...</div>';
            if (window.bootstrap) bootstrap.Modal.getOrCreateInstance(modalEl).show();

            try {
                const response = await fetch(`/admin/sozlesmeler/onizleme?contractId=${encodeURIComponent(contractId)}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (!response.ok) throw new Error('Önizleme yüklenemedi.');
                const data = await response.json();
                titleEl.textContent = data.title || contractTitle || 'Sözleşme';
                bodyEl.innerHTML = data.html || '<div class="text-muted">İçerik bulunamadı.</div>';
            } catch (e) {
                bodyEl.innerHTML = `<div class="alert alert-warning mb-0">${(e && e.message) ? e.message : 'Önizleme yüklenemedi.'}</div>`;
            }
        }

        document.addEventListener('click', event => {
            const btn = event.target.closest('[data-contract-preview]');
            if (!btn) return;
            const id = btn.getAttribute('data-contract-id');
            const title = btn.getAttribute('data-contract-title');
            if (!id) return;
            openPreview(id, title);
        });
    })();
</script>
