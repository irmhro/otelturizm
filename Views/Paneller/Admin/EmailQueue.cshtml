@using otelturizmnew.Models.Paneller.Admin
@model AdminEmailQueuePageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">E-posta Kuyruğu</h3>
    </div>
    <div class="card-body">
        <form method="get" action="/admin/email-kuyruk" class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Durum</label>
                <input class="form-control form-control-sm" name="status" value="@Model.Filter.Status" placeholder="Beklemede / SMTP Kabul / Dosyaya Yazıldı / Başarısız" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Ara</label>
                <input class="form-control form-control-sm" name="q" value="@Model.Filter.Query" placeholder="E-posta / konu" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-sm btn-primary w-100" type="submit">Filtrele</button>
            </div>
        </form>

        <div class="table-responsive mt-3">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Alıcı</th>
                    <th>Konu</th>
                    <th>Durum</th>
                    <th>Sağlayıcı Mesaj ID</th>
                    <th>Deneme</th>
                    <th>Sonraki</th>
                    <th>Hata</th>
                    <th>İşlem</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.Id</td>
                        <td>@row.RecipientEmail</td>
                        <td style="max-width:360px;white-space:normal;">@row.Subject</td>
                        <td>@row.Status</td>
                        <td style="max-width:260px;white-space:normal;">@(string.IsNullOrWhiteSpace(row.ProviderMessageId) ? "-" : row.ProviderMessageId)</td>
                        <td>@row.AttemptCount / @row.MaxAttempts</td>
                        <td>@(row.NextAttemptUtc.HasValue ? row.NextAttemptUtc.Value.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") : "-")</td>
                        <td style="max-width:320px;white-space:normal;">@row.LastError</td>
                        <td style="min-width:280px;">
                            <form method="post" action="/admin/email-kuyruk/retry" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.Id" />
                                <input class="form-control form-control-sm d-inline-block" style="width:160px;" name="reason" placeholder="Gerekçe" required minlength="5" maxlength="240" />
                                <button class="btn btn-sm btn-outline-success" type="submit">Retry</button>
                            </form>
                            <form method="post" action="/admin/email-kuyruk/fail" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.Id" />
                                <input class="form-control form-control-sm d-inline-block" style="width:160px;" name="reason" placeholder="Gerekçe" required minlength="5" maxlength="240" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Fail</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="text-muted small">Toplam: @Model.Total</div>
    </div>
</div>

