@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsActive(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    string Active(string action) => IsActive(action) ? "active" : string.Empty;
    string Badge(int value) => value > 0 ? value.ToString() : "0";
    bool IsOpen(params string[] actions) => actions.Any(IsActive);

    var hotelOpen = IsOpen("Hotels", "ActiveHotels", "PendingHotels", "Campaigns", "Reviews");
    var commerceOpen = IsOpen("Reservations", "CompanyReservations", "ListingSubscriptions", "Payments", "Invoices", "Commissions", "Contracts", "Reports", "CommerceInsight");
    var userOpen = IsOpen("Users", "Managers", "PlatformOfficials", "ApprovalCenter", "PartnerApplications", "CompanyApplications", "DevelopmentRequests");
    var contentOpen = IsOpen("Notifications", "MailCenter", "EmailTemplates", "WhatsAppCloudApi", "Blog", "Faq", "SupportArticles");
    var systemOpen = IsOpen("PlatformCheckup", "Settings", "Sitemap", "Security", "Complaints", "Backups", "Logs", "GeoSearchLogs", "HotelCoordinateChanges");
}
<aside class="navbar navbar-vertical navbar-expand-lg partner-sidebar admin-sidebar-alias" data-bs-theme="dark" aria-label="Admin menüsü">
    <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminSidebarMenu" aria-controls="adminSidebarMenu" aria-expanded="false" aria-label="Menüyü aç">
            <span class="navbar-toggler-icon"></span>
        </button>

        <h1 class="navbar-brand navbar-brand-autodark">
            <a asp-controller="AdminPanel" asp-action="Dashboard" class="partner-brand-link">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="partner-brand-logo" />
                <span class="badge bg-primary-lt text-primary ms-1 align-middle" style="font-size:0.65rem">ADMIN</span>
            </a>
        </h1>

        <div class="collapse navbar-collapse" id="adminSidebarMenu">
            <div class="d-lg-none px-2 pb-2 mb-2 border-bottom border-light border-opacity-10">
                <div class="d-flex align-items-center gap-2 text-white">
                    <span class="avatar bg-primary-lt text-primary"><i class="fas fa-user-shield"></i></span>
                    <div class="small">
                        <div class="fw-bold">@Model.FullName</div>
                        <div class="text-secondary">@Model.Email</div>
                    </div>
                </div>
            </div>

            <div class="d-none d-lg-block partner-hotel-line">
                <span>Yetkili</span>
                <strong>@Model.FullName</strong>
                <small>@Model.Email</small>
            </div>

            <div class="partner-sidebar-scroll">
                <ul class="navbar-nav partner-sidebar-nav">
                    <li class="nav-item">
                        <a class="nav-link @(Active("Dashboard"))" asp-controller="AdminPanel" asp-action="Dashboard">
                            <span class="nav-link-icon"><i class="fas fa-table-columns"></i></span>
                            <span class="nav-link-title">Panel Özeti</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("SystemHealth"))" asp-controller="AdminPanel" asp-action="SystemHealth">
                            <span class="nav-link-icon"><i class="fas fa-heart-pulse"></i></span>
                            <span class="nav-link-title">Sistem Sağlığı</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("PlatformCheckup"))" asp-controller="AdminPanel" asp-action="PlatformCheckup">
                            <span class="nav-link-icon"><i class="fas fa-list-check"></i></span>
                            <span class="nav-link-title">Platform Checkup</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("ApprovalCenter"))" asp-controller="AdminPanel" asp-action="ApprovalCenter">
                            <span class="nav-link-icon"><i class="fas fa-clipboard-check"></i></span>
                            <span class="nav-link-title">Onay Merkezi</span>
                        </a>
                    </li>

                    <li class="nav-item text-uppercase text-secondary px-3 pt-2 pb-1 small fw-bold" style="font-size:0.68rem; letter-spacing:0.12em;">Yönetim</li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(hotelOpen ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavHotels" aria-expanded="@(hotelOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-hotel"></i></span>
                            <span class="nav-link-title">Konaklama</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(hotelOpen ? "show" : "")" id="adminNavHotels">
                            <div class="partner-subnav">
                                <a class="@Active("Hotels")" asp-controller="AdminPanel" asp-action="Hotels">Oteller</a>
                                <a class="@Active("ActiveHotels")" asp-controller="AdminPanel" asp-action="ActiveHotels">Açık Oteller</a>
                                <a class="@Active("PendingHotels")" asp-controller="AdminPanel" asp-action="PendingHotels">Bekleyen Oteller</a>
                                <a class="@Active("Campaigns")" asp-controller="AdminPanel" asp-action="Campaigns">Kampanyalar</a>
                                <a class="@Active("Reviews")" asp-controller="AdminPanel" asp-action="Reviews">Değerlendirmeler <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingReviews)</span></a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(commerceOpen ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavCommerce" aria-expanded="@(commerceOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-wallet"></i></span>
                            <span class="nav-link-title">Ticari Operasyon</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(commerceOpen ? "show" : "")" id="adminNavCommerce">
                            <div class="partner-subnav">
                                <a class="@Active("Reservations")" asp-controller="AdminPanel" asp-action="Reservations">Rezervasyonlar</a>
                                <a class="@Active("CompanyReservations")" asp-controller="AdminPanel" asp-action="CompanyReservations">Firma Rezervasyonları</a>
                                <a class="@Active("ListingSubscriptions")" asp-controller="AdminPanel" asp-action="ListingSubscriptions">Otel Liste Abonelikleri</a>
                                <a class="@Active("Payments")" asp-controller="AdminPanel" asp-action="Payments">Ödemeler</a>
                                <a class="@Active("Invoices")" asp-controller="AdminPanel" asp-action="Invoices">Faturalar</a>
                                <a class="@Active("Commissions")" asp-controller="AdminPanel" asp-action="Commissions">Komisyonlar</a>
                                <a class="@Active("Contracts")" asp-controller="AdminPanel" asp-action="Contracts">Sözleşmeler</a>
                                <a class="@Active("Reports")" asp-controller="AdminPanel" asp-action="Reports">Gelir / Komisyon Raporu</a>
                                <a class="@Active("CommerceInsight")" asp-controller="AdminPanel" asp-action="CommerceInsight">Ticari içgörü</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(userOpen ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavUsers" aria-expanded="@(userOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-users"></i></span>
                            <span class="nav-link-title">Kullanıcı ve Yetki</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(userOpen ? "show" : "")" id="adminNavUsers">
                            <div class="partner-subnav">
                                <a class="@Active("Users")" asp-controller="AdminPanel" asp-action="Users">Kullanıcılar</a>
                                <a class="@Active("Managers")" asp-controller="AdminPanel" asp-action="Managers">Yöneticiler</a>
                                <a class="@Active("PlatformOfficials")" asp-controller="AdminPanel" asp-action="PlatformOfficials">Platform Yetkilileri</a>
                                <a class="@Active("ApprovalCenter")" asp-controller="AdminPanel" asp-action="ApprovalCenter">Onay Merkezi</a>
                                <a class="@Active("DevelopmentRequests")" asp-controller="AdminPanel" asp-action="DevelopmentRequests">Geliştirme Talepleri</a>
                                <a class="@Active("PartnerApplications")" asp-controller="AdminPanel" asp-action="PartnerApplications">Partner Başvuruları <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingPartnerApplications)</span></a>
                                <a class="@Active("CompanyApplications")" asp-controller="AdminPanel" asp-action="CompanyApplications">Firma Başvuruları <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingCompanyApplications)</span></a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item text-uppercase text-secondary px-3 pt-3 pb-1 small fw-bold" style="font-size:0.68rem; letter-spacing:0.12em;">İçerik ve Sistem</li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(contentOpen ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavContent" aria-expanded="@(contentOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-bullhorn"></i></span>
                            <span class="nav-link-title">İletişim ve İçerik</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(contentOpen ? "show" : "")" id="adminNavContent">
                            <div class="partner-subnav">
                                <a class="@Active("Notifications")" asp-controller="AdminPanel" asp-action="Notifications">Bildirimler <span class="badge bg-azure-lt text-azure ms-1">@Badge(Model.UnreadNotifications)</span></a>
                                <a class="@Active("MailCenter")" asp-controller="AdminPanel" asp-action="MailCenter">Mail Merkezi</a>
                                <a class="@Active("EmailTemplates")" asp-controller="AdminPanel" asp-action="EmailTemplates">E-posta Hesapları</a>
                                <a class="@Active("WhatsAppCloudApi")" asp-controller="AdminPanel" asp-action="WhatsAppCloudApi">WhatsApp Cloud API</a>
                                <a class="@Active("Blog")" asp-controller="AdminPanel" asp-action="Blog">Blog Yönetimi</a>
                                <a class="@Active("Faq")" asp-controller="AdminPanel" asp-action="Faq">SSS Yönetimi</a>
                                <a class="@Active("SupportArticles")" asp-controller="AdminPanel" asp-action="SupportArticles">Destek Makaleleri</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(systemOpen ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavSystem" aria-expanded="@(systemOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-shield-halved"></i></span>
                            <span class="nav-link-title">Sistem ve Güvenlik</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(systemOpen ? "show" : "")" id="adminNavSystem">
                            <div class="partner-subnav">
                                <a class="@Active("Settings")" asp-controller="AdminPanel" asp-action="Settings">Ayarlar</a>
                                <a class="@Active("Sitemap")" asp-controller="AdminPanel" asp-action="Sitemap">Sitemap XML</a>
                                <a class="@Active("Security")" asp-controller="AdminPanel" asp-action="Security">Güvenlik</a>
                                <a class="@Active("Complaints")" asp-controller="AdminPanel" asp-action="Complaints">Şikayetler</a>
                                <a class="@Active("Backups")" asp-controller="AdminPanel" asp-action="Backups">Yedekleme</a>
                                <a class="@Active("Logs")" asp-controller="AdminPanel" asp-action="Logs">Log Kayıtları <span class="badge bg-warning-lt text-warning ms-1">@Badge(Model.CriticalLogs)</span></a>
                                <a class="@Active("GeoSearchLogs")" asp-controller="AdminPanel" asp-action="GeoSearchLogs">Konum Arama Logları</a>
                                <a class="@Active("HotelCoordinateChanges")" asp-controller="AdminPanel" asp-action="HotelCoordinateChanges">Otel Koordinat Değişimleri</a>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="partner-sidebar-footer">
                <div class="partner-footer-actions">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Site
                    </a>
                    <form method="post" action="/cikis-yap" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fas fa-right-from-bracket me-1"></i>Çıkış
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</aside>
