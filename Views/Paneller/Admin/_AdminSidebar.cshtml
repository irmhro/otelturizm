@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";

    string Active(string action) => currentAction == action ? "active" : string.Empty;
}

<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a asp-controller="AdminPanel" asp-action="Dashboard" class="brand-link justify-content-center">
        <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="brand-image img-circle elevation-3 admin-brand-logo" />
    </a>

    <div class="sidebar">
        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="image">
                <i class="fas fa-user-circle text-white fa-2x"></i>
            </div>
            <div class="info">
                <a href="#" class="d-block">@Model.FullName</a>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column nav-compact text-sm" data-widget="treeview" role="menu" data-accordion="false">
                <li class="nav-item">
                    <a asp-controller="AdminPanel" asp-action="Dashboard" class="nav-link @Active("Dashboard")">
                        <i class="nav-icon fas fa-tachometer-alt"></i><p>Dashboard</p>
                    </a>
                </li>

                <li class="nav-header">CORE</li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Hotels" class="nav-link @Active("Hotels")"><i class="nav-icon fas fa-hotel"></i><p>Oteller</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Reservations" class="nav-link @Active("Reservations")"><i class="nav-icon fas fa-calendar-check"></i><p>Rezervasyonlar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Payments" class="nav-link @Active("Payments")"><i class="nav-icon fas fa-credit-card"></i><p>Ödemeler</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Users" class="nav-link @Active("Users")"><i class="nav-icon fas fa-users"></i><p>Kullanıcılar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Managers" class="nav-link @Active("Managers")"><i class="nav-icon fas fa-user-tie"></i><p>Yöneticiler</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="PartnerApplications" class="nav-link @Active("PartnerApplications")"><i class="nav-icon fas fa-handshake"></i><p>Partner Başvuruları <span class="right badge badge-warning">@(Model.PendingPartnerApplications)</span></p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Reviews" class="nav-link @Active("Reviews")"><i class="nav-icon fas fa-star"></i><p>Değerlendirmeler <span class="right badge badge-info">@(Model.PendingReviews)</span></p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Campaigns" class="nav-link @Active("Campaigns")"><i class="nav-icon fas fa-bullhorn"></i><p>Kampanyalar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Invoices" class="nav-link @Active("Invoices")"><i class="nav-icon fas fa-file-invoice"></i><p>Faturalar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Commissions" class="nav-link @Active("Commissions")"><i class="nav-icon fas fa-percent"></i><p>Komisyonlar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Contracts" class="nav-link @Active("Contracts")"><i class="nav-icon fas fa-file-contract"></i><p>Sözleşmeler</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Notifications" class="nav-link @Active("Notifications")"><i class="nav-icon fas fa-bell"></i><p>Bildirimler <span class="right badge badge-warning">@(Model.UnreadNotifications)</span></p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="EmailTemplates" class="nav-link @Active("EmailTemplates")"><i class="nav-icon fas fa-envelope"></i><p>E-posta Şablonları</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="WhatsAppCloudApi" class="nav-link @Active("WhatsAppCloudApi")"><i class="nav-icon fab fa-whatsapp"></i><p>WhatsApp Cloud API</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Logs" class="nav-link @Active("Logs")"><i class="nav-icon fas fa-clipboard-list"></i><p>Log Kayıtları <span class="right badge badge-danger">@(Model.CriticalLogs)</span></p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Reports" class="nav-link @Active("Reports")"><i class="nav-icon fas fa-chart-line"></i><p>Raporlar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Blog" class="nav-link @Active("Blog")"><i class="nav-icon fas fa-blog"></i><p>Blog Yönetimi</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Faq" class="nav-link @Active("Faq")"><i class="nav-icon fas fa-question-circle"></i><p>SSS Yönetimi</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Settings" class="nav-link @Active("Settings")"><i class="nav-icon fas fa-cog"></i><p>Ayarlar</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Security" class="nav-link @Active("Security")"><i class="nav-icon fas fa-shield-alt"></i><p>Güvenlik</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Complaints" class="nav-link @Active("Complaints")"><i class="nav-icon fas fa-exclamation-triangle"></i><p>Şikayetler</p></a></li>
                <li class="nav-item"><a asp-controller="AdminPanel" asp-action="Backups" class="nav-link @Active("Backups")"><i class="nav-icon fas fa-database"></i><p>Yedekleme</p></a></li>

                <li class="nav-header">ADMINLTE ROADMAP</li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Widgets New</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Layout Options</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Charts</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Forms</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Tables</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Calendar</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Gallery</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Kanban Board</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Mailbox</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Pages & Extras</p></a></li>
                <li class="nav-item"><a href="#" class="nav-link"><i class="nav-icon far fa-circle text-info"></i><p>Documentation</p></a></li>
            </ul>
        </nav>

        <div class="mt-3 px-2 pb-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-block btn-sm">
                <i class="fas fa-arrow-left mr-1"></i> Ana Sayfaya Dön
            </a>
            <form method="post" action="/cikis-yap" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-block btn-sm">
                    <i class="fas fa-sign-out-alt mr-1"></i> Çıkış Yap
                </button>
            </form>
        </div>
    </div>
</aside>
