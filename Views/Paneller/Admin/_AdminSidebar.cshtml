@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsActive(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    string Active(string action) => IsActive(action) ? "active" : string.Empty;
    bool Can(string code) => Model.Permissions.Contains("*") || Model.HasPermission(code);

    int BadgeValue(string? badgeKey) => badgeKey switch
    {
        "PendingPartnerApplications" => Model.PendingPartnerApplications,
        "PendingCompanyApplications" => Model.PendingCompanyApplications,
        "PendingReviews" => Model.PendingReviews,
        "UnreadNotifications" => Model.UnreadNotifications,
        "CriticalLogs" => Model.CriticalLogs,
        "PendingApprovals" => Model.PendingPartnerApplications + Model.PendingCompanyApplications,
        _ => 0
    };

    string BadgeText(string? badgeKey)
    {
        var value = BadgeValue(badgeKey);
        return value > 0 ? value.ToString() : string.Empty;
    }

    bool IsItemActive(AdminNavigationCatalog.AdminNavItem item)
    {
        var actions = item.ActiveActions ?? [item.Action];
        return actions.Any(IsActive);
    }

    bool CanSeeItem(AdminNavigationCatalog.AdminNavItem item) => Can(item.Permission);

    bool CanSeeGroup(AdminNavigationCatalog.AdminNavGroup group)
        => group.Items.Any(CanSeeItem);
}
<aside class="admin-sidebar" id="appSidebar" aria-label="Admin menüsü">
    <div class="sidebar-header">
        <a asp-controller="AdminPanel" asp-action="Dashboard" class="logo-wordmark-wrapper">
            <span class="logo-wordmark">
                <span class="logo-otel">OTEL</span><span class="logo-turizm">TURİZM</span>
            </span>
        </a>
    </div>

    <div class="sidebar-scroll">
        @foreach (var group in AdminNavigationCatalog.GetGroups())
        {
            if (!CanSeeGroup(group))
            {
                continue;
            }

            var visibleItems = group.Items.Where(CanSeeItem).ToList();
            var groupOpen = visibleItems.Any(IsItemActive);

            <span class="sidebar-group-label">@group.Label</span>
            <div class="nav-menu-item @(groupOpen ? "open active" : "")" data-nav-group>
                <button type="button" class="nav-main-link" data-admin-nav-toggle aria-expanded="@(groupOpen ? "true" : "false")">
                    <div class="nav-link-left"><i class="fas @group.IconClass @group.IconTone"></i><span>@group.MenuTitle</span></div>
                    <i class="fas fa-chevron-down chevron-icon"></i>
                </button>
                <div class="sub-links-container">
                    @foreach (var item in visibleItems)
                    {
                        var activeClass = IsItemActive(item) ? "active" : string.Empty;
                        var badge = BadgeText(item.BadgeKey);
                        <a class="@activeClass" asp-controller="AdminPanel" asp-action="@item.Action">
                            @item.Label
                            @if (!string.IsNullOrEmpty(badge))
                            {
                                <span class="ap-nav-badge">@badge</span>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</aside>
