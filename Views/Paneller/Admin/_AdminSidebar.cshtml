@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var items = new[]
    {
        new { Action = "Dashboard", Label = "Dashboard", Icon = "fa-tachometer-alt", Badge = "" },
        new { Action = "Hotels", Label = "Oteller", Icon = "fa-hotel", Badge = "" },
        new { Action = "Reservations", Label = "Rezervasyonlar", Icon = "fa-calendar-check", Badge = "" },
        new { Action = "Payments", Label = "Ödemeler", Icon = "fa-credit-card", Badge = "" },
        new { Action = "Users", Label = "Kullanıcılar", Icon = "fa-users", Badge = "" },
        new { Action = "Managers", Label = "Yöneticiler", Icon = "fa-user-tie", Badge = "" },
        new { Action = "PartnerApplications", Label = "Partner Başvuruları", Icon = "fa-handshake", Badge = Model.PendingPartnerApplications > 0 ? Model.PendingPartnerApplications.ToString() : "" },
        new { Action = "Reviews", Label = "Değerlendirmeler", Icon = "fa-star", Badge = Model.PendingReviews > 0 ? Model.PendingReviews.ToString() : "" },
        new { Action = "Campaigns", Label = "Kampanyalar", Icon = "fa-bullhorn", Badge = "" },
        new { Action = "Invoices", Label = "Faturalar", Icon = "fa-file-invoice", Badge = "" },
        new { Action = "Commissions", Label = "Komisyonlar", Icon = "fa-percent", Badge = "" },
        new { Action = "Contracts", Label = "Sözleşmeler", Icon = "fa-file-contract", Badge = "" },
        new { Action = "Notifications", Label = "Bildirimler", Icon = "fa-bell", Badge = Model.UnreadNotifications > 0 ? Model.UnreadNotifications.ToString() : "" },
        new { Action = "EmailTemplates", Label = "E-posta Şablonları", Icon = "fa-envelope", Badge = "" },
        new { Action = "Logs", Label = "Log Kayıtları", Icon = "fa-clipboard-list", Badge = Model.CriticalLogs > 0 ? Model.CriticalLogs.ToString() : "" },
        new { Action = "Reports", Label = "Raporlar", Icon = "fa-chart-line", Badge = "" },
        new { Action = "Blog", Label = "Blog Yönetimi", Icon = "fa-blog", Badge = "" },
        new { Action = "Faq", Label = "SSS Yönetimi", Icon = "fa-question-circle", Badge = "" },
        new { Action = "Settings", Label = "Ayarlar", Icon = "fa-cog", Badge = "" },
        new { Action = "Security", Label = "Güvenlik", Icon = "fa-shield-alt", Badge = "" },
        new { Action = "Complaints", Label = "Şikayetler", Icon = "fa-exclamation-triangle", Badge = "" },
        new { Action = "Backups", Label = "Yedekleme", Icon = "fa-database", Badge = "" }
    };
}

<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a asp-controller="AdminPanel" asp-action="Dashboard" class="brand-link">
        <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="brand-image img-circle elevation-3" style="opacity: .8" />
        <span class="brand-text font-weight-light">Otelturizm Admin</span>
    </a>

    <div class="sidebar">
        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="image">
                <i class="fas fa-user-circle text-white fa-2x"></i>
            </div>
            <div class="info">
                <a href="#" class="d-block">@Model.FullName</a>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column nav-compact text-sm" data-widget="treeview" role="menu" data-accordion="false">
                @foreach (var item in items)
                {
                    var active = currentAction == item.Action;
                    <li class="nav-item">
                        <a asp-controller="AdminPanel" asp-action="@item.Action" class="nav-link @(active ? "active" : string.Empty)">
                            <i class="nav-icon fas @item.Icon"></i>
                            <p>
                                @item.Label
                                @if (!string.IsNullOrWhiteSpace(item.Badge))
                                {
                                    <span class="right badge badge-warning">@item.Badge</span>
                                }
                            </p>
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <div class="mt-3 px-2 pb-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-block btn-sm">
                <i class="fas fa-arrow-left mr-1"></i> Ana Sayfaya Dön
            </a>
            <form method="post" action="/cikis-yap" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-block btn-sm">
                    <i class="fas fa-sign-out-alt mr-1"></i> Çıkış Yap
                </button>
            </form>
        </div>
    </div>
</aside>
