@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsActive(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    string Active(string action) => IsActive(action) ? "active" : string.Empty;
    string Badge(int value) => value > 0 ? value.ToString() : "0";
    bool IsOpen(params string[] actions) => actions.Any(IsActive);
}

<aside class="main-sidebar sidebar-dark-primary elevation-4 admin-accordion-sidebar">
    <div class="sidebar">
        <div class="admin-sidebar-sticky-top">
            <a asp-controller="AdminPanel" asp-action="Dashboard" class="admin-sidebar-brand">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="admin-brand-logo" />
                <span class="admin-brand-badge">ADMIN</span>
            </a>

            <div class="admin-sidebar-profile">
                <div class="admin-sidebar-avatar">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div>
                    <h3>@Model.FullName</h3>
                    <p>@Model.Email</p>
                </div>
            </div>
        </div>

        <nav class="admin-sidebar-accordion" aria-label="Admin gezinti">
            <p class="admin-sidebar-section-title">Genel</p>
            <a asp-controller="AdminPanel" asp-action="Dashboard" class="admin-sidebar-link standalone @Active("Dashboard")">
                <span class="admin-sidebar-link-icon"><i class="fas fa-table-columns"></i></span>
                <span>Panel Özeti</span>
            </a>

            <p class="admin-sidebar-section-title">Yönetim</p>
            <section class="admin-sidebar-group @(IsOpen("Hotels", "ActiveHotels", "PendingHotels", "Campaigns", "Reviews") ? "open" : string.Empty)">
                <button type="button" class="admin-sidebar-group-toggle" data-admin-accordion="group">
                    <span class="admin-sidebar-group-meta">
                        <span class="admin-sidebar-link-icon"><i class="fas fa-hotel"></i></span>
                        <span>
                            <strong>Konaklama Yönetimi</strong>
                            <small>Otel, kampanya ve kalite</small>
                        </span>
                    </span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="admin-sidebar-group-body">
                    <a asp-controller="AdminPanel" asp-action="Hotels" class="admin-sidebar-link @Active("Hotels")"><span>Oteller</span></a>
                    <a asp-controller="AdminPanel" asp-action="ActiveHotels" class="admin-sidebar-link @Active("ActiveHotels")"><span>Açık Oteller</span></a>
                    <a asp-controller="AdminPanel" asp-action="PendingHotels" class="admin-sidebar-link @Active("PendingHotels")"><span>Bekleyen Oteller</span></a>
                    <a asp-controller="AdminPanel" asp-action="Campaigns" class="admin-sidebar-link @Active("Campaigns")"><span>Kampanyalar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Reviews" class="admin-sidebar-link @Active("Reviews")"><span>Değerlendirmeler</span><strong>@Badge(Model.PendingReviews)</strong></a>
                </div>
            </section>

            <section class="admin-sidebar-group @(IsOpen("Reservations", "Payments", "Invoices", "Commissions", "Contracts", "Reports") ? "open" : string.Empty)">
                <button type="button" class="admin-sidebar-group-toggle" data-admin-accordion="group">
                    <span class="admin-sidebar-group-meta">
                        <span class="admin-sidebar-link-icon"><i class="fas fa-wallet"></i></span>
                        <span>
                            <strong>Ticari Operasyon</strong>
                            <small>Rezervasyon, ödeme ve gelir</small>
                        </span>
                    </span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="admin-sidebar-group-body">
                    <a asp-controller="AdminPanel" asp-action="Reservations" class="admin-sidebar-link @Active("Reservations")"><span>Rezervasyonlar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Payments" class="admin-sidebar-link @Active("Payments")"><span>Ödemeler</span></a>
                    <a asp-controller="AdminPanel" asp-action="Invoices" class="admin-sidebar-link @Active("Invoices")"><span>Faturalar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Commissions" class="admin-sidebar-link @Active("Commissions")"><span>Komisyonlar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Contracts" class="admin-sidebar-link @Active("Contracts")"><span>Sözleşmeler</span></a>
                    <a asp-controller="AdminPanel" asp-action="Reports" class="admin-sidebar-link @Active("Reports")"><span>Gelir / Komisyon Raporu</span></a>
                </div>
            </section>

            <section class="admin-sidebar-group @(IsOpen("Users", "Managers", "PlatformOfficials", "PartnerApplications", "CompanyApplications") ? "open" : string.Empty)">
                <button type="button" class="admin-sidebar-group-toggle" data-admin-accordion="group">
                    <span class="admin-sidebar-group-meta">
                        <span class="admin-sidebar-link-icon"><i class="fas fa-users"></i></span>
                        <span>
                            <strong>Kullanıcı ve Yetki</strong>
                            <small>Hesap, rol ve başvuru</small>
                        </span>
                    </span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="admin-sidebar-group-body">
                    <a asp-controller="AdminPanel" asp-action="Users" class="admin-sidebar-link @Active("Users")"><span>Kullanıcılar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Managers" class="admin-sidebar-link @Active("Managers")"><span>Yöneticiler</span></a>
                    <a asp-controller="AdminPanel" asp-action="PlatformOfficials" class="admin-sidebar-link @Active("PlatformOfficials")"><span>Platform Yetkilileri</span></a>
                    <a asp-controller="AdminPanel" asp-action="PartnerApplications" class="admin-sidebar-link @Active("PartnerApplications")"><span>Partner Başvuruları</span><strong>@Badge(Model.PendingPartnerApplications)</strong></a>
                    <a asp-controller="AdminPanel" asp-action="CompanyApplications" class="admin-sidebar-link @Active("CompanyApplications")"><span>Firma Başvuruları</span><strong>@Badge(Model.PendingCompanyApplications)</strong></a>
                </div>
            </section>

            <p class="admin-sidebar-section-title">İçerik ve Sistem</p>
            <section class="admin-sidebar-group @(IsOpen("Notifications", "EmailTemplates", "WhatsAppCloudApi", "Blog", "Faq") ? "open" : string.Empty)">
                <button type="button" class="admin-sidebar-group-toggle" data-admin-accordion="group">
                    <span class="admin-sidebar-group-meta">
                        <span class="admin-sidebar-link-icon"><i class="fas fa-bullhorn"></i></span>
                        <span>
                            <strong>İletişim ve İçerik</strong>
                            <small>Mesajlaşma, şablon ve içerik</small>
                        </span>
                    </span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="admin-sidebar-group-body">
                    <a asp-controller="AdminPanel" asp-action="Notifications" class="admin-sidebar-link @Active("Notifications")"><span>Bildirimler</span><strong>@Badge(Model.UnreadNotifications)</strong></a>
                    <a asp-controller="AdminPanel" asp-action="EmailTemplates" class="admin-sidebar-link @Active("EmailTemplates")"><span>E-posta Şablonları</span></a>
                    <a asp-controller="AdminPanel" asp-action="WhatsAppCloudApi" class="admin-sidebar-link @Active("WhatsAppCloudApi")"><span>WhatsApp Cloud API</span></a>
                    <a asp-controller="AdminPanel" asp-action="Blog" class="admin-sidebar-link @Active("Blog")"><span>Blog Yönetimi</span></a>
                    <a asp-controller="AdminPanel" asp-action="Faq" class="admin-sidebar-link @Active("Faq")"><span>SSS Yönetimi</span></a>
                </div>
            </section>

            <section class="admin-sidebar-group @(IsOpen("Settings", "Security", "Complaints", "Backups", "Logs") ? "open" : string.Empty)">
                <button type="button" class="admin-sidebar-group-toggle" data-admin-accordion="group">
                    <span class="admin-sidebar-group-meta">
                        <span class="admin-sidebar-link-icon"><i class="fas fa-shield-halved"></i></span>
                        <span>
                            <strong>Sistem ve Güvenlik</strong>
                            <small>Ayar, log, yedekleme ve denetim</small>
                        </span>
                    </span>
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="admin-sidebar-group-body">
                    <a asp-controller="AdminPanel" asp-action="Settings" class="admin-sidebar-link @Active("Settings")"><span>Ayarlar</span></a>
                    <a asp-controller="AdminPanel" asp-action="Security" class="admin-sidebar-link @Active("Security")"><span>Güvenlik</span></a>
                    <a asp-controller="AdminPanel" asp-action="Complaints" class="admin-sidebar-link @Active("Complaints")"><span>Şikayetler</span></a>
                    <a asp-controller="AdminPanel" asp-action="Backups" class="admin-sidebar-link @Active("Backups")"><span>Yedekleme</span></a>
                    <a asp-controller="AdminPanel" asp-action="Logs" class="admin-sidebar-link @Active("Logs")"><span>Log Kayıtları</span><strong>@Badge(Model.CriticalLogs)</strong></a>
                </div>
            </section>
        </nav>

        <div class="admin-sidebar-actions">
            <a asp-controller="Home" asp-action="Index" class="admin-sidebar-secondary-link">
                <i class="fas fa-arrow-left"></i>
                <span>Ana Sayfaya Dön</span>
            </a>
            <form method="post" action="/cikis-yap" class="admin-sidebar-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="admin-sidebar-logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Çıkış Yap</span>
                </button>
            </form>
        </div>
    </div>
</aside>
