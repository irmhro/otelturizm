@using otelturizmnew.Models.Paneller.Admin
@model AdminSettingsMonitorPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Kritik Ayarlar (Read-only)</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>Anahtar</th>
                    <th>Değer</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var kv in Model.Items)
                {
                    <tr>
                        <td><code>@kv.Key</code></td>
                        <td style="max-width:720px;white-space:normal;">@kv.Value</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

