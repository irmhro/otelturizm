@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var fn = Model.FullName?.Trim() ?? string.Empty;
    var initial = fn.Length > 0 ? char.ToUpper(fn[0]).ToString() : "A";
    var hasNotifications = Model.UnreadNotifications > 0;
    var returnUrl = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
}
<header class="global-topbar" role="banner">
    <div class="topbar-left">
        <button type="button" class="menu-trigger" id="adminSidebarToggle" aria-label="Menüyü aç/kapat">
            <i class="fas fa-bars-staggered"></i>
        </button>
        <div class="header-search">
            <i class="fas fa-search"></i>
            <input type="search" id="adminGlobalSearch" placeholder="PNR, Otel ID, Acente veya Misafir ara..." autocomplete="off" />
            <span class="search-shortcut">Ctrl+K</span>
        </div>
    </div>

    <div class="topbar-right">
        <a asp-controller="Home" asp-action="Index" class="lang-currency-btn ap-hide-mobile" title="Siteye dön">
            <i class="fas fa-arrow-up-right-from-square"></i>
            <span>Site</span>
        </a>
        <a href="/locale/set?lang=tr&returnUrl=@returnUrl" class="lang-currency-btn ap-hide-mobile" title="Dil">
            <span>TR</span>
        </a>
        <a href="/currency/set?currency=TRY&returnUrl=@returnUrl" class="lang-currency-btn ap-hide-mobile" title="Para birimi">
            <span>TRY</span>
        </a>
        <button type="button" class="utility-btn ap-hide-mobile" id="adminThemeOpen" aria-label="Tema ayarları">
            <i class="fas fa-palette"></i>
        </button>
        <a asp-controller="AdminPanel" asp-action="Notifications" class="utility-btn" title="Bildirimler">
            <i class="far fa-bell"></i>
            @if (hasNotifications)
            {
                <span class="bell-dot"></span>
            }
        </a>
        <a asp-controller="AdminPanel" asp-action="ApprovalCenter" class="btn-quick-add">
            <i class="fas fa-plus"></i>
            <span class="ap-hide-mobile">Hızlı İşlem</span>
        </a>

        <div class="profile-dropdown-wrapper">
            <div class="avatar-trigger" id="adminAvatarBtn" role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
                <span class="header-avatar">@initial</span>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="profile-dropdown" id="adminProfileDropdown">
                <div class="dropdown-header">
                    <strong>@Model.FullName</strong>
                    <span>@Model.Email</span>
                </div>
                <ul class="dropdown-menu-list">
                    <li><a asp-controller="AdminPanel" asp-action="Settings"><i class="fas fa-user-circle"></i> Hesabım</a></li>
                    <li><a asp-controller="AdminPanel" asp-action="Team"><i class="fas fa-building"></i> Organizasyon Ayarları</a></li>
                    <li><a asp-controller="AdminPanel" asp-action="Security"><i class="fas fa-shield-alt"></i> Güvenlik / 2FA</a></li>
                    <li><a href="/yardim-merkezi" target="_blank" rel="noopener"><i class="fas fa-circle-question"></i> Yardım Merkezi</a></li>
                    <li><div class="dropdown-divider"></div></li>
                    <li>
                        <form method="post" action="/cikis-yap" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-danger"><i class="fas fa-sign-out-alt"></i> Güvenli Çıkış</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>
