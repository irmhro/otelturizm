@using otelturizmnew.Models.Paneller.Admin
@model AdminSystemHealthPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">Canlı Sağlık Kontrolleri</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover text-nowrap mb-0">
                    <thead>
                    <tr>
                        <th>Kontrol</th>
                        <th>Durum</th>
                        <th>Detay</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Checks)
                    {
                        var badge = item.ToneClass switch
                        {
                            "success" => "badge-success",
                            "warning" => "badge-warning",
                            "danger" => "badge-danger",
                            _ => "badge-info"
                        };
                        <tr>
                            <td><strong>@item.Title</strong></td>
                            <td><span class="badge @badge ot-badge">@item.StatusText</span></td>
                            <td class="text-muted">@item.Detail</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-secondary">
            <div class="card-header">
                <h3 class="card-title">Kuyruklar</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover text-nowrap mb-0">
                    <thead>
                    <tr>
                        <th>Kuyruk</th>
                        <th>Beklemede</th>
                        <th>Başarısız</th>
                        <th>En Eski Bekleyen</th>
                        <th>Not</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var q in Model.Queues)
                    {
                        <tr>
                            <td><strong>@q.QueueName</strong></td>
                            <td>@q.PendingCount</td>
                            <td>@q.FailedCount</td>
                            <td>@q.OldestPendingText</td>
                            <td class="text-muted">@q.Note</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

