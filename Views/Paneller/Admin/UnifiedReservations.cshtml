@using otelturizmnew.Models.Paneller.Admin
@model AdminUnifiedReservationsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Rezervasyonlar (Tek Liste)</h3>
    </div>
    <div class="card-body">
        <form method="get" action="/admin/rezervasyonlar-tek-liste" class="row g-2">
            <div class="col-md-6">
                <label class="form-label">Ara</label>
                <input class="form-control form-control-sm" name="q" value="@Model.Query" placeholder="Otel / müşteri / email / firma" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Durum</label>
                <input class="form-control form-control-sm" name="status" value="@Model.Status" placeholder="örn: Onaylandı" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-sm btn-primary w-100" type="submit">Filtrele</button>
            </div>
        </form>

        <div class="table-responsive mt-3">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Otel</th>
                    <th>Müşteri</th>
                    <th>Firma</th>
                    <th>Durum</th>
                    <th>Tutar</th>
                    <th>Tarih (UTC)</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.ReservationId</td>
                        <td>@row.HotelName</td>
                        <td>
                            <div>@row.CustomerName</div>
                            <div class="text-muted small">@row.CustomerEmail</div>
                        </td>
                        <td>@row.CompanyName</td>
                        <td>@row.Status</td>
                        <td>@row.TotalAmount.ToString("N2") @row.Currency</td>
                        <td>@row.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="text-muted small">Toplam: @Model.Total</div>
    </div>
</div>

