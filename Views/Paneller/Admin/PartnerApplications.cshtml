@model otelturizmnew.Models.Paneller.Admin.AdminPartnerApplicationsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>@card.Value</h3>
                    <p>@card.Label</p>
                    <small>@card.Description</small>
                </div>
                <div class="icon"><i class="fas @card.IconClass"></i></div>
            </div>
        </div>
    }
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Partner başvuru listesi</h3>
    </div>
    <div class="card-body">
        @if (Model.Applications.Count == 0)
        {
            <div class="alert alert-secondary mb-0">Bekleyen partner başvurusu bulunmuyor.</div>
        }
        else
        {
            @foreach (var application in Model.Applications)
            {
                <div class="card card-outline card-primary mb-3">
                    <div class="card-header">
                        <h3 class="card-title">@application.CompanyName</h3>
                        <div class="card-tools">
                            <span class="badge @(application.StatusToneClass?.Contains("danger") == true ? "badge-danger" : "badge-warning")">@application.StatusText</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6"><strong>Otel:</strong> @application.HotelName</div>
                            <div class="col-md-6"><strong>Yetkili:</strong> @application.ContactName</div>
                            <div class="col-md-6"><strong>E-posta:</strong> @application.Email</div>
                            <div class="col-md-6"><strong>Vergi No:</strong> @application.TaxNumber</div>
                            <div class="col-md-6"><strong>Kayıt:</strong> @application.RegistrationDateText</div>
                            <div class="col-md-6"><strong>E-posta Onayı:</strong> @(application.EmailVerified ? "Tamamlandı" : "Bekleniyor")</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(application.ReviewNote))
                        {
                            <div class="alert alert-light border">@application.ReviewNote</div>
                        }

                        <form method="post" action="/admin/partner-basvurulari/durum">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="PartnerId" value="@application.PartnerId" />
                            <div class="row">
                                <div class="col-md-4 form-group">
                                    <label>Karar</label>
                                    <select name="TargetStatus" class="form-control">
                                        <option value="Onaylandi" selected="@(application.StatusText == "Onaylandi" ? "selected" : null)">Onayla</option>
                                        <option value="Askida" selected="@(application.StatusText == "Askida" ? "selected" : null)">Askıya al</option>
                                        <option value="Reddedildi" selected="@(application.StatusText == "Reddedildi" ? "selected" : null)">Reddet</option>
                                    </select>
                                </div>
                                <div class="col-md-8 form-group">
                                    <label>Not</label>
                                    <textarea name="Note" rows="2" class="form-control" placeholder="Partnera gösterilecek not">@application.ReviewNote</textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Kararı Kaydet</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>
