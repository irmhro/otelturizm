@model otelturizmnew.Models.Paneller.Developer.AdminDevelopmentRequestsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["Title"] = "Gelistirme Talepleri";
}

<section class="admin-users-page admin-development-page">
    @if (TempData["AdminMessage"] is string successMessage)
    {
        <div class="admin-inline-status success ot-card">@successMessage</div>
    }

    @if (TempData["AdminError"] is string errorMessage)
    {
        <div class="admin-inline-status error ot-card">@errorMessage</div>
    }

    <section class="admin-users-summary-grid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="admin-summary-card @card.ToneClass">
                <p>@card.Label</p>
                <strong>@card.Value</strong>
                <span>@card.Description</span>
            </article>
        }
    </section>

    <section class="admin-users-toolbar">
        <form method="get" asp-action="DevelopmentRequests" class="admin-development-filters">
            <input type="search" name="q" value="@Model.SearchText" placeholder="Baslik veya aciklama ara" />
            <select name="status">
                <option value="all" selected="@(Model.StatusFilter == "all" ? "selected" : null)">Tum durumlar</option>
                <option value="Yeni" selected="@(Model.StatusFilter == "Yeni" ? "selected" : null)">Yeni</option>
                <option value="Planlandi" selected="@(Model.StatusFilter == "Planlandi" ? "selected" : null)">Planlandi</option>
                <option value="Devam Ediyor" selected="@(Model.StatusFilter == "Devam Ediyor" ? "selected" : null)">Devam Ediyor</option>
                <option value="Kontrol Bekliyor" selected="@(Model.StatusFilter == "Kontrol Bekliyor" ? "selected" : null)">Kontrol Bekliyor</option>
                <option value="Tamamlandi" selected="@(Model.StatusFilter == "Tamamlandi" ? "selected" : null)">Tamamlandi</option>
                <option value="Reddedildi" selected="@(Model.StatusFilter == "Reddedildi" ? "selected" : null)">Reddedildi</option>
            </select>
            <select name="priority">
                <option value="all" selected="@(Model.PriorityFilter == "all" ? "selected" : null)">Tum oncelikler</option>
                <option value="Kritik" selected="@(Model.PriorityFilter == "Kritik" ? "selected" : null)">Kritik</option>
                <option value="Yuksek" selected="@(Model.PriorityFilter == "Yuksek" ? "selected" : null)">Yuksek</option>
                <option value="Orta" selected="@(Model.PriorityFilter == "Orta" ? "selected" : null)">Orta</option>
                <option value="Dusuk" selected="@(Model.PriorityFilter == "Dusuk" ? "selected" : null)">Dusuk</option>
            </select>
            <select name="developerUserId">
                <option value="">Tum developerlar</option>
                @foreach (var developer in Model.Developers)
                {
                    <option value="@developer.UserId" selected="@(developer.IsSelected ? "selected" : null)">@developer.FullName</option>
                }
            </select>
            <button type="submit" class="admin-toolbar-search ot-btn ot-btn--primary">Filtrele</button>
        </form>
    </section>

    <section class="admin-development-list">
        @foreach (var request in Model.Requests)
        {
            <article class="admin-development-card ot-card">
                <div class="admin-development-card-head">
                    <div>
                        <div class="admin-development-chip-row">
                            <span class="developer-chip @request.PriorityToneClass ot-badge">@request.Priority</span>
                            <span class="developer-chip status @request.StatusToneClass ot-badge">@request.Status</span>
                        </div>
                        <h2>@request.Title</h2>
                        <p>@request.Description</p>
                    </div>
                    <div class="admin-development-meta">
                        <span>Olusturan: @request.CreatorName</span>
                        <span>Atanan: @(string.IsNullOrWhiteSpace(request.AssignedDeveloperName) ? "Planlanmadi" : request.AssignedDeveloperName)</span>
                        <span>Olusturulma: @request.CreatedAtText</span>
                        <span>Son hareket: @request.LastActivityText</span>
                    </div>
                </div>

                <div class="admin-development-grid">
                    <div class="admin-development-activity-list">
                        @foreach (var activity in request.Activities)
                        {
                            <article class="developer-activity-item">
                                <div class="developer-activity-dot"></div>
                                <div>
                                    <strong>@activity.ActivityLabel · @activity.SourceRoleLabel</strong>
                                    <p>@activity.Message</p>
                                    <span>@activity.SourceName · @activity.CreatedAtText</span>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="admin-development-side-forms">
                        <form method="post" asp-action="SaveDevelopmentRequest" enctype="multipart/form-data" class="admin-development-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="RequestId" value="@request.RequestId" />
                            <label><span>Baslik</span><input type="text" name="Title" value="@request.AdminForm.Title" required /></label>
                            <label><span>Oncelik</span>
                                <select name="Priority">
                                    <option value="Kritik" selected="@(request.AdminForm.Priority == "Kritik" ? "selected" : null)">Kritik</option>
                                    <option value="Yuksek" selected="@(request.AdminForm.Priority == "Yuksek" ? "selected" : null)">Yuksek</option>
                                    <option value="Orta" selected="@(request.AdminForm.Priority == "Orta" ? "selected" : null)">Orta</option>
                                    <option value="Dusuk" selected="@(request.AdminForm.Priority == "Dusuk" ? "selected" : null)">Dusuk</option>
                                </select>
                            </label>
                            <label><span>Durum</span>
                                <select name="Status">
                                    <option value="Yeni" selected="@(request.AdminForm.Status == "Yeni" ? "selected" : null)">Yeni</option>
                                    <option value="Planlandi" selected="@(request.AdminForm.Status == "Planlandi" ? "selected" : null)">Planlandi</option>
                                    <option value="Devam Ediyor" selected="@(request.AdminForm.Status == "Devam Ediyor" ? "selected" : null)">Devam Ediyor</option>
                                    <option value="Kontrol Bekliyor" selected="@(request.AdminForm.Status == "Kontrol Bekliyor" ? "selected" : null)">Kontrol Bekliyor</option>
                                    <option value="Kontrol Ediliyor" selected="@(request.AdminForm.Status == "Kontrol Ediliyor" ? "selected" : null)">Kontrol Ediliyor</option>
                                    <option value="Tamamlandi" selected="@(request.AdminForm.Status == "Tamamlandi" ? "selected" : null)">Tamamlandi</option>
                                    <option value="Reddedildi" selected="@(request.AdminForm.Status == "Reddedildi" ? "selected" : null)">Reddedildi</option>
                                    <option value="Ek Gelistirme Istendi" selected="@(request.AdminForm.Status == "Ek Gelistirme Istendi" ? "selected" : null)">Ek Gelistirme Istendi</option>
                                </select>
                            </label>
                            <label><span>Atanan developer</span>
                                <select name="AssignedDeveloperUserId">
                                    <option value="">Atama yok</option>
                                    @foreach (var developer in Model.Developers)
                                    {
                                        <option value="@developer.UserId" selected="@(request.AdminForm.AssignedDeveloperUserId == developer.UserId ? "selected" : null)">@developer.FullName</option>
                                    }
                                </select>
                            </label>
                            <label><span>Baslangic tarihi</span><input type="date" name="PlannedStartDate" value="@request.AdminForm.PlannedStartDate?.ToString("yyyy-MM-dd")" /></label>
                            <label><span>Hedef bitis</span><input type="date" name="DueDate" value="@request.AdminForm.DueDate?.ToString("yyyy-MM-dd")" /></label>
                            <label class="full"><span>Aciklama</span><textarea name="Description" rows="5" required>@request.AdminForm.Description</textarea></label>
                            <label class="full"><span>Admin cevabi</span><textarea name="ReplyMessage" rows="4" placeholder="Developer tarafina not, tarih veya kontrol donusu yazin."></textarea></label>
                            <label><span>Gorsel</span><input type="file" name="VisualFile" accept="image/*" /></label>
                            <button type="submit" class="primary-btn ot-btn ot-btn--success">Kaydet</button>
                        </form>

                        <form method="post" asp-action="DeleteDevelopmentRequest" class="admin-development-delete-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@request.RequestId" />
                            <textarea name="note" rows="3" placeholder="Silme veya reddetme notu"></textarea>
                            <button type="submit" class="ghost-danger-btn ot-btn ot-btn--danger">Talebi Sil / Reddet</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </section>
</section>
