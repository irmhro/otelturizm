@using otelturizmnew.Models.Paneller.Admin
@model AdminListingSubscriptionsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var success = TempData["AdminMessage"] as string;
    var error = TempData["AdminError"] as string;
}

@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success ot-card">@success</div>
}
@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger ot-card">@error</div>
}

<div class="row">
    @foreach (var card in Model.SummaryCards)
    {
        var bg = card.ToneClass switch
        {
            "success" => "bg-success",
            "warning" => "bg-warning",
            "danger" => "bg-danger",
            "secondary" => "bg-secondary",
            _ => "bg-info"
        };
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box @bg">
                <div class="inner">
                    <h3>@card.Value</h3>
                    <p>@card.Label</p>
                    <small>@card.Description</small>
                </div>
                <div class="icon"><i class="fas @card.IconClass"></i></div>
            </div>
        </div>
    }
</div>

<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">Otel Liste Abonelikleri</h3>
        <div class="card-tools">
            <span class="badge badge-light ot-badge">Son 200</span>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap mb-0">
            <thead>
            <tr>
                <th>Otel</th>
                <th>Kapsam</th>
                <th>Sıra</th>
                <th>Durum</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>İletişim</th>
                <th>İşlem</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows)
            {
                var badge = row.StatusToneClass switch
                {
                    "success" => "badge-success",
                    "danger" => "badge-danger",
                    "warning" => "badge-warning",
                    "secondary" => "badge-secondary",
                    _ => "badge-info"
                };
                <tr>
                    <td>
                        <strong>@row.HotelName</strong>
                        <div class="text-muted">ID: @row.HotelId · @row.CityText</div>
                    </td>
                    <td>
                        <span class="badge badge-light ot-badge">@row.ScopeType</span>
                        <div class="text-muted">@row.ScopeValue</div>
                    </td>
                    <td><strong>@row.Rank</strong></td>
                    <td><span class="badge @badge">@row.StatusText</span></td>
                    <td>@row.StartText</td>
                    <td>@row.EndText</td>
                    <td>
                        <div>@row.PartnerEmail</div>
                        @if (!string.IsNullOrWhiteSpace(row.PartnerNote))
                        {
                            <div class="text-muted">@row.PartnerNote</div>
                        }
                    </td>
                    <td>
                        <form method="post" action="/admin/otel-liste-abonelikleri/guncelle" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SubscriptionId" value="@row.SubscriptionId" />
                            <input type="hidden" name="Action" value="approve" />
                            <button type="submit" class="btn btn-success btn-sm ot-btn ot-btn--success">Onayla</button>
                        </form>
                        <form method="post" action="/admin/otel-liste-abonelikleri/guncelle" class="d-inline ml-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SubscriptionId" value="@row.SubscriptionId" />
                            <input type="hidden" name="Action" value="suspend" />
                            <button type="submit" class="btn btn-warning btn-sm ot-btn ot-btn--warning">Askıya Al</button>
                        </form>
                        <form method="post" action="/admin/otel-liste-abonelikleri/guncelle" class="d-inline ml-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SubscriptionId" value="@row.SubscriptionId" />
                            <input type="hidden" name="Action" value="reject" />
                            <button type="submit" class="btn btn-danger btn-sm ot-btn ot-btn--danger">Reddet</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Rows.Count == 0)
        {
            <div class="p-3 text-muted">Abonelik kaydı bulunamadı.</div>
        }
    </div>
</div>

