@using otelturizmnew.Models.Paneller.Admin
@model AdminSectionPageViewModel
<div class="row">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-primary">
                <div class="inner">
                    <h3>@card.Value</h3>
                    <p>@card.Label</p>
                    <small>@card.Description</small>
                </div>
                <div class="icon"><i class="fas @card.IconClass"></i></div>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.InfoNote))
{
    <div class="alert alert-info">
        <i class="fas fa-circle-info mr-1"></i>@Model.InfoNote
    </div>
}

@if (Model.Columns.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">@Model.Shell.PanelTitle</h3>
            <div class="card-tools">
                <span class="badge badge-light">Veritabanı listesi</span>
            </div>
        </div>

        @if (Model.Rows.Count == 0)
        {
            <div class="card-body">
                <div class="alert alert-secondary mb-0">@Model.EmptyStateMessage</div>
            </div>
        }
        else
        {
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover text-nowrap mb-0">
                    <thead>
                        <tr>
                            @foreach (var column in Model.Columns)
                            {
                                <th>@column.Label</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td>@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <strong>@Model.EmptyStateMessage</strong>
        @if (!string.IsNullOrWhiteSpace(Model.InfoNote))
        {
            <p class="mb-0 mt-2 text-muted">@Model.InfoNote</p>
        }
        </div>
    </div>
}


