@model otelturizmnew.Models.Paneller.Admin.AdminHomepageHotelsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    ViewData["PageCssPath"] = "admin_panel_anasayfa_oteller_masaustu";
    var activeSectionId = Model.ActiveSectionId ?? Model.Sections.FirstOrDefault()?.Id;
    var activeSection = Model.Sections.FirstOrDefault(x => x.Id == activeSectionId);
}

<section class="anasayfa-oteller-page">
    <article class="admin-section-card ao-intro-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">Anasayfa Yapılandırma</p>
                <h2>Aktif Oteller</h2>
                <span>Anasayfadaki <strong>Seçilen Özel Rotalar</strong> ve özel alt bölümleri (ör. İstanbul Gösteriler) buradan yönetin.</span>
            </div>
        </div>
    </article>

    <div class="anasayfa-oteller-layout">
        <aside class="anasayfa-oteller-sidebar admin-section-card">
            <div class="admin-section-head">
                <div>
                    <p class="mini-caption">Bölümler</p>
                    <h3>Vitrin Bölümleri</h3>
                </div>
            </div>
            <div class="anasayfa-oteller-section-list">
                @foreach (var hpSection in Model.Sections)
                {
                    var isActive = hpSection.Id == activeSectionId;
                    <a class="anasayfa-oteller-section-item @(isActive ? "is-active" : "")" href="/admin/anasayfa-oteller?sectionId=@hpSection.Id">
                        <div>
                            <strong>@hpSection.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(hpSection.Subtitle))
                            {
                                <span class="text-muted small d-block">@hpSection.Subtitle</span>
                            }
                            <span class="anasayfa-oteller-section-meta">
                                @(hpSection.IsSystemSection ? "Sistem bölümü" : "Özel bölüm") · @hpSection.Hotels.Count otel
                            </span>
                        </div>
                        @if (!hpSection.IsActive)
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </a>
                }
            </div>
            <div class="anasayfa-oteller-sidebar-actions">
                <button type="button"
                        class="btn btn-outline-primary btn-sm w-100"
                        data-ao-toggle="collapse"
                        data-ao-target="#newSectionForm"
                        data-ao-label-show="+ Yeni Bölüm Ekle"
                        data-ao-label-hide="Formu Gizle"
                        aria-expanded="false"
                        aria-controls="newSectionForm">
                    + Yeni Bölüm Ekle
                </button>
                <div id="newSectionForm" class="ao-collapse" aria-hidden="true">
                    <form method="post" action="/admin/anasayfa-oteller/bolum-ekle" class="admin-form-grid">
                        @Html.AntiForgeryToken()
                        <label>
                            <span>Başlık</span>
                            <input type="text" name="Title" placeholder="Örn. İstanbul Gösteriler" required maxlength="200" />
                        </label>
                        <label>
                            <span>Alt başlık (opsiyonel)</span>
                            <input type="text" name="Subtitle" placeholder="Kısa açıklama" maxlength="300" />
                        </label>
                        <label>
                            <span>Sıralama</span>
                            <input type="number" name="SortOrder" value="100" min="1" />
                        </label>
                        <label class="checkbox-inline">
                            <input type="checkbox" name="IsActive" value="true" checked />
                            <span>Aktif</span>
                        </label>
                        <button type="submit" class="btn btn-primary btn-sm">Bölüm Oluştur</button>
                    </form>
                </div>
            </div>
        </aside>

        <div class="anasayfa-oteller-main">
            @if (activeSection is null)
            {
                <article class="admin-section-card">
                    <p class="text-muted mb-0">Henüz bölüm tanımlı değil. Migration uygulandıktan sonra varsayılan <em>Seçilen Özel Rotalar</em> bölümü görünür.</p>
                </article>
            }
            else
            {
                <article class="admin-section-card ao-panel">
                    <button type="button"
                            class="ao-panel-toggle is-expanded"
                            data-ao-toggle="collapse"
                            data-ao-target="#panelSectionEdit"
                            data-ao-default="open"
                            aria-expanded="true"
                            aria-controls="panelSectionEdit">
                        <div class="admin-section-head">
                            <div>
                                <p class="mini-caption">@(activeSection.IsSystemSection ? "Ana Vitrin" : "Özel Bölüm")</p>
                                <h3>@activeSection.Title</h3>
                                @if (!string.IsNullOrWhiteSpace(activeSection.Subtitle))
                                {
                                    <span>@activeSection.Subtitle</span>
                                }
                            </div>
                        </div>
                        <i class="fas fa-chevron-down ao-panel-chevron" aria-hidden="true"></i>
                    </button>
                    <div id="panelSectionEdit" class="ao-panel-body is-open">
                        <form method="post" action="/admin/anasayfa-oteller/bolum-guncelle" class="admin-form-grid ao-section-edit-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@activeSection.Id" />
                            <label>
                                <span>Başlık</span>
                                <input type="text" name="Title" value="@activeSection.Title" required maxlength="200" />
                            </label>
                            <label>
                                <span>Alt başlık</span>
                                <input type="text" name="Subtitle" value="@activeSection.Subtitle" maxlength="300" />
                            </label>
                            <label>
                                <span>Sıralama</span>
                                <input type="number" name="SortOrder" value="@activeSection.SortOrder" min="1" />
                            </label>
                            <label class="checkbox-inline">
                                <input type="checkbox" name="IsActive" value="true" @(activeSection.IsActive ? "checked" : "") />
                                <span>Aktif</span>
                            </label>
                            <button type="submit" class="btn btn-primary btn-sm">Bölümü Kaydet</button>
                        </form>
                        @if (!activeSection.IsSystemSection)
                        {
                            <form method="post" action="/admin/anasayfa-oteller/bolum-sil" class="ao-form-actions" onsubmit="return confirm('Bu bölüm ve içindeki oteller silinecek. Emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sectionId" value="@activeSection.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Bölümü Sil</button>
                            </form>
                        }
                    </div>
                </article>

                <article class="admin-section-card ao-panel">
                    <button type="button"
                            class="ao-panel-toggle is-expanded"
                            data-ao-toggle="collapse"
                            data-ao-target="#panelHotelSearch"
                            data-ao-default="open"
                            aria-expanded="true"
                            aria-controls="panelHotelSearch">
                        <div class="admin-section-head">
                            <div>
                                <p class="mini-caption">Otel Ekle</p>
                                <h3>Yayındaki otellerden seç</h3>
                                <span>İl, ilçe, mahalle veya otel adı ile arayın.</span>
                            </div>
                        </div>
                        <i class="fas fa-chevron-down ao-panel-chevron" aria-hidden="true"></i>
                    </button>
                    <div id="panelHotelSearch" class="ao-panel-body is-open">
                        <div class="ao-hotel-search" data-section-id="@activeSection.Id">
                            <input type="search" class="form-control" id="hpHotelSearchInput" placeholder="Otel ara: İstanbul, Beyoğlu, otel adı..." autocomplete="off" />
                            <div id="hpHotelSearchResults" class="ao-search-results" hidden></div>
                        </div>
                    </div>
                </article>

                <article class="admin-section-card ao-panel">
                    <button type="button"
                            class="ao-panel-toggle is-expanded"
                            data-ao-toggle="collapse"
                            data-ao-target="#panelHotelList"
                            data-ao-default="open"
                            aria-expanded="true"
                            aria-controls="panelHotelList">
                        <div class="admin-section-head">
                            <div>
                                <p class="mini-caption">Seçili Oteller</p>
                                <h3>Bölüm otel listesi (@activeSection.Hotels.Count)</h3>
                                <span>Sıralama anasayfada yukarıdan aşağıya uygulanır.</span>
                            </div>
                        </div>
                        <i class="fas fa-chevron-down ao-panel-chevron" aria-hidden="true"></i>
                    </button>
                    <div id="panelHotelList" class="ao-panel-body is-open">
                        <div class="admin-table-wrap">
                            @if (activeSection.Hotels.Count == 0)
                            {
                                <p class="text-muted mb-0">Bu bölümde henüz otel yok. Yukarıdan arama ile ekleyin.</p>
                            }
                            else
                            {
                                <table class="admin-table">
                                    <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Otel</th>
                                        <th>İl</th>
                                        <th>İlçe</th>
                                        <th>Mahalle</th>
                                        <th>Durum</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @{
                                        var rowIndex = 1;
                                    }
                                    @foreach (var hotel in activeSection.Hotels)
                                    {
                                        <tr>
                                            <td data-label="#">@rowIndex</td>
                                            <td data-label="Otel"><strong>@hotel.HotelName</strong><div class="text-muted small">#@hotel.HotelId</div></td>
                                            <td data-label="İl">@hotel.City</td>
                                            <td data-label="İlçe">@hotel.District</td>
                                            <td data-label="Mahalle">@(string.IsNullOrWhiteSpace(hotel.Neighborhood) ? "-" : hotel.Neighborhood)</td>
                                            <td data-label="Durum">
                                                <span class="badge @(hotel.PublishStatus == "Yayında" ? "bg-success" : "bg-warning")">@hotel.PublishStatus</span>
                                                <span class="badge bg-light">@hotel.ApprovalStatus</span>
                                            </td>
                                            <td class="text-end ao-row-actions" data-label="İşlem">
                                                <form method="post" action="/admin/anasayfa-oteller/otel-tasi" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="EntryId" value="@hotel.EntryId" />
                                                    <input type="hidden" name="SectionId" value="@activeSection.Id" />
                                                    <input type="hidden" name="Direction" value="up" />
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Yukarı">↑</button>
                                                </form>
                                                <form method="post" action="/admin/anasayfa-oteller/otel-tasi" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="EntryId" value="@hotel.EntryId" />
                                                    <input type="hidden" name="SectionId" value="@activeSection.Id" />
                                                    <input type="hidden" name="Direction" value="down" />
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Aşağı">↓</button>
                                                </form>
                                                <form method="post" action="/admin/anasayfa-oteller/otel-kaldir" class="d-inline" onsubmit="return confirm('Otel bu bölümden kaldırılsın mı?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="EntryId" value="@hotel.EntryId" />
                                                    <input type="hidden" name="SectionId" value="@activeSection.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Kaldır</button>
                                                </form>
                                            </td>
                                        </tr>
                                        rowIndex++;
                                    }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<script>
    (function () {
        function setCollapseState(trigger, target, open) {
            trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
            trigger.classList.toggle('is-expanded', open);
            target.classList.toggle('is-open', open);
            target.setAttribute('aria-hidden', open ? 'false' : 'true');

            const showLabel = trigger.getAttribute('data-ao-label-show');
            const hideLabel = trigger.getAttribute('data-ao-label-hide');
            if (showLabel && hideLabel) {
                trigger.textContent = open ? hideLabel : showLabel;
            }
        }

        document.querySelectorAll('[data-ao-toggle="collapse"]').forEach(function (trigger) {
            const selector = trigger.getAttribute('data-ao-target');
            const target = selector ? document.querySelector(selector) : null;
            if (!target) return;

            const defaultOpen = trigger.getAttribute('data-ao-default') === 'open';
            setCollapseState(trigger, target, defaultOpen);

            trigger.addEventListener('click', function () {
                setCollapseState(trigger, target, !target.classList.contains('is-open'));
            });
        });

        const root = document.querySelector('.ao-hotel-search');
        if (!root) return;

        const sectionId = root.getAttribute('data-section-id');
        const input = document.getElementById('hpHotelSearchInput');
        const results = document.getElementById('hpHotelSearchResults');
        let timer = null;

        function hideResults() {
            results.hidden = true;
            results.innerHTML = '';
        }

        function renderItems(items) {
            if (!items || items.length === 0) {
                results.innerHTML = '<div class="ao-search-item text-muted">Sonuç bulunamadı</div>';
                results.hidden = false;
                return;
            }

            results.innerHTML = items.map(function (item) {
                return `
                <div class="ao-search-item">
                    <div>
                        <strong>${escapeHtml(item.hotelName)}</strong>
                        <div class="text-muted small">${escapeHtml(item.locationLabel)}</div>
                    </div>
                    <form method="post" action="/admin/anasayfa-oteller/otel-ekle">
                        <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                        <input type="hidden" name="SectionId" value="${sectionId}" />
                        <input type="hidden" name="HotelId" value="${item.hotelId}" />
                        <button type="submit" class="btn btn-primary btn-sm">Ekle</button>
                    </form>
                </div>`;
            }).join('');
            results.hidden = false;
        }

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, function (ch) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
            });
        }

        function getAntiForgeryToken() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        async function searchHotels(query) {
            const url = `/admin/anasayfa-oteller/otel-ara?q=${encodeURIComponent(query)}&limit=20`;
            const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
            if (!response.ok) return [];
            return response.json();
        }

        input.addEventListener('input', function () {
            clearTimeout(timer);
            const q = input.value.trim();
            if (q.length < 2) {
                hideResults();
                return;
            }
            timer = setTimeout(async function () {
                try {
                    const items = await searchHotels(q);
                    renderItems(items);
                } catch {
                    hideResults();
                }
            }, 250);
        });

        document.addEventListener('click', function (event) {
            if (!root.contains(event.target)) hideResults();
        });
    })();
</script>
