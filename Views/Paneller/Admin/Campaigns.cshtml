@using otelturizmnew.Models.Paneller.Admin
@model AdminCampaignsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
    var totalPages = Model.PageSize <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(Model.Total / (double)Model.PageSize));
    var pageSizes = new[] { 10, 25, 50, 100, 200 };
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    static string DateText(DateTimeOffset? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd.MM.yyyy") : "-";
    static string Tone(bool active) => active ? "success" : "danger";
}

<section class="admin-campaigns-page">
    <div class="admin-summary-grid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="admin-summary-card admin-summary-card--@card.ToneClass">
                <span class="admin-summary-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    <article class="admin-section-card">
        <div class="card-header">
            <div>
                <p class="mini-caption">KONAKLAMA PAZARLAMA</p>
                <h2 class="card-title mb-1">Kampanya Yönetimi</h2>
                <span class="text-muted">Yayın, görünürlük, partner katılımı ve kullanım limitlerini tek tabloda izleyin.</span>
            </div>
        </div>

        <form method="get" action="/admin/kampanyalar" class="admin-ops-filter admin-campaigns-filter">
            <label>
                <span>Arama</span>
                <input type="search" name="q" value="@Model.Query" placeholder="Kod, ad, şehir veya etiket" />
            </label>
            <label>
                <span>Görünürlük</span>
                <select name="status">
                    <option value="">Tüm durumlar</option>
                    @foreach (var option in Model.StatusOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.Status, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Tür</span>
                <select name="campaignType">
                    <option value="">Tüm türler</option>
                    @foreach (var option in Model.TypeOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.CampaignType, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Partner katılımı</span>
                <select name="partnerJoinOpen">
                    <option value="">Tümü</option>
                    <option value="true" selected="@(Model.PartnerJoinOpen == true)">Açık</option>
                    <option value="false" selected="@(Model.PartnerJoinOpen == false)">Kapalı</option>
                </select>
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="pageSize">
                    @foreach (var size in pageSizes)
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </label>
            <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Filtrele</button>
            <a class="btn btn-outline-primary" href="/admin/kampanyalar"><i class="fas fa-rotate-left me-2"></i>Temizle</a>
        </form>

        <div class="table-responsive">
            <table class="table table-vcenter table-hover admin-ops-table admin-campaigns-table">
                <thead>
                    <tr>
                        <th>Kampanya</th>
                        <th>Tür / Hedef</th>
                        <th>İndirim</th>
                        <th>Kullanım</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th>Partner</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="8">Filtreye uygun kampanya bulunamadı.</td></tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>
                                <strong>@row.CampaignName</strong>
                                <small>@row.CampaignCode</small>
                                @if (!string.IsNullOrWhiteSpace(row.Badge))
                                {
                                    <span class="campaign-badge">@row.Badge</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.ShortDescription))
                                {
                                    <small>@row.ShortDescription</small>
                                }
                            </td>
                            <td>
                                <span>@row.CampaignType</span>
                                <small>@(string.IsNullOrWhiteSpace(row.TargetCities) ? "Genel hedef" : row.TargetCities)</small>
                            </td>
                            <td>
                                <strong>@(row.DiscountRate > 0 ? $"%{row.DiscountRate:0.##}" : row.DiscountAmount.ToString("N2", tr) + " TRY")</strong>
                                <small>Min @row.MinCartAmount.ToString("N0", tr) · Maks @row.MaxDiscountAmount.ToString("N0", tr)</small>
                            </td>
                            <td>
                                <span>@row.UsedCount kullanım</span>
                                <small>@(row.TotalLimit.HasValue ? $"{row.RemainingLimit} kalan / {row.TotalLimit}" : "Limitsiz")</small>
                            </td>
                            <td>
                                <span>@DateText(row.StartsAtUtc)</span>
                                <small>@DateText(row.EndsAtUtc)</small>
                            </td>
                            <td>
                                <span class="status-pill status-pill--@Tone(row.IsActive)">@(row.IsActive ? "Aktif" : "Pasif")</span>
                                <small>@row.VisibilityStatus</small>
                                @if (row.Featured || row.ShowcaseActive)
                                {
                                    <small>Vitrin / öne çıkan</small>
                                }
                            </td>
                            <td>
                                <span class="status-pill status-pill--@Tone(row.PartnerJoinOpen)">@(row.PartnerJoinOpen ? "Açık" : "Kapalı")</span>
                            </td>
                            <td class="panel-form-ux-actions" data-label="Aksiyon">
                                <form method="post" action="/admin/kampanyalar/aktiflik" class="admin-inline-form panel-form-ux-toggle-form @(row.IsActive ? "panel-form-ux-delete" : "")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="campaignId" value="@row.CampaignId" />
                                    <input type="hidden" name="active" value="@(row.IsActive ? "false" : "true")" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm panel-form-ux-delete-btn @(row.IsActive ? "btn-outline-danger" : "btn-success panel-form-ux-edit")">
                                        <i class="fas @(row.IsActive ? "fa-pause" : "fa-play") me-1"></i>@(row.IsActive ? "Pasife al" : "Aktif et")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination-row">
            <span>@Model.Total kayıt · Sayfa @Model.Page / @totalPages</span>
            <div>
                <a class="btn btn-outline-primary btn-sm @(Model.Page <= 1 ? "disabled" : "")" href="/admin/kampanyalar?page=@(Model.Page - 1)&pageSize=@Model.PageSize&q=@Model.Query&status=@Model.Status&campaignType=@Model.CampaignType&partnerJoinOpen=@Model.PartnerJoinOpen">Önceki</a>
                <a class="btn btn-outline-primary btn-sm @(Model.Page >= totalPages ? "disabled" : "")" href="/admin/kampanyalar?page=@(Model.Page + 1)&pageSize=@Model.PageSize&q=@Model.Query&status=@Model.Status&campaignType=@Model.CampaignType&partnerJoinOpen=@Model.PartnerJoinOpen">Sonraki</a>
            </div>
        </div>
    </article>
</section>
