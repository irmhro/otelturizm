@inject otelturizmnew.Services.Abstractions.ITimeZoneService TimeZoneService
@{
    var localNow = TimeZoneService.ToLocal(DateTime.UtcNow);
}
<footer class="admin-panel-footer d-print-none">
    <div>&copy; @localNow.Year <a href="/">Otelturizm</a> Admin</div>
    <div class="admin-panel-footer-meta">
        <span>@localNow.ToString("dd.MM.yyyy HH:mm")</span>
        <a href="/yardim-merkezi">Yardım</a>
        <a asp-controller="Home" asp-action="Privacy">Gizlilik</a>
    </div>
</footer>
