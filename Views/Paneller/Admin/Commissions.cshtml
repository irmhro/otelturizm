@model otelturizmnew.Models.Paneller.Admin.AdminCommissionManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>@card.Value</h3>
                    <p>@card.Label</p>
                    <small>@card.Description</small>
                </div>
                <div class="icon"><i class="fas @card.IconClass"></i></div>
            </div>
        </div>
    }
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">Komisyon ve vergi kuralı</h3>
            </div>
            <form method="post" action="/admin/komisyonlar/kaydet">
                <div class="card-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="RuleId" value="@Model.Form.RuleId" />

                    <div class="form-group">
                        <label>Otel</label>
                        <select name="HotelId" class="form-control">
                            @foreach (var hotel in Model.Hotels)
                            {
                                <option value="@hotel.HotelId" selected="@(hotel.HotelId == Model.Form.HotelId)">@hotel.HotelName (@hotel.HotelCode)</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 form-group">
                            <label>Başlangıç</label>
                            <input type="date" name="StartDate" class="form-control" value="@Model.Form.StartDate.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-6 form-group">
                            <label>Bitiş</label>
                            <input type="date" name="EndDate" class="form-control" value="@(Model.Form.EndDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 form-group">
                            <label>Komisyon %</label>
                            <input type="number" step="0.01" min="0" name="CommissionRate" class="form-control" value="@Model.Form.CommissionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                        <div class="col-6 form-group">
                            <label>Komisyon gelir vergisi %</label>
                            <input type="number" step="0.01" min="0" name="CommissionIncomeTaxRate" class="form-control" value="@Model.Form.CommissionIncomeTaxRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 form-group">
                            <label>KDV %</label>
                            <input type="number" step="0.01" min="0" name="VatRate" class="form-control" value="@Model.Form.VatRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                        <div class="col-6 form-group">
                            <label>Konaklama vergisi %</label>
                            <input type="number" step="0.01" min="0" name="AccommodationTaxRate" class="form-control" value="@Model.Form.AccommodationTaxRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Para birimi</label>
                        <select name="Currency" class="form-control">
                            <option value="TRY" selected="@(Model.Form.Currency == "TRY")">TRY</option>
                            <option value="USD" selected="@(Model.Form.Currency == "USD")">USD</option>
                            <option value="EUR" selected="@(Model.Form.Currency == "EUR")">EUR</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Not</label>
                        <textarea name="Note" rows="3" class="form-control">@Model.Form.Note</textarea>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">Kuralı Kaydet</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Kayıtlı komisyon kuralları</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover text-nowrap mb-0">
                    <thead>
                        <tr>
                            <th>Otel</th>
                            <th>Tarih</th>
                            <th>Komisyon</th>
                            <th>Vergiler</th>
                            <th>Net</th>
                            <th>Not</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Rules.Count == 0)
                    {
                        <tr><td colspan="6">Komisyon kuralı bulunmuyor.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Rules)
                        {
                            <tr>
                                <td><strong>@item.HotelName</strong><div>@item.HotelCode</div></td>
                                <td>@item.DateRangeText</td>
                                <td>@item.CommissionText</td>
                                <td>@item.TaxText</td>
                                <td>@item.NetText</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
