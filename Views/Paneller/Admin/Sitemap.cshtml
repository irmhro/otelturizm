@using otelturizmnew.Models.Seo
@model SitemapDiagnosticsViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
}

<div class="row">
    <div class="col-lg-3 col-md-6 col-12">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.SubSitemapCount</h3>
                <p>Alt sitemap</p>
                <small>/sitemap.xml index</small>
            </div>
            <div class="icon"><i class="fas fa-sitemap"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="small-box bg-primary">
            <div class="inner">
                <h3>@Model.HotelUrlCount</h3>
                <p>Otel URL</p>
                <small>/sitemaps/hotels.xml</small>
            </div>
            <div class="icon"><i class="fas fa-hotel"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.RoomUrlCount</h3>
                <p>Oda URL</p>
                <small>/sitemaps/rooms.xml</small>
            </div>
            <div class="icon"><i class="fas fa-bed"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.PriceFeedOfferCount</h3>
                <p>Fiyatlı teklif</p>
                <small>/feeds/hotel-offers.json</small>
            </div>
            <div class="icon"><i class="fas fa-tags"></i></div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-3 col-md-6 col-12">
        <div class="info-box">
            <span class="info-box-icon bg-secondary"><i class="fas fa-bullhorn"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Kampanya</span>
                <span class="info-box-number">@Model.CampaignUrlCount</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="info-box">
            <span class="info-box-icon bg-secondary"><i class="fas fa-newspaper"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Blog</span>
                <span class="info-box-number">@Model.BlogUrlCount</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="info-box">
            <span class="info-box-icon bg-secondary"><i class="fas fa-map-location-dot"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Konum listeleme</span>
                <span class="info-box-number">@Model.LocationUrlCount</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 col-12">
        <div class="info-box">
            <span class="info-box-icon bg-secondary"><i class="fas fa-map"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">İl/ilçe XML</span>
                <span class="info-box-number">@Model.RegionalFileCount · @Model.RegionalUrlCount URL</span>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h3 class="card-title mb-0">Sitemap yönetimi</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/sitemap.xml" target="_blank" rel="noopener">
                <i class="fas fa-external-link-alt mr-1"></i> Index önizle
            </a>
            <a class="btn btn-sm btn-outline-secondary" href="@Model.PriceFeedUrl" target="_blank" rel="noopener">
                <i class="fas fa-code mr-1"></i> Fiyat feed
            </a>
            <form method="post" action="/admin/sitemap/yenile">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="fas fa-wand-magic-sparkles mr-1"></i> Sitemap Oluştur
                </button>
            </form>
        </div>
    </div>
    <div class="card-body">
        <p class="mb-1"><strong>Fiziksel dosya:</strong> @Model.MainSitemapPhysicalPath</p>
        <p class="mb-1"><strong>Son üretim (UTC):</strong> @(Model.LastRefreshUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</p>
        <p class="mb-0 text-muted small">
            Sitemap index; statik sayfalar, oteller, odalar, kampanyalar, blog, konumlar ve il/ilçe XML dosyalarını kapsar.
            Otel fiyatları <code>/feeds/hotel-offers.json</code> Schema.org feed ile Google ve AI ajanlarına açıktır.
        </p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Üretilen dosyalar</h3>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-striped table-hover text-nowrap mb-0">
            <thead>
                <tr>
                    <th>Dosya</th>
                    <th>Kapsam</th>
                    <th>URL / teklif</th>
                    <th>Son güncelleme (UTC)</th>
                    <th>Servis URL</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var file in Model.Files.OrderBy(x => x.ScopeText).ThenBy(x => x.FileName))
                {
                    <tr>
                        <td>@file.FileName</td>
                        <td>@file.ScopeText</td>
                        <td>@file.UrlCount</td>
                        <td>@(file.LastModifiedUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        <td><a href="@file.PublicUrl" target="_blank" rel="noopener">@file.PublicUrl</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
