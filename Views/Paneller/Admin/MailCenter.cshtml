@using otelturizmnew.Models.Paneller.Admin
@model AdminMailCenterPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="admin-mail-center">
    <section class="admin-mail-center-hero">
        <div>
            <p class="admin-mail-center-kicker">Mail Merkezi</p>
            <h2>Platform posta akışı</h2>
            <p>Admin hesapları için gelen kutusu senkronu, giden e-posta görünümü ve hesap yönetimi tek ekranda.</p>
        </div>
        <div class="admin-mail-center-stats">
            <article>
                <span>Hesap</span>
                <strong>@Model.Accounts.Count</strong>
            </article>
            <article>
                <span>Gelen</span>
                <strong>@Model.TotalIncoming</strong>
            </article>
            <article>
                <span>Giden</span>
                <strong>@Model.TotalOutgoing</strong>
            </article>
            <article>
                <span>Aktif gönderen</span>
                <strong>@Model.ActiveSenderEmail</strong>
            </article>
        </div>
    </section>

    <div class="admin-mail-center-grid">
        <section class="admin-mail-center-panel">
            <div class="admin-mail-center-panel-head">
                <div>
                    <h3>Mail hesapları</h3>
                    <p>IMAP/POP3 ile gelen kutusu okunur. SMTP ayarları kayıt altındadır.</p>
                </div>
                @if (Model.SelectedAccountId.HasValue)
                {
                    <form method="post" action="/admin/mail-merkezi/senkronize">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="accountId" value="@Model.SelectedAccountId.Value" />
                        <button type="submit" class="btn btn-primary btn-sm">Şimdi Senkronize Et</button>
                    </form>
                }
            </div>

            <div class="admin-mail-account-list">
                @foreach (var account in Model.Accounts)
                {
                    var selected = Model.SelectedAccountId == account.Id;
                    <a class="admin-mail-account-card @(selected ? "selected" : string.Empty)" href="/admin/mail-merkezi?accountId=@account.Id">
                        <div>
                            <strong>@account.AccountName</strong>
                            <span>@account.EmailAddress</span>
                        </div>
                        <div class="admin-mail-account-meta">
                            <span>@account.IncomingProtocol @account.IncomingHost:@account.IncomingPort</span>
                            <small>@(account.LastSyncUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Henüz senkron yok")</small>
                        </div>
                    </a>
                }
            </div>
        </section>

        <section class="admin-mail-center-panel">
            <div class="admin-mail-center-panel-head">
                <div>
                    <h3>Hesap düzenle / ekle</h3>
                    <p>Parola boş bırakılırsa mevcut kayıt korunur.</p>
                </div>
            </div>

            <form method="post" action="/admin/mail-merkezi/hesap-kaydet" class="admin-mail-form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Form.Id" />
                <label>
                    <span>Hesap kodu</span>
                    <input name="AccountCode" value="@Model.Form.AccountCode" required />
                </label>
                <label>
                    <span>Hesap adı</span>
                    <input name="AccountName" value="@Model.Form.AccountName" required />
                </label>
                <label>
                    <span>E-posta</span>
                    <input name="EmailAddress" value="@Model.Form.EmailAddress" type="email" required />
                </label>
                <label>
                    <span>Kullanıcı adı</span>
                    <input name="Username" value="@Model.Form.Username" required />
                </label>
                <label>
                    <span>Şifre</span>
                    <input name="Password" type="password" autocomplete="new-password" />
                </label>
                <label>
                    <span>Gelen protokol</span>
                    <select name="IncomingProtocol">
                        <option value="IMAP" selected="@(Model.Form.IncomingProtocol == "IMAP")">IMAP</option>
                        <option value="POP3" selected="@(Model.Form.IncomingProtocol == "POP3")">POP3</option>
                    </select>
                </label>
                <label>
                    <span>Gelen sunucu</span>
                    <input name="IncomingHost" value="@Model.Form.IncomingHost" required />
                </label>
                <label>
                    <span>Gelen port</span>
                    <input name="IncomingPort" value="@Model.Form.IncomingPort" type="number" required />
                </label>
                <label>
                    <span>Giden sunucu</span>
                    <input name="OutgoingHost" value="@Model.Form.OutgoingHost" required />
                </label>
                <label>
                    <span>Giden port</span>
                    <input name="OutgoingPort" value="@Model.Form.OutgoingPort" type="number" required />
                </label>
                <label>
                    <span>SMTP güvenlik</span>
                    <input name="OutgoingSecurityType" value="@Model.Form.OutgoingSecurityType" required />
                </label>
                <label class="admin-mail-checkbox">
                    <input name="IncomingUseSsl" type="checkbox" value="true" checked="@Model.Form.IncomingUseSsl" />
                    <span>Gelen SSL/TLS kullan</span>
                </label>
                <label class="admin-mail-checkbox">
                    <input name="IsActive" type="checkbox" value="true" checked="@Model.Form.IsActive" />
                    <span>Aktif</span>
                </label>
                <label class="admin-mail-checkbox">
                    <input name="IsDefaultSender" type="checkbox" value="true" checked="@Model.Form.IsDefaultSender" />
                    <span>Varsayılan gönderen</span>
                </label>
                <div class="admin-mail-form-actions">
                    <button type="submit" class="btn btn-primary btn-sm">Kaydet</button>
                </div>
            </form>
            @if (Model.Form.Id.HasValue)
            {
                <form method="post" action="/admin/mail-merkezi/hesap-sil" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Form.Id.Value" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">Hesabı Sil</button>
                </form>
            }
        </section>
    </div>

    <div class="admin-mail-center-grid">
        <section class="admin-mail-center-panel">
            <div class="admin-mail-center-panel-head">
                <div>
                    <h3>Gelen kutusu</h3>
                    <p>Seçili hesap için son senkronlanan iletiler.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                    <tr>
                        <th>Hesap</th>
                        <th>Gönderen</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th>Özet</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Incoming)
                    {
                        <tr>
                            <td>@row.AccountEmail</td>
                            <td>@row.From</td>
                            <td>@row.Subject</td>
                            <td>@(row.ReceivedAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td style="max-width:320px;white-space:normal;">@row.Summary</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="admin-mail-center-panel">
            <div class="admin-mail-center-panel-head">
                <div>
                    <h3>Gönderilen</h3>
                    <p>Mevcut bildirim kuyruğu ve SMTP kabul bilgileri.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                    <tr>
                        <th>Gönderen</th>
                        <th>Alıcı</th>
                        <th>Konu</th>
                        <th>Durum</th>
                        <th>Mesaj ID</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.Outgoing)
                    {
                        <tr>
                            <td>@row.SenderEmail</td>
                            <td>@row.RecipientEmail</td>
                            <td>@row.Subject</td>
                            <td>@row.Status</td>
                            <td style="max-width:260px;white-space:normal;">@(row.ProviderMessageId ?? "-")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
