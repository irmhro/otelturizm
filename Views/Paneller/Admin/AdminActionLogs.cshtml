@using otelturizmnew.Models.Paneller.Admin
@model AdminActionLogsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Admin İşlem Logları</h3>
        <div class="card-tools">
            <a class="btn btn-sm btn-outline-primary"
               href="/admin/islem-loglari/csv?adminUserId=@Model.Filter.AdminUserId&actionType=@Model.Filter.ActionType&targetTable=@Model.Filter.TargetTable&q=@Model.Filter.Query">CSV indir</a>
        </div>
    </div>
    <div class="card-body">
        <form method="get" action="/admin/islem-loglari" class="row g-2">
            <div class="col-md-2">
                <label class="form-label">Admin ID</label>
                <input class="form-control form-control-sm" name="adminUserId" value="@Model.Filter.AdminUserId" />
            </div>
            <div class="col-md-2">
                <label class="form-label">İşlem</label>
                <input class="form-control form-control-sm" name="actionType" value="@Model.Filter.ActionType" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tablo</label>
                <input class="form-control form-control-sm" name="targetTable" value="@Model.Filter.TargetTable" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Ara</label>
                <input class="form-control form-control-sm" name="q" value="@Model.Filter.Query" placeholder="Açıklama / hedef id / ip" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-sm btn-primary w-100" type="submit">Filtrele</button>
            </div>
        </form>

        <div class="table-responsive mt-3">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Admin</th>
                    <th>İşlem</th>
                    <th>Hedef</th>
                    <th>IP</th>
                    <th>Tarih (UTC)</th>
                    <th>Açıklama</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.Id</td>
                        <td>@row.AdminUserId</td>
                        <td>@row.ActionType</td>
                        <td>@row.TargetTable @if (!string.IsNullOrWhiteSpace(row.TargetId)) { <span class="text-muted">(@row.TargetId)</span> }</td>
                        <td>@row.IpAddress</td>
                        <td>@row.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td style="max-width:520px;white-space:normal;">@row.Note</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="text-muted small">Toplam: @Model.Total</div>
    </div>
</div>

