@using System.Security.Claims
@using otelturizmnew.Models.Paneller.Admin
@inject otelturizmnew.Services.Abstractions.IPanelThemeService PanelThemeService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string ?? ViewData["PageCss"] as string;
    var shell = ViewData["AdminShell"] as AdminShellViewModel;
    if (shell is null && ViewData.Model is not null)
    {
        var shellProperty = ViewData.Model.GetType().GetProperty("Shell");
        shell = shellProperty?.GetValue(ViewData.Model) as AdminShellViewModel;
        if (shell is not null)
        {
            ViewData["AdminShell"] = shell;
        }
    }
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Admin Panel";
    var nonce = Context.Items["CspNonce"] as string;
    var rawUserId = Context.User.FindFirstValue(otelturizmnew.Constants.AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var userId = long.TryParse(rawUserId, out var parsedUserId) ? parsedUserId : 0;
    var theme = userId > 0 ? await PanelThemeService.LoadAsync("admin", userId, Context.RequestAborted) : new otelturizmnew.Models.Paneller.Partner.PanelThemeViewModel();
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme != "light" && bsTheme != "dark" && bsTheme != "auto") { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var primaryHex = !string.IsNullOrWhiteSpace(theme?.PrimaryHex) ? theme!.PrimaryHex : theme?.AccentHex;
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : primaryHex;
        // Ana renk sadece aksiyon/buton tonunu etkilemeli (Tabler global primary ezilmesin).
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--partner-accent: {accentHex};");
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--partner-sidebar-bg: {theme!.SidebarBgHex}; --partner-sidebar-bg-2: color-mix(in srgb, {theme.SidebarBgHex} 76%, #ffffff 24%);");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily)) parts.Add($"--tblr-font-sans-serif: {theme!.FontFamily};");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/paneltematabler/dist/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/tabler-bridge.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/partner/shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/admin/admin-tabler-overrides.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/admin/admin-tabler-overrides.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    <link rel="stylesheet" href="~/assets/css/panel-admin-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/panel-admin-shell.mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).mobile.css" asp-append-version="true" media="(max-width: 900px)" />
    }
</head>
<body class="layout-fluid partner-panel-v2 admin-tabler-shell admin-panel-theme"
      data-bs-theme="@(bsTheme == "auto" ? null : bsTheme)"
      dir="@dir"
      style="@BuildThemeStyle()">
    <div class="page">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Admin/_AdminSidebar.cshtml" model="shell" />
        }

        <div class="page-wrapper">
            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Admin/_AdminTopNav.cshtml" model="shell" />
            }

            <div class="page-body">
                <div class="container-fluid">
                    @if (shell is not null)
                    {
                        <div class="page-header d-print-none pb-3 mb-3 border-bottom border-secondary-subtle">
                            <div class="row align-items-center">
                                <div class="col">
                                    <div class="page-pretitle text-primary small fw-bold text-uppercase ls-wide">Admin Panel</div>
                                    <h1 class="page-title mb-1">@shell.PanelTitle</h1>
                                    @if (!string.IsNullOrWhiteSpace(shell.PanelSubtitle))
                                    {
                                        <div class="text-muted">@shell.PanelSubtitle</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
                    @RenderBody()
                </div>
            </div>

            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Admin/_AdminFooter.cshtml" />
                <partial name="~/Views/Paneller/Admin/_AdminMobileNav.cshtml" model="shell" />
                <div class="offcanvas offcanvas-end" tabindex="-1" id="adminThemeSettings" aria-labelledby="adminThemeSettingsLabel">
                    <div class="offcanvas-header">
                        <h2 class="offcanvas-title" id="adminThemeSettingsLabel">Tema Ayarları</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
                    </div>
                    <div class="offcanvas-body">
                        <form method="post" action="/admin/tema/kaydet">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <input type="hidden" name="PrimaryHex" id="adminThemePrimaryHex" value="@(theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="AccentHex" id="adminThemeAccentHex" value="@(theme?.AccentHex ?? theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="SidebarBgHex" id="adminThemeSidebarBgHex" value="@(theme?.SidebarBgHex ?? string.Empty)" />
                            <label class="form-label">Renk modu</label>
                            <div class="form-selectgroup-boxes row g-2 mb-3">
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="light" class="form-selectgroup-input" @(string.Equals(bsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-sun me-2"></i>Açık</span>
                                </label>
                                <label class="form-selectgroup-item col-6">
                                    <input type="radio" name="BsTheme" value="dark" class="form-selectgroup-input" @(string.Equals(bsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span class="form-selectgroup-label d-flex align-items-center p-3"><i class="fas fa-moon me-2"></i>Koyu</span>
                                </label>
                            </div>
                            <label class="form-label">Ana renk</label>
                            <div class="d-flex flex-wrap gap-2 mb-3" data-color-palette="admin-primary">
                                @foreach (var color in new[] { "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#334155" })
                                {
                                    <button type="button" class="btn btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                                }
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Temayı Kaydet</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="~/paneltematabler/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
    <script nonce="@nonce">
    (() => {
        const primaryInput = document.getElementById('adminThemePrimaryHex');
        const accentInput = document.getElementById('adminThemeAccentHex');
        const sidebarInput = document.getElementById('adminThemeSidebarBgHex');
        const body = document.body;
        const root = document.documentElement;
        const applyThemePreview = ({ mode, accent, sidebar }) => {
            if (mode) { root.setAttribute('data-bs-theme', mode); body.setAttribute('data-bs-theme', mode); }
            if (accent) root.style.setProperty('--partner-accent', accent);
            if (sidebar) { root.style.setProperty('--partner-sidebar-bg', sidebar); root.style.setProperty('--partner-sidebar-bg-2', `color-mix(in srgb, ${sidebar} 76%, #ffffff 24%)`); }
        };
        document.querySelectorAll('[data-color-palette=\"admin-primary\"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                applyThemePreview({
                    mode: document.querySelector('#adminThemeSettings input[name=\"BsTheme\"]:checked')?.value || 'light',
                    accent: hex,
                    sidebar: sidebarInput?.value || ''
                });
            });
        });
        document.querySelectorAll('#adminThemeSettings input[name=\"BsTheme\"]').forEach((input) => {
            input.addEventListener('change', () => {
                const value = input.value || 'light';
                const accent = accentInput?.value || primaryInput?.value || '';
                applyThemePreview({ mode: value, accent, sidebar: sidebarInput?.value || '' });
            });
        });
    })();
    </script>
    <script nonce="@nonce">
        (function () {
            var root = document.querySelector('.admin-tabler-shell .page-body');
            if (!root) return;
            root.querySelectorAll('input').forEach(function (el) {
                var type = (el.getAttribute('type') || 'text').toLowerCase();
                if (type === 'checkbox' || type === 'radio') {
                    if (!el.classList.contains('form-check-input')) el.classList.add('form-check-input');
                    return;
                }
                if (type === 'file') {
                    if (!el.classList.contains('form-control')) el.classList.add('form-control');
                    return;
                }
                if (!el.classList.contains('form-control')) el.classList.add('form-control');
            });
            root.querySelectorAll('select, textarea').forEach(function (el) {
                if (!el.classList.contains('form-control')) el.classList.add('form-control');
            });
            root.querySelectorAll('table.admin-table').forEach(function (el) {
                el.classList.add('table', 'table-striped', 'table-hover', 'text-nowrap');
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
