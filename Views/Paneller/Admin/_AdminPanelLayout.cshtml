@using otelturizmnew.Models.Paneller.Admin
@{
    Layout = null;
    var pageCss = ViewData["PageCss"] as string;
    var shell = ViewData["AdminShell"] as AdminShellViewModel;
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Admin Panel";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover" />
    <title>@title - Otelturizm</title>
    <link rel="stylesheet" href="~/vendor/AdminLTE-3.2.0/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/vendor/AdminLTE-3.2.0/plugins/icheck-bootstrap/icheck-bootstrap.min.css" />
    <link rel="stylesheet" href="~/vendor/AdminLTE-3.2.0/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/assets/css/panel-admin-shell.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(pageCss))
    {
        <link rel="stylesheet" href="~/assets/css/@(pageCss).css" asp-append-version="true" />
    }
</head>
<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
    <div class="wrapper">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Admin/_AdminTopNav.cshtml" model="shell" />
            <partial name="~/Views/Paneller/Admin/_AdminSidebar.cshtml" model="shell" />
        }

        <div class="content-wrapper">
            @if (shell is not null)
            {
                <section class="content-header">
                    <div class="container-fluid">
                        <div class="row mb-2">
                            <div class="col-sm-12">
                                <h1 class="m-0">@shell.PanelTitle</h1>
                                <small class="text-muted">@shell.PanelSubtitle</small>
                            </div>
                        </div>
                    </div>
                </section>
            }

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Admin/_AdminFooter.cshtml" />
        }
    </div>

    <script src="~/vendor/AdminLTE-3.2.0/plugins/jquery/jquery.min.js"></script>
    <script src="~/vendor/AdminLTE-3.2.0/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/AdminLTE-3.2.0/dist/js/adminlte.min.js"></script>
    <script>
        (function () {
            var content = document.querySelector('.content-wrapper');
            if (!content) {
                return;
            }

            content.querySelectorAll('input').forEach(function (el) {
                var type = (el.getAttribute('type') || 'text').toLowerCase();
                if (type === 'checkbox' || type === 'radio') {
                    if (!el.classList.contains('form-check-input')) {
                        el.classList.add('form-check-input');
                    }
                    return;
                }
                if (type === 'file') {
                    if (!el.classList.contains('form-control-file')) {
                        el.classList.add('form-control-file');
                    }
                    return;
                }
                if (!el.classList.contains('form-control')) {
                    el.classList.add('form-control');
                }
                if (!el.classList.contains('form-control-sm')) {
                    el.classList.add('form-control-sm');
                }
            });

            content.querySelectorAll('select, textarea').forEach(function (el) {
                if (!el.classList.contains('form-control')) {
                    el.classList.add('form-control');
                }
                if (!el.classList.contains('form-control-sm')) {
                    el.classList.add('form-control-sm');
                }
            });

            content.querySelectorAll('button').forEach(function (el) {
                if (el.classList.contains('btn')) {
                    return;
                }
                el.classList.add('btn', 'btn-primary', 'btn-sm');
            });

            content.querySelectorAll('table.admin-table').forEach(function (el) {
                el.classList.add('table', 'table-striped', 'table-hover', 'text-nowrap');
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
