@using System.Security.Claims
@using otelturizmnew.Models.Paneller.Admin
@inject otelturizmnew.Services.Abstractions.IPanelThemeService PanelThemeService
@{
    Layout = null;
    var pageCssPath = ViewData["PageCssPath"] as string ?? ViewData["PageCss"] as string;
    var pageCssMobilePath = ViewData["PageCssMobilePath"] as string ?? ViewData["PageCssMobile"] as string;
    var shell = ViewData["AdminShell"] as AdminShellViewModel;
    if (shell is null && ViewData.Model is not null)
    {
        var shellProperty = ViewData.Model.GetType().GetProperty("Shell");
        shell = shellProperty?.GetValue(ViewData.Model) as AdminShellViewModel;
        if (shell is not null)
        {
            ViewData["AdminShell"] = shell;
        }
    }
    var title = ViewData["Title"] as string ?? shell?.PanelTitle ?? "Admin Panel";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var hideLayoutHeader = string.Equals(currentAction, "Dashboard", StringComparison.OrdinalIgnoreCase);
    var nonce = Context.Items["CspNonce"] as string;
    var rawUserId = Context.User.FindFirstValue(otelturizmnew.Constants.AuthClaimTypes.UserId) ?? Context.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var userId = long.TryParse(rawUserId, out var parsedUserId) ? parsedUserId : 0;
    var theme = userId > 0 ? await PanelThemeService.LoadAsync("admin", userId, Context.RequestAborted) : new otelturizmnew.Models.Paneller.Partner.PanelThemeViewModel();
    var bsTheme = (theme?.BsTheme ?? "light").Trim().ToLowerInvariant();
    if (bsTheme != "light" && bsTheme != "dark" && bsTheme != "auto") { bsTheme = "light"; }
    var dir = theme?.Rtl == true ? "rtl" : "ltr";

    string BuildThemeStyle()
    {
        var parts = new List<string>();
        var accentHex = !string.IsNullOrWhiteSpace(theme?.AccentHex) ? theme!.AccentHex : theme?.PrimaryHex;
        if (!string.IsNullOrWhiteSpace(accentHex)) parts.Add($"--ap-primary-red: {accentHex};");
        if (!string.IsNullOrWhiteSpace(theme?.SidebarBgHex))
            parts.Add($"--ap-sidebar-bg: {theme!.SidebarBgHex};");
        if (!string.IsNullOrWhiteSpace(theme?.FontFamily))
            parts.Add($"--ap-font-sans: {theme!.FontFamily}, 'Inter', sans-serif;");
        return string.Join(" ", parts);
    }
}
<!DOCTYPE html>
<html lang="tr" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@title - Otelturizm Admin</title>
    <link rel="stylesheet" href="~/assets/vendor/fonts/inter/inter-local.css" asp-append-version="true" />
    <partial name="~/Views/Shared/_VendorPlusJakartaFont.cshtml" />
    <link rel="stylesheet" href="~/assets/vendor/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/admin_panel_masaustu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/admin_panel_mobil.css" asp-append-version="true" media="(max-width: 991px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-form-ux.mobile.css" asp-append-version="true" media="(max-width: 991px)" />
    <link rel="stylesheet" href="~/assets/css/paneller/panel-toasts.mobile.css" asp-append-version="true" media="(max-width: 991px)" />
    @if (!string.IsNullOrWhiteSpace(pageCssPath))
    {
        var pageCssMobileHref = !string.IsNullOrWhiteSpace(pageCssMobilePath)
            ? $"~/assets/css/{pageCssMobilePath}.css"
            : pageCssPath.EndsWith("_masaustu", StringComparison.OrdinalIgnoreCase)
                ? $"~/assets/css/{pageCssPath[..^"_masaustu".Length]}_mobil.css"
                : $"~/assets/css/{pageCssPath}.mobile.css";
        <link rel="stylesheet" href="~/assets/css/@(pageCssPath).css" asp-append-version="true" />
        <link rel="stylesheet" href="@pageCssMobileHref" asp-append-version="true" media="(max-width: 991px)" />
    }
</head>
<body class="admin-panel-shell" style="@BuildThemeStyle()">
    <div class="admin-shell-container">
        @if (shell is not null)
        {
            <partial name="~/Views/Paneller/Admin/_AdminSidebar.cshtml" model="shell" />
            <div class="admin-sidebar-backdrop" id="adminSidebarBackdrop" aria-hidden="true"></div>
        }

        <div class="main-layout">
            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Admin/_AdminTopNav.cshtml" model="shell" />
            }

            <main class="content-body">
                @if (shell is not null && !hideLayoutHeader)
                {
                    <div class="ap-page-header d-print-none">
                        <div>
                            <div class="ap-page-pretitle">Admin Panel</div>
                            <h1>@shell.PanelTitle</h1>
                            @if (!string.IsNullOrWhiteSpace(shell.PanelSubtitle))
                            {
                                <p>@shell.PanelSubtitle</p>
                            }
                        </div>
                    </div>
                }
                <partial name="~/Views/Paneller/Common/_PanelToasts.cshtml" />
                @RenderBody()
            </main>

            @if (shell is not null)
            {
                <partial name="~/Views/Paneller/Admin/_AdminFooter.cshtml" />
                <partial name="~/Views/Paneller/Admin/_AdminMobileNav.cshtml" model="shell" />

                <div class="admin-theme-backdrop" id="adminThemeBackdrop" aria-hidden="true"></div>
                <aside class="admin-theme-drawer" id="adminThemeSettings" aria-labelledby="adminThemeSettingsLabel" aria-hidden="true">
                    <div class="admin-theme-drawer-header">
                        <h2 id="adminThemeSettingsLabel">Tema Ayarları</h2>
                        <button type="button" class="admin-theme-close" id="adminThemeClose" aria-label="Kapat"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="admin-theme-drawer-body">
                        <form method="post" action="/admin/tema/kaydet">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <input type="hidden" name="PrimaryHex" id="adminThemePrimaryHex" value="@(theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="AccentHex" id="adminThemeAccentHex" value="@(theme?.AccentHex ?? theme?.PrimaryHex ?? string.Empty)" />
                            <input type="hidden" name="SidebarBgHex" id="adminThemeSidebarBgHex" value="@(theme?.SidebarBgHex ?? string.Empty)" />
                            <label class="form-group"><span>Renk modu</span></label>
                            <div class="ap-theme-options">
                                <label class="ap-theme-option">
                                    <input type="radio" name="BsTheme" value="light" @(string.Equals(bsTheme, "light", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span><i class="fas fa-sun"></i> Açık</span>
                                </label>
                                <label class="ap-theme-option">
                                    <input type="radio" name="BsTheme" value="dark" @(string.Equals(bsTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                    <span><i class="fas fa-moon"></i> Koyu</span>
                                </label>
                            </div>
                            <label class="form-group"><span>Ana renk</span></label>
                            <div class="ap-color-swatches" data-color-palette="admin-primary">
                                @foreach (var color in new[] { "#DC2626", "#2563eb", "#0ea5e9", "#10b981", "#f59e0b", "#8b5cf6", "#334155" })
                                {
                                    <button type="button" class="btn-color-swatch" style="background:@color" data-color="@color" aria-label="@color"></button>
                                }
                            </div>
                            <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Temayı Kaydet</button>
                        </form>
                    </div>
                </aside>
            }
        </div>
    </div>

    <script src="~/assets/js/panel-toasts.js" asp-append-version="true"></script>
    <script src="~/assets/js/admin_panel-shell.js" asp-append-version="true"></script>
    <script nonce="@nonce">
    (() => {
        const primaryInput = document.getElementById('adminThemePrimaryHex');
        const accentInput = document.getElementById('adminThemeAccentHex');
        document.querySelectorAll('[data-color-palette="admin-primary"] [data-color]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const hex = btn.getAttribute('data-color') || '';
                if (primaryInput) primaryInput.value = hex;
                if (accentInput) accentInput.value = hex;
                document.documentElement.style.setProperty('--ap-primary-red', hex);
            });
        });
    })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
