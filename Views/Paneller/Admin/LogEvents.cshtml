@using otelturizmnew.Models.Paneller.Admin
@model AdminLogEventsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">@Model.Shell.PanelTitle</h3>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.Warning))
        {
            <div class="alert alert-warning">@Model.Warning</div>
        }

        <div class="text-muted small mb-2">Event: @Model.EventType · Son @Model.Take kayıt</div>

        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>Zaman</th>
                    <th>Mesaj</th>
                    <th>Raw</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@(row.Timestamp.HasValue ? row.Timestamp.Value.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") : "-")</td>
                        <td style="max-width:520px;white-space:normal;">@row.Message</td>
                        <td style="max-width:640px;white-space:normal;"><code>@row.Raw</code></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

