@model otelturizmnew.Models.Paneller.Admin.AdminApprovalCenterPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
}

<section class="admin-approval-page">
    <div class="admin-kpi-grid admin-approval-kpis">
        @foreach (var card in Model.SummaryCards)
        {
            var tone = string.IsNullOrWhiteSpace(card.ToneClass) ? "info" : card.ToneClass;
            <article class="admin-kpi-card @tone">
                <span class="kpi-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    <article class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">MERKEZI ONAY AKIŞI</p>
                <h2>Bekleyen Onaylar</h2>
                <span>Partner, firma ve otel yayın onayları admin kararı olmadan yayına çıkmaz.</span>
            </div>
            <div class="admin-action-pills panel-form-ux-bulk-actions">
                <a class="btn btn-outline-primary btn-sm" href="/admin/partner-basvurulari">Partnerler</a>
                <a class="btn btn-outline-primary btn-sm" href="/admin/partner-evraklari">Evraklar</a>
                <a class="btn btn-outline-primary btn-sm" href="/admin/firma-basvurulari">Firmalar</a>
                <a class="btn btn-primary btn-sm" href="/admin/oteller">Oteller · toplu yayın</a>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table approval-table admin-table--cards">
                <thead>
                    <tr>
                        <th>Tip</th>
                        <th>Kayıt</th>
                        <th>Detay</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.PendingApprovals)
                    {
                        <tr class="approval-row-@row.ToneClass">
                            <td data-label="Tip"><span class="approval-type">@row.Type</span></td>
                            <td data-label="Kayıt"><strong>@row.Title</strong><small>#@row.EntityId</small></td>
                            <td data-label="Detay">@row.Detail</td>
                            <td data-label="Durum"><span class="table-status @row.ToneClass">@row.StatusText</span></td>
                            <td data-label="Tarih">@row.CreatedAtText</td>
                            <td data-label="Aksiyon"><a class="btn btn-outline-primary btn-sm" href="@row.ActionUrl">İncele</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>

    <article class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">OTEL YAYIN VE KOMISYON KONTROLÜ</p>
                <h2>Partner Otelleri</h2>
                <span>Liste kart değil tablo mantığında; yayın, askı, onay, ciro ve komisyon takibi aynı satırda.</span>
            </div>
            <div class="admin-action-pills panel-form-ux-bulk-actions">
                <a class="btn btn-outline-primary btn-sm" href="/admin/komisyonlar">Komisyon Kuralı</a>
                <a class="btn btn-outline-success btn-sm" href="/admin/oteller?approvalStatus=Beklemede">Toplu yayın (T356)</a>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table approval-table admin-table--cards">
                <thead>
                    <tr>
                        <th class="admin-hotels-select-head" scope="col" aria-label="Toplu seçim için oteller sayfasına gidin"></th>
                        <th>Otel</th>
                        <th>Partner</th>
                        <th>Konum</th>
                        <th>Onay</th>
                        <th>Yayın</th>
                        <th>Komisyon</th>
                        <th>Bu Ay Ciro</th>
                        <th>Bu Ay Komisyon</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Hotels)
                    {
                        <tr>
                            <td data-label="Seç" class="admin-hotels-select-cell">
                                <a class="btn btn-outline-secondary btn-sm" href="/admin/oteller#hotel-@row.HotelId" title="Oteller listesinde düzenle">↗</a>
                            </td>
                            <td data-label="Otel"><strong>@row.HotelName</strong><small>#@row.HotelId</small></td>
                            <td data-label="Partner">@row.PartnerName</td>
                            <td data-label="Konum">@row.CityLabel</td>
                            <td data-label="Onay"><span class="table-status @row.ToneClass">@row.ApprovalStatus</span></td>
                            <td data-label="Yayın"><span class="table-status @row.ToneClass">@row.PublishStatus</span></td>
                            <td data-label="Komisyon">%@row.CommissionRate.ToString("0.##", tr)</td>
                            <td data-label="Bu Ay Ciro"><strong>@row.MonthRevenue.ToString("N0", tr) TL</strong></td>
                            <td data-label="Bu Ay Komisyon">@row.MonthCommission.ToString("N0", tr) TL</td>
                            <td data-label="Aksiyon" class="approval-actions">
                                <a class="btn btn-outline-primary btn-sm" href="/admin/otel-detay/@row.HotelId">Detay</a>
                                <a class="btn btn-outline-success btn-sm" href="/admin/komisyonlar?hotelId=@row.HotelId">Komisyon</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>

    <article class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">FATURA VE MUHASEBE</p>
                <h2>Son Faturalar</h2>
                <span>Kullanıcı, firma ve partner konaklama faturaları tek muhasebe izinde takip edilir.</span>
            </div>
            <a class="btn btn-outline-primary btn-sm" href="/admin/faturalar">Faturalar</a>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table approval-table admin-table--cards">
                <thead>
                    <tr>
                        <th>Fatura</th>
                        <th>Tür</th>
                        <th>Otel</th>
                        <th>Alıcı</th>
                        <th>Durum</th>
                        <th>Tutar</th>
                        <th>Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Invoices)
                    {
                        <tr>
                            <td data-label="Fatura"><strong>@row.InvoiceNo</strong><small>#@row.InvoiceId</small></td>
                            <td data-label="Tür">@row.InvoiceType</td>
                            <td data-label="Otel">@row.HotelName</td>
                            <td data-label="Alıcı">@row.BuyerTitle</td>
                            <td data-label="Durum"><span class="table-status @row.ToneClass">@row.StatusText</span></td>
                            <td data-label="Tutar"><strong>@row.TotalAmount.ToString("N0", tr) TL</strong></td>
                            <td data-label="Tarih">@row.DateText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>
</section>
