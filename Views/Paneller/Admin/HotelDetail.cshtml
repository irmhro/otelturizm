@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const pager = document.querySelector('.admin-section-pager');
            if (!pager) return;

            const links = Array.from(pager.querySelectorAll('a[data-tab-target]'));
            const panels = Array.from(document.querySelectorAll('.admin-tab-panel'));

            function showPanel(id) {
                panels.forEach(function (panel) {
                    panel.hidden = panel.id !== id;
                });
                links.forEach(function (link) {
                    link.classList.toggle('is-active', link.getAttribute('data-tab-target') === id);
                });
                if (history.replaceState) {
                    history.replaceState(null, '', '#' + id);
                }
            }

            function bindTabJump(el) {
                el.addEventListener('click', function (event) {
                    var targetId = el.getAttribute('data-tab-jump') || (el.getAttribute('href') || '').replace('#', '');
                    if (!targetId) return;
                    event.preventDefault();
                    showPanel(targetId);
                });
            }

            links.forEach(function (link) {
                link.addEventListener('click', function (event) {
                    event.preventDefault();
                    var targetId = link.getAttribute('data-tab-target');
                    if (targetId) showPanel(targetId);
                });
            });

            document.querySelectorAll('[data-tab-jump]').forEach(bindTabJump);

            const initial = (location.hash || '#tab-genel').replace('#', '');
            showPanel(links.some(function (l) { return l.getAttribute('data-tab-target') === initial; }) ? initial : 'tab-genel');
        })();

        (function () {
            const form = document.getElementById('hotel-master-form');
            if (!form || !form.action || form.action.indexOf('/admin/oteller/kaydet') === -1) return;

            const statusBox = document.getElementById('admin-hotel-autosave-status');
            const debounceMs = 1200;
            let saveTimer = 0;
            let statusTimer = 0;
            let saveRequestId = 0;
            let isReady = false;
            let lastSnapshot = '';

            const snapshotForm = function () {
                const fd = buildFormData();
                const parts = [];
                fd.forEach(function (value, key) {
                    if (key === '__RequestVerificationToken') return;
                    parts.push(key + '=' + value);
                });
                parts.sort();
                return parts.join('&');
            };

            const buildFormData = function () {
                const fd = new FormData(form);
                form.querySelectorAll('input[type="checkbox"][name]').forEach(function (cb) {
                    if (!cb.checked) {
                        fd.set(cb.name, 'false');
                    }
                });
                return fd;
            };

            const showStatus = function (message, tone) {
                if (!statusBox) return;
                window.clearTimeout(statusTimer);
                statusBox.hidden = false;
                statusBox.dataset.tone = tone;
                statusBox.querySelector('span').textContent = message;
                const icon = statusBox.querySelector('i');
                icon.className = tone === 'success'
                    ? 'fas fa-circle-check'
                    : tone === 'danger'
                        ? 'fas fa-triangle-exclamation'
                        : 'fas fa-circle-notch fa-spin';
                if (tone !== 'info') {
                    statusTimer = window.setTimeout(function () { statusBox.hidden = true; }, tone === 'success' ? 2800 : 4200);
                }
            };

            const save = async function () {
                window.clearTimeout(saveTimer);
                const snapshot = snapshotForm();
                if (!isReady || snapshot === lastSnapshot) return;

                const requestId = ++saveRequestId;
                showStatus('Kaydediliyor...', 'info');

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: buildFormData(),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const payload = await response.json().catch(function () {
                        return { success: false, message: 'Kayıt sonucu okunamadı.' };
                    });

                    if (requestId !== saveRequestId) return;

                    if (!response.ok || !payload.success) {
                        showStatus(payload.message || 'Kayıt tamamlanamadı.', 'danger');
                        return;
                    }

                    lastSnapshot = snapshot;
                    showStatus(payload.message || 'Kaydedildi', 'success');
                } catch (error) {
                    if (requestId !== saveRequestId) return;
                    showStatus(error && error.message ? error.message : 'Bağlantı hatası.', 'danger');
                }
            };

            const scheduleSave = function () {
                window.clearTimeout(saveTimer);
                saveTimer = window.setTimeout(save, debounceMs);
            };

            form.addEventListener('submit', function (event) {
                event.preventDefault();
                window.clearTimeout(saveTimer);
                save();
            });

            form.querySelectorAll('input:not([type="hidden"]):not([type="file"]), select, textarea').forEach(function (field) {
                const eventName = field.tagName === 'SELECT' || field.type === 'checkbox' || field.type === 'radio'
                    ? 'change'
                    : 'input';
                field.addEventListener(eventName, scheduleSave);
                if (eventName === 'input') {
                    field.addEventListener('blur', function () {
                        window.clearTimeout(saveTimer);
                        save();
                    });
                }
            });

            window.setTimeout(function () {
                lastSnapshot = snapshotForm();
                isReady = true;
            }, 0);
        })();
    </script>
}
