@using otelturizmnew.Models.Paneller.Admin
@model AdminHotelManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var currentUserRole = User.FindFirst("otelturizm:user_role")?.Value ?? string.Empty;
    var canDeactivateHotel = string.Equals(currentUserRole, "admin", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentUserRole, "superadmin", StringComparison.OrdinalIgnoreCase)
        || User.IsInRole("admin")
        || User.IsInRole("superadmin");
    var isHotelPassive = string.Equals(Model.HotelForm.PublishStatus, "Kapatıldı", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.HotelForm.PublishStatus, "Kapal\u0131", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.HotelForm.PublishStatus, "Askıda", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.HotelForm.PublishStatus, "Askida", StringComparison.OrdinalIgnoreCase);
    var hotelTypes = new[] { "Hotel", "Otel", "Butik Otel", "Apart Otel", "Villa", "Pansiyon", "Tatil Köyü", "Hostel", "Kamping", "Apartman Dairesi", "Resort Hotel", "City Hotel", "Business Hotel", "Airport Hotel", "Boutique Hotel", "Bungalow", "Glamping", "Residence", "Motel", "Thermal Hotel", "Ski Hotel", "Beach Hotel", "Luxury Hotel" };
    var tourismTypes = new[] { "Turizm İşletme Belgeli", "Turizm Yatırım Belgeli", "Belediye Belgeli", "Basit Konaklama Belgeli", "Belgesiz" };
    var publishStatuses = new[] { "Taslak", "Yayında", "Bakımda", "Sezon Dışı", "Kapatıldı", "Askıda" };
    var approvalStatuses = new[] { "Beklemede", "İçerik Eksik", "Onaylandı", "Reddedildi" };
    var commissionTypes = new[] { "sabit_oran", "oda_bazli", "sezon_bazli", "karma" };
    var calcTypes = new[] { "gecelik_fiyat_uzerinden", "toplam_tutar_uzerinden", "kira_bedeli_uzerinden" };
    var paymentTerms = new[] { "Rezervasyon Anında", "Giriş Günü", "Çıkış Günü", "Haftalık", "Aylık", "15 Günde Bir" };
    var paymentMethods = new[] { "Havale/EFT", "Sanal POS (Platform Tahsilat)", "Otel Tahsilatı" };
    var invoiceTypes = new[] { "Platform Keser", "Otel Keser" };
    var roomCategories = new[] { "Standart", "Superior", "Deluxe", "Junior Suite", "Suite", "Executive Suite", "Presidential Suite", "Aile Odası", "Engelli Odası", "Villa" };
    var bedTypes = new[] { "Tek Kişilik", "Çift Kişilik", "Queen Size", "King Size", "Super King Size", "Ranza", "Çekyat" };
    var viewTypes = new[] { "Yok", "Deniz", "Havuz", "Bahçe", "Dağ", "Şehir", "Göl", "İç Avlu" };
    var bathroomTypes = new[] { "Duş", "Küvet", "Jakuzi", "Duş ve Küvet" };
    var hotelPhotoTypes = new[] { "Dış Cephe", "Lobi", "Restoran", "Havuz", "Plaj", "Oda", "Banyo", "Spor Salonu", "SPA", "Toplantı Odası", "Genel Alan", "Yemek", "Manzara" };
}

<section class="admin-summary-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="admin-summary-card @card.ToneClass">
            <div class="summary-icon"><i class="fas @card.IconClass"></i></div>
            <div>
                <p>@card.Label</p>
                <h2>@card.Value</h2>
                <span>@card.Description</span>
            </div>
        </article>
    }
</section>

<div class="admin-page-links">
    <a href="/admin/oteller" class="admin-text-link"><i class="fas fa-arrow-left"></i> Otel listesine don</a>
</div>

@if (TempData["AdminHotelMessage"] is string successMessage)
{
    <div class="admin-alert is-success"><i class="fas fa-circle-check"></i><span>@successMessage</span></div>
}
@if (TempData["AdminHotelError"] is string errorMessage)
{
    <div class="admin-alert is-error"><i class="fas fa-triangle-exclamation"></i><span>@errorMessage</span></div>
}

@{
    var completenessTone = Model.CompletenessScore >= 85 ? "is-strong" : Model.CompletenessScore >= 60 ? "is-mid" : "is-weak";
    ViewBag.HotelTypes = hotelTypes;
    ViewBag.TourismTypes = tourismTypes;
    ViewBag.PublishStatuses = publishStatuses;
    ViewBag.ApprovalStatuses = approvalStatuses;
    ViewBag.CommissionTypes = commissionTypes;
    ViewBag.CalcTypes = calcTypes;
    ViewBag.PaymentTerms = paymentTerms;
    ViewBag.PaymentMethods = paymentMethods;
    ViewBag.InvoiceTypes = invoiceTypes;
}

<section class="admin-hotel-completeness-banner @completenessTone">
    <div class="admin-hotel-completeness-score">
        <div class="admin-hotel-completeness-ring"><strong>@Model.CompletenessScore%</strong></div>
        <div>
            <span class="mini-caption">PROFİL TAMAMLANMA</span>
            <p>@Model.CompletenessCompletedRules / @Model.CompletenessTotalRules kural karşılandı</p>
            @if (Model.CompletenessCriticalMissingCount > 0){<small class="is-critical">@Model.CompletenessCriticalMissingCount kritik eksik</small>}
        </div>
    </div>
    <div class="admin-hotel-completeness-chips">
        @if (Model.MissingFields.Count == 0)
        {
            <span class="admin-completeness-chip is-complete"><i class="fas fa-circle-check"></i> Tüm zorunlu alanlar tamam</span>
        }
        else
        {
            @foreach (var field in Model.MissingFields)
            {
                <a href="#@field.TabTarget" class="admin-completeness-chip @(string.Equals(field.Severity, "critical", StringComparison.OrdinalIgnoreCase) ? "is-critical" : "is-warning")" data-tab-jump="@field.TabTarget">@field.FieldLabel</a>
            }
        }
    </div>
</section>

<section class="admin-hotel-command-bar">
    <div class="admin-hotel-command-copy">
        <h2>@Model.HotelForm.HotelName</h2>
        <p>Kod: @Model.HotelForm.HotelCode · Durum: @Model.HotelForm.PublishStatus · Onay: @Model.HotelForm.ApprovalStatus</p>
    </div>
    <div class="admin-hotel-command-actions">
        <div class="admin-hotel-autosave-status" id="admin-hotel-autosave-status" role="status" aria-live="polite" hidden>
            <i class="fas fa-circle-notch fa-spin" aria-hidden="true"></i>
            <span>Kaydediliyor...</span>
        </div>
        @if (canDeactivateHotel)
        {
            @if (isHotelPassive)
            {
                <form method="post" action="/admin/oteller/aktive-et" onsubmit="return confirm('Oteli tekrar aktif duruma almak istediginize emin misiniz?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" />
                    <button type="submit" class="admin-action-btn primary ot-btn ot-btn--success"><i class="fas fa-power-off"></i> Oteli Aktif Et</button>
                </form>
            }
            else
            {
                <form method="post" action="/admin/oteller/pasife-al" onsubmit="return confirm('Oteli pasif duruma almak istediginize emin misiniz?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" />
                    <button type="submit" class="admin-action-btn danger ot-btn ot-btn--danger"><i class="fas fa-ban"></i> Oteli Pasife Al</button>
                </form>
            }
        }
        else
        {
            <span class="admin-lock-note"><i class="fas fa-lock"></i> Pasife alma islemi sadece admin yetkisindedir</span>
        }
    </div>
</section>

<nav class="admin-section-pager admin-section-pager--hotel-detail" aria-label="Otel yönetim sekmeleri">
    <a href="#tab-genel" class="is-active" data-tab-target="tab-genel">Genel</a>
    <a href="#tab-konum" data-tab-target="tab-konum">Konum</a>
    <a href="#tab-gorseller" data-tab-target="tab-gorseller">Görseller</a>
    <a href="#tab-odalar" data-tab-target="tab-odalar">Odalar</a>
    <a href="#tab-fiyatlar" data-tab-target="tab-fiyatlar">Fiyatlar</a>
    <a href="#tab-ozellikler" data-tab-target="tab-ozellikler">Özellikler</a>
    <a href="#tab-rezervasyonlar" data-tab-target="tab-rezervasyonlar">Rezervasyonlar</a>
    <a href="#tab-partner" data-tab-target="tab-partner">Partner / Evrak</a>
    <a href="#tab-onay" data-tab-target="tab-onay">Onay &amp; Yayın</a>
    <a href="#tab-eksikler" data-tab-target="tab-eksikler" class="@(Model.MissingFields.Count > 0 ? "has-missing" : "")">Eksikler @if (Model.MissingFields.Count > 0){<em>@Model.MissingFields.Count</em>}</a>
</nav>

<section class="admin-detail-grid admin-hotel-detail-layout">
    <partial name="~/Views/Paneller/Admin/_HotelDetailMasterForm.cshtml" model="Model.HotelForm" />

    <article class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="tab-partner" hidden>
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">PARTNER_DETAYLARI + OTELLER</p>
                <h2>Yonetici bilgileri</h2>
                <p>Partner yetkili ve otel satis kontak bilgileri.</p>
            </div>
            @if (Model.HotelForm.PartnerId > 0)
            {
                <a class="admin-action-btn secondary" href="/admin/partner-basvurulari?partnerId=@Model.HotelForm.PartnerId">Partner kaydina git</a>
            }
        </div>
        <dl class="admin-readonly-grid">
            <div><dt>Firma unvani</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.CompanyName) ? "—" : Model.ManagerInfo.CompanyName)</dd></div>
            <div><dt>Yetkili ad soyad</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.ManagerName) ? "—" : Model.ManagerInfo.ManagerName)</dd></div>
            <div><dt>Yetkili telefon</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.ManagerPhone) ? "—" : Model.ManagerInfo.ManagerPhone)</dd></div>
            <div><dt>Yetkili e-posta</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.ManagerEmail) ? "—" : Model.ManagerInfo.ManagerEmail)</dd></div>
            <div><dt>Yetkili gorev</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.ManagerRole) ? "—" : Model.ManagerInfo.ManagerRole)</dd></div>
            <div><dt>Partner onay</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.ApprovalStatus) ? "—" : Model.ManagerInfo.ApprovalStatus)</dd></div>
            <div><dt>Satis kontak</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.SalesContactName) ? "—" : Model.ManagerInfo.SalesContactName)</dd></div>
            <div><dt>Satis telefon</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.SalesContactPhone) ? "—" : Model.ManagerInfo.SalesContactPhone)</dd></div>
            <div><dt>Satis e-posta</dt><dd>@(string.IsNullOrWhiteSpace(Model.ManagerInfo.SalesContactEmail) ? "—" : Model.ManagerInfo.SalesContactEmail)</dd></div>
        </dl>

        <div class="admin-section-head top-gap">
            <div>
                <p class="mini-caption">OTEL_KULLANICI_SAHIPLIKLERI</p>
                <h3>Partner kullanıcıları</h3>
            </div>
        </div>
        @if (Model.PartnerUsers.Count == 0)
        {
            <div class="admin-empty-state">Bu otele bagli partner kullanicisi bulunamadi.</div>
        }
        else
        {
            <div class="admin-hotels-table-wrap">
                <table class="admin-hotels-table">
                    <thead><tr><th>Kullanici ID</th><th>Ad soyad</th><th>E-posta</th><th>Telefon</th><th>Rol</th><th>Ana sorumlu</th><th>Durum</th><th>Baglanti</th></tr></thead>
                    <tbody>
                        @foreach (var user in Model.PartnerUsers)
                        {
                            <tr>
                                <td>@user.UserId</td>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@(string.IsNullOrWhiteSpace(user.Phone) ? "—" : user.Phone)</td>
                                <td>@user.Role</td>
                                <td>@(user.IsMainResponsible ? "Evet" : "Hayir")</td>
                                <td><span class="admin-chip @(user.IsActive ? "success" : "warning")">@(user.IsActive ? "Aktif" : "Pasif")</span></td>
                                <td>@(user.LinkedAt?.ToString("dd.MM.yyyy") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="admin-section-head top-gap">
            <div>
                <p class="mini-caption">PLATFORM_EPOSTA_HESAPLARI</p>
                <h3>E-posta hesapları</h3>
            </div>
            <a class="admin-action-btn secondary" href="/admin/e-posta-sablonlari">E-posta merkezi</a>
        </div>
        @if (Model.EmailAccounts.Count == 0)
        {
            <div class="admin-empty-state">Bu otel icin tanimli e-posta hesabi bulunamadi.</div>
        }
        else
        {
            <div class="admin-hotels-table-wrap">
                <table class="admin-hotels-table">
                    <thead><tr><th>Kaynak</th><th>Hesap adi</th><th>E-posta</th><th>Protokol</th><th>Varsayilan</th><th>Durum</th><th>Son senkron</th></tr></thead>
                    <tbody>
                        @foreach (var account in Model.EmailAccounts)
                        {
                            <tr>
                                <td>@account.Source</td>
                                <td>@account.AccountName</td>
                                <td>@account.EmailAddress</td>
                                <td>@account.Protocol</td>
                                <td>@(account.IsDefaultSender ? "Evet" : "—")</td>
                                <td><span class="admin-chip @(account.IsActive ? "success" : "warning")">@(account.IsActive ? "Aktif" : "Pasif")</span></td>
                                <td>@(account.LastSyncAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="admin-section-head top-gap">
            <div>
                <p class="mini-caption">PARTNER_BASVURU_EVRAKLARI</p>
                <h3>Partner evrakları</h3>
                <p>Partner ID: @Model.HotelForm.PartnerId</p>
            </div>
            @if (Model.HotelForm.PartnerId > 0)
            {
                <a class="admin-action-btn secondary" href="/admin/partner-evraklari?partnerId=@Model.HotelForm.PartnerId">Evrak merkezi</a>
            }
        </div>
        @if (Model.Documents.Count == 0)
        {
            <div class="admin-empty-state">Bu partner için yüklenmiş evrak bulunamadı.</div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table admin-table--cards">
                    <thead><tr><th>Başlık</th><th>Tip</th><th>Durum</th><th>Yükleme</th></tr></thead>
                    <tbody>
                        @foreach (var doc in Model.Documents)
                        {
                            <tr>
                                <td>@doc.Title</td>
                                <td>@doc.Type</td>
                                <td><span class="admin-chip info">@doc.Status</span></td>
                                <td>@(doc.UploadedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="tab-rezervasyonlar" hidden>
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">REZERVASYONLAR + OTEL_ISTATISTIKLERI</p>
                <h2>Rezervasyon istatistikleri</h2>
            </div>
            <a class="admin-action-btn secondary" href="/admin/rezervasyonlar?hotelId=@Model.HotelForm.HotelId">Tum rezervasyonlar</a>
        </div>
        <div class="admin-summary-grid compact">
            <article class="admin-summary-card info"><div><p>Toplam rezervasyon</p><h2>@Model.ReservationStats.TotalReservations</h2></div></article>
            <article class="admin-summary-card success"><div><p>Benzersiz misafir</p><h2>@Model.ReservationStats.UniqueGuestCount</h2></div></article>
            <article class="admin-summary-card warning"><div><p>Onayli</p><h2>@Model.ReservationStats.ConfirmedCount</h2></div></article>
            <article class="admin-summary-card danger"><div><p>Iptal</p><h2>@Model.ReservationStats.CancelledCount</h2></div></article>
            <article class="admin-summary-card info"><div><p>Toplam ciro</p><h2>@Model.ReservationStats.TotalRevenue.ToString("0.##") TL</h2></div></article>
            <article class="admin-summary-card success"><div><p>Toplam komisyon</p><h2>@Model.ReservationStats.TotalCommission.ToString("0.##") TL</h2></div></article>
        </div>
        @if (Model.RecentReservations.Count == 0)
        {
            <div class="admin-empty-state top-gap">Bu otelde henuz rezervasyon kaydi yok.</div>
        }
        else
        {
            <div class="admin-hotels-table-wrap top-gap">
                <table class="admin-hotels-table">
                    <thead><tr><th>No</th><th>Misafir</th><th>E-posta</th><th>Oda</th><th>Giris</th><th>Cikis</th><th>Tutar</th><th>Komisyon %</th><th>Durum</th></tr></thead>
                    <tbody>
                        @foreach (var reservation in Model.RecentReservations)
                        {
                            <tr>
                                <td>@reservation.ReservationNo</td>
                                <td>@reservation.GuestName</td>
                                <td>@reservation.GuestEmail</td>
                                <td>@reservation.RoomName</td>
                                <td>@reservation.CheckIn.ToString("dd.MM.yyyy")</td>
                                <td>@reservation.CheckOut.ToString("dd.MM.yyyy")</td>
                                <td>@reservation.TotalAmount.ToString("0.##") TL</td>
                                <td>@reservation.CommissionRate.ToString("0.##")</td>
                                <td><span class="admin-chip info">@reservation.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="tab-odalar" hidden>
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">ODA_TIPLERI</p>
                <h2>Oda tipleri tablosu</h2>
            </div>
        </div>
        @if (Model.RoomTableRows.Count == 0)
        {
            <div class="admin-empty-state">Bu otelde tanimli oda tipi yok.</div>
        }
        else
        {
            <div class="admin-hotels-table-wrap">
                <table class="admin-hotels-table">
                    <thead><tr><th>ID</th><th>Kod</th><th>Ad</th><th>Kategori</th><th>Taban fiyat</th><th>Kapasite</th><th>Stok</th><th>Yatak</th><th>m2</th><th>Durum</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var room in Model.RoomTableRows)
                        {
                            <tr class="@(room.IsActive ? string.Empty : "is-passive-row")">
                                <td>@room.RoomId</td>
                                <td>@room.RoomCode</td>
                                <td>@room.RoomName</td>
                                <td>@room.Category</td>
                                <td>@room.BasePrice.ToString("0.##") TL</td>
                                <td>@room.MaxPeople</td>
                                <td>@room.TotalRooms</td>
                                <td>@(string.IsNullOrWhiteSpace(room.BedType) ? "—" : room.BedType)</td>
                                <td>@(room.RoomSize?.ToString() ?? "—")</td>
                                <td><span class="admin-chip @(room.IsActive ? "success" : "warning")">@(room.IsActive ? "Aktif" : "Pasif")</span></td>
                                <td><a href="/admin/otel-detay/@Model.HotelForm.HotelId?roomId=@room.RoomId" class="admin-text-link">Duzenle</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="admin-section-head top-gap"><div><p class="mini-caption">ODA TIPLERI</p><h3>Bağlı odalar</h3></div></div>
        <div class="admin-linked-list">
            @foreach (var room in Model.Rooms)
            {
                <article class="admin-linked-item @(room.IsActive ? string.Empty : "is-passive")">
                    <div>
                        <strong>@room.RoomName</strong>
                        <span>@room.RoomCode · @room.Category</span>
                        <small>@room.PriceText · @room.CapacityText · @room.StockText</small>
                    </div>
                    <div class="admin-inline-actions">
                        <a href="/admin/otel-detay/@Model.HotelForm.HotelId?roomId=@room.RoomId" class="admin-action-btn secondary ot-btn ot-btn--ghost">Düzenle</a>
                        <form method="post" action="/admin/oteller/oda-pasife-al" onsubmit="return confirm('Oda tipi pasife alınsın mı?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" />
                            <input type="hidden" name="roomId" value="@room.RoomId" />
                            <button type="submit" class="admin-action-btn danger ot-btn ot-btn--danger">Pasife al</button>
                        </form>
                    </div>
                </article>
            }
        </div>

        <div class="admin-section-head top-gap"><div><p class="mini-caption">ODA_TIPLERI</p><h3>@(Model.IsEditingRoom ? "Oda tipini düzenle" : "Yeni oda tipi ekle")</h3></div></div>
        <form method="post" action="/admin/oteller/oda-kaydet" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <input type="hidden" name="RoomId" value="@Model.RoomForm.RoomId" />
            <label><span>Oda kodu</span><input type="text" name="RoomCode" value="@Model.RoomForm.RoomCode" /></label>
            <label class="span-2"><span>Oda adı</span><input type="text" name="RoomName" value="@Model.RoomForm.RoomName" /></label>
            <label><span>Kategori</span><select name="RoomCategory">@foreach (var item in roomCategories){<option value="@item" selected="@(Model.RoomForm.RoomCategory == item)">@item</option>}</select></label>
            <label><span>Maks kişi</span><input type="number" name="MaxPeople" value="@Model.RoomForm.MaxPeople" /></label>
            <label><span>Taban fiyat</span><input type="number" step="0.01" name="BasePrice" value="@Model.RoomForm.BasePrice" /></label>
            <label><span>Toplam oda</span><input type="number" name="TotalRooms" value="@Model.RoomForm.TotalRooms" /></label>
            <label class="checkbox"><input type="checkbox" name="IsActive" value="true" checked="@Model.RoomForm.IsActive" /><span>Aktif</span></label>
            <div class="span-3 admin-form-actions"><button type="submit" class="admin-action-btn primary ot-btn ot-btn--primary"><i class="fas fa-floppy-disk"></i> Oda kaydını kaydet</button></div>
        </form>
    </article>

    <article class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="tab-fiyatlar" hidden>
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">ODA_FIYAT_MUSAITLIK + KOMISYON</p>
                <h2>Fiyat ve komisyon özeti</h2>
            </div>
            <a class="admin-action-btn secondary" href="/admin/komisyonlar">Komisyon merkezi</a>
        </div>
        <dl class="admin-readonly-grid">
            <div><dt>Komisyon türü</dt><dd>@Model.CommissionSummary.CommissionType</dd></div>
            <div><dt>Varsayılan oran %</dt><dd>@Model.CommissionSummary.DefaultCommissionRate.ToString("0.##")</dd></div>
            <div><dt>Toplam rezervasyon</dt><dd>@Model.CommissionSummary.TotalReservationAmount.ToString("0.##") TL</dd></div>
            <div><dt>Toplam komisyon</dt><dd>@Model.CommissionSummary.TotalCommissionAmount.ToString("0.##") TL</dd></div>
        </dl>
        @if (Model.PriceRows.Count == 0)
        {
