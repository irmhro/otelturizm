                            <p>@(string.IsNullOrWhiteSpace(photo.Description) ? "Aciklama girilmemis." : photo.Description)</p>
                            <div class="admin-inline-actions wrap">
                                <a href="/admin/otel-detay/@Model.HotelForm.HotelId?roomId=@photo.RoomId&roomPhotoId=@photo.PhotoId" class="admin-action-btn secondary">Duzenle</a>
                                <form method="post" action="/admin/oteller/oda-fotograf-kapak-yap">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="roomId" value="@photo.RoomId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn secondary">Kapak yap</button></form>
                                <form method="post" action="/admin/oteller/oda-fotograf-sil" onsubmit="return confirm('Oda fotografi silinsin mi?');">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="roomId" value="@photo.RoomId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn danger">Sil</button></form>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }

        <form method="post" action="/admin/oteller/oda-fotograf-guncelle" class="admin-form-grid compact top-gap">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <input type="hidden" name="RoomId" value="@Model.RoomPhotoEditForm.RoomId" />
            <input type="hidden" name="PhotoId" value="@Model.RoomPhotoEditForm.PhotoId" />
            <label><span>Secili baslik</span><input type="text" name="Title" value="@Model.RoomPhotoEditForm.Title" /></label>
            <label><span>Siralama</span><input type="number" name="DisplayOrder" value="@Model.RoomPhotoEditForm.DisplayOrder" /></label>
            <label class="span-2"><span>Aciklama</span><textarea name="Description">@Model.RoomPhotoEditForm.Description</textarea></label>
            <div class="span-2 admin-form-actions"><button type="submit" class="admin-action-btn secondary" @(Model.IsEditingRoomPhoto ? null : "disabled")>Secili oda gorselini guncelle</button></div>
        </form>
    }
</section>

<section class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="section-evraklar" hidden>
    <div class="admin-section-head">
        <div>
            <p class="mini-caption">PARTNER_BASVURU_EVRAKLARI</p>
            <h2>Partner evraklari</h2>
            <p>Partner ID: @Model.HotelForm.PartnerId</p>
        </div>
        @if (Model.HotelForm.PartnerId > 0)
        {
            <a class="admin-action-btn secondary" href="/admin/partner-evraklari?partnerId=@Model.HotelForm.PartnerId">Partner evrak merkezi</a>
        }
    </div>
    @if (Model.Documents.Count == 0)
    {
        <div class="admin-empty-state">Bu partner icin yuklenmis evrak bulunamadi.</div>
    }
    else
    {
        <div class="admin-hotels-table-wrap">
            <table class="admin-hotels-table">
                <thead><tr><th>Baslik</th><th>Tip</th><th>Durum</th><th>Yukleme</th></tr></thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        <tr>
                            <td>@doc.Title</td>
                            <td>@doc.Type</td>
                            <td><span class="admin-chip info">@doc.Status</span></td>
                            <td>@(doc.UploadedAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    @{
        var nonce = Context.Items["CspNonce"] as string;
    }
    <script nonce="@nonce">
        (function () {
            const pager = document.querySelector('.admin-section-pager');
            if (!pager) return;

            const links = Array.from(pager.querySelectorAll('a[data-tab-target]'));
            const panels = Array.from(document.querySelectorAll('.admin-tab-panel, #section-temel-kayit'));

            function showPanel(id) {
                panels.forEach(function (panel) {
                    const isTarget = panel.id === id;
                    if (panel.classList.contains('admin-tab-panel')) {
                        panel.hidden = !isTarget;
                    } else if (panel.id === 'section-temel-kayit') {
                        panel.hidden = id !== 'section-temel-kayit';
                    }
                });
                links.forEach(function (link) {
                    link.classList.toggle('is-active', link.getAttribute('data-tab-target') === id);
                });
                if (history.replaceState) {
                    history.replaceState(null, '', '#' + id);
                }
            }

            links.forEach(function (link) {
                link.addEventListener('click', function (event) {
                    event.preventDefault();
                    const targetId = link.getAttribute('data-tab-target');
                    if (targetId) showPanel(targetId);
                });
            });

            const initial = (location.hash || '#section-temel-kayit').replace('#', '');
            showPanel(links.some(function (l) { return l.getAttribute('data-tab-target') === initial; }) ? initial : 'section-temel-kayit');
        })();
    </script>
}
