    <article class="admin-section-card admin-anchor-target ot-card admin-tab-panel" id="tab-eksikler" hidden>
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">TAMAMLANMA KONTROLÜ</p>
                <h2>Eksikler checklist</h2>
                <p>Partner kayıt akışı ve yayın öncesi zorunlu alanlar.</p>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table admin-hotel-completeness-table">
                <thead><tr><th>Alan</th><th>Önem</th><th>Durum</th><th>Sekme</th><th>Partner linki</th></tr></thead>
                <tbody>
                    @foreach (var rule in Model.CompletenessRules)
                    {
                        <tr class="@(rule.IsMissing ? "is-missing-row" : "is-complete-row")">
                            <td>@rule.FieldLabel</td>
                            <td><span class="admin-chip @(string.Equals(rule.Severity, "critical", StringComparison.OrdinalIgnoreCase) ? "danger" : "warning")">@rule.Severity</span></td>
                            <td>@(rule.IsMissing ? "Eksik" : "Tamam")</td>
                            <td><a href="#@rule.TabTarget" class="admin-text-link" data-tab-jump="@rule.TabTarget">@rule.TabTarget</a></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(rule.PartnerFixUrl))
                                {
                                    <a href="@rule.PartnerFixUrl" class="admin-text-link" target="_blank" rel="noopener">Partner paneli</a>
