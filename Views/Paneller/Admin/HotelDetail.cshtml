@using otelturizmnew.Models.Paneller.Admin
@model AdminHotelManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var hotelTypes = new[] { "Hotel", "Otel", "Butik Otel", "Apart Otel", "Villa", "Pansiyon", "Tatil Köyü", "Hostel", "Kamping", "Apartman Dairesi", "Resort Hotel", "City Hotel", "Business Hotel", "Airport Hotel", "Boutique Hotel", "Bungalow", "Glamping", "Residence", "Motel", "Thermal Hotel", "Ski Hotel", "Beach Hotel", "Luxury Hotel" };
    var tourismTypes = new[] { "Turizm İşletme Belgeli", "Turizm Yatırım Belgeli", "Belediye Belgeli", "Basit Konaklama Belgeli", "Belgesiz" };
    var publishStatuses = new[] { "Taslak", "Yayında", "Bakımda", "Sezon Dışı", "Kapatıldı", "Askıda" };
    var approvalStatuses = new[] { "Beklemede", "İçerik Eksik", "Onaylandı", "Reddedildi" };
    var commissionTypes = new[] { "sabit_oran", "oda_bazli", "sezon_bazli", "karma" };
    var calcTypes = new[] { "gecelik_fiyat_uzerinden", "toplam_tutar_uzerinden", "kira_bedeli_uzerinden" };
    var paymentTerms = new[] { "Rezervasyon Anında", "Giriş Günü", "Çıkış Günü", "Haftalık", "Aylık", "15 Günde Bir" };
    var paymentMethods = new[] { "Havale/EFT", "Sanal POS (Platform Tahsilat)", "Otel Tahsilatı" };
    var invoiceTypes = new[] { "Platform Keser", "Otel Keser" };
    var roomCategories = new[] { "Standart", "Superior", "Deluxe", "Junior Suite", "Suite", "Executive Suite", "Presidential Suite", "Aile Odası", "Engelli Odası", "Villa" };
    var bedTypes = new[] { "Tek Kişilik", "Çift Kişilik", "Queen Size", "King Size", "Super King Size", "Ranza", "Çekyat" };
    var viewTypes = new[] { "Yok", "Deniz", "Havuz", "Bahçe", "Dağ", "Şehir", "Göl", "İç Avlu" };
    var bathroomTypes = new[] { "Duş", "Küvet", "Jakuzi", "Duş ve Küvet" };
    var hotelPhotoTypes = new[] { "Dış Cephe", "Lobi", "Restoran", "Havuz", "Plaj", "Oda", "Banyo", "Spor Salonu", "SPA", "Toplantı Odası", "Genel Alan", "Yemek", "Manzara" };
}

<section class="admin-summary-grid">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="admin-summary-card @card.ToneClass">
            <div class="summary-icon"><i class="fas @card.IconClass"></i></div>
            <div>
                <p>@card.Label</p>
                <h2>@card.Value</h2>
                <span>@card.Description</span>
            </div>
        </article>
    }
</section>

<div class="admin-page-links">
    <a href="/admin/oteller" class="admin-text-link"><i class="fas fa-arrow-left"></i> Otel listesine don</a>
</div>

@if (TempData["AdminHotelMessage"] is string successMessage)
{
    <div class="admin-alert is-success"><i class="fas fa-circle-check"></i><span>@successMessage</span></div>
}
@if (TempData["AdminHotelError"] is string errorMessage)
{
    <div class="admin-alert is-error"><i class="fas fa-triangle-exclamation"></i><span>@errorMessage</span></div>
}

<section class="admin-detail-grid">
    <article class="admin-section-card admin-detail-main-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">OTELLER TABLOSU</p>
                <h2>Temel otel kaydi</h2>
                <p>Otelin ana kolonlari, yayin durumu, operasyon bilgileri ve finans ayarlari bu formdan yonetilir.</p>
            </div>
        </div>
        <form method="post" action="/admin/oteller/kaydet" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <label><span>Otel kodu</span><input type="text" name="HotelCode" value="@Model.HotelForm.HotelCode" /></label>
            <label><span>Partner ID</span><input type="number" name="PartnerId" value="@Model.HotelForm.PartnerId" /></label>
            <label><span>User ID</span><input type="number" name="UserId" value="@Model.HotelForm.UserId" /></label>
            <label class="span-2"><span>Otel adi</span><input type="text" name="HotelName" value="@Model.HotelForm.HotelName" /></label>
            <label><span>Otel turu</span><select name="HotelType">@foreach (var item in hotelTypes){<option value="@item" selected="@(Model.HotelForm.HotelType == item)">@item</option>}</select></label>
            <label><span>Yildiz</span><input type="number" name="StarCount" value="@Model.HotelForm.StarCount" min="0" max="7" /></label>
            <label><span>Belge no</span><input type="text" name="TourismDocumentNo" value="@Model.HotelForm.TourismDocumentNo" /></label>
            <label><span>Belge turu</span><select name="TourismDocumentType"><option value="">Seciniz</option>@foreach (var item in tourismTypes){<option value="@item" selected="@(Model.HotelForm.TourismDocumentType == item)">@item</option>}</select></label>
            <label><span>Ulke</span><input type="text" name="Country" value="@Model.HotelForm.Country" /></label>
            <label><span>Sehir</span><input type="text" name="City" value="@Model.HotelForm.City" /></label>
            <label><span>Ilce</span><input type="text" name="District" value="@Model.HotelForm.District" /></label>
            <label><span>Mahalle</span><input type="text" name="Neighborhood" value="@Model.HotelForm.Neighborhood" /></label>
            <label><span>Posta kodu</span><input type="text" name="PostalCode" value="@Model.HotelForm.PostalCode" /></label>
            <label><span>Enlem</span><input type="number" step="0.00000001" name="Latitude" value="@Model.HotelForm.Latitude" /></label>
            <label><span>Boylam</span><input type="number" step="0.00000001" name="Longitude" value="@Model.HotelForm.Longitude" /></label>
            <label class="span-3"><span>Tam adres</span><textarea name="Address">@Model.HotelForm.Address</textarea></label>
            <label><span>Telefon 1</span><input type="text" name="Phone1" value="@Model.HotelForm.Phone1" /></label>
            <label><span>Telefon 2</span><input type="text" name="Phone2" value="@Model.HotelForm.Phone2" /></label>
            <label><span>Faks</span><input type="text" name="Fax" value="@Model.HotelForm.Fax" /></label>
            <label><span>E-posta</span><input type="email" name="ContactEmail" value="@Model.HotelForm.ContactEmail" /></label>
            <label><span>Web sitesi</span><input type="text" name="Website" value="@Model.HotelForm.Website" /></label>
            <label><span>Rezervasyon telefonu</span><input type="text" name="ReservationPhone" value="@Model.HotelForm.ReservationPhone" /></label>
            <label><span>Satis kontak adi</span><input type="text" name="SalesContactName" value="@Model.HotelForm.SalesContactName" /></label>
            <label><span>Satis kontak telefonu</span><input type="text" name="SalesContactPhone" value="@Model.HotelForm.SalesContactPhone" /></label>
            <label><span>Satis kontak e-posta</span><input type="email" name="SalesContactEmail" value="@Model.HotelForm.SalesContactEmail" /></label>
            <label class="span-3"><span>Satis notlari</span><textarea name="SalesNotes">@Model.HotelForm.SalesNotes</textarea></label>
            <label><span>Check-in</span><input type="text" name="CheckInTime" value="@Model.HotelForm.CheckInTime" placeholder="14:00" /></label>
            <label><span>Check-out</span><input type="text" name="CheckOutTime" value="@Model.HotelForm.CheckOutTime" placeholder="12:00" /></label>
            <label class="checkbox"><input type="checkbox" name="LateCheckoutAvailable" value="true" checked="@Model.HotelForm.LateCheckoutAvailable" /><span>Gec cikis acik</span></label>
            <label><span>Gec cikis ucreti</span><input type="number" step="0.01" name="LateCheckoutFee" value="@Model.HotelForm.LateCheckoutFee" /></label>
            <label class="checkbox"><input type="checkbox" name="EarlyCheckInAvailable" value="true" checked="@Model.HotelForm.EarlyCheckInAvailable" /><span>Erken giris acik</span></label>
            <label><span>Erken giris ucreti</span><input type="number" step="0.01" name="EarlyCheckInFee" value="@Model.HotelForm.EarlyCheckInFee" /></label>
            <label><span>Toplam oda sayisi</span><input type="number" name="TotalRoomCount" value="@Model.HotelForm.TotalRoomCount" /></label>
            <label><span>Yatak kapasitesi</span><input type="number" name="TotalBedCapacity" value="@Model.HotelForm.TotalBedCapacity" /></label>
            <label><span>Kat sayisi</span><input type="number" name="FloorCount" value="@Model.HotelForm.FloorCount" /></label>
            <label class="checkbox"><input type="checkbox" name="ElevatorAvailable" value="true" checked="@Model.HotelForm.ElevatorAvailable" /><span>Asansor var</span></label>
            <label><span>Asansor sayisi</span><input type="number" name="ElevatorCount" value="@Model.HotelForm.ElevatorCount" /></label>
            <label><span>Komisyon turu</span><select name="CommissionType">@foreach (var item in commissionTypes){<option value="@item" selected="@(Model.HotelForm.CommissionType == item)">@item</option>}</select></label>
            <label><span>Varsayilan komisyon</span><input type="number" step="0.01" name="DefaultCommissionRate" value="@Model.HotelForm.DefaultCommissionRate" /></label>
            <label><span>Komisyon hesaplama</span><select name="CommissionCalculationType">@foreach (var item in calcTypes){<option value="@item" selected="@(Model.HotelForm.CommissionCalculationType == item)">@item</option>}</select></label>
            <label><span>Odeme vadesi</span><select name="PaymentTerm">@foreach (var item in paymentTerms){<option value="@item" selected="@(Model.HotelForm.PaymentTerm == item)">@item</option>}</select></label>
            <label><span>Odeme yontemi</span><select name="PaymentMethod">@foreach (var item in paymentMethods){<option value="@item" selected="@(Model.HotelForm.PaymentMethod == item)">@item</option>}</select></label>
            <label><span>Fatura kesim</span><select name="InvoiceType">@foreach (var item in invoiceTypes){<option value="@item" selected="@(Model.HotelForm.InvoiceType == item)">@item</option>}</select></label>
            <label><span>Depozito</span><input type="number" step="0.01" name="DepositAmount" value="@Model.HotelForm.DepositAmount" /></label>
            <label><span>Depozito iade gunu</span><input type="number" name="DepositReturnDays" value="@Model.HotelForm.DepositReturnDays" /></label>
            <label><span>Min gece</span><input type="number" name="MinStay" value="@Model.HotelForm.MinStay" /></label>
            <label><span>Max gece</span><input type="number" name="MaxStay" value="@Model.HotelForm.MaxStay" /></label>
            <label><span>Konusulan diller</span><input type="text" name="SpokenLanguages" value="@Model.HotelForm.SpokenLanguages" /></label>
            <label><span>Ort puan</span><input type="number" step="0.01" name="AverageScore" value="@Model.HotelForm.AverageScore" /></label>
            <label><span>Yorum sayisi</span><input type="number" name="TotalReviewCount" value="@Model.HotelForm.TotalReviewCount" /></label>
            <label><span>Temizlik</span><input type="number" step="0.01" name="CleanlinessScore" value="@Model.HotelForm.CleanlinessScore" /></label>
            <label><span>Konfor</span><input type="number" step="0.01" name="ComfortScore" value="@Model.HotelForm.ComfortScore" /></label>
            <label><span>Konum</span><input type="number" step="0.01" name="LocationScore" value="@Model.HotelForm.LocationScore" /></label>
            <label><span>Personel</span><input type="number" step="0.01" name="StaffScore" value="@Model.HotelForm.StaffScore" /></label>
            <label><span>Fiyat performans</span><input type="number" step="0.01" name="PricePerformanceScore" value="@Model.HotelForm.PricePerformanceScore" /></label>
            <label><span>Kapak fotograf yolu</span><input type="text" name="CoverPhotoPath" value="@Model.HotelForm.CoverPhotoPath" /></label>
            <label><span>Video URL</span><input type="text" name="VideoUrl" value="@Model.HotelForm.VideoUrl" /></label>
            <label><span>Sanal tur URL</span><input type="text" name="VirtualTourUrl" value="@Model.HotelForm.VirtualTourUrl" /></label>
            <label><span>Yayin durumu</span><select name="PublishStatus">@foreach (var item in publishStatuses){<option value="@item" selected="@(Model.HotelForm.PublishStatus == item)">@item</option>}</select></label>
            <label><span>Onay durumu</span><select name="ApprovalStatus">@foreach (var item in approvalStatuses){<option value="@item" selected="@(Model.HotelForm.ApprovalStatus == item)">@item</option>}</select></label>
            <label><span>Populerlik</span><input type="number" name="PopularityOrder" value="@Model.HotelForm.PopularityOrder" /></label>
            <label class="checkbox"><input type="checkbox" name="IsFeatured" value="true" checked="@Model.HotelForm.IsFeatured" /><span>One cikan</span></label>
            <label class="checkbox"><input type="checkbox" name="IsRecommended" value="true" checked="@Model.HotelForm.IsRecommended" /><span>Tavsiye edilen</span></label>
            <label class="span-3"><span>Kisa aciklama</span><textarea name="ShortDescription">@Model.HotelForm.ShortDescription</textarea></label>
            <label class="span-3"><span>Uzun aciklama</span><textarea name="Description">@Model.HotelForm.Description</textarea></label>
            <label class="span-3"><span>Konum aciklamasi</span><textarea name="LocationDescription">@Model.HotelForm.LocationDescription</textarea></label>
            <div class="span-3 admin-form-actions"><button type="submit" class="admin-action-btn primary"><i class="fas fa-floppy-disk"></i> Otel kaydini guncelle</button></div>
        </form>
    </article>

    <aside class="admin-section-card admin-side-card">
        <div class="admin-section-head"><div><p class="mini-caption">ODA TIPLERI</p><h2>Bagli odalar</h2></div></div>
        <div class="admin-linked-list">
            @foreach (var room in Model.Rooms)
            {
                <article class="admin-linked-item @(room.IsActive ? string.Empty : "is-passive")">
                    <div>
                        <strong>@room.RoomName</strong>
                        <span>@room.RoomCode · @room.Category</span>
                        <small>@room.PriceText · @room.CapacityText · @room.StockText</small>
                    </div>
                    <div class="admin-inline-actions">
                        <a href="/admin/oteller/duzenle/@Model.HotelForm.HotelId?roomId=@room.RoomId" class="admin-action-btn secondary">Duzenle</a>
                        <form method="post" action="/admin/oteller/oda-pasife-al" onsubmit="return confirm('Oda tipi pasife alinsin mi?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" />
                            <input type="hidden" name="roomId" value="@room.RoomId" />
                            <button type="submit" class="admin-action-btn danger">Pasife al</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    </aside>
</section>

<section class="admin-detail-grid secondary">
    <article class="admin-section-card">
        <div class="admin-section-head"><div><p class="mini-caption">ODA TIPLERI TABLOSU</p><h2>@(Model.IsEditingRoom ? "Oda tipini duzenle" : "Yeni oda tipi ekle")</h2></div></div>
        <form method="post" action="/admin/oteller/oda-kaydet" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <input type="hidden" name="RoomId" value="@Model.RoomForm.RoomId" />
            <label><span>Oda kodu</span><input type="text" name="RoomCode" value="@Model.RoomForm.RoomCode" /></label>
            <label class="span-2"><span>Oda adi</span><input type="text" name="RoomName" value="@Model.RoomForm.RoomName" /></label>
            <label><span>Kategori</span><select name="RoomCategory">@foreach (var item in roomCategories){<option value="@item" selected="@(Model.RoomForm.RoomCategory == item)">@item</option>}</select></label>
            <label><span>Maks kisi</span><input type="number" name="MaxPeople" value="@Model.RoomForm.MaxPeople" /></label>
            <label><span>Maks yetiskin</span><input type="number" name="MaxAdults" value="@Model.RoomForm.MaxAdults" /></label>
            <label><span>Maks cocuk</span><input type="number" name="MaxChildren" value="@Model.RoomForm.MaxChildren" /></label>
            <label><span>Yatak tipi</span><select name="BedType"><option value="">Seciniz</option>@foreach (var item in bedTypes){<option value="@item" selected="@(Model.RoomForm.BedType == item)">@item</option>}</select></label>
            <label><span>Yatak sayisi</span><input type="number" name="BedCount" value="@Model.RoomForm.BedCount" /></label>
            <label class="checkbox"><input type="checkbox" name="ExtraBedAvailable" value="true" checked="@Model.RoomForm.ExtraBedAvailable" /><span>Ek yatak</span></label>
            <label><span>Metrekare</span><input type="number" name="RoomSize" value="@Model.RoomForm.RoomSize" /></label>
            <label class="checkbox"><input type="checkbox" name="BalconyAvailable" value="true" checked="@Model.RoomForm.BalconyAvailable" /><span>Balkon var</span></label>
            <label><span>Balkon m2</span><input type="number" name="BalconySize" value="@Model.RoomForm.BalconySize" /></label>
            <label><span>Manzara</span><select name="ViewType"><option value="">Seciniz</option>@foreach (var item in viewTypes){<option value="@item" selected="@(Model.RoomForm.ViewType == item)">@item</option>}</select></label>
            <label class="checkbox"><input type="checkbox" name="PrivateBathroom" value="true" checked="@Model.RoomForm.PrivateBathroom" /><span>Ozel banyo</span></label>
            <label><span>Banyo tipi</span><select name="BathroomType"><option value="">Seciniz</option>@foreach (var item in bathroomTypes){<option value="@item" selected="@(Model.RoomForm.BathroomType == item)">@item</option>}</select></label>
            <label><span>Taban fiyat</span><input type="number" step="0.01" name="BasePrice" value="@Model.RoomForm.BasePrice" /></label>
            <label><span>Haftasonu fark %</span><input type="number" step="0.01" name="WeekendDifferenceRate" value="@Model.RoomForm.WeekendDifferenceRate" /></label>
            <label><span>Cocuk indirim %</span><input type="number" step="0.01" name="ChildDiscountRate" value="@Model.RoomForm.ChildDiscountRate" /></label>
            <label class="checkbox"><input type="checkbox" name="BabyFree" value="true" checked="@Model.RoomForm.BabyFree" /><span>Bebek ucretsiz</span></label>
            <label><span>Bebek yas siniri</span><input type="number" name="BabyAgeLimit" value="@Model.RoomForm.BabyAgeLimit" /></label>
            <label><span>Cocuk yas siniri</span><input type="number" name="ChildAgeLimit" value="@Model.RoomForm.ChildAgeLimit" /></label>
            <label><span>Toplam oda</span><input type="number" name="TotalRooms" value="@Model.RoomForm.TotalRooms" /></label>
            <label><span>Overbooking limit</span><input type="number" name="OverbookingLimit" value="@Model.RoomForm.OverbookingLimit" /></label>
            <label class="span-2"><span>Kapak fotograf yolu</span><input type="text" name="CoverPhotoPath" value="@Model.RoomForm.CoverPhotoPath" /></label>
            <label class="span-3"><span>Galeri JSON</span><textarea name="GalleryJson">@Model.RoomForm.GalleryJson</textarea></label>
            <label class="span-3"><span>Oda ozellikleri</span><textarea name="FeaturesText">@Model.RoomForm.FeaturesText</textarea></label>
            <label class="checkbox"><input type="checkbox" name="IsActive" value="true" checked="@Model.RoomForm.IsActive" /><span>Aktif</span></label>
            <label><span>Siralama</span><input type="number" name="SortOrder" value="@Model.RoomForm.SortOrder" /></label>
            <div class="span-3 admin-form-actions"><button type="submit" class="admin-action-btn primary"><i class="fas fa-floppy-disk"></i> Oda kaydini kaydet</button></div>
        </form>
    </article>

    <article class="admin-section-card">
        <div class="admin-section-head"><div><p class="mini-caption">OTEL GORSELLERI</p><h2>Otel galerisi</h2></div></div>
        <form method="post" action="/admin/oteller/otel-fotograf-yukle" enctype="multipart/form-data" class="admin-form-grid compact">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <label><span>Baslik</span><input type="text" name="Title" value="@Model.HotelPhotoUploadForm.Title" /></label>
            <label><span>Tur</span><select name="PhotoType">@foreach (var item in hotelPhotoTypes){<option value="@item" selected="@(Model.HotelPhotoUploadForm.PhotoType == item)">@item</option>}</select></label>
            <label><span>Siralama</span><input type="number" name="DisplayOrder" value="@Model.HotelPhotoUploadForm.DisplayOrder" /></label>
            <label class="checkbox"><input type="checkbox" name="MakeCover" value="true" checked="@Model.HotelPhotoUploadForm.MakeCover" /><span>Kapak yap</span></label>
            <label class="span-2"><span>Aciklama</span><textarea name="Description">@Model.HotelPhotoUploadForm.Description</textarea></label>
            <label class="span-2"><span>Dosyalar</span><input type="file" name="Files" accept="image/*" multiple /></label>
            <div class="span-2 admin-form-actions"><button type="submit" class="admin-action-btn primary">Otel gorseli yukle</button></div>
        </form>

        @if (Model.HotelPhotos.Count > 0)
        {
            <div class="admin-photo-grid">
                @foreach (var photo in Model.HotelPhotos)
                {
                    <article class="admin-photo-card @(photo.IsCover ? "is-cover" : string.Empty)">
                        <img src="@photo.Url" alt="@photo.Title" />
                        <div class="admin-photo-body">
                            <strong>@(string.IsNullOrWhiteSpace(photo.Title) ? "Basliksiz" : photo.Title)</strong>
                            <span>@photo.Type · Sira @photo.SortOrder</span>
                            <p>@(string.IsNullOrWhiteSpace(photo.Description) ? "Aciklama girilmemis." : photo.Description)</p>
                            <div class="admin-inline-actions wrap">
                                <a href="/admin/oteller/duzenle/@Model.HotelForm.HotelId?hotelPhotoId=@photo.PhotoId" class="admin-action-btn secondary">Duzenle</a>
                                <form method="post" action="/admin/oteller/otel-fotograf-kapak-yap">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn secondary">Kapak yap</button></form>
                                <form method="post" action="/admin/oteller/otel-fotograf-sil" onsubmit="return confirm('Otel fotografi silinsin mi?');">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn danger">Sil</button></form>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }

        <form method="post" action="/admin/oteller/otel-fotograf-guncelle" class="admin-form-grid compact top-gap">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelPhotoEditForm.HotelId" />
            <input type="hidden" name="PhotoId" value="@Model.HotelPhotoEditForm.PhotoId" />
            <label><span>Secili baslik</span><input type="text" name="Title" value="@Model.HotelPhotoEditForm.Title" /></label>
            <label><span>Tur</span><select name="PhotoType">@foreach (var item in hotelPhotoTypes){<option value="@item" selected="@(Model.HotelPhotoEditForm.PhotoType == item)">@item</option>}</select></label>
            <label><span>Siralama</span><input type="number" name="DisplayOrder" value="@Model.HotelPhotoEditForm.DisplayOrder" /></label>
            <label class="checkbox"><input type="checkbox" name="MarkAsFeatured" value="true" checked="@Model.HotelPhotoEditForm.MarkAsFeatured" /><span>One cikan</span></label>
            <label class="span-2"><span>Aciklama</span><textarea name="Description">@Model.HotelPhotoEditForm.Description</textarea></label>
            <div class="span-2 admin-form-actions"><button type="submit" class="admin-action-btn secondary" @(Model.IsEditingHotelPhoto ? null : "disabled")>Secili otel gorselini guncelle</button></div>
        </form>
    </article>
</section>

<section class="admin-section-card">
    <div class="admin-section-head"><div><p class="mini-caption">ODA GORSELLERI</p><h2>@(string.IsNullOrWhiteSpace(Model.SelectedRoomName) ? "Oda secin" : Model.SelectedRoomName)</h2></div></div>
    @if (!Model.SelectedRoomId.HasValue)
    {
        <div class="admin-empty-state">Oda gorseli yonetmek icin once bu otele bagli bir oda tipi secin veya yeni oda ekleyin.</div>
    }
    else
    {
        <form method="post" action="/admin/oteller/oda-fotograf-yukle" enctype="multipart/form-data" class="admin-form-grid compact">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <input type="hidden" name="RoomId" value="@Model.RoomPhotoUploadForm.RoomId" />
            <label><span>Baslik</span><input type="text" name="Title" value="@Model.RoomPhotoUploadForm.Title" /></label>
            <label><span>Siralama</span><input type="number" name="DisplayOrder" value="@Model.RoomPhotoUploadForm.DisplayOrder" /></label>
            <label class="checkbox"><input type="checkbox" name="MakeCover" value="true" checked="@Model.RoomPhotoUploadForm.MakeCover" /><span>Kapak yap</span></label>
            <label class="span-2"><span>Aciklama</span><textarea name="Description">@Model.RoomPhotoUploadForm.Description</textarea></label>
            <label class="span-2"><span>Dosyalar</span><input type="file" name="Files" accept="image/*" multiple /></label>
            <div class="span-2 admin-form-actions"><button type="submit" class="admin-action-btn primary">Oda gorseli yukle</button></div>
        </form>

        @if (Model.RoomPhotos.Count > 0)
        {
            <div class="admin-photo-grid top-gap">
                @foreach (var photo in Model.RoomPhotos)
                {
                    <article class="admin-photo-card @(photo.IsCover ? "is-cover" : string.Empty)">
                        <img src="@photo.Url" alt="@photo.Title" />
                        <div class="admin-photo-body">
                            <strong>@(string.IsNullOrWhiteSpace(photo.Title) ? photo.RoomName : photo.Title)</strong>
                            <span>@photo.RoomName · Sira @photo.SortOrder</span>
                            <p>@(string.IsNullOrWhiteSpace(photo.Description) ? "Aciklama girilmemis." : photo.Description)</p>
                            <div class="admin-inline-actions wrap">
                                <a href="/admin/oteller/duzenle/@Model.HotelForm.HotelId?roomId=@photo.RoomId&roomPhotoId=@photo.PhotoId" class="admin-action-btn secondary">Duzenle</a>
                                <form method="post" action="/admin/oteller/oda-fotograf-kapak-yap">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="roomId" value="@photo.RoomId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn secondary">Kapak yap</button></form>
                                <form method="post" action="/admin/oteller/oda-fotograf-sil" onsubmit="return confirm('Oda fotografi silinsin mi?');">@Html.AntiForgeryToken()<input type="hidden" name="hotelId" value="@Model.HotelForm.HotelId" /><input type="hidden" name="roomId" value="@photo.RoomId" /><input type="hidden" name="photoId" value="@photo.PhotoId" /><button type="submit" class="admin-action-btn danger">Sil</button></form>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }

        <form method="post" action="/admin/oteller/oda-fotograf-guncelle" class="admin-form-grid compact top-gap">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.HotelForm.HotelId" />
            <input type="hidden" name="RoomId" value="@Model.RoomPhotoEditForm.RoomId" />
            <input type="hidden" name="PhotoId" value="@Model.RoomPhotoEditForm.PhotoId" />
            <label><span>Secili baslik</span><input type="text" name="Title" value="@Model.RoomPhotoEditForm.Title" /></label>
            <label><span>Siralama</span><input type="number" name="DisplayOrder" value="@Model.RoomPhotoEditForm.DisplayOrder" /></label>
            <label class="span-2"><span>Aciklama</span><textarea name="Description">@Model.RoomPhotoEditForm.Description</textarea></label>
            <div class="span-2 admin-form-actions"><button type="submit" class="admin-action-btn secondary" @(Model.IsEditingRoomPhoto ? null : "disabled")>Secili oda gorselini guncelle</button></div>
        </form>
    }
</section>
