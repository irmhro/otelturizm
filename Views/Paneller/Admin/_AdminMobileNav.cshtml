@using System
@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var current = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsAct(string a) => string.Equals(current, a, StringComparison.OrdinalIgnoreCase);
    bool AnyAct(params string[] actions) => actions.Any(a => IsAct(a));
    bool Can(string code) => Model.Permissions.Contains("*") || Model.HasPermission(code);

    var locAct = AnyAct("Countries", "LocationsCities", "LocationsDistricts", "LocationsNeighborhoods");
    var hotelAct = AnyAct("Hotels", "HotelDetail", "ActiveHotels", "PendingHotels", "Campaigns", "PartnerApplications");
    var firmaAct = AnyAct("Companies", "CompanyApplications", "CompanyReservations");
    var platformAct = AnyAct("Dashboard", "SystemHealth", "PlatformCheckup", "ApprovalCenter", "EmailQueue");
    var financeAct = AnyAct("Commissions", "Invoices", "Payments", "Reservations", "UnifiedReservations", "RevenueCommandCenter");
    var configAct = AnyAct("AdminRoles", "Users", "Managers", "Settings", "Notifications");

    var showReservations = Can("admin.reservations") || Can("admin.unified_reservations");
    var reservationsAction = Can("admin.unified_reservations") ? "UnifiedReservations" : "Reservations";
}
<nav class="admin-mobile-nav admin-mobile-nav--scroll" aria-label="Hızlı gezinme">
    <a asp-controller="AdminPanel" asp-action="Dashboard" class="@(IsAct("Dashboard") ? "active" : null) @(Can("admin.dashboard") ? null : "d-none")"><i class="fas fa-table-columns" aria-hidden="true"></i><span>Panel</span></a>
    <a asp-controller="AdminPanel" asp-action="LocationsCities" class="@(locAct ? "active" : null) @(Can("admin.locations") ? null : "d-none")"><i class="fas fa-map" aria-hidden="true"></i><span>Konum</span></a>
    <a asp-controller="AdminPanel" asp-action="Hotels" class="@(hotelAct ? "active" : null) @(Can("admin.hotels") ? null : "d-none")"><i class="fas fa-hotel" aria-hidden="true"></i><span>Oteller</span></a>
    <a asp-controller="AdminPanel" asp-action="Companies" class="@(firmaAct ? "active" : null) @(Can("admin.companies") ? null : "d-none")"><i class="fas fa-building" aria-hidden="true"></i><span>Firma</span></a>
    @if (showReservations)
    {
        <a asp-controller="AdminPanel" asp-action="@reservationsAction" class="@(financeAct ? "active" : null)"><i class="fas fa-calendar-check" aria-hidden="true"></i><span>Rez.</span></a>
    }
    <a asp-controller="AdminPanel" asp-action="SystemHealth" class="@(platformAct ? "active" : null) @(Can("admin.system_health") ? null : "d-none")"><i class="fas fa-heart-pulse" aria-hidden="true"></i><span>Sağlık</span></a>
    <a asp-controller="AdminPanel" asp-action="AdminRoles" class="@(configAct ? "active" : null) @(Can("admin.roles") ? null : "d-none")"><i class="fas fa-key" aria-hidden="true"></i><span>Rol</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket" aria-hidden="true"></i><span>Çıkış</span></button>
    </form>
</nav>
