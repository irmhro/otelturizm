@using otelturizmnew.Models.Paneller.Admin
@model AdminHotelsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;

    static string StatusTone(string? value)
    {
        var text = (value ?? string.Empty).Trim().ToLowerInvariant();
        if (text.Contains("onay") || text.Contains("yayinda") || text.Contains("yayında") || text.Contains("aktif")) return "success";
        if (text.Contains("bekle") || text.Contains("taslak")) return "warning";
        if (text.Contains("red") || text.Contains("ask") || text.Contains("kapat") || text.Contains("kapali") || text.Contains("kapalı")) return "danger";
        return "info";
    }

    var pageSizes = new[] { 50, 100, 200 };
    var currentPath = Context.Request.Path.Value ?? "/admin/oteller";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentUserRole = User.FindFirst("otelturizm:user_role")?.Value ?? string.Empty;
    var canManagePublish = string.Equals(currentUserRole, "admin", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentUserRole, "superadmin", StringComparison.OrdinalIgnoreCase)
        || User.IsInRole("admin")
        || User.IsInRole("superadmin");
    static string Enc(string? value) => System.Net.WebUtility.UrlEncode(value ?? string.Empty);
    string PageUrl(int targetPage) => $"{currentPath}?q={Enc(Model.SearchTerm)}&city={Enc(Model.CityFilter)}&district={Enc(Model.DistrictFilter)}&neighborhood={Enc(Model.NeighborhoodFilter)}&publishStatus={Enc(Model.PublishStatusFilter)}&approvalStatus={Enc(Model.ApprovalStatusFilter)}&page={targetPage}&pageSize={Model.PageSize}";
}

<section class="admin-hotels-page">
    <div class="admin-summary-grid admin-hotels-summary">
        @foreach (var card in Model.SummaryCards)
        {
            var tone = string.IsNullOrWhiteSpace(card.ToneClass) ? "info" : card.ToneClass;
            <article class="admin-summary-card @tone">
                <span class="summary-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    @if (TempData["AdminHotelMessage"] is string successMessage)
    {
        <div class="admin-alert is-success"><i class="fas fa-circle-check"></i><span>@successMessage</span></div>
    }
    @if (TempData["AdminHotelError"] is string errorMessage)
    {
        <div class="admin-alert is-error"><i class="fas fa-triangle-exclamation"></i><span>@errorMessage</span></div>
    }

    <article class="admin-hotel-listing-card admin-hotels-table-card">
        <header class="admin-hotel-listing-head">
            <div>
                <p class="mini-caption">MERKEZI OTEL YONETIMI</p>
                <h2>Oteller</h2>
                <span>Otel kayıtları, yayın/onay durumları, oda ve görsel adetleri yatay tablo üzerinden yönetilir.</span>
            </div>
            <div class="admin-hotels-filter-actions">
                <a class="admin-action-btn primary" href="/admin/oteller/yeni"><i class="fas fa-plus"></i> Yeni Otel</a>
            </div>
        </header>

        <form method="get" action="@currentPath" class="admin-hotels-filter-grid">
            <label>
                <span>Otel adı / kod / arama</span>
                <input type="text" name="q" value="@Model.SearchTerm" placeholder="Otel adı, kodu, ilçe..." />
            </label>
            <label>
                <span>İl</span>
                <select name="city">
                    <option value="">Tüm iller</option>
                    @foreach (var option in Model.CityOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.CityFilter, option, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>İlçe</span>
                <select name="district">
                    <option value="">Tüm ilçeler</option>
                    @foreach (var option in Model.DistrictOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.DistrictFilter, option, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Mahalle</span>
                <select name="neighborhood">
                    <option value="">Tüm mahalleler</option>
                    @foreach (var option in Model.NeighborhoodOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.NeighborhoodFilter, option, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Yayın</span>
                <select name="publishStatus">
                    <option value="">Tüm yayın durumları</option>
                    @foreach (var option in Model.PublishStatusOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.PublishStatusFilter, option, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Onay</span>
                <select name="approvalStatus">
                    <option value="">Tüm onay durumları</option>
                    @foreach (var option in Model.ApprovalStatusOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.ApprovalStatusFilter, option, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="pageSize">
                    @foreach (var size in pageSizes)
                    {
                        <option value="@size" selected="@(Model.PageSize == size ? "selected" : null)">@size</option>
                    }
                </select>
            </label>
            <input type="hidden" name="page" value="1" />
            <div class="admin-hotels-filter-actions">
                <button type="submit" class="admin-action-btn primary"><i class="fas fa-filter"></i> Filtrele</button>
                <a class="admin-action-btn secondary" href="/admin/oteller"><i class="fas fa-rotate-left"></i> Temizle</a>
            </div>
        </form>

        @if (Model.Hotels.Count == 0)
        {
            <div class="admin-empty-panel">Arama kriterlerine uygun otel bulunamadı.</div>
        }
        else
        {
            <form id="admin-hotels-bulk-form" method="post" action="/admin/oteller/toplu-yayin" class="admin-hotels-bulk-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="publish" id="admin-hotels-bulk-publish" value="" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <div class="admin-hotels-bulk-bar panel-form-ux-bulk-bar" id="admin-hotels-bulk-bar" hidden>
                    <strong id="admin-hotels-bulk-count">0 otel seçildi</strong>
                    <div class="admin-hotels-bulk-actions panel-form-ux-bulk-actions">
                        <button type="submit" class="admin-action-btn success" data-publish="true" disabled>
                            <i class="fas fa-broadcast-tower"></i> Seçilenleri yayınla
                        </button>
                        <button type="submit" class="admin-action-btn danger" data-publish="false" disabled>
                            <i class="fas fa-eye-slash"></i> Seçilenleri kapat
                        </button>
                    </div>
                </div>
            </form>

            <div class="admin-hotels-table-wrap">
                <table class="admin-hotels-table admin-table--cards">
                    <thead>
                        <tr>
                            <th class="admin-hotels-select-head">
                                <label class="admin-hotels-select-all" title="Sayfadaki tüm otelleri seç">
                                    <input type="checkbox" id="admin-hotels-select-all" aria-label="Tümünü seç" />
                                </label>
                            </th>
                            <th>Otel</th>
                            <th>Konum</th>
                            <th>Tip</th>
                            <th>Oda</th>
                            <th>Görsel</th>
                            <th>Yayın</th>
                            <th>Onay</th>
                            <th>Puan</th>
                            <th class="admin-hotels-actions-head">Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hotel in Model.Hotels)
                        {
                            <tr>
                                <td data-label="Seç" class="admin-hotels-select-cell">
                                    <input form="admin-hotels-bulk-form" type="checkbox" class="admin-hotels-row-select" name="hotelIds" value="@hotel.HotelId" aria-label="@hotel.HotelName seç" />
                                </td>
                                <td data-label="Otel">
                                    <strong>@hotel.HotelName</strong>
                                    <small>@hotel.HotelCode</small>
                                </td>
                                <td data-label="Konum">@hotel.LocationText</td>
                                <td data-label="Tip"><span class="admin-chip info"><i class="fas fa-hotel"></i>@hotel.HotelType</span></td>
                                <td data-label="Oda"><strong>@hotel.RoomCount</strong><small>oda tipi</small></td>
                                <td data-label="Görsel">
                                    <span>@hotel.HotelPhotoCount otel</span>
                                    <small>@hotel.RoomPhotoCount oda</small>
                                </td>
                                <td data-label="Yayın"><span class="admin-chip @StatusTone(hotel.PublishStatus)">@hotel.PublishStatus</span></td>
                                <td data-label="Onay"><span class="admin-chip @StatusTone(hotel.ApprovalStatus)">@hotel.ApprovalStatus</span></td>
                                <td data-label="Puan"><span class="admin-hotel-score compact">@hotel.ScoreText</span></td>
                                <td data-label="Aksiyon" class="admin-hotels-actions">
                                    <div class="admin-hotels-action-toolbar panel-form-ux-actions">
                                        <a class="admin-action-btn primary panel-form-ux-edit" href="/admin/otel-detay/@hotel.HotelId">
                                            <i class="fas fa-pen"></i> Düzenle
                                        </a>
                                        @if (canManagePublish)
                                        {
                                            <form method="post" action="/admin/oteller/sil" class="admin-inline-post panel-form-ux-delete" onsubmit="return confirm('Otel kaydı silinsin mi?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="hotelId" value="@hotel.HotelId" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="admin-action-btn danger panel-form-ux-delete-btn"><i class="fas fa-trash"></i> Sil</button>
                                            </form>
                                            @if (hotel.IsPublished)
                                            {
                                                <form method="post" action="/admin/oteller/pasife-al" class="admin-inline-post panel-form-ux-toggle-form" onsubmit="return confirm('Bu otelin yayini kapatilsin mi?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="hotelId" value="@hotel.HotelId" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="admin-action-btn danger panel-form-ux-delete-btn"><i class="fas fa-eye-slash"></i> Yayını Kapat</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" action="/admin/oteller/aktive-et" class="admin-inline-post panel-form-ux-toggle-form" onsubmit="return confirm('Bu otel yayina alinsin mi?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="hotelId" value="@hotel.HotelId" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="admin-action-btn success panel-form-ux-edit"><i class="fas fa-broadcast-tower"></i> Yayına Al</button>
                                                </form>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <footer class="admin-hotels-pager">
                <span>@Model.TotalCount kayıt · Sayfa @Model.Page / @Model.TotalPages</span>
                <div>
                    <a class="admin-action-btn secondary @(Model.HasPreviousPage ? string.Empty : "is-disabled")" href="@(Model.HasPreviousPage ? PageUrl(Model.Page - 1) : "#")">Önceki</a>
                    <a class="admin-action-btn secondary @(Model.HasNextPage ? string.Empty : "is-disabled")" href="@(Model.HasNextPage ? PageUrl(Model.Page + 1) : "#")">Sonraki</a>
                </div>
            </footer>
        }
    </article>
</section>

@if (Model.Hotels.Count > 0)
{
    var bulkNonce = Context.Items["CspNonce"] as string;
    <script nonce="@bulkNonce">
    (() => {
        const bulkForm = document.getElementById('admin-hotels-bulk-form');
        const bulkBar = document.getElementById('admin-hotels-bulk-bar');
        const bulkCount = document.getElementById('admin-hotels-bulk-count');
        const publishInput = document.getElementById('admin-hotels-bulk-publish');
        const selectAll = document.getElementById('admin-hotels-select-all');
        const rowChecks = Array.from(document.querySelectorAll('.admin-hotels-row-select'));
        const bulkButtons = Array.from(bulkForm?.querySelectorAll('[data-publish]') ?? []);

        const selectedRows = () => rowChecks.filter((item) => item.checked);

        const syncBulkUi = () => {
            const count = selectedRows().length;
            if (bulkBar) bulkBar.hidden = count === 0;
            if (bulkCount) bulkCount.textContent = `${count} otel seçildi`;
            bulkButtons.forEach((button) => { button.disabled = count === 0; });
            if (selectAll) {
                selectAll.indeterminate = count > 0 && count < rowChecks.length;
                selectAll.checked = count > 0 && count === rowChecks.length;
            }
        };

        selectAll?.addEventListener('change', () => {
            rowChecks.forEach((item) => { item.checked = !!selectAll.checked; });
            syncBulkUi();
        });

        rowChecks.forEach((item) => item.addEventListener('change', syncBulkUi));

        bulkForm?.addEventListener('submit', (event) => {
            const submitter = event.submitter;
            const publishValue = submitter?.getAttribute('data-publish');
            if (!publishValue) {
                event.preventDefault();
                return;
            }
            if (selectedRows().length === 0) {
                event.preventDefault();
                return;
            }
            const publish = publishValue === 'true';
            if (publishInput) publishInput.value = publish ? 'true' : 'false';
            const message = publish
                ? 'Seçilen oteller yayına alınsın mı?'
                : 'Seçilen otellerin yayını kapatılsın mı?';
            if (!window.confirm(message)) {
                event.preventDefault();
            }
        });

        syncBulkUi();
    })();
    </script>
}
