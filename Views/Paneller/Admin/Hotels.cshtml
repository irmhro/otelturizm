@using otelturizmnew.Models.Paneller.Admin
@model AdminHotelsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    @foreach (var card in Model.SummaryCards)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-primary">
                <div class="inner">
                    <h3>@card.Value</h3>
                    <p>@card.Label</p>
                    <small>@card.Description</small>
                </div>
                <div class="icon"><i class="fas @card.IconClass"></i></div>
            </div>
        </div>
    }
</div>

@if (TempData["AdminHotelMessage"] is string successMessage)
{
    <div class="alert alert-success ot-card">@successMessage</div>
}
@if (TempData["AdminHotelError"] is string errorMessage)
{
    <div class="alert alert-danger ot-card">@errorMessage</div>
}

<div class="card ot-card">
    <div class="card-header">
        <h3 class="card-title">Merkezi otel yönetimi</h3>
        <div class="card-tools">
            <form method="get" action="/admin/oteller" class="input-group input-group-sm" style="width: 280px;">
                <input type="text" name="q" value="@Model.SearchTerm" class="form-control float-right" placeholder="Otel adı, kodu, şehir..." />
                <div class="input-group-append">
                    <button type="submit" class="btn btn-default ot-btn ot-btn--ghost"><i class="fas fa-search"></i></button>
                </div>
            </form>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Hotels.Count == 0)
        {
            <div class="alert alert-secondary mb-0 ot-card">Arama kriterlerine uygun otel bulunamadı.</div>
        }
        else
        {
            <div class="row">
                @foreach (var hotel in Model.Hotels)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card card-outline card-info ot-card">
                            <div class="card-header">
                                <h3 class="card-title">@hotel.HotelName</h3>
                                <div class="card-tools">
                                    <span class="badge badge-light ot-badge">@hotel.HotelCode</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="mb-2 text-muted">@hotel.LocationText</p>
                                <div class="mb-2"><i class="fas fa-hotel mr-1"></i>@hotel.HotelType</div>
                                <div class="mb-2"><i class="fas fa-bed mr-1"></i>@hotel.RoomCount oda tipi</div>
                                <div class="mb-2"><i class="fas fa-image mr-1"></i>@hotel.HotelPhotoCount otel görseli</div>
                                <div class="mb-2"><i class="fas fa-camera mr-1"></i>@hotel.RoomPhotoCount oda görseli</div>
                                <div class="mb-2"><span class="badge badge-info ot-badge">Yayın: @hotel.PublishStatus</span></div>
                                <div class="mb-3"><span class="badge badge-warning ot-badge">Onay: @hotel.ApprovalStatus</span></div>
                                <a class="btn btn-primary btn-sm ot-btn ot-btn--primary" href="/admin/oteller/duzenle/@hotel.HotelId">
                                    <i class="fas fa-pen mr-1"></i>Oteli Düzenle
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
