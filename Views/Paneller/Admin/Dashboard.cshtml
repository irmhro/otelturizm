@using otelturizmnew.Models.Paneller.Admin
@model AdminDashboardViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
    var primaryMetrics = Model.Metrics.Take(6).ToList();
    var secondaryMetrics = Model.Metrics.Skip(6).Take(4).ToList();
    var criticalItems = new[]
    {
        new { Label = "Bekleyen onaylar", Value = Model.PendingApprovalsQueueCount, Url = "/admin/onay-merkezi", Icon = "fa-clipboard-check", Tone = "primary" },
        new { Label = "Partner onayı", Value = Model.Shell.PendingPartnerApplications, Url = "/admin/partner-basvurulari", Icon = "fa-file-signature", Tone = "warning" },
        new { Label = "Firma onayı", Value = Model.Shell.PendingCompanyApplications, Url = "/admin/firma-basvurulari", Icon = "fa-building", Tone = "warning" },
        new { Label = "Yorum moderasyonu", Value = Model.Shell.PendingReviews, Url = "/admin/degerlendirmeler", Icon = "fa-comments", Tone = "info" },
        new { Label = "Kritik log", Value = Model.Shell.CriticalLogs, Url = "/admin/log-kayitlari", Icon = "fa-triangle-exclamation", Tone = "danger" }
    };

    string MapKpi(string? tone) => tone switch
    {
        "success" => "kpi-green",
        "danger" => "kpi-red",
        "warning" => "kpi-warning",
        "purple" => "kpi-purple",
        "teal" => "kpi-teal",
        _ => "kpi-blue"
    };

    string MapIcon(string? tone) => tone switch
    {
        "success" => "icon-green",
        "danger" => "icon-red",
        "warning" => "icon-warning",
        "purple" => "icon-purple",
        "teal" => "icon-teal",
        _ => "icon-blue"
    };

    string MetricUrl(AdminMetricCardViewModel metric)
    {
        if (metric.Label.Contains("Komisyon", StringComparison.OrdinalIgnoreCase)) return "/admin/komisyonlar";
        if (metric.Label.Contains("Otel", StringComparison.OrdinalIgnoreCase)) return "/admin/oteller";
        if (metric.Label.Contains("Rezervasyon", StringComparison.OrdinalIgnoreCase)) return "/admin/rezervasyonlar-tek-liste";
        return "/admin/raporlar";
    }
}

<section class="admin-panel-dashboard">
    <div class="ap-page-header">
        <div>
            <div class="ap-page-pretitle">Executive · Global Platform</div>
            <h1>Merkezi Operasyon Üssü</h1>
            <p>Global platform — tüm tesislerin anlık konsolide verileri ve ağ hareketleri.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn-primary-ap" href="/admin/onay-merkezi"><i class="fas fa-clipboard-check"></i> Onay Merkezi</a>
            <a class="btn-outline-ap" href="/admin/platform-checkup"><i class="fas fa-list-check"></i> Platform Checkup</a>
        </div>
    </div>

    <div class="quick-actions-bar">
        <a class="action-chip" href="/admin/onay-merkezi"><i class="fas fa-clipboard-check" style="color: var(--ap-primary-red);"></i> Onay Kuyruğu</a>
        <a class="action-chip" href="/admin/oteller"><i class="fas fa-hotel" style="color: var(--ap-warning);"></i> Otel Yönetimi</a>
        <a class="action-chip" href="/admin/rezervasyonlar-tek-liste"><i class="fas fa-calendar-check" style="color: var(--ap-info);"></i> Rezervasyonlar</a>
        <a class="action-chip" href="/admin/sistem-sagligi"><i class="fas fa-heart-pulse" style="color: var(--ap-success);"></i> Sistem Sağlığı</a>
    </div>

    <div class="kpi-grid-pro">
        @foreach (var metric in primaryMetrics)
        {
            var tone = string.IsNullOrWhiteSpace(metric.ToneClass) ? "info" : metric.ToneClass;
            <a class="kpi-card-pro @MapKpi(tone)" href="@MetricUrl(metric)">
                <div class="kpi-top">
                    <span class="kpi-title">@metric.Label</span>
                    <div class="kpi-icon @MapIcon(tone)"><i class="fas @metric.IconClass"></i></div>
                </div>
                <div class="kpi-value">@metric.Value</div>
                @if (!string.IsNullOrWhiteSpace(metric.TrendText))
                {
                    <div class="kpi-bottom up"><i class="fas fa-chart-line"></i> @metric.TrendText</div>
                }
            </a>
        }
    </div>

    <div class="complex-grid">
        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-stream"></i> Son 6 ay rezervasyon hareketi</h3>
                <a class="btn-outline-ap" style="height:28px;font-size:11px;padding:0 10px;" href="/admin/rezervasyonlar-tek-liste">Tümünü Gör</a>
            </div>
            <div class="panel-body panel-body-padded">
                <div class="ap-chart-bars">
                    @foreach (var bar in Model.ReservationChart)
                    {
                        <div class="ap-chart-bar-item">
                            <span class="ap-chart-bar" style="height:@bar.HeightPercent%;"></span>
                            <strong>@bar.Value</strong>
                            <small>@bar.Label</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-bolt" style="color:var(--ap-warning);"></i> Bekleyen işler</h3>
            </div>
            <div class="panel-body panel-body-padded">
                <div class="ap-action-stack">
                    @foreach (var item in criticalItems)
                    {
                        <a class="ap-action-tile @item.Tone" href="@item.Url">
                            <span><i class="fas @item.Icon"></i></span>
                            <div>
                                <strong>@item.Value.ToString("N0", tr)</strong>
                                <small>@item.Label</small>
                            </div>
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.Revenue30DayMetrics.Count > 0)
    {
        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-chart-line"></i> Platform GMV (30 gün)</h3>
                <a class="btn-outline-ap" style="height:28px;font-size:11px;padding:0 10px;" href="/admin/raporlar">Gelir raporu</a>
            </div>
            <div class="panel-body panel-body-padded">
                <div class="kpi-grid-pro">
                    @foreach (var metric in Model.Revenue30DayMetrics)
                    {
                        var tone = string.IsNullOrWhiteSpace(metric.ToneClass) ? "info" : metric.ToneClass;
                        <a class="kpi-card-pro @MapKpi(tone)" href="/admin/raporlar">
                            <div class="kpi-top">
                                <span class="kpi-title">@metric.Label</span>
                                <div class="kpi-icon @MapIcon(tone)"><i class="fas @metric.IconClass"></i></div>
                            </div>
                            <div class="kpi-value">@metric.Value</div>
                            @if (!string.IsNullOrWhiteSpace(metric.TrendText))
                            {
                                <div class="kpi-bottom up">@metric.TrendText</div>
                            }
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    <div class="ap-route-grid">
        <a class="ap-route-card" href="/admin/oteller">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-hotel"></i></span>
                <strong>Otel yönetimi</strong>
            </div>
            <span class="ap-route-card-desc">Yayın, askı, detay, oda ve medya</span>
        </a>
        <a class="ap-route-card" href="/admin/komisyonlar">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-percent"></i></span>
                <strong>Komisyon oranları</strong>
            </div>
            <span class="ap-route-card-desc">Oran, tahakkuk ve ödeme bildirimi</span>
        </a>
        <a class="ap-route-card" href="/admin/email-kuyruk">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-envelope-open-text"></i></span>
                <strong>E-posta kuyruğu</strong>
            </div>
            <span class="ap-route-card-desc">Bekleyen ve hatalı gönderimler</span>
        </a>
        <a class="ap-route-card" href="/admin/kullanicilar">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-users-gear"></i></span>
                <strong>Kullanıcı ve rol</strong>
            </div>
            <span class="ap-route-card-desc">Rol, panel ve hesap durumları</span>
        </a>
        <a class="ap-route-card" href="/admin/raporlar">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-chart-line"></i></span>
                <strong>Gelir raporları</strong>
            </div>
            <span class="ap-route-card-desc">Aylık ciro ve komisyon</span>
        </a>
        <a class="ap-route-card" href="/admin/sistem-sagligi">
            <div class="ap-route-card-head">
                <span class="ap-route-card-icon"><i class="fas fa-shield-halved"></i></span>
                <strong>Sistem monitörü</strong>
            </div>
            <span class="ap-route-card-desc">Servis, link, kuyruk ve sağlık</span>
        </a>
    </div>

    <div class="complex-grid">
        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-clock-rotate-left"></i> Son hareketler</h3>
            </div>
            <div class="panel-body">
                <div class="ap-activity-list">
                    @foreach (var activity in Model.Activities)
                    {
                        var tone = string.IsNullOrWhiteSpace(activity.ToneClass) ? "info" : activity.ToneClass;
                        <div class="ap-activity-item @tone">
                            <span class="activity-icon"><i class="fas @activity.IconClass"></i></span>
                            <div>
                                <strong>@activity.Title</strong>
                                <p>@activity.Subtitle</p>
                            </div>
                            <small>@activity.TimeText</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fas fa-ranking-star"></i> Tesis performansı</h3>
            </div>
            <div class="panel-body panel-body-padded">
                @if (secondaryMetrics.Count > 0)
                {
                    <div class="ap-mini-metrics mb-3">
                        @foreach (var metric in secondaryMetrics)
                        {
                            <span>@metric.Label<strong>@metric.Value</strong></span>
                        }
                    </div>
                }
                @if (Model.HotelKpis.Count == 0)
                {
                    <div class="ap-empty-panel">Henüz KPI kaydı yok.</div>
                }
                else
                {
                    <table class="pro-table">
                        <thead>
                            <tr>
                                <th>Otel</th>
                                <th>Konum</th>
                                <th>Rez.</th>
                                <th>Ciro</th>
                                <th>Puan</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.HotelKpis.Take(8))
                            {
                                <tr>
                                    <td>
                                        <div class="guest-info">
                                            <span class="guest-name">@row.HotelName</span>
                                            <span class="guest-meta"><a href="/admin/otel-detay/@row.HotelId">Detay</a> · @row.PublishStatus</span>
                                        </div>
                                    </td>
                                    <td>@row.CityLabel</td>
                                    <td>@row.ReservationCount</td>
                                    <td><strong>@row.GrossRevenue.ToString("N0", tr) TL</strong></td>
                                    <td>@row.AverageScore.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</section>
