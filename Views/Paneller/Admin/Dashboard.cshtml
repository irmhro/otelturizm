@using otelturizmnew.Models.Paneller.Admin
@model AdminDashboardViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}
<div class="row">
    @foreach (var metric in Model.Metrics)
    {
        <div class="col-lg-3 col-md-6 col-12">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>@metric.Value</h3>
                    <p>@metric.Label</p>
                    <small>@metric.TrendText</small>
                </div>
                <div class="icon">
                    <i class="fas @metric.IconClass"></i>
                </div>
            </div>
        </div>
    }
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">Rezervasyon Hareketi (Son 6 Ay)</h3>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-end justify-content-between" style="gap: 10px; min-height: 220px;">
                    @foreach (var bar in Model.ReservationChart)
                    {
                        <div class="text-center flex-fill">
                            <div class="bg-primary rounded" style="height:@bar.HeightPercent%; min-height: 8px;"></div>
                            <div class="mt-2 font-weight-bold">@bar.Value</div>
                            <small class="text-muted">@bar.Label</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-secondary card-outline">
            <div class="card-header">
                <h3 class="card-title">Son Hareketler</h3>
            </div>
            <div class="card-body p-0">
                <ul class="products-list product-list-in-card pl-2 pr-2">
                    @foreach (var activity in Model.Activities)
                    {
                        <li class="item">
                            <div class="product-img text-primary">
                                <i class="fas @activity.IconClass fa-lg"></i>
                            </div>
                            <div class="product-info">
                                <span class="product-title">@activity.Title</span>
                                <span class="product-description">@activity.Subtitle</span>
                            </div>
                            <span class="text-muted float-right">@activity.TimeText</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Öne Çıkan Tesisler</h3>
                <div class="card-tools">
                    <span class="badge badge-info">Rezervasyon yoğunluğu yüksek</span>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Otel</th>
                            <th>Konum</th>
                            <th>Durum</th>
                            <th>Puan</th>
                            <th>Rezervasyon</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.HighlightHotels)
                        {
                            <tr>
                                <td>@row.HotelName</td>
                                <td>@row.CityLabel</td>
                                <td>
                                    <span class="badge @(row.StatusToneClass?.Contains("danger") == true ? "badge-danger" : "badge-success")">@row.StatusLabel</span>
                                </td>
                                <td>@row.ScoreText</td>
                                <td>@row.ReservationText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


