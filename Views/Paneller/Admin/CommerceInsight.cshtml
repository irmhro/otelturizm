@using otelturizmnew.Models.Paneller.Admin
@model AdminCommerceInsightPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="row">
    <div class="col-lg-6">
        <div class="card card-outline card-secondary">
            <div class="card-header"><h3 class="card-title">Growth yönetişimi</h3></div>
            <div class="card-body">
                <p class="mb-2">
                    <strong>Config kill-switch (<code>Growth:KillSwitchAll</code>):</strong>
                    @(Model.KillSwitchConfig ? "Açık" : "Kapalı")
                </p>
                <p class="mb-3">
                    <strong>Acil kill-switch (runtime):</strong>
                    @(Model.KillSwitchEmergency ? "Açık" : "Kapalı")
                </p>
                <form method="post" asp-controller="AdminPanel" asp-action="CommerceGrowthKill" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="growthKillReason">Gerekçe (zorunlu)</label>
                        <input type="text" name="reason" id="growthKillReason" class="form-control form-control-sm" maxlength="240" required placeholder="Örn: Anomali sonrası growth ingest durduruldu." />
                    </div>
                    <div class="btn-group btn-group-sm">
                        <button type="submit" name="enableEmergencyKill" value="true" class="btn btn-danger">Acil kill aç</button>
                        <button type="submit" name="enableEmergencyKill" value="false" class="btn btn-outline-secondary">Acil kill kapat</button>
                    </div>
                </form>
                <p class="text-muted small mb-0">Acil kill açıkken tüm <code>Growth:Flags</code> yüzde rollout değerlendirmeleri kapalıdır.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card card-outline card-info">
            <div class="card-header"><h3 class="card-title">Public cache purge</h3></div>
            <div class="card-body">
                <form method="post" asp-controller="AdminPanel" asp-action="EvictPublicCache">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnTo" value="commerce" />
                    <div class="form-group">
                        <label for="cacheReason">Gerekçe</label>
                        <input type="text" name="reason" id="cacheReason" class="form-control form-control-sm" maxlength="240" required />
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">OutputCache tag temizle</button>
                </form>
                <p class="text-muted small mt-2 mb-0">Aynı işlem <a asp-action="SystemHealth">Sistem Sağlığı</a> ekranından da tetiklenebilir.</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><h3 class="card-title">Son 7 gün (KPI)</h3></div>
            <div class="card-body">
                <p class="mb-1">Rezervasyon adedi: <strong>@Model.ReservationsLast7Days</strong></p>
                <p class="mb-0">Tahmini ciro (TRY): <strong>@Model.RevenueLast7Days.ToString("N2")</strong></p>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h3 class="card-title">Arşiv tablosu</h3></div>
            <div class="card-body">
                <p class="mb-1">Kayıt sayımı (örnek): <strong>@Model.ArchivedReservationSampleCount</strong></p>
                <p class="text-muted small mb-0">@Model.ArchiveHint</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">Growth event türleri (bellek içi)</h3></div>
    <div class="card-body">
        @if (Model.GrowthKinds.Count == 0)
        {
            <p class="text-muted mb-0">Henüz ingest yok.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead><tr><th>Kind</th><th>Adet</th></tr></thead>
                    <tbody>
                    @foreach (var kv in Model.GrowthKinds.OrderByDescending(static x => x.Value))
                    {
                        <tr><td><code>@kv.Key</code></td><td>@kv.Value</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">Web Vitals / RUM (bellek içi özet)</h3></div>
    <div class="card-body">
        @if (Model.RumRows.Count == 0)
        {
            <p class="text-muted mb-0">Henüz RUM ingest yok.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr>
                        <th>Route + metrik</th>
                        <th>Ort.</th>
                        <th>N</th>
                        <th>Min</th>
                        <th>Max</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model.RumRows)
                    {
                        <tr>
                            <td><small>@r.RouteMetric</small></td>
                            <td>@r.Avg.ToString("F1")</td>
                            <td>@r.Count</td>
                            <td>@r.Min.ToString("F1")</td>
                            <td>@r.Max.ToString("F1")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">Canlı envanter uyarısı (düşük stok)</h3></div>
    <div class="card-body">
        @if (Model.InventoryRows.Count == 0)
        {
            <p class="text-muted mb-0">Uyarı koşulu yok veya tablo eksik.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr><th>Otel</th><th>Oda</th><th>Tarih</th><th>Kalan</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model.InventoryRows)
                    {
                        <tr>
                            <td>@r.HotelName</td>
                            <td>@r.RoomName</td>
                            <td>@r.Date.ToString("yyyy-MM-dd")</td>
                            <td>@r.Remaining</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Fiyat örnekleri (otel #@Model.PriceHistoryHotelId)</h3>
    </div>
    <div class="card-body">
        <form method="get" asp-controller="AdminPanel" asp-action="CommerceInsight" class="form-inline mb-3">
            <label class="mr-2" for="hid">Otel Id</label>
            <input type="number" name="hotelId" id="hid" class="form-control form-control-sm" value="@Model.PriceHistoryHotelId" style="max-width:140px;" />
            <button type="submit" class="btn btn-sm btn-secondary ml-2">Göster</button>
        </form>
        @if (Model.PriceSampleRows.Count == 0)
        {
            <p class="text-muted mb-0">Kayıt yok veya oda_fiyat_musaitlik boş.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr><th>Oda</th><th>Tarih</th><th>Taban</th><th>İndirimli</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model.PriceSampleRows)
                    {
                        <tr>
                            <td>@r.RoomName</td>
                            <td>@r.Date.ToString("yyyy-MM-dd")</td>
                            <td>@r.BasePrice.ToString("N2")</td>
                            <td>@(r.DiscountPrice?.ToString("N2") ?? "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
