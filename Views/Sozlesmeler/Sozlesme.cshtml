@model otelturizmnew.Models.Legal.ContractDetailPageViewModel
@{
    Layout = "~/Views/Shared/_PublicPremiumPageLayout.cshtml";
    ViewData["Title"] = Model.Title;
    ViewData["BodyClass"] = "sozlesme-page anasayfa-page";
    ViewData["PageCss"] = "sozlesme";
    ViewData["PageCssMobile"] = "sozlesme";
    ViewData["IncludeAnasayfaStyles"] = true;
}

<div class="sozlesme-main">
    <div class="container sozlesme-body">
        <section class="eco-ribbon eco-ribbon-stack sozlesme-trust-strip" aria-label="Sözleşme bilgisi">
            <div class="eco-meta"><span><i class="fas fa-scale-balanced" aria-hidden="true"></i></span> @Model.Audience.ToUpperInvariant() · Sözleşme Merkezi</div>
            <div class="eco-pills sozlesme-trust-pills">
                <span class="eco-pill">@Model.VersionText</span>
                <span class="eco-pill"><i class="fas fa-calendar-check" aria-hidden="true"></i> @Model.EffectiveDateText</span>
            </div>
        </section>

        <header class="sozlesme-hero">
            <div class="sozlesme-hero-copy">
                <h1 class="sozlesme-title">@Model.Title</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                {
                    <p class="sozlesme-subtitle">@Model.Subtitle</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PdfUrl))
                {
                    <a class="sozlesme-pdf-btn" href="@Model.PdfUrl" target="_blank" rel="noopener noreferrer">
                        <i class="fas fa-file-pdf" aria-hidden="true"></i> PDF formatında aç
                    </a>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
            {
                <div class="sozlesme-hero-visual">
                    <img src="@Model.HeroImageUrl" alt="@Model.Title" loading="lazy" />
                </div>
            }
        </header>

        <article class="sozlesme-content-card">
            @if (!string.IsNullOrWhiteSpace(Model.SummaryHtml))
            {
                <div class="sozlesme-summary">@Html.Raw(Model.SummaryHtml)</div>
            }
            <div class="sozlesme-content">@Html.Raw(Model.ContentHtml)</div>
        </article>

        @if (Model.RelatedContracts?.Count > 0)
        {
            <section class="sozlesme-related" aria-labelledby="sozlesme-related-title">
                <h2 id="sozlesme-related-title" class="section-headline sozlesme-related-title">
                    <span class="headline-left">İlgili sözleşmeler</span>
                </h2>
                <div class="sozlesme-related-grid">
                    @foreach (var item in Model.RelatedContracts)
                    {
                        <a class="sozlesme-related-card" href="@item.Url">@item.Title</a>
                    }
                </div>
            </section>
        }
    </div>
</div>
