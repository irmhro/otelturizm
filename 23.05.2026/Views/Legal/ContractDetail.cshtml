@model otelturizmnew.Models.Legal.ContractDetailPageViewModel

<section class="legal-contract-page">
    <div class="legal-contract-hero">
        <div>
            <p class="legal-contract-kicker">@Model.Audience.ToUpperInvariant() SÖZLEŞME MERKEZİ</p>
            <h1>@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
            {
                <p class="legal-contract-subtitle">@Model.Subtitle</p>
            }
            <div class="legal-contract-meta">
                <span>@Model.VersionText</span>
                <span>@Model.EffectiveDateText itibarıyla yürürlükte</span>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
        {
            <div class="legal-contract-visual">
                <img src="@Model.HeroImageUrl" alt="@Model.Title" />
            </div>
        }
    </div>

    <div class="legal-contract-layout">
        <article class="legal-contract-body">
            @if (!string.IsNullOrWhiteSpace(Model.SummaryHtml))
            {
                <div class="legal-contract-summary">@Html.Raw(Model.SummaryHtml)</div>
            }
            <div class="legal-contract-content">@Html.Raw(Model.ContentHtml)</div>
        </article>

        <aside class="legal-contract-sidebar">
            <div class="legal-contract-sidebar-card">
                <h3>İlgili sözleşmeler</h3>
                <ul>
                    @foreach (var item in Model.RelatedContracts)
                    {
                        <li><a href="@item.Url">@item.Title</a></li>
                    }
                </ul>
            </div>
        </aside>
    </div>
</section>
