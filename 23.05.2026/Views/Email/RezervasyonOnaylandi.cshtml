<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#f5f7fb;font-family:Arial,sans-serif;color:#10203a;">
    <div style="max-width:640px;margin:0 auto;padding:28px 14px;">
        <div style="background:#fff;border:1px solid #dbe4f0;border-radius:18px;padding:28px;">
            <p style="margin:0 0 10px;font-size:13px;font-weight:700;letter-spacing:.08em;color:#2f6fed;">OTELTURIZM</p>
            <h1 style="margin:0 0 14px;font-size:26px;line-height:1.25;">Rezervasyonunuz onaylandı</h1>
            <p style="margin:0 0 10px;font-size:15px;">Merhaba <strong>{{user_first_name}}</strong>,</p>
            <p style="margin:0 0 16px;font-size:15px;line-height:1.6;">
                <strong>{{hotel_name}}</strong> için <strong>{{booking_reference}}</strong> numaralı rezervasyonunuz onaylandı.
            </p>
            <div style="padding:14px 16px;border-radius:12px;background:#f0fdf4;border:1px solid #bbf7d0;margin:0 0 16px;">
                <div style="font-size:14px;margin:0 0 6px;"><strong>Giriş:</strong> {{check_in_date}}</div>
                <div style="font-size:14px;margin:0 0 6px;"><strong>Çıkış:</strong> {{check_out_date}}</div>
                <div style="font-size:14px;margin:0 0 6px;"><strong>Oda:</strong> {{room_type_name}}</div>
                <div style="font-size:14px;"><strong>Toplam:</strong> {{total_price}}</div>
            </div>
            <a href="{{booking_details_link}}" style="display:inline-block;padding:12px 18px;border-radius:999px;background:#174ea6;color:#fff;text-decoration:none;font-weight:700;">
                Rezervasyonu görüntüle
            </a>
        </div>
    </div>
</body>
</html>
