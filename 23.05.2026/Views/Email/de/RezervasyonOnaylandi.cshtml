<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Otelturizm · Booking confirmed</title>
</head>
<body style="margin:0;padding:0;background:#E8ECF2;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,Helvetica,Arial,sans-serif;color:#1A1F26;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#E8ECF2;padding:36px 12px;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:#FFFFFF;border-radius:24px;overflow:hidden;box-shadow:0 10px 34px rgba(15,23,42,0.10);">
                <tr>
                    <td style="background:linear-gradient(135deg,#003B95 0%,#0c5adb 100%);padding:34px 28px;color:#ffffff;text-align:center;">
                        <div style="font-size:13px;letter-spacing:.16em;text-transform:uppercase;opacity:.92;font-weight:800;">Booking Center</div>
                        <div style="margin-top:10px;font-size:22px;font-weight:900;">Your booking is confirmed</div>
                        <div style="margin-top:8px;font-size:14px;opacity:.92;">Have a great stay</div>
                    </td>
                </tr>
                <tr>
                    <td style="padding:28px;">
                        <p style="margin:0 0 12px;font-size:18px;">Hi <strong>{{user_first_name}}</strong>,</p>
                        <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
                            Your booking at <strong>{{hotel_name}}</strong> has been confirmed. Your reference:
                            <strong style="font-size:18px;color:#003B95;">#{{booking_reference}}</strong>
                        </p>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#F5F7FA;border:1px solid #E7E9EC;border-radius:16px;margin:0 0 16px;">
                            <tr>
                                <td style="padding:16px 16px;">
                                    <div style="font-size:12px;color:#6B7380;text-transform:uppercase;letter-spacing:.08em;font-weight:800;">Booking details</div>
                                    <div style="margin-top:10px;font-size:14px;color:#1A1F26;"><strong>Stay:</strong> {{check_in_date}} → {{check_out_date}}</div>
                                    <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Room:</strong> {{room_type_name}}</div>
                                    <div style="margin-top:6px;font-size:14px;color:#1A1F26;"><strong>Total:</strong> ₺{{total_price}}</div>
                                    <div style="margin-top:6px;font-size:13px;color:#6B7380;"><strong>Address:</strong> {{hotel_address}}</div>
                                </td>
                            </tr>
                        </table>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
                            <tr>
                                <td style="border-radius:999px;background:linear-gradient(135deg,#003B95 0%,#0c5adb 100%);">
                                    <a href="{{booking_details_link}}" style="display:inline-block;padding:14px 22px;color:#ffffff !important;text-decoration:none;font-size:15px;font-weight:900;border-radius:999px;">View booking →</a>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:0;font-size:12px;color:#6B7380;">
                            Need help? Contact us at destek@otelturizm.com
                        </p>
                    </td>
                </tr>
                <tr>
                    <td style="padding:18px 22px;background:#F5F7FA;border-top:1px solid #E7E9EC;color:#6B7380;text-align:center;">
                        <p style="margin:0;font-size:12px;">© 2026 Otelturizm · Reservierungs-Nr.: #{{booking_reference}}</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>

