<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#f2f5fa;font-family:Inter,Arial,sans-serif;color:#132238;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f2f5fa;padding:26px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="660" style="max-width:660px;background:#ffffff;border:1px solid #dbe5f3;border-radius:20px;overflow:hidden;">
                    <tr>
                        <td style="padding:30px;background:linear-gradient(135deg,#2f3441 0%,#1c2333 100%);color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;opacity:.84;">Rezervasyon Durum Bildirimi</p>
                            <h1 style="margin:0;font-size:28px;line-height:1.2;">Rezervasyon talebiniz güncellendi</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:30px;">
                            <p style="margin:0 0 12px;font-size:16px;">Sayın <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#425873;">
                                <strong>{{booking_reference}}</strong> numaralı rezervasyon talebiniz tesis tarafından reddedilmiştir.
                            </p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f7f9fd;border:1px solid #e2e8f3;border-radius:14px;margin-bottom:14px;">
                                <tr>
                                    <td style="padding:14px 16px;font-size:14px;line-height:1.6;color:#2b3f58;">
                                        <p style="margin:0 0 6px;"><strong>Otel:</strong> {{hotel_name}}</p>
                                        <p style="margin:0 0 6px;"><strong>Tarih:</strong> {{check_in_date}} - {{check_out_date}}</p>
                                        <p style="margin:0 0 6px;"><strong>Oda:</strong> {{room_type_name}}</p>
                                        <p style="margin:0;"><strong>Tutar:</strong> ₺{{total_price}}</p>
                                    </td>
                                </tr>
                            </table>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fff5f5;border:1px solid #fecaca;border-radius:14px;">
                                <tr>
                                    <td style="padding:14px 16px;">
                                        <p style="margin:0 0 6px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#b91c1c;">Detaylı red sebebi</p>
                                        <p style="margin:0;font-size:14px;line-height:1.6;color:#7f1d1d;">{{rejection_reason}}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 30px;background:#f8fbff;border-top:1px solid #e5edf8;">
                            <p style="margin:0;font-size:12px;color:#66758c;">Bu e-posta otomatik gönderilmiştir.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
