<!DOCTYPE html>
<html lang="tr">
<body style="margin:0;padding:0;background:#eef3fa;font-family:Inter,Arial,sans-serif;color:#17263a;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#eef3fa;padding:28px 12px;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="max-width:640px;background:#ffffff;border:1px solid #d9e2f1;border-radius:20px;overflow:hidden;">
                    <tr>
                        <td style="padding:28px;background:linear-gradient(135deg,#0f5bd7 0%,#1647a5 100%);color:#ffffff;">
                            <p style="margin:0 0 8px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;opacity:.88;">Rezervasyon Mesaj Merkezi</p>
                            <h1 style="margin:0;font-size:27px;line-height:1.2;">Rezervasyonunuz için yeni mesaj var</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:28px;">
                            <p style="margin:0 0 12px;font-size:16px;">Merhaba <strong>{{user_first_name}}</strong>,</p>
                            <p style="margin:0 0 14px;font-size:14px;line-height:1.6;color:#425873;">
                                <strong>{{booking_reference}}</strong> referanslı rezervasyonunuz için tesis tarafından yeni bir bilgilendirme mesajı gönderildi.
                            </p>
                            <p style="margin:0 0 6px;font-size:13px;color:#5f738c;letter-spacing:.08em;text-transform:uppercase;">Konu</p>
                            <p style="margin:0 0 14px;font-size:15px;font-weight:700;color:#1e3a8a;">{{message_subject}}</p>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f7faff;border:1px solid #dbe6f8;border-radius:14px;">
                                <tr>
                                    <td style="padding:15px 16px;">
                                        <p style="margin:0;font-size:14px;line-height:1.7;color:#2c3f57;white-space:pre-line;">{{message_text}}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:18px 28px;background:#f8fbff;border-top:1px solid #e4ecf8;">
                            <p style="margin:0;font-size:12px;color:#6b7c92;">Bu e-posta rezervasyon mesajlaşma akışı kapsamında otomatik gönderilmiştir.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
