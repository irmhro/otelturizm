@model otelturizmnew.Models.Paneller.User.UserReviewsPageViewModel
@{
    Layout = "~/Views/Paneller/User/_UserPanelLayout.cshtml";
    ViewData["Title"] = "Yorumlarım";
    var pageStart = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var pageEnd = Math.Min(Model.TotalCount, Model.Page * Model.PageSize);
}

<div class="user-reviews-page">
    @if (TempData["UserReviewSuccess"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="review-alert review-alert--success"><i class="fas fa-check-circle"></i><span>@successMessage</span></div>
    }
    @if (TempData["UserReviewError"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="review-alert review-alert--danger"><i class="fas fa-triangle-exclamation"></i><span>@errorMessage</span></div>
    }

    <section class="reviews-page-hero">
        <div>
            <div class="page-pretitle">DEĞERLENDİRMELER</div>
            <h1 class="page-title">Yorumlarım</h1>
            <p class="text-muted mb-0">Onaylı konaklamaların için yorum yaz; 7 gün içinde düzenleyebilir veya silebilirsin.</p>
        </div>
        <div class="reviews-page-hero-actions">
            <a class="btn btn-primary btn-pill" asp-action="Reservations"><i class="fas fa-calendar-check me-2"></i>Rezervasyonlarım</a>
            <a class="btn btn-outline-primary btn-pill" href="/oteller"><i class="fas fa-magnifying-glass me-2"></i>Otel Ara</a>
        </div>
    </section>

    <section class="reviews-stat-grid" aria-label="Yorum özeti">
        <article class="reviews-stat reviews-stat--all">
            <span><i class="fas fa-list-check"></i></span>
            <div><strong>@Model.TotalCount</strong><small>Listelenen</small></div>
        </article>
        <article class="reviews-stat reviews-stat--waiting">
            <span><i class="fas fa-hourglass-half"></i></span>
            <div><strong>@Model.WaitingReviewCount</strong><small>Yorum bekleyen</small></div>
        </article>
        <article class="reviews-stat reviews-stat--reviewed">
            <span><i class="fas fa-comment-dots"></i></span>
            <div><strong>@Model.ReviewedCount</strong><small>Yorumlanan</small></div>
        </article>
    </section>

    <section class="card reviews-filter-card">
        <div class="card-header">
            <h3 class="card-title">Filtrele</h3>
            <div class="card-actions">
                <span class="reviews-count-chip">@pageStart-@pageEnd / @Model.TotalCount kayıt</span>
            </div>
        </div>
        <div class="card-body">
            <nav class="reviews-status-tabs" aria-label="Yorum durumu">
                <a asp-action="Reviews" asp-route-status="all" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "all" ? "is-active" : string.Empty)">Tümü</a>
                <a asp-action="Reviews" asp-route-status="waiting" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "waiting" ? "is-active" : string.Empty)">Yorum bekleyen</a>
                <a asp-action="Reviews" asp-route-status="reviewed" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="1" class="reviews-tab @(Model.StatusFilter == "reviewed" ? "is-active" : string.Empty)">Yorumlanan</a>
            </nav>

            <form method="get" asp-action="Reviews" class="reviews-filter-form">
                <input type="hidden" name="status" value="@Model.StatusFilter" />
                <input type="hidden" name="page" value="1" />
                <div class="reviews-filter-field reviews-filter-field--search">
                    <label class="form-label">Arama</label>
                    <div class="input-icon">
                        <span class="input-icon-addon"><i class="fas fa-search"></i></span>
                        <input class="form-control" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Otel, şehir veya rezervasyon no" />
                    </div>
                </div>
                <div class="reviews-filter-actions">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Filtrele</button>
                    <a asp-action="Reviews" class="btn btn-outline-primary">Temizle</a>
                </div>
            </form>
        </div>
    </section>

    <section class="card reviews-list-card">
        <div class="card-header">
            <h3 class="card-title">Konaklama ve yorumlar</h3>
            <div class="card-actions text-muted">Sayfa @Model.Page / @Model.TotalPages</div>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty reviews-empty">
                <div class="empty-icon"><i class="fas fa-comment-slash"></i></div>
                <p class="empty-title">Kayıt bulunamadı</p>
                <p class="empty-subtitle text-muted">Filtreleri değiştir veya rezervasyonlarından yorum yazılabilir kayıt seç.</p>
                <div class="empty-action">
                    <a asp-action="Reservations" class="btn btn-primary">Rezervasyonlarım</a>
                </div>
            </div>
        }
        else
        {
            <div class="reviews-list-horizontal">
                @foreach (var item in Model.Items)
                {
                    <article class="review-row-card review-row-card--@item.ReviewTone">
                        <a class="review-row-media" href="/oteller/@item.HotelSlug">
                            @if (!string.IsNullOrWhiteSpace(item.HotelImageUrl))
                            {
                                <img src="@item.HotelImageUrl" alt="@item.HotelName" />
                            }
                            else
                            {
                                <span><i class="fas fa-hotel"></i></span>
                            }
                        </a>
                        <div class="review-row-main">
                            <div class="review-row-top">
                                <div class="review-row-titles">
                                    <strong>@item.HotelName</strong>
                                    <small>@item.District, @item.City</small>
                                </div>
                                <span class="review-row-status review-row-status--@item.ReviewTone">@item.ReviewStatusText</span>
                            </div>
                            <div class="review-row-meta">
                                <span><i class="far fa-calendar"></i>@item.StayDateText</span>
                                <span><i class="far fa-moon"></i>@item.RoomName</span>
                                <span><i class="fas fa-hashtag"></i>Rez. @item.ReservationNo</span>
                                <span class="text-muted">@item.ReservationStatusText</span>
                            </div>

                            @if (item.HasReview)
                            {
                                <div class="review-snippet-block">
                                    <div class="review-snippet-head">
                                        <span class="review-snippet-score">@item.ReviewScore.ToString("0.0")<small>/10</small></span>
                                        <span class="review-snippet-date">@item.ReviewDateText</span>
                                    </div>
                                    <p class="review-snippet-text">@item.ReviewSnippet</p>
                                    @if (item.ReviewSnippetTruncated)
                                    {
                                        <span class="review-snippet-hint text-muted">Yorumun bir kısmı gösteriliyor.</span>
                                    }
                                </div>
                            }

                            <div class="review-row-footer">
                                <div class="review-row-actions">
                                    <a class="btn btn-outline-primary btn-sm" href="/oteller/@item.HotelSlug"><i class="fas fa-hotel me-1"></i>Otel</a>
                                    @if (item.CanWriteReview && !item.HasReview)
                                    {
                                        <a class="btn btn-primary btn-sm" asp-action="ReservationReview" asp-route-reservationId="@item.ReservationId"><i class="fas fa-plus me-1"></i>Yorum ekle</a>
                                    }
                                    @if (item.HasReview && item.CanEditReview && item.ReviewId.HasValue)
                                    {
                                        <details class="review-edit-details">
                                            <summary class="btn btn-outline-primary btn-sm review-edit-summary"><i class="fas fa-pen me-1"></i>Düzenle</summary>
                                            <div class="review-edit-panel">
                                                <form method="post" asp-action="UpdateReview" class="review-update-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ReviewId" value="@item.ReviewId.Value" />
                                                    <label class="form-label">Yorum metni <small class="field-optional">Opsiyonel</small></label>
                                                    <textarea name="Comment" class="form-control" rows="4" maxlength="4000">@item.ReviewText</textarea>
                                                    <small class="review-optional-warning">Yorum yazmazsanız mevcut metin boş kaydedilir.</small>
                                                    <div class="review-edit-panel-foot">
                                                        <small class="text-muted">@item.EditLimitText tarihine kadar düzenlenebilir.</small>
                                                        <button type="submit" class="btn btn-primary btn-sm">Kaydet</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </details>
                                        <form method="post" asp-action="DeleteReview" class="review-delete-inline" onsubmit="return confirm('Yorumu silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ReviewId" value="@item.ReviewId.Value" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash me-1"></i>Sil</button>
                                        </form>
                                    }
                                    else if (item.HasReview && !item.CanEditReview)
                                    {
                                        <span class="review-locked-inline text-muted small"><i class="fas fa-lock me-1"></i>7 günlük düzenleme süresi doldu</span>
                                    }
                                    else if (!item.HasReview && !item.CanWriteReview)
                                    {
                                        <span class="text-muted small">Bu konaklama için yorum yazılamaz.</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }

        <div class="card-footer reviews-pager">
            <div class="text-muted">@pageStart-@pageEnd arası gösteriliyor · @Model.TotalCount kayıt</div>
            <div class="btn-list">
                <a asp-action="Reviews" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Math.Max(1, Model.Page - 1))" class="btn btn-outline-primary btn-sm @(Model.Page <= 1 ? "disabled" : string.Empty)">
                    <i class="fas fa-chevron-left me-1"></i>Önceki
                </a>
                <a asp-action="Reviews" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Math.Min(Model.TotalPages, Model.Page + 1))" class="btn btn-outline-primary btn-sm @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                    Sonraki<i class="fas fa-chevron-right ms-1"></i>
                </a>
            </div>
        </div>
    </section>
</div>
