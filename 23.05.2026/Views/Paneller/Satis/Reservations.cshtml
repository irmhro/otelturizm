@model otelturizmnew.Models.Paneller.Satis.SalesReservationsPageViewModel
@{
    Layout = "~/Views/Paneller/Satis/_SalesPanelLayout.cshtml";
    ViewData["SalesShell"] = Model.Shell;
}
<section class="sales-grid cards-4 sales-summary-strip">
    <article class="sales-stat-card info">
        <div class="sales-stat-icon"><i class="fas fa-list-check"></i></div>
        <strong>@Model.Summary.TotalCount</strong>
        <h3>Toplam Kayıt</h3>
        <p>Mevcut filtreye giren rezervasyonlar</p>
    </article>
    <article class="sales-stat-card success">
        <div class="sales-stat-icon"><i class="fas fa-circle-check"></i></div>
        <strong>@Model.Summary.ApprovedCount</strong>
        <h3>Onaylanan</h3>
        <p>Partner veya sistem onayından geçenler</p>
    </article>
    <article class="sales-stat-card danger">
        <div class="sales-stat-icon"><i class="fas fa-ban"></i></div>
        <strong>@Model.Summary.CancelledCount</strong>
        <h3>İptal Edilen</h3>
        <p>İptal veya düşen rezervasyonlar</p>
    </article>
    <article class="sales-stat-card warning">
        <div class="sales-stat-icon"><i class="fas fa-turkish-lira-sign"></i></div>
        <strong>@Model.Summary.TotalRevenueText</strong>
        <h3>Toplam Tutar</h3>
        <p>Filtrede görülen rezervasyon cirosu</p>
    </article>
</section>

<section class="sales-panel-card">
    <div class="sales-card-head sales-card-head-stack">
        <div>
            <h2>Gelişmiş Rezervasyon Filtreleri</h2>
            <span>Müşteri adı, telefon, e-posta, durum veya tarih aralığı ile anında sonuç alın.</span>
        </div>
    </div>
    <form method="get" class="sales-form-grid compact-grid sales-reservation-filter-grid">
        <div class="span-2">
            <label>Ara</label>
            <input type="text" name="search" value="@Model.Filters.Search" placeholder="Rezervasyon no, otel, müşteri adı, telefon veya e-posta" />
        </div>
        <div>
            <label>Rezervasyon durumu</label>
            <select name="status">
                <option value="">Tümü</option>
                <option value="Onay Bekliyor" selected="@(Model.Filters.Status == "Onay Bekliyor")">Onay Bekliyor</option>
                <option value="Onaylandı" selected="@(Model.Filters.Status == "Onaylandı")">Onaylandı</option>
                <option value="İptal Edildi" selected="@(Model.Filters.Status == "İptal Edildi")">İptal Edildi</option>
            </select>
        </div>
        <div>
            <label>Partner onayı</label>
            <select name="approval">
                <option value="">Tümü</option>
                <option value="Beklemede" selected="@(Model.Filters.Approval == "Beklemede")">Beklemede</option>
                <option value="Onaylandı" selected="@(Model.Filters.Approval == "Onaylandı")">Onaylandı</option>
                <option value="Reddedildi" selected="@(Model.Filters.Approval == "Reddedildi")">Reddedildi</option>
            </select>
        </div>
        <div>
            <label>Giriş başlangıç</label>
            <input type="date" name="startDate" value="@(Model.Filters.StartDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div>
            <label>Çıkış bitiş</label>
            <input type="date" name="endDate" value="@(Model.Filters.EndDate?.ToString("yyyy-MM-dd"))" />
        </div>
        <div>
            <label>Sayfa başı</label>
            <select name="pageSize">
                <option value="10" selected="@(Model.Filters.PageSize == 10)">10 kayıt</option>
                <option value="20" selected="@(Model.Filters.PageSize == 20)">20 kayıt</option>
                <option value="30" selected="@(Model.Filters.PageSize == 30)">30 kayıt</option>
            </select>
        </div>
        <input type="hidden" name="page" value="1" />
        <div class="sales-filter-actions">
            <button type="submit">Filtreleri Uygula</button>
        </div>
    </form>
</section>

<section class="sales-panel-card">
    <div class="sales-card-head">
        <h2>Rezervasyon Listesi</h2>
        <span>@Model.Pagination.TotalCount kayıt · Sayfa @Model.Pagination.Page / @Model.Pagination.TotalPages</span>
    </div>

    @if (!Model.Reservations.Any())
    {
        <div class="sales-empty-state">
            <i class="fas fa-magnifying-glass"></i>
            <strong>Filtreye uyan rezervasyon bulunamadı</strong>
            <p>Daha geniş tarih aralığı, farklı durum veya daha kısa arama kelimesi deneyebilirsiniz.</p>
        </div>
    }
    else
    {
        <div class="sales-table-wrap sales-desktop-only">
            <table class="sales-table">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Misafir</th>
                        <th>Otel / Oda</th>
                        <th>Konaklama</th>
                        <th>Durum</th>
                        <th>Tutar</th>
                        <th>Kanal</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Reservations)
                {
                    <tr>
                        <td>
                            <strong>@item.ReservationNo</strong><br />
                            <small>@item.CreatedAtText</small>
                        </td>
                        <td>
                            <strong>@item.CustomerName</strong><br />
                            <small>@item.CustomerPhone</small><br />
                            <small>@item.CustomerEmail</small>
                        </td>
                        <td>
                            <strong>@item.HotelName</strong><br />
                            <small>@item.RoomName</small>
                        </td>
                        <td>@item.StayText</td>
                        <td>
                            <span class="sales-pill">@item.StatusText</span><br />
                            <small>@item.ApprovalText</small>
                        </td>
                        <td>
                            <strong>@item.TotalText</strong><br />
                            <small>Komisyon: @item.CommissionText</small>
                        </td>
                        <td>
                            <strong>@item.ChannelText</strong><br />
                            <small>@(string.IsNullOrWhiteSpace(item.DemandNote) ? "Not yok" : item.DemandNote)</small>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="sales-mobile-card-list sales-mobile-only">
            @foreach (var item in Model.Reservations)
            {
                <article class="sales-mobile-card">
                    <div class="sales-mobile-card-head">
                        <div>
                            <strong>@item.ReservationNo</strong>
                            <small>@item.CreatedAtText</small>
                        </div>
                        <span class="sales-pill">@item.StatusText</span>
                    </div>
                    <h3>@item.CustomerName</h3>
                    <p>@item.CustomerPhone · @item.CustomerEmail</p>
                    <p><strong>@item.HotelName</strong> · @item.RoomName</p>
                    <p>@item.StayText</p>
                    <div class="sales-mobile-card-metrics">
                        <span>@item.TotalText</span>
                        <span>@item.ChannelText</span>
                        <span>@item.ApprovalText</span>
                    </div>
                </article>
            }
        </div>
    }

    @if (Model.Pagination.TotalPages > 1)
    {
        <div class="sales-pagination">
            @for (var pageNumber = 1; pageNumber <= Model.Pagination.TotalPages; pageNumber++)
            {
                var reservationPageUrl = $"/panel/satis/rezervasyonlarim?search={Uri.EscapeDataString(Model.Filters.Search ?? string.Empty)}&status={Uri.EscapeDataString(Model.Filters.Status ?? string.Empty)}&approval={Uri.EscapeDataString(Model.Filters.Approval ?? string.Empty)}&startDate={Model.Filters.StartDate?.ToString("yyyy-MM-dd") ?? string.Empty}&endDate={Model.Filters.EndDate?.ToString("yyyy-MM-dd") ?? string.Empty}&pageSize={Model.Filters.PageSize}&page={pageNumber}";
                <a class="@(pageNumber == Model.Pagination.Page ? "active" : string.Empty)"
                   href="@reservationPageUrl">@pageNumber</a>
            }
        </div>
    }
</section>
