@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var welcomeEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "devoloper.orhan@otelturizm.com";
    var fullName = User.FindFirst("otelturizm:full_name")?.Value ?? User.Identity?.Name ?? "Developer";
}
<aside class="user-sidebar developer-sidebar">
    <div>
        <div class="brand-row">
            <a asp-controller="Home" asp-action="Index" class="brand-link" aria-label="Otelturizm">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" />
            </a>
        </div>

        <div class="profile-card developer-profile-card">
            <div>
                <h3>@fullName</h3>
                <p>@welcomeEmail</p>
            </div>
        </div>

        <nav class="sidebar-nav">
            <p class="nav-caption">Gelistirme</p>
            <a asp-action="Index" class="@(currentAction == "Index" ? "active" : "")"><i class="fas fa-list-check"></i> Taleplerim</a>
            <a asp-action="Security" class="@(currentAction == "Security" ? "active" : "")"><i class="fas fa-shield-halved"></i> Guvenlik</a>

            <p class="nav-caption second">Hizli Gecis</p>
            <a href="/admin/gelistirme-talepleri"><i class="fas fa-user-gear"></i> Admin Takip</a>
            <a href="/panel/user"><i class="fas fa-user"></i> Kullanici Paneli</a>
        </nav>
    </div>

    <div class="sidebar-bottom">
        <a asp-controller="Home" asp-action="Index" class="secondary-link"><i class="fas fa-arrow-left"></i> Ana Sayfaya Don</a>
        <form method="post" action="/cikis-yap" class="panel-logout-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-link"><i class="fas fa-right-from-bracket"></i> Cikis Yap</button>
        </form>
    </div>
</aside>
