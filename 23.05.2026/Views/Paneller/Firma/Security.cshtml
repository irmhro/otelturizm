@model otelturizmnew.Models.Paneller.User.UserSecurityPageViewModel
@{
    Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml";
    ViewData["Title"] = "Güvenlik";
}

<section class="form-stack firma-security-stack">
    <form method="post" action="/panel/firma/guvenlik/iki-asamali" class="panel-card" id="twoFactorForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Channel" value="email" />
        <div class="section-head"><h2>İki aşamalı doğrulama</h2></div>
        <div class="security-subhead">
            <h3>Firma hesabı için 2FA</h3>
            <p>Şifre sonrası ek doğrulama adımı; kurumsal hesap güvenliği için önerilir.</p>
        </div>

        <div class="security-block">
            <div class="security-block-head">
                <strong>Doğrulama kanalı</strong>
                <span class="text-muted">Durumu kaydetmek için alttaki butonu kullanın.</span>
            </div>

            <div class="security-channel-grid" role="group" aria-label="Doğrulama kanalı (e-posta)">
                <div class="security-channel-card @(!Model.EmailUsableForTwoFactor ? "is-disabled" : string.Empty)">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-envelope"></i></span>
                    <span class="security-channel-copy">
                        <strong>E-posta güvenlik kodu</strong>
                        <small>@(Model.EmailUsableForTwoFactor ? $"Aktif adres: {Model.MaskedEmailAddress}" : "Önce e-posta doğrulaması tamamlanmalı.")</small>
                    </span>
                    <span class="security-channel-pill @(Model.TwoFactorEnabled ? "on" : "off")">
                        <i class="fas @(Model.TwoFactorEnabled ? "fa-lock" : "fa-lock-open")"></i>
                        <span>@(Model.TwoFactorEnabled ? "Açık" : "Kapalı")</span>
                    </span>
                </div>

                <div class="security-channel-card is-upcoming" aria-disabled="true">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-mobile-screen"></i></span>
                    <span class="security-channel-copy">
                        <strong>Telefon / WhatsApp</strong>
                        <small>Firma panelinde şu an yalnızca e-posta kanalı desteklenir.</small>
                    </span>
                    <span class="security-channel-pill upcoming">
                        <i class="fas fa-screwdriver-wrench"></i>
                        Yakında
                    </span>
                </div>
            </div>

            <label class="toggle-row no-border" style="margin-top:18px;">
                <div>
                    <h3>2FA&apos;yı etkinleştir</h3>
                    <p>E-posta ile tek kullanımlık kod gönderilir.</p>
                </div>
                <span class="firma-twofactor-bind">
                    <input type="hidden" name="Enabled" value="false" />
                    <input name="Enabled" type="checkbox" value="true" @(Model.TwoFactorEnabled ? "checked" : null) @(!Model.EmailUsableForTwoFactor ? "disabled" : null) />
                </span>
            </label>

            <p class="auth-inline-hint security-hint">Firma hesabında ikinci adım yalnızca e-posta ile yapılandırılabilir.</p>

            <div class="save-row">
                <button type="submit" class="primary-btn">Güvenlik tercihini kaydet</button>
            </div>
        </div>
    </form>

    <div class="panel-card" id="firma-sozlesmeler-panel">
        <div class="section-head"><h2>Sözleşmeler</h2></div>
        <div class="security-subhead" style="margin-bottom: 0;">
            <h3>Kurumsal &amp; kullanıcı metinleri</h3>
            <p>Firma başvurusu ve panel kullanımına ilişkin güncel sözleşme ve aydınlatma sayfalarına buradan ulaşın.</p>
        </div>
        <div class="security-block" style="padding-top: 14px;">
            <div class="security-channel-grid" style="grid-template-columns: 1fr; gap: 10px;">
                <a class="security-channel-card" href="/sozlesmeler/firma-kurumsal-kullanim-kosullari" target="_blank" rel="noopener">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-building-shield"></i></span>
                    <span class="security-channel-copy">
                        <strong>Firma kurumsal kullanım koşulları</strong>
                        <small>Kurumsal üyelik, çalışanlar ve firma paneli kullanım kuralları.</small>
                    </span>
                    <span class="security-channel-pill upcoming">
                        <i class="fas fa-arrow-up-right-from-square"></i>
                        Aç
                    </span>
                </a>
                <a class="security-channel-card" href="/sozlesmeler/firma-kvkk-aydinlatma" target="_blank" rel="noopener">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-user-shield"></i></span>
                    <span class="security-channel-copy">
                        <strong>Firma KVKK aydınlatma metni</strong>
                        <small>6698 sayılı Kanun kapsamında firma veri işleme bilgilendirmesi.</small>
                    </span>
                    <span class="security-channel-pill upcoming">
                        <i class="fas fa-arrow-up-right-from-square"></i>
                        Aç
                    </span>
                </a>
                <a class="security-channel-card" href="/sozlesmeler/kullanici-kullanim-kosullari" target="_blank" rel="noopener">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-file-signature"></i></span>
                    <span class="security-channel-copy">
                        <strong>Kullanıcı kullanım koşulları</strong>
                        <small>Platform üyeliği ve bireysel rezervasyon kuralları.</small>
                    </span>
                    <span class="security-channel-pill upcoming">
                        <i class="fas fa-arrow-up-right-from-square"></i>
                        Aç
                    </span>
                </a>
                <a class="security-channel-card" href="/sozlesmeler/kullanici-kvkk-aydinlatma" target="_blank" rel="noopener">
                    <span class="security-channel-icon" aria-hidden="true"><i class="fas fa-shield-halved"></i></span>
                    <span class="security-channel-copy">
                        <strong>Kullanıcı KVKK aydınlatma metni</strong>
                        <small>Kişisel verilerin işlenmesine ilişkin üye aydınlatması.</small>
                    </span>
                    <span class="security-channel-pill upcoming">
                        <i class="fas fa-arrow-up-right-from-square"></i>
                        Aç
                    </span>
                </a>
            </div>
        </div>
    </div>
</section>
