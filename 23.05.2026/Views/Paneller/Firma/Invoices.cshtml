@model otelturizmnew.Models.Paneller.Firma.FirmaInvoicesPageViewModel
@{ Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml"; ViewData["FirmaShell"] = Model.Shell; }
<section class="firma-section-card"><h2>Faturalar</h2><div class="firma-table-wrap"><table class="firma-table"><thead><tr><th>Fatura No</th><th>Tarih</th><th>Tür</th><th>Alıcı</th><th>Tutar</th><th>Durum</th></tr></thead><tbody>@foreach (var item in Model.Invoices) { <tr><td>@item.InvoiceNo</td><td>@item.InvoiceDateText</td><td>@item.InvoiceType</td><td>@item.RecipientName</td><td>@item.TotalText</td><td>@item.StatusText</td></tr> }</tbody></table></div></section>
