@model otelturizmnew.Models.Paneller.Firma.FirmaReservationsPageViewModel
@{ Layout = "~/Views/Paneller/Firma/_FirmaPanelLayout.cshtml"; ViewData["FirmaShell"] = Model.Shell; }
<section class="firma-section-card ot-card">
    <h2>Firma Rezervasyonları</h2>
    <div class="firma-table-wrap">
        <table class="firma-table">
            <thead><tr><th>No</th><th>Çalışan</th><th>Otel</th><th>Konaklama</th><th>Rezervasyon Durumu</th><th>Firma Onayı</th><th>Tutar</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Reservations)
            {
                <tr>
                    <td>@item.ReservationNo</td>
                    <td>@item.EmployeeName</td>
                    <td><strong>@item.HotelName</strong><br /><small>@item.HotelCityText</small></td>
                    <td>@item.StayText</td>
                    <td><span class="ot-badge">@item.StatusText</span></td>
                    <td><span class="ot-badge ot-badge--info">@item.ApprovalText</span></td>
                    <td>@item.TotalText</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.Reservations.Count == 0)
    {
        <div class="firma-empty-inline">Firma adına açılmış rezervasyon bulunmuyor.</div>
    }
</section>
