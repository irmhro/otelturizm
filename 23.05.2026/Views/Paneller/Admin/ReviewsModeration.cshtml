@using otelturizmnew.Models.Paneller.Admin
@model AdminReviewModerationPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title">Değerlendirmeler</h3>
        <div class="card-tools">
            <span class="badge bg-light">Son @Model.Take kayıt</span>
        </div>
    </div>
    <div class="card-body">
        <form method="get" action="/admin/degerlendirmeler" class="row g-2 align-items-end">
            <div class="col-lg-5 col-12">
                <label class="form-label">Kelime / otel / kullanıcı</label>
                <input class="form-control" name="q" value="@Model.Q" placeholder="örn: aq, demo otel, recep..." />
            </div>
            <div class="col-lg-3 col-12">
                <label class="form-label">Şehir</label>
                <input class="form-control" name="city" value="@Model.City" placeholder="örn: İstanbul" />
            </div>
            <div class="col-lg-3 col-12">
                <label class="form-label">Otel</label>
                <input class="form-control" name="hotel" value="@Model.Hotel" placeholder="örn: Demo Test Otel" />
            </div>
            <div class="col-lg-1 col-12">
                <label class="form-label">Adet</label>
                <select class="form-select" name="take">
                    @foreach (var n in new[] { 20, 50, 100 })
                    {
                        if (Model.Take == n)
                        {
                            <option value="@n" selected>@n</option>
                        }
                        else
                        {
                            <option value="@n">@n</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 d-flex gap-2 flex-wrap mt-2">
                <button class="btn btn-primary" type="submit"><i class="fas fa-magnifying-glass me-2"></i>Filtrele</button>
                <a class="btn btn-outline-primary" href="/admin/degerlendirmeler"><i class="fas fa-rotate-left me-2"></i>Temizle</a>
            </div>
        </form>
        <p class="text-muted mb-0 mt-3">
            Kullanıcı sözleşmesi gereği: hakaret, iftira, ayrımcılık, kişisel veri ifşası ve hukuka aykırı içeriklerde admin yorumu silebilir / yayından kaldırabilir ve kullanıcıya ihlali bildirebilir.
        </p>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-striped table-hover text-nowrap mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Otel</th>
                    <th>Kullanıcı</th>
                    <th>Puan</th>
                    <th>Durum</th>
                    <th>Rapor</th>
                    <th>Tarih</th>
                    <th>Yorum</th>
                    <th>Aksiyon</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Reviews.Count == 0)
            {
                <tr><td colspan="9" class="text-muted p-3">Kayıt bulunamadı.</td></tr>
            }
            else
            {
                foreach (var r in Model.Reviews)
                {
                    <tr>
                        <td><code>@r.ReviewId</code></td>
                        <td>
                            <strong>@r.HotelName</strong><br />
                            <small class="text-muted">@r.District · @r.City</small>
                        </td>
                        <td>
                            <strong>@r.UserName</strong><br />
                            <small class="text-muted">#@r.UserId</small>
                        </td>
                        <td>@r.Score / 5</td>
                        <td>@r.StatusText</td>
                        <td>@r.ReportCount</td>
                        <td>@r.CreatedText</td>
                        <td style="max-width: 420px; white-space: normal;">
                            @r.CommentSnippet
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <form method="post" action="/admin/degerlendirmeler/islem">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ReviewId" value="@r.ReviewId" />
                                    <input type="hidden" name="HotelId" value="@r.HotelId" />
                                    <input type="hidden" name="Action" value="approve" />
                                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-success">Yayınla</button>
                                </form>
                                <form method="post" action="/admin/degerlendirmeler/islem">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ReviewId" value="@r.ReviewId" />
                                    <input type="hidden" name="HotelId" value="@r.HotelId" />
                                    <input type="hidden" name="Action" value="unpublish" />
                                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-warning">Yayından kaldır</button>
                                </form>
                                <form method="post" action="/admin/degerlendirmeler/sil" onsubmit="return confirm('Yorum kalıcı silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ReviewId" value="@r.ReviewId" />
                                    <input type="hidden" name="HotelId" value="@r.HotelId" />
                                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                                <form method="post" action="/admin/degerlendirmeler/ihlali-bildir">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ReviewId" value="@r.ReviewId" />
                                    <input type="hidden" name="UserId" value="@r.UserId" />
                                    <input type="hidden" name="RuleSummary" value="Yorum içeriği topluluk kurallarına aykırı olabilir (hakaret/iftira/ayrımcılık/kişisel veri ifşası/hukuka aykırı içerik)." />
                                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">İhlali bildir</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Yasaklı kelimeler (otel detay + partner yorumlarında maskelenir)</h3>
            </div>
            <div class="card-body">
                <form method="post" action="/admin/degerlendirmeler/yasakli-kelime/ekle" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                    <div class="col-md-5 col-12">
                        <label class="form-label">Kelime</label>
                        <input class="form-control" name="Word" placeholder="örn: aq" maxlength="120" />
                    </div>
                    <div class="col-md-5 col-12">
                        <label class="form-label">Açıklama</label>
                        <input class="form-control" name="Description" placeholder="örn: argo / hakaret" maxlength="250" />
                    </div>
                    <div class="col-md-2 col-12">
                        <button type="submit" class="btn btn-primary w-100">Ekle</button>
                    </div>
                </form>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped text-nowrap mb-0">
                    <thead>
                        <tr><th>Kelime</th><th>Durum</th><th>Açıklama</th><th>Tarih</th><th></th></tr>
                    </thead>
                    <tbody>
                    @if (Model.BlockedWords.Count == 0)
                    {
                        <tr><td colspan="5" class="text-muted p-3">Henüz tanım yok.</td></tr>
                    }
                    else
                    {
                        foreach (var w in Model.BlockedWords)
                        {
                            <tr>
                                <td><code>@w.Word</code></td>
                                <td>@(w.Active ? "Aktif" : "Pasif")</td>
                                <td>@(w.Description ?? "-")</td>
                                <td>@w.CreatedText</td>
                                <td>
                                    <form method="post" action="/admin/degerlendirmeler/yasakli-kelime/durum">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@w.Id" />
                                        <input type="hidden" name="Active" value="@(!w.Active)" />
                                        <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@(w.Active ? "Pasif yap" : "Aktif yap")</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6 col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Partner kaldırma talepleri</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped text-nowrap mb-0">
                    <thead>
                        <tr><th>Durum</th><th>Otel</th><th>Yorum</th><th>Partner</th><th>Gerekçe</th><th>Tarih</th></tr>
                    </thead>
                    <tbody>
                    @if (Model.TakedownRequests.Count == 0)
                    {
                        <tr><td colspan="6" class="text-muted p-3">Bekleyen talep yok.</td></tr>
                    }
                    else
                    {
                        foreach (var t in Model.TakedownRequests)
                        {
                            <tr>
                                <td>@t.StatusText</td>
                                <td><strong>@t.HotelName</strong><br /><small class="text-muted">#@t.HotelId</small></td>
                                <td><code>#@t.ReviewId</code></td>
                                <td><small>@t.PartnerEmail</small></td>
                                <td style="max-width: 360px; white-space: normal;">@(t.Reason ?? "-")</td>
                                <td>@t.CreatedText</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

