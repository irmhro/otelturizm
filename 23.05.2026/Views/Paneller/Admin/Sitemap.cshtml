@using otelturizmnew.Models.Seo
@model SitemapDiagnosticsViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
}

<div class="row">
    <div class="col-lg-4 col-md-6 col-12">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.MainSitemapUrlCount</h3>
                <p>Ana sitemap URL</p>
                <small>/sitemap.xml</small>
            </div>
            <div class="icon"><i class="fas fa-sitemap"></i></div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6 col-12">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.RegionalFileCount</h3>
                <p>İl/ilçe XML dosyası</p>
                <small>Views/xml klasörü</small>
            </div>
            <div class="icon"><i class="fas fa-map-location-dot"></i></div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6 col-12">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.RegionalUrlCount</h3>
                <p>İl/ilçe URL toplamı</p>
                <small>Son üretim çıktısı</small>
            </div>
            <div class="icon"><i class="fas fa-link"></i></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Sitemap yönetimi</h3>
        <form method="post" action="/admin/sitemap/yenile">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="fas fa-rotate mr-1"></i> Şimdi yenile
            </button>
        </form>
    </div>
    <div class="card-body">
        <p class="mb-1"><strong>Fiziksel dosya:</strong> @Model.MainSitemapPhysicalPath</p>
        <p class="mb-0"><strong>Son güncelleme (UTC):</strong> @(Model.LastRefreshUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Üretilen dosyalar</h3>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-striped table-hover text-nowrap mb-0">
            <thead>
                <tr>
                    <th>Dosya</th>
                    <th>Kapsam</th>
                    <th>URL sayısı</th>
                    <th>Son güncelleme (UTC)</th>
                    <th>Servis URL</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var file in Model.Files.OrderBy(x => x.FileName))
                {
                    <tr>
                        <td>@file.FileName</td>
                        <td>@file.ScopeText</td>
                        <td>@file.UrlCount</td>
                        <td>@(file.LastModifiedUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        <td><a href="@file.PublicUrl" target="_blank" rel="noopener">@file.PublicUrl</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
