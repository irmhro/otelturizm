@using otelturizmnew.Models.Paneller.Admin
@model AdminEmailRoutingPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var success = TempData["AdminMessage"] as string;
    var error = TempData["AdminError"] as string;
}

@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success ot-card">@success</div>
}
@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger ot-card">@error</div>
}
@if (!string.IsNullOrWhiteSpace(Model.Shell.PanelSubtitle) &&
     (Model.Shell.PanelSubtitle.Contains("admin_eposta", StringComparison.OrdinalIgnoreCase) ||
      Model.Shell.PanelSubtitle.Contains("Migration", StringComparison.OrdinalIgnoreCase) ||
      Model.Shell.PanelSubtitle.Contains("bulunamad", StringComparison.OrdinalIgnoreCase)))
{
    <div class="alert alert-warning ot-card admin-email-routing-warn">@Model.Shell.PanelSubtitle</div>
}

<div class="admin-email-routing">
    <section class="admin-email-routing-hero">
        <div>
            <p class="admin-email-routing-kicker">Yönlendirme kuralları</p>
            <h2>Olay bazlı admin bildirimleri</h2>
            <p>Her satır bir olay türünü temsil eder. Birden fazla adres için virgül veya noktalı virgül kullanın. Pasif satırlarda e-posta gönderilmez; boş veya hatalı yapılandırmada <strong>appsettings</strong> içindeki <code>Admin:NotificationFallbackEmail</code> devreye girer.</p>
        </div>
        <div class="admin-email-routing-hero-aside">
            <article>
                <span>Kayıtlı olay</span>
                <strong>@Model.Rows.Count</strong>
            </article>
            <article>
                <span>Şablon</span>
                <strong class="admin-email-routing-mono">admin_routing_notice</strong>
            </article>
        </div>
    </section>

    @if (Model.Rows.Count == 0)
    {
        <div class="card card-outline card-secondary">
            <div class="card-body">
                <p class="mb-0 text-muted">Henüz veritabanından satır yüklenemedi. <code>20260504_admin_eposta_yonlendirme.sql</code> migration dosyasını çalıştırdıktan sonra sayfayı yenileyin.</p>
            </div>
        </div>
    }
    else
    {
        <form method="post" asp-controller="AdminPanel" asp-action="SaveEmailRouting" class="admin-email-routing-form">
            @Html.AntiForgeryToken()
            <div class="admin-email-routing-toolbar">
                <div>
                    <span class="badge badge-light ot-badge">Toplu kayıt</span>
                    <span class="text-muted small ms-2">Değişiklikler tek seferde kaydedilir.</span>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1" aria-hidden="true"></i>Kaydet
                </button>
            </div>

            <div class="admin-email-routing-grid">
                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    var row = Model.Rows[i];
                    <article class="admin-email-routing-card">
                        <header class="admin-email-routing-card__head">
                            <div>
                                <h3>@row.Title</h3>
                                @if (!string.IsNullOrWhiteSpace(row.Description))
                                {
                                    <p>@row.Description</p>
                                }
                            </div>
                            <div class="admin-email-routing-card__meta">
                                <span class="admin-email-routing-badge">@row.EventCode</span>
                                <label class="admin-email-routing-toggle mb-0">
                                    <input type="hidden" name="Rows[@i].EventCode" value="@row.EventCode" />
                                    <span>Aktif</span>
                                    <input type="hidden" name="Rows[@i].Active" value="false" />
                                    <input type="checkbox" name="Rows[@i].Active" value="true" @(row.Active ? "checked" : null) />
                                </label>
                            </div>
                        </header>
                        <label class="admin-email-routing-label">
                            <span>Hedef e-postalar</span>
                            <textarea name="Rows[@i].EmailsCsv" rows="3" placeholder="ornek@firma.com, diger@firma.com" class="form-control">@row.EmailsCsv</textarea>
                        </label>
                        @if (!string.IsNullOrWhiteSpace(row.DeepLinkHint))
                        {
                            <footer class="admin-email-routing-card__foot">
                                <span class="text-muted small">İlgili ekran:</span>
                                <a href="@row.DeepLinkHint" target="_blank" rel="noopener" class="small">@row.DeepLinkHint</a>
                            </footer>
                        }
                    </article>
                }
            </div>

            <div class="admin-email-routing-toolbar admin-email-routing-toolbar--bottom">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1" aria-hidden="true"></i>Kaydet
                </button>
            </div>
        </form>
    }
</div>
