@model otelturizmnew.Models.Paneller.Admin.AdminHelpCenterPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var activeTab = (ViewData["HelpCenterTab"]?.ToString() ?? "categories").Trim().ToLowerInvariant();
}

<section class="admin-section-card">
    <div class="admin-section-head">
        <div>
            <p class="mini-caption">İÇERİK MERKEZİ</p>
            <h2>Yardım Merkezi Yönetimi</h2>
            <span>Kategori detayları (hero + tam açıklama), SSS ve Hakkımızda/Kariyer/Basın/Blog içerikleri.</span>
        </div>
    </div>

    <div class="admin-table-wrap">
        <div class="btn-group mb-3" role="group" aria-label="Sekmeler">
            <a class="btn @(activeTab=="categories" ? "btn-primary" : "btn-outline-primary")" href="/admin/yardim-merkezi-yonetim?tab=categories">Kategoriler</a>
            <a class="btn @(activeTab=="faq" ? "btn-primary" : "btn-outline-primary")" href="/admin/yardim-merkezi-yonetim?tab=faq">Soru &amp; Cevap</a>
            <a class="btn @(activeTab=="pages" ? "btn-primary" : "btn-outline-primary")" href="/admin/yardim-merkezi-yonetim?tab=pages">Sayfalar / Blog</a>
        </div>
    </div>
</section>

@if (activeTab == "categories")
{
    <section class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">KATEGORİ DETAY</p>
                <h2>Kategori hero + tam içerik</h2>
                <span>Kartlar `DESTEK_KATEGORILERI` tablosundan gelir; detay alanları bu ekrandan yönetilir.</span>
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>Kategori</th>
                    <th>Slug</th>
                    <th>Hero</th>
                    <th class="text-end">İşlem</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Categories)
                {
                    <tr>
                        <td><strong>@c.Name</strong><div class="text-muted small">@c.ShortDescription</div></td>
                        <td>@c.Slug</td>
                        <td class="text-muted">@((string.IsNullOrWhiteSpace(c.HeroTitle) ? "-" : c.HeroTitle))</td>
                        <td class="text-end">
                            <a class="btn btn-outline-primary btn-sm" href="/admin/yardim-merkezi-yonetim?tab=categories&editCategoryId=@c.CategoryId">Düzenle</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-section-card" style="margin-top: 1rem;">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">DÜZENLE</p>
                <h2>Kategori detay kaydı</h2>
                <span>Hero görsel yükleyebilir, başlık/altbaşlık ve tam açıklamayı HTML olarak girebilirsiniz.</span>
            </div>
        </div>
        <form method="post" action="/admin/yardim-merkezi-yonetim/kategori-kaydet" enctype="multipart/form-data" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <label>
                <span>Kategori</span>
                <select name="CategoryId" required>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.CategoryId" selected="@(c.CategoryId == Model.CategoryForm.CategoryId)">@c.Name</option>
                    }
                </select>
            </label>
            <label class="admin-form-span">
                <span>Hero başlık</span>
                <input type="text" name="HeroTitle" value="@Model.CategoryForm.HeroTitle" />
            </label>
            <label class="admin-form-span">
                <span>Hero alt başlık</span>
                <input type="text" name="HeroSubtitle" value="@Model.CategoryForm.HeroSubtitle" />
            </label>
            <label class="admin-form-span">
                <span>Hero görsel</span>
                <input type="file" name="heroFile" accept="image/*" />
                @if (!string.IsNullOrWhiteSpace(Model.CategoryForm.HeroImageUrl))
                {
                    <div class="text-muted small mt-1">Mevcut: <a href="@Model.CategoryForm.HeroImageUrl" target="_blank" rel="noopener">@Model.CategoryForm.HeroImageUrl</a></div>
                }
            </label>
            <label class="admin-form-span">
                <span>Tam detay açıklama (HTML)</span>
                <textarea name="FullHtml" rows="10">@Model.CategoryForm.FullHtml</textarea>
            </label>
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </section>
}

@if (activeTab == "faq")
{
    <section class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">SSS</p>
                <h2>Soru &amp; Cevap</h2>
                <span>Her kategori için soru/cevap ekleyin, sıralayın, aktif/pasif yapın.</span>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>Kategori</th>
                    <th>Soru</th>
                    <th>Sıra</th>
                    <th>Aktif</th>
                    <th class="text-end">İşlem</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var f in Model.FaqItems)
                {
                    <tr>
                        <td>@f.CategoryName</td>
                        <td><strong>@f.Question</strong></td>
                        <td>@f.OrderNo</td>
                        <td>@(f.IsActive ? "Evet" : "Hayır")</td>
                        <td class="text-end">
                            <a class="btn btn-outline-primary btn-sm" href="/admin/yardim-merkezi-yonetim?tab=faq&editFaqId=@f.Id">Düzenle</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-section-card" style="margin-top: 1rem;">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">DÜZENLE</p>
                <h2>SSS kaydı</h2>
            </div>
        </div>
        <form method="post" action="/admin/yardim-merkezi-yonetim/sss-kaydet" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.FaqForm.Id" />
            <label>
                <span>Kategori</span>
                <select name="CategoryId" required>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.CategoryId" selected="@(c.CategoryId == Model.FaqForm.CategoryId)">@c.Name</option>
                    }
                </select>
            </label>
            <label>
                <span>Sıralama</span>
                <input type="number" name="OrderNo" value="@Model.FaqForm.OrderNo" />
            </label>
            <label>
                <span>Aktif</span>
                <select name="IsActive">
                    <option value="true" selected="@(Model.FaqForm.IsActive)">Evet</option>
                    <option value="false" selected="@(!Model.FaqForm.IsActive)">Hayır</option>
                </select>
            </label>
            <label class="admin-form-span">
                <span>Soru</span>
                <input type="text" name="Question" value="@Model.FaqForm.Question" required />
            </label>
            <label class="admin-form-span">
                <span>Cevap (HTML)</span>
                <textarea name="AnswerHtml" rows="8" required>@Model.FaqForm.AnswerHtml</textarea>
            </label>
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </section>
}

@if (activeTab == "pages")
{
    <section class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">SAYFALAR / BLOG</p>
                <h2>İçerikler</h2>
                <span>Hakkımızda, Kariyer, Basın Odası ve Blog içeriklerini yönetin.</span>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>Tür</th>
                    <th>Başlık</th>
                    <th>Slug</th>
                    <th>Sıra</th>
                    <th>Öne çıkan</th>
                    <th>Aktif</th>
                    <th class="text-end">İşlem</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Contents)
                {
                    <tr>
                        <td>@c.Type</td>
                        <td><strong>@c.Title</strong></td>
                        <td>@c.Slug</td>
                        <td>@c.OrderNo</td>
                        <td>@(c.IsFeatured ? "Evet" : "Hayır")</td>
                        <td>@(c.IsActive ? "Evet" : "Hayır")</td>
                        <td class="text-end">
                            <a class="btn btn-outline-primary btn-sm" href="/admin/yardim-merkezi-yonetim?tab=pages&editContentId=@c.Id">Düzenle</a>
                            <a class="btn btn-outline-secondary btn-sm" href="/yardim-merkezi/sayfa/@c.Type/@c.Slug" target="_blank" rel="noopener">Önizle</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-section-card" style="margin-top: 1rem;">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">DÜZENLE</p>
                <h2>İçerik kaydı</h2>
            </div>
        </div>
        <form method="post" action="/admin/yardim-merkezi-yonetim/icerik-kaydet" enctype="multipart/form-data" class="admin-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.ContentForm.Id" />
            <label>
                <span>Tür</span>
                <select name="Type">
                    @{
                        var types = new[] { "about", "career", "press", "blog", "doc" };
                        foreach (var t in types)
                        {
                            <option value="@t" selected="@(string.Equals(Model.ContentForm.Type, t, StringComparison.OrdinalIgnoreCase))">@t</option>
                        }
                    }
                </select>
            </label>
            <label>
                <span>Sıralama</span>
                <input type="number" name="OrderNo" value="@Model.ContentForm.OrderNo" />
            </label>
            <label>
                <span>Öne çıkan</span>
                <select name="IsFeatured">
                    <option value="true" selected="@(Model.ContentForm.IsFeatured)">Evet</option>
                    <option value="false" selected="@(!Model.ContentForm.IsFeatured)">Hayır</option>
                </select>
            </label>
            <label>
                <span>Aktif</span>
                <select name="IsActive">
                    <option value="true" selected="@(Model.ContentForm.IsActive)">Evet</option>
                    <option value="false" selected="@(!Model.ContentForm.IsActive)">Hayır</option>
                </select>
            </label>
            <label class="admin-form-span">
                <span>Başlık</span>
                <input type="text" name="Title" value="@Model.ContentForm.Title" required />
            </label>
            <label class="admin-form-span">
                <span>Slug (url)</span>
                <input type="text" name="Slug" value="@Model.ContentForm.Slug" required />
            </label>
            <label class="admin-form-span">
                <span>Özet</span>
                <input type="text" name="Summary" value="@Model.ContentForm.Summary" />
            </label>
            <label class="admin-form-span">
                <span>Hero başlık</span>
                <input type="text" name="HeroTitle" value="@Model.ContentForm.HeroTitle" />
            </label>
            <label class="admin-form-span">
                <span>Hero alt başlık</span>
                <input type="text" name="HeroSubtitle" value="@Model.ContentForm.HeroSubtitle" />
            </label>
            <label class="admin-form-span">
                <span>Hero görsel</span>
                <input type="file" name="heroFile" accept="image/*" />
                @if (!string.IsNullOrWhiteSpace(Model.ContentForm.HeroImageUrl))
                {
                    <div class="text-muted small mt-1">Mevcut: <a href="@Model.ContentForm.HeroImageUrl" target="_blank" rel="noopener">@Model.ContentForm.HeroImageUrl</a></div>
                }
            </label>
            <label class="admin-form-span">
                <span>İçerik (HTML)</span>
                <textarea name="Html" rows="12" required>@Model.ContentForm.Html</textarea>
            </label>
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </section>
}

