@model otelturizmnew.Models.Paneller.Admin.AdminCommissionManagementPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
    string Money(decimal value) => "₺" + value.ToString("N0", tr);
    string Enc(string? value) => System.Net.WebUtility.UrlEncode(value ?? string.Empty);
    var queryCity = Context.Request.Query["city"].ToString();
    var queryDistrict = Context.Request.Query["district"].ToString();
    var queryNeighborhood = Context.Request.Query["neighborhood"].ToString();
    var queryRuleId = long.TryParse(Context.Request.Query["ruleId"].ToString(), out var parsedRuleId) ? parsedRuleId : (long?)null;
}

<section class="admin-commissions-page">
    <div class="commission-hero">
        <div>
            <p class="mini-caption">FİNANS OPERASYONU</p>
            <h1>Komisyon merkezi</h1>
            <span>Otel bazlı ciro, rezervasyon, satılan oda, komisyon tahakkuku ve ödeme bildirimlerini tek ekrandan yönetin.</span>
        </div>
        <div class="commission-hero-panel">
            <span>Ödeme günü</span>
            <strong>Her ayın 15'i</strong>
            <small>Seçili dönem için otele ödeme bildirimi kuyruğa alınabilir.</small>
        </div>
    </div>

    <div class="admin-kpi-grid">
        @foreach (var card in Model.SummaryCards.Take(4))
        {
            var tone = string.IsNullOrWhiteSpace(card.ToneClass) ? "info" : card.ToneClass;
            <article class="admin-kpi-card @tone">
                <span class="kpi-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    <article class="admin-section-card commission-filter-card">
        <form method="get" action="/admin/komisyonlar" class="admin-form-grid commission-filter-grid">
            <label class="admin-form-span">
                <span>Otel</span>
                <select name="hotelId">
                    <option value="">Tüm oteller</option>
                    @foreach (var hotel in Model.Hotels)
                    {
                        <option value="@hotel.HotelId" selected="@(hotel.IsSelected)">@hotel.HotelName (@hotel.HotelCode)</option>
                    }
                </select>
            </label>
            <label><span>Başlangıç</span><input type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" /></label>
            <label><span>Bitiş</span><input type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" /></label>
            <label>
                <span>İl</span>
                <input type="text" name="city" value="@queryCity" placeholder="Örn. İstanbul" />
            </label>
            <label>
                <span>İlçe</span>
                <input type="text" name="district" value="@queryDistrict" placeholder="Örn. Kartal" />
            </label>
            <label>
                <span>Mahalle</span>
                <input type="text" name="neighborhood" value="@queryNeighborhood" placeholder="Örn. Atalar" />
            </label>
            <label>
                <span>Komisyon ödeme durumu</span>
                <select name="paymentStatus">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.PaymentStatus))">Tümü</option>
                    <option value="Ödendi" selected="@(Model.PaymentStatus == "Ödendi")">Ödendi</option>
                    <option value="Ödenmedi" selected="@(Model.PaymentStatus == "Ödenmedi")">Ödenmedi</option>
                </select>
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="pageSize">
                    @foreach (var size in new[] { 50, 100, 200 })
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </label>
            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filtrele</button>
                <a class="btn btn-outline-secondary" href="/admin/komisyonlar">Sıfırla</a>
            </div>
        </form>
    </article>

    <article class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">OTEL BAZLI TAHAKKUK</p>
                <h2>Aylık ciro ve komisyon tablosu</h2>
                <span>Rezervasyon sayısı, satılan oda, toplam ciro, platform komisyonu ve ödeme durumu.</span>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table commission-table">
                <thead>
                    <tr>
                        <th>Otel</th>
                        <th>Rezervasyon</th>
                        <th>Satılan oda</th>
                        <th>Ciro</th>
                        <th>Komisyon</th>
                        <th>Net platform</th>
                        <th>Ödeme</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.HotelFinanceRows.Count == 0)
                {
                    <tr><td colspan="8">Seçili dönem için komisyon kaydı bulunmuyor.</td></tr>
                }
                else
                {
                    foreach (var row in Model.HotelFinanceRows)
                    {
                        <tr>
                            <td>
                                <strong>@row.HotelName</strong>
                                <div class="muted-line">@row.HotelCode @row.CityLabel</div>
                                <div class="muted-line">@row.ContactEmail</div>
                            </td>
                            <td><strong>@row.ReservationCount.ToString("N0", tr)</strong><div class="muted-line">@row.CompletedReservationCount tamamlandı</div></td>
                            <td>@row.SoldRoomCount.ToString("N0", tr)</td>
                            <td>@Money(row.GrossRevenue)</td>
                            <td><strong>@Money(row.TotalCommission)</strong><div class="muted-line">Ödenen @Money(row.PaidCommission)</div></td>
                            <td>@Money(row.PlatformNetCommission)</td>
                            <td>
                                <span class="commission-status @(row.PendingCommission <= 0 ? "paid" : "pending")">@row.PaymentStatusText</span>
                                <div class="muted-line">@row.PaymentDueText</div>
                            </td>
                            <td>
                                <form method="post" action="/admin/komisyonlar/odeme-bildirimi-gonder" class="inline-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="hotelId" value="@row.HotelId" />
                                    <input type="hidden" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" />
                                    <input type="hidden" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm"><i class="fas fa-paper-plane"></i> Bildirim gönder</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </article>

    <article class="admin-section-card">
        <div class="admin-section-head">
            <div>
                <p class="mini-caption">REZERVASYON KIRILIMI</p>
                <h2>Komisyon hesaplanan rezervasyonlar</h2>
                <span>Müşteri, oda, konaklama, komisyon oranı ve ödeme durumu detayları.</span>
            </div>
        </div>
        <div class="admin-table-wrap">
            <table class="admin-table commission-table compact">
                <thead>
                    <tr>
                        <th>Rezervasyon</th>
                        <th>Otel / Oda</th>
                        <th>Müşteri</th>
                        <th>Konaklama</th>
                        <th>Tutar</th>
                        <th>Komisyon</th>
                        <th>Otele net</th>
                        <th>Ödeme</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ReservationRows.Count == 0)
                {
                    <tr><td colspan="8">Rezervasyon kırılımı bulunmuyor.</td></tr>
                }
                else
                {
                    foreach (var row in Model.ReservationRows)
                    {
                        <tr>
                            <td><strong>@row.ReservationNo</strong><div class="muted-line">#@row.ReservationId</div></td>
                            <td><strong>@row.HotelName</strong><div class="muted-line">@row.RoomName · @row.RoomCount oda</div></td>
                            <td><strong>@row.GuestName</strong><div class="muted-line">@row.GuestEmail</div></td>
                            <td>@row.StayText</td>
                            <td>@Money(row.ReservationTotal)</td>
                            <td><strong>@Money(row.CommissionAmount)</strong><div class="muted-line">%@row.CommissionRate.ToString("0.##", tr)</div></td>
                            <td>@Money(row.NetPayout)</td>
                            <td><span class="commission-status @(row.PaymentStatusText == "Ödendi" ? "paid" : "pending")">@row.PaymentStatusText</span></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </article>

    <div class="admin-commission-grid">
        <article class="admin-section-card">
            <div class="admin-section-head">
                <div>
                    <p class="mini-caption">KURAL TANIMI</p>
                    <h2>Oteller komisyon oranları</h2>
                    <span>Otel seçin, dönem ve vergi oranlarını güncelleyin. Kayıtlı kuraldan düzenle dediğinizde form otomatik dolar.</span>
                </div>
            </div>
            <form method="post" action="/admin/komisyonlar/kaydet" class="admin-form-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RuleId" value="@Model.Form.RuleId" />
                @if (Model.Form.RuleId.HasValue)
                {
                    <div class="commission-edit-note admin-form-span">
                        <strong>#@Model.Form.RuleId kuralı düzenleniyor.</strong>
                        <a href="/admin/komisyonlar?hotelId=@Model.Form.HotelId&dateFrom=@(Model.DateFrom?.ToString("yyyy-MM-dd"))&dateTo=@(Model.DateTo?.ToString("yyyy-MM-dd"))&paymentStatus=@Enc(Model.PaymentStatus)&city=@Enc(queryCity)&district=@Enc(queryDistrict)&neighborhood=@Enc(queryNeighborhood)&pageSize=@Model.PageSize">Yeni kural moduna dön</a>
                    </div>
                }
                <label class="admin-form-span">
                    <span>Otel</span>
                    <select name="HotelId">
                        @foreach (var hotel in Model.Hotels)
                        {
                            <option value="@hotel.HotelId" selected="@(hotel.HotelId == Model.Form.HotelId)">@hotel.HotelName (@hotel.HotelCode)</option>
                        }
                    </select>
                </label>
                <label><span>Başlangıç</span><input type="date" name="StartDate" value="@Model.Form.StartDate.ToString("yyyy-MM-dd")" /></label>
                <label><span>Bitiş</span><input type="date" name="EndDate" value="@(Model.Form.EndDate?.ToString("yyyy-MM-dd"))" /></label>
                <label><span>Komisyon %</span><input type="number" step="0.01" min="0" name="CommissionRate" value="@Model.Form.CommissionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" /></label>
                <label><span>Komisyon gelir vergisi %</span><input type="number" step="0.01" min="0" name="CommissionIncomeTaxRate" value="@Model.Form.CommissionIncomeTaxRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" /></label>
                <label><span>KDV %</span><input type="number" step="0.01" min="0" name="VatRate" value="@Model.Form.VatRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" /></label>
                <label><span>Konaklama vergisi %</span><input type="number" step="0.01" min="0" name="AccommodationTaxRate" value="@Model.Form.AccommodationTaxRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" /></label>
                <label class="admin-form-span"><span>Not</span><textarea name="Note" rows="3">@Model.Form.Note</textarea></label>
                <div class="admin-form-actions">
                    <button type="submit" class="btn btn-primary">Kuralı Kaydet</button>
                </div>
            </form>
        </article>

        <article class="admin-section-card">
            <div class="admin-section-head">
                <div>
                    <p class="mini-caption">KAYITLI KURALLAR</p>
                    <h2>Komisyon kuralları</h2>
                    <span>Sayfa başı @Model.PageSize kayıt gösterilir. İl, ilçe, mahalle ve otel filtresi bu tabloya da uygulanır.</span>
                </div>
            </div>
            <div class="admin-table-wrap">
                <table class="admin-table commission-rules-table">
                    <thead>
                        <tr><th>Otel</th><th>Konum</th><th>Tarih</th><th>Komisyon</th><th>Vergiler</th><th>Durum</th><th>Aksiyon</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Rules)
                    {
                        <tr class="@(queryRuleId == item.RuleId ? "selected-rule-row" : "")">
                            <td><strong>@item.HotelName</strong><div>@item.HotelCode</div></td>
                            <td>@item.CityLabel</td>
                            <td>@item.DateRangeText</td>
                            <td><span class="table-status info">@item.CommissionText</span></td>
                            <td>@item.TaxText</td>
                            <td><span class="commission-status @(item.IsActive ? "paid" : "pending")">@(item.IsActive ? "Aktif" : "Pasif")</span><div class="muted-line">@item.NetText</div></td>
                            <td>
                                <a class="btn btn-outline-primary btn-sm" href="/admin/komisyonlar?ruleId=@item.RuleId&hotelId=@item.HotelId&dateFrom=@(Model.DateFrom?.ToString("yyyy-MM-dd"))&dateTo=@(Model.DateTo?.ToString("yyyy-MM-dd"))&paymentStatus=@Enc(Model.PaymentStatus)&city=@Enc(queryCity)&district=@Enc(queryDistrict)&neighborhood=@Enc(queryNeighborhood)&pageSize=@Model.PageSize">
                                    <i class="fas fa-pen"></i> Düzenle
                                </a>
                            </td>
                        </tr>
                    }
                    @if (Model.Rules.Count == 0)
                    {
                        <tr><td colspan="7">Komisyon kuralı bulunmuyor.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>
