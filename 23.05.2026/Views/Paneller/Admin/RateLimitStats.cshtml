@using otelturizmnew.Models.Paneller.Admin
@model AdminRateLimitStatsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Rate Limit İstatistikleri (Son @Model.WindowHours saat)</h3>
    </div>
    <div class="card-body">
        <form method="get" action="/admin/rate-limit" class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Pencere (saat)</label>
                <input class="form-control form-control-sm" name="windowHours" value="@Model.WindowHours" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-sm btn-primary w-100" type="submit">Yenile</button>
            </div>
        </form>

        <div class="table-responsive mt-3">
            <table class="table table-striped table-sm">
                <thead>
                <tr>
                    <th>Endpoint</th>
                    <th>Method</th>
                    <th>429</th>
                    <th>Toplam</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td style="max-width:640px;white-space:normal;">@row.Endpoint</td>
                        <td>@row.Method</td>
                        <td><span class="badge badge-danger">@row.Count429</span></td>
                        <td>@row.CountTotal</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

