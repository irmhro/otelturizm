@using otelturizmnew.Models.Paneller.Admin
@model AdminReportsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
    var totalPages = Model.PageSize <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(Model.Total / (double)Model.PageSize));
    var pageSizes = new[] { 10, 25, 50, 100, 200 };
    static string DateValue(DateTime? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty;
}

<section class="admin-reports-page">
    <div class="admin-report-hero">
        <div>
            <p class="mini-caption">FİNANS ANALİTİĞİ</p>
            <h1>Gelir ve komisyon raporu</h1>
            <span>Otel bazlı dönemsel ciro, komisyon, vergi ve iptal etkisini yönetilebilir tabloya dönüştürün.</span>
        </div>
        <a class="btn btn-primary" href="/admin/raporlar/aylik-ciro-komisyon.csv" download>
            <i class="fas fa-file-csv me-2"></i>CSV indir
        </a>
    </div>

    <div class="admin-summary-grid admin-report-summary-grid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="admin-summary-card admin-summary-card--@card.ToneClass">
                <span class="admin-summary-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    <article class="admin-section-card">
        <div class="card-header">
            <div>
                <p class="mini-caption">FİNANS RAPORU</p>
                <h2 class="card-title mb-1">Aylık kırılım</h2>
                <span class="text-muted">Otel bazlı aylık ciro, brüt/net komisyon ve vergi kırılımı.</span>
            </div>
        </div>

        <form method="get" action="/admin/raporlar" class="admin-ops-filter admin-reports-filter">
            <label>
                <span>Otel</span>
                <select name="hotelId">
                    <option value="">Tüm oteller</option>
                    @foreach (var option in Model.HotelOptions)
                    {
                        <option value="@option.HotelId" selected="@(Model.HotelId == option.HotelId)">@option.HotelName</option>
                    }
                </select>
            </label>
            <label>
                <span>Başlangıç</span>
                <input type="date" name="dateFrom" value="@DateValue(Model.DateFrom)" />
            </label>
            <label>
                <span>Bitiş</span>
                <input type="date" name="dateTo" value="@DateValue(Model.DateTo)" />
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="pageSize">
                    @foreach (var size in pageSizes)
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </label>
            <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Filtrele</button>
            <a class="btn btn-outline-primary" href="/admin/raporlar"><i class="fas fa-rotate-left me-2"></i>Temizle</a>
        </form>

        <div class="table-responsive admin-report-table-wrap">
            <table class="table table-vcenter table-hover admin-ops-table">
                <thead>
                    <tr>
                        <th>Ay</th>
                        <th>Otel</th>
                        <th>Rezervasyon</th>
                        <th>Ciro</th>
                        <th>Komisyon</th>
                        <th>Vergi</th>
                        <th>Ortalama</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="7">Filtreye uygun rapor kaydı bulunamadı.</td></tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td><strong>@row.MonthText</strong></td>
                            <td><strong>@row.HotelName</strong><small>@row.CityLabel</small></td>
                            <td><span>@row.ReservationCount toplam</span><small>@row.CompletedCount tamamlandı · @row.CancelledCount iptal</small></td>
                            <td><strong>@row.GrossRevenue.ToString("N2", tr) TRY</strong></td>
                            <td><span>Brüt @row.GrossCommission.ToString("N2", tr)</span><small>Net @row.NetCommission.ToString("N2", tr)</small></td>
                            <td><span>KDV @row.KdvAmount.ToString("N2", tr)</span><small>Konaklama @row.AccommodationTax.ToString("N2", tr)</small></td>
                            <td>@row.AverageNightAmount.ToString("N2", tr) TRY</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination-row">
            <span>@Model.Page / @totalPages sayfa</span>
            <div>
                <a class="btn btn-outline-primary btn-sm @(Model.Page <= 1 ? "disabled" : "")" href="/admin/raporlar?page=@(Model.Page - 1)&pageSize=@Model.PageSize&hotelId=@Model.HotelId&dateFrom=@DateValue(Model.DateFrom)&dateTo=@DateValue(Model.DateTo)">Önceki</a>
                <a class="btn btn-outline-primary btn-sm @(Model.Page >= totalPages ? "disabled" : "")" href="/admin/raporlar?page=@(Model.Page + 1)&pageSize=@Model.PageSize&hotelId=@Model.HotelId&dateFrom=@DateValue(Model.DateFrom)&dateTo=@DateValue(Model.DateTo)">Sonraki</a>
            </div>
        </div>
    </article>
</section>
