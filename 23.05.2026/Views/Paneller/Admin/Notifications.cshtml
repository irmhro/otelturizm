@using otelturizmnew.Models.Paneller.Admin
@model AdminNotificationsPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var totalPages = Model.PageSize <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(Model.Total / (double)Model.PageSize));
    var pageSizes = new[] { 10, 25, 50, 100, 200 };
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    static string DateText(DateTimeOffset? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "-";
    static string Tone(string status)
    {
        var normalized = (status ?? string.Empty).ToLowerInvariant();
        if (normalized.Contains("başarısız") || normalized.Contains("basarisiz") || normalized.Contains("iptal")) return "danger";
        if (normalized.Contains("bekle")) return "warning";
        if (normalized.Contains("okundu") || normalized.Contains("gönder") || normalized.Contains("gonder") || normalized.Contains("iletildi")) return "success";
        return "info";
    }
}

<section class="admin-notifications-page">
    <div class="admin-summary-grid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="admin-summary-card admin-summary-card--@card.ToneClass">
                <span class="admin-summary-icon"><i class="fas @card.IconClass"></i></span>
                <div>
                    <p>@card.Label</p>
                    <h2>@card.Value</h2>
                    <span>@card.Description</span>
                </div>
            </article>
        }
    </div>

    <article class="admin-section-card">
        <div class="card-header">
            <div>
                <p class="mini-caption">İLETİŞİM TAKİBİ</p>
                <h2 class="card-title mb-1">Bildirim Logları</h2>
                <span class="text-muted">Üretimde gönderilen veya kuyrukta bekleyen bildirim kayıtlarını deneme ve hata bilgileriyle izleyin.</span>
            </div>
            <a class="btn btn-outline-primary" href="/admin/e-posta-kuyrugu">
                <i class="fas fa-envelope me-2"></i>E-posta kuyruğu
            </a>
        </div>

        <form method="get" action="/admin/bildirimler" class="admin-ops-filter admin-notifications-filter">
            <label>
                <span>Arama</span>
                <input type="search" name="q" value="@Model.Query" placeholder="Alıcı, konu, içerik, hata" />
            </label>
            <label>
                <span>Durum</span>
                <select name="status">
                    <option value="">Tüm durumlar</option>
                    @foreach (var option in Model.StatusOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.Status, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Tür</span>
                <select name="notificationType">
                    <option value="">Tüm türler</option>
                    @foreach (var option in Model.TypeOptions)
                    {
                        <option value="@option" selected="@(string.Equals(Model.NotificationType, option, StringComparison.OrdinalIgnoreCase))">@option</option>
                    }
                </select>
            </label>
            <label>
                <span>Sayfa başı</span>
                <select name="pageSize">
                    @foreach (var size in pageSizes)
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </label>
            <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Filtrele</button>
            <a class="btn btn-outline-primary" href="/admin/bildirimler"><i class="fas fa-rotate-left me-2"></i>Temizle</a>
        </form>

        <div class="table-responsive">
            <table class="table table-vcenter table-hover admin-ops-table admin-notifications-table">
                <thead>
                    <tr>
                        <th>Bildirim</th>
                        <th>Alıcı</th>
                        <th>Kanal</th>
                        <th>Deneme</th>
                        <th>Tarih</th>
                        <th>İlişki</th>
                        <th>Durum</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="8">Filtreye uygun bildirim kaydı bulunamadı.</td></tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>
                                <strong>@row.Subject</strong>
                                <small>#@row.NotificationId</small>
                                @if (!string.IsNullOrWhiteSpace(row.ErrorMessage))
                                {
                                    <small class="text-danger">@row.ErrorMessage</small>
                                }
                            </td>
                            <td><span>@row.Recipient</span></td>
                            <td>
                                <strong>@row.Type</strong>
                                <small>@row.Provider · @row.ServiceCode</small>
                            </td>
                            <td>
                                <span>@row.AttemptCount / @row.MaxAttemptCount</span>
                            </td>
                            <td>
                                <span>@DateText(row.CreatedAtUtc)</span>
                                <small>Gönderim: @DateText(row.SentAtUtc)</small>
                                <small>Okunma: @DateText(row.ReadAtUtc)</small>
                            </td>
                            <td>
                                <span>@row.RelatedTable</span>
                                <small>@(row.RelatedId.HasValue ? "#" + row.RelatedId.Value : "-")</small>
                            </td>
                            <td><span class="status-pill status-pill--@Tone(row.Status)">@row.Status</span></td>
                            <td>
                                @if (!string.Equals(row.Status, "Okundu", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post" action="/admin/bildirimler/okundu" class="admin-inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="notificationId" value="@row.NotificationId" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-check me-1"></i>Okundu
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination-row">
            <span>@Model.Total kayıt · Sayfa @Model.Page / @totalPages</span>
            <div>
                <a class="btn btn-outline-primary btn-sm @(Model.Page <= 1 ? "disabled" : "")" href="/admin/bildirimler?page=@(Model.Page - 1)&pageSize=@Model.PageSize&q=@Model.Query&status=@Model.Status&notificationType=@Model.NotificationType">Önceki</a>
                <a class="btn btn-outline-primary btn-sm @(Model.Page >= totalPages ? "disabled" : "")" href="/admin/bildirimler?page=@(Model.Page + 1)&pageSize=@Model.PageSize&q=@Model.Query&status=@Model.Status&notificationType=@Model.NotificationType">Sonraki</a>
            </div>
        </div>
    </article>
</section>
