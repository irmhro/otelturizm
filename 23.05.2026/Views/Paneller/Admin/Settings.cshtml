@using otelturizmnew.Models.Paneller.Admin
@model AdminSettingsMonitorPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    var grouped = Model.Items
        .GroupBy(x => x.Key.Contains(':') ? x.Key.Split(':')[0] : "Platform")
        .OrderBy(x => x.Key)
        .ToList();
    static string DisplayValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "-";
        if (value.Length > 90) return value[..90] + "...";
        return value;
    }
}

<section class="admin-settings-page">
    <div class="admin-summary-grid">
        <article class="admin-summary-card admin-summary-card--info">
            <span class="admin-summary-icon"><i class="fas fa-sliders"></i></span>
            <div>
                <p>Ayar Anahtarı</p>
                <h2>@Model.Items.Count</h2>
                <span>Okunan kritik değer</span>
            </div>
        </article>
        <article class="admin-summary-card admin-summary-card--success">
            <span class="admin-summary-icon"><i class="fas fa-envelope-circle-check"></i></span>
            <div>
                <p>E-posta Servisi</p>
                <h2>@(Model.Items.TryGetValue("EmailProvider:Active", out var active) && active == "1" ? "Aktif" : "Kontrol")</h2>
                <span>@(Model.Items.TryGetValue("EmailProvider:Provider", out var provider) ? provider : "Servis kaydı yok")</span>
            </div>
        </article>
        <article class="admin-summary-card admin-summary-card--warning">
            <span class="admin-summary-icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <p>CSP</p>
                <h2>@(Model.Items.TryGetValue("Security:Csp:Enforce", out var csp) ? csp : "-")</h2>
                <span>Güvenlik başlığı durumu</span>
            </div>
        </article>
    </div>

    <div class="admin-settings-grid">
        @foreach (var group in grouped)
        {
            <article class="admin-section-card">
                <div class="card-header">
                    <div>
                        <p class="mini-caption">AYAR GRUBU</p>
                        <h2 class="card-title mb-1">@group.Key</h2>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter admin-ops-table">
                        <thead>
                            <tr>
                                <th>Anahtar</th>
                                <th>Değer</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in group)
                            {
                                <tr>
                                    <td><code>@item.Key</code></td>
                                    <td><span title="@item.Value">@DisplayValue(item.Value)</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        }
    </div>
</section>
