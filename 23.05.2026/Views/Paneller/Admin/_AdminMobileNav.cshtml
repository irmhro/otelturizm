@using System
@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var current = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsAct(string a) => string.Equals(current, a, StringComparison.OrdinalIgnoreCase);
    bool AnyAct(params string[] actions) => actions.Any(a => IsAct(a));
    bool Can(string code) => Model.Permissions.Contains("*") || Model.HasPermission(code);

    var hotelAct = AnyAct("Hotels", "HotelDetail", "ActiveHotels", "PendingHotels", "Campaigns");
    var resAct = AnyAct("Reservations", "UnifiedReservations", "CompanyReservations");
    var userAct = AnyAct("Users", "Managers", "PlatformOfficials", "PartnerApplications", "CompanyApplications", "DevelopmentRequests");
    var settingsAct = AnyAct("Settings", "SettingsMonitor", "SystemHealth", "PlatformCheckup");

    var showReservations = Can("admin.reservations") || Can("admin.unified_reservations");
    var reservationsAction = Can("admin.reservations") ? "Reservations" : "UnifiedReservations";
}
<nav class="admin-mobile-nav admin-mobile-nav--scroll" aria-label="Hızlı gezinme">
    <a asp-controller="AdminPanel" asp-action="Dashboard" class="@(IsAct("Dashboard") ? "active" : null) @(Can("admin.dashboard") ? null : "d-none")"><i class="fas fa-table-columns" aria-hidden="true"></i><span>Panel</span></a>
    <a asp-controller="AdminPanel" asp-action="ApprovalCenter" class="@(IsAct("ApprovalCenter") ? "active" : null) @(Can("admin.approval_center") ? null : "d-none")"><i class="fas fa-clipboard-check" aria-hidden="true"></i><span>Onay</span></a>
    <a asp-controller="AdminPanel" asp-action="Hotels" class="@(hotelAct ? "active" : null) @(Can("admin.hotels") ? null : "d-none")"><i class="fas fa-hotel" aria-hidden="true"></i><span>Oteller</span></a>
    @if (showReservations)
    {
        <a asp-controller="AdminPanel" asp-action="@reservationsAction" class="@(resAct ? "active" : null)"><i class="fas fa-calendar-check" aria-hidden="true"></i><span>Rez.</span></a>
    }
    <a asp-controller="AdminPanel" asp-action="Users" class="@(userAct ? "active" : null) @(Can("admin.users") ? null : "d-none")"><i class="fas fa-users" aria-hidden="true"></i><span>Üyeler</span></a>
    <a asp-controller="AdminPanel" asp-action="Notifications" class="@(AnyAct("Notifications", "MailCenter", "EmailQueue") ? "active" : null) @(Can("admin.notifications") ? null : "d-none")"><i class="fas fa-bell" aria-hidden="true"></i><span>Bild.</span></a>
    <a asp-controller="AdminPanel" asp-action="Settings" class="@(settingsAct ? "active" : null) @(Can("admin.settings") ? null : "d-none")"><i class="fas fa-sliders" aria-hidden="true"></i><span>Ayar</span></a>
    <form method="post" action="/cikis-yap" class="panel-mobile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit"><i class="fas fa-right-from-bracket" aria-hidden="true"></i><span>Çıkış</span></button>
    </form>
</nav>
