@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var fn = Model.FullName?.Trim() ?? string.Empty;
    var initial = fn.Length > 0 ? char.ToUpper(fn[0]).ToString() : "A";
}
<header class="navbar navbar-expand-md d-print-none partner-topbar admin-topbar" role="banner">
    <div class="container-fluid">
        <button class="navbar-toggler d-lg-none me-2" type="button" data-bs-toggle="collapse" data-bs-target="#adminSidebarMenu" aria-controls="adminSidebarMenu" aria-expanded="false" aria-label="Menüyü aç">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-brand d-lg-none">
            <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="partner-topbar-logo" />
        </div>

        <div class="d-none d-lg-flex align-items-center gap-3 flex-grow-1">
            <span class="avatar bg-primary-lt text-primary"><i class="fas fa-user-shield"></i></span>
            <div>
                <div class="text-muted small">Yönetici</div>
                <div class="fw-bold">@Model.FullName</div>
            </div>
        </div>

        <div class="navbar-nav flex-row ms-auto align-items-center gap-2">
            <a class="btn btn-outline-primary btn-sm btn-pill d-none d-md-inline-flex" asp-controller="AdminPanel" asp-action="Dashboard">
                <i class="fas fa-gauge-high me-2"></i>Özet
            </a>
            <a class="btn btn-primary btn-sm btn-pill d-none d-md-inline-flex" asp-controller="AdminPanel" asp-action="Notifications">
                <i class="fas fa-bell me-2"></i>Bildirimler
                @if (Model.UnreadNotifications > 0)
                {
                    <span class="badge bg-white text-primary ms-1">@Model.UnreadNotifications</span>
                }
            </a>
            <button class="btn btn-icon btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminThemeSettings" aria-label="Tema ayarları">
                <i class="fas fa-palette"></i>
            </button>

            <div class="nav-item dropdown">
                <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown" aria-label="Hızlı bağlantılar">
                    <span class="avatar avatar-sm bg-azure-lt text-azure"><i class="fas fa-link"></i></span>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                    <a class="dropdown-item" asp-controller="AdminPanel" asp-action="SystemHealth"><i class="fas fa-heart-pulse me-2"></i>Sistem Sağlığı</a>
                    <a class="dropdown-item" asp-controller="AdminPanel" asp-action="Hotels"><i class="fas fa-hotel me-2"></i>Oteller</a>
                    <a class="dropdown-item" asp-controller="AdminPanel" asp-action="Reservations"><i class="fas fa-calendar-check me-2"></i>Rezervasyonlar</a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="/yardim-merkezi" target="_blank" rel="noopener"><i class="fas fa-circle-question me-2"></i>Yardım Merkezi</a>
                </div>
            </div>

            <div class="nav-item dropdown">
                <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown" aria-label="Kullanıcı menüsü">
                    <span class="avatar avatar-sm bg-blue-lt text-blue">@initial</span>
                    <div class="d-none d-xl-block ps-2 text-start">
                        <div class="fw-bold small">@Model.FullName</div>
                        <div class="small text-muted text-truncate" style="max-width:12rem">@Model.Email</div>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                    <a class="dropdown-item" asp-controller="AdminPanel" asp-action="Settings"><i class="fas fa-user me-2"></i>Hesabım</a>
                    <a class="dropdown-item" asp-controller="AdminPanel" asp-action="Dashboard"><i class="fas fa-grid-2 me-2"></i>Panel</a>
                    <div class="dropdown-divider"></div>
                    <form method="post" action="/cikis-yap" class="px-2 mb-1">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger"><i class="fas fa-right-from-bracket me-2"></i>Güvenli Çıkış</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</header>
