@using otelturizmnew.Models.Paneller.Admin
@model AdminSystemHealthPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    ViewData["AdminShell"] = Model.Shell;
    ViewData["PageCssPath"] = "panel-admin-system-health";
    var warningCount = Model.Checks.Count(x => string.Equals(x.ToneClass, "warning", StringComparison.OrdinalIgnoreCase));
    var dangerCount = Model.Checks.Count(x => string.Equals(x.ToneClass, "danger", StringComparison.OrdinalIgnoreCase));
    var okRows = Model.LinkCheck.Rows.Count(x => x.IsOk);
    var badRows = Model.LinkCheck.Rows.Count(x => !x.IsOk);
}

<section class="system-health-page">
    <div class="page-header d-print-none mb-3">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">Operasyon Merkezi</div>
                <h2 class="page-title">Sistem Sağlığı</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <div class="btn-list">
                    <a class="btn btn-outline-primary" href="/admin/platform-checkup">
                        <i class="fas fa-list-check me-2"></i>Platform Checkup
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="system-health-hero">
        <div class="system-health-hero__copy">
            <span class="system-health-kicker">Operasyon Merkezi</span>
            <h2>Canlı sistem, link akışı ve kuyrukları tek ekrandan izleyin</h2>
            <p>Bu ekran link bütünlüğünü, sağlık kontrollerini ve e-posta servis davranışını tek bir operasyon panelinde toplar.</p>
        </div>
        <div class="system-health-hero__stats">
            <article class="system-health-stat is-primary">
                <span>Kontrol</span>
                <strong>@Model.Checks.Count</strong>
                <small>Toplam sağlık kontrolü</small>
            </article>
            <article class="system-health-stat is-danger">
                <span>Kritik</span>
                <strong>@dangerCount</strong>
                <small>Anında müdahale gereken</small>
            </article>
            <article class="system-health-stat is-warning">
                <span>İzleme</span>
                <strong>@warningCount</strong>
                <small>Takip isteyen uyarı</small>
            </article>
            <article class="system-health-stat is-success">
                <span>Linkler</span>
                <strong>@Model.LinkCheck.Total</strong>
                <small>Taranan route sayısı</small>
            </article>
        </div>
    </div>

    <div class="system-health-command-grid">
        <article class="system-health-radar">
            <div class="system-health-radar-ring" style="--ok:@okRows;--bad:@badRows;--total:@Math.Max(Model.LinkCheck.Total, 1);">
                <span>@(Model.Checks.Count - warningCount - dangerCount)</span>
                <small>sağlıklı kontrol</small>
            </div>
            <div>
                <p class="system-health-panel__eyebrow">Grafik özet</p>
                <h3>Platform sağlık dengesi</h3>
                <span>Sağlıklı, izleme ve kritik sinyaller tek indeks altında gösterilir.</span>
            </div>
        </article>
        <a class="system-health-route-card" href="/admin/email-kuyruk">
            <i class="fas fa-envelope-open-text"></i>
            <strong>E-posta kuyruğu</strong>
            <span>Bekleyen ve hatalı gönderimleri aç</span>
        </a>
        <a class="system-health-route-card" href="/admin/log-kayitlari">
            <i class="fas fa-file-lines"></i>
            <strong>Log kayıtları</strong>
            <span>Kritik sistem kayıtlarını incele</span>
        </a>
        <a class="system-health-route-card" href="/admin/rate-limit">
            <i class="fas fa-gauge-high"></i>
            <strong>Rate limit</strong>
            <span>Trafik ve sınır sinyallerini izle</span>
        </a>
    </div>

    <div class="system-health-grid">
        <section class="system-health-panel system-health-panel--platform">
            <div class="system-health-panel__head">
                <div>
                    <span class="system-health-panel__eyebrow">Health Checks API</span>
                    <h3>Platform prob’ları (ASP.NET)</h3>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.PlatformHealthAggregateStatus))
                {
                    <span class="system-health-pill @(Model.PlatformHealthAggregateStatus.Equals("Healthy", StringComparison.OrdinalIgnoreCase) ? "is-success" : "is-danger")">@Model.PlatformHealthAggregateStatus</span>
                }
            </div>
            <div class="system-health-checklist">
                @if (!string.IsNullOrWhiteSpace(Model.PlatformHealthError))
                {
                    <article class="system-health-check is-danger">
                        <div class="system-health-check__body">
                            <strong>Health raporu alınamadı</strong>
                            <p>@Model.PlatformHealthError</p>
                        </div>
                    </article>
                }
                else if (Model.PlatformHealthProbes.Count == 0)
                {
                    <p class="text-muted mb-0 small">Henüz kayıtlı prob yok.</p>
                }
                else
                {
                    <p class="text-muted small mb-2">Toplam süre: <strong>@Model.PlatformHealthTotalDurationMs.ToString("F1")</strong> ms · Uç: <code>/health/platform</code></p>
                    @foreach (var p in Model.PlatformHealthProbes)
                    {
                        var tone = p.Status.Equals("Healthy", StringComparison.OrdinalIgnoreCase) ? "is-success" : (p.Status.Equals("Degraded", StringComparison.OrdinalIgnoreCase) ? "is-warning" : "is-danger");
                        <article class="system-health-check @tone">
                            <div class="system-health-check__status">
                                <span class="system-health-pill @tone">@p.Status</span>
                            </div>
                            <div class="system-health-check__body">
                                <strong>@p.Name</strong>
                                <p class="mb-0">@((p.Detail ?? "-") + " · " + p.DurationMs.ToString("F1") + " ms")</p>
                            </div>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="system-health-panel">
            <div class="system-health-panel__head">
                <div>
                    <span class="system-health-panel__eyebrow">Sağlık Kontrolleri</span>
                    <h3>Canlı sağlık sinyalleri</h3>
                </div>
            </div>
            <div class="system-health-checklist">
                @foreach (var item in Model.Checks)
                {
                    var toneClass = item.ToneClass switch
                    {
                        "success" => "is-success",
                        "warning" => "is-warning",
                        "danger" => "is-danger",
                        _ => "is-info"
                    };
                    <article class="system-health-check @toneClass">
                        <div class="system-health-check__status">
                            <span class="system-health-pill @toneClass">@item.StatusText</span>
                        </div>
                        <div class="system-health-check__body">
                            <strong>@item.Title</strong>
                            <p>@item.Detail</p>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="system-health-panel system-health-panel--link-audit">
            <div class="system-health-panel__head system-health-panel__head--split">
                <div>
                    <span class="system-health-panel__eyebrow">Link Kontrol</span>
                    <h3>Broken link ve route doğrulama</h3>
                </div>
                <form method="post" action="/admin/sistem-sagligi/link-kontrol" class="system-health-inline-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="system-health-cta">
                        <i class="fas fa-satellite-dish"></i>
                        Linkleri yeniden tara
                    </button>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.LinkCheck.Warning))
            {
                <div class="system-health-alert">
                    <i class="fas fa-triangle-exclamation"></i>
                    <span>@Model.LinkCheck.Warning</span>
                </div>
            }

            <div class="system-health-metrics">
                <article class="system-health-metric-card">
                    <span>Base URL</span>
                    <strong>@Model.LinkCheck.BaseUrl</strong>
                    <small>Tarama hedefi</small>
                </article>
                <article class="system-health-metric-card">
                    <span>Son kontrol</span>
                    <strong>@(Model.LinkCheck.CheckedAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "-")</strong>
                    <small>En son tarama zamanı</small>
                </article>
                <article class="system-health-metric-card is-success">
                    <span>Sağlam</span>
                    <strong>@okRows</strong>
                    <small>200/başarılı yanıt</small>
                </article>
                <article class="system-health-metric-card is-danger">
                    <span>Sorunlu</span>
                    <strong>@badRows</strong>
                    <small>Düzeltme gereken route</small>
                </article>
            </div>

            @if (Model.LinkCheck.Rows.Count > 0)
            {
                <div class="system-health-table-wrap">
                    <table class="table table-vcenter table-hover system-health-table">
                        <thead>
                            <tr>
                                <th>Route</th>
                                <th>Durum</th>
                                <th>Süre</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.LinkCheck.Rows.Take(200))
                            {
                                var rowToneClass = row.IsOk ? "is-success" : "is-danger";
                                <tr>
                                    <td>
                                        <code>@row.Route</code>
                                    </td>
                                    <td>
                                        <span class="system-health-pill @rowToneClass">@row.StatusText</span>
                                    </td>
                                    <td>@row.Ms ms</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>

    <div class="system-health-secondary-grid">
        <section class="system-health-panel">
            <div class="system-health-panel__head system-health-panel__head--split">
                <div>
                    <span class="system-health-panel__eyebrow">E-posta Servisi</span>
                    <h3>Gönderim modunu yönetin</h3>
                </div>
                <div class="system-health-actions">
                    <form method="post" action="/admin/sistem-sagligi/email-test-modu" class="system-health-inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="enabled" value="true" />
                        <input type="text" name="reason" class="form-control form-control-sm" style="width:200px;display:inline-block;margin-right:8px;" placeholder="Gerekçe" required minlength="5" maxlength="240" />
                        <button type="submit" class="system-health-chip-btn is-warning">
                            <i class="fas fa-vial"></i>
                            Test modu
                        </button>
                    </form>
                    <form method="post" action="/admin/sistem-sagligi/email-test-modu" class="system-health-inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="enabled" value="false" />
                        <input type="text" name="reason" class="form-control form-control-sm" style="width:200px;display:inline-block;margin-right:8px;" placeholder="Gerekçe" required minlength="5" maxlength="240" />
                        <button type="submit" class="system-health-chip-btn is-success">
                            <i class="fas fa-paper-plane"></i>
                            Gerçek gönderim
                        </button>
                    </form>
                </div>
            </div>
            <div class="system-health-note">
                Bu kontrol, <code>EPOSTA_SERVISLERI</code> tablosundaki aktif kaydın <code>TEST_MODU</code> alanını değiştirir. Development ortamında test modunda bile e-postalar pickup klasörüne kaydedilebilir.
            </div>
        </section>

        <section class="system-health-panel">
            <div class="system-health-panel__head system-health-panel__head--split">
                <div>
                    <span class="system-health-panel__eyebrow">Operasyon</span>
                    <h3>Cache / Sitemap</h3>
                </div>
                <div class="system-health-actions">
                    <form method="post" action="/admin/cache/evict-public" class="system-health-inline-form">
                        @Html.AntiForgeryToken()
                        <input type="text" name="reason" class="form-control form-control-sm" style="width:220px;display:inline-block;margin-right:8px;" placeholder="Cache temizleme gerekçesi" required minlength="5" maxlength="240" />
                        <button type="submit" class="system-health-chip-btn is-danger">
                            <i class="fas fa-broom"></i>
                            Public cache temizle
                        </button>
                    </form>
                    <form method="post" action="/admin/sitemap/refresh" class="system-health-inline-form">
                        @Html.AntiForgeryToken()
                        <input type="text" name="reason" class="form-control form-control-sm" style="width:220px;display:inline-block;margin-right:8px;" placeholder="Sitemap gerekçesi" required minlength="5" maxlength="240" />
                        <button type="submit" class="system-health-chip-btn is-info">
                            <i class="fas fa-rotate"></i>
                            Sitemap refresh
                        </button>
                    </form>
                </div>
            </div>
            <div class="system-health-note">
                Bu işlemler kritik operasyon aksiyonlarıdır; zorunlu gerekçe ile <code>admin_islem_loglari</code> içine yazılır.
            </div>
        </section>

        <section class="system-health-panel">
            <div class="system-health-panel__head">
                <div>
                    <span class="system-health-panel__eyebrow">Kuyruklar</span>
                    <h3>İşlem kuyruklarının durumu</h3>
                </div>
            </div>
            <div class="system-health-table-wrap">
                <table class="table table-vcenter table-hover system-health-table">
                    <thead>
                        <tr>
                            <th>Kuyruk</th>
                            <th>Beklemede</th>
                            <th>Başarısız</th>
                            <th>En eski</th>
                            <th>Not</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var q in Model.Queues)
                    {
                        <tr>
                            <td><strong>@q.QueueName</strong></td>
                            <td>@q.PendingCount</td>
                            <td>@q.FailedCount</td>
                            <td>@q.OldestPendingText</td>
                            <td class="text-muted">@q.Note</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</section>
