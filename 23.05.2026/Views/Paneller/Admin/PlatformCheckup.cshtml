@model otelturizmnew.Models.Paneller.Admin.AdminPlatformCheckupPageViewModel
@{
    Layout = "~/Views/Paneller/Admin/_AdminPanelLayout.cshtml";
    var generatedAt = DateTime.Now.ToString("dd.MM.yyyy HH:mm");
}

<section class="admin-page-heading platform-checkup-hero">
    <div>
        <span class="admin-eyebrow">PLATFORM OPERASYON</span>
        <h1>Eksiksiz Checkup ve Gelişim Takibi</h1>
        <p>Yetki, onay, satış, otel, oda, fiyat, görsel, e-posta, log ve kurulum katmanları canlı şema üzerinden kontrol ediliyor.</p>
    </div>
    <div class="platform-checkup-hero__meta">
        <span>Son kontrol</span>
        <strong>@generatedAt</strong>
    </div>
</section>

<section class="admin-kpi-grid platform-checkup-kpis">
    @foreach (var card in Model.SummaryCards)
    {
        <article class="admin-kpi-card tone-@card.ToneClass">
            <span class="admin-kpi-icon"><i class="@card.IconClass"></i></span>
            <div>
                <strong>@card.Value</strong>
                <span>@card.Label</span>
                <small>@card.Description</small>
            </div>
        </article>
    }
</section>

<section class="platform-checkup-grid">
    @foreach (var group in Model.Groups)
    {
        var missing = group.Items.Count(x => x.ToneClass != "success");
        <article class="platform-checkup-card tone-@group.ToneClass">
            <header>
                <div>
                    <span class="platform-checkup-card__tag">@group.Title</span>
                    <p>@group.Description</p>
                </div>
                <strong class="platform-checkup-card__score">@missing eksik</strong>
            </header>
            <div class="platform-checkup-list">
                @foreach (var item in group.Items)
                {
                    <a class="platform-checkup-row status-@item.ToneClass" href="@item.ActionUrl">
                        <span class="platform-checkup-row__status">@item.StatusText</span>
                        <span>
                            <strong>@item.Label</strong>
                            <small>@item.Detail</small>
                        </span>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </article>
    }
</section>

<section class="platform-roadmap">
    <header>
        <span class="admin-eyebrow">OTOMATIK TAMAMLAMA PLANI</span>
        <h2>Sıralı Geliştirme Fazları</h2>
    </header>
    <div class="platform-roadmap__list">
        @foreach (var item in Model.Roadmap)
        {
            <article class="platform-roadmap__item">
                <span>@item.Phase</span>
                <div>
                    <strong>@item.Scope</strong>
                    <em>@item.Status</em>
                    <p>@item.Detail</p>
                </div>
            </article>
        }
    </div>
</section>
