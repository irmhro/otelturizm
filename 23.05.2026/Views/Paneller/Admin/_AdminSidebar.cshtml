@using otelturizmnew.Models.Paneller.Admin
@model AdminShellViewModel
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    bool IsActive(string action) => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    string Active(string action) => IsActive(action) ? "active" : string.Empty;
    string Badge(int value) => value > 0 ? value.ToString() : "0";
    bool IsOpen(params string[] actions) => actions.Any(IsActive);
    bool Can(string code) => Model.Permissions.Contains("*") || Model.HasPermission(code);

    var hotelOpen = IsOpen("Hotels", "HotelDetail", "ActiveHotels", "PendingHotels", "Campaigns", "Reviews");
    var commerceOpen = IsOpen("Reservations", "UnifiedReservations", "CompanyReservations", "ListingSubscriptions", "Payments", "Invoices", "Commissions", "Contracts", "Reports", "CommerceInsight");
    var userOpen = IsOpen("Users", "Managers", "PlatformOfficials", "ApprovalCenter", "PartnerApplications", "CompanyApplications", "DevelopmentRequests");
    var contentOpen = IsOpen("Notifications", "MailCenter", "EmailQueue", "EmailRouting", "EmailTemplates", "WhatsAppCloudApi", "Blog", "Faq", "SupportArticles", "HelpCenter", "Team");
    var systemOpen = IsOpen("PlatformCheckup", "Settings", "SettingsMonitor", "Sitemap", "Security", "SecurityEvents", "UploadHistory", "Complaints", "Backups", "Logs", "GeoSearchLogs", "HotelCoordinateChanges", "AdminActionLogs", "RateLimitStats");
}
<aside class="navbar navbar-vertical navbar-expand-lg partner-sidebar admin-sidebar-alias" data-bs-theme="dark" aria-label="Admin menüsü">
    <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminSidebarMenu" aria-controls="adminSidebarMenu" aria-expanded="false" aria-label="Menüyü aç">
            <span class="navbar-toggler-icon"></span>
        </button>

        <h1 class="navbar-brand navbar-brand-autodark">
            <a asp-controller="AdminPanel" asp-action="Dashboard" class="partner-brand-link">
                <img src="~/uploads/logo/logo.png" alt="Otelturizm" class="partner-brand-logo" />
                <span class="badge bg-primary-lt text-primary ms-1 align-middle" style="font-size:0.65rem">ADMIN</span>
            </a>
        </h1>

        <div class="collapse navbar-collapse" id="adminSidebarMenu">
            <div class="d-lg-none px-2 pb-2 mb-2 border-bottom border-light border-opacity-10">
                <div class="d-flex align-items-center gap-2 text-white">
                    <span class="avatar bg-primary-lt text-primary"><i class="fas fa-user-shield"></i></span>
                    <div class="small">
                        <div class="fw-bold">@Model.FullName</div>
                        <div class="text-secondary">@Model.Email</div>
                    </div>
                </div>
            </div>

            <div class="d-none d-lg-block partner-hotel-line">
                <span>Yetkili</span>
                <strong>@Model.FullName</strong>
                <small>@Model.Email</small>
            </div>

            <div class="partner-sidebar-scroll">
                <ul class="navbar-nav partner-sidebar-nav">
                    <li class="nav-item">
                        <a class="nav-link @(Active("Dashboard")) @(Can("admin.dashboard") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Dashboard">
                            <span class="nav-link-icon"><i class="fas fa-table-columns"></i></span>
                            <span class="nav-link-title">Panel Özeti</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("SystemHealth")) @(Can("admin.system_health") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="SystemHealth">
                            <span class="nav-link-icon"><i class="fas fa-heart-pulse"></i></span>
                            <span class="nav-link-title">Sistem Sağlığı</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("PlatformCheckup")) @(Can("admin.platform_checkup") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="PlatformCheckup">
                            <span class="nav-link-icon"><i class="fas fa-list-check"></i></span>
                            <span class="nav-link-title">Platform Checkup</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Active("ApprovalCenter")) @(Can("admin.approval_center") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="ApprovalCenter">
                            <span class="nav-link-icon"><i class="fas fa-clipboard-check"></i></span>
                            <span class="nav-link-title">Onay Merkezi</span>
                        </a>
                    </li>

                    <li class="nav-item text-uppercase text-secondary px-3 pt-2 pb-1 small fw-bold" style="font-size:0.68rem; letter-spacing:0.12em;">Yönetim</li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(hotelOpen ? "" : "collapsed")" type="button" data-admin-nav-target="#adminNavHotels" aria-expanded="@(hotelOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-hotel"></i></span>
                            <span class="nav-link-title">Konaklama</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(hotelOpen ? "show" : "")" id="adminNavHotels">
                            <div class="partner-subnav">
                                <a class="@Active("Hotels") @(Can("admin.hotels") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Hotels">Oteller</a>
                                <a class="@Active("ActiveHotels") @(Can("admin.hotels") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="ActiveHotels">Açık Oteller</a>
                                <a class="@Active("PendingHotels") @(Can("admin.hotels") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="PendingHotels">Bekleyen Oteller</a>
                                <a class="@Active("Campaigns") @(Can("admin.hotels") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Campaigns">Kampanyalar</a>
                                <a class="@Active("Reviews") @(Can("admin.reviews") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Reviews">Değerlendirmeler <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingReviews)</span></a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(commerceOpen ? "" : "collapsed")" type="button" data-admin-nav-target="#adminNavCommerce" aria-expanded="@(commerceOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-wallet"></i></span>
                            <span class="nav-link-title">Ticari Operasyon</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(commerceOpen ? "show" : "")" id="adminNavCommerce">
                            <div class="partner-subnav">
                                <a class="@Active("Reservations") @(Can("admin.reservations") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Reservations">Rezervasyonlar</a>
                                <a class="@Active("UnifiedReservations") @(Can("admin.unified_reservations") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="UnifiedReservations">Rezervasyonlar (Tek Liste)</a>
                                <a class="@Active("CompanyReservations") @(Can("admin.company_reservations") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="CompanyReservations">Firma Rezervasyonları</a>
                                <a class="@Active("ListingSubscriptions") @(Can("admin.listing_subscriptions") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="ListingSubscriptions">Otel Liste Abonelikleri</a>
                                <a class="@Active("PlatformPackages") @(Can("admin.platform_packages") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="PlatformPackages">Platform Paket Satışı</a>
                                <a class="@Active("Payments") @(Can("admin.payments") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Payments">Ödemeler</a>
                                <a class="@Active("Invoices") @(Can("admin.invoices") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Invoices">Faturalar</a>
                                <a class="@Active("Commissions") @(Can("admin.commissions") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Commissions">Oteller Komisyon Oranları</a>
                                <a class="@Active("Contracts") @(Can("admin.contracts") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Contracts">Sözleşmeler</a>
                                <a class="@Active("Reports") @(Can("admin.reports") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Reports">Gelir / Komisyon Raporu</a>
                                <a class="@Active("CommerceInsight") @(Can("admin.commerce_insight") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="CommerceInsight">Ticari içgörü</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(userOpen ? "" : "collapsed")" type="button" data-admin-nav-target="#adminNavUsers" aria-expanded="@(userOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-users"></i></span>
                            <span class="nav-link-title">Kullanıcı ve Yetki</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(userOpen ? "show" : "")" id="adminNavUsers">
                            <div class="partner-subnav">
                                <a class="@Active("Users") @(Can("admin.users") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Users">Kullanıcılar</a>
                                <a class="@Active("Managers") @(Can("admin.managers") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Managers">Yöneticiler</a>
                                <a class="@Active("PlatformOfficials") @(Can("admin.platform_officials") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="PlatformOfficials">Platform Yetkilileri</a>
                                <a class="@Active("ApprovalCenter") @(Can("admin.approval_center") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="ApprovalCenter">Onay Merkezi</a>
                                <a class="@Active("DevelopmentRequests") @(Can("admin.development_requests") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="DevelopmentRequests">Geliştirme Talepleri</a>
                                <a class="@Active("PartnerApplications") @(Can("admin.partner_applications") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="PartnerApplications">Partner Başvuruları <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingPartnerApplications)</span></a>
                                <a class="@Active("CompanyApplications") @(Can("admin.company_applications") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="CompanyApplications">Firma Başvuruları <span class="badge bg-danger-lt text-danger ms-1">@Badge(Model.PendingCompanyApplications)</span></a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item text-uppercase text-secondary px-3 pt-3 pb-1 small fw-bold" style="font-size:0.68rem; letter-spacing:0.12em;">İçerik ve Sistem</li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(contentOpen ? "" : "collapsed")" type="button" data-admin-nav-target="#adminNavContent" aria-expanded="@(contentOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-bullhorn"></i></span>
                            <span class="nav-link-title">İletişim ve İçerik</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(contentOpen ? "show" : "")" id="adminNavContent">
                            <div class="partner-subnav">
                                <a class="@Active("Notifications") @(Can("admin.notifications") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Notifications">Bildirimler <span class="badge bg-azure-lt text-azure ms-1">@Badge(Model.UnreadNotifications)</span></a>
                                <a class="@Active("MailCenter") @(Can("admin.mail_center") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="MailCenter">Mail Merkezi</a>
                                <a class="@Active("EmailQueue") @(Can("admin.email_queue") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="EmailQueue">E-posta Kuyruğu</a>
                                <a class="@Active("EmailRouting") @(Can("admin.email_routing") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="EmailRouting">E-posta Yönlendirmeleri</a>
                                <a class="@Active("EmailTemplates") @(Can("admin.email_templates") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="EmailTemplates">E-posta Hesapları</a>
                                <a class="@Active("WhatsAppCloudApi") @(Can("admin.whatsapp") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="WhatsAppCloudApi">WhatsApp Cloud API</a>
                                <a class="@Active("Blog") @(Can("admin.blog") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Blog">Blog Yönetimi</a>
                                <a class="@Active("Faq") @(Can("admin.faq") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Faq">SSS Yönetimi</a>
                                <a class="@Active("SupportArticles") @(Can("admin.support_articles") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="SupportArticles">Destek Makaleleri</a>
                                <a class="@Active("HelpCenter") @(Can("admin.support_articles") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="HelpCenter">Yardım Merkezi Yönetim</a>
                                <a class="@Active("Team") @(Can("admin.notifications") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Team">Platform Ekibi</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item partner-nav-group">
                        <button class="nav-link partner-nav-toggle @(systemOpen ? "" : "collapsed")" type="button" data-admin-nav-target="#adminNavSystem" aria-expanded="@(systemOpen ? "true" : "false")">
                            <span class="nav-link-icon"><i class="fas fa-shield-halved"></i></span>
                            <span class="nav-link-title">Sistem ve Güvenlik</span>
                            <i class="fas fa-chevron-right partner-nav-chevron"></i>
                        </button>
                        <div class="collapse @(systemOpen ? "show" : "")" id="adminNavSystem">
                            <div class="partner-subnav">
                                <a class="@Active("Settings") @(Can("admin.settings") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Settings">Ayarlar</a>
                                <a class="@Active("SettingsMonitor") @(Can("admin.settings_monitor") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="SettingsMonitor">Ayar Monitörü</a>
                                <a class="@Active("Sitemap") @(Can("admin.sitemap") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Sitemap">Sitemap XML</a>
                                <a class="@Active("Security") @(Can("admin.security") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Security">Güvenlik</a>
                                <a class="@Active("SecurityEvents") @(Can("admin.security_events") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="SecurityEvents">Güvenlik Olayları</a>
                                <a class="@Active("UploadHistory") @(Can("admin.upload_history") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="UploadHistory">Upload Geçmişi</a>
                                <a class="@Active("Complaints") @(Can("admin.complaints") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Complaints">Şikayetler</a>
                                <a class="@Active("Backups") @(Can("admin.backups") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Backups">Yedekleme</a>
                                <a class="@Active("Logs") @(Can("admin.logs") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="Logs">Log Kayıtları <span class="badge bg-warning-lt text-warning ms-1">@Badge(Model.CriticalLogs)</span></a>
                                <a class="@Active("AdminActionLogs") @(Can("admin.admin_action_logs") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="AdminActionLogs">İşlem Logları</a>
                                <a class="@Active("GeoSearchLogs") @(Can("admin.geo_search_logs") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="GeoSearchLogs">Konum Arama Logları</a>
                                <a class="@Active("HotelCoordinateChanges") @(Can("admin.hotel_coord_changes") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="HotelCoordinateChanges">Otel Koordinat Değişimleri</a>
                                <a class="@Active("RateLimitStats") @(Can("admin.rate_limit") ? "" : "d-none")" asp-controller="AdminPanel" asp-action="RateLimitStats">Rate Limit</a>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="partner-sidebar-footer">
                <div class="partner-footer-actions">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Site
                    </a>
                    <form method="post" action="/cikis-yap" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fas fa-right-from-bracket me-1"></i>Çıkış
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</aside>
