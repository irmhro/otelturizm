@using System.Globalization
@model otelturizmnew.Models.Paneller.Partner.PartnerPricingPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    var maxPricingDate = DateTime.Today.AddDays(365).ToString("yyyy-MM-dd");
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Fiyat & Stok</div>
            <h2 class="page-title">Oda kontenjanları ve satış durumu</h2>
            <div class="text-muted mt-1">Tarih aralığı seçin, oda tiplerini işaretleyin ve tek seferde satışa aç/kapat veya kontenjan güncelleyin.</div>
        </div>
        <div class="col-auto ms-auto">
            <a class="btn btn-outline-primary" href="/panel/partner/takvim-fiyatlar?otelId=@Model.SelectedHotelId&roomId=@Model.SelectedRoomId&month=@Model.MonthKey">
                <i class="fas fa-calendar-days me-2"></i>Takvim & Fiyatlar
            </a>
        </div>
    </div>
</div>

<div class="row row-cards mt-2">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3 class="card-title mb-0">Toplu kontenjan güncelleme</h3>
                    <div class="text-muted small">Sadece kontenjan ve satış durumu alanları güncellenir.</div>
                </div>
            </div>
            <div class="card-body">
                <form method="post" action="/panel/partner/fiyat/stok-kontenjan/uygula">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                    <input type="hidden" name="ViewRoomId" value="@Model.SelectedRoomId" />
                    <input type="hidden" name="ViewMonth" value="@Model.MonthKey" />

                    <div class="mb-3">
                        <div class="form-label">Güncelleme uygulanacak odalar</div>
                        <div class="row g-2">
                            @foreach (var room in Model.Rooms.Where(x => x.IsActive))
                            {
                                var isChecked = Model.BulkForm.SelectedRoomIds.Contains(room.RoomId);
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-check stock-room-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoomIds" value="@room.RoomId" checked="@(isChecked ? "checked" : null)" />
                                        <span class="form-check-label">
                                            <span class="fw-bold">@room.RoomName</span>
                                            <span class="text-muted d-block small">@room.StockText</span>
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih başlangıcı</label>
                            <input class="form-control" type="date" name="DateFrom" value="@Model.BulkForm.DateFrom.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Tarih bitişi</label>
                            <input class="form-control" type="date" name="DateTo" value="@Model.BulkForm.DateTo.ToString("yyyy-MM-dd")" max="@maxPricingDate" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Satışa açık oda</label>
                            <input class="form-control" type="number" name="TotalRooms" min="0" value="@(Model.BulkForm.TotalRooms?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" placeholder="Stok korunacak" />
                            <div class="form-hint">Boş bırakırsanız mevcut stok korunur.</div>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label class="form-label">Satış durumu</label>
                            <select class="form-select" name="SaleStatusAction">
                                <option value="keep" selected>Mevcut durum korunsun</option>
                                <option value="open">Satışa aç</option>
                                <option value="close">Satışa kapat</option>
                            </select>
                        </div>
                        <div class="col-12 d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-floppy-disk me-2"></i>Uygula
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3 class="card-title mb-0">Oda tipleri (özet)</h3>
                    <div class="text-muted small">Stok metni oda tipinin varsayılan kapasitesini gösterir; gün bazlı stok takvimi “Takvim & Fiyatlar” ekranındadır.</div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter table-hover">
                    <thead>
                    <tr>
                        <th>Oda</th>
                        <th>Durum</th>
                        <th>Varsayılan stok</th>
                        <th class="text-end">Aksiyon</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var room in Model.Rooms)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@room.RoomName</div>
                                <div class="text-muted small">@room.BasePriceText</div>
                            </td>
                            <td>
                                <span class="badge @(room.IsActive ? "bg-green-lt text-green" : "bg-secondary-lt text-secondary")">@(room.IsActive ? "Aktif" : "Pasif")</span>
                            </td>
                            <td>@room.StockText</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm" href="/panel/partner/fiyat/stok-kontenjan?otelId=@Model.SelectedHotelId&roomId=@room.RoomId&month=@Model.MonthKey">
                                    Seç
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

