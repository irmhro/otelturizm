@model otelturizmnew.Models.Paneller.Partner.PartnerReservationCalendarPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/reservations";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Rezervasyon yönetimi</div>
            <h2 class="page-title">Rezervasyon Takvimi</h2>
            <div class="text-muted mt-1">@Model.RangeLabel aralığında giriş/çıkış ve doluluk özetini izleyin.</div>
        </div>
    </div>
</div>

<form method="get" class="card mb-3">
    <div class="card-body">
        <input type="hidden" name="otelId" value="@Model.SelectedHotelId" />
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label">Başlangıç</label>
                <input class="form-control" type="date" name="dateFrom" value="@Model.DateFrom" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Bitiş</label>
                <input class="form-control" type="date" name="dateTo" value="@Model.DateTo" />
            </div>
            <div class="col-12 col-md-4 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">
                    <i class="fas fa-filter me-2"></i>Filtrele
                </button>
                <a class="btn btn-outline-primary" href="/panel/partner/rezervasyonlar/takvim?otelId=@Model.SelectedHotelId">
                    Sıfırla
                </a>
            </div>
        </div>
    </div>
</form>

<div class="row row-cards">
    <div class="col-12 col-xl-7">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Gün bazlı özet</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Giriş</th>
                            <th>Çıkış</th>
                            <th>Konaklayan</th>
                            <th>İptal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Days)
                        {
                            <tr>
                                <td class="fw-bold">@d.DayLabel <span class="text-muted">(@d.WeekdayLabel)</span></td>
                                <td>@d.CheckinCount</td>
                                <td>@d.CheckoutCount</td>
                                <td>@d.InhouseCount</td>
                                <td>@d.CancelledCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title mb-0">Yaklaşan check-in</h3>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.UpcomingCheckins.Count == 0)
                {
                    <div class="p-3 text-muted">Bu aralıkta check-in yok.</div>
                }
                else
                {
                    @foreach (var r in Model.UpcomingCheckins)
                    {
                        <a class="list-group-item list-group-item-action" href="/panel/partner/rezervasyonlar?otelId=@Model.SelectedHotelId">
                            <div class="d-flex justify-content-between gap-2">
                                <div class="min-w-0">
                                    <div class="fw-bold text-truncate">@r.GuestName</div>
                                    <div class="text-muted small text-truncate">@r.StayText • @r.RoomName</div>
                                </div>
                                <span class="badge bg-azure-lt text-azure">@r.ReservationNo</span>
                            </div>
                        </a>
                    }
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Yaklaşan check-out</h3>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.UpcomingCheckouts.Count == 0)
                {
                    <div class="p-3 text-muted">Bu aralıkta check-out yok.</div>
                }
                else
                {
                    @foreach (var r in Model.UpcomingCheckouts)
                    {
                        <a class="list-group-item list-group-item-action" href="/panel/partner/rezervasyonlar?otelId=@Model.SelectedHotelId">
                            <div class="d-flex justify-content-between gap-2">
                                <div class="min-w-0">
                                    <div class="fw-bold text-truncate">@r.GuestName</div>
                                    <div class="text-muted small text-truncate">@r.StayText • @r.RoomName</div>
                                </div>
                                <span class="badge bg-indigo-lt text-indigo">@r.ReservationNo</span>
                            </div>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</div>

