@model otelturizmnew.Models.Paneller.Partner.PartnerPreferencesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var q = Model.Shell.SelectedHotelId is long hid ? $"?otelId={hid}" : string.Empty;
}

<section class="partner-growth-hero">
    <div>
        <p class="partner-room-kicker">Panel</p>
        <h2>Tercihler</h2>
        <p>Panel kullanım tercihleri <code>partner_panel_tercihleri</code> tablosuna kaydedilir. Tema ayarları ayrı olarak <code>tema_panel</code> tablosuna yazılır.</p>
    </div>
</section>

@if (TempData["PartnerError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="partner-alert is-danger mb-3">@err</div>
}
@if (TempData["PartnerSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="partner-alert is-success mb-3">@ok</div>
}

<section class="partner-settings-grid">
    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Panel tercihleri</h2>
                <p>Para birimi, zaman dilimi, takvim görünümü ve bildirim kanallarını yönetin.</p>
            </div>
        </div>

        <form method="post" action="/panel/partner/tercihler/kaydet" class="partner-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.Form.HotelId" />
            <input type="hidden" name="DefaultHotelId" value="@(Model.Form.DefaultHotelId ?? Model.Form.HotelId)" />

            <label>
                <span>Para birimi</span>
                <select name="Currency">
                    <option value="TRY" selected="@(Model.Form.Currency == "TRY")">TRY</option>
                    <option value="USD" selected="@(Model.Form.Currency == "USD")">USD</option>
                    <option value="EUR" selected="@(Model.Form.Currency == "EUR")">EUR</option>
                </select>
            </label>
            <label>
                <span>Zaman dilimi</span>
                <input type="text" name="Timezone" value="@Model.Form.Timezone" placeholder="Europe/Istanbul" />
            </label>
            <label class="partner-form-span">
                <span>Takvim görünümü</span>
                <select name="CalendarView">
                    <option value="Aylik" selected="@(Model.Form.CalendarView == "Aylik")">Aylık</option>
                    <option value="Haftalik" selected="@(Model.Form.CalendarView == "Haftalik")">Haftalık</option>
                </select>
            </label>

            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="EmailNotifications" value="true" checked="@(Model.Form.EmailNotifications)" />
                <span>E‑posta bildirimleri</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="SmsNotifications" value="true" checked="@(Model.Form.SmsNotifications)" />
                <span>SMS bildirimleri</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="PushNotifications" value="true" checked="@(Model.Form.PushNotifications)" />
                <span>Push bildirimleri</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="DesktopNotifications" value="true" checked="@(Model.Form.DesktopNotifications)" />
                <span>Masaüstü bildirimleri</span>
            </label>

            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="NewReservationNotifications" value="true" checked="@(Model.Form.NewReservationNotifications)" />
                <span>Yeni rezervasyon</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="CancellationNotifications" value="true" checked="@(Model.Form.CancellationNotifications)" />
                <span>İptal / no-show</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="PaymentNotifications" value="true" checked="@(Model.Form.PaymentNotifications)" />
                <span>Ödeme</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="ReviewNotifications" value="true" checked="@(Model.Form.ReviewNotifications)" />
                <span>Yorum</span>
            </label>

            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="AutoPriceSuggestions" value="true" checked="@(Model.Form.AutoPriceSuggestions)" />
                <span>Otomatik fiyat önerileri</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="AutoCloseoutWarnings" value="true" checked="@(Model.Form.AutoCloseoutWarnings)" />
                <span>Closeout uyarıları</span>
            </label>
            <label class="partner-inline-toggle partner-form-span">
                <input type="checkbox" name="RememberDevice" value="true" checked="@(Model.Form.RememberDevice)" />
                <span>Cihazı hatırla</span>
            </label>

            <button type="submit" class="partner-primary-btn partner-form-span">
                <i class="fas fa-floppy-disk me-2"></i>Tercihleri kaydet
            </button>
        </form>
    </article>

    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Görünüm</h2>
                <p>Açık / koyu mod ve ana renk seçimi üst menüdeki tema çekmecesinden yapılır; kayıt sonrası bu sayfaya dönebilirsiniz.</p>
            </div>
        </div>
        <button type="button" class="partner-primary-btn" data-bs-toggle="offcanvas" data-bs-target="#partnerThemeSettings">
            <i class="fas fa-palette me-2"></i>Tema ayarlarını aç
        </button>
    </article>

    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Hesap ve başvuru</h2>
                <p>Veri tabanı kaynaklı formlar.</p>
            </div>
        </div>
        <ul class="partner-settings-links">
            <li><a href="/panel/partner/basvuru-ve-evraklar@q"><i class="fas fa-file-contract text-muted me-2"></i>Başvuru ve evraklar</a><span class="partner-muted small d-block ms-4">partner_detaylari, partner evrak tabloları</span></li>
            <li><a href="/panel/partner/hesap-bilgileri@q"><i class="fas fa-id-card text-muted me-2"></i>Hesap bilgileri</a><span class="partner-muted small d-block ms-4">KULLANICILAR + PARTNER_DETAYLARI özeti</span></li>
        </ul>
    </article>

    <article class="partner-section-card">
        <div class="partner-section-head">
            <div>
                <h2>Güvenlik ve bildirim</h2>
            </div>
        </div>
        <ul class="partner-settings-links">
            <li><a href="/panel/partner/guvenlik@q"><i class="fas fa-shield-halved text-muted me-2"></i>Güvenlik (2FA)</a></li>
            <li><a href="/panel/partner/guvenlik/tesis-kullanicilari@q"><i class="fas fa-users text-muted me-2"></i>Tesis kullanıcıları</a></li>
            <li><a href="/panel/partner/bildirim-tercihleri@q"><i class="fas fa-bell text-muted me-2"></i>Bildirim tercihleri</a></li>
            <li><a href="/panel/partner/724-destek@q"><i class="fas fa-headset text-muted me-2"></i>7/24 Destek</a></li>
        </ul>
    </article>
</section>
