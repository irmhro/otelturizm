@model otelturizmnew.Models.Paneller.Partner.PartnerAccountInfoPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    var q = Model.Shell.SelectedHotelId is long hid ? $"?otelId={hid}" : string.Empty;
}

<div class="row row-cards">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-3">
                    <div>
                        <div class="text-muted small fw-bold text-uppercase ls-wide">Profil</div>
                        <h2 class="mb-1">Hesap bilgileri</h2>
                        <div class="text-muted">Kurumsal bilgileriniz ve hesap doğrulama özetiniz.</div>
                    </div>
                    <a href="/panel/partner/basvuru-ve-evraklar@q" class="btn btn-outline-primary">
                        <i class="fas fa-file-shield me-2"></i>Başvuru ve evraklar
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Doğrulanmış özet</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter">
                    <tbody>
                    <tr><td class="text-muted">Ad soyad</td><td class="fw-bold">@Model.UserSection.FullName</td></tr>
                    <tr><td class="text-muted">E-posta</td><td>@Model.UserSection.Email</td></tr>
                    <tr><td class="text-muted">Telefon</td><td>@(string.IsNullOrWhiteSpace(Model.UserSection.Phone) ? "—" : Model.UserSection.Phone)</td></tr>
                    <tr><td class="text-muted">Hesap durumu</td><td><span class="badge bg-blue-lt">@Model.UserSection.AccountStatusText</span></td></tr>
                    <tr><td class="text-muted">E-posta doğrulama</td><td>@Model.UserSection.EmailVerificationText</td></tr>
                    <tr><td class="text-muted">Telefon doğrulama</td><td>@Model.UserSection.PhoneVerificationText</td></tr>
                    <tr><td class="text-muted">KVKK</td><td>@Model.UserSection.KvkkText</td></tr>
                    <tr><td class="text-muted">Pazarlama izni</td><td>@Model.UserSection.MarketingConsentText</td></tr>
                    <tr><td class="text-muted">Kayıt</td><td>@Model.UserSection.RegistrationText</td></tr>
                    <tr><td class="text-muted">Son giriş</td><td>@Model.UserSection.LastLoginText</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3 class="card-title mb-0">Kurumsal bilgiler</h3>
                    <div class="text-muted small">Bu alanlar faturalaşma ve ödeme süreçlerinde kullanılır.</div>
                </div>
                @if (Model.PartnerSection is not null)
                {
                    <span class="badge @(Model.PartnerSection.PartnerActive ? "bg-green-lt" : "bg-secondary-lt")">@(Model.PartnerSection.PartnerActive ? "Aktif kayıt" : "Pasif")</span>
                }
            </div>
            <div class="card-body">
                @if (Model.PartnerSection is null)
                {
                    <div class="alert alert-warning">
                        Partner kurumsal kaydı bulunamadı. Başvuru sürecini tamamladıktan sonra bu form aktif olacaktır.
                    </div>
                }

                <form method="post" action="/panel/partner/hesap-bilgileri/kaydet" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="HotelId" value="@(Model.UpdateForm.HotelId?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />

                    <div class="col-12 col-md-6">
                        <label class="form-label">Firma ünvanı</label>
                        <input class="form-control" name="CompanyName" value="@Model.UpdateForm.CompanyName" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Firma türü</label>
                        <input class="form-control" name="CompanyType" value="@Model.UpdateForm.CompanyType" placeholder="Ltd. / A.Ş. / Şahıs..." />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Vergi dairesi</label>
                        <input class="form-control" name="TaxOffice" value="@Model.UpdateForm.TaxOffice" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Vergi numarası</label>
                        <input class="form-control" name="TaxNumber" value="@Model.UpdateForm.TaxNumber" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Yetkili ad soyad</label>
                        <input class="form-control" name="AuthorizedName" value="@Model.UpdateForm.AuthorizedName" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Yetkili e-posta</label>
                        <input class="form-control" type="email" name="AuthorizedEmail" value="@Model.UpdateForm.AuthorizedEmail" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Yetkili telefon</label>
                        <input class="form-control" name="AuthorizedPhone" value="@Model.UpdateForm.AuthorizedPhone" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Hesap sahibi</label>
                        <input class="form-control" name="AccountHolderName" value="@Model.UpdateForm.AccountHolderName" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Fatura adresi</label>
                        <textarea class="form-control" rows="3" name="BillingAddress">@Model.UpdateForm.BillingAddress</textarea>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">İl</label>
                        <input class="form-control" name="BillingCity" value="@Model.UpdateForm.BillingCity" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">İlçe</label>
                        <input class="form-control" name="BillingDistrict" value="@Model.UpdateForm.BillingDistrict" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Banka</label>
                        <input class="form-control" name="BankName" value="@Model.UpdateForm.BankName" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Şube</label>
                        <input class="form-control" name="BankBranch" value="@Model.UpdateForm.BankBranch" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">IBAN</label>
                        <input class="form-control" name="Iban" value="@Model.UpdateForm.Iban" placeholder="TR..." />
                    </div>

                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary" @(Model.PartnerSection is null ? "disabled" : string.Empty)>
                            <i class="fas fa-floppy-disk me-2"></i>Kaydet
                        </button>
                    </div>
                </form>
            </div>
            @if (Model.PartnerSection is not null)
            {
                <div class="card-footer">
                    <div class="small text-muted">Onay durumu: <span class="badge bg-azure-lt">@Model.PartnerSection.ApprovalStatus</span></div>
                </div>
            }
        </div>
    </div>
</div>
