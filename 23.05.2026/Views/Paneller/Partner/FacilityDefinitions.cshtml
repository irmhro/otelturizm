@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    var tables = ViewData["ModuleTables"] as string ?? string.Empty;
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Tesis yönetimi</div>
            <h2 class="page-title">Genel Tanımlar</h2>
            <div class="text-muted mt-1">Bu alandan tesis veri girişlerinin tamamlayıcı ekranlarına hızlıca erişin.</div>
        </div>
    </div>
</div>

<div class="row row-cards">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Hızlı bağlantılar</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/otel-bilgileri">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-pen-to-square text-primary"></i>
                                    <strong>Tesis Bilgileri</strong>
                                </div>
                                <div class="text-muted small mt-1">Kimlik, iletişim, içerik ve operasyon alanları.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/tesis/ozellikler">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-sparkles text-success"></i>
                                    <strong>Tesis Özellikleri</strong>
                                </div>
                                <div class="text-muted small mt-1">Filtrelerde görünen ikonlu özellikler.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/tesis/konum">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-location-dot text-warning"></i>
                                    <strong>Konum & Harita</strong>
                                </div>
                                <div class="text-muted small mt-1">Adres, enlem/boylam ve konum açıklaması.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/tesis/kosullar">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-file-contract text-info"></i>
                                    <strong>Otel Koşulları</strong>
                                </div>
                                <div class="text-muted small mt-1">İptal, ödeme ve tesis kuralları.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/oda-yonetimi">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-bed text-primary"></i>
                                    <strong>Oda Tipleri</strong>
                                </div>
                                <div class="text-muted small mt-1">Oda tipleri, stok, fiyat ve görseller.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/oda/ozellikler">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-list-check text-secondary"></i>
                                    <strong>Oda Özellikleri</strong>
                                </div>
                                <div class="text-muted small mt-1">Oda özellik listesi (aktif/pasif).</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/fotograflar">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-images text-indigo"></i>
                                    <strong>Fotoğraflar</strong>
                                </div>
                                <div class="text-muted small mt-1">Otel galeri, kapak ve medya yönetimi.</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a class="card card-link card-link-pop" href="/panel/partner/basvuru-ve-evraklar">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-file-arrow-up text-danger"></i>
                                    <strong>Evraklar</strong>
                                </div>
                                <div class="text-muted small mt-1">Başvuru ve doğrulama evrakları.</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">İlgili tablolar</h3>
            </div>
            <div class="card-body">
                <div class="text-muted small">@tables</div>
            </div>
        </div>
    </div>
</div>

