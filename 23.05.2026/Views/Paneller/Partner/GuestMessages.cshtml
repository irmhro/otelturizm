@model otelturizmnew.Models.Paneller.Partner.PartnerGuestMessagesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/reservations";
}

<div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
        <div class="col">
            <div class="page-pretitle">Rezervasyon yönetimi</div>
            <h2 class="page-title">Misafir Mesajları</h2>
            <div class="text-muted mt-1">Rezervasyon bazlı konuşmaları görüntüleyin, yanıtlayın ve okunmamışları yönetin.</div>
        </div>
    </div>
</div>

<div class="row row-cards">
    <div class="col-12 col-xl-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Konuşmalar</h3>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.Conversations.Count == 0)
                {
                    <div class="p-3 text-muted">Henüz konuşma yok.</div>
                }
                else
                {
                    @foreach (var c in Model.Conversations)
                    {
                        <a class="list-group-item list-group-item-action @(c.IsSelected ? "active" : "")"
                           href="/panel/partner/rezervasyonlar/misafir-mesajlari?otelId=@Model.SelectedHotelId&conversationId=@c.ConversationId">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="min-w-0">
                                    <div class="fw-bold text-truncate">@c.GuestName</div>
                                    <div class="text-muted small text-truncate">@c.Subject</div>
                                </div>
                                @if (c.UnreadCount > 0)
                                {
                                    <span class="badge bg-danger-lt text-danger">@c.UnreadCount</span>
                                }
                            </div>
                            <div class="text-muted small mt-1 text-truncate">@c.LastMessagePreview</div>
                            <div class="text-muted small mt-1">@c.LastMessageTimeText • <code>@c.ReservationNo</code></div>
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2">
                    <h3 class="card-title mb-0">Mesajlar</h3>
                    @if (Model.SelectedConversationId.HasValue)
                    {
                        <span class="badge bg-azure-lt text-azure">Konuşma #@Model.SelectedConversationId</span>
                    }
                </div>
                <div class="card-actions">
                    <a class="btn btn-outline-primary btn-sm" href="/panel/partner/rezervasyonlar">
                        <i class="fas fa-arrow-left me-1"></i>Rezervasyonlara dön
                    </a>
                </div>
            </div>
            <div class="card-body" style="min-height: 360px;">
                @if (!Model.SelectedConversationId.HasValue)
                {
                    <div class="text-muted">Soldan bir konuşma seçin.</div>
                }
                else if (Model.ConversationMessages.Count == 0)
                {
                    <div class="text-muted">Bu konuşmada henüz mesaj yok.</div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var m in Model.ConversationMessages)
                        {
                            <div class="d-flex @(m.IsFromHotel ? "justify-content-end" : "justify-content-start")">
                                <div class="p-3 rounded-3 border @(m.IsFromHotel ? "bg-azure-lt" : "bg-light")" style="max-width: 720px;">
                                    <div class="small fw-bold">@m.SenderLabel</div>
                                    <div class="mt-1" style="white-space:pre-wrap;">@m.Body</div>
                                    <div class="text-muted small mt-1">@m.TimeText</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="card-footer">
                @if (!Model.SelectedConversationId.HasValue)
                {
                    <div class="text-muted">Mesaj göndermek için bir konuşma seçin.</div>
                }
                else
                {
                    <form method="post" action="/panel/partner/rezervasyonlar/mesaj-gonder" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                        <input type="hidden" name="ReservationId" value="@Model.MessageForm.ReservationId" />
                        <input type="hidden" name="ConversationId" value="@Model.SelectedConversationId" />
                        <input type="hidden" name="ReturnUrl" value="@Model.MessageForm.ReturnUrl" />
                        <input type="text" name="Subject" class="form-control" placeholder="Konu (opsiyonel)" value="@Model.MessageForm.Subject" />
                        <input type="text" name="Message" class="form-control" placeholder="Mesajınızı yazın" required />
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>Gönder
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

