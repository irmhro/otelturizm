@model otelturizmnew.Models.Paneller.PartnerPlatformPackagesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/platform-packages";
    var tr = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
}

<section class="partner-platform-packages">
    <div class="partner-row-between partner-platform-packages__hero">
        <div>
            <div class="page-pretitle">Pazarlama & Uyumluluk</div>
            <h2 class="page-title">Platform Paketleri</h2>
            <p class="partner-muted">5651 internet loglama ve 5661 konaklama loglama paketlerini otellerinize sunun. 5661 kurulu tesislerde ilgili paketler gizlenir.</p>
        </div>
        <div class="partner-chip ot-badge ot-badge--info">
            Otel: <strong>@Model.SelectedHotelName</strong>
            @if (Model.HotelHas5661Installed)
            {
                <span class="ms-1 ot-badge ot-badge--success">5661 kayıtlı</span>
            }
        </div>
    </div>

    @if (!Model.TablesReady)
    {
        <div class="partner-alert is-warning">Paket tabloları henüz uygulanmadı. <code>20260525_platform_paket_satis</code> migration çalıştırılmalı.</div>
    }

    @if (TempData["PartnerError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="partner-alert is-danger">@err</div>
    }
    @if (TempData["PartnerSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="partner-alert is-success">@ok</div>
    }

    <div class="partner-platform-packages__filters">
        <a class="ot-btn ot-btn--sm @(string.IsNullOrEmpty(Model.CategoryFilter) ? "ot-btn--primary" : "ot-btn--ghost")" href="@Url.Action("PlatformPackages", new { otelId = Model.SelectedHotelId })">Tümü</a>
        <a class="ot-btn ot-btn--sm @(Model.CategoryFilter == "5651" ? "ot-btn--primary" : "ot-btn--ghost")" href="@Url.Action("PlatformPackages", new { otelId = Model.SelectedHotelId, kategori = "5651" })">5651</a>
        <a class="ot-btn ot-btn--sm @(Model.CategoryFilter == "5661" ? "ot-btn--primary" : "ot-btn--ghost")" href="@Url.Action("PlatformPackages", new { otelId = Model.SelectedHotelId, kategori = "5661" })">5661</a>
        <a class="ot-btn ot-btn--sm @(Model.CategoryFilter == "PAKET" ? "ot-btn--primary" : "ot-btn--ghost")" href="@Url.Action("PlatformPackages", new { otelId = Model.SelectedHotelId, kategori = "PAKET" })">Paket</a>
    </div>

    <div class="partner-platform-packages__grid">
        @foreach (var pkg in Model.Packages)
        {
            <article class="partner-platform-package-card ot-card">
                <div class="partner-platform-package-card__media">
                    @if (!string.IsNullOrWhiteSpace(pkg.CoverImageUrl))
                    {
                        <img src="@pkg.CoverImageUrl" alt="@pkg.Title" loading="lazy" />
                    }
                    <span class="partner-platform-package-card__badge">@pkg.CategoryTitle</span>
                </div>
                <div class="partner-platform-package-card__body">
                    <h3>@pkg.Title</h3>
                    <p>@pkg.ShortDescription</p>
                    <div class="partner-platform-package-card__meta">
                        <strong>@pkg.PriceText</strong>
                        <small>@pkg.TargetRuleBadge</small>
                    </div>
                    <a class="partner-primary-btn ot-btn ot-btn--primary ot-btn--block" href="/panel/partner/platform-paketleri/detay/@pkg.Id?otelId=@Model.SelectedHotelId">
                        Detay & Başvuru
                    </a>
                </div>
            </article>
        }
        @if (Model.Packages.Count == 0 && Model.TablesReady)
        {
            <div class="partner-empty partner-form-span">Bu otel için uygun paket bulunamadı (5661 kuralı veya filtre).</div>
        }
    </div>

    <div class="partner-table-card ot-card partner-platform-packages__apps">
        <div class="partner-table-head">
            <h3>Başvurularım</h3>
        </div>
        @if (Model.Applications.Count == 0)
        {
            <div class="partner-empty p-3">Henüz paket başvurunuz yok.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-vcenter">
                    <thead>
                        <tr><th>Paket</th><th>Durum</th><th>Tutar</th><th>Tarih</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Applications)
                        {
                            <tr>
                                <td>@row.PackageTitle</td>
                                <td><span class="ot-badge">@row.Status</span></td>
                                <td>@row.PriceText</td>
                                <td>@row.CreatedText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
