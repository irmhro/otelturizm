@model otelturizmnew.Models.Paneller.Partner.PartnerRoomFeaturesPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/room-features";
    var selectedRoom = Model.SelectedRoom;
    var selectedSet = Model.SelectedFeatureIds.ToHashSet();
    var selectedRoomId = Model.SelectedRoomId ?? 0;
}

<div class="room-features-page">
    <div class="room-features-hero">
        <div>
            <div class="page-pretitle">Tesis yönetimi</div>
            <h2 class="page-title">Oda Özellikleri</h2>
            <p>Önce oda tipini seçin, ardından kategoriler altındaki özellikleri yatay seçenekler olarak işaretleyin.</p>
        </div>
        <a class="btn btn-outline-primary" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId">
            <i class="fas fa-bed me-2"></i>Oda yönetimi
        </a>
    </div>

    <div class="room-feature-stats">
        <div class="room-feature-stat">
            <span>Oda tipi</span>
            <strong>@Model.Rooms.Count</strong>
        </div>
        <div class="room-feature-stat">
            <span>Kategori</span>
            <strong>@Model.CategoryCount</strong>
        </div>
        <div class="room-feature-stat">
            <span>Seçili özellik</span>
            <strong>@Model.SelectedFeatureCount</strong>
        </div>
    </div>

    @if (Model.Rooms.Count == 0)
    {
        <div class="card empty-room-feature-card">
            <div class="card-body">
                <i class="fas fa-bed"></i>
                <h3>Henüz oda tipi bulunmuyor</h3>
                <p>Özellik seçimi yapabilmek için önce oda tipinizi oluşturun.</p>
                <a class="btn btn-primary" href="/panel/partner/oda-yonetimi?otelId=@Model.SelectedHotelId">Oda tipi oluştur</a>
            </div>
        </div>
    }
    else
    {
        <div class="card room-picker-card">
            <div class="card-header">
                <div>
                    <h3 class="card-title mb-0">Oda seçimi</h3>
                    <div class="text-muted small">Her oda tipi kendi özellik listesiyle ayrı kaydedilir.</div>
                </div>
            </div>
            <div class="card-body">
                <div class="room-choice-grid">
                    @foreach (var room in Model.Rooms)
                    {
                        var isSelected = room.RoomId == selectedRoomId;
                        <a class="room-choice-card @(isSelected ? "is-selected" : string.Empty) @(room.IsActive ? string.Empty : "is-passive")"
                           href="/panel/partner/oda/ozellikler?otelId=@Model.SelectedHotelId&roomId=@room.RoomId">
                            <span class="room-choice-status">@(room.IsActive ? "Satışta" : "Pasif")</span>
                            <strong>@room.RoomName</strong>
                            <small>@room.Category · @room.CapacityText</small>
                            <span class="room-choice-meta">
                                <span><i class="fas fa-door-open"></i>@room.StockText</span>
                                <span><i class="fas fa-tag"></i>@room.PriceText</span>
                            </span>
                            <span class="room-choice-count">@room.SelectedFeatureCount özellik</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <form method="post" action="/panel/partner/oda/ozellikler/kaydet" class="card room-feature-editor">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
            <input type="hidden" name="RoomId" value="@selectedRoomId" />

            <div class="card-header room-feature-editor-head">
                <div>
                    <h3 class="card-title mb-0">@(selectedRoom?.RoomName ?? "Oda") özellikleri</h3>
                    <div class="text-muted small">Seçimler kaydedildiğinde otel detayında bu oda için doğrulanmış özellik olarak görünür.</div>
                </div>
                <button type="submit" class="btn btn-primary" @(selectedRoomId <= 0 ? "disabled" : null)>
                    <i class="fas fa-check me-2"></i>Özellikleri Kaydet
                </button>
            </div>

            <div class="card-body">
                @if (Model.Features.Count == 0)
                {
                    <div class="feature-empty-state">
                        <i class="fas fa-list-check"></i>
                        <strong>Oda özellik sözlüğü boş</strong>
                        <span>Özellik sözlüğü admin kurulum verileriyle doldurulmalıdır.</span>
                    </div>
                }
                else
                {
                    <div class="feature-category-list">
                        @foreach (var group in Model.Features
                                     .OrderBy(x => x.Category)
                                     .ThenBy(x => x.Order)
                                     .ThenBy(x => x.Name)
                                     .GroupBy(x => x.Category))
                        {
                            var activeCount = group.Count(x => x.IsActive);
                            var selectedCount = group.Count(x => selectedSet.Contains(x.FeatureId));
                            <section class="feature-category-card">
                                <div class="feature-category-head">
                                    <div>
                                        <h4>@group.Key</h4>
                                        <p>@selectedCount seçili · @activeCount aktif seçenek</p>
                                    </div>
                                    <span>@group.Count() seçenek</span>
                                </div>
                                <div class="feature-option-wrap">
                                    @foreach (var feature in group)
                                    {
                                        var inputId = $"room-feature-{feature.FeatureId}";
                                        var isChecked = selectedSet.Contains(feature.FeatureId);
                                        <input class="feature-option-input"
                                               type="checkbox"
                                               id="@inputId"
                                               name="SelectedFeatureIds"
                                               value="@feature.FeatureId"
                                               checked="@(isChecked ? "checked" : null)"
                                               disabled="@(!feature.IsActive ? "disabled" : null)" />
                                        <label class="feature-option @(feature.IsActive ? string.Empty : "is-disabled")" for="@inputId">
                                            @if (!string.IsNullOrWhiteSpace(feature.IconClass))
                                            {
                                                <i class="fas @feature.IconClass"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-check"></i>
                                            }
                                            <span>@feature.Name</span>
                                        </label>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                }
            </div>
        </form>
    }
</div>
