@model otelturizmnew.Models.Paneller.Partner.PartnerCampaignsPageViewModel
@{
    Layout = "~/Views/Paneller/Partner/_PartnerPanelLayout.cshtml";
    ViewData["PartnerShell"] = Model.Shell;
    ViewData["PageCssPath"] = "paneller/partner/campaigns";

    var activeJoinedIds = Model.JoinedCampaigns
        .Where(item => string.Equals(item.StatusText, "Aktif", StringComparison.OrdinalIgnoreCase))
        .Select(item => item.CampaignId)
        .ToHashSet();
}

<section class="partner-campaigns-hero">
    <div>
        <p class="partner-room-kicker">Kampanya yönetimi</p>
        <h2>Kampanyaları tablo üzerinden yönetin</h2>
        <p>Katılıma açık kampanyaları görseli, detayı, tarih aralığı ve katılım aksiyonu ile tek listede izleyin. Katıldığınız kampanya, bitiş tarihine kadar kampanya oteller kaydında aktif kalır.</p>
    </div>
    <a class="partner-secondary-btn" href="/kampanyalar" target="_blank" rel="noopener">
        <i class="fas fa-arrow-up-right-from-square"></i>
        Public kampanyalar
    </a>
</section>

<section class="partner-grid partner-pricing-summary-grid">
    @foreach (var item in Model.SummaryCards)
    {
        <article class="partner-stat-card partner-pricing-stat @item.ToneClass">
            <i class="fas @item.IconClass"></i>
            <strong>@item.Value</strong>
            <span>@item.Label</span>
            <p>@item.Description</p>
        </article>
    }
</section>

<section class="partner-section-card partner-campaigns-card">
    <div class="partner-section-head">
        <div>
            <h2>Katılıma açık kampanyalar</h2>
            <p>Satırdaki formu kullanarak seçili oteli ilgili kampanyaya dahil edin. Tarih girilmezse kampanyanın kendi tarihleri kullanılır.</p>
        </div>
    </div>

    @if (Model.AvailableCampaigns.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Şu an katılıma açık kampanya görünmüyor.</strong>
            <p>Yeni kampanyalar admin tarafından yayınlandığında burada otomatik listelenecek.</p>
        </div>
    }
    else
    {
        <div class="partner-table-wrap partner-campaign-table-wrap">
            <table class="partner-table partner-campaign-table">
                <thead>
                    <tr>
                        <th>Kampanya</th>
                        <th>Görsel</th>
                        <th>Tarih ve detay</th>
                        <th>İndirim</th>
                        <th>Katılım</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var campaign in Model.AvailableCampaigns)
                    {
                        var isJoined = activeJoinedIds.Contains(campaign.CampaignId);
                        <tr class="@(isJoined ? "is-joined" : null)">
                            <td class="partner-campaign-title-cell">
                                <strong>@campaign.CampaignName</strong>
                                <span>@campaign.CampaignCode</span>
                                <div class="partner-campaign-tags">
                                    @if (!string.IsNullOrWhiteSpace(campaign.PromoBadge))
                                    {
                                        <em>@campaign.PromoBadge</em>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(campaign.BadgeText))
                                    {
                                        <em>@campaign.BadgeText</em>
                                    }
                                    @if (isJoined)
                                    {
                                        <em class="joined">Katıldınız</em>
                                    }
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(campaign.ImageUrl))
                                {
                                    <img class="partner-campaign-thumb" src="@campaign.ImageUrl" alt="@campaign.CampaignName" loading="lazy" />
                                }
                                else
                                {
                                    <div class="partner-campaign-thumb fallback">
                                        <i class="fas fa-bullhorn"></i>
                                    </div>
                                }
                            </td>
                            <td class="partner-campaign-detail-cell">
                                <strong>@campaign.DateText</strong>
                                <details>
                                    <summary>Detayı gör</summary>
                                    @if (!string.IsNullOrWhiteSpace(campaign.Description))
                                    {
                                        <p>@campaign.Description</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(campaign.TermsText))
                                    {
                                        <p>@campaign.TermsText</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(campaign.DetailUrl))
                                    {
                                        <a href="@campaign.DetailUrl" target="_blank" rel="noopener">Kampanya sayfasını aç</a>
                                    }
                                </details>
                            </td>
                            <td>
                                <span class="partner-campaign-discount" style="--campaign-accent:@campaign.ColorCode">@campaign.DiscountText</span>
                                <small>@campaign.CampaignType</small>
                            </td>
                            <td class="partner-campaign-action-cell">
                                <form method="post" action="/panel/partner/kampanyalar/katil" class="partner-campaign-row-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="HotelId" value="@Model.SelectedHotelId" />
                                    <input type="hidden" name="CampaignId" value="@campaign.CampaignId" />
                                    <input type="hidden" name="CampaignLabel" value="@campaign.CampaignName" />
                                    <input type="hidden" name="SortOrder" value="@Model.JoinForm.SortOrder" />
                                    <div class="partner-campaign-mini-fields">
                                        <input type="date" name="StartDate" aria-label="Katılım başlangıcı" />
                                        <input type="date" name="EndDate" aria-label="Katılım bitişi" />
                                    </div>
                                    <textarea name="PartnerNote" maxlength="4000" placeholder="Kısa partner notu"></textarea>
                                    <button type="submit" class="partner-primary-btn" disabled="@isJoined">
                                        <i class="fas @(isJoined ? "fa-check" : "fa-plus")"></i>
                                        @(isJoined ? "Aktif Katılım" : "Kampanyaya Katıl")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="partner-section-card partner-campaigns-card">
    <div class="partner-section-head">
        <div>
            <h2>Katıldığınız kampanyalar</h2>
            <p>Bu otelin kampanya oteller tablosundaki aktif, pasif ve geçmiş kayıtları.</p>
        </div>
    </div>

    @if (Model.JoinedCampaigns.Count == 0)
    {
        <div class="partner-empty-state">
            <strong>Bu otele ait kampanya katılımı yok.</strong>
            <p>Yukarıdaki listeden ilk kampanyaya katılabilirsiniz.</p>
        </div>
    }
    else
    {
        <div class="partner-table-wrap">
            <table class="partner-table partner-joined-campaign-table">
                <thead>
                    <tr>
                        <th>Kampanya</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th>Etiket</th>
                        <th>İndirim</th>
                        <th>Not</th>
                        <th>Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.JoinedCampaigns)
                    {
                        var isActive = string.Equals(item.StatusText, "Aktif", StringComparison.OrdinalIgnoreCase);
                        <tr class="@(isActive ? "is-active" : "is-passive")">
                            <td>
                                <strong>@item.CampaignName</strong>
                                <div class="partner-table-note">@item.CampaignCode</div>
                            </td>
                            <td>
                                <span class="partner-campaign-status @(isActive ? "is-active" : "is-passive")">@item.StatusText</span>
                                @if (item.IsFeatured)
                                {
                                    <span class="partner-campaign-status is-featured">Öne çıkan</span>
                                }
                            </td>
                            <td>@item.DateText</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CampaignLabel) ? "-" : item.CampaignLabel)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.DiscountText) ? "-" : item.DiscountText)</td>
                            <td class="partner-muted">@(!string.IsNullOrWhiteSpace(item.PartnerNote) ? item.PartnerNote : "-")</td>
                            <td class="text-end">
                                @if (isActive)
                                {
                                    <form method="post" action="/panel/partner/kampanyalar/ayril" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="hotelId" value="@Model.SelectedHotelId" />
                                        <input type="hidden" name="campaignId" value="@item.CampaignId" />
                                        <button type="submit" class="partner-secondary-btn danger">
                                            <i class="fas fa-xmark"></i>
                                            Kampanyadan Çık
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="partner-muted">Kapalı kayıt</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
