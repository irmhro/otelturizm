@model otelturizmnew.Models.Kampanyalar.CampaignListingPageViewModel

@{
    ViewData["Title"] = "Kampanyalar";
    ViewData["PageCss"] = "kampanyalar";
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.PageDescription)
        ? "Otelturizm kampanyalarını keşfedin. Sezon fırsatları ve özel indirimleri görüntüleyin."
        : Model.PageDescription;
    var baseUrl = (Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration)?["App:PublicBaseUrl"]?.TrimEnd('/')
                  ?? "https://otelturizm.com";
    ViewData["Canonical"] = $"{baseUrl}/kampanyalar";
    try
    {
        var breadcrumbJsonLd = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new object[]
            {
                new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Kampanyalar", ["item"] = $"{baseUrl}/kampanyalar" }
            }
        };
        ViewData["JsonLd"] = System.Text.Json.JsonSerializer.Serialize(breadcrumbJsonLd);
    }
    catch { }
}

<section class="campaign-index-grid">
    @if (Model.Campaigns.Count == 0)
    {
        <div class="campaign-empty-state">
            <strong>Şu an yayında aktif kampanya görünmüyor.</strong>
            <p>Kampanya başlangıç ve bitiş tarihleri aktif olduğunda bu ekran otomatik dolacaktır.</p>
        </div>
    }
    else
    {
        @foreach (var campaign in Model.Campaigns)
        {
            var listingUrl = $"/oteller?kampanya={Uri.EscapeDataString(campaign.Slug ?? string.Empty)}";
            <article class="campaign-card" style="--campaign-accent:@campaign.ColorCode;">
                <a class="campaign-card__tap" href="@listingUrl" aria-label="@campaign.CampaignName kampanyasına katılan otelleri listele">
                    <div class="campaign-card__media @(string.IsNullOrWhiteSpace(campaign.HeroImageUrl) ? string.Empty : "has-image")">
                        @if (!string.IsNullOrWhiteSpace(campaign.HeroImageUrl))
                        {
                            <img src="@campaign.HeroImageUrl" alt="@campaign.CampaignName" loading="lazy" decoding="async" />
                        }
                        @if (!string.IsNullOrWhiteSpace(campaign.BadgeText))
                        {
                            <span class="campaign-card__badge">@campaign.BadgeText</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(campaign.PromoBadge))
                        {
                            <span class="campaign-card__promo">@campaign.PromoBadge</span>
                        }
                    </div>
                    <div class="campaign-card__body">
                        <h2>@campaign.CampaignName</h2>
                        <p>@campaign.ShortDescription</p>
                        <div class="campaign-card__meta">
                            <span><i class="fas fa-tag"></i> @campaign.CampaignType</span>
                        </div>
                        <span class="campaign-card__date"><i class="fas fa-calendar-check"></i> @campaign.EndDateText</span>
                        <span class="campaign-card__link">Otelleri Listele</span>
                    </div>
                </a>
                <div class="campaign-card__footer">
                    <a class="campaign-card__secondary" href="@campaign.Url" aria-label="@campaign.CampaignName kampanya detayını aç">
                        Kampanya detayı <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </article>
        }
    }
</section>
