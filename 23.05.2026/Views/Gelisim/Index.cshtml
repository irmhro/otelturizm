@model otelturizmnew.Models.Gelisim.DevelopmentPageViewModel

<section class="gelisim-shell">
    <div class="container gelisim-container">
        @if (!Model.IsUnlocked)
        {
            <div class="gelisim-lock-card">
                <span class="gelisim-kicker">Gelişim Takibi</span>
                <h1>Şifre korumalı alan</h1>
                <p>`Dokumanlar/Arsiv/ilk-200-gelistirme-plani.md` içeriği bu sayfada otomatik gösterilir. Erişim için ekranda yetkili kodunu yazın.</p>

                @if (!string.IsNullOrWhiteSpace(Model.PasswordError))
                {
                    <div class="gelisim-error">@Model.PasswordError</div>
                }

                <div class="gelisim-hint-card">
                    <strong>Erişim yolu</strong>
                    <span>Bu ekranda veya ana ön yüzde doğrudan erişim kodunu yazın. Form alanı kullanılmaz.</span>
                </div>
            </div>
        }
        else
        {
            <div class="gelisim-header-card">
                <div>
                    <span class="gelisim-kicker">Gelişim Takibi</span>
                    <h1>İlk 200 geliştirme planı</h1>
                    <p>`Dokumanlar/Arsiv/ilk-200-gelistirme-plani.md` dosyası canlı içerikten otomatik okunuyor.</p>
                </div>

                <div class="gelisim-header-actions">
                    @if (Model.AccessExpiresAt.HasValue)
                    {
                        <div class="gelisim-meta">
                            <span>Erişim geçerli</span>
                            <strong>@Model.AccessExpiresAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    }

                    <button type="button" class="gelisim-ghost-button" id="gelisimLockButton">Çıkış</button>
                </div>
            </div>

            <article class="gelisim-content-card prose-content">
                @Html.Raw(Model.RenderedHtml)
            </article>
        }
    </div>
</section>

@section Scripts {
    <script nonce="@(Context.Items["CspNonce"] as string)">
        (function () {
            var lockButton = document.getElementById('gelisimLockButton');
            if (!lockButton) {
                return;
            }

            lockButton.addEventListener('click', async function () {
                await fetch('/gelisim/kilidi-kapat', {
                    method: 'POST',
                    credentials: 'same-origin'
                });

                window.location.reload();
            });
        })();
    </script>
}
